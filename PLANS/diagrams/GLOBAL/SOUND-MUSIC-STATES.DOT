digraph SOUND_MUSIC {
    label="SOUND & MUSIC STATE MACHINE" labelloc=t labeljust=c
    ordering=out rankdir=TB
    fontcolor=white fontsize=24.0 fontname="Cascadia Code PL"
    splines=true compound=true
    bgcolor=transparent
    edge [color=gray fontcolor="#aaaaaa" fontsize=9.0 fontname="Cascadia Code PL"];
    node [color=white shape=rect style="" fontname="Cascadia Code PL" fontsize=11.0 fontcolor=cyan];

    { node [shape=folder color=orange penwidth=2 fontcolor=orange fontsize=13.0];
        SFX_F [label="SFX (ONE-SHOT)"];
        MUSIC_F [label="MUSIC (PLAYLIST)"];
    }

    subgraph cluster_sfx {
        label="SFX — SOUND_play()" labelloc=t labeljust=l
        fontcolor=orange fontsize=11.0 color=orange style=dashed penwidth=1

        SFX_IDLE [label="1 · IDLE\n─────────────────\nNo sample loaded\nSOUND.* table populated\nat init"];
        SFX_LOAD [label="2 · LOADED\n─────────────────\n_SNDOPEN handles\ncached per-sample\nReady for playback"];
        SFX_PLAY [label="3 · PLAYING\n─────────────────\n_SNDPLAYCOPY fired\nNon-blocking, layered\nVolume = SFX volume"];
        SFX_DISABLED [label="4 · DISABLED\n─────────────────\nCFG.SFX_VOLUME = 0\nor mute toggled\nNo playback occurs"];

        SFX_IDLE -> SFX_LOAD [label="  SOUND_init at startup" color="#66cc66"];
        SFX_LOAD -> SFX_PLAY [label="  Trigger event\n  (click, palette change,\n  brush draw)" color="#66cc66"];
        SFX_PLAY -> SFX_LOAD [label="  Sample completes\n  (auto)" color="#cc6666" style=dashed];
        SFX_LOAD -> SFX_DISABLED [label="  Volume → 0" color="#cc6666" style=dashed];
        SFX_DISABLED -> SFX_LOAD [label="  Volume restored" color="#66cc66"];
    }

    subgraph cluster_music {
        label="MUSIC — MUSIC_tick()" labelloc=t labeljust=l
        fontcolor=orange fontsize=11.0 color=orange style=dashed penwidth=1

        M_OFF [label="1 · OFF\n─────────────────\nNo track playing\nUser disabled music\nor playlist empty"];
        M_PLAYING [label="2 · PLAYING\n─────────────────\nCurrent track loaded\n_SNDPLAY active\nMUSIC_tick monitors"];
        M_PAUSED [label="3 · PAUSED\n─────────────────\nUser pressed pause\n_SNDPAUSE state\nResume on toggle"];
        M_NEXT [label="4 · ADVANCING\n─────────────────\nCurrent track ended\nMUSIC_tick detects\nFree handle, load next\nShuffle or sequential"];

        M_OFF -> M_PLAYING [label="  Music toggled on\n  Playlist available" color="#66cc66"];
        M_PLAYING -> M_PAUSED [label="  Pause action" color="#cccc66"];
        M_PAUSED -> M_PLAYING [label="  Resume action" color="#66cc66"];
        M_PLAYING -> M_NEXT [label="  Track finished\n  _SNDPLAYING returns 0" color="#cccc66"];
        M_NEXT -> M_PLAYING [label="  Next track loaded" color="#66cc66"];
        M_NEXT -> M_OFF [label="  Playlist empty" color="#cc6666" style=dashed];
        M_PLAYING -> M_OFF [label="  Music toggled off" color="#cc6666" style=dashed];
    }

    subgraph cluster_loop {
        label="MAIN-LOOP INTEGRATION" labelloc=t labeljust=l
        fontcolor=orange fontsize=11.0 color=orange style=dashed penwidth=1

        ML1 [label="MUSIC_tick\n────────────\nCalled in DRAW.BAS\nstep 5 every frame\nAuto-shuffle to next\nwhen track ends" fontsize=10.0];
        ML2 [label="SFX trigger\n────────────\nFired from event sites\n(GUI clicks, paint,\nundo, save)" fontsize=10.0];
    }

    SFX_F -> SFX_IDLE [arrowhead=none color="#555555" style=dotted lhead=cluster_sfx];
    MUSIC_F -> M_OFF [arrowhead=none color="#555555" style=dotted lhead=cluster_music];
    { rank=min; SFX_F; MUSIC_F }

    subgraph cluster_legend {
        label="LEGEND" labelloc=t labeljust=l
        fontcolor=white fontsize=11.0 color=white style=dashed penwidth=1
        L1 [label="" shape=point width=0.01]; L2 [label="" shape=point width=0.01];
        L3 [label="" shape=point width=0.01]; L4 [label="" shape=point width=0.01];
        L5 [label="" shape=point width=0.01]; L6 [label="" shape=point width=0.01];
        L1 -> L2 [label=" Activate" arrowhead=normal color="#66cc66" fontsize=9.0];
        L3 -> L4 [label=" Stop / Disable" arrowhead=normal color="#cc6666" style=dashed fontsize=9.0];
        L5 -> L6 [label=" Transition" arrowhead=normal color="#cccc66" fontsize=9.0];
    }
}
