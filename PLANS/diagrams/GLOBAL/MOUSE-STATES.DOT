digraph MOUSE_OPERATION {
    label="MOUSE OPERATION STATE MACHINE" labelloc=t labeljust=c
    ordering=out rankdir=TB
    fontcolor=white fontsize=24.0 fontname="Cascadia Code PL"
    splines=true compound=true
    bgcolor=transparent
    edge [
        color=gray fontcolor="#aaaaaa" fontsize=9.0
        fontname="Cascadia Code PL"
    ];
    node [
        color=white shape=rect style=""
        fontname="Cascadia Code PL" fontsize=11.0 fontcolor=cyan
    ];

    // ─────────────────────────────────────────────────────
    //  CATEGORY FOLDERS
    // ─────────────────────────────────────────────────────

    { node [shape=folder color=orange penwidth=2 fontcolor=orange fontsize=13.0];
        MAIN_STATES  [label="MAIN STATES"];
        GESTURES     [label="GESTURES"];
        GUARDS       [label="GUARD LOGIC"];
        DEFERRED     [label="DEFERRED ACTIONS"];
    }

    // ─────────────────────────────────────────────────────
    //  MAIN STATES
    // ─────────────────────────────────────────────────────

    M_IDLE [label="1 · IDLE\n─────────────────\nB1=0, B2=0, B3=0\nDRAG = \"\"\nNo buttons pressed\nMOUSE_process_frame%()"];
    M_PRESS [label="2 · BUTTON PRESS\n─────────────────\nB1 AND NOT OLD_B1\nTransition detected\nCheck UI_CHROME_CLICKED%\nRoute: GUI or Tool"];
    M_HOLD [label="3 · DRAGGING / HOLD\n─────────────────\nB1% = TRUE (ongoing)\nMOUSE_dispatch_tool_hold()\nContinuous brush stroke\nPreview rendering active"];
    M_RELEASE [label="4 · BUTTON RELEASE\n─────────────────\nNOT B1% AND OLD_B1%\nMOUSE_dispatch_tool_release()\nCommit stroke to HISTORY\nReset tool state"];
    M_UI_CONSUMED [label="5 · UI CONSUMED\n─────────────────\nUI_CHROME_CLICKED% = TRUE\nTool actions blocked\nGUI owns this click cycle\nWait for all buttons up"];
    M_SUPPRESS [label="6 · SUPPRESSED\n─────────────────\nSUPPRESS_FRAMES% > 0\nPost-dialog drain\nIgnore all input\nDecrement each frame"];

    // ─────────────────────────────────────────────────────
    //  MAIN TRANSITIONS
    // ─────────────────────────────────────────────────────

    M_IDLE -> M_PRESS [
        label="  B1 AND NOT OLD_B1\n  (button down transition)"
        color="#66cc66"
    ];
    M_PRESS -> M_HOLD [
        label="  Tool dispatch\n  MOUSE_dispatch_tool_hold()\n  NOT UI_CHROME_CLICKED%"
        color="#66cc66"
    ];
    M_PRESS -> M_UI_CONSUMED [
        label="  GUI element clicked\n  MOUSE_handle_gui_early%() = TRUE\n  UI_CHROME_CLICKED% = TRUE"
        color="#cccc66"
    ];
    M_HOLD -> M_HOLD [
        label="  B1% still held\n  Continuous stroke\n  Interpolate brush positions"
        color="#88aacc"
    ];
    M_HOLD -> M_RELEASE [
        label="  NOT B1% AND OLD_B1%\n  Button released"
        color="#cc6666"
    ];
    M_RELEASE -> M_IDLE [
        label="  Tool release complete\n  HISTORY recorded\n  Reset drag state"
        color="#cc6666" style=dashed
    ];
    M_UI_CONSUMED -> M_IDLE [
        label="  All buttons released\n  MOUSE_should_skip_tool_actions%()\n  Resets UI_CHROME_CLICKED% = FALSE"
        color="#cc6666" style=dashed
    ];
    M_IDLE -> M_SUPPRESS [
        label="  Native dialog returned\n  MOUSE_cleanup_after_dialog\n  SUPPRESS_FRAMES% = 2"
        color="#cc66cc"
    ];
    M_SUPPRESS -> M_IDLE [
        label="  SUPPRESS_FRAMES% = 0\n  Drain complete"
        color="#cc66cc" style=dashed
    ];

    // ─────────────────────────────────────────────────────
    //  GESTURE SUB-STATES
    // ─────────────────────────────────────────────────────

    subgraph cluster_gestures {
        label="GESTURES" labelloc=t labeljust=l
        fontcolor=orange fontsize=11.0 fontname="Cascadia Code PL"
        color=orange style=dashed penwidth=1

        G_CLICK [label="Single Click\n────────────\nB1 press + release\nNo significant drag\nUsed by: dot, fill,\npicker, palette click"
                 fontsize=10.0];
        G_DBLCLICK [label="Double Click\n────────────\nTwo B1 clicks within\nB1_CLICK_TIME threshold\nUsed by: text re-edit,\nlayer rename"
                    fontsize=10.0];
        G_DRAG [label="Left Drag\n────────────\nB1 held + movement\nDRAG = tool mode string\nUsed by: brush, line,\nrect, ellipse, marquee"
                fontsize=10.0];
        G_RIGHT [label="Right Click\n────────────\nB2 press\nMOUSE_handle_right_click()\nContext menus, BG color"
                 fontsize=10.0];
        G_MIDDLE [label="Middle Click / Drag\n────────────\nB3 press or hold\nPan canvas (assistant)\nSPACE + B1 equivalent"
                  fontsize=10.0];
        G_WHEEL [label="Scroll Wheel\n────────────\nMOUSE.SW% ≠ 0\nZoom in/out (canvas)\nScroll lists (panels)\nMOUSE.OSW → history"
                 fontsize=10.0];
        G_SWIPE [label="Visibility Swipe\n────────────\nB1 drag over eye icons\nLAYER_PANEL visibility\nvisSwiping% = TRUE"
                 fontsize=10.0];

        G_CLICK -> G_DBLCLICK [
            label=" Second click\n within threshold"
            color="#88aacc" fontsize=8.0
        ];
        G_CLICK -> G_DRAG [
            label=" B1 held +\n movement"
            color="#88aacc" fontsize=8.0
        ];
    }

    // ─────────────────────────────────────────────────────
    //  GUARD LOGIC
    // ─────────────────────────────────────────────────────

    subgraph cluster_guards {
        label="GUARD LOGIC — MOUSE_should_skip_tool_actions%()" labelloc=t labeljust=l
        fontcolor=orange fontsize=11.0 fontname="Cascadia Code PL"
        color=orange style=dashed penwidth=1

        GD_CHECK [label="Check UI_CHROME_CLICKED%\n────────────\nIF TRUE → consume OLD_B*\ntransitions, skip tool\ndispatch entirely"
                  fontsize=10.0];
        GD_MODAL [label="Modal Override Check\n────────────\nIMG_IMPORT.STATE > IDLE?\nTRANSFORM.ACTIVE?\nFILL_ADJ.ACTIVE%?\nSCRN.panning%?\nREFIMG.REPOSITION?"
                  fontsize=10.0];
        GD_PASS [label="Tool Dispatch Allowed\n────────────\nAll guards pass\nProceed to tool handler\nfor CURRENT_TOOL%"
                 fontsize=10.0];

        GD_CHECK -> GD_MODAL [
            label=" UI_CHROME_CLICKED% = FALSE"
            color="#66cc66" fontsize=8.0
        ];
        GD_CHECK -> M_UI_CONSUMED [
            label=" UI_CHROME_CLICKED% = TRUE"
            color="#cc6666" fontsize=8.0 style=dashed
            ltail=cluster_guards
        ];
        GD_MODAL -> GD_PASS [
            label=" No modal active"
            color="#66cc66" fontsize=8.0
        ];
    }

    // ─────────────────────────────────────────────────────
    //  DEFERRED ACTIONS (post-render)
    // ─────────────────────────────────────────────────────

    subgraph cluster_deferred {
        label="DEFERRED ACTIONS — MOUSE_input_handler_loop()" labelloc=t labeljust=l
        fontcolor=orange fontsize=11.0 fontname="Cascadia Code PL"
        color=orange style=dashed penwidth=1

        DA_NONE [label="No Deferred Action\n────────────\nDEFERRED_ACTION% = 0"
                 fontsize=10.0];
        DA_SAVE [label="1 · Save\n────────────\n_SAVEFILEDIALOG$()\nDRW or BMP export"
                 fontsize=10.0];
        DA_IMPORT [label="2 · Import Image\n────────────\n_OPENFILEDIALOG$()\nIMAGE_IMPORT_start"
                   fontsize=10.0];
        DA_OPEN [label="3 · Open DRW\n────────────\n_OPENFILEDIALOG$()\nDRW_load_binary"
                 fontsize=10.0];
        DA_EXPORT [label="4 · Export\n────────────\nBMP/BSAVE/BAS\nexport pipeline"
                   fontsize=10.0];
        DA_DRAWER [label="5 · Drawer Import\n────────────\nImport .dset file\nDRAWER_IMPORT_dset"
                   fontsize=10.0];

        DA_NONE -> DA_SAVE [label=" Menu/hotkey\n triggers save" color="#88aacc" fontsize=8.0];
        DA_NONE -> DA_IMPORT [label=" Menu/hotkey\n triggers import" color="#88aacc" fontsize=8.0];
        DA_NONE -> DA_OPEN [label=" Menu/hotkey\n triggers open" color="#88aacc" fontsize=8.0];
        DA_NONE -> DA_EXPORT [label=" Menu/hotkey\n triggers export" color="#88aacc" fontsize=8.0];
        DA_NONE -> DA_DRAWER [label=" Drawer btn\n triggers import" color="#88aacc" fontsize=8.0];
        DA_SAVE -> DA_NONE [label=" Dialog returns\n cleanup" color="#cc6666" fontsize=8.0 style=dashed];
        DA_IMPORT -> DA_NONE [label=" Dialog returns\n cleanup" color="#cc6666" fontsize=8.0 style=dashed];
        DA_OPEN -> DA_NONE [label=" Dialog returns\n cleanup" color="#cc6666" fontsize=8.0 style=dashed];
        DA_EXPORT -> DA_NONE [label=" Dialog returns\n cleanup" color="#cc6666" fontsize=8.0 style=dashed];
        DA_DRAWER -> DA_NONE [label=" Dialog returns\n cleanup" color="#cc6666" fontsize=8.0 style=dashed];
    }

    // ─────────────────────────────────────────────────────
    //  CROSS-LINKS
    // ─────────────────────────────────────────────────────

    M_PRESS -> GD_CHECK [
        label="  Route through guard"
        color="#555555" style=dotted
        lhead=cluster_guards
    ];

    { rank=same; M_IDLE; M_PRESS }
    { rank=same; M_HOLD; M_RELEASE }
    { rank=same; M_UI_CONSUMED; M_SUPPRESS }

    MAIN_STATES -> M_IDLE [arrowhead=none color="#555555" style=dotted];
    GESTURES -> G_CLICK [arrowhead=none color="#555555" style=dotted lhead=cluster_gestures];
    GUARDS -> GD_CHECK [arrowhead=none color="#555555" style=dotted lhead=cluster_guards];
    DEFERRED -> DA_NONE [arrowhead=none color="#555555" style=dotted lhead=cluster_deferred];

    { rank=min; MAIN_STATES; GESTURES; GUARDS; DEFERRED }

    // ─────────────────────────────────────────────────────
    //  LEGEND
    // ─────────────────────────────────────────────────────

    subgraph cluster_legend {
        label="LEGEND" labelloc=t labeljust=l
        fontcolor=white fontsize=11.0 fontname="Cascadia Code PL"
        color=white style=dashed penwidth=1

        L1 [label="" shape=point width=0.01];
        L2 [label="" shape=point width=0.01];
        L3 [label="" shape=point width=0.01];
        L4 [label="" shape=point width=0.01];
        L5 [label="" shape=point width=0.01];
        L6 [label="" shape=point width=0.01];
        L7 [label="" shape=point width=0.01];
        L8 [label="" shape=point width=0.01];

        L1 -> L2 [label=" Activate / Press" arrowhead=normal color="#66cc66" fontsize=9.0];
        L3 -> L4 [label=" Release / Reset" arrowhead=normal color="#cc6666" style=dashed fontsize=9.0];
        L5 -> L6 [label=" Commit" arrowhead=normal color="#cccc66" fontsize=9.0];
        L7 -> L8 [label=" Modal/Special" arrowhead=normal color="#cc66cc" fontsize=9.0];
    }
}
