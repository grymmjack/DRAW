digraph KEYBOARD_OPERATION {
    label="KEYBOARD OPERATION STATE MACHINE" labelloc=t labeljust=c
    ordering=out rankdir=TB
    fontcolor=white fontsize=24.0 fontname="Cascadia Code PL"
    splines=true compound=true
    bgcolor=transparent
    edge [
        color=gray fontcolor="#aaaaaa" fontsize=9.0
        fontname="Cascadia Code PL"
    ];
    node [
        color=white shape=rect style=""
        fontname="Cascadia Code PL" fontsize=11.0 fontcolor=cyan
    ];

    // ─────────────────────────────────────────────────────
    //  CATEGORY FOLDERS
    // ─────────────────────────────────────────────────────

    { node [shape=folder color=orange penwidth=2 fontcolor=orange fontsize=13.0];
        MODIFIERS_F [label="MODIFIERS"];
        HOTKEYS_F   [label="HOTKEYS"];
        CHORDS_F    [label="CHORDS"];
        ROUTING_F   [label="INPUT ROUTING"];
    }

    // ─────────────────────────────────────────────────────
    //  MODIFIER TRACKING
    // ─────────────────────────────────────────────────────

    subgraph cluster_modifiers {
        label="MODIFIER TRACKING — MODIFIERS_update()" labelloc=t labeljust=l
        fontcolor=orange fontsize=11.0 fontname="Cascadia Code PL"
        color=orange style=dashed penwidth=1

        MOD_NONE [label="No Modifiers\n────────────\nMODIFIERS.none% = TRUE\nAll ctrl/shift/alt = FALSE"
                  fontsize=10.0];
        MOD_CTRL [label="Ctrl Only\n────────────\nMODIFIERS.ctrlOnly% = TRUE\nCommand shortcuts active"
                  fontsize=10.0];
        MOD_SHIFT [label="Shift Only\n────────────\nMODIFIERS.shiftOnly% = TRUE\nCrosshair assistant\nConstrain axis/aspect"
                   fontsize=10.0];
        MOD_ALT [label="Alt Only\n────────────\nMODIFIERS.altOnly% = TRUE\nTemp color picker\nMenu bar access"
                 fontsize=10.0];
        MOD_CS [label="Ctrl+Shift\n────────────\nMODIFIERS.ctrlShift% = TRUE\nUI panel toggles\nCtrl+Shift+Arrow"
                fontsize=10.0];
        MOD_CA [label="Ctrl+Alt\n────────────\nMODIFIERS.ctrlAlt% = TRUE\nZoom assistant\nAdvanced hotkeys"
                fontsize=10.0];
        MOD_SA [label="Shift+Alt\n────────────\nMODIFIERS.shiftAlt% = TRUE\nSpecial combos"
                fontsize=10.0];
        MOD_CSA [label="Ctrl+Shift+Alt\n────────────\nMODIFIERS.ctrlShiftAlt% = TRUE\nAll three held"
                 fontsize=10.0];

        MOD_NONE -> MOD_CTRL [label=" Ctrl down" color="#88aacc" fontsize=8.0];
        MOD_NONE -> MOD_SHIFT [label=" Shift down" color="#88aacc" fontsize=8.0];
        MOD_NONE -> MOD_ALT [label=" Alt down" color="#88aacc" fontsize=8.0];
        MOD_CTRL -> MOD_CS [label=" +Shift" color="#88aacc" fontsize=8.0];
        MOD_CTRL -> MOD_CA [label=" +Alt" color="#88aacc" fontsize=8.0];
        MOD_SHIFT -> MOD_CS [label=" +Ctrl" color="#88aacc" fontsize=8.0];
        MOD_SHIFT -> MOD_SA [label=" +Alt" color="#88aacc" fontsize=8.0];
        MOD_ALT -> MOD_CA [label=" +Ctrl" color="#88aacc" fontsize=8.0];
        MOD_ALT -> MOD_SA [label=" +Shift" color="#88aacc" fontsize=8.0];
        MOD_CS -> MOD_CSA [label=" +Alt" color="#88aacc" fontsize=8.0];
        MOD_CA -> MOD_CSA [label=" +Shift" color="#88aacc" fontsize=8.0];
        MOD_SA -> MOD_CSA [label=" +Ctrl" color="#88aacc" fontsize=8.0];
    }

    // ─────────────────────────────────────────────────────
    //  HOTKEY CATEGORIES
    // ─────────────────────────────────────────────────────

    subgraph cluster_hotkeys {
        label="HOTKEY CATEGORIES — KEYBOARD_input_handler()" labelloc=t labeljust=l
        fontcolor=orange fontsize=11.0 fontname="Cascadia Code PL"
        color=orange style=dashed penwidth=1

        HK_TOOLS [label="Tool Switching\n────────────\nKEYBOARD_tools()\nD=Dot, B=Brush, L=Line\nR=Rect, E=Ellipse\nF=Fill, P=Picker\nM=Marquee, V=Move\nT=Text, S=Spray\nK=Custom Brush\nA=Pan, Z=Zoom"
                  fontsize=10.0];
        HK_FILE [label="File Operations\n────────────\nCtrl+N = New\nCtrl+O = Open\nCtrl+S = Save\nCtrl+Shift+S = Save As\nCtrl+E = Export BMP"
                 fontsize=10.0];
        HK_EDIT [label="Edit Operations\n────────────\nCtrl+Z = Undo\nCtrl+Y = Redo\nCtrl+C = Copy\nCtrl+X = Cut\nCtrl+V = Paste\nDel = Clear selection"
                 fontsize=10.0];
        HK_COLOR [label="Color & Opacity\n────────────\n1–0 = Opacity 10–100%\nX = Swap FG/BG\n[ ] = Prev/Next palette\n, . = Brush size ±1\nCtrl+I = Invert colors"
                  fontsize=10.0];
        HK_VIEW [label="View Controls\n────────────\n+ - = Zoom in/out\n0 = Fit to screen\nG = Toggle grid\n# = Toggle grid snap\nTab = Toggle UI\nF11 = Fullscreen"
                 fontsize=10.0];
        HK_LAYER [label="Layer Hotkeys\n────────────\nCtrl+Shift+N = New layer\nCtrl+Shift+E = Merge down\nPgUp/PgDn = Select layer\nCtrl+PgUp/PgDn = Move layer"
                  fontsize=10.0];
    }

    // ─────────────────────────────────────────────────────
    //  CHORD PATTERNS (Ctrl+ combos)
    // ─────────────────────────────────────────────────────

    subgraph cluster_chords {
        label="CHORD PATTERNS — _KEYDOWN() with STATIC guard" labelloc=t labeljust=l
        fontcolor=orange fontsize=11.0 fontname="Cascadia Code PL"
        color=orange style=dashed penwidth=1

        CH_IDLE [label="No Key Down\n────────────\nSTATIC pressed% = FALSE\nWaiting for chord"
                 fontsize=10.0];
        CH_MOD [label="Modifier Held\n────────────\nCtrl/Alt/Shift detected\nMODIFIERS_update() ran\nWatch for key press"
                fontsize=10.0];
        CH_FIRE [label="Chord Fired\n────────────\npressed% = TRUE\nCMD_execute_action()\nOne-shot guard active"
                 fontsize=10.0];
        CH_WAIT [label="Waiting Release\n────────────\npressed% = TRUE\nKey still held\nBlocked until release"
                 fontsize=10.0];

        CH_IDLE -> CH_MOD [
            label=" Modifier key pressed\n _KEYDOWN(100303/100304/100305/100306)"
            color="#66cc66" fontsize=8.0
        ];
        CH_MOD -> CH_FIRE [
            label=" Action key pressed\n IF NOT pressed% THEN fire"
            color="#66cc66" fontsize=8.0
        ];
        CH_FIRE -> CH_WAIT [
            label=" Same frame\n pressed% = TRUE"
            color="#cccc66" fontsize=8.0
        ];
        CH_WAIT -> CH_IDLE [
            label=" Key released\n NOT _KEYDOWN(key)\n pressed% = FALSE"
            color="#cc6666" fontsize=8.0 style=dashed
        ];
    }

    // ─────────────────────────────────────────────────────
    //  INPUT ROUTING
    // ─────────────────────────────────────────────────────

    subgraph cluster_routing {
        label="INPUT ROUTING PRIORITY" labelloc=t labeljust=l
        fontcolor=orange fontsize=11.0 fontname="Cascadia Code PL"
        color=orange style=dashed penwidth=1

        R1 [label="1. Command Palette\n────────────\nIF CMD.VISIBLE THEN\n  KEYBOARD_handle_command_palette%\n  EXIT" fontsize=10.0];
        R2 [label="2. Menu Bar\n────────────\nIF MENU_BAR.openMenu ≥ 0\n  OR MENU_BAR.kbActive\n  KEYBOARD_handle_menubar%" fontsize=10.0];
        R3 [label="3. Modal Tools\n────────────\nImage Import, Crop,\nRefImg Reposition,\nTransform, Fill-Adj" fontsize=10.0];
        R4 [label="4. Text Tool Editing\n────────────\nIF TEXT.ACTIVE THEN\n  KEYBOARD_handle_text_tool\n  Most keys consumed" fontsize=10.0];
        R5 [label="5. Normal Hotkeys\n────────────\nTool switching\nFile/Edit/View commands\nColor/Opacity changes" fontsize=10.0];
        R6 [label="6. Layer Keys\n────────────\n_KEYDOWN-based\nPgUp/PgDn/Arrow\nPer-frame repeat" fontsize=10.0];

        R1 -> R2 [label=" Not consumed" color="#88aacc" fontsize=8.0];
        R2 -> R3 [label=" Not consumed" color="#88aacc" fontsize=8.0];
        R3 -> R4 [label=" Not consumed" color="#88aacc" fontsize=8.0];
        R4 -> R5 [label=" Not consumed" color="#88aacc" fontsize=8.0];
        R5 -> R6 [label=" Not consumed" color="#88aacc" fontsize=8.0];
    }

    // ─────────────────────────────────────────────────────
    //  CROSS-LINKS
    // ─────────────────────────────────────────────────────

    MODIFIERS_F -> MOD_NONE [arrowhead=none color="#555555" style=dotted lhead=cluster_modifiers];
    HOTKEYS_F -> HK_TOOLS [arrowhead=none color="#555555" style=dotted lhead=cluster_hotkeys];
    CHORDS_F -> CH_IDLE [arrowhead=none color="#555555" style=dotted lhead=cluster_chords];
    ROUTING_F -> R1 [arrowhead=none color="#555555" style=dotted lhead=cluster_routing];

    { rank=min; MODIFIERS_F; HOTKEYS_F; CHORDS_F; ROUTING_F }

    // ─────────────────────────────────────────────────────
    //  LEGEND
    // ─────────────────────────────────────────────────────

    subgraph cluster_legend {
        label="LEGEND" labelloc=t labeljust=l
        fontcolor=white fontsize=11.0 fontname="Cascadia Code PL"
        color=white style=dashed penwidth=1

        L1 [label="" shape=point width=0.01];
        L2 [label="" shape=point width=0.01];
        L3 [label="" shape=point width=0.01];
        L4 [label="" shape=point width=0.01];
        L5 [label="" shape=point width=0.01];
        L6 [label="" shape=point width=0.01];

        L1 -> L2 [label=" Key Press / Activate" arrowhead=normal color="#66cc66" fontsize=9.0];
        L3 -> L4 [label=" Key Release / Deactivate" arrowhead=normal color="#cc6666" style=dashed fontsize=9.0];
        L5 -> L6 [label=" Guard / One-Shot" arrowhead=normal color="#cccc66" fontsize=9.0];
    }
}
