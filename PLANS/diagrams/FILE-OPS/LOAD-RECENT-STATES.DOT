digraph LOAD_RECENT_STATES {
    label="LOAD RECENT STATE MACHINE" labelloc=t labeljust=c
    ordering=out rankdir=TB
    fontcolor=white fontsize=24.0 fontname="Cascadia Code PL"
    splines=true compound=true
    bgcolor=transparent
    edge [
        color=gray fontcolor="#aaaaaa" fontsize=9.0
        fontname="Cascadia Code PL"
    ];
    node [
        color=white shape=rect style=""
        fontname="Cascadia Code PL" fontsize=11.0 fontcolor=cyan
    ];

    { node [shape=folder color=orange penwidth=2 fontcolor=orange fontsize=13.0];
        MAIN [label="LOAD\nRECENT"];
    }

    S_IDLE [label="1 В· IDLE\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nCurrent project loaded\nor new blank canvas\nRecent files tracked"];
    S_UNSAVED_CHECK [label="2 В· UNSAVED CHECK\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nCheck CANVAS_DIRTY%\nor unsaved changes\nPrompt: Save? / Don't / Cancel"];
    S_LOADING [label="3 В· LOADING\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nDRW_load_binary(filename)\nor IMAGE_IMPORT_load_file()\nParse file format\nRestore all state"];
    S_LOADED [label="4 В· LOADED\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nAll layers restored\nTool state reset\nPalette loaded\nDrawer slots loaded\nGrid/symmetry reset\nCANVAS_DIRTY = FALSE"];

    S_IDLE -> S_UNSAVED_CHECK [label="  File в†’ Open Recent\n  or File в†’ Open\n  or recent file click\n  or deferred action" color="#66cc66"];
    S_UNSAVED_CHECK -> S_LOADING [label="  Save first (saved)\n  or Don't Save" color="#cccc66"];
    S_UNSAVED_CHECK -> S_IDLE [label="  Cancel\n  Abort load" color="#cc6666" style=dashed];
    S_LOADING -> S_LOADED [label="  File parsed OK\n  State restored" color="#66cc66"];
    S_LOADING -> S_IDLE [label="  File error\n  Invalid format\n  or file not found" color="#cc6666" style=dashed];
    S_LOADED -> S_IDLE [label="  Return to\n  normal mode" color="#cccc66"];

    MAIN -> S_IDLE [arrowhead=none color="#555555" style=dotted];
    { rank=min; MAIN }

    subgraph cluster_recent {
        label="RECENT FILES LIST" labelloc=t labeljust=l
        fontcolor=white fontsize=11.0 fontname="Cascadia Code PL"
        color=orange style=dashed penwidth=1

        R1 [label="File в†’ Open Recent\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nSubmenu lists up to\nN recent files\nMost recent first\nFull path shown"];
        R2 [label="Stored In Config\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nDRAW.cfg persists\nrecent file paths\nUpdated on save/load"];
        R3 [label="Command-Line Load\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nDRAW.run filename.drw\nDeferred to first frame\nSkips recent menu"];
    }

    subgraph cluster_formats {
        label="SUPPORTED FORMATS" labelloc=t labeljust=l
        fontcolor=white fontsize=11.0 fontname="Cascadia Code PL"
        color=orange style=dashed penwidth=1

        F_DRW [label="DRW (Native)\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nPNG with drAw chunk\nFull project restore:\nlayers, palette, tools,\ndrawer, history"];
        F_PNG [label="PNG Image\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nSingle layer import\nRGBA preserved\nChecks for drAw chunk"];
        F_BMP [label="BMP Image\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nFILE_BMP_load()\nSingle layer import\nRGB only"];
        F_GPL [label="GPL Palette\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nGIMP palette file\nLoads 256 colors\nPAL_load_gpl()"];
    }

    subgraph cluster_deferred {
        label="DEFERRED LOAD PATTERN" labelloc=t labeljust=l
        fontcolor=white fontsize=11.0 fontname="Cascadia Code PL"
        color=orange style=dashed penwidth=1

        D1 [label="MOUSE.DEFERRED_ACTION%\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nFile dialog blocks mouse\nDefer load to post-frame\nMOUSE_input_handler_loop()\nexecutes deferred action"];
        D2 [label="MOUSE_cleanup_after_dialog\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nDrain mouse buffer\nForce buttons up\nSUPPRESS_FRAMES = 2\nClear keyboard buffer"];
    }

    subgraph cluster_state_reset {
        label="STATE RESET ON LOAD" labelloc=t labeljust=l
        fontcolor=white fontsize=11.0 fontname="Cascadia Code PL"
        color=orange style=dashed penwidth=1

        SR1 [label="DRW_load_binary resets:\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nвЂў All tool states\nвЂў Marquee / selection\nвЂў Transform overlay\nвЂў Custom brush\nвЂў Text tool\nвЂў Fill-adj\nвЂў Image import\nвЂў History system\nвЂў Panel visibility\nвЂў Zoom / pan offset"];
    }

    subgraph cluster_legend {
        label="LEGEND" labelloc=t labeljust=l
        fontcolor=white fontsize=11.0 fontname="Cascadia Code PL"
        color=white style=dashed penwidth=1
        L1 [label="" shape=point width=0.01]; L2 [label="" shape=point width=0.01];
        L3 [label="" shape=point width=0.01]; L4 [label="" shape=point width=0.01];
        L5 [label="" shape=point width=0.01]; L6 [label="" shape=point width=0.01];
        L1 -> L2 [label=" Load / Activate" arrowhead=normal color="#66cc66" fontsize=9.0];
        L3 -> L4 [label=" Cancel / Error" arrowhead=normal color="#cc6666" style=dashed fontsize=9.0];
        L5 -> L6 [label=" Step / Complete" arrowhead=normal color="#cccc66" fontsize=9.0];
    }
}
