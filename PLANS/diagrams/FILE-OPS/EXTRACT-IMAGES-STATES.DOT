digraph EXTRACT_IMAGES_STATES {
    label="EXTRACT IMAGES STATE MACHINE" labelloc=t labeljust=c
    ordering=out rankdir=TB
    fontcolor=white fontsize=24.0 fontname="Cascadia Code PL"
    splines=true compound=true
    bgcolor=transparent
    edge [
        color=gray fontcolor="#aaaaaa" fontsize=9.0
        fontname="Cascadia Code PL"
    ];
    node [
        color=white shape=rect style=""
        fontname="Cascadia Code PL" fontsize=11.0 fontcolor=cyan
    ];

    { node [shape=folder color=orange penwidth=2 fontcolor=orange fontsize=13.0];
        MAIN [label="EXTRACT\nIMAGES"];
    }

    S_IDLE [label="1 В· IDLE\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nNo extraction active\nNormal drawing mode"];
    S_CONFIG [label="2 В· CONFIGURE\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nEXTRACT_IMAGES_dialog()\nSettings dialog open\nвЂў Background mode\nвЂў Output directory\nвЂў Naming method\nвЂў Merge layers option"];
    S_DETECT [label="3 В· DETECTING\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nEXTRACT_find_components()\n8-connected flood fill\nLabel each pixel by\ncomponent ID\nBuild bounding boxes"];
    S_SAVING [label="4 В· SAVING\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nEXTRACT_save_component()\nFor each component:\nвЂў Crop to bounding box\nвЂў Write PNG with alpha\nProgress dialog shown"];
    S_COMPLETE [label="5 В· COMPLETE\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nAll components saved\nOpen output folder\noptional (file manager)\nReturn to idle"];

    S_IDLE -> S_CONFIG [label="  Tools в†’ Extract Images\n  Open config dialog" color="#66cc66"];
    S_CONFIG -> S_DETECT [label="  OK / Extract\n  Begin processing" color="#cccc66"];
    S_CONFIG -> S_IDLE [label="  Cancel\n  cancelled = TRUE" color="#cc6666" style=dashed];
    S_DETECT -> S_SAVING [label="  Components found\n  EXTRACT_COMP_COUNT > 0" color="#cccc66"];
    S_DETECT -> S_IDLE [label="  No components\n  Nothing to extract" color="#cc6666" style=dashed];
    S_SAVING -> S_COMPLETE [label="  All saved\n  EXTRACT_open_folder()" color="#cccc66"];
    S_COMPLETE -> S_IDLE [label="  Return to\n  normal mode" color="#cc6666" style=dashed];

    MAIN -> S_IDLE [arrowhead=none color="#555555" style=dotted];
    { rank=min; MAIN }

    subgraph cluster_bg_mode {
        label="BACKGROUND MODE" labelloc=t labeljust=l
        fontcolor=white fontsize=11.0 fontname="Cascadia Code PL"
        color=orange style=dashed penwidth=1

        BG_TRANS [label="Transparent\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nEXTRACT_BG_TRANSPARENT=0\nIgnore fully transparent\npixels (alpha=0)\nComponents = opaque blobs"];
        BG_FG [label="FG Color\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nEXTRACT_BG_FG_COLOR=1\nTreat FG color as BG\nExclude from components"];
        BG_BG [label="BG Color\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nEXTRACT_BG_BG_COLOR=2\nTreat BG color as BG\nExclude from components"];
    }

    subgraph cluster_naming {
        label="NAMING METHOD" labelloc=t labeljust=l
        fontcolor=white fontsize=11.0 fontname="Cascadia Code PL"
        color=orange style=dashed penwidth=1

        N_NUM [label="Sequential Numbers\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nEXTRACT_NAME_NUMBERS=0\nbase_001.png, base_002.png\nstartNumber configurable"];
        N_LAYER [label="Layer Names\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nEXTRACT_NAME_LAYER_NAME=1\nUse source layer name\nas output filename"];
    }

    subgraph cluster_detection {
        label="COMPONENT DETECTION" labelloc=t labeljust=l
        fontcolor=white fontsize=11.0 fontname="Cascadia Code PL"
        color=orange style=dashed penwidth=1

        D1 [label="Flood Fill Labeling\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nEXTRACT_LABELS(x,y)\nEach pixel gets component ID\n8-connected connectivity\n(includes diagonals)"];
        D2 [label="EXTRACT_COMPS()\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nPer-component:\nвЂў minX/Y, maxX/Y (bbox)\nвЂў pixelCount\nвЂў origIndex"];
    }

    subgraph cluster_merge {
        label="MERGE OPTION" labelloc=t labeljust=l
        fontcolor=white fontsize=11.0 fontname="Cascadia Code PL"
        color=orange style=dashed penwidth=1

        MG_OFF [label="Per-Layer Mode\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nmergeLayers = FALSE\nExtract from each\nlayer separately"];
        MG_ON [label="Merged Mode\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nmergeLayers = TRUE\nFlatten all layers\nthen extract from\nmerged result"];
    }

    subgraph cluster_persistence {
        label="PERSISTENCE (DRW v14+)" labelloc=t labeljust=l
        fontcolor=white fontsize=11.0 fontname="Cascadia Code PL"
        color=orange style=dashed penwidth=1

        P1 [label="Saved Config\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nEXTRACT_SAVED_BG_MODE\n*_BASE_FILENAME\n*_NAMING_METHOD\n*_START_NUMBER\n*_APPEND_DIMS\n*_MERGE_LAYERS\n*_DEST_DIR"];
    }

    subgraph cluster_legend {
        label="LEGEND" labelloc=t labeljust=l
        fontcolor=white fontsize=11.0 fontname="Cascadia Code PL"
        color=white style=dashed penwidth=1
        L1 [label="" shape=point width=0.01]; L2 [label="" shape=point width=0.01];
        L3 [label="" shape=point width=0.01]; L4 [label="" shape=point width=0.01];
        L5 [label="" shape=point width=0.01]; L6 [label="" shape=point width=0.01];
        L1 -> L2 [label=" Activate / Start" arrowhead=normal color="#66cc66" fontsize=9.0];
        L3 -> L4 [label=" Cancel / Empty" arrowhead=normal color="#cc6666" style=dashed fontsize=9.0];
        L5 -> L6 [label=" Step / Process" arrowhead=normal color="#cccc66" fontsize=9.0];
    }
}
