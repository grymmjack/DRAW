digraph EXTRACT_GRID {
    label="EXTRACT FROM GRID STATE MACHINE" labelloc=t labeljust=c
    ordering=out rankdir=TB
    fontcolor=white fontsize=24.0 fontname="Cascadia Code PL"
    splines=true compound=true
    bgcolor=transparent
    edge [color=gray fontcolor="#aaaaaa" fontsize=9.0 fontname="Cascadia Code PL"];
    node [color=white shape=rect style="" fontname="Cascadia Code PL" fontsize=11.0 fontcolor=cyan];

    { node [shape=folder color=orange penwidth=2 fontcolor=orange fontsize=13.0];
        MAIN [label="EXTRACT FROM GRID — PNG OUTPUT"];
    }

    S_IDLE [label="1 · IDLE\n─────────────────\nNo extraction in progress\nNormal app state"];
    S_DIALOG [label="2 · DIALOG OPEN\n─────────────────\nFile → Extract From Grid...\nCell W/H inputs\nOffset X/Y\nNaming pattern\nOutput dir"];
    S_VALIDATING [label="3 · VALIDATING\n─────────────────\nGrid params sane?\nCanvas dims divisible?\nOutput dir writable?"];
    S_EXTRACTING [label="4 · EXTRACTING\n─────────────────\nLoop rows × cols\nFor each cell:\n  _COPYIMAGE region\n  Save as PNG\n  Index in filename"];
    S_REPORTING [label="5 · REPORTING\n─────────────────\nProgress shown\nFinal count message\nOpen output folder?"];
    S_ABORTED [label="6 · ABORTED\n─────────────────\nEsc / Cancel\nNo files written"];

    S_IDLE -> S_DIALOG [label="  Menu action fired" color="#66cc66"];
    S_DIALOG -> S_VALIDATING [label="  OK pressed" color="#cccc66"];
    S_DIALOG -> S_ABORTED [label="  Cancel / Esc" color="#cc6666" style=dashed];
    S_VALIDATING -> S_DIALOG [label="  Bad params\n  show inline error" color="#cc6666" style=dashed];
    S_VALIDATING -> S_EXTRACTING [label="  All params valid" color="#cccc66"];
    S_EXTRACTING -> S_REPORTING [label="  Loop complete" color="#cccc66"];
    S_REPORTING -> S_IDLE [label="  Acknowledged" color="#cc6666" style=dashed];
    S_ABORTED -> S_IDLE [label="  (immediate)" color="#cc6666" style=dashed];

    subgraph cluster_params {
        label="PARAMETERS" labelloc=t labeljust=l
        fontcolor=orange fontsize=11.0 color=orange style=dashed penwidth=1

        P1 [label="Cell Size\n────────────\nWidth × Height\nin pixels" fontsize=10.0];
        P2 [label="Offset\n────────────\nStart X / Y\nfor grid origin" fontsize=10.0];
        P3 [label="Source\n────────────\nActive layer\nor merged composite" fontsize=10.0];
        P4 [label="Output\n────────────\nDirectory + name pattern\ne.g. sprite_{row}_{col}.png" fontsize=10.0];
    }

    subgraph cluster_output {
        label="OUTPUT" labelloc=t labeljust=l
        fontcolor=orange fontsize=11.0 color=orange style=dashed penwidth=1

        O1 [label="One PNG per cell\n────────────\nIndividual files\nNo modification of\nsource canvas" fontsize=10.0];
        O2 [label="Skip Empty?\n────────────\nOption to skip\nfully transparent cells" fontsize=10.0];
    }

    MAIN -> S_IDLE [arrowhead=none color="#555555" style=dotted];
    { rank=min; MAIN }

    subgraph cluster_legend {
        label="LEGEND" labelloc=t labeljust=l
        fontcolor=white fontsize=11.0 color=white style=dashed penwidth=1
        L1 [label="" shape=point width=0.01]; L2 [label="" shape=point width=0.01];
        L3 [label="" shape=point width=0.01]; L4 [label="" shape=point width=0.01];
        L5 [label="" shape=point width=0.01]; L6 [label="" shape=point width=0.01];
        L1 -> L2 [label=" Begin" arrowhead=normal color="#66cc66" fontsize=9.0];
        L3 -> L4 [label=" End / Cancel" arrowhead=normal color="#cc6666" style=dashed fontsize=9.0];
        L5 -> L6 [label=" Transition" arrowhead=normal color="#cccc66" fontsize=9.0];
    }
}
