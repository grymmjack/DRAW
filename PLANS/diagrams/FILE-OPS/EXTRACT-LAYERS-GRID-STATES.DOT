digraph EXTRACT_LAYERS_GRID {
    label="EXTRACT TO LAYERS FROM GRID STATE MACHINE" labelloc=t labeljust=c
    ordering=out rankdir=TB
    fontcolor=white fontsize=24.0 fontname="Cascadia Code PL"
    splines=true compound=true
    bgcolor=transparent
    edge [color=gray fontcolor="#aaaaaa" fontsize=9.0 fontname="Cascadia Code PL"];
    node [color=white shape=rect style="" fontname="Cascadia Code PL" fontsize=11.0 fontcolor=cyan];

    { node [shape=folder color=orange penwidth=2 fontcolor=orange fontsize=13.0];
        MAIN [label="EXTRACT TO LAYERS FROM GRID"];
    }

    S_IDLE [label="1 ¬∑ IDLE\n‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ\nNo extraction running"];
    S_DIALOG [label="2 ¬∑ DIALOG OPEN\n‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ\nFile ‚Üí Extract To Layers\nFrom Grid...\nCell W/H, offset,\nnaming pattern"];
    S_VALIDATING [label="3 ¬∑ VALIDATING\n‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ\nParams valid?\nCanvas large enough?"];
    S_EXTRACTING [label="4 ¬∑ EXTRACTING\n‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ\nLoop rows √ó cols\nFor each cell:\n  Create new layer\n  Copy cell pixels in\n  Set layer name\n  contentDirty% = TRUE"];
    S_FINALIZING [label="5 ¬∑ FINALIZING\n‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ\nHISTORY_record state\nLayer panel refresh\nSCENE_DIRTY% = TRUE"];
    S_DONE [label="6 ¬∑ DONE\n‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ\nLayers visible in panel\nLayer count message\nReturn to idle"];
    S_ABORTED [label="7 ¬∑ ABORTED\n‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ\nEsc / Cancel\nNo layers added"];

    S_IDLE -> S_DIALOG [label="  Menu action fired" color="#66cc66"];
    S_DIALOG -> S_VALIDATING [label="  OK pressed" color="#cccc66"];
    S_DIALOG -> S_ABORTED [label="  Cancel / Esc" color="#cc6666" style=dashed];
    S_VALIDATING -> S_DIALOG [label="  Invalid params" color="#cc6666" style=dashed];
    S_VALIDATING -> S_EXTRACTING [label="  Valid" color="#cccc66"];
    S_EXTRACTING -> S_FINALIZING [label="  All cells processed" color="#cccc66"];
    S_FINALIZING -> S_DONE [label="  History saved\n  panel updated" color="#cccc66"];
    S_DONE -> S_IDLE [label="  Acknowledged" color="#cc6666" style=dashed];
    S_ABORTED -> S_IDLE [label="  (immediate)" color="#cc6666" style=dashed];

    subgraph cluster_params {
        label="PARAMETERS" labelloc=t labeljust=l
        fontcolor=orange fontsize=11.0 color=orange style=dashed penwidth=1

        P1 [label="Cell Size\n‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ\nWidth √ó Height" fontsize=10.0];
        P2 [label="Offset\n‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ\nGrid origin X / Y" fontsize=10.0];
        P3 [label="Naming\n‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ\nLayer name pattern\ne.g. cell_{row}_{col}" fontsize=10.0];
        P4 [label="Source\n‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ\nActive layer\nor merged composite" fontsize=10.0];
    }

    subgraph cluster_diff {
        label="DIFFERENCE FROM EXTRACT-GRID" labelloc=t labeljust=l
        fontcolor=orange fontsize=11.0 color=orange style=dashed penwidth=1

        D1 [label="Output\n‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ\nLayers in current document\n(NOT external PNG files)\nUndoable via HISTORY" fontsize=10.0];
    }

    MAIN -> S_IDLE [arrowhead=none color="#555555" style=dotted];
    { rank=min; MAIN }

    subgraph cluster_legend {
        label="LEGEND" labelloc=t labeljust=l
        fontcolor=white fontsize=11.0 color=white style=dashed penwidth=1
        L1 [label="" shape=point width=0.01]; L2 [label="" shape=point width=0.01];
        L3 [label="" shape=point width=0.01]; L4 [label="" shape=point width=0.01];
        L5 [label="" shape=point width=0.01]; L6 [label="" shape=point width=0.01];
        L1 -> L2 [label=" Begin" arrowhead=normal color="#66cc66" fontsize=9.0];
        L3 -> L4 [label=" End / Cancel" arrowhead=normal color="#cc6666" style=dashed fontsize=9.0];
        L5 -> L6 [label=" Transition" arrowhead=normal color="#cccc66" fontsize=9.0];
    }
}
