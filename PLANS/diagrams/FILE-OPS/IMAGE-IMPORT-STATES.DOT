digraph IMAGE_IMPORT_STATES {
    label="IMAGE IMPORT STATE MACHINE" labelloc=t labeljust=c
    ordering=out rankdir=TB
    fontcolor=white fontsize=24.0 fontname="Cascadia Code PL"
    splines=true compound=true
    bgcolor=transparent
    edge [
        color=gray fontcolor="#aaaaaa" fontsize=9.0
        fontname="Cascadia Code PL"
    ];
    node [
        color=white shape=rect style=""
        fontname="Cascadia Code PL" fontsize=11.0 fontcolor=cyan
    ];

    { node [shape=folder color=orange penwidth=2 fontcolor=orange fontsize=13.0];
        MAIN [label="IMAGE\nIMPORT"];
    }

    S_IDLE [label="1 В· IDLE\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nIMPORT_STATE_IDLE\nNo import active\nNormal drawing mode"];
    S_LOADED [label="2 В· LOADED\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nIMPORT_STATE_LOADED\nIMAGE < -1 (valid handle)\nFILENAME set\nWaiting for marquee box"];
    S_PLACING [label="3 В· PLACING\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nIMPORT_STATE_PLACING\nMarquee drawn on canvas\nDEST_X/Y/W/H set\nResize handles active\nCrop+zoom adjustable"];
    S_PANNING [label="4 В· PANNING\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nIMPORT_STATE_PANNING\nMiddle-click pan active\nwithin crop area\nPAN_X/Y adjusting\nCROP window shifts"];

    S_IDLE -> S_LOADED [label="  File в†’ Import Image\n  File dialog opens\n  IMAGE_IMPORT_load_file()\n  IMAGE = _LOADIMAGE" color="#66cc66"];
    S_LOADED -> S_PLACING [label="  Draw marquee on canvas\n  IMAGE_IMPORT_start_\n  placement()\n  DEST_X/Y/W/H set" color="#66cc66"];
    S_PLACING -> S_PANNING [label="  Middle-click drag\n  PANNING = TRUE\n  PAN_START_X/Y = mouse" color="#6699ff"];
    S_PANNING -> S_PLACING [label="  Middle-click release\n  PANNING = FALSE\n  PAN offset committed" color="#6699ff"];
    S_PLACING -> S_PLACING [label="  Resize handles drag\n  RESIZING = TRUE\n  DEST W/H updated\n  or scroll wheel zoom\n  CROP window adjusts" color="#88aacc"];
    S_PLACING -> S_IDLE [label="  Enter в†’ Commit\n  Paste image to layer\n  HISTORY_record\n  PREV_TOOL restored" color="#cccc66"];
    S_PLACING -> S_IDLE [label="  Escape в†’ Cancel\n  IMAGE_IMPORT_cancel()\n  Free IMAGE handle\n  PREV_TOOL restored" color="#cc6666" style=dashed];

    MAIN -> S_IDLE [arrowhead=none color="#555555" style=dotted];
    { rank=min; MAIN }

    subgraph cluster_transform {
        label="IN-PLACE TRANSFORMS" labelloc=t labeljust=l
        fontcolor=white fontsize=11.0 fontname="Cascadia Code PL"
        color=orange style=dashed penwidth=1

        T_ROT [label="Rotation\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nROTATION: 0/90/180/270\nRotate imported image\nbefore commit"];
        T_FLIP [label="Flip\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nFLIP_H/V flags\nMirror imported image\nbefore commit"];
        T_SCALE [label="Scale\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nSCALE_FACTOR (1.0=orig)\nCumulative scaling\nPREVIEW_IMG cached"];
        T_ASPECT [label="Aspect Lock\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nLOCK_ASPECT = TRUE\nMaintain source ratio\nwhen resizing handles\nASPECT_RATIO = W/H"];
    }

    subgraph cluster_crop {
        label="CROP/ZOOM WITHIN IMAGE" labelloc=t labeljust=l
        fontcolor=white fontsize=11.0 fontname="Cascadia Code PL"
        color=orange style=dashed penwidth=1

        CZ1 [label="Zoom Level\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nZOOM: ZOOM_MIN..ZOOM_MAX\nScroll wheel adjusts\nCROP window expands/shrinks"];
        CZ2 [label="Pan Offset\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nPAN_X, PAN_Y offsets\nMiddle-click drag\nShifts visible crop region"];
        CZ3 [label="Crop Region\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nCROP_X/Y/W/H (SINGLE)\nSubset of source image\nshown in DEST rectangle"];
    }

    subgraph cluster_resize {
        label="RESIZE HANDLES" labelloc=t labeljust=l
        fontcolor=white fontsize=11.0 fontname="Cascadia Code PL"
        color=orange style=dashed penwidth=1

        RH [label="8 Edge Handles\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nRESIZE_HANDLE = 1-8\nCorners + edges\nCONSTRAIN (Shift)\nlocks aspect ratio\nDrag to resize DEST"];
    }

    subgraph cluster_drag_drop {
        label="DRAG & DROP ENTRY" labelloc=t labeljust=l
        fontcolor=white fontsize=11.0 fontname="Cascadia Code PL"
        color=orange style=dashed penwidth=1

        DD1 [label="Windows _ACCEPTFILEDROP\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nDrag image file onto\nDRAW window\nAuto-load as import\nSame flow as Fileв†’Import"];
    }

    subgraph cluster_legend {
        label="LEGEND" labelloc=t labeljust=l
        fontcolor=white fontsize=11.0 fontname="Cascadia Code PL"
        color=white style=dashed penwidth=1
        L1 [label="" shape=point width=0.01]; L2 [label="" shape=point width=0.01];
        L3 [label="" shape=point width=0.01]; L4 [label="" shape=point width=0.01];
        L5 [label="" shape=point width=0.01]; L6 [label="" shape=point width=0.01];
        L7 [label="" shape=point width=0.01]; L8 [label="" shape=point width=0.01];
        L1 -> L2 [label=" Load / Activate" arrowhead=normal color="#66cc66" fontsize=9.0];
        L3 -> L4 [label=" Cancel / Restore" arrowhead=normal color="#cc6666" style=dashed fontsize=9.0];
        L5 -> L6 [label=" Commit / Record" arrowhead=normal color="#cccc66" fontsize=9.0];
        L7 -> L8 [label=" Mode switch" arrowhead=normal color="#6699ff" fontsize=9.0];
    }
}
