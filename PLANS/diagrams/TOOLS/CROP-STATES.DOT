digraph CROP_TOOL {
    label="CROP TOOL STATE MACHINE" labelloc=t labeljust=c
    ordering=out rankdir=TB
    fontcolor=white fontsize=24.0 fontname="Cascadia Code PL"
    splines=true compound=true
    bgcolor=transparent
    edge [
        color=gray fontcolor="#aaaaaa" fontsize=9.0
        fontname="Cascadia Code PL"
    ];
    node [
        color=white shape=rect style=""
        fontname="Cascadia Code PL" fontsize=11.0 fontcolor=cyan
    ];

    { node [shape=folder color=orange penwidth=2 fontcolor=orange fontsize=13.0];
        MAIN [label="CROP STATES"];
    }

    S_IDLE [label="1 · IDLE\n─────────────────\nCURRENT_TOOL = TOOL_CROP\nSaves previous tool\nCursor: crosshair"];
    S_DRAWING [label="2 · DRAWING REGION\n─────────────────\nB1 drag on canvas\nCrop rectangle preview\nRubberband overlay\nDim area outside crop"];
    S_DEFINED [label="3 · REGION DEFINED\n─────────────────\nCrop area set\nOverlay shows bounds\nResize handles visible\nAwaiting Enter/Escape"];
    S_RESIZE [label="4 · HANDLE RESIZE\n─────────────────\nDrag corner/edge handle\nAdjust crop bounds\nLive preview update"];
    S_COMMIT [label="5 · COMMITTED\n─────────────────\nEnter pressed\nCanvas resized to crop\nAll layers cropped\nHISTORY_record_brush()\nRestore previous tool"];
    S_CANCEL [label="6 · CANCELLED\n─────────────────\nEscape pressed\nCrop overlay removed\nRestore previous tool\nNo changes made"];

    S_IDLE -> S_DRAWING [label="  B1 drag on canvas\n  Start crop region" color="#66cc66"];
    S_DRAWING -> S_DEFINED [label="  B1 released\n  Region bounds set" color="#cccc66"];
    S_DEFINED -> S_RESIZE [label="  B1 on handle\n  Adjust region" color="#66cc66"];
    S_RESIZE -> S_DEFINED [label="  B1 released\n  New bounds set" color="#cccc66"];
    S_DEFINED -> S_COMMIT [label="  Enter key\n  Apply crop to all layers\n  HISTORY_record_brush()" color="#cccc66"];
    S_DEFINED -> S_CANCEL [label="  Escape key\n  Cancel crop" color="#cc6666" style=dashed];
    S_COMMIT -> S_IDLE [label="  Crop applied\n  Restore prev tool" color="#cc6666" style=dashed];
    S_CANCEL -> S_IDLE [label="  Crop cancelled\n  Restore prev tool" color="#cc6666" style=dashed];
    S_DEFINED -> S_DRAWING [label="  B1 drag outside handles\n  Start new crop region" color="#66cc66"];

    MAIN -> S_IDLE [arrowhead=none color="#555555" style=dotted];
    { rank=min; MAIN }
    { rank=same; S_COMMIT; S_CANCEL }

    subgraph cluster_legend {
        label="LEGEND" labelloc=t labeljust=l
        fontcolor=white fontsize=11.0 fontname="Cascadia Code PL"
        color=white style=dashed penwidth=1
        L1 [label="" shape=point width=0.01]; L2 [label="" shape=point width=0.01];
        L3 [label="" shape=point width=0.01]; L4 [label="" shape=point width=0.01];
        L5 [label="" shape=point width=0.01]; L6 [label="" shape=point width=0.01];
        L1 -> L2 [label=" Start / Activate" arrowhead=normal color="#66cc66" fontsize=9.0];
        L3 -> L4 [label=" Cancel / Restore" arrowhead=normal color="#cc6666" style=dashed fontsize=9.0];
        L5 -> L6 [label=" Commit / Apply" arrowhead=normal color="#cccc66" fontsize=9.0];
    }
}
