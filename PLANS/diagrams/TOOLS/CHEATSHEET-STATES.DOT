digraph CHEATSHEET_TOOL {
    label="CHEAT SHEET / HELP TOOL STATE MACHINE" labelloc=t labeljust=c
    ordering=out rankdir=TB
    fontcolor=white fontsize=24.0 fontname="Cascadia Code PL"
    splines=true compound=true
    bgcolor=transparent
    edge [
        color=gray fontcolor="#aaaaaa" fontsize=9.0
        fontname="Cascadia Code PL"
    ];
    node [
        color=white shape=rect style=""
        fontname="Cascadia Code PL" fontsize=11.0 fontcolor=cyan
    ];

    { node [shape=folder color=orange penwidth=2 fontcolor=orange fontsize=13.0];
        MAIN [label="HELP STATES"];
    }

    S_HIDDEN [label="1 · HIDDEN\n─────────────────\nHELP overlay not visible\nNormal drawing mode\nCURRENT_TOOL% ≠ TOOL_HELP"];
    S_VISIBLE [label="2 · VISIBLE\n─────────────────\nHELP overlay shown\nFull-screen cheat sheet\nAll keyboard shortcuts\nMouse bindings displayed"];
    S_SCROLLING [label="3 · SCROLLING\n─────────────────\nContent taller than screen\nScroll with mouse wheel\nor arrow keys\nPage up/down supported"];

    S_HIDDEN -> S_VISIBLE [label="  Press H or F1\n  or click HELP tool\n  HELP_show()" color="#66cc66"];
    S_VISIBLE -> S_SCROLLING [label="  Content overflow\n  Scroll available" color="#66cc66"];
    S_SCROLLING -> S_SCROLLING [label="  Mouse wheel\n  or arrow keys\n  Scroll position changes" color="#88aacc"];
    S_VISIBLE -> S_HIDDEN [label="  Press Escape\n  or H or F1\n  HELP_hide()" color="#cc6666" style=dashed];
    S_SCROLLING -> S_HIDDEN [label="  Press Escape\n  or H or F1\n  HELP_hide()" color="#cc6666" style=dashed];

    MAIN -> S_HIDDEN [arrowhead=none color="#555555" style=dotted];
    { rank=min; MAIN }

    subgraph cluster_legend {
        label="LEGEND" labelloc=t labeljust=l
        fontcolor=white fontsize=11.0 fontname="Cascadia Code PL"
        color=white style=dashed penwidth=1
        L1 [label="" shape=point width=0.01]; L2 [label="" shape=point width=0.01];
        L3 [label="" shape=point width=0.01]; L4 [label="" shape=point width=0.01];
        L1 -> L2 [label=" Show / Open" arrowhead=normal color="#66cc66" fontsize=9.0];
        L3 -> L4 [label=" Hide / Close" arrowhead=normal color="#cc6666" style=dashed fontsize=9.0];
    }
}
