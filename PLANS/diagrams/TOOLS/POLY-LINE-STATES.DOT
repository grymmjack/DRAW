digraph POLY_LINE_TOOL {
    label="POLY LINE / FILLED POLYGON TOOL STATE MACHINE" labelloc=t labeljust=c
    ordering=out rankdir=TB
    fontcolor=white fontsize=24.0 fontname="Cascadia Code PL"
    splines=true compound=true
    bgcolor=transparent
    edge [
        color=gray fontcolor="#aaaaaa" fontsize=9.0
        fontname="Cascadia Code PL"
    ];
    node [
        color=white shape=rect style=""
        fontname="Cascadia Code PL" fontsize=11.0 fontcolor=cyan
    ];

    { node [shape=folder color=orange penwidth=2 fontcolor=orange fontsize=13.0];
        MAIN [label="POLY LINE STATES"];
        FILL_F [label="FILLED POLYGON"];
    }

    S_IDLE [label="1 · IDLE\n─────────────────\nHAS_LAST = FALSE\nPOINT_COUNT = 0\nNo vertices placed"];
    S_PLACING [label="2 · PLACING VERTICES\n─────────────────\nClick to add vertex\nPOLY_POINTS_X/Y(n)\nPreview line to cursor\nPOINT_COUNT increments"];
    S_PREVIEW [label="3 · PREVIEW\n─────────────────\nWhite outline shown\nAll vertices connected\nMouse → next preview segment\nFrom LAST_X/Y to cursor"];
    S_CLOSING [label="4 · CLOSING POLYGON\n─────────────────\nRightClick near FIRST\nor double-click\nor Enter key\nConnect LAST to FIRST"];
    S_COMMITTED [label="5 · COMMITTED\n─────────────────\nPolygon finalized\nHISTORY_record_brush()\nFILLED: POLY_FILL_scanline()\nOUTLINE: edge lines drawn"];

    S_IDLE -> S_PLACING [label="  B1 click on canvas\n  FIRST_X/Y = click\n  HAS_LAST = TRUE" color="#66cc66"];
    S_PLACING -> S_PREVIEW [label="  First vertex placed\n  Preview edge drawn" color="#66cc66"];
    S_PREVIEW -> S_PLACING [label="  B1 click\n  Add vertex at cursor\n  POINT_COUNT++" color="#66cc66"];
    S_PREVIEW -> S_CLOSING [label="  B2 click near FIRST\n  or double-click near\n  FIRST_X/Y\n  or Enter key" color="#cccc66"];
    S_CLOSING -> S_COMMITTED [label="  Auto-close polygon\n  Draw LAST → FIRST\n  HISTORY_record_brush()" color="#cccc66"];
    S_COMMITTED -> S_IDLE [label="  POLY_LINE_reset()\n  HAS_LAST = FALSE\n  POINT_COUNT = 0" color="#6699ff"];
    S_PREVIEW -> S_IDLE [label="  Escape pressed\n  POLY_LINE_reset()\n  Cancel polygon" color="#cc6666" style=dashed];

    subgraph cluster_filled {
        label="FILLED vs OUTLINE MODE" labelloc=t labeljust=l
        fontcolor=orange fontsize=11.0 fontname="Cascadia Code PL"
        color=orange style=dashed penwidth=1

        FM_OUTLINE [label="Poly Line (Outline)\n────────────\nCURRENT_TOOL% = TOOL_POLY_LINE\nFILLED = FALSE\nDraw edges only\nBresenham per segment" fontsize=10.0];
        FM_FILLED [label="Poly Fill (Filled)\n────────────\nCURRENT_TOOL% = TOOL_POLY_FILL\nFILLED = TRUE\nPOLY_FILL_scanline()\nScanline fill algorithm" fontsize=10.0];

        FM_OUTLINE -> FM_FILLED [label=" Select POLY_FILL tool" color="#6699ff" fontsize=8.0];
        FM_FILLED -> FM_OUTLINE [label=" Select POLY_LINE tool" color="#6699ff" fontsize=8.0];
    }

    MAIN -> S_IDLE [arrowhead=none color="#555555" style=dotted];
    FILL_F -> FM_OUTLINE [arrowhead=none color="#555555" style=dotted lhead=cluster_filled];
    { rank=min; MAIN; FILL_F }

    subgraph cluster_legend {
        label="LEGEND" labelloc=t labeljust=l
        fontcolor=white fontsize=11.0 fontname="Cascadia Code PL"
        color=white style=dashed penwidth=1
        L1 [label="" shape=point width=0.01]; L2 [label="" shape=point width=0.01];
        L3 [label="" shape=point width=0.01]; L4 [label="" shape=point width=0.01];
        L5 [label="" shape=point width=0.01]; L6 [label="" shape=point width=0.01];
        L7 [label="" shape=point width=0.01]; L8 [label="" shape=point width=0.01];
        L1 -> L2 [label=" Place Vertex / Activate" arrowhead=normal color="#66cc66" fontsize=9.0];
        L3 -> L4 [label=" Cancel / Escape" arrowhead=normal color="#cc6666" style=dashed fontsize=9.0];
        L5 -> L6 [label=" Close / Commit" arrowhead=normal color="#cccc66" fontsize=9.0];
        L7 -> L8 [label=" Reset / Mode Switch" arrowhead=normal color="#6699ff" fontsize=9.0];
    }
}
