digraph SPRAY_TOOL {
    label="SPRAY TOOL STATE MACHINE" labelloc=t labeljust=c
    ordering=out rankdir=TB
    fontcolor=white fontsize=24.0 fontname="Cascadia Code PL"
    splines=true compound=true
    bgcolor=transparent
    edge [
        color=gray fontcolor="#aaaaaa" fontsize=9.0
        fontname="Cascadia Code PL"
    ];
    node [
        color=white shape=rect style=""
        fontname="Cascadia Code PL" fontsize=11.0 fontcolor=cyan
    ];

    { node [shape=folder color=orange penwidth=2 fontcolor=orange fontsize=13.0];
        MAIN [label="SPRAY STATES"];
    }

    S_IDLE [label="1 · IDLE\n─────────────────\nCURRENT_TOOL% = TOOL_SPRAY\nSPRAY.ACTIVE = FALSE\nCursor: spray can icon"];
    S_SPRAYING [label="2 · SPRAYING\n─────────────────\nB1 held on canvas\nRandomized pixel burst\nwithin BRUSH_SIZE radius\nDensity per frame tick\nPAINT_pset_with_symmetry()"];
    S_CONTINUOUS [label="3 · CONTINUOUS\n─────────────────\nB1 held + drag\nSpray follows cursor\nAccumulates spray density\nover time per position"];
    S_COMMITTED [label="4 · COMMITTED\n─────────────────\nB1 released\nHISTORY_record_brush()\nSPRAY.HISTORY_BEFORE_IMG\nLayer contentDirty%"];

    S_IDLE -> S_SPRAYING [label="  B1 press on canvas\n  Capture BEFORE_IMG\n  Start spray burst" color="#66cc66"];
    S_SPRAYING -> S_CONTINUOUS [label="  B1 held + movement\n  Spray follows cursor" color="#66cc66"];
    S_SPRAYING -> S_SPRAYING [label="  B1 held stationary\n  Accumulate spray\n  density increases" color="#88aacc"];
    S_CONTINUOUS -> S_CONTINUOUS [label="  B1 held + movement\n  Spray at new position" color="#88aacc"];
    S_CONTINUOUS -> S_COMMITTED [label="  B1 released\n  HISTORY_record_brush()" color="#cccc66"];
    S_SPRAYING -> S_COMMITTED [label="  B1 released\n  HISTORY_record_brush()" color="#cccc66"];
    S_COMMITTED -> S_IDLE [label="  Ready for\n  next spray" color="#6699ff"];

    MAIN -> S_IDLE [arrowhead=none color="#555555" style=dotted];
    { rank=min; MAIN }

    subgraph cluster_legend {
        label="LEGEND" labelloc=t labeljust=l
        fontcolor=white fontsize=11.0 fontname="Cascadia Code PL"
        color=white style=dashed penwidth=1
        L1 [label="" shape=point width=0.01]; L2 [label="" shape=point width=0.01];
        L3 [label="" shape=point width=0.01]; L4 [label="" shape=point width=0.01];
        L5 [label="" shape=point width=0.01]; L6 [label="" shape=point width=0.01];
        L1 -> L2 [label=" Activate / Spray" arrowhead=normal color="#66cc66" fontsize=9.0];
        L3 -> L4 [label=" Commit to History" arrowhead=normal color="#cccc66" fontsize=9.0];
        L5 -> L6 [label=" Ready / Re-enter" arrowhead=normal color="#6699ff" fontsize=9.0];
    }
}
