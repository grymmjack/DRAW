digraph FILL_TOOL {
    label="FILL (FLOOD FILL) TOOL STATE MACHINE" labelloc=t labeljust=c
    ordering=out rankdir=TB
    fontcolor=white fontsize=24.0 fontname="Cascadia Code PL"
    splines=true compound=true
    bgcolor=transparent
    edge [
        color=gray fontcolor="#aaaaaa" fontsize=9.0
        fontname="Cascadia Code PL"
    ];
    node [
        color=white shape=rect style=""
        fontname="Cascadia Code PL" fontsize=11.0 fontcolor=cyan
    ];

    { node [shape=folder color=orange penwidth=2 fontcolor=orange fontsize=13.0];
        MAIN [label="FILL STATES"];
        ADJ_F [label="FILL ADJUST (F8)"];
    }

    S_IDLE [label="1 · IDLE\n─────────────────\nCURRENT_TOOL% = TOOL_FILL\nFILL.ACTIVE = FALSE\nCursor: bucket icon"];
    S_FILLING [label="2 · FILLING\n─────────────────\nB1 click on canvas\nFlood fill at UNSNAPPED_X/Y\nFILL_generate_mask%()\nQueue-based fill algorithm"];
    S_COMMITTED [label="3 · COMMITTED\n─────────────────\nFill complete\nHISTORY_record_brush()\nFILL.BEFORE_IMG saved\nLayer contentDirty%"];
    S_FILL_ADJ [label="4 · FILL ADJUST MODE\n─────────────────\nFILL_ADJ.ACTIVE% = TRUE\nInteractive overlay shown\nL-handle for tile origin\n+ X/Y scale controls"];

    S_IDLE -> S_FILLING [label="  B1 click on canvas\n  FILL_flood() initiated\n  Capture BEFORE_IMG" color="#66cc66"];
    S_FILLING -> S_COMMITTED [label="  Fill complete\n  FILL_ADJ.ENABLED = FALSE\n  HISTORY_record_brush()" color="#cccc66"];
    S_FILLING -> S_FILL_ADJ [label="  Fill complete +\n  FILL_ADJ.ENABLED = TRUE\n  Enter adjustment mode" color="#cc66cc"];
    S_COMMITTED -> S_IDLE [label="  Ready for\n  next fill" color="#6699ff"];
    S_FILL_ADJ -> S_COMMITTED [label="  Enter → commit\n  FILL_ADJ_commit()\n  HISTORY_record_brush()" color="#cccc66"];
    S_FILL_ADJ -> S_IDLE [label="  Escape → cancel\n  FILL_ADJ_cancel()\n  Restore CANCEL_IMG" color="#cc6666" style=dashed];

    subgraph cluster_filladj {
        label="FILL ADJUST OVERLAY — F8 Toggle" labelloc=t labeljust=l
        fontcolor=orange fontsize=11.0 fontname="Cascadia Code PL"
        color=orange style=dashed penwidth=1

        FA_DISABLED [label="F8 Disabled\n────────────\nFILL_ADJ.ENABLED = FALSE\nFills commit immediately\nNo interactive overlay" fontsize=10.0];
        FA_ENABLED [label="F8 Enabled\n────────────\nFILL_ADJ.ENABLED = TRUE\nNext fill/shape enters\nadjustment mode" fontsize=10.0];
        FA_ACTIVE [label="Interactive Overlay\n────────────\nFILL_ADJ.ACTIVE = TRUE\nDrag body: pan tile origin\nDrag corner: uniform scale\nDrag H arm: scale X only\nDrag V arm: scale Y only\nScroll: uniform scale" fontsize=10.0];

        FA_DISABLED -> FA_ENABLED [label=" F8 toggle\n FILL_ADJ_toggle_enabled()" color="#66cc66" fontsize=8.0];
        FA_ENABLED -> FA_ACTIVE [label=" Fill/shape release\n FILL_ADJ_enter_*()" color="#66cc66" fontsize=8.0];
        FA_ACTIVE -> FA_ENABLED [label=" Enter/Escape\n commit or cancel" color="#cccc66" fontsize=8.0];
        FA_ENABLED -> FA_DISABLED [label=" F8 toggle\n Disabled again" color="#cc6666" fontsize=8.0 style=dashed];
    }

    subgraph cluster_drag {
        label="FILL ADJUST DRAG MODES" labelloc=t labeljust=l
        fontcolor=orange fontsize=11.0 fontname="Cascadia Code PL"
        color=orange style=dashed penwidth=1

        DM_NONE [label="DRAG_NONE\n────────\nNo drag active\nOverlay idle" fontsize=9.0];
        DM_PAN [label="DRAG_PAN\n────────\nBody drag\nMove tile origin\nORIGIN_X/Y changes" fontsize=9.0];
        DM_UNIFORM [label="DRAG_UNIFORM\n────────\nCorner drag\nScale TILE_W + TILE_H\nProportional" fontsize=9.0];
        DM_SCALE_X [label="DRAG_SCALE_X\n────────\nH arm drag\nScale TILE_W only\nIndependent X" fontsize=9.0];
        DM_SCALE_Y [label="DRAG_SCALE_Y\n────────\nV arm drag\nScale TILE_H only\nIndependent Y" fontsize=9.0];

        DM_NONE -> DM_PAN [label=" Hit body" color="#66cc66" fontsize=7.0];
        DM_NONE -> DM_UNIFORM [label=" Hit corner" color="#66cc66" fontsize=7.0];
        DM_NONE -> DM_SCALE_X [label=" Hit H arm" color="#66cc66" fontsize=7.0];
        DM_NONE -> DM_SCALE_Y [label=" Hit V arm" color="#66cc66" fontsize=7.0];
        DM_PAN -> DM_NONE [label=" Release" color="#cc6666" fontsize=7.0 style=dashed];
        DM_UNIFORM -> DM_NONE [label=" Release" color="#cc6666" fontsize=7.0 style=dashed];
        DM_SCALE_X -> DM_NONE [label=" Release" color="#cc6666" fontsize=7.0 style=dashed];
        DM_SCALE_Y -> DM_NONE [label=" Release" color="#cc6666" fontsize=7.0 style=dashed];
    }

    subgraph cluster_shapes {
        label="FILL ADJUST ENTRY POINTS" labelloc=t labeljust=l
        fontcolor=orange fontsize=11.0 fontname="Cascadia Code PL"
        color=orange style=dashed penwidth=1

        EP_FLOOD [label="Flood Fill\n────────\nFILL_ADJ_enter_flood()\nSHAPE_TYPE = FLOOD\nFILL_MASK from seed" fontsize=9.0];
        EP_RECT [label="Rectangle\n────────\nFILL_ADJ_enter_rect()\nSHAPE_TYPE = RECT\nRECT_X1/Y1/X2/Y2" fontsize=9.0];
        EP_ELLIPSE [label="Ellipse\n────────\nFILL_ADJ_enter_ellipse()\nSHAPE_TYPE = ELLIPSE\nELL_CX/CY/RX/RY" fontsize=9.0];
        EP_POLYGON [label="Polygon\n────────\nFILL_ADJ_enter_polygon()\nSHAPE_TYPE = POLYGON\nPOLY_COUNT vertices" fontsize=9.0];
    }

    MAIN -> S_IDLE [arrowhead=none color="#555555" style=dotted];
    ADJ_F -> FA_DISABLED [arrowhead=none color="#555555" style=dotted lhead=cluster_filladj];
    { rank=min; MAIN; ADJ_F }

    subgraph cluster_legend {
        label="LEGEND" labelloc=t labeljust=l
        fontcolor=white fontsize=11.0 fontname="Cascadia Code PL"
        color=white style=dashed penwidth=1
        L1 [label="" shape=point width=0.01]; L2 [label="" shape=point width=0.01];
        L3 [label="" shape=point width=0.01]; L4 [label="" shape=point width=0.01];
        L5 [label="" shape=point width=0.01]; L6 [label="" shape=point width=0.01];
        L7 [label="" shape=point width=0.01]; L8 [label="" shape=point width=0.01];
        L9 [label="" shape=point width=0.01]; L10 [label="" shape=point width=0.01];
        L1 -> L2 [label=" Activate / Fill" arrowhead=normal color="#66cc66" fontsize=9.0];
        L3 -> L4 [label=" Cancel / Deactivate" arrowhead=normal color="#cc6666" style=dashed fontsize=9.0];
        L5 -> L6 [label=" Commit to History" arrowhead=normal color="#cccc66" fontsize=9.0];
        L7 -> L8 [label=" Ready / Re-enter" arrowhead=normal color="#6699ff" fontsize=9.0];
        L9 -> L10 [label=" Special (Adjust Mode)" arrowhead=normal color="#cc66cc" fontsize=9.0];
    }
}
