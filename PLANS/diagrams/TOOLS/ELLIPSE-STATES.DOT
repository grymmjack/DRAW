digraph ELLIPSE_TOOL {
    label="ELLIPSE / FILLED ELLIPSE TOOL STATE MACHINE" labelloc=t labeljust=c
    ordering=out rankdir=TB
    fontcolor=white fontsize=24.0 fontname="Cascadia Code PL"
    splines=true compound=true
    bgcolor=transparent
    edge [
        color=gray fontcolor="#aaaaaa" fontsize=9.0
        fontname="Cascadia Code PL"
    ];
    node [
        color=white shape=rect style=""
        fontname="Cascadia Code PL" fontsize=11.0 fontcolor=cyan
    ];

    { node [shape=folder color=orange penwidth=2 fontcolor=orange fontsize=13.0];
        MAIN [label="ELLIPSE STATES"];
        MODS [label="MODIFIERS"];
    }

    S_IDLE [label="1 · IDLE\n─────────────────\nELLIPSE_TOOL.DRAGGING = FALSE\nCursor: crosshair"];
    S_DRAGGING [label="2 · DRAGGING\n─────────────────\nELLIPSE_TOOL.DRAGGING = TRUE\nPreview ellipse rendered\nCIRCLE instruction\nSTART_X/Y to END_X/Y"];
    S_COMMITTED [label="3 · COMMITTED\n─────────────────\nB1 released\nEllipse drawn to layer\nHISTORY_record_brush()\nDRAGGING = FALSE"];

    S_IDLE -> S_DRAGGING [label="  B1 press on canvas\n  START_X/Y = cursor\n  DRAGGING = TRUE" color="#66cc66"];
    S_DRAGGING -> S_DRAGGING [label="  B1 held + movement\n  Update END_X/Y\n  Preview ellipse each frame" color="#88aacc"];
    S_DRAGGING -> S_COMMITTED [label="  B1 released\n  Commit to layer\n  HISTORY_record_brush()" color="#cccc66"];
    S_COMMITTED -> S_IDLE [label="  Ready for\n  next ellipse" color="#6699ff"];

    subgraph cluster_modes {
        label="ELLIPSE MODES" labelloc=t labeljust=l
        fontcolor=orange fontsize=11.0 fontname="Cascadia Code PL"
        color=orange style=dashed penwidth=1

        EM_OUTLINE [label="Outline\n────────────\nFILLED = FALSE\nCURRENT_TOOL% = TOOL_ELLIPSE\nDraw border only\nCIRCLE step" fontsize=10.0];
        EM_FILLED [label="Filled\n────────────\nFILLED = TRUE\nCURRENT_TOOL% = TOOL_ELLIPSE_FILL\nFill + border\nScanline fill" fontsize=10.0];

        EM_OUTLINE -> EM_FILLED [label=" Select ELLIPSE_FILL tool" color="#6699ff" fontsize=8.0];
        EM_FILLED -> EM_OUTLINE [label=" Select ELLIPSE tool" color="#6699ff" fontsize=8.0];
    }

    subgraph cluster_mods {
        label="DRAW MODIFIERS" labelloc=t labeljust=l
        fontcolor=orange fontsize=11.0 fontname="Cascadia Code PL"
        color=orange style=dashed penwidth=1

        M_FREE [label="Free Form\n────────────\nAny ellipse shape\nVariable radii" fontsize=10.0];
        M_CIRCLE [label="Shift → Circle\n────────────\nradius_X = radius_Y\nForce perfect circle" fontsize=10.0];
        M_CENTER [label="Ctrl → From Center\n────────────\nCENTER_X/Y = START\nEllipse expands outward\naround click point" fontsize=10.0];
        M_BOTH [label="Ctrl+Shift\n────────────\nCircle from center\nBoth constraints" fontsize=10.0];

        M_FREE -> M_CIRCLE [label=" Shift" color="#66cc66" fontsize=8.0];
        M_FREE -> M_CENTER [label=" Ctrl" color="#66cc66" fontsize=8.0];
        M_CIRCLE -> M_BOTH [label=" +Ctrl" color="#66cc66" fontsize=8.0];
        M_CENTER -> M_BOTH [label=" +Shift" color="#66cc66" fontsize=8.0];
        M_BOTH -> M_FREE [label=" Release all" color="#cc6666" fontsize=8.0 style=dashed];
    }

    MAIN -> S_IDLE [arrowhead=none color="#555555" style=dotted];
    MODS -> M_FREE [arrowhead=none color="#555555" style=dotted lhead=cluster_mods];
    { rank=min; MAIN; MODS }

    subgraph cluster_legend {
        label="LEGEND" labelloc=t labeljust=l
        fontcolor=white fontsize=11.0 fontname="Cascadia Code PL"
        color=white style=dashed penwidth=1
        L1 [label="" shape=point width=0.01]; L2 [label="" shape=point width=0.01];
        L3 [label="" shape=point width=0.01]; L4 [label="" shape=point width=0.01];
        L5 [label="" shape=point width=0.01]; L6 [label="" shape=point width=0.01];
        L1 -> L2 [label=" Activate / Draw" arrowhead=normal color="#66cc66" fontsize=9.0];
        L3 -> L4 [label=" Commit to History" arrowhead=normal color="#cccc66" fontsize=9.0];
        L5 -> L6 [label=" Reset / Mode Switch" arrowhead=normal color="#6699ff" fontsize=9.0];
    }
}
