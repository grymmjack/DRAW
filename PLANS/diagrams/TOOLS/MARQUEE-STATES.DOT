digraph MARQUEE_TOOL {
    label="MARQUEE TOOL STATE MACHINE" labelloc=t labeljust=c
    ordering=out rankdir=TB
    fontcolor=white fontsize=24.0 fontname="Cascadia Code PL"
    splines=true compound=true
    bgcolor=transparent
    edge [
        color=gray fontcolor="#aaaaaa" fontsize=9.0
        fontname="Cascadia Code PL"
    ];
    node [
        color=white shape=rect style=""
        fontname="Cascadia Code PL" fontsize=11.0 fontcolor=cyan
    ];

    { node [shape=folder color=orange penwidth=2 fontcolor=orange fontsize=13.0];
        MAIN [label="MAIN STATES"];
        SHAPES [label="SELECTION SHAPES"];
        MODES_F [label="SELECTION MODES"];
    }

    // ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
    //  MAIN STATES
    // ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ

    S_IDLE [label="1 ¬∑ IDLE\n‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ\nNo selection active\nMARQUEE.active% = FALSE\nMarching ants not visible"];
    S_DRAWING [label="2 ¬∑ DRAWING SELECTION\n‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ\nB1 drag on canvas\nRubberband preview\nShape depends on mode\nShift = square/circle"];
    S_ACTIVE [label="3 ¬∑ SELECTION ACTIVE\n‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ\nMARQUEE.active% = TRUE\nMarching ants animation\nSelection mask valid\nCopy/Cut/Move available"];
    S_MODIFY [label="4 ¬∑ MODIFYING SELECTION\n‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ\nAdd/Subtract/Intersect\nShift+drag = add\nAlt+drag = subtract\nShift+Alt+drag = intersect"];
    S_MOVING [label="5 ¬∑ MOVING SELECTION\n‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ\nDrag inside selection\nFloat and move content\nMOVE tool integration"];

    S_IDLE -> S_DRAWING [label="  B1 drag on canvas\n  Start selection shape" color="#66cc66"];
    S_DRAWING -> S_ACTIVE [label="  B1 released\n  Selection mask created\n  Marching ants start" color="#cccc66"];
    S_ACTIVE -> S_MODIFY [label="  Shift/Alt+B1 drag\n  Add/subtract selection" color="#66cc66"];
    S_MODIFY -> S_ACTIVE [label="  B1 released\n  Selection updated" color="#cccc66"];
    S_ACTIVE -> S_MOVING [label="  B1 drag inside selection\n  Float content" color="#66cc66"];
    S_MOVING -> S_ACTIVE [label="  B1 released\n  Content placed" color="#cccc66"];
    S_ACTIVE -> S_IDLE [label="  Escape / Ctrl+D\n  Deselect all\n  MARQUEE_reset()" color="#cc6666" style=dashed];
    S_ACTIVE -> S_DRAWING [label="  B1 outside selection\n  Start new selection\n  (Replace mode)" color="#66cc66"];
    S_DRAWING -> S_IDLE [label="  Escape\n  Cancel drawing" color="#cc6666" style=dashed];

    // ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
    //  SELECTION SHAPES
    // ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ

    subgraph cluster_shapes {
        label="SELECTION SHAPES ‚Äî 5 MARQUEE TYPES" labelloc=t labeljust=l
        fontcolor=orange fontsize=11.0 fontname="Cascadia Code PL"
        color=orange style=dashed penwidth=1

        SH_RECT [label="Rectangle\n‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ\nTOOL_SELECT_RECT\nDrag corner-to-corner\nShift = square\nStandard selection box"
                 fontsize=10.0];
        SH_FREE [label="Freehand\n‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ\nTOOL_SELECT_FREEHAND\nDraw freeform boundary\nAuto-close on release\nIrregular selection"
                 fontsize=10.0];
        SH_POLY [label="Polygonal\n‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ\nTOOL_SELECT_POLYGON\nClick to add vertices\nDouble-click to close\nStraight-edge selection"
                 fontsize=10.0];
        SH_ELLIPSE [label="Ellipse\n‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ\nTOOL_SELECT_ELLIPSE\nDrag bounding box\nShift = circle\nElliptical selection"
                    fontsize=10.0];
        SH_WAND [label="Magic Wand\n‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ\nTOOL_SELECT_WAND\nClick to flood-select\nTolerance-based\nContiguous similar colors"
                 fontsize=10.0];
    }

    // ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
    //  SELECTION MODES
    // ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ

    subgraph cluster_modes {
        label="SELECTION MODES ‚Äî Combine Behavior" labelloc=t labeljust=l
        fontcolor=orange fontsize=11.0 fontname="Cascadia Code PL"
        color=orange style=dashed penwidth=1

        MD_REPLACE [label="Replace\n‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ\nNo modifier held\nNew selection replaces\nprevious entirely"
                    fontsize=10.0];
        MD_ADD [label="Add\n‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ\nShift held\nNew area added to\nexisting selection"
                fontsize=10.0];
        MD_SUBTRACT [label="Subtract\n‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ\nAlt held\nNew area removed from\nexisting selection"
                     fontsize=10.0];
        MD_INTERSECT [label="Intersect\n‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ\nShift+Alt held\nKeep only overlap of\nnew and existing"
                      fontsize=10.0];

        MD_REPLACE -> MD_ADD [label=" +Shift" color="#88aacc" fontsize=8.0];
        MD_REPLACE -> MD_SUBTRACT [label=" +Alt" color="#88aacc" fontsize=8.0];
        MD_ADD -> MD_INTERSECT [label=" +Alt" color="#88aacc" fontsize=8.0];
        MD_SUBTRACT -> MD_INTERSECT [label=" +Shift" color="#88aacc" fontsize=8.0];
    }

    // ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ
    //  OPERATIONS ON SELECTION
    // ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ

    subgraph cluster_ops {
        label="SELECTION OPERATIONS" labelloc=t labeljust=l
        fontcolor=orange fontsize=11.0 fontname="Cascadia Code PL"
        color=orange style=dashed penwidth=1

        OP_COPY [label="Copy (Ctrl+C)\n‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ\nCopy selected pixels\nto clipboard" fontsize=10.0];
        OP_CUT [label="Cut (Ctrl+X)\n‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ\nCopy + clear selected\narea to transparent" fontsize=10.0];
        OP_PASTE [label="Paste (Ctrl+V)\n‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ\nNew layer with\nclipboard content" fontsize=10.0];
        OP_CLEAR [label="Clear (Del)\n‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ\nFill selection with\ntransparent/BG color" fontsize=10.0];
        OP_ALL [label="Select All (Ctrl+A)\n‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ\nSelect entire canvas" fontsize=10.0];
        OP_INVERT [label="Invert (Ctrl+Shift+I)\n‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ\nInvert selection mask" fontsize=10.0];
        OP_CROP [label="Crop to Selection\n‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ\nResize canvas to\nselection bounds" fontsize=10.0];
    }

    MAIN -> S_IDLE [arrowhead=none color="#555555" style=dotted];
    SHAPES -> SH_RECT [arrowhead=none color="#555555" style=dotted lhead=cluster_shapes];
    MODES_F -> MD_REPLACE [arrowhead=none color="#555555" style=dotted lhead=cluster_modes];
    { rank=min; MAIN; SHAPES; MODES_F }

    subgraph cluster_legend {
        label="LEGEND" labelloc=t labeljust=l
        fontcolor=white fontsize=11.0 fontname="Cascadia Code PL"
        color=white style=dashed penwidth=1
        L1 [label="" shape=point width=0.01]; L2 [label="" shape=point width=0.01];
        L3 [label="" shape=point width=0.01]; L4 [label="" shape=point width=0.01];
        L5 [label="" shape=point width=0.01]; L6 [label="" shape=point width=0.01];
        L1 -> L2 [label=" Start / Modify" arrowhead=normal color="#66cc66" fontsize=9.0];
        L3 -> L4 [label=" Deselect / Cancel" arrowhead=normal color="#cc6666" style=dashed fontsize=9.0];
        L5 -> L6 [label=" Commit / Apply" arrowhead=normal color="#cccc66" fontsize=9.0];
    }
}
