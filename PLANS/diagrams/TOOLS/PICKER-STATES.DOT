digraph COLOR_PICKER {
    label="COLOR PICKER TOOL STATE MACHINE" labelloc=t labeljust=c
    ordering=out rankdir=TB
    fontcolor=white fontsize=24.0 fontname="Cascadia Code PL"
    splines=true compound=true
    bgcolor=transparent
    edge [
        color=gray fontcolor="#aaaaaa" fontsize=9.0
        fontname="Cascadia Code PL"
    ];
    node [
        color=white shape=rect style=""
        fontname="Cascadia Code PL" fontsize=11.0 fontcolor=cyan
    ];

    { node [shape=folder color=orange penwidth=2 fontcolor=orange fontsize=13.0];
        MAIN [label="PICKER STATES"];
        LOUPE_F [label="LOUPE"];
    }

    S_IDLE [label="1 · IDLE\n─────────────────\nCURRENT_TOOL = TOOL_PICKER\nor Alt held (assistant)\nLoupe overlay active\nCursor: eyedropper"];
    S_SAMPLE_FG [label="2 · SAMPLE FG\n─────────────────\nB1 click/drag on canvas\nSample pixel at cursor\nPAINT_COLOR~& = sampled\nPAL_FG_IDX% updated"];
    S_SAMPLE_BG [label="3 · SAMPLE BG\n─────────────────\nB2 click/drag on canvas\nSample pixel at cursor\nPAINT_BG_COLOR~& = sampled"];
    S_CONTINUOUS [label="4 · CONTINUOUS SAMPLE\n─────────────────\nB1 held + dragging\nLive-sample under cursor\nColor updates per frame\nUseful for finding color"];

    S_IDLE -> S_SAMPLE_FG [label="  B1 click on canvas\n  PICKER_sample()" color="#66cc66"];
    S_IDLE -> S_SAMPLE_BG [label="  B2 click on canvas\n  PICKER_sample_bg()" color="#6699ff"];
    S_SAMPLE_FG -> S_IDLE [label="  Click processed\n  FG color set" color="#cccc66"];
    S_SAMPLE_BG -> S_IDLE [label="  Click processed\n  BG color set" color="#cccc66"];
    S_IDLE -> S_CONTINUOUS [label="  B1 drag on canvas\n  Continuous sampling" color="#66cc66"];
    S_CONTINUOUS -> S_CONTINUOUS [label="  B1 held + movement\n  Update color each frame" color="#88aacc"];
    S_CONTINUOUS -> S_IDLE [label="  B1 released\n  Final color set" color="#cccc66"];

    subgraph cluster_loupe {
        label="PICKER LOUPE — Magnified Preview" labelloc=t labeljust=l
        fontcolor=orange fontsize=11.0 fontname="Cascadia Code PL"
        color=orange style=dashed penwidth=1

        LP_OFF [label="Loupe Hidden\n────────────\nNo magnifier displayed\nDefault state" fontsize=10.0];
        LP_ON [label="Loupe Active\n────────────\nLOUPE.visible% = TRUE\n8-16x magnified view\naround cursor position\nHex/RGB overlay shown\nCrosshair on center pixel" fontsize=10.0];
        LP_LOCK [label="Loupe Locked\n────────────\nPosition frozen\nContinue viewing at\nlocked position" fontsize=10.0];

        LP_OFF -> LP_ON [label=" Picker tool active\n or Alt held" color="#66cc66" fontsize=8.0];
        LP_ON -> LP_OFF [label=" Tool switch\n Alt released" color="#cc6666" fontsize=8.0 style=dashed];
        LP_ON -> LP_LOCK [label=" Lock hotkey" color="#88aacc" fontsize=8.0];
        LP_LOCK -> LP_ON [label=" Unlock / move" color="#88aacc" fontsize=8.0];
    }

    subgraph cluster_info {
        label="LOUPE INFO OVERLAY" labelloc=t labeljust=l
        fontcolor=orange fontsize=11.0 fontname="Cascadia Code PL"
        color=orange style=dashed penwidth=1

        INFO [label="Displayed Info\n────────────\nHex color: #RRGGBB\nRGB: (R, G, B)\nAlpha value\nPalette index (if match)\nCoordinate position" fontsize=10.0];
    }

    MAIN -> S_IDLE [arrowhead=none color="#555555" style=dotted];
    LOUPE_F -> LP_OFF [arrowhead=none color="#555555" style=dotted lhead=cluster_loupe];
    { rank=min; MAIN; LOUPE_F }

    subgraph cluster_legend {
        label="LEGEND" labelloc=t labeljust=l
        fontcolor=white fontsize=11.0 fontname="Cascadia Code PL"
        color=white style=dashed penwidth=1
        L1 [label="" shape=point width=0.01]; L2 [label="" shape=point width=0.01];
        L3 [label="" shape=point width=0.01]; L4 [label="" shape=point width=0.01];
        L5 [label="" shape=point width=0.01]; L6 [label="" shape=point width=0.01];
        L1 -> L2 [label=" Sample / Activate" arrowhead=normal color="#66cc66" fontsize=9.0];
        L3 -> L4 [label=" Release / Deactivate" arrowhead=normal color="#cc6666" style=dashed fontsize=9.0];
        L5 -> L6 [label=" Color Set" arrowhead=normal color="#cccc66" fontsize=9.0];
    }
}
