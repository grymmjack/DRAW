digraph SAVE_TOOL {
    label="SAVE / QB64 CODE / EXPORT TOOL STATE MACHINE" labelloc=t labeljust=c
    ordering=out rankdir=TB
    fontcolor=white fontsize=24.0 fontname="Cascadia Code PL"
    splines=true compound=true
    bgcolor=transparent
    edge [
        color=gray fontcolor="#aaaaaa" fontsize=9.0
        fontname="Cascadia Code PL"
    ];
    node [
        color=white shape=rect style=""
        fontname="Cascadia Code PL" fontsize=11.0 fontcolor=cyan
    ];

    { node [shape=folder color=orange penwidth=2 fontcolor=orange fontsize=13.0];
        SAVE_F [label="SAVE / EXPORT"];
        CODE_F [label="QB64 CODE"];
        LOAD_F [label="LOAD / IMPORT"];
        SELECTION_F [label="EXPORT SELECTION"];
    }

    // в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
    //  SAVE / EXPORT
    // в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

    SV_IDLE [label="1 В· IDLE\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nNo save in progress\nDeferred action = 0"];
    SV_DEFERRED [label="2 В· DEFERRED\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nMOUSE.DEFERRED_ACTION% = 1\nWait for post-render\nMOUSE_input_handler_loop()"];
    SV_DIALOG [label="3 В· FILE DIALOG\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\n_SAVEFILEDIALOG$()\nBlocking native dialog\nUser selects path"];
    SV_WRITING [label="4 В· WRITING\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nDRW_save(filename$)\nor FILE_BMP_save()\nor FILE_BSAVE_save()\nCompress + write"];
    SV_DONE [label="5 В· DONE\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nFile written successfully\nMOUSE_cleanup_after_dialog\nSUPPRESS_FRAMES% = 2"];

    SV_IDLE -> SV_DEFERRED [label="  Ctrl+S or menu Save\n  DEFERRED_ACTION% = 1" color="#66cc66"];
    SV_DEFERRED -> SV_DIALOG [label="  Post-render dispatch\n  _SAVEFILEDIALOG$()" color="#66cc66"];
    SV_DIALOG -> SV_WRITING [label="  User selects file\n  filename$ в‰  \"\"" color="#cccc66"];
    SV_DIALOG -> SV_IDLE [label="  User cancels\n  filename$ = \"\"" color="#cc6666" style=dashed];
    SV_WRITING -> SV_DONE [label="  Write complete\n  MOUSE_cleanup_after_dialog" color="#cccc66"];
    SV_DONE -> SV_IDLE [label="  DEFERRED_ACTION% = 0\n  Ready for next save" color="#6699ff"];

    // в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
    //  QB64 CODE EXPORT
    // в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

    QB_IDLE [label="1 В· IDLE\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nCURRENT_TOOL% = TOOL_CODE\nNo export in progress"];
    QB_DIALOG [label="2 В· FILE DIALOG\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\n_SAVEFILEDIALOG$()\nFilter: *.bas"];
    QB_GENERATE [label="3 В· GENERATING\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nFILE_BAS_save()\nGenerate DATA statements\nRGB/palette encoding\nPixel-by-pixel export"];
    QB_DONE [label="4 В· DONE\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\n.bas file written\nReady to compile in QB64"];

    QB_IDLE -> QB_DIALOG [label="  Click CODE tool\n  or Ctrl+E" color="#66cc66"];
    QB_DIALOG -> QB_GENERATE [label="  User selects file\n  FILE_BAS_save()" color="#cccc66"];
    QB_DIALOG -> QB_IDLE [label="  User cancels" color="#cc6666" style=dashed];
    QB_GENERATE -> QB_DONE [label="  Export complete" color="#cccc66"];
    QB_DONE -> QB_IDLE [label="  Ready for next" color="#6699ff"];

    // в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
    //  LOAD / OPEN
    // в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

    LD_IDLE [label="1 В· IDLE\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nNo load in progress\nDEFERRED_ACTION% = 0"];
    LD_DEFERRED [label="2 В· DEFERRED\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nMOUSE.DEFERRED_ACTION% = 3\nWait for post-render"];
    LD_DIALOG [label="3 В· FILE DIALOG\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\n_OPENFILEDIALOG$()\nFilter: *.drw;*.png;*.bmp"];
    LD_LOADING [label="4 В· LOADING\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nDRW_load(filename$)\nReset all tool state\nRestore layers + palette"];
    LD_DONE [label="5 В· DONE\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nFile loaded successfully\nDRW_load_binary resets\nall tool/panel state"];

    LD_IDLE -> LD_DEFERRED [label="  Ctrl+O or menu Open\n  DEFERRED_ACTION% = 3" color="#66cc66"];
    LD_DEFERRED -> LD_DIALOG [label="  Post-render dispatch\n  _OPENFILEDIALOG$()" color="#66cc66"];
    LD_DIALOG -> LD_LOADING [label="  User selects file\n  DRW_load()" color="#cccc66"];
    LD_DIALOG -> LD_IDLE [label="  User cancels" color="#cc6666" style=dashed];
    LD_LOADING -> LD_DONE [label="  Load complete\n  MOUSE_cleanup_after_dialog" color="#cccc66"];
    LD_DONE -> LD_IDLE [label="  DEFERRED_ACTION% = 0" color="#6699ff"];

    // в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
    //  EXPORT SELECTION
    // в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

    EX_IDLE [label="1 В· IDLE\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nCURRENT_TOOL% = TOOL_EXPORT_SEL\nNeeds active marquee"];
    EX_CHECK [label="2 В· CHECK SELECTION\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nVerify MARQUEE.ACTIVE\nCopy marquee region\nto temp image buffer"];
    EX_DIALOG [label="3 В· FILE DIALOG\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\n_SAVEFILEDIALOG$()\nFilter: *.png"];
    EX_SAVING [label="4 В· SAVING\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\n_SAVEIMAGE(tempImg&,\nfilename$)\nPNG with alpha"];
    EX_DONE [label="5 В· DONE\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nSelection exported\nTemp image freed\nCleanup after dialog"];

    EX_IDLE -> EX_CHECK [label="  Click EXPORT_SEL tool\n  or Ctrl+Shift+E" color="#66cc66"];
    EX_CHECK -> EX_DIALOG [label="  Marquee active\n  Pixels captured" color="#cccc66"];
    EX_CHECK -> EX_IDLE [label="  No active marquee\n  Show message" color="#cc6666" style=dashed];
    EX_DIALOG -> EX_SAVING [label="  User selects file" color="#cccc66"];
    EX_DIALOG -> EX_IDLE [label="  User cancels" color="#cc6666" style=dashed];
    EX_SAVING -> EX_DONE [label="  Export complete" color="#cccc66"];
    EX_DONE -> EX_IDLE [label="  Ready for next" color="#6699ff"];

    SAVE_F -> SV_IDLE [arrowhead=none color="#555555" style=dotted];
    CODE_F -> QB_IDLE [arrowhead=none color="#555555" style=dotted];
    LOAD_F -> LD_IDLE [arrowhead=none color="#555555" style=dotted];
    SELECTION_F -> EX_IDLE [arrowhead=none color="#555555" style=dotted];
    { rank=min; SAVE_F; CODE_F; LOAD_F; SELECTION_F }

    subgraph cluster_legend {
        label="LEGEND" labelloc=t labeljust=l
        fontcolor=white fontsize=11.0 fontname="Cascadia Code PL"
        color=white style=dashed penwidth=1
        L1 [label="" shape=point width=0.01]; L2 [label="" shape=point width=0.01];
        L3 [label="" shape=point width=0.01]; L4 [label="" shape=point width=0.01];
        L5 [label="" shape=point width=0.01]; L6 [label="" shape=point width=0.01];
        L7 [label="" shape=point width=0.01]; L8 [label="" shape=point width=0.01];
        L1 -> L2 [label=" Initiate / Activate" arrowhead=normal color="#66cc66" fontsize=9.0];
        L3 -> L4 [label=" Cancel / Abort" arrowhead=normal color="#cc6666" style=dashed fontsize=9.0];
        L5 -> L6 [label=" Complete / Commit" arrowhead=normal color="#cccc66" fontsize=9.0];
        L7 -> L8 [label=" Reset / Ready" arrowhead=normal color="#6699ff" fontsize=9.0];
    }
}
