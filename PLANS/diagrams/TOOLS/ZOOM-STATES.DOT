digraph ZOOM_TOOL {
    label="ZOOM TOOL STATE MACHINE" labelloc=t labeljust=c
    ordering=out rankdir=TB
    fontcolor=white fontsize=24.0 fontname="Cascadia Code PL"
    splines=true compound=true
    bgcolor=transparent
    edge [
        color=gray fontcolor="#aaaaaa" fontsize=9.0
        fontname="Cascadia Code PL"
    ];
    node [
        color=white shape=rect style=""
        fontname="Cascadia Code PL" fontsize=11.0 fontcolor=cyan
    ];

    { node [shape=folder color=orange penwidth=2 fontcolor=orange fontsize=13.0];
        MAIN [label="ZOOM STATES"];
    }

    S_IDLE [label="1 В· IDLE\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nCURRENT_TOOL = TOOL_ZOOM\nor Ctrl+Alt held (assistant)\nCursor: magnifier"];
    S_ZOOM_IN [label="2 В· ZOOM IN\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nB1 click or + key\nSCRN.zoomLevel! increases\nSnap to next level:\n25в†’50в†’100в†’200в†’400в†’800%"];
    S_ZOOM_OUT [label="3 В· ZOOM OUT\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nB2 click or - key\nSCRN.zoomLevel! decreases\nSnap to previous level"];
    S_FIT [label="4 В· FIT TO SCREEN\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\n0 key / Menu command\nAuto-calculate zoom\nCenter canvas on screen"];
    S_WHEEL [label="5 В· WHEEL ZOOM\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nMousewheel over canvas\nSmooth zoom steps\nZoom toward cursor position\nSCRN.zoomTarget!"];

    S_IDLE -> S_ZOOM_IN [label="  B1 click / + key\n  Ctrl+Alt+B1 (assistant)" color="#66cc66"];
    S_IDLE -> S_ZOOM_OUT [label="  B2 click / - key\n  Ctrl+Alt+B2 (assistant)" color="#cc6666"];
    S_IDLE -> S_FIT [label="  0 key / CMD 'Fit'\n  Auto-fit zoom" color="#6699ff"];
    S_IDLE -> S_WHEEL [label="  Mousewheel\n  Over canvas area" color="#88aacc"];
    S_ZOOM_IN -> S_IDLE [label="  Zoom applied\n  SCENE_DIRTY% = TRUE" color="#cccc66"];
    S_ZOOM_OUT -> S_IDLE [label="  Zoom applied\n  SCENE_DIRTY% = TRUE" color="#cccc66"];
    S_FIT -> S_IDLE [label="  Zoom + offset set" color="#cccc66"];
    S_WHEEL -> S_IDLE [label="  Wheel event processed" color="#cccc66"];

    subgraph cluster_levels {
        label="ZOOM LEVELS вЂ” Snap Points" labelloc=t labeljust=l
        fontcolor=orange fontsize=11.0 fontname="Cascadia Code PL"
        color=orange style=dashed penwidth=1

        ZL [label="Zoom Snap Levels\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\n25% в†’ 50% в†’ 100%\nв†’ 200% в†’ 400% в†’ 800%\n\nSCRN.zoomLevel! = float\nPixel grid at в‰Ґ 4x\nGrid visible at в‰Ґ 2x" fontsize=10.0];
    }

    MAIN -> S_IDLE [arrowhead=none color="#555555" style=dotted];
    { rank=min; MAIN }
    { rank=same; S_ZOOM_IN; S_ZOOM_OUT }
}
