digraph BRUSH_TOOL {
    label="BRUSH TOOL STATE MACHINE" labelloc=t labeljust=c
    ordering=out rankdir=TB
    fontcolor=white fontsize=24.0 fontname="Cascadia Code PL"
    splines=true compound=true
    bgcolor=transparent
    edge [
        color=gray fontcolor="#aaaaaa" fontsize=9.0
        fontname="Cascadia Code PL"
    ];
    node [
        color=white shape=rect style=""
        fontname="Cascadia Code PL" fontsize=11.0 fontcolor=cyan
    ];

    { node [shape=folder color=orange penwidth=2 fontcolor=orange fontsize=13.0];
        MAIN [label="BRUSH STATES"];
        CUSTOM [label="CUSTOM BRUSH"];
        MODIFIERS_F [label="MODIFIERS"];
        BIN_F [label="BIN / DRAWER"];
        PP_F [label="PIXEL PERFECT"];
    }

    // ─────────────────────────────────────────────────────
    //  MAIN STATES
    // ─────────────────────────────────────────────────────

    S_IDLE [label="1 · IDLE\n─────────────────\nCURRENT_TOOL% = TOOL_BRUSH\nNo stroke active\nCursor: brush preview"];
    S_DRAGGING [label="2 · DRAGGING\n─────────────────\nB1 held + painting\nPAINT_on() per frame\nInterpolate from OLD to NEW\nBRUSH_HISTORY_BEFORE_IMG" ];
    S_COMMITTED [label="3 · COMMITTED\n─────────────────\nB1 released\nHISTORY_record_brush()\nBRUSH_HISTORY_COLOR\nBRUSH_HISTORY_FLAGS"];

    S_IDLE -> S_DRAGGING [label="  B1 press on canvas\n  Capture BEFORE_IMG\n  PAINT_on()" color="#66cc66"];
    S_DRAGGING -> S_DRAGGING [label="  B1 held + movement\n  Interpolate brush stroke\n  PAINT_on() each frame" color="#88aacc"];
    S_DRAGGING -> S_COMMITTED [label="  B1 released\n  HISTORY_record_brush()" color="#cccc66"];
    S_COMMITTED -> S_IDLE [label="  Ready for\n  next stroke" color="#6699ff"];

    // ─────────────────────────────────────────────────────
    //  CUSTOM BRUSH
    // ─────────────────────────────────────────────────────

    subgraph cluster_custom {
        label="CUSTOM BRUSH — Capture & Use" labelloc=t labeljust=l
        fontcolor=orange fontsize=11.0 fontname="Cascadia Code PL"
        color=orange style=dashed penwidth=1

        CB_NONE [label="No Custom Brush\n────────────\nCUSTOM_BRUSH.ACTIVE = FALSE\nStandard circular brush\nfrom BRUSH_SIZE" fontsize=10.0];
        CB_CAPTURE [label="Capture from Marquee\n────────────\nCtrl+B with active marquee\nCopy pixels to\nCUSTOM_BRUSH.IMAGE\nSet WIDTH/HEIGHT" fontsize=10.0];
        CB_LOADED [label="Custom Brush Active\n────────────\nCUSTOM_BRUSH.ACTIVE = TRUE\nIMAGE < -1 (valid)\nCUSTOM_BRUSH_render()\nreplaces circular brush" fontsize=10.0];
        CB_STASHED [label="Brush Stashed\n────────────\nCUSTOM_BRUSH_SAVED.VALID\nStored while non-brush\ntool is selected" fontsize=10.0];

        CB_NONE -> CB_CAPTURE [label=" Ctrl+B\n with marquee" color="#66cc66" fontsize=8.0];
        CB_CAPTURE -> CB_LOADED [label=" Pixels captured\n ACTIVE = TRUE" color="#66cc66" fontsize=8.0];
        CB_LOADED -> CB_STASHED [label=" Switch to\n non-brush tool\n CUSTOM_BRUSH_stash()" color="#888888" fontsize=8.0 style=dotted];
        CB_STASHED -> CB_LOADED [label=" Return to brush\n CUSTOM_BRUSH_unstash()" color="#888888" fontsize=8.0 style=dotted];
        CB_LOADED -> CB_NONE [label=" Ctrl+B (clear)\n CUSTOM_BRUSH_clear()" color="#cc6666" fontsize=8.0 style=dashed];
    }

    subgraph cluster_custom_ops {
        label="CUSTOM BRUSH OPERATIONS" labelloc=t labeljust=l
        fontcolor=orange fontsize=11.0 fontname="Cascadia Code PL"
        color=orange style=dashed penwidth=1

        CO_FLIP_H [label="Flip H\n────────\nFLIP_H = -1 ↔ 0\nToggle horizontal" fontsize=9.0];
        CO_FLIP_V [label="Flip V\n────────\nFLIP_V = -1 ↔ 0\nToggle vertical" fontsize=9.0];
        CO_ROTATE [label="Rotate CW/CCW\n────────\nSwap W↔H\nRotate IMAGE" fontsize=9.0];
        CO_SCALE [label="Scale\n────────\nSCALE factor adjust\nScroll wheel ±0.1" fontsize=9.0];
        CO_RECOLOR [label="Recolor Mode\n────────\nRECOLOR_MODE = TRUE\nAll non-transparent →\nFG color" fontsize=9.0];
        CO_OUTLINE [label="Outline Mode\n────────\nSHOW_OUTLINE = TRUE\nAdd outline around\nbrush silhouette" fontsize=9.0];
        CO_EXPORT [label="Export PNG\n────────\nSave brush to file\nPreserves transparency" fontsize=9.0];
    }

    // ─────────────────────────────────────────────────────
    //  MODIFIERS
    // ─────────────────────────────────────────────────────

    subgraph cluster_modifiers {
        label="BRUSH MODIFIERS" labelloc=t labeljust=l
        fontcolor=orange fontsize=11.0 fontname="Cascadia Code PL"
        color=orange style=dashed penwidth=1

        MOD_NONE [label="No Modifier\n────────────\nFree-form painting\nNo constraints" fontsize=10.0];
        MOD_SHIFT [label="Shift Held\n────────────\nConstraint active\nCONSTRAIN_X% or\nCONSTRAIN_Y% locked\nH/V line forced" fontsize=10.0];
        MOD_CTRL [label="Ctrl Held\n────────────\nSquare brush shape\nBRUSH_SIZE.SHAPE = -1\n(if shape switching on)" fontsize=10.0];
        MOD_ALT [label="Alt Held\n────────────\nClone mode: CLONING%\nClone from reference point\nStamp each drag" fontsize=10.0];

        MOD_NONE -> MOD_SHIFT [label=" Shift" color="#66cc66" fontsize=8.0];
        MOD_NONE -> MOD_CTRL [label=" Ctrl" color="#66cc66" fontsize=8.0];
        MOD_NONE -> MOD_ALT [label=" Alt" color="#66cc66" fontsize=8.0];
        MOD_SHIFT -> MOD_NONE [label=" Released" color="#cc6666" fontsize=8.0 style=dashed];
        MOD_CTRL -> MOD_NONE [label=" Released" color="#cc6666" fontsize=8.0 style=dashed];
        MOD_ALT -> MOD_NONE [label=" Released" color="#cc6666" fontsize=8.0 style=dashed];
    }

    // ─────────────────────────────────────────────────────
    //  BIN / DRAWER INTEGRATION
    // ─────────────────────────────────────────────────────

    subgraph cluster_bin {
        label="DRAWER BIN — Brush/Pattern/Gradient" labelloc=t labeljust=l
        fontcolor=orange fontsize=11.0 fontname="Cascadia Code PL"
        color=orange style=dashed penwidth=1

        BIN_BRUSH [label="Brush Bin Active\n────────────\nDRAWER.mode = BRUSH\nPaint with slot brush\nDRAWER_BRUSH_SLOTS(sel)" fontsize=10.0];
        BIN_PATTERN [label="Pattern Bin Active\n────────────\nDRAWER.mode = PATTERN\nTile fill pattern\nDRAWER_PATTERN_SLOTS(sel)" fontsize=10.0];
        BIN_GRADIENT [label="Gradient Bin Active\n────────────\nDRAWER.mode = GRADIENT\nApply gradient along stroke\nGRAD_DEFS(sel).family" fontsize=10.0];

        BIN_BRUSH -> BIN_PATTERN [label=" Switch to Pattern\n DRAWER_set_mode()" color="#6699ff" fontsize=8.0];
        BIN_PATTERN -> BIN_GRADIENT [label=" Switch to Gradient\n DRAWER_set_mode()" color="#6699ff" fontsize=8.0];
        BIN_GRADIENT -> BIN_BRUSH [label=" Switch to Brush\n DRAWER_set_mode()" color="#6699ff" fontsize=8.0];
    }

    // ─────────────────────────────────────────────────────
    //  PIXEL PERFECT
    // ─────────────────────────────────────────────────────

    subgraph cluster_pp {
        label="PIXEL PERFECT MODE — Ctrl+D" labelloc=t labeljust=l
        fontcolor=orange fontsize=11.0 fontname="Cascadia Code PL"
        color=orange style=dashed penwidth=1

        PPM_OFF [label="Normal Brush\n────────────\nStandard interpolation\nBrush circle stamped\nalong path" fontsize=10.0];
        PPM_ON [label="Pixel Perfect\n────────────\nBRUSH_SIZE.PIXEL_PERFECT=-1\nPP_STROKE() tracks each\npixel placed\nRemoves corner artifacts" fontsize=10.0];

        PPM_OFF -> PPM_ON [label=" Ctrl+D" color="#66cc66" fontsize=8.0];
        PPM_ON -> PPM_OFF [label=" Ctrl+D" color="#cc6666" fontsize=8.0 style=dashed];
    }

    MAIN -> S_IDLE [arrowhead=none color="#555555" style=dotted];
    CUSTOM -> CB_NONE [arrowhead=none color="#555555" style=dotted lhead=cluster_custom];
    MODIFIERS_F -> MOD_NONE [arrowhead=none color="#555555" style=dotted lhead=cluster_modifiers];
    BIN_F -> BIN_BRUSH [arrowhead=none color="#555555" style=dotted lhead=cluster_bin];
    PP_F -> PPM_OFF [arrowhead=none color="#555555" style=dotted lhead=cluster_pp];
    { rank=min; MAIN; CUSTOM; MODIFIERS_F; BIN_F; PP_F }

    // Cross-links
    CB_LOADED -> S_DRAGGING [label="Custom brush painting\nCUSTOM_BRUSH_render()" color="#555555" style=dotted constraint=false];
    BIN_PATTERN -> S_DRAGGING [label="Pattern tile applied\nper stroke pixel" color="#555555" style=dotted constraint=false];
    BIN_GRADIENT -> S_DRAGGING [label="Gradient resolved\nper pixel distance" color="#555555" style=dotted constraint=false];

    subgraph cluster_legend {
        label="LEGEND" labelloc=t labeljust=l
        fontcolor=white fontsize=11.0 fontname="Cascadia Code PL"
        color=white style=dashed penwidth=1
        L1 [label="" shape=point width=0.01]; L2 [label="" shape=point width=0.01];
        L3 [label="" shape=point width=0.01]; L4 [label="" shape=point width=0.01];
        L5 [label="" shape=point width=0.01]; L6 [label="" shape=point width=0.01];
        L7 [label="" shape=point width=0.01]; L8 [label="" shape=point width=0.01];
        L9 [label="" shape=point width=0.01]; L10 [label="" shape=point width=0.01];
        L1 -> L2 [label=" Activate / Draw" arrowhead=normal color="#66cc66" fontsize=9.0];
        L3 -> L4 [label=" Deactivate / Clear" arrowhead=normal color="#cc6666" style=dashed fontsize=9.0];
        L5 -> L6 [label=" Commit to History" arrowhead=normal color="#cccc66" fontsize=9.0];
        L7 -> L8 [label=" Mode Switch / Re-enter" arrowhead=normal color="#6699ff" fontsize=9.0];
        L9 -> L10 [label=" Cross-link" arrowhead=normal color="#555555" style=dotted fontsize=9.0];
    }
}
