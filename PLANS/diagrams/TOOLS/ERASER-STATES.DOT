digraph ERASER_TOOL {
    label="ERASER TOOL STATE MACHINE" labelloc=t labeljust=c
    ordering=out rankdir=TB
    fontcolor=white fontsize=24.0 fontname="Cascadia Code PL"
    splines=true compound=true
    bgcolor=transparent
    edge [
        color=gray fontcolor="#aaaaaa" fontsize=9.0
        fontname="Cascadia Code PL"
    ];
    node [
        color=white shape=rect style=""
        fontname="Cascadia Code PL" fontsize=11.0 fontcolor=cyan
    ];

    { node [shape=folder color=orange penwidth=2 fontcolor=orange fontsize=13.0];
        MAIN [label="ERASER STATES"];
        SMART [label="SMART ERASE"];
        MODES [label="MODES"];
    }

    S_INACTIVE [label="1 В· INACTIVE\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nERASER.ACTIVE = FALSE\nNormal brush painting\nPAINT_COLOR~& is solid"];
    S_ACTIVE [label="2 В· ACTIVE\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nERASER.ACTIVE = TRUE\nCURRENT_TOOL% = TOOL_ERASER\nCursor: eraser icon"];
    S_DRAWING [label="3 В· DRAWING\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nMouse B1 held\nPSET _RGBA32(0,0,0,0)\n_DONTBLEND active\nPAINT_pset_with_symmetry()"];
    S_COMMITTED [label="4 В· COMMITTED\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nMouse released\nHISTORY_record_brush()\nLayer contentDirty% = TRUE"];

    S_INACTIVE -> S_ACTIVE [label="  Select TOOL_ERASER\n  or press E key" color="#66cc66"];
    S_ACTIVE -> S_DRAWING [label="  B1 press on canvas\n  Capture BEFORE_IMG" color="#66cc66"];
    S_DRAWING -> S_DRAWING [label="  B1 held + movement\n  Interpolate erase stroke" color="#88aacc"];
    S_DRAWING -> S_COMMITTED [label="  B1 released\n  HISTORY_record_brush()" color="#cccc66"];
    S_COMMITTED -> S_ACTIVE [label="  Ready for next stroke" color="#6699ff"];
    S_ACTIVE -> S_INACTIVE [label="  Switch to\n  another tool" color="#cc6666" style=dashed];

    subgraph cluster_smart {
        label="SMART ERASE вЂ” Multi-Layer" labelloc=t labeljust=l
        fontcolor=orange fontsize=11.0 fontname="Cascadia Code PL"
        color=orange style=dashed penwidth=1

        SM_OFF [label="Smart Erase Off\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nErase only current layer\nNormal single-layer eraser" fontsize=10.0];
        SM_ON [label="Smart Erase On\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nShift+Erase activates\nERASER_SMART_DIRTY(1-64)\nERASER_SMART_BEFORE_IMG(1-64)\nAll multi-selected layers" fontsize=10.0];
        SM_SAVE [label="Per-Layer Snapshot\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nEach affected layer gets\nindividual BEFORE_IMG\nfor independent undo" fontsize=10.0];

        SM_OFF -> SM_ON [label=" Shift+E held\n Multi-select active" color="#66cc66" fontsize=8.0];
        SM_ON -> SM_SAVE [label=" B1 press\n Snapshot all selected layers" color="#cccc66" fontsize=8.0];
        SM_ON -> SM_OFF [label=" Shift released\n or single-select" color="#cc6666" fontsize=8.0 style=dashed];
    }

    subgraph cluster_modes {
        label="ERASE RENDERING MODES" labelloc=t labeljust=l
        fontcolor=orange fontsize=11.0 fontname="Cascadia Code PL"
        color=orange style=dashed penwidth=1

        M_BRUSH [label="Circular Brush\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nStandard brush shape\nBRUSH_SIZE.CURRENT\nCircle or square" fontsize=10.0];
        M_CUSTOM [label="Custom Brush\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nCUSTOM_BRUSH.ACTIVE% = TRUE\n_DONTBLEND + per-pixel\nPSET _RGBA32(0,0,0,0)" fontsize=10.0];

        M_BRUSH -> M_CUSTOM [label=" Custom brush\n loaded (Ctrl+B)" color="#6699ff" fontsize=8.0];
        M_CUSTOM -> M_BRUSH [label=" Custom brush\n cleared" color="#cc6666" fontsize=8.0 style=dashed];
    }

    MAIN -> S_INACTIVE [arrowhead=none color="#555555" style=dotted];
    SMART -> SM_OFF [arrowhead=none color="#555555" style=dotted lhead=cluster_smart];
    MODES -> M_BRUSH [arrowhead=none color="#555555" style=dotted lhead=cluster_modes];
    { rank=min; MAIN; SMART; MODES }

    subgraph cluster_legend {
        label="LEGEND" labelloc=t labeljust=l
        fontcolor=white fontsize=11.0 fontname="Cascadia Code PL"
        color=white style=dashed penwidth=1
        L1 [label="" shape=point width=0.01]; L2 [label="" shape=point width=0.01];
        L3 [label="" shape=point width=0.01]; L4 [label="" shape=point width=0.01];
        L5 [label="" shape=point width=0.01]; L6 [label="" shape=point width=0.01];
        L7 [label="" shape=point width=0.01]; L8 [label="" shape=point width=0.01];
        L1 -> L2 [label=" Activate / Draw" arrowhead=normal color="#66cc66" fontsize=9.0];
        L3 -> L4 [label=" Deactivate / Switch" arrowhead=normal color="#cc6666" style=dashed fontsize=9.0];
        L5 -> L6 [label=" Commit to History" arrowhead=normal color="#cccc66" fontsize=9.0];
        L7 -> L8 [label=" Ready / Cycle" arrowhead=normal color="#6699ff" fontsize=9.0];
    }
}
