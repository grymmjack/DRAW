digraph LINE_TOOL {
    label="LINE TOOL STATE MACHINE" labelloc=t labeljust=c
    ordering=out rankdir=TB
    fontcolor=white fontsize=24.0 fontname="Cascadia Code PL"
    splines=true compound=true
    bgcolor=transparent
    edge [
        color=gray fontcolor="#aaaaaa" fontsize=9.0
        fontname="Cascadia Code PL"
    ];
    node [
        color=white shape=rect style=""
        fontname="Cascadia Code PL" fontsize=11.0 fontcolor=cyan
    ];

    { node [shape=folder color=orange penwidth=2 fontcolor=orange fontsize=13.0];
        MAIN [label="LINE STATES"];
        MODS [label="MODIFIERS"];
    }

    S_IDLE [label="1 · IDLE\n─────────────────\nCURRENT_TOOL% = TOOL_LINE\nLINE_TOOL.DRAGGING = FALSE\nCursor: crosshair"];
    S_DRAGGING [label="2 · DRAGGING\n─────────────────\nLINE_TOOL.DRAGGING = TRUE\nPreview line rendered\nSTART_X/Y to END_X/Y\nBresenham algorithm preview"];
    S_COMMITTED [label="3 · COMMITTED\n─────────────────\nB1 released\nLINE_draw_clipped()\nLINE_draw_resolved()\nHISTORY_record_brush()"];

    S_IDLE -> S_DRAGGING [label="  B1 press on canvas\n  Capture START_X/Y\n  DRAGGING = TRUE" color="#66cc66"];
    S_DRAGGING -> S_DRAGGING [label="  B1 held + movement\n  Update END_X/Y\n  Preview line each frame" color="#88aacc"];
    S_DRAGGING -> S_COMMITTED [label="  B1 released\n  Commit line to layer\n  HISTORY_record_brush()" color="#cccc66"];
    S_COMMITTED -> S_IDLE [label="  DRAGGING = FALSE\n  Ready for next line" color="#6699ff"];

    subgraph cluster_mods {
        label="LINE MODIFIERS" labelloc=t labeljust=l
        fontcolor=orange fontsize=11.0 fontname="Cascadia Code PL"
        color=orange style=dashed penwidth=1

        M_FREE [label="Free Angle\n────────────\nNo constraint\nAny angle line" fontsize=10.0];
        M_SHIFT [label="Shift Constrained\n────────────\nSnap to 0°/45°/90°\nNearest 45° increment\nFrom START to END" fontsize=10.0];
        M_GRID [label="Grid Snapped\n────────────\nGRID.SNAP% = TRUE\nEndpoints snap to\ngrid cell boundaries" fontsize=10.0];
        M_SELECTION [label="Selection Clipped\n────────────\nSELECTION_is_point_inside%()\nLine clipped to\nactive marquee region" fontsize=10.0];

        M_FREE -> M_SHIFT [label=" Shift held" color="#66cc66" fontsize=8.0];
        M_SHIFT -> M_FREE [label=" Shift released" color="#cc6666" fontsize=8.0 style=dashed];
        M_FREE -> M_GRID [label=" Grid snap on" color="#66cc66" fontsize=8.0];
    }

    MAIN -> S_IDLE [arrowhead=none color="#555555" style=dotted];
    MODS -> M_FREE [arrowhead=none color="#555555" style=dotted lhead=cluster_mods];
    { rank=min; MAIN; MODS }

    subgraph cluster_legend {
        label="LEGEND" labelloc=t labeljust=l
        fontcolor=white fontsize=11.0 fontname="Cascadia Code PL"
        color=white style=dashed penwidth=1
        L1 [label="" shape=point width=0.01]; L2 [label="" shape=point width=0.01];
        L3 [label="" shape=point width=0.01]; L4 [label="" shape=point width=0.01];
        L5 [label="" shape=point width=0.01]; L6 [label="" shape=point width=0.01];
        L1 -> L2 [label=" Activate / Draw" arrowhead=normal color="#66cc66" fontsize=9.0];
        L3 -> L4 [label=" Commit to History" arrowhead=normal color="#cccc66" fontsize=9.0];
        L5 -> L6 [label=" Ready / Re-enter" arrowhead=normal color="#6699ff" fontsize=9.0];
    }
}
