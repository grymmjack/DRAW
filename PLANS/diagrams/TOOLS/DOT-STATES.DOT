digraph DOT_TOOL {
    label="DOT (PSET) TOOL STATE MACHINE" labelloc=t labeljust=c
    ordering=out rankdir=TB
    fontcolor=white fontsize=24.0 fontname="Cascadia Code PL"
    splines=true compound=true
    bgcolor=transparent
    edge [
        color=gray fontcolor="#aaaaaa" fontsize=9.0
        fontname="Cascadia Code PL"
    ];
    node [
        color=white shape=rect style=""
        fontname="Cascadia Code PL" fontsize=11.0 fontcolor=cyan
    ];

    { node [shape=folder color=orange penwidth=2 fontcolor=orange fontsize=13.0];
        MAIN [label="DOT STATES"];
        PP [label="PIXEL PERFECT"];
        LINE_F [label="SHIFT LINE"];
    }

    S_IDLE [label="1 · IDLE\n─────────────────\nCURRENT_TOOL% = TOOL_DOT\nNo drag active\nDOT.HAS_LAST = FALSE"];
    S_DRAWING [label="2 · DRAWING\n─────────────────\nB1 held on canvas\nPAINT_pset_with_symmetry()\nDot at each cursor position\nDOT.LAST_X/Y updated"];
    S_HAS_LAST [label="3 · HAS LAST\n─────────────────\nDOT.HAS_LAST = TRUE\nDOT.LAST_X/Y = prev click\nShift+RightClick draws\nline from LAST to cursor"];
    S_COMMITTED [label="4 · COMMITTED\n─────────────────\nB1 released\nHISTORY_record_brush()\nHISTORY_BEFORE_IMG saved"];

    S_IDLE -> S_DRAWING [label="  B1 press on canvas\n  Capture HISTORY_BEFORE_IMG" color="#66cc66"];
    S_DRAWING -> S_DRAWING [label="  B1 held + movement\n  PAINT_on() per frame" color="#88aacc"];
    S_DRAWING -> S_COMMITTED [label="  B1 released\n  HISTORY_record_brush()" color="#cccc66"];
    S_COMMITTED -> S_HAS_LAST [label="  LAST_X/Y = end pos\n  HAS_LAST = TRUE" color="#6699ff"];
    S_HAS_LAST -> S_DRAWING [label="  B1 press\n  New stroke from cursor" color="#66cc66"];
    S_HAS_LAST -> S_HAS_LAST [label="  Shift+B2 click\n  Line from LAST to click\n  LAST_X/Y updated" color="#88aacc"];

    subgraph cluster_pixelperfect {
        label="PIXEL-PERFECT MODE — Ctrl+D Toggle" labelloc=t labeljust=l
        fontcolor=orange fontsize=11.0 fontname="Cascadia Code PL"
        color=orange style=dashed penwidth=1

        PP_OFF [label="Normal Mode\n────────────\nStandard PSET painting\nNo per-pixel tracking" fontsize=10.0];
        PP_ON [label="Pixel Perfect Mode\n────────────\nPP_STROKE_COUNT > 0\nEach pixel tracked in\nPP_STROKE() array\nPP_BACKUP = full layer" fontsize=10.0];
        PP_UNDO [label="Per-Pixel Undo\n────────────\nRestore PP_BACKUP\nReplay minus last pixel\nLossless undo per pixel" fontsize=10.0];

        PP_OFF -> PP_ON [label=" Ctrl+D toggle\n PP mode enabled" color="#66cc66" fontsize=8.0];
        PP_ON -> PP_UNDO [label=" Ctrl+Z in PP\n Undo last pixel" color="#cccc66" fontsize=8.0];
        PP_ON -> PP_OFF [label=" Ctrl+D toggle\n PP mode disabled" color="#cc6666" fontsize=8.0 style=dashed];
    }

    subgraph cluster_shiftline {
        label="SHIFT+RIGHTCLICK LINE PREVIEW" labelloc=t labeljust=l
        fontcolor=orange fontsize=11.0 fontname="Cascadia Code PL"
        color=orange style=dashed penwidth=1

        SL_NONE [label="No Preview\n────────────\nShift not held\nNo line preview" fontsize=10.0];
        SL_PREVIEW [label="Preview Line\n────────────\nShift held + HAS_LAST\nWhite preview line from\nLAST_X/Y to cursor\nUpdates every frame" fontsize=10.0];
        SL_DRAW [label="Line Drawn\n────────────\nShift+B2 click\nLine committed from\nLAST to click point\nLAST updated to endpoint" fontsize=10.0];

        SL_NONE -> SL_PREVIEW [label=" Shift held\n + HAS_LAST" color="#66cc66" fontsize=8.0];
        SL_PREVIEW -> SL_DRAW [label=" Shift+B2 click\n Line committed" color="#cccc66" fontsize=8.0];
        SL_PREVIEW -> SL_NONE [label=" Shift released" color="#cc6666" fontsize=8.0 style=dashed];
        SL_DRAW -> SL_PREVIEW [label=" Still holding Shift\n New preview from last" color="#6699ff" fontsize=8.0];
    }

    MAIN -> S_IDLE [arrowhead=none color="#555555" style=dotted];
    PP -> PP_OFF [arrowhead=none color="#555555" style=dotted lhead=cluster_pixelperfect];
    LINE_F -> SL_NONE [arrowhead=none color="#555555" style=dotted lhead=cluster_shiftline];
    { rank=min; MAIN; PP; LINE_F }

    subgraph cluster_legend {
        label="LEGEND" labelloc=t labeljust=l
        fontcolor=white fontsize=11.0 fontname="Cascadia Code PL"
        color=white style=dashed penwidth=1
        L1 [label="" shape=point width=0.01]; L2 [label="" shape=point width=0.01];
        L3 [label="" shape=point width=0.01]; L4 [label="" shape=point width=0.01];
        L5 [label="" shape=point width=0.01]; L6 [label="" shape=point width=0.01];
        L7 [label="" shape=point width=0.01]; L8 [label="" shape=point width=0.01];
        L1 -> L2 [label=" Activate / Draw" arrowhead=normal color="#66cc66" fontsize=9.0];
        L3 -> L4 [label=" Deactivate" arrowhead=normal color="#cc6666" style=dashed fontsize=9.0];
        L5 -> L6 [label=" Commit / History" arrowhead=normal color="#cccc66" fontsize=9.0];
        L7 -> L8 [label=" Ready / Re-enter" arrowhead=normal color="#6699ff" fontsize=9.0];
    }
}
