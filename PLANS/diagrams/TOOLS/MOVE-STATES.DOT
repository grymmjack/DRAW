digraph MOVE_TOOL {
    label="MOVE TOOL STATE MACHINE" labelloc=t labeljust=c
    ordering=out rankdir=TB
    fontcolor=white fontsize=24.0 fontname="Cascadia Code PL"
    splines=true compound=true
    bgcolor=transparent
    edge [
        color=gray fontcolor="#aaaaaa" fontsize=9.0
        fontname="Cascadia Code PL"
    ];
    node [
        color=white shape=rect style=""
        fontname="Cascadia Code PL" fontsize=11.0 fontcolor=cyan
    ];

    { node [shape=folder color=orange penwidth=2 fontcolor=orange fontsize=13.0];
        MAIN [label="MAIN STATES"];
        NUDGE [label="NUDGE"];
    }

    S_IDLE [label="1 · IDLE\n─────────────────\nCURRENT_TOOL = TOOL_MOVE\nNo drag active\nCursor: move arrows"];
    S_CAPTURE [label="2 · CAPTURE\n─────────────────\nB1 pressed on canvas\nCapture layer content\nSnapshot taken (before&)\nMOVE.captured% = TRUE"];
    S_DRAGGING [label="3 · DRAGGING\n─────────────────\nB1 held + movement\nFloating selection follows\nOffset from capture point\nPreview rendered"];
    S_COMMIT [label="4 · COMMITTED\n─────────────────\nB1 released\nPlace content at new pos\nHISTORY_record_brush()\nMOVE_reset()"];

    S_IDLE -> S_CAPTURE [label="  B1 press on canvas\n  MOVE_capture()" color="#66cc66"];
    S_CAPTURE -> S_DRAGGING [label="  Mouse movement\n  Offset calculated" color="#66cc66"];
    S_DRAGGING -> S_DRAGGING [label="  Continued drag\n  Update position" color="#88aacc"];
    S_DRAGGING -> S_COMMIT [label="  B1 released\n  MOVE_commit()\n  HISTORY_record_brush()" color="#cccc66"];
    S_COMMIT -> S_IDLE [label="  Move complete\n  MOVE_reset()" color="#cc6666" style=dashed];
    S_CAPTURE -> S_IDLE [label="  Escape\n  Cancel, restore" color="#cc6666" style=dashed];
    S_DRAGGING -> S_IDLE [label="  Escape\n  Cancel, restore original" color="#cc6666" style=dashed];

    subgraph cluster_nudge {
        label="NUDGE — MOVE_NUDGE.BM" labelloc=t labeljust=l
        fontcolor=orange fontsize=11.0 fontname="Cascadia Code PL"
        color=orange style=dashed penwidth=1

        N_IDLE [label="Nudge Idle\n────────────\nNo arrow key pressed\nNudge inactive" fontsize=10.0];
        N_PRESS [label="Nudge Active\n────────────\nArrow key held\nMove layer ±1px per key\nMOVE_NUDGE_apply()" fontsize=10.0];
        N_COMMIT [label="Nudge Committed\n────────────\nKey released\nHISTORY_record_brush()\nPosition finalized" fontsize=10.0];

        N_IDLE -> N_PRESS [label=" Arrow key down\n ↑↓←→" color="#66cc66" fontsize=8.0];
        N_PRESS -> N_PRESS [label=" Repeat (held)" color="#88aacc" fontsize=8.0];
        N_PRESS -> N_COMMIT [label=" Key released" color="#cccc66" fontsize=8.0];
        N_COMMIT -> N_IDLE [label=" History saved" color="#cc6666" fontsize=8.0 style=dashed];
    }

    subgraph cluster_multi {
        label="MULTI-LAYER LINKED MOVE" labelloc=t labeljust=l
        fontcolor=orange fontsize=11.0 fontname="Cascadia Code PL"
        color=orange style=dashed penwidth=1

        ML_SINGLE [label="Single Layer\n────────────\nMove only CURRENT_LAYER%\nDefault behavior" fontsize=10.0];
        ML_LINKED [label="Linked Layers\n────────────\nMove all selected layers\ntogether as group\nMaintain relative offsets" fontsize=10.0];

        ML_SINGLE -> ML_LINKED [label=" Multiple layers\n selected" color="#88aacc" fontsize=8.0];
        ML_LINKED -> ML_SINGLE [label=" Single selection" color="#88aacc" fontsize=8.0];
    }

    MAIN -> S_IDLE [arrowhead=none color="#555555" style=dotted];
    NUDGE -> N_IDLE [arrowhead=none color="#555555" style=dotted lhead=cluster_nudge];
    { rank=min; MAIN; NUDGE }

    subgraph cluster_legend {
        label="LEGEND" labelloc=t labeljust=l
        fontcolor=white fontsize=11.0 fontname="Cascadia Code PL"
        color=white style=dashed penwidth=1
        L1 [label="" shape=point width=0.01]; L2 [label="" shape=point width=0.01];
        L3 [label="" shape=point width=0.01]; L4 [label="" shape=point width=0.01];
        L5 [label="" shape=point width=0.01]; L6 [label="" shape=point width=0.01];
        L1 -> L2 [label=" Capture / Activate" arrowhead=normal color="#66cc66" fontsize=9.0];
        L3 -> L4 [label=" Reset / Cancel" arrowhead=normal color="#cc6666" style=dashed fontsize=9.0];
        L5 -> L6 [label=" Commit / Record" arrowhead=normal color="#cccc66" fontsize=9.0];
    }
}
