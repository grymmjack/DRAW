digraph PAN_TOOL {
    label="PAN TOOL STATE MACHINE" labelloc=t labeljust=c
    ordering=out rankdir=TB
    fontcolor=white fontsize=24.0 fontname="Cascadia Code PL"
    splines=true compound=true
    bgcolor=transparent
    edge [
        color=gray fontcolor="#aaaaaa" fontsize=9.0
        fontname="Cascadia Code PL"
    ];
    node [
        color=white shape=rect style=""
        fontname="Cascadia Code PL" fontsize=11.0 fontcolor=cyan
    ];

    { node [shape=folder color=orange penwidth=2 fontcolor=orange fontsize=13.0];
        MAIN [label="PAN STATES"];
    }

    S_IDLE [label="1 В· IDLE\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nCURRENT_TOOL = TOOL_PAN\nor Space held (assistant)\nor Middle-click (B3)\nSCRN.panning% = FALSE"];
    S_PAN_START [label="2 В· PAN START\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nB1 pressed (or B3/Space)\nSCRN.panning% = TRUE\nCapture start position\nSCRN.panStartX/Y%"];
    S_PANNING [label="3 В· PANNING\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nMouse dragging\nSCRN.offsetX/Y% updates\nCanvas scrolls with mouse\nNo drawing occurs"];
    S_PAN_END [label="4 В· PAN END\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nButton released\nSCRN.panning% = FALSE\nFinal offset applied"];

    S_IDLE -> S_PAN_START [
        label="  B1 (tool mode) or\n  Space+B1 or B3 (assistant)\n  SCRN.panning% = TRUE"
        color="#66cc66"
    ];
    S_PAN_START -> S_PANNING [
        label="  Mouse movement\n  Delta applied to offset"
        color="#66cc66"
    ];
    S_PANNING -> S_PANNING [
        label="  Continued drag\n  offsetX/Y += delta"
        color="#88aacc"
    ];
    S_PANNING -> S_PAN_END [
        label="  Button released\n  SCRN.panning% = FALSE"
        color="#cccc66"
    ];
    S_PAN_END -> S_IDLE [
        label="  Pan complete\n  Offset persists"
        color="#cc6666" style=dashed
    ];

    subgraph cluster_triggers {
        label="PAN TRIGGERS (3 entry points)" labelloc=t labeljust=l
        fontcolor=orange fontsize=11.0 fontname="Cascadia Code PL"
        color=orange style=dashed penwidth=1

        T_TOOL [label="Pan Tool Selected\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nCURRENT_TOOL% = TOOL_PAN\nB1 = drag to pan\nDedicated tool mode" fontsize=10.0];
        T_SPACE [label="Space Bar Hold\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nTemporary assistant\nAny tool в†’ pan override\nRelease = return to tool" fontsize=10.0];
        T_MIDDLE [label="Middle Mouse Button\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nB3 press and drag\nAlways available\nNo tool switch needed" fontsize=10.0];
    }

    MAIN -> S_IDLE [arrowhead=none color="#555555" style=dotted];
    { rank=min; MAIN }
}
