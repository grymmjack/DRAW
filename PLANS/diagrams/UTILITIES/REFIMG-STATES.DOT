digraph REFIMG_STATES {
    label="REFERENCE IMAGE STATE MACHINE" labelloc=t labeljust=c
    ordering=out rankdir=TB
    fontcolor=white fontsize=24.0 fontname="Cascadia Code PL"
    splines=true compound=true
    bgcolor=transparent
    edge [
        color=gray fontcolor="#aaaaaa" fontsize=9.0
        fontname="Cascadia Code PL"
    ];
    node [
        color=white shape=rect style=""
        fontname="Cascadia Code PL" fontsize=11.0 fontcolor=cyan
    ];

    { node [shape=folder color=orange penwidth=2 fontcolor=orange fontsize=13.0];
        MAIN [label="REFERENCE\nIMAGE"];
    }

    S_NONE [label="1 · NOT LOADED\n─────────────────\nREFIMG.IMAGE = 0\nVISIBLE = FALSE\nNo reference overlay"];
    S_LOADED [label="2 · LOADED (HIDDEN)\n─────────────────\nIMAGE < -1 (valid handle)\nVISIBLE = FALSE\nImage in memory\nbut not displayed"];
    S_VISIBLE [label="3 · VISIBLE\n─────────────────\nVISIBLE = TRUE\nRendered BEFORE grid+layers\nScaled at POS_X/Y\nOPACITY% blended (0-100)"];
    S_REPOSITION [label="4 · REPOSITIONING\n─────────────────\nREPOSITION = TRUE\nModal drag mode\nDRAGGING tracks mouse\nPOS_X/Y updates on drag"];

    S_NONE -> S_LOADED [label="  View → Ref Image → Load\n  File dialog opens\n  REFIMG_load(filename)" color="#66cc66"];
    S_LOADED -> S_VISIBLE [label="  Ctrl+R toggle\n  REFIMG_toggle_visible()\n  VISIBLE = TRUE" color="#66cc66"];
    S_VISIBLE -> S_LOADED [label="  Ctrl+R toggle\n  VISIBLE = FALSE\n  Still in memory" color="#cc6666" style=dashed];
    S_VISIBLE -> S_REPOSITION [label="  View → Ref Image\n  → Reposition\n  REPOSITION = TRUE" color="#cccc66"];
    S_REPOSITION -> S_VISIBLE [label="  Press Esc\n  REPOSITION = FALSE\n  PREV_TOOL restored" color="#cc6666" style=dashed];
    S_REPOSITION -> S_REPOSITION [label="  Mouse drag\n  DRAGGING = TRUE\n  POS_X/Y updated\n  via DRAG_OFS_X/Y" color="#88aacc"];
    S_LOADED -> S_NONE [label="  View → Ref Image → Clear\n  _FREEIMAGE IMAGE\n  VISIBLE = FALSE" color="#cc6666" style=dashed];
    S_VISIBLE -> S_NONE [label="  View → Ref Image → Clear\n  REFIMG_unload()" color="#cc6666" style=dashed];

    MAIN -> S_NONE [arrowhead=none color="#555555" style=dotted];
    { rank=min; MAIN }

    subgraph cluster_opacity {
        label="OPACITY CONTROL" labelloc=t labeljust=l
        fontcolor=white fontsize=11.0 fontname="Cascadia Code PL"
        color=orange style=dashed penwidth=1

        OP_MIN [label="Min Opacity\n─────────────────\nOPACITY = 5%\nREFIMG_OPACITY_MIN\nBarely visible"];
        OP_DEFAULT [label="Default\n─────────────────\nOPACITY = 30%\nREFIMG_OPACITY_DEFAULT\nSemi-transparent"];
        OP_MAX [label="Max Opacity\n─────────────────\nOPACITY = 100%\nREFIMG_OPACITY_MAX\nFully opaque"];

        OP_MIN -> OP_DEFAULT [label="  Ctrl+Shift+Wheel Up\n  OPACITY += STEP(5)" color="#66cc66"];
        OP_DEFAULT -> OP_MAX [label="  Ctrl+Shift+Wheel Up\n  OPACITY += STEP(5)" color="#66cc66"];
        OP_MAX -> OP_DEFAULT [label="  Ctrl+Shift+Wheel Down\n  OPACITY -= STEP(5)" color="#cc6666" style=dashed];
        OP_DEFAULT -> OP_MIN [label="  Ctrl+Shift+Wheel Down\n  OPACITY -= STEP(5)" color="#cc6666" style=dashed];
    }

    subgraph cluster_persistence {
        label="PERSISTENCE (DRW v4+)" labelloc=t labeljust=l
        fontcolor=white fontsize=11.0 fontname="Cascadia Code PL"
        color=orange style=dashed penwidth=1

        P1 [label="Saved Fields\n─────────────────\nFILENAME$\nPOS_X, POS_Y\nSCALE_W, SCALE_H\nOPACITY%"];
    }

    subgraph cluster_sampling {
        label="COLOR SAMPLING" labelloc=t labeljust=l
        fontcolor=white fontsize=11.0 fontname="Cascadia Code PL"
        color=orange style=dashed penwidth=1

        S1 [label="REFIMG_sample_color_at_canvas()\n─────────────────\nSample pixel from\nreference image at\ncanvas coordinates\n(used by picker)"];
    }

    subgraph cluster_legend {
        label="LEGEND" labelloc=t labeljust=l
        fontcolor=white fontsize=11.0 fontname="Cascadia Code PL"
        color=white style=dashed penwidth=1
        L1 [label="" shape=point width=0.01]; L2 [label="" shape=point width=0.01];
        L3 [label="" shape=point width=0.01]; L4 [label="" shape=point width=0.01];
        L5 [label="" shape=point width=0.01]; L6 [label="" shape=point width=0.01];
        L7 [label="" shape=point width=0.01]; L8 [label="" shape=point width=0.01];
        L1 -> L2 [label=" Load / Show" arrowhead=normal color="#66cc66" fontsize=9.0];
        L3 -> L4 [label=" Hide / Clear" arrowhead=normal color="#cc6666" style=dashed fontsize=9.0];
        L5 -> L6 [label=" Commit / Modal" arrowhead=normal color="#cccc66" fontsize=9.0];
        L7 -> L8 [label=" Self-transition" arrowhead=normal color="#88aacc" fontsize=9.0];
    }
}
