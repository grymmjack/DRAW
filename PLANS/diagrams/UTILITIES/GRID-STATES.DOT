digraph GRID_STATES {
    label="GRID STATE MACHINE" labelloc=t labeljust=c
    ordering=out rankdir=TB
    fontcolor=white fontsize=24.0 fontname="Cascadia Code PL"
    splines=true compound=true
    bgcolor=transparent
    edge [
        color=gray fontcolor="#aaaaaa" fontsize=9.0
        fontname="Cascadia Code PL"
    ];
    node [
        color=white shape=rect style=""
        fontname="Cascadia Code PL" fontsize=11.0 fontcolor=cyan
    ];

    { node [shape=folder color=orange penwidth=2 fontcolor=orange fontsize=13.0];
        MAIN [label="GRID SYSTEM"];
    }

    // Main visibility states
    S_HIDDEN [label="1 · GRID HIDDEN\n─────────────────\nGRID.VISIBLE = FALSE\nNo grid overlay\nNo snap active"];
    S_VISIBLE [label="2 · GRID VISIBLE\n─────────────────\nGRID.VISIBLE = TRUE\nGrid lines drawn\non canvas overlay\nGRID_draw() renders"];

    S_HIDDEN -> S_VISIBLE [label="  Toggle grid\n  View → Grid → Show\n  or hotkey G" color="#66cc66"];
    S_VISIBLE -> S_HIDDEN [label="  Toggle grid\n  View → Grid → Hide\n  or hotkey G" color="#cc6666" style=dashed];
    S_VISIBLE -> S_VISIBLE [label="  Grid settings change\n  GRID_draw() re-renders\n  SCENE_DIRTY = TRUE" color="#88aacc"];

    MAIN -> S_HIDDEN [arrowhead=none color="#555555" style=dotted];
    { rank=min; MAIN }

    subgraph cluster_snap {
        label="SNAP MODES" labelloc=t labeljust=l
        fontcolor=white fontsize=11.0 fontname="Cascadia Code PL"
        color=orange style=dashed penwidth=1

        SNAP_OFF [label="Snap OFF\n─────────────────\nGRID.SNAP = FALSE\nMouse coords unmodified\nPixel-precise placement"];
        SNAP_CORNER [label="Snap to Corner\n─────────────────\nGRID.SNAP = TRUE\nSNAP_MODE = CORNER\nCoords snap to\ngrid intersections"];
        SNAP_CENTER [label="Snap to Center\n─────────────────\nGRID.SNAP = TRUE\nSNAP_MODE = CENTER\nCoords snap to\ngrid cell centers"];

        SNAP_OFF -> SNAP_CORNER [label="  Enable snap\n  Toggle hotkey" color="#66cc66"];
        SNAP_CORNER -> SNAP_CENTER [label="  Cycle snap mode\n  Shift+toggle" color="#6699ff"];
        SNAP_CENTER -> SNAP_OFF [label="  Disable snap\n  Toggle hotkey" color="#cc6666" style=dashed];
        SNAP_CORNER -> SNAP_OFF [label="  Disable snap" color="#cc6666" style=dashed];
    }

    subgraph cluster_modes {
        label="GRID MODES" labelloc=t labeljust=l
        fontcolor=white fontsize=11.0 fontname="Cascadia Code PL"
        color=orange style=dashed penwidth=1

        MODE_LINES [label="Line Grid\n─────────────────\nStandard grid lines\nCELL_W × CELL_H pixels\nConfigurable size"];
        MODE_DOTS [label="Dot Grid\n─────────────────\nDots at intersections\nLighter visual weight\nLess obstructive"];
        MODE_DASHES [label="Dashed Grid\n─────────────────\nDashed line grid\nHybrid visibility"];

        MODE_LINES -> MODE_DOTS [label="  Cycle mode" color="#6699ff"];
        MODE_DOTS -> MODE_DASHES [label="  Cycle mode" color="#6699ff"];
        MODE_DASHES -> MODE_LINES [label="  Cycle mode" color="#6699ff"];
    }

    subgraph cluster_cell_fill {
        label="GRID CELL FILL" labelloc=t labeljust=l
        fontcolor=white fontsize=11.0 fontname="Cascadia Code PL"
        color=orange style=dashed penwidth=1

        CF_OFF [label="Cell Fill OFF\n─────────────────\nNormal pixel painting\nNo cell-wide operations"];
        CF_ON [label="Cell Fill ON\n─────────────────\nClick fills entire\ngrid cell with color\nFast tile-based painting"];

        CF_OFF -> CF_ON [label="  Enable cell fill\n  Grid menu option" color="#66cc66"];
        CF_ON -> CF_OFF [label="  Disable cell fill" color="#cc6666" style=dashed];
    }

    subgraph cluster_rendering {
        label="RENDER REQUIREMENTS" labelloc=t labeljust=l
        fontcolor=white fontsize=11.0 fontname="Cascadia Code PL"
        color=orange style=dashed penwidth=1

        R1 [label="GRID_draw()\n─────────────────\nRenders into\nGRID.imgHandle&\nMust be called on\nsettings change"];
        R2 [label="Invalidation\n─────────────────\nSet SCENE_DIRTY = TRUE\nSet FRAME_IDLE = FALSE\nAfter any grid change"];
    }

    subgraph cluster_legend {
        label="LEGEND" labelloc=t labeljust=l
        fontcolor=white fontsize=11.0 fontname="Cascadia Code PL"
        color=white style=dashed penwidth=1
        L1 [label="" shape=point width=0.01]; L2 [label="" shape=point width=0.01];
        L3 [label="" shape=point width=0.01]; L4 [label="" shape=point width=0.01];
        L5 [label="" shape=point width=0.01]; L6 [label="" shape=point width=0.01];
        L7 [label="" shape=point width=0.01]; L8 [label="" shape=point width=0.01];
        L1 -> L2 [label=" Activate" arrowhead=normal color="#66cc66" fontsize=9.0];
        L3 -> L4 [label=" Deactivate" arrowhead=normal color="#cc6666" style=dashed fontsize=9.0];
        L5 -> L6 [label=" Mode switch" arrowhead=normal color="#6699ff" fontsize=9.0];
        L7 -> L8 [label=" Self-transition" arrowhead=normal color="#88aacc" fontsize=9.0];
    }
}
