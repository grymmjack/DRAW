digraph BRUSH_SIZE_STATES {
    label="BRUSH SIZE STATE MACHINE" labelloc=t labeljust=c
    ordering=out rankdir=TB
    fontcolor=white fontsize=24.0 fontname="Cascadia Code PL"
    splines=true compound=true
    bgcolor=transparent
    edge [
        color=gray fontcolor="#aaaaaa" fontsize=9.0
        fontname="Cascadia Code PL"
    ];
    node [
        color=white shape=rect style=""
        fontname="Cascadia Code PL" fontsize=11.0 fontcolor=cyan
    ];

    { node [shape=folder color=orange penwidth=2 fontcolor=orange fontsize=13.0];
        MAIN [label="BRUSH SIZE"];
    }

    S_NORMAL [label="1 В· NORMAL\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nBRUSH_SIZE.CURRENT = 1-25\nBRUSH_SIZE.SHAPE = CIRCLE\nPIXEL_PERFECT = OFF\nStandard round brush"];
    S_SQUARE [label="2 В· SQUARE MODE\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nBRUSH_SIZE.SHAPE = SQUARE\nSquare brush stamp\nCURRENT = 1-25"];
    S_PIXEL_PERFECT [label="3 В· PIXEL PERFECT\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nBRUSH_SIZE.PIXEL_PERFECT = ON\nRemoves corner pixels\nCleaner 45В° strokes\nSmooth diagonal lines"];

    S_NORMAL -> S_SQUARE [label="  Toggle shape\n  SHAPE = -1 (square)" color="#6699ff"];
    S_SQUARE -> S_NORMAL [label="  Toggle shape\n  SHAPE = 0 (circle)" color="#6699ff"];
    S_NORMAL -> S_PIXEL_PERFECT [label="  Toggle pixel-perfect\n  PIXEL_PERFECT = -1" color="#66cc66"];
    S_PIXEL_PERFECT -> S_NORMAL [label="  Toggle pixel-perfect\n  PIXEL_PERFECT = 0" color="#cc6666" style=dashed];

    S_NORMAL -> S_NORMAL [label="  Scroll wheel: CURRENT В± 1\n  Clamped to MIN..MAX (1-25)\n  BRUSH_PIXEL_SIZES() lookup" color="#88aacc"];
    S_SQUARE -> S_SQUARE [label="  Scroll wheel: CURRENT В± 1\n  Same clamp logic" color="#88aacc"];

    MAIN -> S_NORMAL [arrowhead=none color="#555555" style=dotted];
    { rank=min; MAIN }

    subgraph cluster_presets {
        label="SIZE PRESETS" labelloc=t labeljust=l
        fontcolor=white fontsize=11.0 fontname="Cascadia Code PL"
        color=orange style=dashed penwidth=1

        P1 [label="Preset 1 (F1)\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nCURRENT = PRESET1\nJump to saved size"];
        P2 [label="Preset 2 (F2)\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nCURRENT = PRESET2\nJump to saved size"];
        P3 [label="Preset 3 (F3)\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nCURRENT = PRESET3\nJump to saved size"];
        P4 [label="Preset 4 (F4)\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nCURRENT = PRESET4\nJump to saved size"];

        P1 -> P2 [style=invis];
        P2 -> P3 [style=invis];
        P3 -> P4 [style=invis];
    }

    subgraph cluster_preview {
        label="PREVIEW" labelloc=t labeljust=l
        fontcolor=white fontsize=11.0 fontname="Cascadia Code PL"
        color=orange style=dashed penwidth=1

        PR_OFF [label="Preview OFF\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nPREVIEW = 0\nNo brush outline\nshown at cursor"];
        PR_ON [label="Preview ON\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nPREVIEW = -1\nBrush outline shown\nat cursor position\nUpdates each frame"];

        PR_OFF -> PR_ON [label="  Toggle preview" color="#66cc66"];
        PR_ON -> PR_OFF [label="  Toggle preview" color="#cc6666" style=dashed];
    }

    subgraph cluster_persistence {
        label="PERSISTENCE" labelloc=t labeljust=l
        fontcolor=white fontsize=11.0 fontname="Cascadia Code PL"
        color=orange style=dashed penwidth=1

        D1 [label="Saved in DRW\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nCURRENT, SHAPE\nPIXEL_PERFECT\nPRESET1-4 values\nPersisted on save"];
    }

    subgraph cluster_legend {
        label="LEGEND" labelloc=t labeljust=l
        fontcolor=white fontsize=11.0 fontname="Cascadia Code PL"
        color=white style=dashed penwidth=1
        L1 [label="" shape=point width=0.01]; L2 [label="" shape=point width=0.01];
        L3 [label="" shape=point width=0.01]; L4 [label="" shape=point width=0.01];
        L5 [label="" shape=point width=0.01]; L6 [label="" shape=point width=0.01];
        L7 [label="" shape=point width=0.01]; L8 [label="" shape=point width=0.01];
        L1 -> L2 [label=" Activate" arrowhead=normal color="#66cc66" fontsize=9.0];
        L3 -> L4 [label=" Deactivate" arrowhead=normal color="#cc6666" style=dashed fontsize=9.0];
        L5 -> L6 [label=" Mode toggle" arrowhead=normal color="#6699ff" fontsize=9.0];
        L7 -> L8 [label=" Self-transition" arrowhead=normal color="#88aacc" fontsize=9.0];
    }
}
