digraph SYMMETRY_STATES {
    label="SYMMETRY ASSISTANT STATE MACHINE" labelloc=t labeljust=c
    ordering=out rankdir=TB
    fontcolor=white fontsize=24.0 fontname="Cascadia Code PL"
    splines=true compound=true
    bgcolor=transparent
    edge [
        color=gray fontcolor="#aaaaaa" fontsize=9.0
        fontname="Cascadia Code PL"
    ];
    node [
        color=white shape=rect style=""
        fontname="Cascadia Code PL" fontsize=11.0 fontcolor=cyan
    ];

    { node [shape=folder color=orange penwidth=2 fontcolor=orange fontsize=13.0];
        MAIN [label="SYMMETRY\nASSISTANT"];
    }

    S_OFF [label="1 В· OFF (MODE=0)\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nNo symmetry applied\nSingle paint point only\nNo guide lines"];
    S_VERT [label="2 В· VERTICAL (MODE=1)\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nLeft/right mirroring\nAcross vertical CENTER_X line\n2 paint points per stroke"];
    S_CROSS [label="3 В· CROSS (MODE=2)\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\n4-way mirror\nVertical + Horizontal\nCENTER_X + CENTER_Y lines\n4 paint points per stroke"];
    S_ASTERISK [label="4 В· ASTERISK (MODE=3)\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\n8-way mirror\nVert + Horiz + 2 diagonals\n8 paint points per stroke"];

    S_OFF -> S_VERT [label="  Press F\n  SYMMETRY_cycle_mode()\n  MODE = 1" color="#66cc66"];
    S_VERT -> S_CROSS [label="  Press F\n  SYMMETRY_cycle_mode()\n  MODE = 2" color="#66cc66"];
    S_CROSS -> S_ASTERISK [label="  Press F\n  SYMMETRY_cycle_mode()\n  MODE = 3" color="#66cc66"];
    S_ASTERISK -> S_OFF [label="  Press F\n  SYMMETRY_cycle_mode()\n  MODE = 0" color="#cc6666" style=dashed];

    MAIN -> S_OFF [arrowhead=none color="#555555" style=dotted];
    { rank=min; MAIN }

    subgraph cluster_center {
        label="CENTER CONTROL" labelloc=t labeljust=l
        fontcolor=white fontsize=11.0 fontname="Cascadia Code PL"
        color=orange style=dashed penwidth=1

        C_DEFAULT [label="Default Center\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nCENTER_X = canvas W/2\nCENTER_Y = canvas H/2\nCENTER_SET = FALSE"];
        C_CUSTOM [label="Custom Center\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nCtrl+Click sets\nCENTER_X/Y = click pos\nCENTER_SET = TRUE\nCrosshair shown"];

        C_DEFAULT -> C_CUSTOM [label="  Ctrl+Click\n  SYMMETRY_set_center(x,y)" color="#cccc66"];
        C_CUSTOM -> C_DEFAULT [label="  SYMMETRY_init()\n  or canvas resize" color="#cc6666" style=dashed];
    }

    subgraph cluster_guides {
        label="GUIDE RENDERING" labelloc=t labeljust=l
        fontcolor=white fontsize=11.0 fontname="Cascadia Code PL"
        color=orange style=dashed penwidth=1

        G_CLEAN [label="Guides Clean\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nDIRTY = FALSE\nimgHandle& current\nGuide lines cached"];
        G_DIRTY [label="Guides Dirty\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nDIRTY = TRUE\nNeed regeneration\nSYMMETRY_render_guides()"];

        G_CLEAN -> G_DIRTY [label="  Mode change\n  or center change\n  DIRTY = TRUE" color="#cccc66"];
        G_DIRTY -> G_CLEAN [label="  SYMMETRY_render_guides()\n  Regenerate image buffer\n  DIRTY = FALSE" color="#66cc66"];
    }

    subgraph cluster_paint {
        label="PAINT INTEGRATION" labelloc=t labeljust=l
        fontcolor=white fontsize=11.0 fontname="Cascadia Code PL"
        color=orange style=dashed penwidth=1

        P1 [label="PAINT_pset_with_symmetry()\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nCalls SYMMETRY_get_\nmirrored_points(x,y,...)\nReturns mx(),my(),count\nPaints at ALL positions"];
    }

    subgraph cluster_legend {
        label="LEGEND" labelloc=t labeljust=l
        fontcolor=white fontsize=11.0 fontname="Cascadia Code PL"
        color=white style=dashed penwidth=1
        L1 [label="" shape=point width=0.01]; L2 [label="" shape=point width=0.01];
        L3 [label="" shape=point width=0.01]; L4 [label="" shape=point width=0.01];
        L5 [label="" shape=point width=0.01]; L6 [label="" shape=point width=0.01];
        L1 -> L2 [label=" Cycle forward" arrowhead=normal color="#66cc66" fontsize=9.0];
        L3 -> L4 [label=" Deactivate / Reset" arrowhead=normal color="#cc6666" style=dashed fontsize=9.0];
        L5 -> L6 [label=" Commit / Update" arrowhead=normal color="#cccc66" fontsize=9.0];
    }
}
