digraph PICKER_LOUPE_STATES {
    label="COLOR PICKER LOUPE STATE MACHINE" labelloc=t labeljust=c
    ordering=out rankdir=TB
    fontcolor=white fontsize=24.0 fontname="Cascadia Code PL"
    splines=true compound=true
    bgcolor=transparent
    edge [
        color=gray fontcolor="#aaaaaa" fontsize=9.0
        fontname="Cascadia Code PL"
    ];
    node [
        color=white shape=rect style=""
        fontname="Cascadia Code PL" fontsize=11.0 fontcolor=cyan
    ];

    { node [shape=folder color=orange penwidth=2 fontcolor=orange fontsize=13.0];
        MAIN [label="PICKER LOUPE"];
    }

    S_HIDDEN [label="1 · HIDDEN\n─────────────────\nPICKER_LOUPE.ACTIVE = FALSE\nNo magnifier visible\nBUFFER not allocated"];
    S_VISIBLE [label="2 · VISIBLE\n─────────────────\nPICKER_LOUPE.ACTIVE = TRUE\nMagnified region at mouse\nBUFFER + TEXT_BUFFER allocated\nSAMPLE_COLOR displayed"];
    S_SAMPLING [label="3 · SAMPLING\n─────────────────\nUser hovering canvas\nPICKER_LOUPE_render()\nframes composited:\n• 8×/16× magnified region\n• Hex code overlay\n• RGB values overlay\n• Crosshair center"];

    S_HIDDEN -> S_VISIBLE [label="  PICKER_LOUPE_activate()\n  Allocate BUFFER image\n  Allocate TEXT_BUFFER" color="#66cc66"];
    S_VISIBLE -> S_SAMPLING [label="  Mouse over canvas\n  Begin compositing\n  magnified region" color="#66cc66"];
    S_SAMPLING -> S_SAMPLING [label="  Mouse moves\n  SAMPLE_COLOR updated\n  Region re-composited" color="#88aacc"];
    S_VISIBLE -> S_HIDDEN [label="  PICKER_LOUPE_deactivate()\n  Free BUFFER\n  Free TEXT_BUFFER" color="#cc6666" style=dashed];
    S_SAMPLING -> S_HIDDEN [label="  Picker tool deselected\n  PICKER_LOUPE_deactivate()" color="#cc6666" style=dashed];

    MAIN -> S_HIDDEN [arrowhead=none color="#555555" style=dotted];
    { rank=min; MAIN }

    subgraph cluster_display {
        label="DISPLAY CONTENT" labelloc=t labeljust=l
        fontcolor=white fontsize=11.0 fontname="Cascadia Code PL"
        color=orange style=dashed penwidth=1

        D1 [label="Magnified Region\n─────────────────\nBUFFER_W × BUFFER_H pixels\n8× or 16× zoom\nComposited from layers"];
        D2 [label="Text Overlay\n─────────────────\nTEXT_BUFFER renders:\n• #RRGGBB hex code\n• R: G: B: values\n• Font: FONT_HANDLE"];
        D3 [label="Crosshair\n─────────────────\nCenter pixel highlighted\nTarget crosshair drawn\nSAMPLE_COLOR shown"];
    }

    subgraph cluster_integration {
        label="INTEGRATION" labelloc=t labeljust=l
        fontcolor=white fontsize=11.0 fontname="Cascadia Code PL"
        color=orange style=dashed penwidth=1

        I1 [label="Used by PICKER tool\n─────────────────\nActivated when picker\nis active tool\nAlso via Alt+Click\ntemp picker mode"];
        I2 [label="Color Resolution\n─────────────────\nPICKER_compose_region()\nresolves blended color\nthrough layer stack"];
    }

    subgraph cluster_legend {
        label="LEGEND" labelloc=t labeljust=l
        fontcolor=white fontsize=11.0 fontname="Cascadia Code PL"
        color=white style=dashed penwidth=1
        L1 [label="" shape=point width=0.01]; L2 [label="" shape=point width=0.01];
        L3 [label="" shape=point width=0.01]; L4 [label="" shape=point width=0.01];
        L5 [label="" shape=point width=0.01]; L6 [label="" shape=point width=0.01];
        L1 -> L2 [label=" Activate" arrowhead=normal color="#66cc66" fontsize=9.0];
        L3 -> L4 [label=" Deactivate" arrowhead=normal color="#cc6666" style=dashed fontsize=9.0];
        L5 -> L6 [label=" Self-transition" arrowhead=normal color="#88aacc" fontsize=9.0];
    }
}
