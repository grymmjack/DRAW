digraph COLOR_MODE_STATES {
    label="COLOR MODE SLOT STATE MACHINE" labelloc=t labeljust=c
    ordering=out rankdir=TB
    fontcolor=white fontsize=24.0 fontname="Cascadia Code PL"
    splines=true compound=true
    bgcolor=transparent
    edge [
        color=gray fontcolor="#aaaaaa" fontsize=9.0
        fontname="Cascadia Code PL"
    ];
    node [
        color=white shape=rect style=""
        fontname="Cascadia Code PL" fontsize=11.0 fontcolor=cyan
    ];

    { node [shape=folder color=orange penwidth=2 fontcolor=orange fontsize=13.0];
        MAIN [label="COLOR MODE\nSLOT"];
    }

    S_NORMAL [label="1 В· NORMAL\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nPAINT_COLOR~& = FG\nPAINT_BG_COLOR~& = BG\nDRAW_COLOR~& = active\nStandard painting mode"];
    S_SWAPPED [label="2 В· SWAPPED\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nFG в†” BG swapped\nPAINT_COLOR~& = old BG\nPAINT_BG_COLOR~& = old FG\nReversed painting"];
    S_RESET [label="3 В· DEFAULT COLORS\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nFG = Black _RGB32(0,0,0)\nBG = White _RGB32(255,255,255)\nDefault palette state"];

    S_NORMAL -> S_SWAPPED [label="  Press X\n  or click swap button\n  COLOR_swap_fg_bg()" color="#6699ff"];
    S_SWAPPED -> S_NORMAL [label="  Press X again\n  or click swap button\n  COLOR_swap_fg_bg()" color="#6699ff"];
    S_NORMAL -> S_RESET [label="  Press D\n  or click reset button\n  COLOR_reset_defaults()" color="#cc6666" style=dashed];
    S_SWAPPED -> S_RESET [label="  Press D\n  or click reset button\n  COLOR_reset_defaults()" color="#cc6666" style=dashed];
    S_RESET -> S_NORMAL [label="  Pick new color\n  from palette or canvas\n  FG/BG updated" color="#66cc66"];

    MAIN -> S_NORMAL [arrowhead=none color="#555555" style=dotted];
    { rank=min; MAIN }

    subgraph cluster_fg {
        label="FOREGROUND COLOR" labelloc=t labeljust=l
        fontcolor=white fontsize=11.0 fontname="Cascadia Code PL"
        color=orange style=dashed penwidth=1

        FG_PAL [label="From Palette\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nLeft-click palette strip\nPAL_color~&(index%)\nFG palette index stored"];
        FG_PICK [label="From Canvas\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nPicker tool left-click\nSample blended color\nat canvas position"];
        FG_DIALOG [label="From Dialog\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nClick FG swatch\nOpens palette picker\nCustom color selection"];
        FG_TRANSPARENT [label="Transparent FG\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nPAL_FG_IS_TRANSPARENT%\n= TRUE\nEraser mode active\n_RGBA32(0,0,0,0)"];
    }

    subgraph cluster_bg {
        label="BACKGROUND COLOR" labelloc=t labeljust=l
        fontcolor=white fontsize=11.0 fontname="Cascadia Code PL"
        color=orange style=dashed penwidth=1

        BG_PAL [label="From Palette\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nRight-click palette strip\nPAL_color~&(index%)\nBG palette index stored"];
        BG_PICK [label="From Canvas\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nPicker tool right-click\nSample blended color\nat canvas position"];
    }

    subgraph cluster_invert {
        label="COLOR INVERT" labelloc=t labeljust=l
        fontcolor=white fontsize=11.0 fontname="Cascadia Code PL"
        color=orange style=dashed penwidth=1

        INV [label="Invert FG Color\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nCOLOR_INVERT tool\nR=255-R, G=255-G, B=255-B\nInstant toggle"];
    }

    subgraph cluster_legend {
        label="LEGEND" labelloc=t labeljust=l
        fontcolor=white fontsize=11.0 fontname="Cascadia Code PL"
        color=white style=dashed penwidth=1
        L1 [label="" shape=point width=0.01]; L2 [label="" shape=point width=0.01];
        L3 [label="" shape=point width=0.01]; L4 [label="" shape=point width=0.01];
        L5 [label="" shape=point width=0.01]; L6 [label="" shape=point width=0.01];
        L1 -> L2 [label=" Set / Activate" arrowhead=normal color="#66cc66" fontsize=9.0];
        L3 -> L4 [label=" Reset / Clear" arrowhead=normal color="#cc6666" style=dashed fontsize=9.0];
        L5 -> L6 [label=" Swap / Toggle" arrowhead=normal color="#6699ff" fontsize=9.0];
    }
}
