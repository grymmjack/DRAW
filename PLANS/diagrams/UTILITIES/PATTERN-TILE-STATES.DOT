digraph PATTERN_TILE_STATES {
    label="PATTERN TILE MODE STATE MACHINE" labelloc=t labeljust=c
    ordering=out rankdir=TB
    fontcolor=white fontsize=24.0 fontname="Cascadia Code PL"
    splines=true compound=true
    bgcolor=transparent
    edge [
        color=gray fontcolor="#aaaaaa" fontsize=9.0
        fontname="Cascadia Code PL"
    ];
    node [
        color=white shape=rect style=""
        fontname="Cascadia Code PL" fontsize=11.0 fontcolor=cyan
    ];

    { node [shape=folder color=orange penwidth=2 fontcolor=orange fontsize=13.0];
        MAIN [label="PATTERN\nTILE MODE"];
    }

    S_OFF [label="1 · OFF\n─────────────────\nDrawing Mode: Color\nNormal brush painting\nSolid FG/BG colors"];
    S_PATTERN [label="2 · PATTERN MODE\n─────────────────\nDrawing Mode: Pattern\nPattern bin slot active\nBrush fills with tile\nfrom selected slot"];
    S_GRADIENT [label="3 · GRADIENT MODE\n─────────────────\nDrawing Mode: Gradient\nGradient bin slot active\nFills use gradient\nfrom selected slot"];

    S_OFF -> S_PATTERN [label="  Select Pattern bin\n  in Drawer panel\n  Drawing mode changes" color="#66cc66"];
    S_OFF -> S_GRADIENT [label="  Select Gradient bin\n  in Drawer panel\n  Drawing mode changes" color="#66cc66"];
    S_PATTERN -> S_OFF [label="  Select Color bin\n  in Drawer panel\n  Back to solid color" color="#cc6666" style=dashed];
    S_GRADIENT -> S_OFF [label="  Select Color bin\n  in Drawer panel\n  Back to solid color" color="#cc6666" style=dashed];
    S_PATTERN -> S_GRADIENT [label="  Switch to gradient\n  bin in Drawer" color="#6699ff"];
    S_GRADIENT -> S_PATTERN [label="  Switch to pattern\n  bin in Drawer" color="#6699ff"];

    MAIN -> S_OFF [arrowhead=none color="#555555" style=dotted];
    { rank=min; MAIN }

    subgraph cluster_tiling {
        label="TILE RENDERING" labelloc=t labeljust=l
        fontcolor=white fontsize=11.0 fontname="Cascadia Code PL"
        color=orange style=dashed penwidth=1

        T1 [label="Tile Origin\n─────────────────\nFILL_ADJ.ORIGIN_X/Y\nOffset for tile placement\nAdjustable via Fill-Adj (F8)"];
        T2 [label="Tile Scale\n─────────────────\nFILL_ADJ.TILE_W/H\nIndependent X/Y scaling\nAdjustable via L-handle"];
        T3 [label="Tile Application\n─────────────────\nPattern/gradient slot\nimage tiled into fill\nor brush stroke region"];
    }

    subgraph cluster_fill_adj {
        label="FILL ADJUSTMENT (F8)" labelloc=t labeljust=l
        fontcolor=white fontsize=11.0 fontname="Cascadia Code PL"
        color=orange style=dashed penwidth=1

        F_OFF [label="Fill-Adj OFF\n─────────────────\nFILL_ADJ.ENABLED = FALSE\nImmediate fill/brush\nNo overlay"];
        F_ON [label="Fill-Adj ON\n─────────────────\nFILL_ADJ.ENABLED = TRUE\nAfter fill: enter adj mode\nL-handle for origin+scale"];
        F_ACTIVE [label="Adjusting\n─────────────────\nFILL_ADJ.ACTIVE = TRUE\nDrag origin, scale X/Y\nLive preview updates"];

        F_OFF -> F_ON [label="  Press F8" color="#66cc66"];
        F_ON -> F_OFF [label="  Press F8" color="#cc6666" style=dashed];
        F_ON -> F_ACTIVE [label="  Fill/brush release\n  enters adj mode" color="#cccc66"];
        F_ACTIVE -> F_ON [label="  Enter = commit\n  Esc = cancel" color="#cccc66"];
    }

    subgraph cluster_legend {
        label="LEGEND" labelloc=t labeljust=l
        fontcolor=white fontsize=11.0 fontname="Cascadia Code PL"
        color=white style=dashed penwidth=1
        L1 [label="" shape=point width=0.01]; L2 [label="" shape=point width=0.01];
        L3 [label="" shape=point width=0.01]; L4 [label="" shape=point width=0.01];
        L5 [label="" shape=point width=0.01]; L6 [label="" shape=point width=0.01];
        L1 -> L2 [label=" Activate" arrowhead=normal color="#66cc66" fontsize=9.0];
        L3 -> L4 [label=" Deactivate" arrowhead=normal color="#cc6666" style=dashed fontsize=9.0];
        L5 -> L6 [label=" Mode switch" arrowhead=normal color="#6699ff" fontsize=9.0];
    }
}
