digraph FILL_ADJUST {
    label="FILL ADJUST OVERLAY STATE MACHINE" labelloc=t labeljust=c
    ordering=out rankdir=TB
    fontcolor=white fontsize=24.0 fontname="Cascadia Code PL"
    splines=true compound=true
    bgcolor=transparent
    edge [color=gray fontcolor="#aaaaaa" fontsize=9.0 fontname="Cascadia Code PL"];
    node [color=white shape=rect style="" fontname="Cascadia Code PL" fontsize=11.0 fontcolor=cyan];

    { node [shape=folder color=orange penwidth=2 fontcolor=orange fontsize=13.0];
        MAIN [label="FILL ADJUST (F8 OVERLAY)"];
    }

    S_INACTIVE [label="1 ¬∑ INACTIVE\n‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ\nFILL_ADJ.active% = FALSE\nCustom brush / paint\nrenders normally tiled"];
    S_ACTIVE [label="2 ¬∑ ACTIVE OVERLAY\n‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ\nF8 toggled on\nHandles drawn over\ntile preview\nLive parameter feedback"];
    S_DRAG_OFFSET [label="3 ¬∑ DRAGGING OFFSET\n‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ\nB1 inside tile area\nUpdate tileX, tileY\nFRAME_IDLE% = FALSE"];
    S_DRAG_SCALE [label="4 ¬∑ DRAGGING SCALE\n‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ\nB1 on L-handle\nIndependent X/Y scale\nor uniform if Shift"];
    S_DRAG_ROT [label="5 ¬∑ DRAGGING ROTATE\n‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ\nB1 on rotation handle\nUpdate angle\nLive rotation preview"];
    S_COMMITTING [label="6 ¬∑ COMMITTING\n‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ\nF8 / Enter to apply\nValues persist on tool\nBuffer flushed"];

    S_INACTIVE -> S_ACTIVE [label="  F8 pressed\n  while custom brush /\n  paint mode active" color="#66cc66"];
    S_ACTIVE -> S_INACTIVE [label="  F8 / Esc / Enter\n  Commit current values" color="#cc6666" style=dashed];
    S_ACTIVE -> S_DRAG_OFFSET [label="  B1 in tile area" color="#66cc66"];
    S_DRAG_OFFSET -> S_ACTIVE [label="  B1 released" color="#cccc66"];
    S_ACTIVE -> S_DRAG_SCALE [label="  B1 on L-handle" color="#66cc66"];
    S_DRAG_SCALE -> S_ACTIVE [label="  B1 released" color="#cccc66"];
    S_ACTIVE -> S_DRAG_ROT [label="  B1 on rotate handle" color="#66cc66"];
    S_DRAG_ROT -> S_ACTIVE [label="  B1 released" color="#cccc66"];
    S_ACTIVE -> S_COMMITTING [label="  Enter / F8 toggle off" color="#cccc66"];
    S_COMMITTING -> S_INACTIVE [label="  Values written\n  back to tool state" color="#cc6666" style=dashed];

    subgraph cluster_handles {
        label="HANDLES" labelloc=t labeljust=l
        fontcolor=orange fontsize=11.0 color=orange style=dashed penwidth=1

        H1 [label="Center / Drag\n‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ\nMove tile origin\n(offsetX, offsetY)" fontsize=10.0];
        H2 [label="L-Handle\n‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ\nIndependent scale\nX leg = scaleX\nY leg = scaleY" fontsize=10.0];
        H3 [label="Rotation Knob\n‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ\nAngle in degrees\nSnap to 15¬∞ w/ Shift" fontsize=10.0];
    }

    subgraph cluster_targets {
        label="APPLIES TO" labelloc=t labeljust=l
        fontcolor=orange fontsize=11.0 color=orange style=dashed penwidth=1

        TG1 [label="Custom Brush Tile\n‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ\nWhen brush is\ncustom-image based" fontsize=10.0];
        TG2 [label="Paint Mode Fill\n‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ\nTiled pattern fills\nfor rect / ellipse / fill\nwith custom brush" fontsize=10.0];
    }

    MAIN -> S_INACTIVE [arrowhead=none color="#555555" style=dotted];
    { rank=min; MAIN }

    subgraph cluster_legend {
        label="LEGEND" labelloc=t labeljust=l
        fontcolor=white fontsize=11.0 color=white style=dashed penwidth=1
        L1 [label="" shape=point width=0.01]; L2 [label="" shape=point width=0.01];
        L3 [label="" shape=point width=0.01]; L4 [label="" shape=point width=0.01];
        L5 [label="" shape=point width=0.01]; L6 [label="" shape=point width=0.01];
        L1 -> L2 [label=" Activate" arrowhead=normal color="#66cc66" fontsize=9.0];
        L3 -> L4 [label=" Deactivate" arrowhead=normal color="#cc6666" style=dashed fontsize=9.0];
        L5 -> L6 [label=" Transition" arrowhead=normal color="#cccc66" fontsize=9.0];
    }
}
