digraph CROSSHAIR_STATES {
    label="CROSSHAIR ASSISTANT STATE MACHINE" labelloc=t labeljust=c
    ordering=out rankdir=TB
    fontcolor=white fontsize=24.0 fontname="Cascadia Code PL"
    splines=true compound=true
    bgcolor=transparent
    edge [
        color=gray fontcolor="#aaaaaa" fontsize=9.0
        fontname="Cascadia Code PL"
    ];
    node [
        color=white shape=rect style=""
        fontname="Cascadia Code PL" fontsize=11.0 fontcolor=cyan
    ];

    { node [shape=folder color=orange penwidth=2 fontcolor=orange fontsize=13.0];
        MAIN [label="CROSSHAIR\nASSISTANT"];
    }

    S_OFF [label="1 · OFF\n─────────────────\nCROSSHAIR.VISIBLE = FALSE\nNo crosshair lines drawn\nDefault state"];
    S_ON [label="2 · ON\n─────────────────\nCROSSHAIR.VISIBLE = TRUE\nFull-screen H+V guide lines\nIntersect at mouse position\nOutline stroke configurable"];
    S_DRAWING [label="3 · DRAWING\n─────────────────\nActive tool in use\nCrosshair shown at\ncurrent canvas coords\nUpdates each frame"];

    S_OFF -> S_ON [label="  Toggle crosshair\n  View → Crosshair\n  or hotkey" color="#66cc66"];
    S_ON -> S_OFF [label="  Toggle crosshair\n  View → Crosshair\n  or hotkey" color="#cc6666" style=dashed];
    S_ON -> S_DRAWING [label="  Mouse enters canvas\n  Active drawing tool\n  selected" color="#66cc66"];
    S_DRAWING -> S_ON [label="  Mouse leaves canvas\n  or tool released" color="#cc6666" style=dashed];
    S_DRAWING -> S_DRAWING [label="  Mouse moves\n  CROSSHAIR_render()\n  updates position" color="#88aacc"];

    MAIN -> S_OFF [arrowhead=none color="#555555" style=dotted];
    { rank=min; MAIN }

    subgraph cluster_outline {
        label="OUTLINE STROKE" labelloc=t labeljust=l
        fontcolor=white fontsize=11.0 fontname="Cascadia Code PL"
        color=orange style=dashed penwidth=1

        O_NONE [label="No Outline\n─────────────────\nSingle-pixel lines\nDirect color only"];
        O_STROKE [label="With Outline\n─────────────────\nConfigurable outline\nstroke width\nContrast against canvas"];

        O_NONE -> O_STROKE [label="  CFG change\n  outline > 0" color="#6699ff"];
        O_STROKE -> O_NONE [label="  CFG change\n  outline = 0" color="#6699ff"];
    }

    subgraph cluster_rendering {
        label="RENDER PIPELINE" labelloc=t labeljust=l
        fontcolor=white fontsize=11.0 fontname="Cascadia Code PL"
        color=orange style=dashed penwidth=1

        R1 [label="CROSSHAIR_render(dest&)\n─────────────────\nDraw horizontal line\nDraw vertical line\nAt canvas mouse coords"];
        R2 [label="After Scene Cache\n─────────────────\nRendered AFTER\nSkipToPointer step 13\nNot cached in scene"];
    }

    subgraph cluster_legend {
        label="LEGEND" labelloc=t labeljust=l
        fontcolor=white fontsize=11.0 fontname="Cascadia Code PL"
        color=white style=dashed penwidth=1
        L1 [label="" shape=point width=0.01]; L2 [label="" shape=point width=0.01];
        L3 [label="" shape=point width=0.01]; L4 [label="" shape=point width=0.01];
        L5 [label="" shape=point width=0.01]; L6 [label="" shape=point width=0.01];
        L1 -> L2 [label=" Activate" arrowhead=normal color="#66cc66" fontsize=9.0];
        L3 -> L4 [label=" Deactivate" arrowhead=normal color="#cc6666" style=dashed fontsize=9.0];
        L5 -> L6 [label=" Self-transition" arrowhead=normal color="#88aacc" fontsize=9.0];
    }
}
