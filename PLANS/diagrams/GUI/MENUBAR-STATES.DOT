digraph MENUBAR {
    label="MENU BAR STATE MACHINE" labelloc=t labeljust=c
    ordering=out rankdir=TB
    fontcolor=white fontsize=24.0 fontname="Cascadia Code PL"
    splines=true compound=true
    bgcolor=transparent
    edge [
        color=gray fontcolor="#aaaaaa" fontsize=9.0
        fontname="Cascadia Code PL"
    ];
    node [
        color=white shape=rect style=""
        fontname="Cascadia Code PL" fontsize=11.0 fontcolor=cyan
    ];

    { node [shape=folder color=orange penwidth=2 fontcolor=orange fontsize=13.0];
        MAIN [label="MAIN STATES"];
        CASCADE [label="CASCADING SUBMENUS"];
        KB_NAV [label="KEYBOARD NAV"];
    }

    // ─────────────────────────────────────────────────────
    //  MAIN STATES
    // ─────────────────────────────────────────────────────

    S_CLOSED [label="1 · CLOSED\n─────────────────\nopenMenu = -1\nNo dropdown visible\nBar rendered with labels\nhoverRoot tracks mouse"];
    S_ROOT_OPEN [label="2 · ROOT MENU OPEN\n─────────────────\nopenMenu = rootIdx\nDropdown rendered below\nhoverSub = item index\nstayOpen = TRUE"];
    S_HOVER [label="3 · SUBMENU HOVER\n─────────────────\nhoverSub = itemIdx\nItem highlighted\nReady for click or\nkeyboard Enter"];
    S_CASCADE [label="4 · CASCADE OPEN\n─────────────────\nrecentOpen / randomOpen /\ntransformOpen / layoutOpen /\npvwOpen = TRUE\nNested dropdown visible"];
    S_OVERFLOW [label="5 · OVERFLOW MENU\n─────────────────\nMENU_CHEVRON_ACTIVE = TRUE\nMENU_OVERFLOW_OPEN = TRUE\n>> button shows hidden roots"];
    S_KB_ACTIVE [label="6 · KEYBOARD ACTIVE\n─────────────────\nkbActive = TRUE\nArrow keys navigate\nMouse ignored until move\nEnter executes action"];

    // ─────────────────────────────────────────────────────
    //  MAIN TRANSITIONS
    // ─────────────────────────────────────────────────────

    S_CLOSED -> S_ROOT_OPEN [
        label="  Click root label\n  MENUBAR_handle_click()"
        color="#66cc66"
    ];
    S_CLOSED -> S_KB_ACTIVE [
        label="  ALT tap / F10\n  altTapped = TRUE\n  kbActive = TRUE"
        color="#6699ff"
    ];
    S_ROOT_OPEN -> S_ROOT_OPEN [
        label="  Hover different root\n  openMenu = newRootIdx\n  (auto-switch while open)"
        color="#88aacc"
    ];
    S_ROOT_OPEN -> S_HOVER [
        label="  Mouse enters submenu item\n  hoverSub = itemIdx"
        color="#66cc66"
    ];
    S_HOVER -> S_CASCADE [
        label="  Hover item with cascade\n  (Recent, Random, Transform,\n  Layout, Preview)\n  Open nested submenu"
        color="#66cc66"
    ];
    S_HOVER -> S_CLOSED [
        label="  Click item → execute action\n  MENUBAR_close_all()\n  CMD_execute_action(actionId)"
        color="#cccc66"
    ];
    S_ROOT_OPEN -> S_CLOSED [
        label="  Click outside menu\n  Escape key\n  MENUBAR_close_all()"
        color="#cc6666" style=dashed
    ];
    S_CASCADE -> S_HOVER [
        label="  Mouse leaves cascade area\n  Close nested dropdown"
        color="#cc6666" style=dashed
    ];
    S_CASCADE -> S_CLOSED [
        label="  Click cascade item\n  Execute action, close all"
        color="#cccc66"
    ];
    S_CLOSED -> S_OVERFLOW [
        label="  Click >> chevron\n  MENU_CHEVRON_ACTIVE = TRUE"
        color="#66cc66"
    ];
    S_OVERFLOW -> S_ROOT_OPEN [
        label="  Click overflow item\n  Open that root's submenu"
        color="#66cc66"
    ];
    S_OVERFLOW -> S_CLOSED [
        label="  Click outside\n  Escape"
        color="#cc6666" style=dashed
    ];
    S_KB_ACTIVE -> S_ROOT_OPEN [
        label="  Enter / Down arrow\n  Open selected root"
        color="#66cc66"
    ];
    S_KB_ACTIVE -> S_KB_ACTIVE [
        label="  Left/Right arrow\n  Move to adjacent root"
        color="#88aacc"
    ];
    S_KB_ACTIVE -> S_CLOSED [
        label="  Escape / ALT tap\n  kbActive = FALSE"
        color="#cc6666" style=dashed
    ];

    // ─────────────────────────────────────────────────────
    //  CASCADE SUB-STATES
    // ─────────────────────────────────────────────────────

    subgraph cluster_cascade {
        label="CASCADING SUBMENUS" labelloc=t labeljust=l
        fontcolor=orange fontsize=11.0 fontname="Cascadia Code PL"
        color=orange style=dashed penwidth=1

        C_RECENT [label="Recent Files\n────────────\nrecentOpen = TRUE\nrecentHover = idx\nUp to 10 recent files"
                  fontsize=10.0];
        C_RANDOM [label="Random Palette\n────────────\nrandomOpen = TRUE\nrandomHover = idx\nLospec random palettes"
                  fontsize=10.0];
        C_TRANSFORM [label="Transform Menu\n────────────\ntransformOpen = TRUE\ntransformHover = idx\nFlip, Rotate, Scale"
                     fontsize=10.0];
        C_LAYOUT [label="Layer Layout\n────────────\nlayoutOpen = TRUE\nlayoutHover = idx\nAlign, Distribute"
                  fontsize=10.0];
        C_PVW [label="Preview Submenu\n────────────\npvwOpen = TRUE\npvwHover = idx\nMode, Recent Images"
               fontsize=10.0];
        C_PVW_RECENT [label="PVW → Recent\n────────────\npvwRecentOpen = TRUE\npvwRecentHover = idx\nNested level 3"
                      fontsize=10.0];

        C_PVW -> C_PVW_RECENT [
            label=" Hover Recent item"
            color="#88aacc" fontsize=8.0
        ];
    }

    // ─────────────────────────────────────────────────────
    //  KEYBOARD NAV SUB-STATES
    // ─────────────────────────────────────────────────────

    subgraph cluster_kbnav {
        label="KEYBOARD NAVIGATION" labelloc=t labeljust=l
        fontcolor=orange fontsize=11.0 fontname="Cascadia Code PL"
        color=orange style=dashed penwidth=1

        KB_ROOT [label="Root Level\n────────────\n← → = Switch root\nEnter/↓ = Open submenu\nEscape = Close"
                 fontsize=10.0];
        KB_SUB [label="Submenu Level\n────────────\n↑ ↓ = Navigate items\nEnter = Execute action\n→ = Open cascade\n← = Close submenu\nEscape = Back to root"
                fontsize=10.0];
        KB_CASCADE [label="Cascade Level\n────────────\n↑ ↓ = Navigate cascade\nEnter = Execute\n← = Close cascade\nEscape = Back to submenu"
                    fontsize=10.0];

        KB_ROOT -> KB_SUB [label=" Enter / ↓" color="#66cc66" fontsize=8.0];
        KB_SUB -> KB_ROOT [label=" ← / Escape" color="#cc6666" fontsize=8.0 style=dashed];
        KB_SUB -> KB_CASCADE [label=" → on cascade item" color="#66cc66" fontsize=8.0];
        KB_CASCADE -> KB_SUB [label=" ← / Escape" color="#cc6666" fontsize=8.0 style=dashed];
    }

    // ─────────────────────────────────────────────────────
    //  CROSS-LINKS
    // ─────────────────────────────────────────────────────

    MAIN -> S_CLOSED [arrowhead=none color="#555555" style=dotted];
    CASCADE -> C_RECENT [arrowhead=none color="#555555" style=dotted lhead=cluster_cascade];
    KB_NAV -> KB_ROOT [arrowhead=none color="#555555" style=dotted lhead=cluster_kbnav];

    { rank=min; MAIN; CASCADE; KB_NAV }
    { rank=same; S_CLOSED; S_ROOT_OPEN; S_KB_ACTIVE }

    // ─────────────────────────────────────────────────────
    //  LEGEND
    // ─────────────────────────────────────────────────────

    subgraph cluster_legend {
        label="LEGEND" labelloc=t labeljust=l
        fontcolor=white fontsize=11.0 fontname="Cascadia Code PL"
        color=white style=dashed penwidth=1

        L1 [label="" shape=point width=0.01];
        L2 [label="" shape=point width=0.01];
        L3 [label="" shape=point width=0.01];
        L4 [label="" shape=point width=0.01];
        L5 [label="" shape=point width=0.01];
        L6 [label="" shape=point width=0.01];
        L7 [label="" shape=point width=0.01];
        L8 [label="" shape=point width=0.01];

        L1 -> L2 [label=" Open / Navigate" arrowhead=normal color="#66cc66" fontsize=9.0];
        L3 -> L4 [label=" Close / Exit" arrowhead=normal color="#cc6666" style=dashed fontsize=9.0];
        L5 -> L6 [label=" Execute Action" arrowhead=normal color="#cccc66" fontsize=9.0];
        L7 -> L8 [label=" Keyboard Entry" arrowhead=normal color="#6699ff" fontsize=9.0];
    }
}
