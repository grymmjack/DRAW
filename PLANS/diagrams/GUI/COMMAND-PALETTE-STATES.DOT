digraph COMMAND_PALETTE {
    label="COMMAND PALETTE STATE MACHINE" labelloc=t labeljust=c
    ordering=out rankdir=TB
    fontcolor=white fontsize=24.0 fontname="Cascadia Code PL"
    splines=true compound=true
    bgcolor=transparent
    edge [
        color=gray fontcolor="#aaaaaa" fontsize=9.0
        fontname="Cascadia Code PL"
    ];
    node [
        color=white shape=rect style=""
        fontname="Cascadia Code PL" fontsize=11.0 fontcolor=cyan
    ];

    { node [shape=folder color=orange penwidth=2 fontcolor=orange fontsize=13.0];
        MAIN [label="COMMAND PALETTE"];
    }

    S_CLOSED [label="1 · CLOSED\n─────────────────\nCMD.VISIBLE% = FALSE\nNot rendered\nNormal keyboard input"];
    S_OPEN [label="2 · OPEN\n─────────────────\nCMD.VISIBLE% = TRUE\nSearch box focused\nAll 200+ commands listed\nCategory filter active"];
    S_SEARCHING [label="3 · SEARCHING\n─────────────────\nSearch text entered\nCMD.SEARCH_TEXT$\nSubstring filter applied\nMatching items shown"];
    S_HOVER [label="4 · ITEM HOVER\n─────────────────\nCMD.HOVER_IDX% set\nItem highlighted\nDescription shown"];
    S_EXECUTE [label="5 · EXECUTE\n─────────────────\nCMD_execute_action()\nAction ID dispatched\nPalette closes"];

    S_CLOSED -> S_OPEN [
        label="  Ctrl+P / Menu\n  CMD.VISIBLE% = TRUE\n  Focus search input"
        color="#66cc66"
    ];
    S_OPEN -> S_SEARCHING [
        label="  Type characters\n  Filter updates live"
        color="#66cc66"
    ];
    S_SEARCHING -> S_SEARCHING [
        label="  More typing / Delete\n  Filter refines"
        color="#88aacc"
    ];
    S_OPEN -> S_HOVER [
        label="  Mouse over item\n  or ↑/↓ arrows"
        color="#88aacc"
    ];
    S_SEARCHING -> S_HOVER [
        label="  Mouse over filtered item\n  or ↑/↓ arrows"
        color="#88aacc"
    ];
    S_HOVER -> S_EXECUTE [
        label="  Enter / Click item\n  CMD_execute_action(actionId)"
        color="#cccc66"
    ];
    S_EXECUTE -> S_CLOSED [
        label="  Action complete\n  CMD.VISIBLE% = FALSE"
        color="#cc6666" style=dashed
    ];
    S_OPEN -> S_CLOSED [
        label="  Escape\n  CMD.VISIBLE% = FALSE"
        color="#cc6666" style=dashed
    ];
    S_SEARCHING -> S_CLOSED [
        label="  Escape\n  Clear search, close"
        color="#cc6666" style=dashed
    ];
    S_HOVER -> S_SEARCHING [
        label="  Continue typing"
        color="#88aacc"
    ];

    subgraph cluster_categories {
        label="COMMAND CATEGORIES — 15 GROUPS" labelloc=t labeljust=l
        fontcolor=orange fontsize=11.0 fontname="Cascadia Code PL"
        color=orange style=dashed penwidth=1

        CAT_LIST [label="Categories\n────────────\nFile, Edit, Select,\nView, Image, Layer,\nBrush, Tools,\nPalette, Grid,\nSymmetry, Preview,\nDrawer, Transform,\nHelp"
                  fontsize=10.0];
    }

    subgraph cluster_keyboard {
        label="KEYBOARD NAVIGATION" labelloc=t labeljust=l
        fontcolor=orange fontsize=11.0 fontname="Cascadia Code PL"
        color=orange style=dashed penwidth=1

        KB_SEARCH [label="Search Input\n────────────\nAll typing goes to\nsearch box\nBackspace deletes\nActive while open"
                   fontsize=10.0];
        KB_NAV [label="List Navigation\n────────────\n↑/↓ = Move highlight\nEnter = Execute\nPageUp/Down = Jump\nHome/End = First/Last"
                fontsize=10.0];
    }

    MAIN -> S_CLOSED [arrowhead=none color="#555555" style=dotted];
    { rank=min; MAIN }
    { rank=same; S_CLOSED; S_OPEN }

    subgraph cluster_legend {
        label="LEGEND" labelloc=t labeljust=l
        fontcolor=white fontsize=11.0 fontname="Cascadia Code PL"
        color=white style=dashed penwidth=1
        L1 [label="" shape=point width=0.01]; L2 [label="" shape=point width=0.01];
        L3 [label="" shape=point width=0.01]; L4 [label="" shape=point width=0.01];
        L5 [label="" shape=point width=0.01]; L6 [label="" shape=point width=0.01];
        L1 -> L2 [label=" Open / Navigate" arrowhead=normal color="#66cc66" fontsize=9.0];
        L3 -> L4 [label=" Close" arrowhead=normal color="#cc6666" style=dashed fontsize=9.0];
        L5 -> L6 [label=" Execute Action" arrowhead=normal color="#cccc66" fontsize=9.0];
    }
}
