digraph DRAWER {
    label="DRAWER PANEL STATE MACHINE" labelloc=t labeljust=c
    ordering=out rankdir=TB
    fontcolor=white fontsize=24.0 fontname="Cascadia Code PL"
    splines=true compound=true
    bgcolor=transparent
    edge [
        color=gray fontcolor="#aaaaaa" fontsize=9.0
        fontname="Cascadia Code PL"
    ];
    node [
        color=white shape=rect style=""
        fontname="Cascadia Code PL" fontsize=11.0 fontcolor=cyan
    ];

    { node [shape=folder color=orange penwidth=2 fontcolor=orange fontsize=13.0];
        MAIN [label="MAIN STATES"];
        MODES [label="DRAWING MODES"];
        CTX [label="CONTEXT MENU"];
    }

    // ─────────────────────────────────────────────────────
    //  MAIN STATES
    // ─────────────────────────────────────────────────────

    S_HIDDEN [label="1 · HIDDEN\n─────────────────\nSCRN.showDrawer% = FALSE\nManuallyHidden% = TRUE\nPanel not rendered"];
    S_VISIBLE [label="2 · VISIBLE\n─────────────────\nSCRN.showDrawer% = TRUE\n30 slots displayed\nCurrent mode active\nMini palette shown"];
    S_HOVER_SLOT [label="3 · SLOT HOVER\n─────────────────\nhoverSlot = slotIdx\nSlot highlighted\nPreview tooltip if applicable\nQuickLook in Preview window"];
    S_DRAG_SLOT [label="4 · SLOT DRAG\n─────────────────\nDragging slot to reorder\ndragSlot = srcIdx\ndropSlot = dstIdx\nInsertion marker shown"];
    S_CONTEXT [label="5 · CONTEXT MENU\n─────────────────\nRight-click on slot\nPopup menu visible\nOptions: Edit, Copy, Paste,\nClear, Import, Export"];

    S_HIDDEN -> S_VISIBLE [label="  F6 / Menu toggle" color="#66cc66"];
    S_VISIBLE -> S_HIDDEN [label="  F6 / Menu toggle" color="#cc6666" style=dashed];
    S_VISIBLE -> S_HOVER_SLOT [label="  Mouse over slot" color="#88aacc"];
    S_HOVER_SLOT -> S_VISIBLE [label="  Mouse leaves slot" color="#cc6666" style=dashed];
    S_HOVER_SLOT -> S_DRAG_SLOT [label="  B1 drag" color="#66cc66"];
    S_DRAG_SLOT -> S_VISIBLE [label="  Release → reorder slots" color="#cccc66"];
    S_HOVER_SLOT -> S_CONTEXT [label="  Right-click (B2)" color="#66cc66"];
    S_CONTEXT -> S_VISIBLE [label="  Click item / outside / Escape" color="#cccc66"];
    S_HOVER_SLOT -> S_VISIBLE [
        label="  B1 click slot\n  Select slot as active\n  DRAWER.currentSlot% = idx"
        color="#cccc66"
    ];

    // ─────────────────────────────────────────────────────
    //  DRAWING MODE BINS
    // ─────────────────────────────────────────────────────

    subgraph cluster_modes {
        label="DRAWING MODES — Color / Gradient / Pattern" labelloc=t labeljust=l
        fontcolor=orange fontsize=11.0 fontname="Cascadia Code PL"
        color=orange style=dashed penwidth=1

        DM_COLOR [label="Color Mode (Brushes Bin)\n────────────\nDRAWER.mode% = MODE_COLOR\nSlots contain brush images\nPaint with custom brush\nor solid color"
                  fontsize=10.0];
        DM_GRADIENT [label="Gradient Mode (Gradient Bin)\n────────────\nDRAWER.mode% = MODE_GRADIENT\nSlots contain gradient defs\n2-color with dither settings\nPaint with gradient fill"
                     fontsize=10.0];
        DM_PATTERN [label="Pattern Mode (Pattern Bin)\n────────────\nDRAWER.mode% = MODE_PATTERN\nSlots contain pattern tiles\n8×8 or larger patterns\nPaint with tiled pattern"
                    fontsize=10.0];

        DM_COLOR -> DM_GRADIENT [
            label=" Click gradient tab\n or Organizer toggle"
            color="#88aacc" fontsize=8.0
        ];
        DM_GRADIENT -> DM_PATTERN [
            label=" Click pattern tab\n or Organizer toggle"
            color="#88aacc" fontsize=8.0
        ];
        DM_PATTERN -> DM_COLOR [
            label=" Click color tab\n or Organizer toggle"
            color="#88aacc" fontsize=8.0
        ];
        DM_COLOR -> DM_PATTERN [
            label=" Click pattern tab"
            color="#88aacc" fontsize=8.0
        ];
        DM_GRADIENT -> DM_COLOR [
            label=" Click color tab"
            color="#88aacc" fontsize=8.0
        ];
        DM_PATTERN -> DM_GRADIENT [
            label=" Click gradient tab"
            color="#88aacc" fontsize=8.0
        ];
    }

    // ─────────────────────────────────────────────────────
    //  CONTEXT MENU SUB-STATES
    // ─────────────────────────────────────────────────────

    subgraph cluster_context {
        label="SLOT CONTEXT MENU — POPUP_MENU" labelloc=t labeljust=l
        fontcolor=orange fontsize=11.0 fontname="Cascadia Code PL"
        color=orange style=dashed penwidth=1

        CM_EDIT [label="Edit Slot\n────────────\nOpen slot editor\n(brush, pattern, gradient)"
                 fontsize=10.0];
        CM_COPY [label="Copy Slot\n────────────\nCopy to clipboard buffer"
                 fontsize=10.0];
        CM_PASTE [label="Paste Slot\n────────────\nPaste from clipboard buffer"
                  fontsize=10.0];
        CM_CLEAR [label="Clear Slot\n────────────\nReset slot to empty"
                  fontsize=10.0];
        CM_IMPORT [label="Import .dset\n────────────\nDRAWER_IMPORT_dset()\nLoad drawer set file"
                   fontsize=10.0];
        CM_EXPORT [label="Export .dset\n────────────\nDRAWER_EXPORT_dset()\nSave drawer set file"
                   fontsize=10.0];
    }

    // ─────────────────────────────────────────────────────
    //  MINI PALETTE
    // ─────────────────────────────────────────────────────

    subgraph cluster_mini_palette {
        label="MINI PALETTE" labelloc=t labeljust=l
        fontcolor=orange fontsize=11.0 fontname="Cascadia Code PL"
        color=orange style=dashed penwidth=1

        MP_IDLE [label="Mini Palette Idle\n────────────\nCompact color grid\nShows current palette\nFG/BG color swatches"
                 fontsize=10.0];
        MP_CLICK [label="Color Selected\n────────────\nB1 = Set FG color\nB2 = Set BG color\nPAINT_COLOR~& updated"
                  fontsize=10.0];

        MP_IDLE -> MP_CLICK [label=" Click color cell" color="#66cc66" fontsize=8.0];
        MP_CLICK -> MP_IDLE [label=" Color applied" color="#cccc66" fontsize=8.0];
    }

    MAIN -> S_HIDDEN [arrowhead=none color="#555555" style=dotted];
    MODES -> DM_COLOR [arrowhead=none color="#555555" style=dotted lhead=cluster_modes];
    CTX -> CM_EDIT [arrowhead=none color="#555555" style=dotted lhead=cluster_context];
    { rank=min; MAIN; MODES; CTX }

    subgraph cluster_legend {
        label="LEGEND" labelloc=t labeljust=l
        fontcolor=white fontsize=11.0 fontname="Cascadia Code PL"
        color=white style=dashed penwidth=1
        L1 [label="" shape=point width=0.01]; L2 [label="" shape=point width=0.01];
        L3 [label="" shape=point width=0.01]; L4 [label="" shape=point width=0.01];
        L5 [label="" shape=point width=0.01]; L6 [label="" shape=point width=0.01];
        L1 -> L2 [label=" Show / Activate" arrowhead=normal color="#66cc66" fontsize=9.0];
        L3 -> L4 [label=" Hide / Close" arrowhead=normal color="#cc6666" style=dashed fontsize=9.0];
        L5 -> L6 [label=" Select / Commit" arrowhead=normal color="#cccc66" fontsize=9.0];
    }
}
