digraph SETTINGS_DIALOG {
    label="SETTINGS DIALOG STATE MACHINE" labelloc=t labeljust=c
    ordering=out rankdir=TB
    fontcolor=white fontsize=24.0 fontname="Cascadia Code PL"
    splines=true compound=true
    bgcolor=transparent
    edge [color=gray fontcolor="#aaaaaa" fontsize=9.0 fontname="Cascadia Code PL"];
    node [color=white shape=rect style="" fontname="Cascadia Code PL" fontsize=11.0 fontcolor=cyan];

    { node [shape=folder color=orange penwidth=2 fontcolor=orange fontsize=13.0];
        MAIN [label="SETTINGS DIALOG"];
    }

    S_CLOSED [label="1 · CLOSED\n─────────────────\nSETTINGS.visible% = FALSE\nNo modal active\nNormal app input"];
    S_OPENING [label="2 · OPENING\n─────────────────\nSETTINGS_open()\nSnapshot CFG.* values\nLoad current tab\nSCENE_DIRTY% = TRUE"];
    S_OPEN [label="3 · OPEN (TABBED)\n─────────────────\nModal overlay active\nLeft tab list rendered\nRight content panel\nMOUSE_dispatch_tool blocked"];
    S_EDITING [label="4 · EDITING WIDGET\n─────────────────\nFocus on text/spinner/\ncheckbox/dropdown\nLive preview where safe\n(theme, panels)"];
    S_CONFIRMING [label="5 · CONFIRMING APPLY\n─────────────────\nOK pressed\nWrite CFG.* fields\nCFG_save to DRAW.cfg\nClose dialog"];
    S_CANCELING [label="6 · CANCELING\n─────────────────\nCancel / Esc\nRestore CFG.* snapshot\nDiscard pending changes"];

    S_CLOSED -> S_OPENING [label="  Edit → Settings...\n  (action ID)" color="#66cc66"];
    S_OPENING -> S_OPEN [label="  Init complete" color="#cccc66"];
    S_OPEN -> S_EDITING [label="  Click input widget" color="#66cc66"];
    S_EDITING -> S_OPEN [label="  Blur / Tab / commit" color="#cccc66"];
    S_OPEN -> S_CONFIRMING [label="  OK button clicked" color="#66cc66"];
    S_OPEN -> S_CANCELING [label="  Cancel / Esc" color="#cc6666" style=dashed];
    S_CONFIRMING -> S_CLOSED [label="  CFG written\n  Dialog closed" color="#cc6666" style=dashed];
    S_CANCELING -> S_CLOSED [label="  Snapshot restored" color="#cc6666" style=dashed];

    subgraph cluster_tabs {
        label="TABS (8)" labelloc=t labeljust=l
        fontcolor=orange fontsize=11.0 color=orange style=dashed penwidth=1

        T1 [label="General\n────────────\nFPS limit\nTitle behavior\nApp-wide flags" fontsize=10.0];
        T2 [label="Grid\n────────────\nDefault size\nSnap mode\nGrid color" fontsize=10.0];
        T3 [label="Palette\n────────────\nDefault palette\nIndex display\nCell size" fontsize=10.0];
        T4 [label="Panels\n────────────\nPanel visibility\nDock sides\nAuto-hide" fontsize=10.0];
        T5 [label="Audio\n────────────\nSFX volume\nMusic volume\nShuffle mode" fontsize=10.0];
        T6 [label="Fonts\n────────────\nDefault font\nDefault size\nUI font" fontsize=10.0];
        T7 [label="Appearance\n────────────\nTheme select\nToolbar scale\nIcon set" fontsize=10.0];
        T8 [label="Directories\n────────────\nUSER folder paths\nLast-used paths\nReset defaults" fontsize=10.0];
    }

    subgraph cluster_modal {
        label="MODAL BEHAVIOR" labelloc=t labeljust=l
        fontcolor=orange fontsize=11.0 color=orange style=dashed penwidth=1

        M1 [label="Input Routing\n────────────\nMOUSE.UI_CHROME_CLICKED%\nKeyboard captured\nNo tool actions fire" fontsize=10.0];
        M2 [label="Render Pipeline\n────────────\nDrawn after scene cache\nas overlay layer\nFRAME_IDLE% controlled\nby internal animations" fontsize=10.0];
    }

    MAIN -> S_CLOSED [arrowhead=none color="#555555" style=dotted];
    { rank=min; MAIN }

    subgraph cluster_legend {
        label="LEGEND" labelloc=t labeljust=l
        fontcolor=white fontsize=11.0 color=white style=dashed penwidth=1
        L1 [label="" shape=point width=0.01]; L2 [label="" shape=point width=0.01];
        L3 [label="" shape=point width=0.01]; L4 [label="" shape=point width=0.01];
        L5 [label="" shape=point width=0.01]; L6 [label="" shape=point width=0.01];
        L1 -> L2 [label=" Open / Apply" arrowhead=normal color="#66cc66" fontsize=9.0];
        L3 -> L4 [label=" Cancel / Close" arrowhead=normal color="#cc6666" style=dashed fontsize=9.0];
        L5 -> L6 [label=" Transition" arrowhead=normal color="#cccc66" fontsize=9.0];
    }
}
