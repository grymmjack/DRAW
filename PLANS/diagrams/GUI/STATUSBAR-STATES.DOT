digraph STATUSBAR {
    label="STATUS BAR STATE MACHINE" labelloc=t labeljust=c
    ordering=out rankdir=TB
    fontcolor=white fontsize=24.0 fontname="Cascadia Code PL"
    splines=true compound=true
    bgcolor=transparent
    edge [
        color=gray fontcolor="#aaaaaa" fontsize=9.0
        fontname="Cascadia Code PL"
    ];
    node [
        color=white shape=rect style=""
        fontname="Cascadia Code PL" fontsize=11.0 fontcolor=cyan
    ];

    { node [shape=folder color=orange penwidth=2 fontcolor=orange fontsize=13.0];
        MAIN [label="STATUS BAR"];
    }

    S_VISIBLE [label="1 В· VISIBLE\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nSCRN.showStatus% = TRUE\nBottom bar displayed\nCoords, colors, tool info"];
    S_HIDDEN [label="2 В· HIDDEN\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nSCRN.showStatus% = FALSE\nManuallyHidden% = TRUE"];

    S_VISIBLE -> S_HIDDEN [label="  Ctrl+Shift+Down / Menu" color="#cc6666" style=dashed];
    S_HIDDEN -> S_VISIBLE [label="  Ctrl+Shift+Down / Menu" color="#66cc66"];

    subgraph cluster_sections {
        label="STATUS BAR SECTIONS" labelloc=t labeljust=l
        fontcolor=orange fontsize=11.0 fontname="Cascadia Code PL"
        color=orange style=dashed penwidth=1

        SEC_COORDS [label="Coordinates\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nCanvas X, Y position\nMOUSE.X%, MOUSE.Y%\nUpdates every frame"
                    fontsize=10.0];
        SEC_COLORS [label="FG/BG Swatches\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nPAINT_COLOR~& swatch\nPAINT_BG_COLOR~& swatch\nTransparency indicator\nClick: open palette picker"
                    fontsize=10.0];
        SEC_TOOL [label="Tool Info\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nCurrent tool name\nBrush size display\nZoom level %\nCanvas dimensions"
                  fontsize=10.0];
        SEC_MSG [label="Status Message\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nTemporary messages\nFile load/save feedback\nError notifications"
                 fontsize=10.0];
    }

    subgraph cluster_color_click {
        label="COLOR SWATCH INTERACTION" labelloc=t labeljust=l
        fontcolor=orange fontsize=11.0 fontname="Cascadia Code PL"
        color=orange style=dashed penwidth=1

        CC_IDLE [label="No Interaction\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nSwatches displayed" fontsize=10.0];
        CC_FG [label="FG Swatch Click\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nB1 on FG swatch\nOpen palette picker\nSet PAINT_COLOR~&" fontsize=10.0];
        CC_BG [label="BG Swatch Click\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nB1 on BG swatch\nOpen palette picker\nSet PAINT_BG_COLOR~&" fontsize=10.0];
        CC_SWAP [label="Swap Colors\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nX key or swap icon\nSwap FG в†” BG\nPAINT_swap_colors()" fontsize=10.0];
        CC_RESET [label="Reset Colors\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nDefault black/white\nor palette default" fontsize=10.0];

        CC_IDLE -> CC_FG [label=" B1 on FG" color="#66cc66" fontsize=8.0];
        CC_IDLE -> CC_BG [label=" B1 on BG" color="#66cc66" fontsize=8.0];
        CC_IDLE -> CC_SWAP [label=" X key / icon" color="#88aacc" fontsize=8.0];
        CC_IDLE -> CC_RESET [label=" Reset hotkey" color="#88aacc" fontsize=8.0];
        CC_FG -> CC_IDLE [label=" Color set" color="#cccc66" fontsize=8.0];
        CC_BG -> CC_IDLE [label=" Color set" color="#cccc66" fontsize=8.0];
        CC_SWAP -> CC_IDLE [label=" Swapped" color="#cccc66" fontsize=8.0];
        CC_RESET -> CC_IDLE [label=" Reset" color="#cccc66" fontsize=8.0];
    }

    MAIN -> S_VISIBLE [arrowhead=none color="#555555" style=dotted];
    { rank=min; MAIN }
}
