digraph EDITBAR {
    label="EDIT BAR STATE MACHINE" labelloc=t labeljust=c
    ordering=out rankdir=TB
    fontcolor=white fontsize=24.0 fontname="Cascadia Code PL"
    splines=true compound=true
    bgcolor=transparent
    edge [
        color=gray fontcolor="#aaaaaa" fontsize=9.0
        fontname="Cascadia Code PL"
    ];
    node [
        color=white shape=rect style=""
        fontname="Cascadia Code PL" fontsize=11.0 fontcolor=cyan
    ];

    { node [shape=folder color=orange penwidth=2 fontcolor=orange fontsize=13.0];
        MAIN [label="MAIN STATES"];
        DOCK [label="DOCKING"];
    }

    S_HIDDEN [label="1 · HIDDEN\n─────────────────\nSCRN.showEditBar% = FALSE\nManuallyHidden% = TRUE\nNot rendered"];
    S_VISIBLE [label="2 · VISIBLE\n─────────────────\nSCRN.showEditBar% = TRUE\nVertical icon bar\n20 action buttons\nDocked LEFT or RIGHT"];
    S_HOVER [label="3 · BUTTON HOVER\n─────────────────\nMouse over action button\nHighlight + tooltip queued"];
    S_CLICK [label="4 · BUTTON CLICK\n─────────────────\nCMD_execute_action()\nAction dispatched\nVisual feedback flash"];

    S_HIDDEN -> S_VISIBLE [label="  F5 / Menu toggle" color="#66cc66"];
    S_VISIBLE -> S_HIDDEN [label="  F5 / Menu toggle" color="#cc6666" style=dashed];
    S_VISIBLE -> S_HOVER [label="  Mouse over button" color="#88aacc"];
    S_HOVER -> S_CLICK [label="  B1 click" color="#66cc66"];
    S_CLICK -> S_VISIBLE [label="  Action executed" color="#cccc66"];
    S_HOVER -> S_VISIBLE [label="  Mouse leaves" color="#cc6666" style=dashed];

    subgraph cluster_docking {
        label="DOCKING — LEFT / RIGHT" labelloc=t labeljust=l
        fontcolor=orange fontsize=11.0 fontname="Cascadia Code PL"
        color=orange style=dashed penwidth=1

        D_LEFT [label="Docked Left\n────────────\nEDITBAR.dock% = DOCK_LEFT\nBar on left edge\nBetween toolbar and canvas"
                fontsize=10.0];
        D_RIGHT [label="Docked Right\n────────────\nEDITBAR.dock% = DOCK_RIGHT\nBar on right edge\nBetween canvas and layers"
                 fontsize=10.0];

        D_LEFT -> D_RIGHT [label=" Menu: Dock Right" color="#88aacc" fontsize=8.0];
        D_RIGHT -> D_LEFT [label=" Menu: Dock Left" color="#88aacc" fontsize=8.0];
    }

    subgraph cluster_actions {
        label="EDIT BAR ACTIONS — 20 BUTTONS" labelloc=t labeljust=l
        fontcolor=orange fontsize=11.0 fontname="Cascadia Code PL"
        color=orange style=dashed penwidth=1

        A_LIST [label="Edit Actions\n────────────\nUndo, Redo\nCut, Copy, Paste\nClear, Select All\nDeselect, Invert Selection\nCrop to Selection\nFlip H/V, Rotate CW/CCW\nScale Up/Down\nTransform...\nImage Adjustments\nRemove Background"
                fontsize=10.0];
    }

    MAIN -> S_HIDDEN [arrowhead=none color="#555555" style=dotted];
    DOCK -> D_LEFT [arrowhead=none color="#555555" style=dotted lhead=cluster_docking];
    { rank=min; MAIN; DOCK }

    subgraph cluster_legend {
        label="LEGEND" labelloc=t labeljust=l
        fontcolor=white fontsize=11.0 fontname="Cascadia Code PL"
        color=white style=dashed penwidth=1
        L1 [label="" shape=point width=0.01]; L2 [label="" shape=point width=0.01];
        L3 [label="" shape=point width=0.01]; L4 [label="" shape=point width=0.01];
        L1 -> L2 [label=" Show / Activate" arrowhead=normal color="#66cc66" fontsize=9.0];
        L3 -> L4 [label=" Hide / Close" arrowhead=normal color="#cc6666" style=dashed fontsize=9.0];
    }
}
