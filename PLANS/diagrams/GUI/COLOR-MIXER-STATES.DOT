digraph COLOR_MIXER {
    label="COLOR MIXER STATE MACHINE" labelloc=t labeljust=c
    ordering=out rankdir=TB
    fontcolor=white fontsize=24.0 fontname="Cascadia Code PL"
    splines=true compound=true
    bgcolor=transparent
    edge [color=gray fontcolor="#aaaaaa" fontsize=9.0 fontname="Cascadia Code PL"];
    node [color=white shape=rect style="" fontname="Cascadia Code PL" fontsize=11.0 fontcolor=cyan];

    { node [shape=folder color=orange penwidth=2 fontcolor=orange fontsize=13.0];
        MAIN [label="COLOR MIXER PANEL"];
    }

    S_HIDDEN [label="1 · HIDDEN\n─────────────────\nCOLOR_MIXER.show% = FALSE\nPanel not rendered\nView → Color Mixer (act 2021)\nto toggle"];
    S_VISIBLE [label="2 · VISIBLE\n─────────────────\nCOLOR_MIXER.show% = TRUE\nFloating panel drawn\nLive sliders for FG color\nRGB + HSV channels"];
    S_DRAGGING [label="3 · DRAGGING SLIDER\n─────────────────\nMOUSE.B1% held\nover R/G/B/H/S/V slider\nLive update PAINT_COLOR~&\nSCENE_DIRTY% = TRUE"];
    S_TYPING [label="4 · TYPING HEX\n─────────────────\nFocus on hex field\nInput keyboard digits\nParse → _RGB32()\nApply on Enter"];
    S_PANEL_DRAG [label="5 · MOVING PANEL\n─────────────────\nMOUSE.B1% on title bar\nUpdate panel X/Y\nClamp to work area"];

    S_HIDDEN -> S_VISIBLE [label="  Action 2021 fired\n  (View menu / Cmd palette)" color="#66cc66"];
    S_VISIBLE -> S_HIDDEN [label="  Action 2021 fired again\n  Close button clicked" color="#cc6666" style=dashed];
    S_VISIBLE -> S_DRAGGING [label="  B1 press on slider track" color="#66cc66"];
    S_DRAGGING -> S_VISIBLE [label="  B1 released\n  Final color committed" color="#cccc66"];
    S_VISIBLE -> S_TYPING [label="  Click hex input field" color="#66cc66"];
    S_TYPING -> S_VISIBLE [label="  Enter / Esc / blur" color="#cccc66"];
    S_VISIBLE -> S_PANEL_DRAG [label="  B1 press on title bar" color="#66cc66"];
    S_PANEL_DRAG -> S_VISIBLE [label="  B1 released" color="#cccc66"];

    subgraph cluster_channels {
        label="EDITABLE CHANNELS" labelloc=t labeljust=l
        fontcolor=orange fontsize=11.0 color=orange style=dashed penwidth=1

        C_RGB [label="RGB Sliders\n────────────\nR / G / B (0–255)\nLive update via _RGB32()" fontsize=10.0];
        C_HSV [label="HSV Sliders\n────────────\nH (0–360) S/V (0–100)\nConvert HSV → RGB\non change" fontsize=10.0];
        C_ALPHA [label="Alpha Slider\n────────────\nA (0–255)\n_RGBA32() builds\nfinal PAINT_COLOR~&" fontsize=10.0];
        C_HEX [label="Hex Input\n────────────\n#RRGGBB or #RRGGBBAA\nParsed on Enter" fontsize=10.0];
    }

    subgraph cluster_persist {
        label="PERSISTENCE" labelloc=t labeljust=l
        fontcolor=orange fontsize=11.0 color=orange style=dashed penwidth=1

        P1 [label="Visibility\n────────────\nCOLOR_MIXER.show%\nsaved to DRAW.cfg\nas COLOR_MIXER_VISIBLE%" fontsize=10.0];
        P2 [label="Position\n────────────\nPanel X/Y persisted\nAlongside other panels" fontsize=10.0];
    }

    MAIN -> S_HIDDEN [arrowhead=none color="#555555" style=dotted];
    { rank=min; MAIN }

    subgraph cluster_legend {
        label="LEGEND" labelloc=t labeljust=l
        fontcolor=white fontsize=11.0 color=white style=dashed penwidth=1
        L1 [label="" shape=point width=0.01]; L2 [label="" shape=point width=0.01];
        L3 [label="" shape=point width=0.01]; L4 [label="" shape=point width=0.01];
        L5 [label="" shape=point width=0.01]; L6 [label="" shape=point width=0.01];
        L1 -> L2 [label=" Activate" arrowhead=normal color="#66cc66" fontsize=9.0];
        L3 -> L4 [label=" Deactivate" arrowhead=normal color="#cc6666" style=dashed fontsize=9.0];
        L5 -> L6 [label=" Transition" arrowhead=normal color="#cccc66" fontsize=9.0];
    }
}
