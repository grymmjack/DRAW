digraph CHARMAP {
    label="CHARACTER MAP STATE MACHINE" labelloc=t labeljust=c
    ordering=out rankdir=TB
    fontcolor=white fontsize=24.0 fontname="Cascadia Code PL"
    splines=true compound=true
    bgcolor=transparent
    edge [
        color=gray fontcolor="#aaaaaa" fontsize=9.0
        fontname="Cascadia Code PL"
    ];
    node [
        color=white shape=rect style=""
        fontname="Cascadia Code PL" fontsize=11.0 fontcolor=cyan
    ];

    { node [shape=folder color=orange penwidth=2 fontcolor=orange fontsize=13.0];
        MAIN [label="MAIN STATES"];
        CELL [label="CELL INTERACTION"];
        USE_CHARS [label="USE CHARS MODE"];
        CHAR_GRID [label="CHARACTER GRID"];
        DOCK [label="DOCKING"];
        BITMAP [label="BITMAP FONT LOADING"];
    }

    // ───────── MAIN STATES ─────────
    S_HIDDEN [label="1 · HIDDEN\n─────────────────\nSCRN.showCharMap% = FALSE\nManuallyHidden% = TRUE\nPanel not rendered"];
    S_VISIBLE [label="2 · VISIBLE\n─────────────────\nSCRN.showCharMap% = TRUE\n16×16 glyph grid shown\nDocked LEFT or RIGHT\nGlyph cache built"];
    S_CACHE_STALE [label="3 · CACHE STALE\n─────────────────\ncacheValid% = FALSE\nFont or size changed\nRebuild on next render"];

    S_HIDDEN -> S_VISIBLE [label="  Ctrl+M / Menu toggle\n  or [USE CHARS] enabled" color="#66cc66"];
    S_VISIBLE -> S_HIDDEN [label="  Ctrl+M / Menu toggle" color="#cc6666" style=dashed];
    S_VISIBLE -> S_CACHE_STALE [label="  Font/size changed\n  in TEXT BAR" color="#cccc66"];
    S_CACHE_STALE -> S_VISIBLE [label="  CHARMAP_rebuild_cache\n  (or _bitmap variant)" color="#66cc66"];
    S_HIDDEN -> S_VISIBLE [label="  F11 restore\n  (toggle-all)" color="#88aacc" style=dotted];

    // ───────── CELL INTERACTION ─────────
    C_IDLE [label="4 · NO SELECTION\n─────────────────\nselectedIdx% = -1\nhoverIdx% = -1\nCells show default colors"];
    C_HOVER [label="5 · CELL HOVER\n─────────────────\nhoverIdx% = 0..255\nHover BG/FG highlight\nTooltip: char code"];
    C_SELECTED [label="6 · CELL SELECTED\n─────────────────\nselectedIdx% = 0..255\nSelected BG/FG highlight\nGlyph → custom brush"];
    C_FLASH [label="7 · CELL FLASH\n─────────────────\nflashIdx% = 0..255\nFlash FG color (0.3s)\nTriggered by typing\nor F-key ANSI insert"];

    C_IDLE -> C_HOVER [label="  Mouse enters cell" color="#88aacc"];
    C_HOVER -> C_IDLE [label="  Mouse leaves all cells" color="#cc6666" style=dashed];
    C_HOVER -> C_SELECTED [label="  L-Click cell" color="#66cc66"];
    C_SELECTED -> C_IDLE [label="  L-Click same cell\n  (deselect toggle)" color="#cc6666" style=dashed];
    C_SELECTED -> C_SELECTED [label="  L-Click different cell" color="#cccc66"];
    C_SELECTED -> C_FLASH [label="  Typing / F-key\n  (char feedback)" color="#cc88ff"];
    C_FLASH -> C_SELECTED [label="  Timer > 0.3s\n  Flash expires" color="#88aacc" style=dotted];
    C_IDLE -> C_FLASH [label="  Typing (Use Chars)\n  syncs selectedIdx%" color="#cc88ff"];

    // ───────── USE CHARS MODE ─────────
    UC_OFF [label="8 · USE CHARS OFF\n─────────────────\nuseChars% = FALSE\nStandard text entry\nNo char grid auto-enable"];
    UC_ON [label="9 · USE CHARS ON\n─────────────────\nuseChars% = TRUE\nChar mode active\nCharMap auto-shown\nBrush recolor enabled\nF-keys → ANSI chars"];
    UC_FKEYS [label="10 · F-KEY INSERT\n─────────────────\nF1→176 ░  F2→177 ▒\nF3→178 ▓  F4→219 █\nF5→223 ▀  F6→220 ▄\nF7→221 ▌  F8→222 ▐\nF9→254 ■  F10→250 ·\nF11,F12→32 (space)"];

    UC_OFF -> UC_ON [label="  [USE CHARS] button\n  in Text Bar" color="#66cc66"];
    UC_ON -> UC_OFF [label="  [USE CHARS] button\n  in Text Bar" color="#cc6666" style=dashed];
    UC_ON -> UC_FKEYS [label="  F1-F12 pressed\n  (text tool active)" color="#cc88ff"];
    UC_FKEYS -> UC_ON [label="  Char inserted +\n  flash on map" color="#88aacc"];

    // ───────── CHARACTER GRID ─────────
    CG_OFF [label="11 · CHAR GRID OFF\n─────────────────\ncharGridShow% = FALSE\nNo overlay on canvas"];
    CG_ON [label="12 · CHAR GRID ON\n─────────────────\ncharGridShow% = TRUE\nGrid lines on canvas\nCell W×H from font"];
    CG_SNAP_OFF [label="13 · SNAP OFF\n─────────────────\ncharGridSnap% = FALSE\nFree cursor movement"];
    CG_SNAP_ON [label="14 · SNAP ON\n─────────────────\ncharGridSnap% = TRUE\nCursor snaps to\nchar cell boundaries"];

    CG_OFF -> CG_ON [label="  View → CHAR GRID" color="#66cc66"];
    CG_ON -> CG_OFF [label="  View → CHAR GRID" color="#cc6666" style=dashed];
    CG_SNAP_OFF -> CG_SNAP_ON [label="  View → SNAP TO\n  CHAR GRID" color="#66cc66"];
    CG_SNAP_ON -> CG_SNAP_OFF [label="  View → SNAP TO\n  CHAR GRID" color="#cc6666" style=dashed];

    // ───────── DOCKING ─────────
    subgraph cluster_docking {
        label="DOCKING — LEFT / RIGHT" labelloc=t labeljust=l
        fontcolor=orange fontsize=11.0 fontname="Cascadia Code PL"
        color=orange style=dashed penwidth=1

        D_LEFT [label="Docked Left\n────────────\ndockSide% = DOCK_LEFT\nPanel on left edge\nInside edit bar"
                fontsize=10.0];
        D_RIGHT [label="Docked Right\n────────────\ndockSide% = DOCK_RIGHT\nPanel on right edge\nInside edit bar"
                 fontsize=10.0];
    }

    D_LEFT -> D_RIGHT [label="  Layout → CHAR MAP RIGHT" color="#cccc66"];
    D_RIGHT -> D_LEFT [label="  Layout → CHAR MAP LEFT" color="#cccc66"];

    // ───────── BITMAP FONT LOADING ─────────
    subgraph cluster_bitmap {
        label="BITMAP FONT LOADING" labelloc=t labeljust=l
        fontcolor=orange fontsize=11.0 fontname="Cascadia Code PL"
        color=orange style=dashed penwidth=1

        BF_SCAN [label="Font Scan\n────────────\nScan ASSETS/FONTS/BITMAP/\nScan USER/FONTS/BITMAP/\nDetect: F??, PSF, BDF"
                 fontsize=10.0];
        BF_DETECT [label="Format Detect\n────────────\nFontraption: filesize=256*H\nPSFv1: magic 0x36 0x04\nPSFv2: magic 0x72 0xb5..\nBDF: FONTBOUNDINGBOX"
                   fontsize=10.0];
        BF_ADD [label="Add to List\n────────────\nisBitmapFont = TRUE\nbitmapGlyphW,H set\nDisplay name + WxH"
                fontsize=10.0];
        BF_RENDER [label="Render Glyphs\n────────────\nCHARMAP_rebuild_cache_bitmap\nRead raw binary per char\nWhite pixels on transparent\n→ CHARMAP_GLYPH(0..255)"
                   fontsize=10.0];
    }

    BF_SCAN -> BF_DETECT [label="  Per file" color="#88aacc"];
    BF_DETECT -> BF_ADD [label="  Format recognized" color="#66cc66"];
    BF_ADD -> BF_RENDER [label="  Selected in\n  Text Bar" color="#cccc66"];
}
