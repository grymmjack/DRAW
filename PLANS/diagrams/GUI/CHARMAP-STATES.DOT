digraph CHARMAP {
    label="CHARACTER MAP STATE MACHINE" labelloc=t labeljust=c
    ordering=out rankdir=TB
    fontcolor=white fontsize=24.0 fontname="Cascadia Code PL"
    splines=true compound=true
    bgcolor=transparent
    edge [
        color=gray fontcolor="#aaaaaa" fontsize=9.0
        fontname="Cascadia Code PL"
    ];
    node [
        color=white shape=rect style=""
        fontname="Cascadia Code PL" fontsize=11.0 fontcolor=cyan
    ];

    { node [shape=folder color=orange penwidth=2 fontcolor=orange fontsize=13.0];
        MAIN [label="MAIN STATES"];
        CELL [label="CELL INTERACTION"];
        USE_CHARS [label="USE CHARS MODE"];
        CHAR_GRID [label="CHARACTER GRID"];
        DOCK [label="DOCKING"];
        BITMAP [label="BITMAP FONT LOADING"];
        VCURSOR [label="VIRTUAL CURSOR"];
        COLOR_PICKUP [label="COLOR PICKUP"];
    }

    // в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ MAIN STATES в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
    S_HIDDEN [label="1 В· HIDDEN\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nSCRN.showCharMap% = FALSE\nManuallyHidden% = TRUE\nPanel not rendered"];
    S_VISIBLE [label="2 В· VISIBLE\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nSCRN.showCharMap% = TRUE\n16Г—16 glyph grid shown\nDocked LEFT or RIGHT\nGlyph cache built"];
    S_CACHE_STALE [label="3 В· CACHE STALE\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\ncacheValid% = FALSE\nFont or size changed\nRebuild on next render"];

    S_HIDDEN -> S_VISIBLE [label="  Ctrl+M / Menu toggle\n  or [USE CHARS] enabled" color="#66cc66"];
    S_VISIBLE -> S_HIDDEN [label="  Ctrl+M / Menu toggle" color="#cc6666" style=dashed];
    S_VISIBLE -> S_CACHE_STALE [label="  Font/size changed\n  in TEXT BAR" color="#cccc66"];
    S_CACHE_STALE -> S_VISIBLE [label="  CHARMAP_rebuild_cache\n  (or _bitmap variant)" color="#66cc66"];
    S_HIDDEN -> S_VISIBLE [label="  F11 restore\n  (toggle-all)" color="#88aacc" style=dotted];

    // в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ CELL INTERACTION в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
    C_IDLE [label="4 В· NO SELECTION\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nselectedIdx% = -1\nhoverIdx% = -1\nCells show default colors"];
    C_HOVER [label="5 В· CELL HOVER\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nhoverIdx% = 0..255\nHover BG/FG highlight\nTooltip: char code"];
    C_SELECTED [label="6 В· CELL SELECTED\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nselectedIdx% = 0..255\nSelected BG/FG highlight\nGlyph в†’ custom brush"];
    C_FLASH [label="7 В· CELL FLASH\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nflashIdx% = 0..255\nFlash FG color (0.3s)\nTriggered by typing\nor F-key ANSI insert"];

    C_IDLE -> C_HOVER [label="  Mouse enters cell" color="#88aacc"];
    C_HOVER -> C_IDLE [label="  Mouse leaves all cells" color="#cc6666" style=dashed];
    C_HOVER -> C_SELECTED [label="  L-Click cell" color="#66cc66"];
    C_SELECTED -> C_IDLE [label="  L-Click same cell\n  (deselect toggle)" color="#cc6666" style=dashed];
    C_SELECTED -> C_SELECTED [label="  L-Click different cell" color="#cccc66"];
    C_SELECTED -> C_FLASH [label="  Typing / F-key\n  (char feedback)" color="#cc88ff"];
    C_FLASH -> C_SELECTED [label="  Timer > 0.3s\n  Flash expires" color="#88aacc" style=dotted];
    C_IDLE -> C_FLASH [label="  Typing (Use Chars)\n  syncs selectedIdx%" color="#cc88ff"];

    // в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ USE CHARS MODE в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
    UC_OFF [label="8 В· USE CHARS OFF\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nuseChars% = FALSE\nStandard text entry\nNo char grid auto-enable"];
    UC_ON [label="9 В· USE CHARS ON\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nuseChars% = TRUE\nChar mode active\nCharMap auto-shown\nBrush recolor enabled\nF-keys в†’ ANSI chars\nFont stays locked\nSaved per-document (v19+)"];
    UC_FKEYS [label="10 В· F-KEY INSERT\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nF1в†’176 в–‘  F2в†’177 в–’\nF3в†’178 в–“  F4в†’219 в–€\nF5в†’223 в–Ђ  F6в†’220 в–„\nF7в†’221 в–Њ  F8в†’222 в–ђ\nF9в†’254 в–   F10в†’250 В·\nF11,F12в†’32 (space)"];
    UC_DRAW [label="10b В· DRAW TOOLS\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nDOT / RECT / RECT_FILLED\nFill cells with selected\ncharmap glyph + FG/BG"];

    UC_OFF -> UC_ON [label="  [USE CHARS] button\n  in Text Bar" color="#66cc66"];
    UC_OFF -> UC_ON [label="  DRW load (v19+)\n  useChars restored" color="#88aacc" style=dotted];
    UC_ON -> UC_OFF [label="  [USE CHARS] button\n  in Text Bar" color="#cc6666" style=dashed];
    UC_ON -> UC_FKEYS [label="  F1-F12 pressed\n  (text tool active)" color="#cc88ff"];
    UC_FKEYS -> UC_ON [label="  Char inserted +\n  flash on map" color="#88aacc"];
    UC_ON -> UC_DRAW [label="  Switch to DOT/RECT\n  tool on text layer" color="#cccc66"];
    UC_DRAW -> UC_ON [label="  Switch back to\n  text tool" color="#88aacc"];

    // в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ CHARACTER GRID в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
    CG_OFF [label="11 В· CHAR GRID OFF\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\ncharGridShow% = FALSE\nNo overlay on canvas"];
    CG_ON [label="12 В· CHAR GRID ON\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\ncharGridShow% = TRUE\nGrid lines on canvas\nCell WГ—H from font"];
    CG_SNAP_OFF [label="13 В· SNAP OFF\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\ncharGridSnap% = FALSE\nFree cursor movement"];
    CG_SNAP_ON [label="14 В· SNAP ON\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\ncharGridSnap% = TRUE\nCursor snaps to\nchar cell boundaries"];

    CG_OFF -> CG_ON [label="  View в†’ CHAR GRID" color="#66cc66"];
    CG_OFF -> CG_ON [label="  DRW load (v18+)\n  charGridShow restored\n  + CHARMAP_char_grid_draw" color="#88aacc" style=dotted];
    CG_ON -> CG_OFF [label="  View в†’ CHAR GRID" color="#cc6666" style=dashed];
    CG_SNAP_OFF -> CG_SNAP_ON [label="  View в†’ SNAP TO\n  CHAR GRID" color="#66cc66"];
    CG_SNAP_ON -> CG_SNAP_OFF [label="  View в†’ SNAP TO\n  CHAR GRID" color="#cc6666" style=dashed];

    // в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ DOCKING в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
    subgraph cluster_docking {
        label="DOCKING вЂ” LEFT / RIGHT" labelloc=t labeljust=l
        fontcolor=orange fontsize=11.0 fontname="Cascadia Code PL"
        color=orange style=dashed penwidth=1

        D_LEFT [label="Docked Left\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\ndockSide% = DOCK_LEFT\nPanel on left edge\nInside edit bar"
                fontsize=10.0];
        D_RIGHT [label="Docked Right\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\ndockSide% = DOCK_RIGHT\nPanel on right edge\nInside edit bar"
                 fontsize=10.0];
    }

    D_LEFT -> D_RIGHT [label="  Layout в†’ CHAR MAP RIGHT" color="#cccc66"];
    D_RIGHT -> D_LEFT [label="  Layout в†’ CHAR MAP LEFT" color="#cccc66"];

    // в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ BITMAP FONT LOADING в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
    subgraph cluster_bitmap {
        label="BITMAP FONT LOADING" labelloc=t labeljust=l
        fontcolor=orange fontsize=11.0 fontname="Cascadia Code PL"
        color=orange style=dashed penwidth=1

        BF_SCAN [label="Font Scan\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nScan ASSETS/FONTS/BITMAP/\nScan USER/FONTS/BITMAP/\nDetect: F??, PSF, BDF"
                 fontsize=10.0];
        BF_DETECT [label="Format Detect\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nFontraption: filesize=256*H\nPSFv1: magic 0x36 0x04\nPSFv2: magic 0x72 0xb5..\nBDF: FONTBOUNDINGBOX"
                   fontsize=10.0];
        BF_ADD [label="Add to List\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nisBitmapFont = TRUE\nbitmapGlyphW,H set\nDisplay name + WxH"
                fontsize=10.0];
        BF_RENDER [label="Render Glyphs\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nCHARMAP_rebuild_cache_bitmap\nRead raw binary per char\nWhite pixels on transparent\nв†’ CHARMAP_GLYPH(0..255)"
                   fontsize=10.0];
    }

    BF_SCAN -> BF_DETECT [label="  Per file" color="#88aacc"];
    BF_DETECT -> BF_ADD [label="  Format recognized" color="#66cc66"];
    BF_ADD -> BF_RENDER [label="  Selected in\n  Text Bar" color="#cccc66"];

    // в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ VIRTUAL CURSOR в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
    VC_IDLE [label="15 В· VCURSOR IDLE\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\ncmVirtualCol / cmVirtualRow\nat current position\nNo data created"];
    VC_MOVE [label="16 В· VCURSOR MOVING\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nArrow keys move cursor\nFree grid navigation\nNo characters created\n(expand=FALSE)"];
    VC_TYPE [label="17 В· VCURSOR TYPING\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nCharacter materialized\nat virtual cursor pos\nCursor advances right\n(expand=TRUE)"];

    VC_IDLE -> VC_MOVE [label="  Arrow key pressed\n  (char mode active)" color="#88aacc"];
    VC_MOVE -> VC_IDLE [label="  Key released" color="#cc6666" style=dashed];
    VC_IDLE -> VC_TYPE [label="  Printable key pressed" color="#66cc66"];
    VC_TYPE -> VC_IDLE [label="  Char inserted\n  cursor advanced" color="#88aacc"];

    // в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ COLOR PICKUP в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
    CP_IDLE [label="18 В· PICKUP IDLE\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nWaiting for Alt+U"];
    CP_SAMPLE [label="19 В· SAMPLING\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nRead FG+BG from char\nat virtual cursor pos\nResolve via line breaks\nSet PAINT_COLOR/BG_COLOR\nUpdate palette indices"];

    CP_IDLE -> CP_SAMPLE [label="  Alt+U pressed\n  (char mode active)" color="#cc88ff"];
    CP_SAMPLE -> CP_IDLE [label="  Colors applied\n  palette synced" color="#66cc66"];
}
