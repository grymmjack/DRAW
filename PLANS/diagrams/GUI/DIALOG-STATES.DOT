digraph DIALOGS {
    label="DIALOGS STATE MACHINE" labelloc=t labeljust=c
    ordering=out rankdir=TB
    fontcolor=white fontsize=24.0 fontname="Cascadia Code PL"
    splines=true compound=true
    bgcolor=transparent
    edge [
        color=gray fontcolor="#aaaaaa" fontsize=9.0
        fontname="Cascadia Code PL"
    ];
    node [
        color=white shape=rect style=""
        fontname="Cascadia Code PL" fontsize=11.0 fontcolor=cyan
    ];

    { node [shape=folder color=orange penwidth=2 fontcolor=orange fontsize=13.0];
        NATIVE [label="NATIVE DIALOGS"];
        OVERLAY [label="OVERLAY DIALOGS"];
    }

    // в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
    //  NATIVE DIALOG STATES
    // в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

    N_IDLE [label="1 В· NO DIALOG\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nNormal application state\nAll input processed\nDialogs closed"];
    N_FILE_OPEN [label="2 В· FILE OPEN DIALOG\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\n_OPENFILEDIALOG$()\nOS native dialog\nBlocking call\nDeferred via MOUSE.DEFERRED_ACTION%"];
    N_FILE_SAVE [label="3 В· FILE SAVE DIALOG\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\n_SAVEFILEDIALOG$()\nOS native dialog\nBlocking call"];
    N_MESSAGE [label="4 В· MESSAGE BOX\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\n_MESSAGEBOX()\nConfirmation dialogs\nUnsaved changes warning\nReturn: OK/Cancel"];
    N_CLEANUP [label="5 В· POST-DIALOG CLEANUP\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nMOUSE_cleanup_after_dialog()\nDrain mouse buffer\nForce buttons up\nSUPPRESS_FRAMES% = 2\nClear keyboard buffer"];

    N_IDLE -> N_FILE_OPEN [label="  DEFERRED_ACTION% = 2/3\n  MOUSE_input_handler_loop()" color="#66cc66"];
    N_IDLE -> N_FILE_SAVE [label="  DEFERRED_ACTION% = 1/4\n  MOUSE_input_handler_loop()" color="#66cc66"];
    N_IDLE -> N_MESSAGE [label="  Unsaved changes / confirm\n  CMD_execute_action()" color="#66cc66"];
    N_FILE_OPEN -> N_CLEANUP [label="  Dialog returns path$\n  or empty (cancelled)" color="#cccc66"];
    N_FILE_SAVE -> N_CLEANUP [label="  Dialog returns path$\n  or empty (cancelled)" color="#cccc66"];
    N_MESSAGE -> N_CLEANUP [label="  User clicks OK/Cancel" color="#cccc66"];
    N_CLEANUP -> N_IDLE [label="  SUPPRESS_FRAMES% = 0\n  Input restored" color="#cc6666" style=dashed];

    // в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
    //  OVERLAY DIALOG STATES (Image Adjustments)
    // в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

    subgraph cluster_overlay {
        label="IMAGE ADJUSTMENT OVERLAYS вЂ” GUI/IMAGE-ADJ.BM" labelloc=t labeljust=l
        fontcolor=orange fontsize=11.0 fontname="Cascadia Code PL"
        color=orange style=dashed penwidth=1

        O_CLOSED [label="No Overlay\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nIMGADJ.ACTIVE% = FALSE\nNormal canvas editing"
                  fontsize=10.0];
        O_OPEN [label="Overlay Open\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nIMGADJ.ACTIVE% = TRUE\nModal overlay panel\nLive preview active\nSliders visible"
                fontsize=10.0];
        O_ADJUSTING [label="Adjusting Values\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nSlider drag active\nLive preview updates\nBefore/after toggle"
                     fontsize=10.0];
        O_COMMIT [label="Apply / Cancel\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nOK = Apply to canvas\n  HISTORY_record_brush()\nCancel = Revert preview\n  Restore original"
                  fontsize=10.0];

        O_CLOSED -> O_OPEN [label=" Menu action\n (Brightness, Hue,\n Levels, Blur, etc.)" color="#66cc66" fontsize=8.0];
        O_OPEN -> O_ADJUSTING [label=" Drag slider" color="#66cc66" fontsize=8.0];
        O_ADJUSTING -> O_OPEN [label=" Release slider" color="#88aacc" fontsize=8.0];
        O_OPEN -> O_COMMIT [label=" OK / Cancel / Enter / Escape" color="#cccc66" fontsize=8.0];
        O_COMMIT -> O_CLOSED [label=" Dialog closes\n IMGADJ.ACTIVE% = FALSE" color="#cc6666" fontsize=8.0 style=dashed];
    }

    // в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
    //  ADJUSTMENT TYPES
    // в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

    subgraph cluster_adj_types {
        label="ADJUSTMENT TYPES" labelloc=t labeljust=l
        fontcolor=orange fontsize=11.0 fontname="Cascadia Code PL"
        color=orange style=dashed penwidth=1

        ADJ_BC [label="Brightness/Contrast\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\n2 sliders: -100 to +100" fontsize=10.0];
        ADJ_HS [label="Hue/Saturation\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\n3 sliders: Hue, Sat, Light" fontsize=10.0];
        ADJ_LV [label="Levels\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nHistogram + input/output\nBlack/White/Gamma points" fontsize=10.0];
        ADJ_BL [label="Blur\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nRadius slider\nBox blur / Gaussian" fontsize=10.0];
        ADJ_SH [label="Sharpen\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nAmount slider\nUnsharp mask" fontsize=10.0];
        ADJ_PO [label="Posterize\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nLevels slider (2-256)\nReduce color depth" fontsize=10.0];
        ADJ_PX [label="Pixelate\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nBlock size slider\nMosaic effect" fontsize=10.0];
        ADJ_RB [label="Remove Background\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nThreshold slider\nAuto-detect + remove" fontsize=10.0];
    }

    NATIVE -> N_IDLE [arrowhead=none color="#555555" style=dotted];
    OVERLAY -> O_CLOSED [arrowhead=none color="#555555" style=dotted lhead=cluster_overlay];
    { rank=min; NATIVE; OVERLAY }

    subgraph cluster_legend {
        label="LEGEND" labelloc=t labeljust=l
        fontcolor=white fontsize=11.0 fontname="Cascadia Code PL"
        color=white style=dashed penwidth=1
        L1 [label="" shape=point width=0.01]; L2 [label="" shape=point width=0.01];
        L3 [label="" shape=point width=0.01]; L4 [label="" shape=point width=0.01];
        L5 [label="" shape=point width=0.01]; L6 [label="" shape=point width=0.01];
        L1 -> L2 [label=" Open / Activate" arrowhead=normal color="#66cc66" fontsize=9.0];
        L3 -> L4 [label=" Close / Cleanup" arrowhead=normal color="#cc6666" style=dashed fontsize=9.0];
        L5 -> L6 [label=" Commit / Apply" arrowhead=normal color="#cccc66" fontsize=9.0];
    }
}
