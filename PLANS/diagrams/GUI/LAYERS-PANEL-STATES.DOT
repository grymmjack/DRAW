digraph LAYERS_PANEL {
    label="LAYERS PANEL STATE MACHINE" labelloc=t labeljust=c
    ordering=out rankdir=TB
    fontcolor=white fontsize=24.0 fontname="Cascadia Code PL"
    splines=true compound=true
    bgcolor=transparent
    edge [
        color=gray fontcolor="#aaaaaa" fontsize=9.0
        fontname="Cascadia Code PL"
    ];
    node [
        color=white shape=rect style=""
        fontname="Cascadia Code PL" fontsize=11.0 fontcolor=cyan
    ];

    { node [shape=folder color=orange penwidth=2 fontcolor=orange fontsize=13.0];
        MAIN [label="MAIN STATES"];
        DRAG_F [label="DRAG REORDER"];
        BLEND_F [label="BLEND POPUP"];
        VIS_F [label="VISIBILITY"];
    }

    // ─────────────────────────────────────────────────────
    //  MAIN STATES
    // ─────────────────────────────────────────────────────

    S_NORMAL [label="1 · NORMAL\n─────────────────\nNo drag, no popup\nRows rendered normally\nhoverRow tracks mouse\nCURRENT_LAYER% selected"];
    S_HOVER [label="2 · HOVER ROW\n─────────────────\nhoverRow = layerIdx\nRow highlighted\nButtons visible (eye, lock)"];
    S_DRAG_PENDING [label="3 · DRAG PENDING\n─────────────────\ndragPending = TRUE\nMouse down, not moved\ndragStartY = mouseY\nWaiting for threshold"];
    S_DRAGGING [label="4 · DRAGGING\n─────────────────\nisDragging = TRUE\ndragLayerIdx set\nDrag preview follows mouse\ndropTargetZIndex updates"];
    S_OPACITY_DRAG [label="5 · OPACITY DRAG\n─────────────────\nopacityDrag = TRUE\nopacityDragLayer = idx\nSlider tracks mouse X\n0-255 range"];
    S_SCROLL_DRAG [label="6 · SCROLL DRAG\n─────────────────\nscrollDragging = TRUE\nscrollDragOffset set\nPanel scrolls with thumb"];
    S_BLEND_POPUP [label="7 · BLEND MODE POPUP\n─────────────────\nblendPopupOpen = TRUE\nblendPopupLayer = idx\n18 blend mode options\nblendPopupHover tracks"];
    S_SOLO [label="8 · SOLO MODE\n─────────────────\nsoloLayer = layerIdx\nsavedVisibility(1-64) stored\nAll others hidden\nAlt+Click eye toggles"];

    // ─────────────────────────────────────────────────────
    //  MAIN TRANSITIONS
    // ─────────────────────────────────────────────────────

    S_NORMAL -> S_HOVER [label="  Mouse over row" color="#66cc66"];
    S_HOVER -> S_NORMAL [label="  Mouse leaves panel" color="#cc6666" style=dashed];
    S_HOVER -> S_DRAG_PENDING [
        label="  Mouse down on row\n  (not on button)"
        color="#66cc66"
    ];
    S_DRAG_PENDING -> S_DRAGGING [
        label="  Mouse moved > threshold\n  isDragging = TRUE"
        color="#66cc66"
    ];
    S_DRAG_PENDING -> S_NORMAL [
        label="  Mouse released (click)\n  LAYERS_select(idx)\n  CURRENT_LAYER% = idx"
        color="#cccc66"
    ];
    S_DRAGGING -> S_NORMAL [
        label="  Mouse released\n  LAYER_PANEL_handle_drop()\n  Reorder layer z-index"
        color="#cccc66"
    ];
    S_HOVER -> S_OPACITY_DRAG [
        label="  Click opacity slider area\n  opacityDrag = TRUE"
        color="#66cc66"
    ];
    S_OPACITY_DRAG -> S_NORMAL [
        label="  Mouse released\n  Opacity finalized\n  LAYERS_set_opacity()"
        color="#cccc66"
    ];
    S_HOVER -> S_SCROLL_DRAG [
        label="  Click scrollbar thumb"
        color="#66cc66"
    ];
    S_SCROLL_DRAG -> S_NORMAL [
        label="  Mouse released"
        color="#cccc66"
    ];
    S_HOVER -> S_BLEND_POPUP [
        label="  Click blend mode cell\n  LAYER_PANEL_blend_popup_show()"
        color="#66cc66"
    ];
    S_BLEND_POPUP -> S_NORMAL [
        label="  Click blend item / outside\n  LAYER_PANEL_blend_popup_close()"
        color="#cccc66"
    ];
    S_NORMAL -> S_SOLO [
        label="  Alt+Click eye icon\n  Save all visibility\n  Hide all except target"
        color="#cc66cc"
    ];
    S_SOLO -> S_NORMAL [
        label="  Alt+Click eye again\n  Restore saved visibility"
        color="#cc66cc" style=dashed
    ];

    // ─────────────────────────────────────────────────────
    //  DRAG REORDER SUB-STATES
    // ─────────────────────────────────────────────────────

    subgraph cluster_drag {
        label="DRAG REORDER" labelloc=t labeljust=l
        fontcolor=orange fontsize=11.0 fontname="Cascadia Code PL"
        color=orange style=dashed penwidth=1

        D_ABOVE [label="Drop Above Target\n────────────\ndropTargetZIndex set\nInsertion line shown\nabove target row"
                 fontsize=10.0];
        D_BELOW [label="Drop Below Target\n────────────\ndropTargetZIndex set\nInsertion line shown\nbelow target row"
                 fontsize=10.0];
        D_AUTOSCROLL [label="Auto-Scroll\n────────────\nautoScrollTimer active\nMouse near panel edge\nscrollOffset adjusts"
                      fontsize=10.0];

        D_ABOVE -> D_BELOW [label=" Mouse crosses\n row midpoint" color="#88aacc" fontsize=8.0];
        D_BELOW -> D_ABOVE [label=" Mouse crosses\n row midpoint" color="#88aacc" fontsize=8.0];
        D_ABOVE -> D_AUTOSCROLL [label=" Mouse near edge" color="#88aacc" fontsize=8.0];
        D_BELOW -> D_AUTOSCROLL [label=" Mouse near edge" color="#88aacc" fontsize=8.0];
    }

    // ─────────────────────────────────────────────────────
    //  VISIBILITY SUB-STATES
    // ─────────────────────────────────────────────────────

    subgraph cluster_visibility {
        label="VISIBILITY SWIPE" labelloc=t labeljust=l
        fontcolor=orange fontsize=11.0 fontname="Cascadia Code PL"
        color=orange style=dashed penwidth=1

        V_OFF [label="No Swipe\n────────────\nvisSwiping = FALSE"
               fontsize=10.0];
        V_SWIPING [label="Swiping\n────────────\nvisSwiping = TRUE\nvisSwipeAction = show/hide\nDrag across eye icons\nToggle each crossed layer"
                   fontsize=10.0];

        V_OFF -> V_SWIPING [
            label=" Click+drag eye icon\n visSwipeAction = opposite\n of clicked layer vis"
            color="#66cc66" fontsize=8.0
        ];
        V_SWIPING -> V_OFF [
            label=" Mouse released\n visSwiping = FALSE"
            color="#cc6666" fontsize=8.0 style=dashed
        ];
    }

    // ─────────────────────────────────────────────────────
    //  BLEND MODE POPUP SUB-STATES
    // ─────────────────────────────────────────────────────

    subgraph cluster_blend {
        label="BLEND MODE POPUP — 18 MODES" labelloc=t labeljust=l
        fontcolor=orange fontsize=11.0 fontname="Cascadia Code PL"
        color=orange style=dashed penwidth=1

        B_CLOSED [label="Popup Closed\n────────────\nblendPopupOpen = FALSE"
                  fontsize=10.0];
        B_OPEN [label="Popup Open\n────────────\nblendPopupOpen = TRUE\n18 items listed\nblendPopupHover = idx"
                fontsize=10.0];
        B_SELECT [label="Mode Selected\n────────────\nblendMode = selected\nLAYER.blendMode set\nComposite invalidated"
                  fontsize=10.0];

        B_CLOSED -> B_OPEN [label=" Click blend cell" color="#66cc66" fontsize=8.0];
        B_OPEN -> B_SELECT [label=" Click item" color="#cccc66" fontsize=8.0];
        B_SELECT -> B_CLOSED [label=" Auto-close" color="#cc6666" fontsize=8.0 style=dashed];
        B_OPEN -> B_CLOSED [label=" Click outside / Escape" color="#cc6666" fontsize=8.0 style=dashed];
    }

    // ─────────────────────────────────────────────────────
    //  CROSS-LINKS
    // ─────────────────────────────────────────────────────

    S_DRAGGING -> D_ABOVE [color="#555555" style=dotted lhead=cluster_drag label="  Drag reorder active"];
    S_HOVER -> V_OFF [color="#555555" style=dotted lhead=cluster_visibility label="  Eye icon interaction"];

    MAIN -> S_NORMAL [arrowhead=none color="#555555" style=dotted];
    DRAG_F -> D_ABOVE [arrowhead=none color="#555555" style=dotted lhead=cluster_drag];
    BLEND_F -> B_CLOSED [arrowhead=none color="#555555" style=dotted lhead=cluster_blend];
    VIS_F -> V_OFF [arrowhead=none color="#555555" style=dotted lhead=cluster_visibility];

    { rank=min; MAIN; DRAG_F; BLEND_F; VIS_F }
    { rank=same; S_NORMAL; S_HOVER }

    subgraph cluster_legend {
        label="LEGEND" labelloc=t labeljust=l
        fontcolor=white fontsize=11.0 fontname="Cascadia Code PL"
        color=white style=dashed penwidth=1
        L1 [label="" shape=point width=0.01]; L2 [label="" shape=point width=0.01];
        L3 [label="" shape=point width=0.01]; L4 [label="" shape=point width=0.01];
        L5 [label="" shape=point width=0.01]; L6 [label="" shape=point width=0.01];
        L7 [label="" shape=point width=0.01]; L8 [label="" shape=point width=0.01];
        L1 -> L2 [label=" Activate / Open" arrowhead=normal color="#66cc66" fontsize=9.0];
        L3 -> L4 [label=" Close / Release" arrowhead=normal color="#cc6666" style=dashed fontsize=9.0];
        L5 -> L6 [label=" Commit / Select" arrowhead=normal color="#cccc66" fontsize=9.0];
        L7 -> L8 [label=" Special / Toggle" arrowhead=normal color="#cc66cc" fontsize=9.0];
    }
}
