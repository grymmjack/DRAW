digraph PALETTE_OPS {
    label="PALETTE OPS STATE MACHINE" labelloc=t labeljust=c
    ordering=out rankdir=TB
    fontcolor=white fontsize=24.0 fontname="Cascadia Code PL"
    splines=true compound=true
    bgcolor=transparent
    edge [color=gray fontcolor="#aaaaaa" fontsize=9.0 fontname="Cascadia Code PL"];
    node [color=white shape=rect style="" fontname="Cascadia Code PL" fontsize=11.0 fontcolor=cyan];

    { node [shape=folder color=orange penwidth=2 fontcolor=orange fontsize=13.0];
        MAIN [label="PALETTE OPS вЂ” ON-STRIP EDITING"];
    }

    S_NORMAL [label="1 В· NORMAL MODE\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nPALETTE_OPS.active% = FALSE\nClick = pick FG/BG color\nStandard palette behavior"];
    S_ENTERING [label="2 В· ENTERING OPS\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nUser toggled Ops mode\nIf no [DOCUMENT] palette,\nauto-clone current в†’\n[DOCUMENT]\nSnapshot saved"];
    S_OPS_IDLE [label="3 В· OPS IDLE\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nPALETTE_OPS.active% = TRUE\nVisual indicator on strip\nClick targets are\neditable cells"];
    S_CHANGE [label="4 В· CHANGE COLOR\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nClick + edit color\nopens picker\nPAL_color~&(idx) updated"];
    S_DELETE [label="5 В· DELETE SLOT\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nRight-click / shortcut\nRemove cell from list\nShift remaining indices"];
    S_INSERT [label="6 В· INSERT SLOT\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nInsert key / button\nNew cell at position\ndefault color"];
    S_REARRANGE [label="7 В· DRAG TO REARRANGE\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nB1 drag a cell\nDrop at new index\nRefresh palette indices"];
    S_WAND [label="8 В· WAND SELECT\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nClick canvas pixel\nLook up nearest palette\nindex, highlight cell"];
    S_EXITING [label="9 В· EXITING OPS\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nUser toggled off\nor switched palette\nWrite [DOCUMENT] back\nor restore snapshot"];

    S_NORMAL -> S_ENTERING [label="  Ops mode toggled on" color="#66cc66"];
    S_ENTERING -> S_OPS_IDLE [label="  [DOCUMENT] ready\n  snapshot stored" color="#cccc66"];
    S_OPS_IDLE -> S_CHANGE [label="  Click cell + edit" color="#66cc66"];
    S_CHANGE -> S_OPS_IDLE [label="  Picker closed" color="#cccc66"];
    S_OPS_IDLE -> S_DELETE [label="  Delete shortcut" color="#66cc66"];
    S_DELETE -> S_OPS_IDLE [label="  Cell removed" color="#cccc66"];
    S_OPS_IDLE -> S_INSERT [label="  Insert shortcut" color="#66cc66"];
    S_INSERT -> S_OPS_IDLE [label="  Cell added" color="#cccc66"];
    S_OPS_IDLE -> S_REARRANGE [label="  B1 drag begin" color="#66cc66"];
    S_REARRANGE -> S_OPS_IDLE [label="  B1 released\n  indices reordered" color="#cccc66"];
    S_OPS_IDLE -> S_WAND [label="  Wand tool clicked" color="#66cc66"];
    S_WAND -> S_OPS_IDLE [label="  Cell highlighted" color="#cccc66"];
    S_OPS_IDLE -> S_EXITING [label="  Ops mode toggled off" color="#cc6666" style=dashed];
    S_EXITING -> S_NORMAL [label="  Snapshot restored or\n  [DOCUMENT] saved" color="#cc6666" style=dashed];

    subgraph cluster_doc {
        label="[DOCUMENT] PALETTE" labelloc=t labeljust=l
        fontcolor=orange fontsize=11.0 color=orange style=dashed penwidth=1

        D1 [label="Auto-Clone\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nCurrent palette в†’\n[DOCUMENT] entry\non Ops entry" fontsize=10.0];
        D2 [label="Document-Scoped\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nLives with the file\nNot a global preset\nSerialized into .draw" fontsize=10.0];
        D3 [label="Snapshot/Restore\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nOps changes can\nbe rolled back\nif user cancels" fontsize=10.0];
    }

    subgraph cluster_actions {
        label="OPS ACTIONS" labelloc=t labeljust=l
        fontcolor=orange fontsize=11.0 color=orange style=dashed penwidth=1

        A1 [label="Change\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nEdit slot color" fontsize=10.0];
        A2 [label="Delete\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nRemove slot" fontsize=10.0];
        A3 [label="Insert\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nAdd new slot" fontsize=10.0];
        A4 [label="Rearrange\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nDrag-to-reorder" fontsize=10.0];
        A5 [label="Wand\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nMatch canvas\npixel to slot" fontsize=10.0];
    }

    MAIN -> S_NORMAL [arrowhead=none color="#555555" style=dotted];
    { rank=min; MAIN }

    subgraph cluster_legend {
        label="LEGEND" labelloc=t labeljust=l
        fontcolor=white fontsize=11.0 color=white style=dashed penwidth=1
        L1 [label="" shape=point width=0.01]; L2 [label="" shape=point width=0.01];
        L3 [label="" shape=point width=0.01]; L4 [label="" shape=point width=0.01];
        L5 [label="" shape=point width=0.01]; L6 [label="" shape=point width=0.01];
        L1 -> L2 [label=" Action" arrowhead=normal color="#66cc66" fontsize=9.0];
        L3 -> L4 [label=" Exit" arrowhead=normal color="#cc6666" style=dashed fontsize=9.0];
        L5 -> L6 [label=" Transition" arrowhead=normal color="#cccc66" fontsize=9.0];
    }
}
