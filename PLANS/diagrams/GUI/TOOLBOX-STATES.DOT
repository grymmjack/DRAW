digraph TOOLBAR {
    label="TOOLBOX STATE MACHINE" labelloc=t labeljust=c
    ordering=out rankdir=TB
    fontcolor=white fontsize=24.0 fontname="Cascadia Code PL"
    splines=true compound=true
    bgcolor=transparent
    edge [
        color=gray fontcolor="#aaaaaa" fontsize=9.0
        fontname="Cascadia Code PL"
    ];
    node [
        color=white shape=rect style=""
        fontname="Cascadia Code PL" fontsize=11.0 fontcolor=cyan
    ];

    { node [shape=folder color=orange penwidth=2 fontcolor=orange fontsize=13.0];
        TOOL_SEL [label="TOOL SELECTION"];
        LAYOUT_F [label="LAYOUT"];
    }

    // ─────────────────────────────────────────────────────
    //  TOOL SELECTION STATES
    // ─────────────────────────────────────────────────────

    S_IDLE [label="1 · NO TOOL ACTIVE\n─────────────────\nCURRENT_TOOL% = 0\nToolbar rendered\nAll buttons normal"];
    S_ACTIVE [label="2 · TOOL ACTIVE\n─────────────────\nCURRENT_TOOL% > 0\nActive button highlighted\nPrev tool saved in\nSCRN.prevTool%"];
    S_HOVER [label="3 · BUTTON HOVER\n─────────────────\nMouse over toolbar button\nTooltip queued\nHighlight drawn"];
    S_CLICK [label="4 · BUTTON CLICK\n─────────────────\nTOOLBAR_click()\nReset previous tool state\nSet CURRENT_TOOL%\nCMD_execute_action()"];

    // ─────────────────────────────────────────────────────
    //  TRANSITIONS
    // ─────────────────────────────────────────────────────

    S_IDLE -> S_ACTIVE [
        label="  Hotkey / Menu action\n  KEYBOARD_tools() / CMD_execute_action()\n  Sets CURRENT_TOOL%"
        color="#66cc66"
    ];
    S_ACTIVE -> S_HOVER [
        label="  Mouse over different button"
        color="#88aacc"
    ];
    S_HOVER -> S_CLICK [
        label="  B1 click on button\n  TOOLBAR_click()"
        color="#66cc66"
    ];
    S_CLICK -> S_ACTIVE [
        label="  New tool activated\n  Previous tool reset\n  (LINE_reset, RECT_reset, etc.)"
        color="#cccc66"
    ];
    S_ACTIVE -> S_ACTIVE [
        label="  Hotkey switches tool\n  KEYBOARD_tools()\n  Reset prev, set new"
        color="#88aacc"
    ];
    S_HOVER -> S_ACTIVE [
        label="  Mouse exits button\n  Tooltip cancelled"
        color="#cc6666" style=dashed
    ];

    // ─────────────────────────────────────────────────────
    //  LAYOUT GRID
    // ─────────────────────────────────────────────────────

    subgraph cluster_layout {
        label="TOOLBAR LAYOUT — 4 cols × 7 rows (TB_COLS × TB_ROWS)" labelloc=t labeljust=l
        fontcolor=orange fontsize=11.0 fontname="Cascadia Code PL"
        color=orange style=dashed penwidth=1

        LY_GRID [label="Button Grid\n────────────\n28 tool buttons (4×7)\nTB_BTN_W × TB_BTN_H each\nTB_GAP% spacing\nIcons loaded from theme"
                 fontsize=10.0];
        LY_MAP [label="Button → Tool Mapping\n────────────\nTOOLBAR_BUTTONS(row, col)\nMaps grid position to\nTOOL_* constant\nAction ID for CMD_execute"
                fontsize=10.0];
        LY_INDICATOR [label="Active Indicator\n────────────\nHighlight border on\nactive tool button\nColor: THEME.TB_ACTIVE_*~&\nUpdated on tool switch"
                      fontsize=10.0];
    }

    // ─────────────────────────────────────────────────────
    //  TOOL CONSTANTS
    // ─────────────────────────────────────────────────────

    subgraph cluster_tools {
        label="TOOL CONSTANTS — GUI/GUI.BI" labelloc=t labeljust=l
        fontcolor=orange fontsize=11.0 fontname="Cascadia Code PL"
        color=orange style=dashed penwidth=1

        T_LIST [label="Drawing Tools\n────────────\nTOOL_DOT, TOOL_BRUSH,\nTOOL_SPRAY, TOOL_LINE,\nTOOL_RECT, TOOL_FRECT,\nTOOL_ELLIPSE, TOOL_FELLIPSE,\nTOOL_FILL, TOOL_POLY_LINE,\nTOOL_POLY_FILL, TOOL_RAY,\nTOOL_TEXT, TOOL_ERASER"
                fontsize=10.0];
        T_SELECT [label="Selection Tools\n────────────\nTOOL_SELECT_RECT,\nTOOL_SELECT_FREEHAND,\nTOOL_SELECT_POLYGON,\nTOOL_SELECT_ELLIPSE,\nTOOL_SELECT_WAND,\nTOOL_MOVE, TOOL_PAN,\nTOOL_ZOOM, TOOL_CROP"
                  fontsize=10.0];
        T_UTIL [label="Utility Tools\n────────────\nTOOL_PICKER,\nTOOL_CUSTOM_BRUSH,\nTOOL_SAVE, TOOL_LOAD,\nTOOL_BAS (QB64 code),\nTOOL_HELP (cheatsheet)"
                fontsize=10.0];
    }

    TOOL_SEL -> S_IDLE [arrowhead=none color="#555555" style=dotted];
    LAYOUT_F -> LY_GRID [arrowhead=none color="#555555" style=dotted lhead=cluster_layout];

    { rank=min; TOOL_SEL; LAYOUT_F }
    { rank=same; S_IDLE; S_ACTIVE }

    subgraph cluster_legend {
        label="LEGEND" labelloc=t labeljust=l
        fontcolor=white fontsize=11.0 fontname="Cascadia Code PL"
        color=white style=dashed penwidth=1
        L1 [label="" shape=point width=0.01]; L2 [label="" shape=point width=0.01];
        L3 [label="" shape=point width=0.01]; L4 [label="" shape=point width=0.01];
        L5 [label="" shape=point width=0.01]; L6 [label="" shape=point width=0.01];
        L1 -> L2 [label=" Activate" arrowhead=normal color="#66cc66" fontsize=9.0];
        L3 -> L4 [label=" Deactivate" arrowhead=normal color="#cc6666" style=dashed fontsize=9.0];
        L5 -> L6 [label=" Commit Switch" arrowhead=normal color="#cccc66" fontsize=9.0];
    }
}
