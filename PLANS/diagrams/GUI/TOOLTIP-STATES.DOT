digraph TOOLTIPS {
    label="TOOLTIP STATE MACHINE" labelloc=t labeljust=c
    ordering=out rankdir=TB
    fontcolor=white fontsize=24.0 fontname="Cascadia Code PL"
    splines=true compound=true
    bgcolor=transparent
    edge [
        color=gray fontcolor="#aaaaaa" fontsize=9.0
        fontname="Cascadia Code PL"
    ];
    node [
        color=white shape=rect style=""
        fontname="Cascadia Code PL" fontsize=11.0 fontcolor=cyan
    ];

    { node [shape=folder color=orange penwidth=2 fontcolor=orange fontsize=13.0];
        MAIN [label="TOOLTIP LIFECYCLE"];
    }

    S_HIDDEN [label="1 · HIDDEN\n─────────────────\nTOOLTIP.visible% = FALSE\nNo tooltip rendered\nWaiting for hover"];
    S_DELAY [label="2 · DELAY\n─────────────────\nMouse hovering over\ntarget element\nTimer counting down\nTOOLTIP.hoverTimer!"];
    S_VISIBLE [label="3 · VISIBLE\n─────────────────\nTOOLTIP.visible% = TRUE\nText rendered near cursor\nPositioned to avoid\nscreen edge overflow"];
    S_FADING [label="4 · FADING\n─────────────────\nMouse moved away\nFade timer counting\nOpacity decreasing"];

    S_HIDDEN -> S_DELAY [
        label="  Mouse enters target\n  (toolbar btn, organizer,\n  palette cell)\n  Start hover timer"
        color="#66cc66"
    ];
    S_DELAY -> S_VISIBLE [
        label="  Timer exceeded threshold\n  (~0.5-1.0 seconds)\n  Show tooltip"
        color="#66cc66"
    ];
    S_DELAY -> S_HIDDEN [
        label="  Mouse left target\n  Cancel timer"
        color="#cc6666" style=dashed
    ];
    S_VISIBLE -> S_FADING [
        label="  Mouse leaves target\n  Start fade timer"
        color="#cccc66"
    ];
    S_VISIBLE -> S_HIDDEN [
        label="  Button clicked\n  Different widget hovered\n  Immediate hide"
        color="#cc6666" style=dashed
    ];
    S_FADING -> S_HIDDEN [
        label="  Fade complete\n  opacity = 0"
        color="#cc6666" style=dashed
    ];
    S_FADING -> S_VISIBLE [
        label="  Mouse returns to\n  same target\n  Cancel fade, show"
        color="#66cc66"
    ];

    // ─────────────────────────────────────────────────────
    //  TOOLTIP SOURCES
    // ─────────────────────────────────────────────────────

    subgraph cluster_sources {
        label="TOOLTIP SOURCES" labelloc=t labeljust=l
        fontcolor=orange fontsize=11.0 fontname="Cascadia Code PL"
        color=orange style=dashed penwidth=1

        SRC_TB [label="Toolbar Buttons\n────────────\nTool name + hotkey\n\"Brush (B)\""
                fontsize=10.0];
        SRC_ORG [label="Organizer Widgets\n────────────\nWidget name + state\n\"Grid Snap: Corner\""
                 fontsize=10.0];
        SRC_PAL [label="Palette Colors\n────────────\nColor index + RGB\n\"#FF0000 (idx 4)\""
                 fontsize=10.0];
        SRC_EDIT [label="Edit Bar Buttons\n────────────\nAction name + hotkey\n\"Undo (Ctrl+Z)\""
                  fontsize=10.0];
        SRC_LAYER [label="Layer Panel Icons\n────────────\nButton function\n\"Toggle Visibility\""
                   fontsize=10.0];
    }

    MAIN -> S_HIDDEN [arrowhead=none color="#555555" style=dotted];
    { rank=min; MAIN }

    subgraph cluster_legend {
        label="LEGEND" labelloc=t labeljust=l
        fontcolor=white fontsize=11.0 fontname="Cascadia Code PL"
        color=white style=dashed penwidth=1
        L1 [label="" shape=point width=0.01]; L2 [label="" shape=point width=0.01];
        L3 [label="" shape=point width=0.01]; L4 [label="" shape=point width=0.01];
        L5 [label="" shape=point width=0.01]; L6 [label="" shape=point width=0.01];
        L1 -> L2 [label=" Show" arrowhead=normal color="#66cc66" fontsize=9.0];
        L3 -> L4 [label=" Hide" arrowhead=normal color="#cc6666" style=dashed fontsize=9.0];
        L5 -> L6 [label=" Transition" arrowhead=normal color="#cccc66" fontsize=9.0];
    }
}
