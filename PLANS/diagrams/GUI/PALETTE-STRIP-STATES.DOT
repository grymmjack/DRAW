digraph PALETTE_STRIP {
    label="COLOR STRIP / PALETTE STRIP STATE MACHINE" labelloc=t labeljust=c
    ordering=out rankdir=TB
    fontcolor=white fontsize=24.0 fontname="Cascadia Code PL"
    splines=true compound=true
    bgcolor=transparent
    edge [
        color=gray fontcolor="#aaaaaa" fontsize=9.0
        fontname="Cascadia Code PL"
    ];
    node [
        color=white shape=rect style=""
        fontname="Cascadia Code PL" fontsize=11.0 fontcolor=cyan
    ];

    { node [shape=folder color=orange penwidth=2 fontcolor=orange fontsize=13.0];
        MAIN [label="PALETTE STRIP"];
        MENU_F [label="PALETTE MENU"];
    }

    S_VISIBLE [label="1 В· VISIBLE\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nSCRN.showPaletteStrip% = TRUE\nHorizontal color row\nAbove status bar\nShows loaded palette"];
    S_HIDDEN [label="2 В· HIDDEN\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nSCRN.showPaletteStrip% = FALSE\nManuallyHidden% = TRUE"];
    S_HOVER [label="3 В· HOVER COLOR\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nhoverIdx = colorIndex\nColor highlighted\nRGB tooltip shown"];
    S_SELECT [label="4 В· COLOR SELECTED\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nB1 = Set FG color\nB2 = Set BG color\nPAINT_COLOR~& updated\nPAL_FG_IDX% set"];
    S_SCROLL [label="5 В· SCROLLING\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nPalette has > visible\nnumber of colors\nMousewheel scrolls\nNav arrows visible"];

    S_VISIBLE -> S_HIDDEN [label="  Ctrl+Shift+Up / Menu" color="#cc6666" style=dashed];
    S_HIDDEN -> S_VISIBLE [label="  Ctrl+Shift+Up / Menu" color="#66cc66"];
    S_VISIBLE -> S_HOVER [label="  Mouse over color cell" color="#88aacc"];
    S_HOVER -> S_SELECT [label="  B1 click (FG)\n  B2 click (BG)" color="#66cc66"];
    S_SELECT -> S_VISIBLE [label="  Color applied" color="#cccc66"];
    S_VISIBLE -> S_SCROLL [label="  Mousewheel / [ ] keys" color="#88aacc"];
    S_SCROLL -> S_VISIBLE [label="  Scroll stop" color="#88aacc"];
    S_HOVER -> S_VISIBLE [label="  Mouse leaves" color="#cc6666" style=dashed];

    subgraph cluster_palette_menu {
        label="PALETTE MENU вЂ” Palette Selection" labelloc=t labeljust=l
        fontcolor=orange fontsize=11.0 fontname="Cascadia Code PL"
        color=orange style=dashed penwidth=1

        PM_CLOSED [label="Menu Closed\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nNormal strip display\nPalette name in corner"
                   fontsize=10.0];
        PM_OPEN [label="Menu Open\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\n56 GPL palette files\nScrollable list\nSearch filter\nHover highlights"
                 fontsize=10.0];
        PM_SELECT [label="Palette Selected\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nPALETTE_LOADER_load()\nPAL_color~&() updated\nStrip redrawn\nAll colors refreshed"
                   fontsize=10.0];

        PM_CLOSED -> PM_OPEN [label=" Click palette name\n or hotkey" color="#66cc66" fontsize=8.0];
        PM_OPEN -> PM_SELECT [label=" Click palette item" color="#cccc66" fontsize=8.0];
        PM_SELECT -> PM_CLOSED [label=" Auto-close" color="#cc6666" fontsize=8.0 style=dashed];
        PM_OPEN -> PM_CLOSED [label=" Escape / click outside" color="#cc6666" fontsize=8.0 style=dashed];
    }

    MAIN -> S_VISIBLE [arrowhead=none color="#555555" style=dotted];
    MENU_F -> PM_CLOSED [arrowhead=none color="#555555" style=dotted lhead=cluster_palette_menu];
    { rank=min; MAIN; MENU_F }

    subgraph cluster_legend {
        label="LEGEND" labelloc=t labeljust=l
        fontcolor=white fontsize=11.0 fontname="Cascadia Code PL"
        color=white style=dashed penwidth=1
        L1 [label="" shape=point width=0.01]; L2 [label="" shape=point width=0.01];
        L3 [label="" shape=point width=0.01]; L4 [label="" shape=point width=0.01];
        L5 [label="" shape=point width=0.01]; L6 [label="" shape=point width=0.01];
        L1 -> L2 [label=" Show / Open" arrowhead=normal color="#66cc66" fontsize=9.0];
        L3 -> L4 [label=" Hide / Close" arrowhead=normal color="#cc6666" style=dashed fontsize=9.0];
        L5 -> L6 [label=" Select / Apply" arrowhead=normal color="#cccc66" fontsize=9.0];
    }
}
