digraph ORGANIZER {
    label="ORGANIZER STATE MACHINE" labelloc=t labeljust=c
    ordering=out rankdir=TB
    fontcolor=white fontsize=24.0 fontname="Cascadia Code PL"
    splines=true compound=true
    bgcolor=transparent
    edge [
        color=gray fontcolor="#aaaaaa" fontsize=9.0
        fontname="Cascadia Code PL"
    ];
    node [
        color=white shape=rect style=""
        fontname="Cascadia Code PL" fontsize=11.0 fontcolor=cyan
    ];

    { node [shape=folder color=orange penwidth=2 fontcolor=orange fontsize=13.0];
        MAIN [label="MAIN STATES"];
        WIDGETS [label="WIDGET TOGGLES"];
    }

    // в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
    //  MAIN STATES
    // в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

    S_VISIBLE [label="1 В· VISIBLE\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nSCRN.showOrganizer% = TRUE\n4Г—3 grid of icon buttons\n11 functional widgets\nRenders below toolbar"];
    S_HIDDEN [label="2 В· HIDDEN\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nSCRN.showOrganizer% = FALSE\nSCRN.organizerManuallyHidden%\nToggle via F4 / menu"];
    S_HOVER [label="3 В· BUTTON HOVER\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nMouse over widget icon\nTooltip queued\nHighlight rendered"];
    S_CLICK [label="4 В· BUTTON CLICK\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nWidget toggled\nState icon updates\nAction dispatched"];

    S_VISIBLE -> S_HIDDEN [
        label="  F4 / Menu toggle\n  ManuallyHidden% = TRUE"
        color="#cc6666" style=dashed
    ];
    S_HIDDEN -> S_VISIBLE [
        label="  F4 / Menu toggle\n  ManuallyHidden% = FALSE"
        color="#66cc66"
    ];
    S_VISIBLE -> S_HOVER [label="  Mouse over icon" color="#88aacc"];
    S_HOVER -> S_CLICK [label="  B1 click" color="#66cc66"];
    S_CLICK -> S_VISIBLE [label="  Widget toggled" color="#cccc66"];

    // в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
    //  WIDGET TOGGLES (4Г—3 grid, 11 widgets)
    // в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

    subgraph cluster_widgets {
        label="ORGANIZER WIDGETS вЂ” 4Г—3 GRID" labelloc=t labeljust=l
        fontcolor=orange fontsize=11.0 fontname="Cascadia Code PL"
        color=orange style=dashed penwidth=1

        W_GRID [label="Grid Toggle\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nON: Grid visible\nOFF: Grid hidden\nIcon: grid-on/off.png"
                fontsize=10.0];
        W_SNAP [label="Grid Snap\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\n3 modes cycle:\nOFF в†’ Corner в†’ Center\nSnap affects MOUSE.X/Y"
                fontsize=10.0];
        W_PIXEL [label="Pixel Grid\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nON: 1px grid at zoom\nOFF: No pixel grid\nOnly visible at zoom в‰Ґ 4x"
                 fontsize=10.0];
        W_CROSSHAIR [label="Crosshair\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nON: Axis lines drawn\nOFF: No crosshair\nShift = temporary on"
                     fontsize=10.0];
        W_SYMMETRY [label="Symmetry Mode\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\n4 modes cycle:\nOFF в†’ Vertical в†’\nCross в†’ Asterisk\nScroll Lock = toggle"
                    fontsize=10.0];
        W_PATTERN [label="Pattern Mode\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nON: Draw with pattern\nOFF: Solid color\nUses drawer slot pattern"
                   fontsize=10.0];
        W_GRADIENT [label="Gradient Mode\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nON: Draw with gradient\nOFF: Solid color\nUses drawer slot gradient"
                    fontsize=10.0];
        W_DITHER [label="Dither Toggle\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nON: Dithered drawing\nOFF: Clean drawing\nAlgorithm per drawer slot"
                  fontsize=10.0];
        W_PREVIEW [label="Preview Window\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nON: Preview visible\nOFF: Preview hidden\nF7 = toggle"
                   fontsize=10.0];
        W_TILE [label="Tile Mode\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nON: Canvas tiles\nOFF: Normal view\nFor seamless patterns"
                fontsize=10.0];
        W_REFIMG [label="Reference Image\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nON: Ref visible\nOFF: Ref hidden\nOverlay for tracing"
                  fontsize=10.0];

        W_SNAP -> W_SNAP [
            label=" Click cycles:\n OFF в†’ Corner в†’\n Center в†’ OFF"
            color="#88aacc" fontsize=8.0
        ];
        W_SYMMETRY -> W_SYMMETRY [
            label=" Click cycles:\n OFF в†’ V-Mirror в†’\n Cross в†’ Asterisk в†’ OFF"
            color="#88aacc" fontsize=8.0
        ];
    }

    MAIN -> S_VISIBLE [arrowhead=none color="#555555" style=dotted];
    WIDGETS -> W_GRID [arrowhead=none color="#555555" style=dotted lhead=cluster_widgets];
    { rank=min; MAIN; WIDGETS }

    subgraph cluster_legend {
        label="LEGEND" labelloc=t labeljust=l
        fontcolor=white fontsize=11.0 fontname="Cascadia Code PL"
        color=white style=dashed penwidth=1
        L1 [label="" shape=point width=0.01]; L2 [label="" shape=point width=0.01];
        L3 [label="" shape=point width=0.01]; L4 [label="" shape=point width=0.01];
        L5 [label="" shape=point width=0.01]; L6 [label="" shape=point width=0.01];
        L1 -> L2 [label=" Show / Enable" arrowhead=normal color="#66cc66" fontsize=9.0];
        L3 -> L4 [label=" Hide / Disable" arrowhead=normal color="#cc6666" style=dashed fontsize=9.0];
        L5 -> L6 [label=" Cycle State" arrowhead=normal color="#88aacc" fontsize=9.0];
    }
}
