digraph PREVIEW {
    label="PREVIEW WINDOW STATE MACHINE" labelloc=t labeljust=c
    ordering=out rankdir=TB
    fontcolor=white fontsize=24.0 fontname="Cascadia Code PL"
    splines=true compound=true
    bgcolor=transparent
    edge [
        color=gray fontcolor="#aaaaaa" fontsize=9.0
        fontname="Cascadia Code PL"
    ];
    node [
        color=white shape=rect style=""
        fontname="Cascadia Code PL" fontsize=11.0 fontcolor=cyan
    ];

    { node [shape=folder color=orange penwidth=2 fontcolor=orange fontsize=13.0];
        MAIN [label="MAIN STATES"];
        MODES [label="PREVIEW MODES"];
        INTERACT [label="INTERACTIONS"];
    }

    S_HIDDEN [label="1 · HIDDEN\n─────────────────\nSCRN.showPreview% = FALSE\nManuallyHidden% = TRUE\nNot rendered"];
    S_VISIBLE [label="2 · VISIBLE\n─────────────────\nSCRN.showPreview% = TRUE\nFloating window rendered\nMode determines content"];
    S_DRAGGING [label="3 · DRAGGING\n─────────────────\nPREVIEW.dragging% = TRUE\nWindow being repositioned\nFollows mouse offset"];
    S_RESIZING [label="4 · RESIZING\n─────────────────\nPREVIEW.resizing% = TRUE\nCorner/edge resize handle\nMin/max size clamped"];
    S_PANNING [label="5 · PANNING\n─────────────────\nPREVIEW.panning% = TRUE\nImage pan within window\nMiddle-click or Space+drag"];
    S_COLOR_PICK [label="6 · COLOR PICKING\n─────────────────\nClick on preview image\nSamples pixel color\nSets PAINT_COLOR~&"];

    S_HIDDEN -> S_VISIBLE [label="  F7 / Menu toggle" color="#66cc66"];
    S_VISIBLE -> S_HIDDEN [label="  F7 / Menu toggle" color="#cc6666" style=dashed];
    S_VISIBLE -> S_DRAGGING [label="  B1 on title bar\n  PREVIEW.dragging% = TRUE" color="#66cc66"];
    S_DRAGGING -> S_VISIBLE [label="  B1 released\n  Position saved" color="#cccc66"];
    S_VISIBLE -> S_RESIZING [label="  B1 on resize handle" color="#66cc66"];
    S_RESIZING -> S_VISIBLE [label="  B1 released\n  Size saved" color="#cccc66"];
    S_VISIBLE -> S_PANNING [label="  Middle-click / Space+drag" color="#66cc66"];
    S_PANNING -> S_VISIBLE [label="  Button released" color="#cccc66"];
    S_VISIBLE -> S_COLOR_PICK [label="  B1 on image (pick mode)" color="#66cc66"];
    S_COLOR_PICK -> S_VISIBLE [label="  Color sampled" color="#cccc66"];

    subgraph cluster_modes {
        label="PREVIEW MODES" labelloc=t labeljust=l
        fontcolor=orange fontsize=11.0 fontname="Cascadia Code PL"
        color=orange style=dashed penwidth=1

        PM_FOLLOW [label="Follow Magnifier\n────────────\nPREVIEW.mode% = FOLLOW\nShows zoomed area\naround cursor position\nReal-time update"
                   fontsize=10.0];
        PM_FLOAT [label="Floating Image\n────────────\nPREVIEW.mode% = FLOATING\nShows full canvas\nat independent zoom\nPan/zoom within window"
                  fontsize=10.0];
        PM_QUICK [label="Bin Quick Look\n────────────\nHover over drawer slot\nShows slot content\nPreview of brush/pattern\nAuto-hides on leave"
                  fontsize=10.0];

        PM_FOLLOW -> PM_FLOAT [label=" Menu / hotkey\n mode switch" color="#88aacc" fontsize=8.0];
        PM_FLOAT -> PM_FOLLOW [label=" Menu / hotkey\n mode switch" color="#88aacc" fontsize=8.0];
        PM_FOLLOW -> PM_QUICK [label=" Drawer slot hover" color="#88aacc" fontsize=8.0];
        PM_FLOAT -> PM_QUICK [label=" Drawer slot hover" color="#88aacc" fontsize=8.0];
        PM_QUICK -> PM_FOLLOW [label=" Mouse leaves slot\n (return to prev mode)" color="#cc6666" fontsize=8.0 style=dashed];
        PM_QUICK -> PM_FLOAT [label=" Mouse leaves slot\n (return to prev mode)" color="#cc6666" fontsize=8.0 style=dashed];
    }

    subgraph cluster_features {
        label="PREVIEW FEATURES" labelloc=t labeljust=l
        fontcolor=orange fontsize=11.0 fontname="Cascadia Code PL"
        color=orange style=dashed penwidth=1

        F_ZOOM [label="Preview Zoom\n────────────\nMousewheel in preview\nIndependent zoom level\nMin 1x, Max 8x"
                fontsize=10.0];
        F_RECENT [label="Recent Images\n────────────\nUp to 10 recent previews\nAccessible via submenu\nQuick comparison"
                  fontsize=10.0];
        F_CLAMP [label="Work-Area Clamping\n────────────\nWindow stays within\nscreen bounds\nSnap to edges"
                 fontsize=10.0];
    }

    MAIN -> S_HIDDEN [arrowhead=none color="#555555" style=dotted];
    MODES -> PM_FOLLOW [arrowhead=none color="#555555" style=dotted lhead=cluster_modes];
    INTERACT -> S_DRAGGING [arrowhead=none color="#555555" style=dotted];
    { rank=min; MAIN; MODES; INTERACT }

    subgraph cluster_legend {
        label="LEGEND" labelloc=t labeljust=l
        fontcolor=white fontsize=11.0 fontname="Cascadia Code PL"
        color=white style=dashed penwidth=1
        L1 [label="" shape=point width=0.01]; L2 [label="" shape=point width=0.01];
        L3 [label="" shape=point width=0.01]; L4 [label="" shape=point width=0.01];
        L5 [label="" shape=point width=0.01]; L6 [label="" shape=point width=0.01];
        L1 -> L2 [label=" Activate / Enter" arrowhead=normal color="#66cc66" fontsize=9.0];
        L3 -> L4 [label=" Close / Release" arrowhead=normal color="#cc6666" style=dashed fontsize=9.0];
        L5 -> L6 [label=" Commit / Apply" arrowhead=normal color="#cccc66" fontsize=9.0];
    }
}
