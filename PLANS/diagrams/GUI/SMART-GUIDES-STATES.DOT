digraph SMART_GUIDES {
    label="SMART GUIDES STATE MACHINE" labelloc=t labeljust=c
    ordering=out rankdir=TB
    fontcolor=white fontsize=24.0 fontname="Cascadia Code PL"
    splines=true compound=true
    bgcolor=transparent
    edge [color=gray fontcolor="#aaaaaa" fontsize=9.0 fontname="Cascadia Code PL"];
    node [color=white shape=rect style="" fontname="Cascadia Code PL" fontsize=11.0 fontcolor=cyan];

    { node [shape=folder color=orange penwidth=2 fontcolor=orange fontsize=13.0];
        MAIN [label="SMART GUIDES вЂ” MOVE TOOL"];
    }

    S_DISABLED [label="1 В· DISABLED\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nSMART_GUIDES.enabled% = FALSE\nNo alignment hints drawn\nAction 910 to enable"];
    S_IDLE [label="2 В· IDLE\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nEnabled but inactive\nMove tool not dragging\nWaiting for drag start"];
    S_DETECTING [label="3 В· DETECTING\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nMove drag in progress\nScan canvas for\nedge / center alignment\nwith other layer bounds"];
    S_SHOW_GUIDE [label="4 В· SHOWING GUIDE\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nMatching alignment found\nDraw colored line\nthrough match axis\nLeft/Right/Top/Bot/Center"];
    S_SNAP [label="5 В· SNAPPED\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nMOUSE within snap radius\nMove offset adjusted\nto exact alignment\nFRAME_IDLE% = FALSE"];

    S_DISABLED -> S_IDLE [label="  Action 910 fired\n  (Toggle Smart Guides)" color="#66cc66"];
    S_IDLE -> S_DISABLED [label="  Action 910 fired again" color="#cc6666" style=dashed];
    S_IDLE -> S_DETECTING [label="  Move tool drag begins\n  CURRENT_TOOL% = TOOL_MOVE" color="#66cc66"];
    S_DETECTING -> S_SHOW_GUIDE [label="  Match within tolerance\n  ~3 px snap distance" color="#cccc66"];
    S_SHOW_GUIDE -> S_SNAP [label="  Snap threshold reached\n  Lock to alignment axis" color="#cccc66"];
    S_SNAP -> S_SHOW_GUIDE [label="  Mouse moved past\n  snap break distance" color="#cccc66"];
    S_SHOW_GUIDE -> S_DETECTING [label="  Lost alignment\n  Hide guide line" color="#cc6666" style=dashed];
    S_DETECTING -> S_IDLE [label="  Move drag released\n  Layer position committed" color="#cc6666" style=dashed];

    subgraph cluster_axes {
        label="ALIGNMENT AXES" labelloc=t labeljust=l
        fontcolor=orange fontsize=11.0 color=orange style=dashed penwidth=1

        A_LEFT [label="Left Edge\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nMatching X bounds\nVertical line drawn" fontsize=10.0];
        A_CTRX [label="Center X\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nMid-X alignment\nCenter line" fontsize=10.0];
        A_RIGHT [label="Right Edge\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nRight-edge match" fontsize=10.0];
        A_TOP [label="Top Edge\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nMatching Y bounds\nHorizontal line drawn" fontsize=10.0];
        A_CTRY [label="Center Y\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nMid-Y alignment" fontsize=10.0];
        A_BOT [label="Bottom Edge\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nBottom-edge match" fontsize=10.0];
    }

    subgraph cluster_render {
        label="RENDER ORDER" labelloc=t labeljust=l
        fontcolor=orange fontsize=11.0 color=orange style=dashed penwidth=1

        R1 [label="Drawn AFTER selection overlay\nin SCREEN_render pipeline\nBefore pointer (step 13)\nAction 911 = clear all" fontsize=10.0];
    }

    MAIN -> S_DISABLED [arrowhead=none color="#555555" style=dotted];
    { rank=min; MAIN }

    subgraph cluster_legend {
        label="LEGEND" labelloc=t labeljust=l
        fontcolor=white fontsize=11.0 color=white style=dashed penwidth=1
        L1 [label="" shape=point width=0.01]; L2 [label="" shape=point width=0.01];
        L3 [label="" shape=point width=0.01]; L4 [label="" shape=point width=0.01];
        L5 [label="" shape=point width=0.01]; L6 [label="" shape=point width=0.01];
        L1 -> L2 [label=" Activate" arrowhead=normal color="#66cc66" fontsize=9.0];
        L3 -> L4 [label=" Deactivate" arrowhead=normal color="#cc6666" style=dashed fontsize=9.0];
        L5 -> L6 [label=" Transition" arrowhead=normal color="#cccc66" fontsize=9.0];
    }
}
