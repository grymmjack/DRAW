digraph ABOUT_DIALOG {
    label="ABOUT DIALOG STATE MACHINE" labelloc=t labeljust=c
    ordering=out rankdir=TB
    fontcolor=white fontsize=24.0 fontname="Cascadia Code PL"
    splines=true compound=true
    bgcolor=transparent
    edge [color=gray fontcolor="#aaaaaa" fontsize=9.0 fontname="Cascadia Code PL"];
    node [color=white shape=rect style="" fontname="Cascadia Code PL" fontsize=11.0 fontcolor=cyan];

    { node [shape=folder color=orange penwidth=2 fontcolor=orange fontsize=13.0];
        MAIN [label="ABOUT DIALOG"];
    }

    S_CLOSED [label="1 · CLOSED\n─────────────────\nABOUT.visible% = FALSE\nNo overlay drawn"];
    S_INTRO [label="2 · INTRO ANIMATION\n─────────────────\nLogo scales/fades in\nFRAME_IDLE% = FALSE\nframeCount counts up"];
    S_IDLE [label="3 · IDLE DISPLAY\n─────────────────\nAnimated logo loop\nVersion APP_VERSION$\nCredits scroll/blink\nClickable GitHub link"];
    S_HOVER_LINK [label="4 · HOVER LINK\n─────────────────\nMouse over GitHub URL\nCursor → hand\nUnderline highlight"];
    S_OPEN_URL [label="5 · OPENING URL\n─────────────────\nLink clicked\n_OPENBROWSER call\n(or shell command)\nReturn to idle"];
    S_CLOSING [label="6 · CLOSING\n─────────────────\nClick outside / Esc / OK\nFade out animation"];

    S_CLOSED -> S_INTRO [label="  Help → About\n  (action ID)" color="#66cc66"];
    S_INTRO -> S_IDLE [label="  Animation done\n  ~1 second" color="#cccc66"];
    S_IDLE -> S_HOVER_LINK [label="  Mouse enters URL hitbox" color="#66cc66"];
    S_HOVER_LINK -> S_IDLE [label="  Mouse leaves" color="#cc6666" style=dashed];
    S_HOVER_LINK -> S_OPEN_URL [label="  B1 click on link" color="#66cc66"];
    S_OPEN_URL -> S_IDLE [label="  Browser launched\n  Stay on About" color="#cccc66"];
    S_IDLE -> S_CLOSING [label="  Esc / OK / outside click" color="#cc6666" style=dashed];
    S_CLOSING -> S_CLOSED [label="  Fade complete" color="#cc6666" style=dashed];

    subgraph cluster_content {
        label="DISPLAYED CONTENT" labelloc=t labeljust=l
        fontcolor=orange fontsize=11.0 color=orange style=dashed penwidth=1

        C1 [label="Animated Logo\n────────────\nDRAW logo with FX\nLooping animation\nDriven by frameCount" fontsize=10.0];
        C2 [label="Version\n────────────\nAPP_VERSION$ from\n_COMMON.BI" fontsize=10.0];
        C3 [label="Credits\n────────────\nAuthor: grymmjack\n(Rick Christy)\nContributors list" fontsize=10.0];
        C4 [label="GitHub Link\n────────────\nClickable URL\nLaunches default browser" fontsize=10.0];
    }

    MAIN -> S_CLOSED [arrowhead=none color="#555555" style=dotted];
    { rank=min; MAIN }

    subgraph cluster_legend {
        label="LEGEND" labelloc=t labeljust=l
        fontcolor=white fontsize=11.0 color=white style=dashed penwidth=1
        L1 [label="" shape=point width=0.01]; L2 [label="" shape=point width=0.01];
        L3 [label="" shape=point width=0.01]; L4 [label="" shape=point width=0.01];
        L5 [label="" shape=point width=0.01]; L6 [label="" shape=point width=0.01];
        L1 -> L2 [label=" Activate" arrowhead=normal color="#66cc66" fontsize=9.0];
        L3 -> L4 [label=" Close / Reset" arrowhead=normal color="#cc6666" style=dashed fontsize=9.0];
        L5 -> L6 [label=" Transition" arrowhead=normal color="#cccc66" fontsize=9.0];
    }
}
