digraph IMAGE_RESIZE_CROP {
    label="IMAGE RESIZE / CROP STATE MACHINE" labelloc=t labeljust=c
    ordering=out rankdir=TB
    fontcolor=white fontsize=24.0 fontname="Cascadia Code PL"
    splines=true compound=true
    bgcolor=transparent
    edge [
        color=gray fontcolor="#aaaaaa" fontsize=9.0
        fontname="Cascadia Code PL"
    ];
    node [
        color=white shape=rect style=""
        fontname="Cascadia Code PL" fontsize=11.0 fontcolor=cyan
    ];

    { node [shape=folder color=orange penwidth=2 fontcolor=orange fontsize=13.0];
        MAIN [label="IMAGE\nRESIZE / CROP"];
    }

    S_IDLE [label="1 В· IDLE\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nCanvas at current size\nAll layers sized equally\nNo resize/crop pending"];

    MAIN -> S_IDLE [arrowhead=none color="#555555" style=dotted];
    { rank=min; MAIN }

    subgraph cluster_resize {
        label="RESIZE (CANVAS RESIZE)" labelloc=t labeljust=l
        fontcolor=white fontsize=11.0 fontname="Cascadia Code PL"
        color=orange style=dashed penwidth=1

        R_DIALOG [label="Resize Dialog\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nImage в†’ Resize\nInput new W Г— H\nOption: maintain aspect\nOption: resample method"];
        R_VALIDATE [label="Validate\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nCheck W,H > 0\nCheck within limits\nPreview new size"];
        R_EXECUTE [label="Execute Resize\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nCANVAS_resize(newW,newH):\n1. History snapshot all layers\n2. _NEWIMAGE for each layer\n3. _PUTIMAGE scale oldв†’new\n4. _FREEIMAGE old handles\n5. Update SCRN dimensions"];
        R_CLEANUP [label="Post-Resize\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nReset all caches\nSCENE_DIRTY = TRUE\nBLEND_invalidate_cache\nGrid needs redraw\nZoom needs update"];

        R_DIALOG -> R_VALIDATE [label="  OK clicked" color="#cccc66"];
        R_VALIDATE -> R_EXECUTE [label="  Valid dimensions" color="#66cc66"];
        R_VALIDATE -> R_DIALOG [label="  Invalid в†’ retry" color="#cc6666" style=dashed];
        R_EXECUTE -> R_CLEANUP [label="  Resized" color="#cccc66"];
    }

    subgraph cluster_crop {
        label="CROP (CANVAS CROP)" labelloc=t labeljust=l
        fontcolor=white fontsize=11.0 fontname="Cascadia Code PL"
        color=orange style=dashed penwidth=1

        C_ACTIVATE [label="Activate Crop\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nSelect CROP tool\nCROP_STATE = ACTIVE\nSave PREV_TOOL\nMarquee controls appear"];
        C_MARQUEE [label="Draw Marquee\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nDrag crop rectangle\non canvas\nDark overlay outside\nSize label shown"];
        C_ADJUST [label="Adjust\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nResize via handles\nMove via body drag\nArrow keys nudge\nAll marquee controls"];
        C_APPLY [label="Apply Crop\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nEnter в†’ CROP_apply():\n1. History snapshot\n2. Trim all layers\n   to marquee bounds\n3. CANVAS_resize\n4. Restore PREV_TOOL"];
        C_CANCEL [label="Cancel Crop\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nEsc в†’ CROP_cancel():\nRestore PREV_TOOL\nClear marquee\nNo changes"];

        C_ACTIVATE -> C_MARQUEE [label="  Draw region" color="#66cc66"];
        C_MARQUEE -> C_ADJUST [label="  Release (box set)" color="#cccc66"];
        C_ADJUST -> C_ADJUST [label="  Resize/move\n  handles" color="#88aacc"];
        C_ADJUST -> C_APPLY [label="  Enter" color="#cccc66"];
        C_ADJUST -> C_CANCEL [label="  Escape" color="#cc6666" style=dashed];
    }

    S_IDLE -> R_DIALOG [label="  Image в†’ Resize" color="#6699ff"];
    S_IDLE -> C_ACTIVATE [label="  Select Crop tool\n  or Image в†’ Crop" color="#66cc66"];

    subgraph cluster_rendering {
        label="CROP RENDERING" labelloc=t labeljust=l
        fontcolor=white fontsize=11.0 fontname="Cascadia Code PL"
        color=orange style=dashed penwidth=1

        CR1 [label="CROP_render(dest&)\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nDark overlay outside\ncrop region (50% alpha)\nSize label above marquee\nHandle indicators"];
    }

    subgraph cluster_legend {
        label="LEGEND" labelloc=t labeljust=l
        fontcolor=white fontsize=11.0 fontname="Cascadia Code PL"
        color=white style=dashed penwidth=1
        L1 [label="" shape=point width=0.01]; L2 [label="" shape=point width=0.01];
        L3 [label="" shape=point width=0.01]; L4 [label="" shape=point width=0.01];
        L5 [label="" shape=point width=0.01]; L6 [label="" shape=point width=0.01];
        L7 [label="" shape=point width=0.01]; L8 [label="" shape=point width=0.01];
        L1 -> L2 [label=" Activate / Create" arrowhead=normal color="#66cc66" fontsize=9.0];
        L3 -> L4 [label=" Cancel / Abort" arrowhead=normal color="#cc6666" style=dashed fontsize=9.0];
        L5 -> L6 [label=" Step / Commit" arrowhead=normal color="#cccc66" fontsize=9.0];
        L7 -> L8 [label=" Menu / Dialog" arrowhead=normal color="#6699ff" fontsize=9.0];
    }
}
