digraph IMAGE_ADJUSTMENTS {
    label="IMAGE ADJUSTMENT DIALOGS STATE MACHINE\n(Brightness, Hue, Levels, Blur, Sharpen, etc.)" labelloc=t labeljust=c
    ordering=out rankdir=TB
    fontcolor=white fontsize=24.0 fontname="Cascadia Code PL"
    splines=true compound=true
    bgcolor=transparent
    edge [
        color=gray fontcolor="#aaaaaa" fontsize=9.0
        fontname="Cascadia Code PL"
    ];
    node [
        color=white shape=rect style=""
        fontname="Cascadia Code PL" fontsize=11.0 fontcolor=cyan
    ];

    { node [shape=folder color=orange penwidth=2 fontcolor=orange fontsize=13.0];
        MAIN [label="IMAGE\nADJUSTMENTS"];
    }

    S_IDLE [label="1 В· IDLE\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nNo adjustment dialog open\nNormal painting mode\nLayer pixels unmodified"];
    S_DIALOG [label="2 В· DIALOG OPEN\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nAdjustment dialog shown\nSlider controls active\nLive preview on canvas\nOriginal snapshot saved"];
    S_ADJUSTING [label="3 В· ADJUSTING\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nUser dragging sliders\nPreview updates per-frame\nPixel computation running\n_MEM-based processing"];
    S_APPLIED [label="4 В· APPLIED\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nOK pressed\nAdjustment committed\nHISTORY_record saved\nLayer pixels modified"];
    S_CANCELLED [label="5 В· CANCELLED\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nCancel pressed\nRestore original snapshot\nLayer pixels unchanged"];

    S_IDLE -> S_DIALOG [label="  Image в†’ Adjustments в†’\n  (select adjustment)\n  Open dialog" color="#66cc66"];
    S_DIALOG -> S_ADJUSTING [label="  Drag slider\n  or change value" color="#cccc66"];
    S_ADJUSTING -> S_ADJUSTING [label="  Slider changes\n  Live preview update\n  Per-pixel recalculate" color="#88aacc"];
    S_ADJUSTING -> S_DIALOG [label="  Slider released\n  Preview stable" color="#cccc66"];
    S_DIALOG -> S_APPLIED [label="  Press OK / Enter\n  Commit changes\n  HISTORY_record" color="#cccc66"];
    S_DIALOG -> S_CANCELLED [label="  Press Cancel / Esc\n  Restore original" color="#cc6666" style=dashed];

    MAIN -> S_IDLE [arrowhead=none color="#555555" style=dotted];
    { rank=min; MAIN }

    subgraph cluster_types {
        label="ADJUSTMENT TYPES (IMAGE-ADJ.BI/BM)" labelloc=t labeljust=l
        fontcolor=white fontsize=11.0 fontname="Cascadia Code PL"
        color=orange style=dashed penwidth=1

        T_BC [label="Brightness/Contrast\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nBrightness: -100..+100\nContrast: -100..+100\nLinear pixel transform"];
        T_HS [label="Hue/Saturation\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nHue shift: -180..+180В°\nSaturation: -100..+100\nLightness: -100..+100\nHSL color space"];
        T_LEV [label="Levels\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nInput black/white points\nOutput black/white points\nGamma/midtone slider\nHistogram display"];
        T_BLUR [label="Blur\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nBox blur radius\nGaussian-ish\nPer-channel averaging"];
        T_SHARP [label="Sharpen\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nUnsharp mask\nAmount + radius\nEdge enhancement"];
        T_INV [label="Invert\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nR=255-R, G=255-G, B=255-B\nInstant (no slider)\nDirect commit"];
        T_DESAT [label="Desaturate\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nConvert to grayscale\nLuminosity method\nInstant commit"];
        T_POST [label="Posterize\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nReduce color levels\nLevels: 2-256\nDither option available"];
        T_PIX [label="Pixelate\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nPixel block size\nMosaic effect\nAverage block colors"];
        T_RMBG [label="Remove Background\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nThreshold-based\nRemove near-transparent\nor near-white pixels\nAlpha channel cleanup"];
    }

    subgraph cluster_preview {
        label="LIVE PREVIEW SYSTEM" labelloc=t labeljust=l
        fontcolor=white fontsize=11.0 fontname="Cascadia Code PL"
        color=orange style=dashed penwidth=1

        PV1 [label="Snapshot\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nOriginal layer pixels\nsaved to temp image\nbefore any adjustment\nfor cancel restore"];
        PV2 [label="Per-Pixel Processing\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\n_MEM-based fast access\nProcess each pixel:\n  read в†’ transform в†’ write\nComposite result shown"];
        PV3 [label="Debounce\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nSlider changes debounced\nPreview updates throttled\nAvoid excessive recompute"];
    }

    subgraph cluster_history {
        label="HISTORY INTEGRATION" labelloc=t labeljust=l
        fontcolor=white fontsize=11.0 fontname="Cascadia Code PL"
        color=orange style=dashed penwidth=1

        H1 [label="On Apply\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nHISTORY_record_brush()\nor shape variant\nkind = HISTORY_KIND_BRUSH\nStores before/after images\nFull undo support"];
    }

    subgraph cluster_legend {
        label="LEGEND" labelloc=t labeljust=l
        fontcolor=white fontsize=11.0 fontname="Cascadia Code PL"
        color=white style=dashed penwidth=1
        L1 [label="" shape=point width=0.01]; L2 [label="" shape=point width=0.01];
        L3 [label="" shape=point width=0.01]; L4 [label="" shape=point width=0.01];
        L5 [label="" shape=point width=0.01]; L6 [label="" shape=point width=0.01];
        L7 [label="" shape=point width=0.01]; L8 [label="" shape=point width=0.01];
        L1 -> L2 [label=" Open / Activate" arrowhead=normal color="#66cc66" fontsize=9.0];
        L3 -> L4 [label=" Cancel / Restore" arrowhead=normal color="#cc6666" style=dashed fontsize=9.0];
        L5 -> L6 [label=" Commit / Record" arrowhead=normal color="#cccc66" fontsize=9.0];
        L7 -> L8 [label=" Self-transition" arrowhead=normal color="#88aacc" fontsize=9.0];
    }
}
