    CFG_DISPLAY     [label="Display Scale\n1x-8x"];
    CFG_TOOLBAR_SC  [label="Toolbar Scale\n1x-4x"];
    CFG_KEYBINDINGS [label="Keyboard\nBindings"];
    CFG_MOUSE_BIND  [label="Mouse\nBindings"];
    CFG_STICK_BIND  [label="Joystick\nBindings"];

    CONFIG_SYS -> {CFG_FILE CFG_OS_SPECIFIC CFG_AUTO_DETECT CFG_CMDLINE_OPT CFG_DISPLAY CFG_TOOLBAR_SC CFG_KEYBINDINGS CFG_MOUSE_BIND CFG_STICK_BIND};

    // Config file details
    node [fillcolor="#f9e79f", fontcolor="#4a4a00", fontsize=8, color="#9a7d0a"];

    CFG_FPS         [label="FPS Limits\nIdle/Active"];
    CFG_GRID_CFG    [label="Grid Color\nOpacity/Angle"];
    CFG_TRANSP      [label="Transparency\nCheckerboard"];
    CFG_SOUNDS_CFG  [label="SFX/Music\nEnabled/Vol/Mute"];
    CFG_SYSTEM_CURS [label="SYSTEM_CURSORS\nToggle"];
    CFG_ANGLE_SNAP  [label="ANGLE_SNAP\nDEGREES"];
    CFG_FONT_DIRS   [label="Font Include\nDirectories"];
    CFG_UPGRADE     [label="--config-upgrade\nReconcile"];

    CFG_FILE -> {CFG_FPS CFG_GRID_CFG CFG_TRANSP CFG_SOUNDS_CFG CFG_SYSTEM_CURS CFG_ANGLE_SNAP CFG_FONT_DIRS CFG_UPGRADE};

    // OS-specific configs
    CFG_MACOS       [label="DRAW.macOS.cfg"];
    CFG_LINUX       [label="DRAW.linux.cfg"];
    CFG_WINDOWS     [label="DRAW.windows.cfg"];

    CFG_OS_SPECIFIC -> {CFG_MACOS CFG_LINUX CFG_WINDOWS};

    // =========================================================================
    // LEVEL 2 — HISTORY / UNDO SYSTEM (cross-cutting)
    // =========================================================================
    node [fillcolor="#641e16", fontcolor="white", fontsize=9, penwidth=1, color="#922b21"];

    UNDO_SYS        [label="History System\nCtrl+Z / Ctrl+Y"];

    DRAW -> UNDO_SYS;

    node [fillcolor="#fadbd8", fontcolor="#641e16", fontsize=8, color="#922b21"];

    UNDO_UNIFIED    [label="Unified History\nAll Operations"];
    UNDO_RECORD     [label="Auto-Record on\nMouse Release"];
    UNDO_GUARD      [label="Double-Save\nPrevention"];
    UNDO_MULTI      [label="Multi-Layer\nUndo Support"];

    UNDO_SYS -> {UNDO_UNIFIED UNDO_RECORD UNDO_GUARD UNDO_MULTI};

    // =========================================================================
    // LEVEL 2 — INPUT SYSTEM (cross-cutting)
    // =========================================================================
    node [fillcolor="#0e4d40", fontcolor="white", fontsize=9, penwidth=1, color="#138d75"];

    INPUT_SYS       [label="Input System"];

    DRAW -> INPUT_SYS;

    node [fillcolor="#d1f2eb", fontcolor="#0e4d40", fontsize=8, color="#138d75"];

    INPUT_MOUSE     [label="Mouse Input\n~2590 lines"];
    INPUT_KEYBOARD  [label="Keyboard\nShortcuts"];
    INPUT_JOYSTICK  [label="Joystick\nSupport"];
    INPUT_MODIFIERS [label="Modifier Keys\nCtrl/Shift/Alt"];
    INPUT_DRAG_DROP [label="Windows\nDrag & Drop"];

    INPUT_SYS -> {INPUT_MOUSE INPUT_KEYBOARD INPUT_JOYSTICK INPUT_MODIFIERS INPUT_DRAG_DROP};

    // Mouse details
    INPUT_COORD     [label="Raw / Canvas\n/ Unsnapped"];
    INPUT_BUTTON_TR [label="Button Press\n/ Release Detect"];
    INPUT_DEFERRED  [label="Deferred\nActions"];
    INPUT_CHROME    [label="UI Chrome\nSkip Logic"];

    INPUT_MOUSE -> {INPUT_COORD INPUT_BUTTON_TR INPUT_DEFERRED INPUT_CHROME};

    // =========================================================================
    // LEVEL 2 — RENDERING PIPELINE (cross-cutting)
    // =========================================================================
    node [fillcolor="#1b2631", fontcolor="white", fontsize=9, penwidth=1, color="#2c3e50"];

    RENDER_SYS      [label="Rendering\nPipeline"];

    DRAW -> RENDER_SYS;

    node [fillcolor="#d6dbdf", fontcolor="#1b2631", fontsize=8, color="#2c3e50"];

    RENDER_SCENE    [label="Scene Cache\nDirty Tracking"];
    RENDER_LAYERS   [label="Layer\nCompositing"];
    RENDER_BLEND    [label="Blend Mode\nProcessing"];
    RENDER_IDLE     [label="Idle Detection\n15 FPS Throttle"];
    RENDER_FPS      [label="Configurable\nFPS Limit"];

    RENDER_SYS -> {RENDER_SCENE RENDER_LAYERS RENDER_BLEND RENDER_IDLE RENDER_FPS};

    // =========================================================================
    // LEVEL 2 — PLATFORM SUPPORT (cross-cutting)
    // =========================================================================
    node [fillcolor="#283747", fontcolor="white", fontsize=9, penwidth=1, color="#34495e"];

    PLATFORM        [label="Platform\nSupport"];

    DRAW -> PLATFORM;

    node [fillcolor="#d5dde5", fontcolor="#283747", fontsize=8, color="#34495e"];

    PLAT_WINDOWS    [label="Windows"];
    PLAT_LINUX      [label="Linux"];
    PLAT_MACOS      [label="macOS"];
    PLAT_INSTALL    [label="Installers\n& File Assoc."];
    PLAT_QB64PE     [label="Built with\nQB64-PE v4.x+"];

    PLATFORM -> {PLAT_WINDOWS PLAT_LINUX PLAT_MACOS PLAT_INSTALL PLAT_QB64PE};
}
