// DRAW — Complete Feature Mind Map
// Generated from project documentation
// Render: dot -Tpng DRAW-feature-mindmap.dot -o DRAW-feature-mindmap.png
// Or:     dot -Tsvg DRAW-feature-mindmap.dot -o DRAW-feature-mindmap.svg

digraph DRAW_MindMap {
    // Global settings
    rankdir=TB;
    splines=ortho;
    nodesep=0.3;
    ranksep=0.5;
    fontname="Arial";
    fontsize=10;
    concentrate=true;

    // Node defaults
    node [
        shape=box,
        style="rounded,filled",
        fontname="Arial",
        fontsize=9,
        margin="0.15,0.08"
    ];

    // Edge defaults
    edge [
        color="#666666",
        arrowsize=0.5
    ];

    // =========================================================================
    // LEVEL 0 — ROOT
    // =========================================================================
    DRAW [
        label="DRAW\nPixel Art Editor\nv0.31.0\nby grymmjack",
        shape=doubleoctagon,
        style="filled,bold",
        fillcolor="#1a1a2e",
        fontcolor="white",
        fontsize=14,
        penwidth=3,
        color="#e94560"
    ];

    // =========================================================================
    // LEVEL 1 — Major Categories
    // =========================================================================
    node [fillcolor="#16213e", fontcolor="white", fontsize=11, penwidth=2, color="#0f3460"];

    TOOLS       [label="Drawing Tools"];
    SELECTION   [label="Selection\n& Clipboard"];
    LAYERS      [label="Layer System"];
    COLOR_SYS   [label="Color &\nPalette System"];
    CANVAS      [label="Canvas &\nView"];
    GRID_SYS    [label="Grid System"];
    BRUSH_SYS   [label="Brush System"];
    TEXT_SYS    [label="Text System"];
    FILE_IO     [label="File I/O"];
    IMAGE_ADJ   [label="Image\nAdjustments"];
    TRANSFORM   [label="Transform\nOperations"];
    UI          [label="User Interface"];
    AUDIO       [label="Audio System"];
    CONFIG_SYS  [label="Configuration"];

    DRAW -> {TOOLS SELECTION LAYERS COLOR_SYS CANVAS GRID_SYS BRUSH_SYS TEXT_SYS FILE_IO IMAGE_ADJ TRANSFORM UI AUDIO CONFIG_SYS};

    // =========================================================================
    // LEVEL 2 — DRAWING TOOLS
    // =========================================================================
    node [fillcolor="#533483", fontcolor="white", fontsize=9, penwidth=1, color="#7b2d8e"];

    TOOL_BRUSH      [label="Brush (B)"];
    TOOL_DOT        [label="Dot (D)"];
    TOOL_LINE       [label="Line (L)"];
    TOOL_RECT       [label="Rectangle (R)"];
    TOOL_ELLIPSE    [label="Ellipse (C)"];
    TOOL_POLYGON    [label="Polygon (P)"];
    TOOL_FILL       [label="Fill (F)"];
    TOOL_SPRAY      [label="Spray (K)"];
    TOOL_PICKER     [label="Picker (I)"];
    TOOL_ERASER     [label="Eraser (E)"];
    TOOL_ZOOM       [label="Zoom (Z)"];
    TOOL_PAN        [label="Pan (Hand)"];
    TOOL_CROP       [label="Crop"];
    TOOL_IMAGE_IMPORT [label="Image Import"];
    TOOL_CUSTOM_BRUSH [label="Custom Brush"];
    TOOL_REFIMG     [label="Reference Image"];
    TOOL_SYMMETRY   [label="Symmetry (F7)"];
    TOOL_ANGLE_SNAP [label="Angle Snap"];
    TOOL_PIXEL_COACH [label="Pixel Art Analyzer"];

    TOOLS -> {TOOL_BRUSH TOOL_DOT TOOL_LINE TOOL_RECT TOOL_ELLIPSE TOOL_POLYGON TOOL_FILL TOOL_SPRAY TOOL_PICKER TOOL_ERASER TOOL_ZOOM TOOL_PAN TOOL_CROP TOOL_IMAGE_IMPORT TOOL_CUSTOM_BRUSH TOOL_REFIMG TOOL_SYMMETRY TOOL_ANGLE_SNAP TOOL_PIXEL_COACH};

    // =========================================================================
    // LEVEL 3 — Tool Details
    // =========================================================================
    node [fillcolor="#e8d5f5", fontcolor="#1a1a2e", fontsize=8, color="#a855f7"];

    // Brush details
    BRUSH_FREEHAND  [label="Freehand\nPainting"];
    BRUSH_SIZE_ADJ  [label="Size 1-50px\n[ ] keys"];
    BRUSH_SHAPE     [label="Circle/Square\n\\ key"];
    BRUSH_PREVIEW   [label="Preview Mode\n` key"];
    BRUSH_PIXPERF   [label="Pixel Perfect\nF6"];
    BRUSH_AXIS_LOCK [label="Shift = Axis\nConstrain"];
    BRUSH_CONNECT   [label="Shift+RClick\nConnecting Line"];
    BRUSH_LR_CLICK  [label="L-Click FG\nR-Click BG"];

    TOOL_BRUSH -> {BRUSH_FREEHAND BRUSH_SIZE_ADJ BRUSH_SHAPE BRUSH_PREVIEW BRUSH_PIXPERF BRUSH_AXIS_LOCK BRUSH_CONNECT BRUSH_LR_CLICK};

    // Line details
    LINE_THICK      [label="Brush-Sized\nThick Preview"];
    LINE_SHIFT      [label="Shift = H/V\nConstrain"];
    LINE_SNAP       [label="Ctrl+Shift\nAngle Snap"];

    TOOL_LINE -> {LINE_THICK LINE_SHIFT LINE_SNAP};

    // Rectangle details
    RECT_OUTLINED   [label="Outlined (R)"];
    RECT_FILLED     [label="Filled (Shift+R)"];
    RECT_SQUARE     [label="Ctrl = Square"];
    RECT_CENTER     [label="Shift = From\nCenter"];
    RECT_FILL_ADJ   [label="Fill Adjust (F8)\nTiled Fill"];

    TOOL_RECT -> {RECT_OUTLINED RECT_FILLED RECT_SQUARE RECT_CENTER RECT_FILL_ADJ};

    // Ellipse details
    ELL_OUTLINED    [label="Outlined (C)"];
    ELL_FILLED      [label="Filled (Shift+C)"];
    ELL_CIRCLE      [label="Ctrl = Circle"];
    ELL_CENTER      [label="Shift = From\nCenter"];
    ELL_FILL_ADJ    [label="Fill Adjust (F8)\nTiled Fill"];

    TOOL_ELLIPSE -> {ELL_OUTLINED ELL_FILLED ELL_CIRCLE ELL_CENTER ELL_FILL_ADJ};

    // Polygon details
    POLY_OUTLINED   [label="Outlined (P)"];
    POLY_FILLED     [label="Filled (Shift+P)"];
    POLY_POINTS     [label="Click = Add Point\nEnter = Close"];
    POLY_ANGLE      [label="Ctrl+Shift\nAngle Snap"];
    POLY_FILL_ADJ   [label="Fill Adjust (F8)\nTiled Fill"];

    TOOL_POLYGON -> {POLY_OUTLINED POLY_FILLED POLY_POINTS POLY_ANGLE POLY_FILL_ADJ};

    // Fill details
    FILL_FLOOD      [label="Flood Fill"];
    FILL_MERGED     [label="Shift = Sample\nFrom Merged"];
    FILL_CUSTOM     [label="Custom Brush\nTiled Fill"];
    FILL_PATTERN    [label="Pattern/Gradient\nPaint Mode"];
    FILL_ADJUST     [label="Fill Adjustment\nOverlay (F8)"];

    TOOL_FILL -> {FILL_FLOOD FILL_MERGED FILL_CUSTOM FILL_PATTERN FILL_ADJUST};

    // Fill Adjustment sub-details
    node [fillcolor="#fde8f0", fontcolor="#4a044e", fontsize=7, color="#db2777"];

    FADJ_DRAG       [label="Drag = Reposition\nTile Origin"];
    FADJ_WHEEL      [label="Wheel = Scale\nUniform X/Y"];
    FADJ_LHANDLE    [label="L-Handle\nIndependent X/Y"];
    FADJ_ROTATE     [label="Rotation Handle\nArc Drag"];
    FADJ_APPLY      [label="Enter = Apply\nEsc = Cancel"];

    FILL_ADJUST -> {FADJ_DRAG FADJ_WHEEL FADJ_LHANDLE FADJ_ROTATE FADJ_APPLY};

    // Spray details
    node [fillcolor="#e8d5f5", fontcolor="#1a1a2e", fontsize=8, color="#a855f7"];

    SPRAY_NOZZLE    [label="Brush-Shaped\nNozzle Tips"];
    SPRAY_RADIUS    [label="Radius Doubles\nPer Size Level"];
    SPRAY_DENSITY   [label="Density Scales\nWith Radius"];
    SPRAY_CUSTOM    [label="Custom Brush\nStamp Support"];
    SPRAY_AXIS      [label="Shift = Axis\nConstrain"];

    TOOL_SPRAY -> {SPRAY_NOZZLE SPRAY_RADIUS SPRAY_DENSITY SPRAY_CUSTOM SPRAY_AXIS};

    // Picker details
    PICKER_LOUPE    [label="Cursor-Adjacent\nLoupe Overlay"];
    PICKER_RGB_HEX  [label="Shows RGB +\nHex Values"];
    PICKER_ALT_TEMP [label="ALT+Click =\nTemp Picker"];
    PICKER_FG_BG    [label="Alt+L = FG\nAlt+R = BG"];

    TOOL_PICKER -> {PICKER_LOUPE PICKER_RGB_HEX PICKER_ALT_TEMP PICKER_FG_BG};

    // Eraser details
    ERASER_PAINT_TRANS [label="Paints\nTransparent"];
    ERASER_HOLD     [label="Hold E =\nTemp Eraser"];
    ERASER_SMART    [label="Shift = Smart\nAll Layers"];
    ERASER_BRUSH_SZ [label="Uses Brush\nSize/Shape"];

    TOOL_ERASER -> {ERASER_PAINT_TRANS ERASER_HOLD ERASER_SMART ERASER_BRUSH_SZ};

    // Zoom details
    ZOOM_CLICK_IN   [label="Click = Zoom In"];
    ZOOM_ALT_OUT    [label="Alt+Click =\nZoom Out"];
    ZOOM_DRAG_RECT  [label="Drag = Zoom\nTo Region"];
    ZOOM_LEVELS     [label="25%-800%\nSnap Levels"];

    TOOL_ZOOM -> {ZOOM_CLICK_IN ZOOM_ALT_OUT ZOOM_DRAG_RECT ZOOM_LEVELS};

    // Crop details
    CROP_MARQUEE    [label="Marquee-Based\nCrop Region"];
    CROP_HANDLES    [label="Resize Handles\n+ Drag Move"];
    CROP_OVERLAY    [label="Dark Overlay\nOutside Region"];
    CROP_SIZE_LABEL [label="Dimensions\nLabel"];
    CROP_CANVAS_RESIZE [label="Canvas Resize\nDialog"];

    TOOL_CROP -> {CROP_MARQUEE CROP_HANDLES CROP_OVERLAY CROP_SIZE_LABEL CROP_CANVAS_RESIZE};

    // Image Import details
    IMPORT_OVERSIZED [label="Oversized Image\nPlacement"];
    IMPORT_ZOOM_PAN [label="Zoom + Pan\nWithin Image"];
    IMPORT_ROTATE   [label="Rotate 90°\nCW/CCW"];
    IMPORT_FLIP     [label="Flip H/V"];
    IMPORT_RESIZE   [label="Resize Dest\nBox"];
    IMPORT_LIVE_PREV [label="Live Preview\nAll Transforms"];

    TOOL_IMAGE_IMPORT -> {IMPORT_OVERSIZED IMPORT_ZOOM_PAN IMPORT_ROTATE IMPORT_FLIP IMPORT_RESIZE IMPORT_LIVE_PREV};

    // Custom Brush details
    CBRUSH_CAPTURE  [label="Capture Selection\nAs Brush"];
    CBRUSH_ALPHA    [label="Non-Rectangular\nvia Alpha"];
    CBRUSH_FLIP     [label="Flip H (Home)\nFlip V (End)"];
    CBRUSH_SCALE    [label="Scale Up (PgUp)\nDown (PgDn)"];
    CBRUSH_RECOLOR  [label="Recolor Mode\nF9"];
    CBRUSH_OUTLINE  [label="Outline Mode\nShift+O"];
    CBRUSH_EXPORT   [label="Export as PNG\nF12"];

    TOOL_CUSTOM_BRUSH -> {CBRUSH_CAPTURE CBRUSH_ALPHA CBRUSH_FLIP CBRUSH_SCALE CBRUSH_RECOLOR CBRUSH_OUTLINE CBRUSH_EXPORT};

    // Reference Image details
    REFIMG_TOGGLE   [label="Ctrl+R Toggle"];
    REFIMG_OPACITY  [label="Ctrl+Shift+Wheel\nOpacity 5-100%"];
    REFIMG_REPOS    [label="Reposition Mode\nDrag/Zoom/Nudge"];
    REFIMG_PERSIST  [label="Persisted in\n.draw Files"];

    TOOL_REFIMG -> {REFIMG_TOGGLE REFIMG_OPACITY REFIMG_REPOS REFIMG_PERSIST};

    // Symmetry details
    SYM_VERTICAL    [label="Vertical |\n2 copies"];
    SYM_CROSS       [label="Cross +\n4 copies"];
    SYM_ASTERISK    [label="Asterisk *\n8 copies"];
    SYM_CENTER      [label="Ctrl+Click\nReposition"];
    SYM_GUIDES      [label="Visual Guide\nLines"];

    TOOL_SYMMETRY -> {SYM_VERTICAL SYM_CROSS SYM_ASTERISK SYM_CENTER SYM_GUIDES};

    // Angle Snap details
    ASNAP_DEGREES   [label="Degree Mode\n15°/30°/45°/90°"];
    ASNAP_PIXEL     [label="Pixel Art Mode\nInteger Ratios"];
    ASNAP_BYPASS    [label="Ctrl+Shift\nBypass Grid"];

    TOOL_ANGLE_SNAP -> {ASNAP_DEGREES ASNAP_PIXEL ASNAP_BYPASS};

    // Pixel Art Analyzer details
    PIXCOACH_ORPHAN [label="Orphan Pixels"];
    PIXCOACH_JAGGED [label="Jagged Lines"];
    PIXCOACH_BAND   [label="Banding"];
    PIXCOACH_PILLOW [label="Pillow Shading"];
    PIXCOACH_DOUBLES [label="Doubles"];
    PIXCOACH_PRECOMP [label="Precompute\nEngine"];

    TOOL_PIXEL_COACH -> {PIXCOACH_ORPHAN PIXCOACH_JAGGED PIXCOACH_BAND PIXCOACH_PILLOW PIXCOACH_DOUBLES PIXCOACH_PRECOMP};

    // =========================================================================
    // LEVEL 2 — SELECTION & CLIPBOARD
    // =========================================================================
    node [fillcolor="#1d3557", fontcolor="white", fontsize=9, penwidth=1, color="#457b9d"];

    SEL_MARQUEE     [label="Marquee (M)"];
    SEL_FREEHAND    [label="Freehand Select"];
    SEL_POLY_SEL    [label="Polygon Select"];
    SEL_ELLIPSE_SEL [label="Ellipse Select"];
    SEL_WAND        [label="Magic Wand (W)"];
    SEL_CLIPBOARD   [label="Clipboard"];
    SEL_MASK        [label="Selection as\nClipping Mask"];
    SEL_STROKE      [label="Stroke\nSelection"];

    SELECTION -> {SEL_MARQUEE SEL_FREEHAND SEL_POLY_SEL SEL_ELLIPSE_SEL SEL_WAND SEL_CLIPBOARD SEL_MASK SEL_STROKE};

    // Marquee details
    node [fillcolor="#d4e8f5", fontcolor="#1a1a2e", fontsize=8, color="#457b9d"];

    MARQ_DRAG       [label="Drag = Create"];
    MARQ_SHIFT_ADD  [label="Shift = Add\nto Selection"];
    MARQ_ALT_SUB    [label="Alt = Subtract\nfrom Selection"];
    MARQ_HANDLES    [label="Resize Handles"];
    MARQ_MOVE_INSIDE [label="Drag Inside\n= Move"];
    MARQ_ARROWS     [label="Arrow Keys\n1px / 10px"];

    SEL_MARQUEE -> {MARQ_DRAG MARQ_SHIFT_ADD MARQ_ALT_SUB MARQ_HANDLES MARQ_MOVE_INSIDE MARQ_ARROWS};

    // Magic Wand details
    WAND_CONTIGUOUS [label="Contiguous\nSame-Color"];
    WAND_SHIFT_ADD  [label="Shift+Click\nAdd to Sel"];
    WAND_ALT_SUB    [label="Alt+Click\nSubtract"];
    WAND_F_FILL     [label="Hold F+Click\nFlood Fill FG"];
    WAND_E_ERASE    [label="Hold E+Click\nFlood Erase"];
    WAND_W_MERGED   [label="Hold W+Click\nSelect Merged"];

    SEL_WAND -> {WAND_CONTIGUOUS WAND_SHIFT_ADD WAND_ALT_SUB WAND_F_FILL WAND_E_ERASE WAND_W_MERGED};

    // Clipboard details
    CLIP_COPY       [label="Copy\nCtrl+C"];
    CLIP_CUT        [label="Cut\nCtrl+X"];
    CLIP_PASTE      [label="Paste at Cursor\nCtrl+V"];
    CLIP_MERGED     [label="Merged Copy\nCtrl+Shift+C"];
    CLIP_CLEAR      [label="Clear Selection\nCtrl+E"];
    CLIP_COPY_LAYER [label="Copy to Layer\nCtrl+Alt+C"];
    CLIP_CUT_LAYER  [label="Cut to Layer\nCtrl+Alt+X"];
    CLIP_PASTE_OS   [label="Paste from OS\nCtrl+Shift+V"];

    SEL_CLIPBOARD -> {CLIP_COPY CLIP_CUT CLIP_PASTE CLIP_MERGED CLIP_CLEAR CLIP_COPY_LAYER CLIP_CUT_LAYER CLIP_PASTE_OS};

    // Stroke Selection details
    STROKE_WIDTH    [label="Configurable\nWidth (px)"];
    STROKE_COLOR    [label="FG or Custom\nColor"];
    STROKE_POS      [label="Inside / Outside\n/ Center"];

    SEL_STROKE -> {STROKE_WIDTH STROKE_COLOR STROKE_POS};

    // Selection mask details
    SEL_FROM_LAYER  [label="From Current\nLayer"];
    SEL_FROM_MULTI  [label="From Selected\nLayers (2+)"];
    SEL_SELECT_ALL  [label="Select All\nCtrl+A"];
    SEL_INVERT      [label="Invert\nCtrl+Shift+I"];
    SEL_EXPAND      [label="Expand\nContract"];

    SEL_MASK -> {SEL_FROM_LAYER SEL_FROM_MULTI SEL_SELECT_ALL SEL_INVERT SEL_EXPAND};

    // =========================================================================
    // LEVEL 2 — LAYER SYSTEM
    // =========================================================================
    node [fillcolor="#2d6a4f", fontcolor="white", fontsize=9, penwidth=1, color="#40916c"];

    LAYER_BASIC     [label="64 Layers\nUp to 128 Slots"];
    LAYER_OPACITY   [label="Per-Layer\nOpacity"];
    LAYER_VISIBILITY [label="Visibility\nToggle"];
    LAYER_BLEND     [label="Blend Modes\n(19 + Pass Through)"];
    LAYER_GROUPS    [label="Layer Groups"];
    LAYER_MULTI_SEL [label="Multi-Layer\nSelect"];
    LAYER_OPS       [label="Layer\nOperations"];
    LAYER_LOCK      [label="Opacity Lock"];
    LAYER_PANEL_UI  [label="Layer Panel\nUI"];
    LAYER_DRAG_DROP [label="Drag & Drop\nReordering"];

    LAYERS -> {LAYER_BASIC LAYER_OPACITY LAYER_VISIBILITY LAYER_BLEND LAYER_GROUPS LAYER_MULTI_SEL LAYER_OPS LAYER_LOCK LAYER_PANEL_UI LAYER_DRAG_DROP};

    // Blend modes details
    node [fillcolor="#d4edda", fontcolor="#1a1a2e", fontsize=7, color="#40916c"];

    BLEND_NORMAL    [label="Normal"];
    BLEND_MULTIPLY  [label="Multiply"];
    BLEND_SCREEN    [label="Screen"];
    BLEND_OVERLAY   [label="Overlay"];
    BLEND_ADD       [label="Add\n(Linear Dodge)"];
    BLEND_SUBTRACT  [label="Subtract"];
    BLEND_DIFF      [label="Difference"];
    BLEND_DARKEN    [label="Darken"];
    BLEND_LIGHTEN   [label="Lighten"];
    BLEND_CDODGE    [label="Color Dodge"];
    BLEND_CBURN     [label="Color Burn"];
    BLEND_HARDL     [label="Hard Light"];
    BLEND_SOFTL     [label="Soft Light"];
    BLEND_EXCLUSION [label="Exclusion"];
    BLEND_VIVIDL    [label="Vivid Light"];
    BLEND_LINEARL   [label="Linear Light"];
    BLEND_PINL      [label="Pin Light"];
    BLEND_COLOR     [label="Color"];
    BLEND_LUMINOSITY [label="Luminosity"];
    BLEND_PASSTHRU  [label="Pass Through\n(Groups)"];

    LAYER_BLEND -> {BLEND_NORMAL BLEND_MULTIPLY BLEND_SCREEN BLEND_OVERLAY BLEND_ADD BLEND_SUBTRACT BLEND_DIFF BLEND_DARKEN BLEND_LIGHTEN BLEND_CDODGE BLEND_CBURN BLEND_HARDL BLEND_SOFTL BLEND_EXCLUSION BLEND_VIVIDL BLEND_LINEARL BLEND_PINL BLEND_COLOR BLEND_LUMINOSITY BLEND_PASSTHRU};

    // Layer Groups details
    node [fillcolor="#d4edda", fontcolor="#1a1a2e", fontsize=8, color="#40916c"];

    LGRP_CREATE     [label="New Group\nCtrl+G"];
    LGRP_FROM_SEL   [label="Group from Sel\nCtrl+Shift+G"];
    LGRP_UNGROUP    [label="Ungroup\nCtrl+Shift+U"];
    LGRP_COLLAPSE   [label="Collapsible\nTriangle Toggle"];
    LGRP_NESTED     [label="Arbitrary\nNesting Depth"];
    LGRP_DND_INTO   [label="Drag Layer\nInto Group"];
    LGRP_MERGE_GRP  [label="Merge Group\nTo One Layer"];
    LGRP_SELECT_ALL [label="Select All\nIn Group"];
    LGRP_SEL_MASK   [label="Selection From\nGroup Pixels"];

    LAYER_GROUPS -> {LGRP_CREATE LGRP_FROM_SEL LGRP_UNGROUP LGRP_COLLAPSE LGRP_NESTED LGRP_DND_INTO LGRP_MERGE_GRP LGRP_SELECT_ALL LGRP_SEL_MASK};

    // Layer operations
    LAYER_NEW       [label="New Layer\nCtrl+Shift+N"];
    LAYER_DELETE    [label="Delete\nCtrl+Shift+Del"];
    LAYER_DUPLICATE [label="Duplicate\nCtrl+Shift+D"];
    LAYER_MERGE_DN  [label="Merge Down\nCtrl+Alt+E"];
    LAYER_MERGE_VIS [label="Merge Visible\nCtrl+Alt+Shift+E"];
    LAYER_MERGE_SEL [label="Merge Selected"];
    LAYER_MOVE_UP   [label="Move Up\nCtrl+PgUp"];
    LAYER_MOVE_DN   [label="Move Down\nCtrl+PgDn"];
    LAYER_ARRANGE_T [label="Arrange Top\nCtrl+Home"];
    LAYER_ARRANGE_B [label="Arrange Bottom\nCtrl+End"];
    LAYER_ALIGN     [label="Align\nL/C/R/T/M/B"];
    LAYER_DISTRIBUTE [label="Distribute\nH/V"];

    LAYER_OPS -> {LAYER_NEW LAYER_DELETE LAYER_DUPLICATE LAYER_MERGE_DN LAYER_MERGE_VIS LAYER_MERGE_SEL LAYER_MOVE_UP LAYER_MOVE_DN LAYER_ARRANGE_T LAYER_ARRANGE_B LAYER_ALIGN LAYER_DISTRIBUTE};

    // Layer Panel UI
    LPANEL_EYE      [label="Eye Icon\nVisibility"];
    LPANEL_LOCK_IC  [label="Lock Icon"];
    LPANEL_NAME     [label="Click = Select\nR-Click = Rename"];
    LPANEL_OPBAR    [label="Opacity Bar\nDrag to Adjust"];
    LPANEL_SOLO     [label="Alt+Click Eye\n= Solo"];
    LPANEL_SWIPE    [label="Drag Across\nEye = Swipe"];
    LPANEL_BLEND_CYC [label="Shift+R-Click\n= Cycle Blend"];
    LPANEL_CONTEXT  [label="Right-Click\nContext Menu"];

    LAYER_PANEL_UI -> {LPANEL_EYE LPANEL_LOCK_IC LPANEL_NAME LPANEL_OPBAR LPANEL_SOLO LPANEL_SWIPE LPANEL_BLEND_CYC LPANEL_CONTEXT};

    // =========================================================================
    // LEVEL 2 — COLOR & PALETTE SYSTEM
    // =========================================================================
    node [fillcolor="#7f2b0a", fontcolor="white", fontsize=9, penwidth=1, color="#b03a2e"];

    PAL_STRIP       [label="Palette Strip"];
    PAL_DROPDOWN    [label="Palette\nDropdown"];
    PAL_OPS         [label="Palette Ops\nMode"];
    PAL_IMPORT_EXP  [label="Palette\nImport/Export"];
    PAL_PICKER      [label="Color Picker\n(RGB)"];
    PAL_FG_BG       [label="FG / BG\nColors"];
    PAL_OPACITY     [label="Paint Opacity\n1-0 Keys"];
    PAL_WORKFLOWS   [label="Palette\nWorkflows"];

    COLOR_SYS -> {PAL_STRIP PAL_DROPDOWN PAL_OPS PAL_IMPORT_EXP PAL_PICKER PAL_FG_BG PAL_OPACITY PAL_WORKFLOWS};

    // Palette Strip details
    node [fillcolor="#f5d5c8", fontcolor="#4a0000", fontsize=8, color="#b03a2e"];

    PSTRIP_LEFT     [label="L-Click = FG"];
    PSTRIP_RIGHT    [label="R-Click = BG"];
    PSTRIP_SCROLL   [label="Wheel = Scroll\nShift+Wheel = Fast"];
    PSTRIP_ARROWS   [label="Arrow Buttons\n◄ ►"];

    PAL_STRIP -> {PSTRIP_LEFT PSTRIP_RIGHT PSTRIP_SCROLL PSTRIP_ARROWS};

    // Palette Ops details
    POPS_DBLCLICK   [label="Dbl-Click =\nChange Color"];
    POPS_RCLICK     [label="R-Click =\nMark Color"];
    POPS_MCLICK_DEL [label="M-Click =\nDelete Color"];
    POPS_MCLICK_INS [label="Shift+M-Click =\nInsert Color"];
    POPS_DRAG       [label="Drag =\nRearrange"];
    POPS_WAND       [label="L-Click =\nWand Select"];
    POPS_DOC_PAL    [label="Auto [DOCUMENT]\nPalette"];

    PAL_OPS -> {POPS_DBLCLICK POPS_RCLICK POPS_MCLICK_DEL POPS_MCLICK_INS POPS_DRAG POPS_WAND POPS_DOC_PAL};

    // FG/BG details
    FGBG_SWAP       [label="X = Swap\nFG/BG"];
    FGBG_DEFAULT    [label="Ctrl+D =\nReset"];
    FGBG_BG_TRANS   [label="Shift+Del =\nBG Transparent"];
    FGBG_STATUS_CLK [label="Click Status Bar\nSwatches"];

    PAL_FG_BG -> {FGBG_SWAP FGBG_DEFAULT FGBG_BG_TRANS FGBG_STATUS_CLK};

    // Palette Workflows details
    PWFLOW_LOSPEC   [label="Lospec\nDownload"];
    PWFLOW_FROM_IMG [label="Create From\nImage"];
    PWFLOW_REMAP    [label="Remap Artwork\nTo Palette"];
    PWFLOW_GPL      [label="56 Bundled\n.GPL Files"];

    PAL_WORKFLOWS -> {PWFLOW_LOSPEC PWFLOW_FROM_IMG PWFLOW_REMAP PWFLOW_GPL};

    // Opacity details
    PAL_OP_10       [label="Keys 1-9 =\n10%-90%"];
    PAL_OP_100      [label="Key 0 =\n100%"];
    PAL_OP_STROKE   [label="Per-Stroke\nCompositing"];

    PAL_OPACITY -> {PAL_OP_10 PAL_OP_100 PAL_OP_STROKE};

    // =========================================================================
    // LEVEL 2 — CANVAS & VIEW
    // =========================================================================
    node [fillcolor="#003049", fontcolor="white", fontsize=9, penwidth=1, color="#0077b6"];

