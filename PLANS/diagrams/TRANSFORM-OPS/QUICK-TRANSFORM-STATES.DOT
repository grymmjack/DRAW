digraph TRANSFORM_QUICK_OPS {
    label="QUICK TRANSFORM OPERATIONS STATE MACHINE" labelloc=t labeljust=c
    ordering=out rankdir=TB
    fontcolor=white fontsize=24.0 fontname="Cascadia Code PL"
    splines=true compound=true
    bgcolor=transparent
    edge [
        color=gray fontcolor="#aaaaaa" fontsize=9.0
        fontname="Cascadia Code PL"
    ];
    node [
        color=white shape=rect style=""
        fontname="Cascadia Code PL" fontsize=11.0 fontcolor=cyan
    ];

    { node [shape=folder color=orange penwidth=2 fontcolor=orange fontsize=13.0];
        MAIN [label="QUICK\nTRANSFORMS"];
    }

    S_IDLE [label="1 В· IDLE\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nCurrent layer selected\nOriginal pixel data\nNo transform pending"];

    MAIN -> S_IDLE [arrowhead=none color="#555555" style=dotted];
    { rank=min; MAIN }

    subgraph cluster_flip {
        label="FLIP OPERATIONS" labelloc=t labeljust=l
        fontcolor=white fontsize=11.0 fontname="Cascadia Code PL"
        color=orange style=dashed penwidth=1

        FLIP_H [label="Flip Horizontal\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nEdit в†’ Flip Horizontal\nMirror pixels leftв†”right\nImmediate application\nNo preview step"];
        FLIP_V [label="Flip Vertical\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nEdit в†’ Flip Vertical\nMirror pixels topв†”bottom\nImmediate application\nNo preview step"];

        FH_EXEC [label="Execute Flip H\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\n1. Snapshot layer img\n2. _PUTIMAGE flip X\n3. HISTORY_record\n4. SCENE_DIRTY=TRUE"];
        FV_EXEC [label="Execute Flip V\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\n1. Snapshot layer img\n2. _PUTIMAGE flip Y\n3. HISTORY_record\n4. SCENE_DIRTY=TRUE"];

        FLIP_H -> FH_EXEC [label="  Apply" color="#cccc66"];
        FLIP_V -> FV_EXEC [label="  Apply" color="#cccc66"];
    }

    subgraph cluster_rotate {
        label="ROTATE OPERATIONS" labelloc=t labeljust=l
        fontcolor=white fontsize=11.0 fontname="Cascadia Code PL"
        color=orange style=dashed penwidth=1

        ROT_CW [label="Rotate 90В° CW\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nEdit в†’ Rotate в†’ 90В° CW\nSwap widthв†”height\nRemap pixels:\n  dst(y,W-1-x) = src(x,y)"];
        ROT_CCW [label="Rotate 90В° CCW\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nEdit в†’ Rotate в†’ 90В° CCW\nSwap widthв†”height\nRemap pixels:\n  dst(H-1-y,x) = src(x,y)"];

        RCW_EXEC [label="Execute Rotate CW\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\n1. Create new image\n   (HГ—W swapped)\n2. Copy rotated pixels\n3. Replace layer img\n4. HISTORY_record"];
        RCCW_EXEC [label="Execute Rotate CCW\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\n1. Create new image\n   (HГ—W swapped)\n2. Copy rotated pixels\n3. Replace layer img\n4. HISTORY_record"];

        ROT_CW -> RCW_EXEC [label="  Apply" color="#cccc66"];
        ROT_CCW -> RCCW_EXEC [label="  Apply" color="#cccc66"];
    }

    subgraph cluster_scale {
        label="SCALE OPERATIONS" labelloc=t labeljust=l
        fontcolor=white fontsize=11.0 fontname="Cascadia Code PL"
        color=orange style=dashed penwidth=1

        SCALE_UP [label="Scale +50%\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nEdit в†’ Scale в†’ +50%\nEnlarge layer pixels\nNearest-neighbor\ninterpolation"];
        SCALE_DOWN [label="Scale -50%\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nEdit в†’ Scale в†’ -50%\nShrink layer pixels\nNearest-neighbor\ninterpolation"];

        SU_EXEC [label="Execute Scale Up\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\n1. Create new image\n   (WГ—1.5, HГ—1.5)\n2. _PUTIMAGE scale\n3. Replace layer img\n4. HISTORY_record"];
        SD_EXEC [label="Execute Scale Down\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\n1. Create new image\n   (WГ—0.5, HГ—0.5)\n2. _PUTIMAGE scale\n3. Replace layer img\n4. HISTORY_record"];

        SCALE_UP -> SU_EXEC [label="  Apply" color="#cccc66"];
        SCALE_DOWN -> SD_EXEC [label="  Apply" color="#cccc66"];
    }

    S_IDLE -> FLIP_H [label="  Flip H" color="#6699ff"];
    S_IDLE -> FLIP_V [label="  Flip V" color="#6699ff"];
    S_IDLE -> ROT_CW [label="  Rotate CW" color="#6699ff"];
    S_IDLE -> ROT_CCW [label="  Rotate CCW" color="#6699ff"];
    S_IDLE -> SCALE_UP [label="  Scale +50%" color="#6699ff"];
    S_IDLE -> SCALE_DOWN [label="  Scale -50%" color="#6699ff"];

    subgraph cluster_post {
        label="POST-TRANSFORM" labelloc=t labeljust=l
        fontcolor=white fontsize=11.0 fontname="Cascadia Code PL"
        color=orange style=dashed penwidth=1

        P1 [label="Invalidation\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nSCENE_DIRTY = TRUE\nCANVAS_DIRTY = TRUE\nBLEND_invalidate_cache\ncontentDirty = TRUE\nfor affected layer"];
    }

    subgraph cluster_legend {
        label="LEGEND" labelloc=t labeljust=l
        fontcolor=white fontsize=11.0 fontname="Cascadia Code PL"
        color=white style=dashed penwidth=1
        L1 [label="" shape=point width=0.01]; L2 [label="" shape=point width=0.01];
        L3 [label="" shape=point width=0.01]; L4 [label="" shape=point width=0.01];
        L1 -> L2 [label=" Execute operation" arrowhead=normal color="#6699ff" fontsize=9.0];
        L3 -> L4 [label=" Commit / Record" arrowhead=normal color="#cccc66" fontsize=9.0];
    }
}
