digraph TRANSFORM_OVERLAY {
    label="TRANSFORM OVERLAY STATE MACHINE\n(Scale / Rotate / Shear / Distort / Perspective)" labelloc=t labeljust=c
    ordering=out rankdir=TB
    fontcolor=white fontsize=24.0 fontname="Cascadia Code PL"
    splines=true compound=true
    bgcolor=transparent
    edge [
        color=gray fontcolor="#aaaaaa" fontsize=9.0
        fontname="Cascadia Code PL"
    ];
    node [
        color=white shape=rect style=""
        fontname="Cascadia Code PL" fontsize=11.0 fontcolor=cyan
    ];

    { node [shape=folder color=orange penwidth=2 fontcolor=orange fontsize=13.0];
        MAIN [label="TRANSFORM\nOVERLAY"];
    }

    S_IDLE [label="1 В· IDLE\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nTRANSFORM.ACTIVE = FALSE\nNo overlay visible\nNormal drawing mode"];
    S_ACTIVATED [label="2 В· ACTIVATED\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nTRANSFORM.ACTIVE = TRUE\nMODE set (Scale/Rotate/etc)\nSRC image captured\n4 corner handles shown\nPivot point shown"];
    S_HOVERING [label="3 В· HOVERING\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nMouse over overlay\nHandle hit detection\nCursor changes on hover\nGRABBED = -1 (none)"];
    S_GRABBED [label="4 В· GRABBED\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nGRABBED = handle index\n0-3 = corners (TL/TR/BR/BL)\n4 = body (move all)\nDRAG_OFX/OFY set"];
    S_DRAGGING [label="5 В· DRAGGING\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nTRANSFORM_mouse_hold()\nupdates handle positions\nPREVIEW_DIRTY = TRUE\nWarped preview recomputed\neach frame"];
    S_COMMITTED [label="6 В· COMMITTED\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nTRANSFORM_commit()\nApply warp to layer\nHISTORY_record\nACTIVE = FALSE\nPREV_TOOL restored"];
    S_CANCELLED [label="7 В· CANCELLED\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nTRANSFORM_cancel()\nRestore layer from SRC\nACTIVE = FALSE\nPREV_TOOL restored"];

    S_IDLE -> S_ACTIVATED [label="  Edit в†’ Transform...\n  CMD_execute_action\n  TRANSFORM_activate(mode)" color="#66cc66"];
    S_ACTIVATED -> S_HOVERING [label="  Mouse enters\n  overlay region" color="#66cc66"];
    S_HOVERING -> S_GRABBED [label="  Mouse press on handle\n  TRANSFORM_mouse_press()\n  GRABBED = handle idx" color="#66cc66"];
    S_GRABBED -> S_DRAGGING [label="  Mouse move\n  Begin drag" color="#cccc66"];
    S_DRAGGING -> S_HOVERING [label="  Mouse release\n  TRANSFORM_mouse_release()\n  GRABBED = -1\n  Finalize drag step" color="#cc6666" style=dashed];
    S_HOVERING -> S_COMMITTED [label="  Press Enter\n  TRANSFORM_commit()" color="#cccc66"];
    S_HOVERING -> S_CANCELLED [label="  Press Escape\n  TRANSFORM_cancel()" color="#cc6666" style=dashed];
    S_DRAGGING -> S_DRAGGING [label="  Mouse moves\n  Update handle positions\n  Recompute preview" color="#88aacc"];

    MAIN -> S_IDLE [arrowhead=none color="#555555" style=dotted];
    { rank=min; MAIN }

    subgraph cluster_modes {
        label="TRANSFORM MODES (TRANSFORM_MODE_*)" labelloc=t labeljust=l
        fontcolor=white fontsize=11.0 fontname="Cascadia Code PL"
        color=orange style=dashed penwidth=1

        M_SCALE [label="MODE_SCALE (1)\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nDrag corners to scale\nSCALE_X/Y computed\nfrom corner deltas\nShift = lock aspect"];
        M_ROTATE [label="MODE_ROTATE (2)\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nDrag corners around\nPIVOT (center point)\nANGLE computed from\nmouse angle to pivot"];
        M_SHEAR [label="MODE_SHEAR (3)\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nSkew one axis\nDrag top/bottom = H shear\nDrag left/right = V shear"];
        M_DISTORT [label="MODE_DISTORT (4)\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nFree-form corner drag\nEach corner independent\nArbitrary quadrilateral"];
        M_PERSPECTIVE [label="MODE_PERSPECTIVE (5)\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nHomography transform\nPerspective projection\nCorner movement with\nperspective constraints"];

        M_SCALE -> M_ROTATE [style=invis];
        M_ROTATE -> M_SHEAR [style=invis];
        M_SHEAR -> M_DISTORT [style=invis];
        M_DISTORT -> M_PERSPECTIVE [style=invis];
    }

    subgraph cluster_handles {
        label="HANDLE SYSTEM" labelloc=t labeljust=l
        fontcolor=white fontsize=11.0 fontname="Cascadia Code PL"
        color=orange style=dashed penwidth=1

        H1 [label="Corner Handles (0-3)\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nTRANSFORM_HX/HY(0..3)\nTL=0, TR=1, BR=2, BL=3\nDrag to transform"];
        H2 [label="Body Drag (4)\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nGRABBED = 4\nTranslate all corners\nequally (move)"];
        H3 [label="Pivot Point\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nTRANSFORM_PX/PY\nCenter of rotation\nDisplayed as crosshair"];
    }

    subgraph cluster_modifiers {
        label="MODIFIER KEYS" labelloc=t labeljust=l
        fontcolor=white fontsize=11.0 fontname="Cascadia Code PL"
        color=orange style=dashed penwidth=1

        MOD_SHIFT [label="SHIFT held\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nConstrain drag to\nX or Y axis only\nLock horizontal/vertical"];
        MOD_CTRL [label="CTRL held\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nScale from center\nPivot stays fixed\nSymmetric scaling"];
        MOD_ARROW [label="Arrow Keys\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nTRANSFORM_rotate_step()\nFine rotation control\n+/- degrees per press"];
    }

    subgraph cluster_preview {
        label="PREVIEW RENDERING" labelloc=t labeljust=l
        fontcolor=white fontsize=11.0 fontname="Cascadia Code PL"
        color=orange style=dashed penwidth=1

        PR1 [label="TRANSFORM_PREVIEW_IMG\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nWarped preview image\nUpdated each drag step\nTRANSFORM_PREVIEW_DIRTY\nflags when recompute needed"];
        PR2 [label="TRANSFORM_render_overlay()\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nDraw handle squares\nDraw guide lines\nDraw pivot crosshair\nDraw warped preview"];
    }

    subgraph cluster_legend {
        label="LEGEND" labelloc=t labeljust=l
        fontcolor=white fontsize=11.0 fontname="Cascadia Code PL"
        color=white style=dashed penwidth=1
        L1 [label="" shape=point width=0.01]; L2 [label="" shape=point width=0.01];
        L3 [label="" shape=point width=0.01]; L4 [label="" shape=point width=0.01];
        L5 [label="" shape=point width=0.01]; L6 [label="" shape=point width=0.01];
        L7 [label="" shape=point width=0.01]; L8 [label="" shape=point width=0.01];
        L1 -> L2 [label=" Activate / Start" arrowhead=normal color="#66cc66" fontsize=9.0];
        L3 -> L4 [label=" Cancel / Release" arrowhead=normal color="#cc6666" style=dashed fontsize=9.0];
        L5 -> L6 [label=" Commit / Record" arrowhead=normal color="#cccc66" fontsize=9.0];
        L7 -> L8 [label=" Self-transition" arrowhead=normal color="#88aacc" fontsize=9.0];
    }
}
