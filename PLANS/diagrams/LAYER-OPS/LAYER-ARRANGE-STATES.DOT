digraph LAYER_ARRANGE {
    label="LAYER ARRANGE STATE MACHINE" labelloc=t labeljust=c
    ordering=out rankdir=TB
    fontcolor=white fontsize=24.0 fontname="Cascadia Code PL"
    splines=true compound=true
    bgcolor=transparent
    edge [
        color=gray fontcolor="#aaaaaa" fontsize=9.0
        fontname="Cascadia Code PL"
    ];
    node [
        color=white shape=rect style=""
        fontname="Cascadia Code PL" fontsize=11.0 fontcolor=cyan
    ];

    { node [shape=folder color=orange penwidth=2 fontcolor=orange fontsize=13.0];
        MAIN [label="LAYER\nARRANGE"];
    }

    S_IDLE [label="1 В· IDLE\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nCURRENT_LAYER% active\nEach layer has zIndex\nRENDER_ORDER_DIRTY=FALSE"];

    MAIN -> S_IDLE [arrowhead=none color="#555555" style=dotted];
    { rank=min; MAIN }

    subgraph cluster_keyboard {
        label="KEYBOARD ARRANGE" labelloc=t labeljust=l
        fontcolor=white fontsize=11.0 fontname="Cascadia Code PL"
        color=orange style=dashed penwidth=1

        K_UP [label="Move Up\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nLayer в†’ Arrange в†’ Up\nSwap zIndex with\nlayer above\nHISTORY_record\n  LAYER_REORDER"];
        K_DOWN [label="Move Down\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nLayer в†’ Arrange в†’ Down\nSwap zIndex with\nlayer below\nHISTORY_record"];
        K_TOP [label="Move to Top\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nLayer в†’ Arrange в†’ Top\nSet zIndex = max\nShift others down\nHISTORY_record"];
        K_BOTTOM [label="Move to Bottom\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nLayer в†’ Arrange в†’Bottom\nSet zIndex = 0\nShift others up\nHISTORY_record"];
    }

    subgraph cluster_drag {
        label="DRAG REORDER (LAYERS PANEL)" labelloc=t labeljust=l
        fontcolor=white fontsize=11.0 fontname="Cascadia Code PL"
        color=orange style=dashed penwidth=1

        D_PENDING [label="Drag Pending\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\ndragPending = TRUE\nMouse down on layer row\ndragStartY = mouseY\nWaiting for threshold"];
        D_DRAGGING [label="Dragging\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nisDragging = TRUE\ndragLayerIdx = source\ndragPreviewY tracks mouse\nDrop target indicator shown"];
        D_AUTOSCROLL [label="Auto-Scroll\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nDrag near panel edge\nautoScrollTimer active\nPanel scrolls to reveal\nmore layers"];
        D_DROP [label="Drop\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nRelease mouse\nLAYER_PANEL_handle_drop()\nMove layer to\ndropTargetZIndex\nHISTORY_record"];

        D_PENDING -> D_DRAGGING [label="  Mouse moves\n  past threshold\n  (5px minimum)" color="#66cc66"];
        D_PENDING -> S_IDLE [label="  Mouse release\n  before threshold\n  (was a click)" color="#cc6666" style=dashed];
        D_DRAGGING -> D_AUTOSCROLL [label="  Mouse near\n  panel edge" color="#88aacc"];
        D_AUTOSCROLL -> D_DRAGGING [label="  Mouse moved\n  away from edge" color="#88aacc"];
        D_DRAGGING -> D_DROP [label="  Mouse release" color="#cccc66"];
        D_AUTOSCROLL -> D_DROP [label="  Mouse release" color="#cccc66"];
    }

    S_IDLE -> K_UP [label="  Arrange Up" color="#6699ff"];
    S_IDLE -> K_DOWN [label="  Arrange Down" color="#6699ff"];
    S_IDLE -> K_TOP [label="  Arrange Top" color="#6699ff"];
    S_IDLE -> K_BOTTOM [label="  Arrange Bottom" color="#6699ff"];
    S_IDLE -> D_PENDING [label="  Mouse down\n  on layer row" color="#66cc66"];

    subgraph cluster_post {
        label="POST-ARRANGE" labelloc=t labeljust=l
        fontcolor=white fontsize=11.0 fontname="Cascadia Code PL"
        color=orange style=dashed penwidth=1

        P1 [label="Invalidation\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nRENDER_ORDER_DIRTY=TRUE\nSCENE_DIRTY = TRUE\nBLEND_invalidate_cache\nComposite below reset"];
    }

    subgraph cluster_legend {
        label="LEGEND" labelloc=t labeljust=l
        fontcolor=white fontsize=11.0 fontname="Cascadia Code PL"
        color=white style=dashed penwidth=1
        L1 [label="" shape=point width=0.01]; L2 [label="" shape=point width=0.01];
        L3 [label="" shape=point width=0.01]; L4 [label="" shape=point width=0.01];
        L5 [label="" shape=point width=0.01]; L6 [label="" shape=point width=0.01];
        L7 [label="" shape=point width=0.01]; L8 [label="" shape=point width=0.01];
        L1 -> L2 [label=" Activate / Start" arrowhead=normal color="#66cc66" fontsize=9.0];
        L3 -> L4 [label=" Cancel / Abort" arrowhead=normal color="#cc6666" style=dashed fontsize=9.0];
        L5 -> L6 [label=" Commit / Record" arrowhead=normal color="#cccc66" fontsize=9.0];
        L7 -> L8 [label=" Rearrange / Move" arrowhead=normal color="#6699ff" fontsize=9.0];
    }
}
