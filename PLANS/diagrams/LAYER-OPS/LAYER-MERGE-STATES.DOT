digraph LAYER_MERGE {
    label="LAYER MERGE STATE MACHINE" labelloc=t labeljust=c
    ordering=out rankdir=TB
    fontcolor=white fontsize=24.0 fontname="Cascadia Code PL"
    splines=true compound=true
    bgcolor=transparent
    edge [
        color=gray fontcolor="#aaaaaa" fontsize=9.0
        fontname="Cascadia Code PL"
    ];
    node [
        color=white shape=rect style=""
        fontname="Cascadia Code PL" fontsize=11.0 fontcolor=cyan
    ];

    { node [shape=folder color=orange penwidth=2 fontcolor=orange fontsize=13.0];
        MAIN [label="LAYER MERGE\nOPERATIONS"];
    }

    S_IDLE [label="1 В· IDLE\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nNo merge active\nAll layers independent\nCURRENT_LAYER% set"];

    MAIN -> S_IDLE [arrowhead=none color="#555555" style=dotted];
    { rank=min; MAIN }

    subgraph cluster_merge_down {
        label="MERGE DOWN" labelloc=t labeljust=l
        fontcolor=white fontsize=11.0 fontname="Cascadia Code PL"
        color=orange style=dashed penwidth=1

        MD_TRIGGER [label="Trigger\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nLayer в†’ Merge Down\nor Ctrl+E\nMerges current into\nlayer below"];
        MD_GUARD [label="Guard\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nCurrent layer has\na layer below it\n(not bottom layer)"];
        MD_SNAPSHOT [label="Snapshot Both\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nHISTORY_record\n  kind = LAYER_MERGE\n  img = current pixels\n  img2 = below pixels\nSave both states"];
        MD_COMPOSITE [label="Composite\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\n_DEST below.imgHandle&\nBlend current onto below\nRespect opacity+blendMode\nPer-pixel alpha composite"];
        MD_CLEANUP [label="Delete Source\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\n_FREEIMAGE current\nRemove layer slot\nReindex z-order\nCURRENT_LAYER% = below"];

        MD_TRIGGER -> MD_GUARD [label="  Execute" color="#cccc66"];
        MD_GUARD -> MD_SNAPSHOT [label="  Has layer below" color="#cccc66"];
        MD_GUARD -> MD_TRIGGER [label="  No layer below\n  Abort" color="#cc6666" style=dashed];
        MD_SNAPSHOT -> MD_COMPOSITE [label="  Saved" color="#cccc66"];
        MD_COMPOSITE -> MD_CLEANUP [label="  Blended" color="#66cc66"];
    }

    subgraph cluster_merge_selected {
        label="MERGE SELECTED" labelloc=t labeljust=l
        fontcolor=white fontsize=11.0 fontname="Cascadia Code PL"
        color=orange style=dashed penwidth=1

        MS_TRIGGER [label="Trigger\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nLayer в†’ Merge Selected\nMerges multi-selected\nlayers into one"];
        MS_GUARD [label="Guard\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nMultiple layers selected\nin multi-select mode"];
        MS_COMPOSITE [label="Composite All\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nBottom-up composite\nof all selected layers\nRespect blend modes\nSnap history for each"];
        MS_CLEANUP [label="Remove Merged\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nDelete all selected\nexcept bottom-most\nResult in bottom slot\nReindex z-order"];

        MS_TRIGGER -> MS_GUARD [label="  Execute" color="#cccc66"];
        MS_GUARD -> MS_COMPOSITE [label="  в‰Ґ 2 selected" color="#cccc66"];
        MS_COMPOSITE -> MS_CLEANUP [label="  Composited" color="#66cc66"];
    }

    subgraph cluster_merge_all {
        label="MERGE ALL (FLATTEN)" labelloc=t labeljust=l
        fontcolor=white fontsize=11.0 fontname="Cascadia Code PL"
        color=orange style=dashed penwidth=1

        MA_TRIGGER [label="Trigger\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nLayer в†’ Merge All\nor Layer в†’ Flatten\nAll layers в†’ one"];
        MA_SNAPSHOT [label="Snapshot All\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nHistory group begin\nSnapshot every layer\nStore all properties"];
        MA_FLATTEN [label="Flatten\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nBottom-up composite\nAll 64 possible layers\ninto single result\nFull alpha blend"];
        MA_CLEANUP [label="Single Layer\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nFree all layer handles\nexcept result\nResult in slot 1\nz=0, name=\"Background\"\nCURRENT_LAYER%=1"];

        MA_TRIGGER -> MA_SNAPSHOT [label="  Execute" color="#cccc66"];
        MA_SNAPSHOT -> MA_FLATTEN [label="  All saved" color="#cccc66"];
        MA_FLATTEN -> MA_CLEANUP [label="  Composited" color="#66cc66"];
    }

    S_IDLE -> MD_TRIGGER [label="  Merge Down" color="#cccc66"];
    S_IDLE -> MS_TRIGGER [label="  Merge Selected" color="#cccc66"];
    S_IDLE -> MA_TRIGGER [label="  Merge All" color="#cccc66"];

    subgraph cluster_post {
        label="POST-MERGE STATE" labelloc=t labeljust=l
        fontcolor=white fontsize=11.0 fontname="Cascadia Code PL"
        color=orange style=dashed penwidth=1

        P1 [label="Invalidation\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nSCENE_DIRTY = TRUE\nCANVAS_DIRTY = TRUE\nRENDER_ORDER_DIRTY = TRUE\nBLEND invalidate cache\nAll caches reset"];
    }

    subgraph cluster_legend {
        label="LEGEND" labelloc=t labeljust=l
        fontcolor=white fontsize=11.0 fontname="Cascadia Code PL"
        color=white style=dashed penwidth=1
        L1 [label="" shape=point width=0.01]; L2 [label="" shape=point width=0.01];
        L3 [label="" shape=point width=0.01]; L4 [label="" shape=point width=0.01];
        L5 [label="" shape=point width=0.01]; L6 [label="" shape=point width=0.01];
        L1 -> L2 [label=" Create / Composite" arrowhead=normal color="#66cc66" fontsize=9.0];
        L3 -> L4 [label=" Delete / Abort" arrowhead=normal color="#cc6666" style=dashed fontsize=9.0];
        L5 -> L6 [label=" Step / Record" arrowhead=normal color="#cccc66" fontsize=9.0];
    }
}
