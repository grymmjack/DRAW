digraph LAYER_MULTISELECT {
    label="LAYER MULTI-SELECT STATE MACHINE" labelloc=t labeljust=c
    ordering=out rankdir=TB
    fontcolor=white fontsize=24.0 fontname="Cascadia Code PL"
    splines=true compound=true
    bgcolor=transparent
    edge [
        color=gray fontcolor="#aaaaaa" fontsize=9.0
        fontname="Cascadia Code PL"
    ];
    node [
        color=white shape=rect style=""
        fontname="Cascadia Code PL" fontsize=11.0 fontcolor=cyan
    ];

    { node [shape=folder color=orange penwidth=2 fontcolor=orange fontsize=13.0];
        MAIN [label="LAYER\nMULTI-SELECT"];
    }

    S_SINGLE [label="1 В· SINGLE SELECT\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nCURRENT_LAYER% = active\nOnly one layer selected\nNormal painting mode"];
    S_MULTI [label="2 В· MULTI-SELECT\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nMultiple layers selected\nHighlighted in panel\nOperations apply to\nall selected layers"];
    S_RANGE [label="3 В· RANGE SELECT\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nShift+Click selects\ncontiguous range from\nanchor to clicked layer"];

    S_SINGLE -> S_MULTI [label="  Ctrl+Click another\n  layer in panel\n  Add to selection" color="#66cc66"];
    S_SINGLE -> S_RANGE [label="  Shift+Click layer\n  Select range from\n  current to clicked" color="#66cc66"];
    S_MULTI -> S_MULTI [label="  Ctrl+Click: toggle\n  layer in selection\n  Add/remove individual" color="#88aacc"];
    S_MULTI -> S_SINGLE [label="  Click layer without\n  Ctrl modifier\n  Deselect all others" color="#cc6666" style=dashed];
    S_RANGE -> S_SINGLE [label="  Click without Shift\n  Deselect range" color="#cc6666" style=dashed];
    S_RANGE -> S_MULTI [label="  Ctrl+Click\n  Switch to individual\n  multi-select" color="#6699ff"];

    MAIN -> S_SINGLE [arrowhead=none color="#555555" style=dotted];
    { rank=min; MAIN }

    subgraph cluster_operations {
        label="MULTI-SELECT OPERATIONS" labelloc=t labeljust=l
        fontcolor=white fontsize=11.0 fontname="Cascadia Code PL"
        color=orange style=dashed penwidth=1

        OP_MERGE [label="Merge Selected\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nLayer в†’ Merge Selected\nComposite all selected\ninto bottom-most layer"];
        OP_DELETE [label="Delete Selected\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nDelete all selected\nlayers (keep в‰Ґ 1)"];
        OP_VISIBLE [label="Toggle Visibility\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nShow/hide all\nselected layers"];
        OP_LOCK [label="Toggle Lock\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nLock/unlock all\nselected layers"];
        OP_ALIGN [label="Align / Distribute\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nAlign or distribute\nall selected layers\n(see ALIGN-DISTRIBUTE)"];
    }

    subgraph cluster_solo {
        label="SOLO MODE" labelloc=t labeljust=l
        fontcolor=white fontsize=11.0 fontname="Cascadia Code PL"
        color=orange style=dashed penwidth=1

        SOLO_OFF [label="Solo OFF\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nsoloLayer = -1\nAll layers show\nnormal visibility"];
        SOLO_ON [label="Solo ON\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nsoloLayer = layerIdx\nAll other layers hidden\nsavedVisibility() stored\nAlt+Click eye icon"];

        SOLO_OFF -> SOLO_ON [label="  Alt+Click eye\n  Solo this layer" color="#66cc66"];
        SOLO_ON -> SOLO_OFF [label="  Alt+Click same eye\n  or click any eye\n  Restore visibility" color="#cc6666" style=dashed];
    }

    subgraph cluster_vis_swipe {
        label="VISIBILITY SWIPE" labelloc=t labeljust=l
        fontcolor=white fontsize=11.0 fontname="Cascadia Code PL"
        color=orange style=dashed penwidth=1

        VS_IDLE [label="Idle\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nvisSwiping = FALSE\nNormal click toggles\nsingle layer visibility"];
        VS_ACTIVE [label="Swiping\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nvisSwiping = TRUE\nDrag over eye icons\nvisSwipeAction = on/off\nAll swiped layers toggled"];

        VS_IDLE -> VS_ACTIVE [label="  Click+drag over\n  multiple eye icons" color="#66cc66"];
        VS_ACTIVE -> VS_IDLE [label="  Mouse release\n  Swipe complete" color="#cc6666" style=dashed];
    }

    subgraph cluster_legend {
        label="LEGEND" labelloc=t labeljust=l
        fontcolor=white fontsize=11.0 fontname="Cascadia Code PL"
        color=white style=dashed penwidth=1
        L1 [label="" shape=point width=0.01]; L2 [label="" shape=point width=0.01];
        L3 [label="" shape=point width=0.01]; L4 [label="" shape=point width=0.01];
        L5 [label="" shape=point width=0.01]; L6 [label="" shape=point width=0.01];
        L7 [label="" shape=point width=0.01]; L8 [label="" shape=point width=0.01];
        L1 -> L2 [label=" Select / Activate" arrowhead=normal color="#66cc66" fontsize=9.0];
        L3 -> L4 [label=" Deselect" arrowhead=normal color="#cc6666" style=dashed fontsize=9.0];
        L5 -> L6 [label=" Mode switch" arrowhead=normal color="#6699ff" fontsize=9.0];
        L7 -> L8 [label=" Self-transition" arrowhead=normal color="#88aacc" fontsize=9.0];
    }
}
