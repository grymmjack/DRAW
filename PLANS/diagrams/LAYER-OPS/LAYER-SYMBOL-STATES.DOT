digraph LAYER_SYMBOL {
    label="LAYER SYMBOL STATE MACHINE" labelloc=t labeljust=c
    ordering=out rankdir=TB
    fontcolor=white fontsize=24.0 fontname="Cascadia Code PL"
    splines=true compound=true
    bgcolor=transparent
    edge [color=gray fontcolor="#aaaaaa" fontsize=9.0 fontname="Cascadia Code PL"];
    node [color=white shape=rect style="" fontname="Cascadia Code PL" fontsize=11.0 fontcolor=cyan];

    { node [shape=folder color=orange penwidth=2 fontcolor=orange fontsize=13.0];
        MAIN [label="SYMBOL LAYER LIFECYCLE"];
    }

    S_NORMAL [label="1 · NORMAL LAYER\n─────────────────\nLAYER_TYPE_RASTER\nNo symbol relationship\nStandard pixel layer"];
    S_PARENT [label="2 · SYMBOL PARENT\n─────────────────\nLAYER_TYPE_SYMBOL_PARENT\nSource of truth\nEdits propagate to children"];
    S_CHILD [label="3 · SYMBOL CHILD\n─────────────────\nLAYER_TYPE_SYMBOL_CHILD\nsymbolParentIdx points\nto parent layer\nAuto-syncs on parent edit"];
    S_DETACHED [label="4 · DETACHED\n─────────────────\nChild → Normal\nLink severed\nIndependent edits allowed"];
    S_RASTERIZED [label="5 · RASTERIZED\n─────────────────\nParent or child flattened\nSymbol bond broken\nPure raster layer"];

    S_NORMAL -> S_PARENT [label="  Convert to Symbol Parent\n  (Layer menu / context)" color="#66cc66"];
    S_PARENT -> S_CHILD [label="  Place Instance\n  Creates child layer\n  symbolParentIdx set" color="#66cc66"];
    S_CHILD -> S_DETACHED [label="  Detach Symbol\n  Type → RASTER\n  symbolParentIdx = -1" color="#cccc66"];
    S_DETACHED -> S_NORMAL [label="  (immediate)" color="#cc6666" style=dashed];
    S_PARENT -> S_RASTERIZED [label="  Rasterize parent\n  All children detached" color="#cccc66"];
    S_CHILD -> S_RASTERIZED [label="  Rasterize child\n  Bake current sync state" color="#cccc66"];
    S_RASTERIZED -> S_NORMAL [label="  (immediate)" color="#cc6666" style=dashed];

    subgraph cluster_sync {
        label="SYNC PROPAGATION" labelloc=t labeljust=l
        fontcolor=orange fontsize=11.0 color=orange style=dashed penwidth=1

        SY1 [label="Parent Edit Detected\n────────────\ncontentDirty% = TRUE\non parent layer" fontsize=10.0];
        SY2 [label="Find Children\n────────────\nScan layers for\nsymbolParentIdx == parent\nBuild child list" fontsize=10.0];
        SY3 [label="Replicate Pixels\n────────────\nCopy parent image\nApply child transforms\n(scale, position)" fontsize=10.0];
        SY4 [label="Mark Children Dirty\n────────────\nEach child\ncontentDirty% = TRUE\nBLEND_invalidate_cache" fontsize=10.0];

        SY1 -> SY2 -> SY3 -> SY4 [color="#88aacc" fontsize=8.0];
    }

    subgraph cluster_ops {
        label="ALLOWED OPERATIONS" labelloc=t labeljust=l
        fontcolor=orange fontsize=11.0 color=orange style=dashed penwidth=1

        O_PARENT [label="On Parent\n────────────\nDraw, paint, transform\nAll children update" fontsize=10.0];
        O_CHILD_OK [label="Child: Position/Scale\n────────────\nMove tool, transform\nIndependent of parent" fontsize=10.0];
        O_CHILD_NO [label="Child: Paint Locked\n────────────\nDirect pixel edits\nblocked or warned\nMust detach to paint" fontsize=10.0];
    }

    MAIN -> S_NORMAL [arrowhead=none color="#555555" style=dotted];
    { rank=min; MAIN }

    subgraph cluster_legend {
        label="LEGEND" labelloc=t labeljust=l
        fontcolor=white fontsize=11.0 color=white style=dashed penwidth=1
        L1 [label="" shape=point width=0.01]; L2 [label="" shape=point width=0.01];
        L3 [label="" shape=point width=0.01]; L4 [label="" shape=point width=0.01];
        L5 [label="" shape=point width=0.01]; L6 [label="" shape=point width=0.01];
        L1 -> L2 [label=" Convert" arrowhead=normal color="#66cc66" fontsize=9.0];
        L3 -> L4 [label=" Reset" arrowhead=normal color="#cc6666" style=dashed fontsize=9.0];
        L5 -> L6 [label=" Transition" arrowhead=normal color="#cccc66" fontsize=9.0];
    }
}
