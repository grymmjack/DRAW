digraph LAYER_ALIGN_DIST {
    label="LAYER ALIGN / DISTRIBUTE STATE MACHINE" labelloc=t labeljust=c
    ordering=out rankdir=TB
    fontcolor=white fontsize=24.0 fontname="Cascadia Code PL"
    splines=true compound=true
    bgcolor=transparent
    edge [
        color=gray fontcolor="#aaaaaa" fontsize=9.0
        fontname="Cascadia Code PL"
    ];
    node [
        color=white shape=rect style=""
        fontname="Cascadia Code PL" fontsize=11.0 fontcolor=cyan
    ];

    { node [shape=folder color=orange penwidth=2 fontcolor=orange fontsize=13.0];
        MAIN [label="LAYER ALIGN\n& DISTRIBUTE"];
    }

    S_IDLE [label="1 · IDLE\n─────────────────\nLayers positioned\nat their current\noffsets (if moved)\nCURRENT_LAYER% set"];

    MAIN -> S_IDLE [arrowhead=none color="#555555" style=dotted];
    { rank=min; MAIN }

    subgraph cluster_align {
        label="ALIGN OPERATIONS" labelloc=t labeljust=l
        fontcolor=white fontsize=11.0 fontname="Cascadia Code PL"
        color=orange style=dashed penwidth=1

        AL [label="Align Left\n─────────────────\nAll selected layers\naligned to left edge\nof canvas (x=0)"];
        AC [label="Align Center\n─────────────────\nAll selected layers\ncentered horizontally\non canvas"];
        AR [label="Align Right\n─────────────────\nAll selected layers\naligned to right edge\nof canvas"];
        AT [label="Align Top\n─────────────────\nAll selected layers\naligned to top edge\nof canvas (y=0)"];
        AM [label="Align Middle\n─────────────────\nAll selected layers\ncentered vertically\non canvas"];
        AB [label="Align Bottom\n─────────────────\nAll selected layers\naligned to bottom\nedge of canvas"];
    }

    subgraph cluster_distribute {
        label="DISTRIBUTE OPERATIONS" labelloc=t labeljust=l
        fontcolor=white fontsize=11.0 fontname="Cascadia Code PL"
        color=orange style=dashed penwidth=1

        DH [label="Distribute Horizontal\n─────────────────\nEvenly space selected\nlayers horizontally\nEqual gaps between\nbounding boxes"];
        DV [label="Distribute Vertical\n─────────────────\nEvenly space selected\nlayers vertically\nEqual gaps between\nbounding boxes"];
    }

    subgraph cluster_execution {
        label="EXECUTION FLOW" labelloc=t labeljust=l
        fontcolor=white fontsize=11.0 fontname="Cascadia Code PL"
        color=orange style=dashed penwidth=1

        E1 [label="1. Snapshot\n─────────────────\nSave current position\nof each affected layer\nHISTORY group begin"];
        E2 [label="2. Compute\n─────────────────\nCalculate target\npositions based on\nalignment/distribution\ncanvas bounds"];
        E3 [label="3. Apply\n─────────────────\nMove layer content\nto computed positions\nUpdate layer offsets"];
        E4 [label="4. Record\n─────────────────\nHISTORY group end\nSCENE_DIRTY = TRUE\nBLEND_invalidate_cache"];

        E1 -> E2 [label="  Saved" color="#cccc66"];
        E2 -> E3 [label="  Computed" color="#cccc66"];
        E3 -> E4 [label="  Applied" color="#cccc66"];
    }

    S_IDLE -> AL [label="  Align Left" color="#6699ff"];
    S_IDLE -> AC [label="  Align Center" color="#6699ff"];
    S_IDLE -> AR [label="  Align Right" color="#6699ff"];
    S_IDLE -> AT [label="  Align Top" color="#6699ff"];
    S_IDLE -> AM [label="  Align Middle" color="#6699ff"];
    S_IDLE -> AB [label="  Align Bottom" color="#6699ff"];
    S_IDLE -> DH [label="  Distribute H" color="#cc66cc"];
    S_IDLE -> DV [label="  Distribute V" color="#cc66cc"];

    subgraph cluster_multisel {
        label="MULTI-SELECT REQUIREMENT" labelloc=t labeljust=l
        fontcolor=white fontsize=11.0 fontname="Cascadia Code PL"
        color=orange style=dashed penwidth=1

        M1 [label="Multi-Select Active\n─────────────────\nCtrl+Click layers\nto select multiple\nAlign/Distribute needs\n≥ 2 selected layers\nto be meaningful"];
    }

    subgraph cluster_legend {
        label="LEGEND" labelloc=t labeljust=l
        fontcolor=white fontsize=11.0 fontname="Cascadia Code PL"
        color=white style=dashed penwidth=1
        L1 [label="" shape=point width=0.01]; L2 [label="" shape=point width=0.01];
        L3 [label="" shape=point width=0.01]; L4 [label="" shape=point width=0.01];
        L5 [label="" shape=point width=0.01]; L6 [label="" shape=point width=0.01];
        L1 -> L2 [label=" Align operation" arrowhead=normal color="#6699ff" fontsize=9.0];
        L3 -> L4 [label=" Distribute operation" arrowhead=normal color="#cc66cc" fontsize=9.0];
        L5 -> L6 [label=" Step / Record" arrowhead=normal color="#cccc66" fontsize=9.0];
    }
}
