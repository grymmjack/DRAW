digraph LAYER_ADD_DELETE {
    label="LAYER ADD / DUPLICATE / DELETE STATE MACHINE" labelloc=t labeljust=c
    ordering=out rankdir=TB
    fontcolor=white fontsize=24.0 fontname="Cascadia Code PL"
    splines=true compound=true
    bgcolor=transparent
    edge [
        color=gray fontcolor="#aaaaaa" fontsize=9.0
        fontname="Cascadia Code PL"
    ];
    node [
        color=white shape=rect style=""
        fontname="Cascadia Code PL" fontsize=11.0 fontcolor=cyan
    ];

    { node [shape=folder color=orange penwidth=2 fontcolor=orange fontsize=13.0];
        MAIN [label="LAYER\nADD / DELETE"];
    }

    S_IDLE [label="1 В· IDLE\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nCURRENT_LAYER% = active\nLAYERS(1..64) available\nLayer panel showing"];

    MAIN -> S_IDLE [arrowhead=none color="#555555" style=dotted];
    { rank=min; MAIN }

    subgraph cluster_add {
        label="ADD NEW LAYER" labelloc=t labeljust=l
        fontcolor=white fontsize=11.0 fontname="Cascadia Code PL"
        color=orange style=dashed penwidth=1

        ADD_TRIGGER [label="Trigger\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nClick + button\nor Layer в†’ New Layer\nor Ctrl+Shift+N"];
        ADD_ALLOC [label="Allocate\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nFind free slot in\nLAYERS(1..64)\nCreate _NEWIMAGE\nSet defaults:\nвЂў name = \"Layer N\"\nвЂў visible = TRUE\nвЂў opacity = 255\nвЂў blendMode = Normal"];
        ADD_REORDER [label="Z-Order Update\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nInsert above current\nShift zIndex for\nlayers above\nRENDER_ORDER_DIRTY=TRUE"];
        ADD_HISTORY [label="History Record\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nHISTORY_record\n  kind = LAYER_ADD\n  primaryLayerId\n  img = snapshot"];
        ADD_DONE [label="Complete\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nCURRENT_LAYER%=new\nSCENE_DIRTY=TRUE\nCANVAS_DIRTY=TRUE"];

        ADD_TRIGGER -> ADD_ALLOC [label="  Execute" color="#66cc66"];
        ADD_ALLOC -> ADD_REORDER [label="  Slot found" color="#66cc66"];
        ADD_REORDER -> ADD_HISTORY [label="  Order updated" color="#cccc66"];
        ADD_HISTORY -> ADD_DONE [label="  Saved" color="#cccc66"];
    }

    subgraph cluster_duplicate {
        label="DUPLICATE LAYER" labelloc=t labeljust=l
        fontcolor=white fontsize=11.0 fontname="Cascadia Code PL"
        color=orange style=dashed penwidth=1

        DUP_TRIGGER [label="Trigger\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nLayer в†’ Duplicate\nor Ctrl+J"];
        DUP_COPY [label="Copy Pixels\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\n_COPYIMAGE of source\nCopy all properties:\nname, opacity, blend\nvisible, locked"];
        DUP_INSERT [label="Insert Above\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nNew layer inserted\nabove source layer\nzIndex = source + 1\nShift layers above"];
        DUP_DONE [label="Complete\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nCURRENT_LAYER%=copy\nHISTORY_record LAYER_ADD\nSCENE_DIRTY=TRUE"];

        DUP_TRIGGER -> DUP_COPY [label="  Execute" color="#66cc66"];
        DUP_COPY -> DUP_INSERT [label="  Pixels copied" color="#66cc66"];
        DUP_INSERT -> DUP_DONE [label="  Inserted" color="#cccc66"];
    }

    subgraph cluster_delete {
        label="DELETE LAYER" labelloc=t labeljust=l
        fontcolor=white fontsize=11.0 fontname="Cascadia Code PL"
        color=orange style=dashed penwidth=1

        DEL_TRIGGER [label="Trigger\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nClick trash button\nor Layer в†’ Delete\nor hotkey"];
        DEL_CHECK [label="Guard Check\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nMust have > 1 layer\nCannot delete last\nremaining layer"];
        DEL_SNAPSHOT [label="Snapshot\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nHISTORY_record\n  kind = LAYER_DELETE\n  img = _COPYIMAGE\n  Store properties"];
        DEL_FREE [label="Free Resources\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\n_FREEIMAGE imgHandle&\nClear layer slot\nRENDER_ORDER_DIRTY=TRUE"];
        DEL_REINDEX [label="Reindex\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nShift zIndex values\nfor layers above\nSelect next valid layer\nCURRENT_LAYER% updated"];
        DEL_DONE [label="Complete\nв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\nSCENE_DIRTY=TRUE\nCANVAS_DIRTY=TRUE\nBLEND_invalidate_cache"];

        DEL_TRIGGER -> DEL_CHECK [label="  Execute" color="#cc6666" style=dashed];
        DEL_CHECK -> DEL_SNAPSHOT [label="  > 1 layer" color="#cccc66"];
        DEL_CHECK -> DEL_TRIGGER [label="  Only 1 layer\n  Abort" color="#cc6666" style=dashed];
        DEL_SNAPSHOT -> DEL_FREE [label="  Saved" color="#cc6666" style=dashed];
        DEL_FREE -> DEL_REINDEX [label="  Freed" color="#cc6666" style=dashed];
        DEL_REINDEX -> DEL_DONE [label="  Done" color="#cccc66"];
    }

    S_IDLE -> ADD_TRIGGER [label="  Add new layer\n  command" color="#66cc66"];
    S_IDLE -> DUP_TRIGGER [label="  Duplicate layer\n  command" color="#66cc66"];
    S_IDLE -> DEL_TRIGGER [label="  Delete layer\n  command" color="#cc6666" style=dashed];

    subgraph cluster_legend {
        label="LEGEND" labelloc=t labeljust=l
        fontcolor=white fontsize=11.0 fontname="Cascadia Code PL"
        color=white style=dashed penwidth=1
        L1 [label="" shape=point width=0.01]; L2 [label="" shape=point width=0.01];
        L3 [label="" shape=point width=0.01]; L4 [label="" shape=point width=0.01];
        L5 [label="" shape=point width=0.01]; L6 [label="" shape=point width=0.01];
        L1 -> L2 [label=" Create / Activate" arrowhead=normal color="#66cc66" fontsize=9.0];
        L3 -> L4 [label=" Delete / Remove" arrowhead=normal color="#cc6666" style=dashed fontsize=9.0];
        L5 -> L6 [label=" Commit / Record" arrowhead=normal color="#cccc66" fontsize=9.0];
    }
}
