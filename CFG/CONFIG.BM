                    CASE "SMART_GUIDES_COLOR_FG"
                        IF LEN(configValue$) = 6 THEN
                            CFG.SMART_GUIDES_COLOR_FG~& = _RGB32(VAL("&H" + LEFT$(configValue$, 2)), VAL("&H" + MID$(configValue$, 3, 2)), VAL("&H" + RIGHT$(configValue$, 2)))
                        END IF
