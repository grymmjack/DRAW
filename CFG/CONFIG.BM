                        IF CFG.PIXEL_ANALYZER_CONFIDENCE% > 90 THEN CFG.PIXEL_ANALYZER_CONFIDENCE% = 90
                    CASE "EDIT_BAR_VISIBLE"
                        CFG.EDIT_BAR_VISIBLE% = VAL(configValue$)
                    CASE "EDIT_BAR_DOCK_POSITION"
                        CFG.EDIT_BAR_DOCK_POSITION$ = UCASE$(_TRIM$(configValue$))
                    CASE "ADV_BAR_VISIBLE"
                        CFG.ADV_BAR_VISIBLE% = VAL(configValue$)
                    CASE "ADV_BAR_DOCK_POSITION"
                        CFG.ADV_BAR_DOCK_POSITION$ = UCASE$(_TRIM$(configValue$))
                    CASE "CHARMAP_VISIBLE"
                        CFG.CHARMAP_VISIBLE% = VAL(configValue$)
                    CASE "CHARMAP_PANEL_DOCK_EDGE"
