' =============================================================================
' Configuration file I/O functions.
'
' @author Rick Christy <grymmjack@gmail.com>
'
$INCLUDEONCE

''
' Set default configuration values
' 
SUB CONFIG_set_defaults ()
    ' Default to windowed mode with auto-detected scale
    CFG.FULLSCREEN%                     = FALSE
    CFG.DISPLAY_SCALE%                  = 0                                               ' 0 = auto-detect from desktop resolution
    CFG.DISPLAY_SCALE_MAX%              = 8                                               ' Maximum allowed scale multiplier
    CFG.DISPLAY_SCALE_CHANGED%          = FALSE                                           ' Runtime flag, not persisted
    CFG.THEME$                          = "DEFAULT"
    CFG.TOOLBAR_SCALE%                  = 0                                               ' Toolbar icon scale (0=auto, 1-4 explicit)
    CFG.NUDGE_N%                        = 10
    CFG.NUM_LAYERS%                     = 1
    CFG.NUM_CUSTOM_BRUSHES%             = 4
    CFG.FPS_LIMIT%                      = 60
    CFG.FPS_IDLE%                       = 30
    CFG.FPS_CURSOR%                     = 240
    CFG.FPS_DIALOG%                     = 60
    CFG.SCREEN_WIDTH%                   = 0                                               ' 0 = auto-detect desktop resolution
    CFG.SCREEN_HEIGHT%                  = 0                                               ' 0 = auto-detect desktop resolution
    CFG.WIN_MIN_WIDTH%                  = 320                                             ' Minimum viewport width
    CFG.WIN_MIN_HEIGHT%                 = 200                                             ' Minimum viewport height
    CFG.WIN_MAX_WIDTH%                  = 0                                               ' 0 = unlimited (auto from desktop)
    CFG.WIN_MAX_HEIGHT%                 = 0                                               ' 0 = unlimited (auto from desktop)
    CFG.DEFAULT_PALETTE$                = "ANSI32 (32)"                                   ' Empty = use default palette
    CFG.PALETTE_CHIP_WIDTH%             = 16                                              ' Width of each color chip
    CFG.PALETTE_CHIP_HEIGHT%            = 8                                               ' Height of each color chip
    CFG.PALETTE_MAX_CHIPS_PER_ROW%      = 32                                              ' Maximum chips per row
    CFG.PALETTE_MAX_ROWS%               = 3                                               ' Maximum rows to display
    CFG.PALETTE_MIN_ROWS%               = 1                                               ' Minimum rows to always show
    CFG.PALETTE_CHIPS_ROW_THRESHOLD%    = 16                                              ' Create new row every N chips
    CFG.PALETTE_DEFAULT_BG_TRANSPARENT% = TRUE                                            ' Default BG is transparent
    CFG.PALETTE_PICKER_CHIP_SIZE%       = 10                                              ' Chip size in palette picker dialog (8-48)
    CFG.PALETTE_PICKER_CHIP_PADDING%    = 2                                               ' Padding between chips in palette picker (1-16)
    CFG.PALETTE_PICKER_COLUMNS%         = 32                                              ' Number of columns in palette picker (8-64)
    CFG.ANGLE_SNAP_DEGREES%             = 45                                              ' Angle snap increment for Ctrl+Shift line drawing (15/30/45/90)
    CFG.ANGLE_SNAP_PIXEL_ART%           = FALSE                                           ' Pixel art angle snap mode (integer slope ratios)
    ' Layer panel settings
    CFG.NUM_LAYERS%            = 64                                                       ' Max layer slots (1-64)
    CFG.LAYER_PANEL_WIDTH%     = 150                                                      ' Layer panel width in pixels (min 40)
    CFG.LAYER_NAME_MAX_LEN%    = 20                                                       ' Max layer name length (1-64)
    CFG.LAYER_GROUP_INDENT%    = 0                                                        ' Per-level indent for nested groups (0=use theme default)
    CFG.LAYERS_PANEL_DOCK_EDGE = "RIGHT"                                                  ' Layer panel docks on right by default
    CFG.TOOLBOX_DOCK_EDGE      = "LEFT"                                                   ' Toolbox stack docks on left by default
    ' Grid settings (0 = use theme defaults, except size which needs a safe default)
    CFG.GRID_COLOR_FG~& = 0                                                               ' 0 = use theme default
    CFG.GRID_OPACITY%   = 0                                                               ' 0 = use theme default
    CFG.GRID_SIZE_X%    = 10                                                              ' Default grid cell width (must be >0; theme may not be loaded yet)
    CFG.GRID_SIZE_Y%    = 10                                                              ' Default grid cell height (must be >0; theme may not be loaded yet)
    ' Crosshair settings (0 = use theme defaults)
    CFG.CROSSHAIR_FG~&               = 0                                                  ' 0 = use theme default
    CFG.CROSSHAIR_OPACITY%           = 0                                                  ' 0 = use theme default
    CFG.CROSSHAIR_FONT$              = ""
    CFG.CROSSHAIR_FONT_SIZE%         = CONFIG_USE_THEME_DEFAULT%
    CFG.CROSSHAIR_FONT_FG~&          = 0                                                  ' 0 = use theme default
    CFG.CROSSHAIR_FONT_STROKE_FG~&   = 0
    CFG.CROSSHAIR_FONT_STROKE_WIDTH% = CONFIG_USE_THEME_DEFAULT%
    CFG.CROSSHAIR_ANGLE!             = 0                                                  ' 0 = use theme default
    CFG.CROSSHAIR_FONT_OFFSET_X%     = CONFIG_USE_THEME_DEFAULT%                          ' offset from cursor
    CFG.CROSSHAIR_FONT_OFFSET_Y%     = CONFIG_USE_THEME_DEFAULT%
    CFG.CROSSHAIR_OUTLINE_FG~&       = 0                                                  ' 0 = use theme default
    CFG.CROSSHAIR_OUTLINE_OPACITY%   = 0                                                  ' 0 = use theme default
    CFG.CROSSHAIR_OUTLINE_WIDTH%     = CONFIG_USE_THEME_DEFAULT%
    ' Picker loupe settings (DRAW.cfg overrides theme when set)
    CFG.PICKER_LOUPE_ZOOM_LEVEL%          = CONFIG_USE_THEME_DEFAULT%
    CFG.PICKER_LOUPE_RECT_X_OFFSET%       = CONFIG_USE_THEME_DEFAULT%
    CFG.PICKER_LOUPE_RECT_Y_OFFSET%       = CONFIG_USE_THEME_DEFAULT%
    CFG.PICKER_LOUPE_RECT_WIDTH%          = CONFIG_USE_THEME_DEFAULT%
    CFG.PICKER_LOUPE_RECT_HEIGHT%         = CONFIG_USE_THEME_DEFAULT%
    CFG.PICKER_LOUPE_RGBA_X%              = CONFIG_USE_THEME_DEFAULT%
    CFG.PICKER_LOUPE_RGBA_Y%              = CONFIG_USE_THEME_DEFAULT%
    CFG.PICKER_LOUPE_FONT$                = ""
    CFG.PICKER_LOUPE_FONT_SIZE%           = CONFIG_USE_THEME_DEFAULT%
    CFG.PICKER_LOUPE_FONT_FG~&            = 0
    CFG.PICKER_LOUPE_FONT_BG~&            = 0
    CFG.PICKER_LOUPE_FONT_STROKE_FG~&     = 0
    CFG.PICKER_LOUPE_FONT_STROKE_WIDTH%   = CONFIG_USE_THEME_DEFAULT%
    CFG.PICKER_LOUPE_RECT_STROKE_FG~&     = 0
    CFG.PICKER_LOUPE_RECT_STROKE_WIDTH%   = CONFIG_USE_THEME_DEFAULT%
    CFG.PICKER_LOUPE_PIXEL_PICKUP_COLOR~& = 0
    ' Grid geometry mode (0=square default)
    CFG.GRID_MODE%      = 0                                                               ' 0 = square
    CFG.GRID_CELL_FILL% = 0                                                               ' 0 = off (normal flood fill)
    CFG.GRID_ON_TOP%    = TRUE                                                            ' Grid renders on top of art by default
    ' Grid angle (0 = use theme default)
    CFG.GRID_ANGLE! = 0                                                                   ' 0 = use theme default
    ' Pixel grid settings (0 = use theme defaults)
    CFG.PIXELGRID_COLOR_FG~& = 0                                                          ' 0 = use theme default
    CFG.PIXELGRID_OPACITY%   = 0                                                          ' 0 = use theme default
    ' Transparency checkerboard settings
    CFG.TRANSPARENCY_CHECK_COLOR1~& = _RGB32(112, 112, 112)                               ' Medium gray
    CFG.TRANSPARENCY_CHECK_COLOR2~& = _RGB32(76, 76, 76)                                  ' Dark gray
    CFG.TRANSPARENCY_CHECK_SIZE_X%  = 4                                                   ' Checkerboard square width
    CFG.TRANSPARENCY_CHECK_SIZE_Y%  = 4                                                   ' Checkerboard square height
    ' Scrollbar settings
    CFG.SCROLLBAR_BG~&        = 0                                                         ' 0 = default (dark gray)
    CFG.SCROLLBAR_HANDLE_FG~& = 0                                                         ' 0 = default (light gray)
    CFG.SCROLLBAR_OPACITY%    = 0                                                         ' 0 = default (180)
    ' Sound / music settings
    CFG.SOUNDS_ENABLED%         = FALSE                                                   ' Sounds on by default
    CFG.SYSTEM_CURSORS_ENABLED% = TRUE                                                    ' Use OS system cursors for resize/hand/text/move by default
    CFG.TOOLTIP_HOVER_DELAY_MS% = 500                                                     ' Show tooltip after 500ms hover
    CFG.TOOLTIPS_DISABLED%      = FALSE                                                   ' Tooltips enabled by default
    CFG.SOUNDS_VOLUME%          = 10                                                      ' 10% volume default
    CFG.SOUNDS_MUTED%           = FALSE                                                   ' SFX not muted by default
    CFG.MUSIC_ENABLED%          = FALSE                                                   ' Music on by default
    CFG.MUSIC_VOLUME%           = 10                                                      ' 10% music volume default
    CFG.MUSIC_MUTED%            = FALSE                                                   ' Music not muted by default
    ' Default startup settings
    CFG.DEFAULT_TOOL%            = 1                                                      ' Default to brush tool (TOOL_BRUSH = 1)
    CFG.DEFAULT_BRUSH_SIZE%      = 1                                                      ' Default brush size index 1 = 1px
    CFG.DEFAULT_BRUSH_SHAPE%     = 1                                                      ' Default brush shape 1=square (0=circle)
    CFG.DEFAULT_DRAW_MODE%       = 1                                                      ' Default to color/brush painting mode
    CFG.DEFAULT_BIN_MODE%        = 1                                                      ' Default visible bins panel = brush bins
    CFG.DEFAULT_LAYER_BG_COLOR~& = _RGBA32(0, 0, 0, 255)                                  ' Opaque black by default
    CFG.BAS_EXPORT_BG_COLOR~&    = _RGBA32(0, 0, 0, 255)                                  ' High-visibility magenta export background
    CFG.BAS_WIP_ENABLED%         = FALSE                                                  ' Live WIP BAS stream disabled by default
    CFG.DEFAULT_SAVE_DIR$        = ""                                                     ' Empty = use current directory
    CFG.DEFAULT_OPEN_DIR$        = ""                                                     ' Empty = use current directory
    ' Per-operation last dirs (empty = use DEFAULT_OPEN_DIR/DEFAULT_SAVE_DIR as fallback)
    CFG.LAST_DIR_OPEN$         = ""
    CFG.LAST_DIR_SAVE$         = ""
    CFG.LAST_DIR_IMPORT$       = ""
    CFG.LAST_DIR_EXPORT_BRUSH$ = ""
    CFG.LAST_DIR_EXPORT_LAYER$ = ""
    CFG.LAST_DIR_EXTRACT$      = ""
    CFG.LAST_DIR_PALETTE$      = ""
    CFG.TEMPLATE_DIR$          = "ASSETS/TEMPLATES"                                       ' Empty = use current directory for templates
    ' User palette visibility settings
    CFG.PALETTE_SHOW_LOSPEC%       = TRUE                                                 ' Show Lospec palettes in picker by default
    CFG.PALETTE_SHOW_CREATED%      = TRUE                                                 ' Show Created palettes in picker by default
    CFG.PALETTE_CREATE_MAX_COLORS% = 32                                                   ' Default max colors for Create from Image
    ' Preview Window settings
    CFG.PREVIEW_VISIBLE%           = TRUE                                                 ' Preview window visible by default
    CFG.PREVIEW_X%                 = -1                                                   ' -1 = auto-position on first open
    CFG.PREVIEW_Y%                 = -1                                                   ' -1 = auto-position on first open
    CFG.PREVIEW_W%                 = 200                                                  ' Default preview width in pixels
    CFG.PREVIEW_H%                 = 200                                                  ' Default preview height in pixels
    CFG.PREVIEW_FOLLOW%            = FALSE                                                ' Floating image mode by default
    CFG.PREVIEW_ZOOM!              = 1.0                                                  ' 1:1 zoom by default
    CFG.PREVIEW_PAN_X!             = 0.0                                                  ' Pan X default
    CFG.PREVIEW_PAN_Y!             = 0.0                                                  ' Pan Y default
    CFG.PREVIEW_MODE%              = 0                                                    ' 0=Follow, 1=Floating
    CFG.PREVIEW_COLOR_PICK%        = TRUE                                                 ' Color picking enabled by default
    CFG.PREVIEW_BIN_QUICK_LOOK%    = TRUE                                                 ' Bin Quick Look enabled by default
    CFG.PREVIEW_FLOAT_IMAGE_PATH$  = ""                                                   ' No floating image by default
    CFG.PREVIEW_FLOAT_LAST_DIR$    = ""                                                   ' No last dir by default
    CFG.COLOR_MIXER_VISIBLE%       = FALSE                                                ' Color mixer hidden by default
    CFG.COLOR_MIXER_X%             = -1                                                   ' -1 = auto-position on first open
    CFG.COLOR_MIXER_Y%             = -1                                                   ' -1 = auto-position on first open
    CFG.BROWSER_VISIBLE%           = FALSE                                                ' Browser hidden by default
    CFG.BROWSER_POS_X%             = -1                                                   ' -1 = auto-position on first open
    CFG.BROWSER_POS_Y%             = -1                                                   ' -1 = auto-position on first open
    CFG.BROWSER_WIDTH%             = 320                                                  ' Default browser width in pixels
    CFG.BROWSER_HEIGHT%            = 220                                                  ' Default browser height in pixels
    CFG.BROWSER_DEFAULT_FOLDER$    = ""                                                   ' Empty = fallback chain
    CFG.BROWSER_LAST_DIR$          = ""                                                   ' Empty = fallback chain
    CFG.BROWSER_DEFAULT_VIEW_MODE% = 2                                                    ' 2 = thumbnails
    CFG.BROWSER_DEFAULT_ZOOM_LEVEL% = 2                                                   ' 2x thumbnail zoom default
    CFG.BROWSER_DEFAULT_SORT_TYPE% = 0                                                    ' 0 = name
    CFG.BROWSER_DEFAULT_SORT_ORDER% = 0                                                   ' 0 = ascending
    CFG.BROWSER_DEFAULT_PREVIEW_OPEN% = TRUE                                              ' Preview pane open by default
    CFG.PIXEL_ANALYZER_CONFIDENCE% = 60                                                   ' Pixel analyzer default confidence threshold percent
    ' Edit Bar settings
    CFG.EDIT_BAR_VISIBLE%       = TRUE                                                    ' Edit bar visible by default
    CFG.EDIT_BAR_DOCK_POSITION$ = "LEFT"                                                  ' Dock on left side by default
    ' Advanced Bar settings
    CFG.ADV_BAR_VISIBLE%       = TRUE                                                     ' Advanced bar visible by default
    CFG.ADV_BAR_DOCK_POSITION$ = "RIGHT"                                                  ' Dock on right side by default
    ' Default drawer set files
    CFG.DEFAULT_DSET_BRUSHES_FILE$   = "ASSETS/DSETS/BRUSHES/empty-brush-set.dset"        ' Empty = use built-in theme samples
    CFG.DEFAULT_DSET_PATTERNS_FILE$  = "ASSETS/DSETS/PATTERNS/default-pattern-set.dset"   ' Empty = use built-in theme samples
    CFG.DEFAULT_DSET_GRADIENTS_FILE$ = "ASSETS/DSETS/GRADIENTS/default-gradient-set.dset" ' Empty = use built-in gradient samples
    ' Canvas size settings
    CFG.DEFAULT_CANVAS_SIZE_W% = 320                                                      ' Default canvas width (320px)
    CFG.DEFAULT_CANVAS_SIZE_H% = 200                                                      ' Default canvas height (200px)
    CFG.CANVAS_APRON_COLOR~&   = _RGB32(48, 48, 48)                                       ' Dark gray apron around canvas
    ' Text tool default font settings
    CFG.FONT_DEFAULT_FONT$       = ""                                                     ' Empty = use Tiny5 Regular (program default)
    CFG.FONT_DEFAULT_SIZE%       = 0                                                      ' 0 = use program default (8)
    CFG.CHARMAP_CELLS_PER_ROW%   = 16
    CFG.CHARMAP_ZOOM_LEVEL!      = 1.0
    CFG.CHARMAP_MIN_FONT_SIZE%   = 4
    CFG.CHARMAP_MAX_FONT_SIZE%   = 16
    CFG.CHARMAP_PANEL_DOCK_EDGE$ = "RIGHT"                                                ' Character map docks on right by default
    CFG.CHARMAP_CELL_W%          = 0                                                      ' 0 = match font
    CFG.CHARMAP_CELL_H%          = 0                                                      ' 0 = match font
    CFG.CHARMAP_CELL_PADDING%    = 1                                                      ' 1px padding between cells
    CFG.CHARMAP_CHAR_SELECTED%   = -1                                                     ' -1 = none selected
    CFG.CHARMAP_TAB_CHARS%       = 4                                                      ' TAB character width
    ' Character grid settings (0 = use theme/font defaults)
    CFG.CHAR_GRID_WIDTH%     = 0                                                          ' 0 = match font
    CFG.CHAR_GRID_HEIGHT%    = 0                                                          ' 0 = match font
    CFG.CHAR_GRID_OPACITY%   = 0                                                          ' 0 = use theme default
    CFG.CHAR_GRID_COLOR_FG~& = 0                                                          ' 0 = use theme default
    ' File dialog settings
    CFG.FD_FONT_SCALE% = 2                                                                ' File dialog UI/font scale (1-4)
    CFG.FD_ICON_SCALE% = 3                                                                ' File dialog icon scale (1-4)
    CFG.FD_FONT%       = 16                                                               ' 8=compact, 16=standard
    CFG.FD_DIALOG_W%   = 0                                                                ' 0 = auto-size
    CFG.FD_DIALOG_H%   = 0                                                                ' 0 = auto-size
    ' Font source toggles — all ON by default
    CFG.FONTS_INCLUDE_OS_INSTALLED% = TRUE
    CFG.FONTS_INCLUDE_DRAW_BITMAP%  = TRUE
    CFG.FONTS_INCLUDE_DRAW_EXTRAS%  = TRUE
    CFG.FONTS_INCLUDE_USER%         = TRUE
    CFG.FONTS_INCLUDE_USER_BITMAP%  = TRUE
    ' Smart Guides: off by default
    CFG.SMART_GUIDES_ENABLED%   = FALSE
    CFG.SMART_GUIDES_SNAP%      = FALSE
    CFG.SMART_GUIDES_DISTANCE%  = 0                                                       ' 0 = use theme default
    CFG.SMART_GUIDES_COLOR_FG~& = 0                                                       ' 0 = use theme
    CFG.SMART_GUIDES_OPACITY%   = 0                                                       ' 0 = use theme
    ' Opacity slider
    CFG.OPACITY_WARN_THRESHOLD% = 10                                                      ' Warn when <= 10%
END SUB


''<br>' Validate palette strip configuration and apply safe defaults if invalid
'
SUB CONFIG_validate_palette_strip ()
    ' Validate chip dimensions (minimum 6x6, maximum 32x32)
    IF CFG.PALETTE_CHIP_WIDTH% < 6 OR CFG.PALETTE_CHIP_WIDTH% > 32 THEN
        CFG.PALETTE_CHIP_WIDTH% = 10          ' Safe default
    END IF
    IF CFG.PALETTE_CHIP_HEIGHT% < 6 OR CFG.PALETTE_CHIP_HEIGHT% > 32 THEN
        CFG.PALETTE_CHIP_HEIGHT% = 10         ' Safe default
    END IF
    
    ' Validate chips per row (minimum 4, maximum 128)
    IF CFG.PALETTE_MAX_CHIPS_PER_ROW% < 4 OR CFG.PALETTE_MAX_CHIPS_PER_ROW% > 128 THEN
        CFG.PALETTE_MAX_CHIPS_PER_ROW% = 64   ' Safe default
    END IF
    
    ' Validate rows (minimum 1, maximum 8)
    IF CFG.PALETTE_MAX_ROWS% < 1 OR CFG.PALETTE_MAX_ROWS% > 8 THEN
        CFG.PALETTE_MAX_ROWS% = 3             ' Safe default
    END IF
    
    ' Validate min rows (1 to max rows)
    IF CFG.PALETTE_MIN_ROWS% < 1 OR CFG.PALETTE_MIN_ROWS% > CFG.PALETTE_MAX_ROWS% THEN
        CFG.PALETTE_MIN_ROWS% = 1             ' Safe default
    END IF
    
    ' Validate chips per row threshold (4 to max chips per row)
    IF CFG.PALETTE_CHIPS_ROW_THRESHOLD% < 4 OR CFG.PALETTE_CHIPS_ROW_THRESHOLD% > CFG.PALETTE_MAX_CHIPS_PER_ROW% THEN
        CFG.PALETTE_CHIPS_ROW_THRESHOLD% = 16 ' Safe default
    END IF
END SUB


''
' Load configuration from disk
' If file doesn't exist, use defaults and create it
' 
SUB CONFIG_load ()
    DIM fh          AS INTEGER
    DIM configLine  AS STRING
    DIM configKey   AS STRING
    DIM configValue AS STRING
    DIM eqPos       AS INTEGER
    DIM section     AS STRING
    DIM bracketEnd  AS INTEGER

    ' Set defaults first
    CONFIG_set_defaults

    ' Check if config file exists; if not, try to bootstrap from DRAW.cfg.default
    IF NOT _FILEEXISTS(CONFIG_FILE_PATH$) THEN
        IF _FILEEXISTS(CONFIG_DEFAULT_FILE$) THEN
            ' Ensure the config directory exists before writing
            DIM cfgBootDir AS STRING
            cfgBootDir$ = CONFIG_extract_dir$(CONFIG_FILE_PATH$)
            IF cfgBootDir$ <> "" THEN PATHS_ensure_dir cfgBootDir$
            ' Copy DRAW.cfg.default -> CONFIG_FILE_PATH$
            DIM cfgBootSrc AS INTEGER, cfgBootDst AS INTEGER, cfgBootLine AS STRING
            cfgBootSrc% = FREEFILE
            OPEN CONFIG_DEFAULT_FILE$ FOR INPUT AS #cfgBootSrc%
            cfgBootDst% = FREEFILE
            OPEN CONFIG_FILE_PATH$ FOR OUTPUT AS #cfgBootDst%
            DO WHILE NOT EOF(cfgBootSrc%)
                LINE INPUT #cfgBootSrc%, cfgBootLine$
                PRINT #cfgBootDst%, cfgBootLine$
            LOOP
            CLOSE #cfgBootSrc%
            CLOSE #cfgBootDst%
        ELSE
            ' No default file either — defer save until after SCREEN_init resolves viewport
            ' so SCREEN_WIDTH/HEIGHT get the actual auto-detected values, not 0
            CONFIG_NEEDS_INITIAL_SAVE% = TRUE
            EXIT SUB
        END IF
    END IF
    
    ' Open config file for reading
    fh% = FREEFILE
    OPEN CONFIG_FILE_PATH$ FOR INPUT AS #fh%
    
    ' Read line by line
    DO WHILE NOT EOF(fh%)
        LINE INPUT #fh%, configLine$
        
        ' Skip empty lines and comments; track [SECTION] headers
        configLine$ = _TRIM$(configLine$)
        IF LEN(configLine$) = 0 OR LEFT$(configLine$, 1) = "#" OR LEFT$(configLine$, 1) = ";" THEN
            ' Skip this line
        ELSEIF LEFT$(configLine$, 1) = "[" THEN
            bracketEnd% = INSTR(configLine$, "]")
            IF bracketEnd% > 1 THEN
                section$ = UCASE$(_TRIM$(MID$(configLine$, 2, bracketEnd% - 2)))
            END IF
        ELSE
            ' Parse key=value
            eqPos% = INSTR(configLine$, "=")
            IF eqPos% > 0 THEN
                configKey$   = _TRIM$(LEFT$(configLine$, eqPos% - 1))
                configValue$ = _TRIM$(MID$(configLine$, eqPos% + 1))
                
                ' Apply configuration values
                SELECT CASE UCASE$(configKey$)
                    CASE "THEME"
                        CFG.THEME$ = configValue$
                    CASE "FULLSCREEN"
                        CFG.FULLSCREEN% = VAL(configValue$)
                    CASE "DISPLAY_SCALE"
                        CFG.DISPLAY_SCALE% = VAL(configValue$)
                    CASE "DISPLAY_SCALE_MAX"
                        CFG.DISPLAY_SCALE_MAX% = VAL(configValue$)
                    CASE "TOOLBAR_SCALE"
                        CFG.TOOLBAR_SCALE% = VAL(configValue$)
                    CASE "FD_FONT_SCALE"
                        CFG.FD_FONT_SCALE% = VAL(configValue$)
                    CASE "FD_ICON_SCALE"
                        CFG.FD_ICON_SCALE% = VAL(configValue$)
                    CASE "FD_FONT"
                        CFG.FD_FONT% = VAL(configValue$)
                    CASE "FD_DIALOG_W"
                        CFG.FD_DIALOG_W% = VAL(configValue$)
                    CASE "FD_DIALOG_H"
                        CFG.FD_DIALOG_H% = VAL(configValue$)
                    CASE "NUDGE_N"
                        CFG.NUDGE_N% = VAL(configValue$)
                    CASE "NUM_CUSTOM_BRUSHES"
                        CFG.NUM_CUSTOM_BRUSHES% = VAL(configValue$)
                    CASE "NUM_LAYERS"
                        CFG.NUM_LAYERS% = VAL(configValue$)
                    CASE "FPS_LIMIT"
                        CFG.FPS_LIMIT% = VAL(configValue$)
                    CASE "FPS_IDLE"
                        CFG.FPS_IDLE% = VAL(configValue$)
                    CASE "FPS_CURSOR"
                        CFG.FPS_CURSOR% = VAL(configValue$)
                    CASE "FPS_DIALOG"
                        CFG.FPS_DIALOG% = VAL(configValue$)
                    CASE "SCREEN_WIDTH"
                        CFG.SCREEN_WIDTH% = VAL(configValue$)
                    CASE "SCREEN_HEIGHT"
                        CFG.SCREEN_HEIGHT% = VAL(configValue$)
                    CASE "BAS_WIP_ENABLED"
                        CFG.BAS_WIP_ENABLED% = VAL(configValue$)
                    CASE "WIN_MIN_WIDTH"
                        CFG.WIN_MIN_WIDTH% = VAL(configValue$)
                    CASE "WIN_MIN_HEIGHT"
                        CFG.WIN_MIN_HEIGHT% = VAL(configValue$)
                    CASE "WIN_MAX_WIDTH"
                        CFG.WIN_MAX_WIDTH% = VAL(configValue$)
                    CASE "WIN_MAX_HEIGHT"
                        CFG.WIN_MAX_HEIGHT% = VAL(configValue$)
                    CASE "DEFAULT_PALETTE"
                        CFG.DEFAULT_PALETTE$ = configValue$
                    CASE "PALETTE_CHIP_WIDTH"
                        CFG.PALETTE_CHIP_WIDTH% = VAL(configValue$)
                    CASE "PALETTE_CHIP_HEIGHT"
                        CFG.PALETTE_CHIP_HEIGHT% = VAL(configValue$)
                    CASE "PALETTE_MAX_CHIPS_PER_ROW"
                        CFG.PALETTE_MAX_CHIPS_PER_ROW% = VAL(configValue$)
                    CASE "PALETTE_MAX_ROWS"
                        CFG.PALETTE_MAX_ROWS% = VAL(configValue$)
                    CASE "PALETTE_MIN_ROWS"
                        CFG.PALETTE_MIN_ROWS% = VAL(configValue$)
                    CASE "PALETTE_CHIPS_ROW_THRESHOLD"
                        CFG.PALETTE_CHIPS_ROW_THRESHOLD% = VAL(configValue$)
                    CASE "PALETTE_DEFAULT_BG_TRANSPARENT"
                        CFG.PALETTE_DEFAULT_BG_TRANSPARENT% = (UCASE$(_TRIM$(configValue$)) = "TRUE" OR VAL(configValue$) <> 0)
                    CASE "PALETTE_PICKER_CHIP_SIZE"
                        CFG.PALETTE_PICKER_CHIP_SIZE% = VAL(configValue$)
                    CASE "PALETTE_PICKER_CHIP_PADDING"
                        CFG.PALETTE_PICKER_CHIP_PADDING% = VAL(configValue$)
                    CASE "PALETTE_PICKER_COLUMNS"
                        CFG.PALETTE_PICKER_COLUMNS% = VAL(configValue$)
                    CASE "ANGLE_SNAP_DEGREES"
                        CFG.ANGLE_SNAP_DEGREES% = VAL(configValue$)
                    CASE "ANGLE_SNAP_PIXEL_ART"
                        CFG.ANGLE_SNAP_PIXEL_ART% = (UCASE$(configValue$) = "TRUE" OR configValue$ = "1")
                    CASE "LAYER_PANEL_WIDTH"
                        CFG.LAYER_PANEL_WIDTH% = VAL(configValue$)
                    CASE "LAYER_NAME_MAX_LEN"
                        CFG.LAYER_NAME_MAX_LEN% = VAL(configValue$)
                    CASE "LAYER_GROUP_INDENT"
                        CFG.LAYER_GROUP_INDENT% = VAL(configValue$)
                    CASE "LAYERS_PANEL_DOCK_EDGE"
                        CFG.LAYERS_PANEL_DOCK_EDGE = UCASE$(_TRIM$(configValue$))
                    CASE "TOOLBOX_DOCK_EDGE"
                        CFG.TOOLBOX_DOCK_EDGE = UCASE$(_TRIM$(configValue$))
                    CASE "GRID_COLOR_FG"
                        CFG.GRID_COLOR_FG~& = _RGB32(VAL("&H" + LEFT$(configValue$, 2)), VAL("&H" + MID$(configValue$, 3, 2)), VAL("&H" + RIGHT$(configValue$, 2)))
                    CASE "GRID_OPACITY"
                        CFG.GRID_OPACITY% = VAL(configValue$)
                    CASE "GRID_SIZE_X"
                        CFG.GRID_SIZE_X% = VAL(configValue$)
                    CASE "GRID_SIZE_Y"
