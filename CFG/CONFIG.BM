''
' Set default configuration values
' 
SUB CONFIG_set_defaults ()
    ' Default to windowed mode with auto-detected scale
    CFG.FULLSCREEN% = FALSE
    CFG.DISPLAY_SCALE% = 0           ' 0 = auto-detect from desktop resolution
    CFG.DISPLAY_SCALE_MAX% = 8       ' Maximum allowed scale multiplier
    CFG.DISPLAY_SCALE_CHANGED% = FALSE ' Runtime flag, not persisted
    CFG.THEME$              = "DEFAULT"
    CFG.TOOLBAR_SCALE%      = 0   ' Toolbar icon scale (0=auto, 1-4 explicit)
    CFG.NUDGE_N%            = 10
    CFG.NUM_LAYERS%         = 1
    CFG.NUM_CUSTOM_BRUSHES% = 4
    CFG.FPS_LIMIT%          = 60
    CFG.FPS_IDLE%           = 15
    CFG.FPS_CURSOR%         = 240
    CFG.FPS_DIALOG%         = 60
    CFG.SCREEN_WIDTH%       = 0 ' 0 = auto-detect desktop resolution
    CFG.SCREEN_HEIGHT%      = 0 ' 0 = auto-detect desktop resolution
    CFG.WIN_MIN_WIDTH%      = 320 ' Minimum viewport width
    CFG.WIN_MIN_HEIGHT%     = 200 ' Minimum viewport height
    CFG.WIN_MAX_WIDTH%      = 0   ' 0 = unlimited (auto from desktop)
    CFG.WIN_MAX_HEIGHT%     = 0   ' 0 = unlimited (auto from desktop)
    CFG.DEFAULT_PALETTE$    = "ANSI32 (32)" ' Empty = use default palette
    CFG.PALETTE_CHIP_WIDTH% = 16  ' Width of each color chip
    CFG.PALETTE_CHIP_HEIGHT% = 8 ' Height of each color chip
    CFG.PALETTE_MAX_CHIPS_PER_ROW% = 32 ' Maximum chips per row
    CFG.PALETTE_MAX_ROWS%   = 3   ' Maximum rows to display
    CFG.PALETTE_MIN_ROWS%   = 1   ' Minimum rows to always show
    CFG.PALETTE_CHIPS_ROW_THRESHOLD% = 16 ' Create new row every N chips
    CFG.PALETTE_DEFAULT_BG_TRANSPARENT% = TRUE  ' Default BG is transparent
    CFG.PALETTE_PICKER_CHIP_SIZE% = 10 ' Chip size in palette picker dialog (8-48)
    CFG.PALETTE_PICKER_CHIP_PADDING% = 2 ' Padding between chips in palette picker (1-16)
    CFG.PALETTE_PICKER_COLUMNS% = 32 ' Number of columns in palette picker (8-64)
    CFG.ANGLE_SNAP_DEGREES% = 45 ' Angle snap increment for Ctrl+Shift line drawing (15/30/45/90)
    CFG.ANGLE_SNAP_PIXEL_ART% = FALSE ' Pixel art angle snap mode (integer slope ratios)
    ' Layer panel settings
    CFG.NUM_LAYERS% = 32 ' Max layer slots (1-64)
    CFG.LAYER_PANEL_WIDTH% = 100 ' Layer panel width in pixels (min 40)
    CFG.LAYER_NAME_MAX_LEN% = 15 ' Max layer name length (1-64)
    CFG.LAYERS_PANEL_DOCK_EDGE = "LEFT"  ' Layer panel docks on left by default
    CFG.TOOLBOX_DOCK_EDGE = "RIGHT"      ' Toolbox stack docks on right by default
    ' Grid settings (0 = use theme defaults, except size which needs a safe default)
    CFG.GRID_COLOR_FG~& = 0 ' 0 = use theme default
    CFG.GRID_OPACITY% = 0   ' 0 = use theme default
    CFG.GRID_SIZE_X% = 10   ' Default grid cell width (must be >0; theme may not be loaded yet)
    CFG.GRID_SIZE_Y% = 10   ' Default grid cell height (must be >0; theme may not be loaded yet)
    ' Crosshair settings (0 = use theme defaults)
    CFG.CROSSHAIR_FG~& = 0       ' 0 = use theme default
    CFG.CROSSHAIR_OPACITY% = 0   ' 0 = use theme default
    CFG.CROSSHAIR_FONT$ = ""
    CFG.CROSSHAIR_FONT_SIZE% = CONFIG_USE_THEME_DEFAULT%
    CFG.CROSSHAIR_FONT_FG~& = 0  ' 0 = use theme default
    CFG.CROSSHAIR_FONT_STROKE_FG~& = 0
    CFG.CROSSHAIR_FONT_STROKE_WIDTH% = CONFIG_USE_THEME_DEFAULT%
    CFG.CROSSHAIR_ANGLE! = 0     ' 0 = use theme default
    CFG.CROSSHAIR_FONT_OFFSET_X% = CONFIG_USE_THEME_DEFAULT% ' offset from cursor
    CFG.CROSSHAIR_FONT_OFFSET_Y% = CONFIG_USE_THEME_DEFAULT%
    CFG.CROSSHAIR_OUTLINE_FG~& = 0  ' 0 = use theme default
    CFG.CROSSHAIR_OUTLINE_OPACITY% = 0  ' 0 = use theme default
    CFG.CROSSHAIR_OUTLINE_WIDTH% = CONFIG_USE_THEME_DEFAULT%
    ' Picker loupe settings (DRAW.cfg overrides theme when set)
    CFG.PICKER_LOUPE_ZOOM_LEVEL% = CONFIG_USE_THEME_DEFAULT%
    CFG.PICKER_LOUPE_RECT_X_OFFSET% = CONFIG_USE_THEME_DEFAULT%
    CFG.PICKER_LOUPE_RECT_Y_OFFSET% = CONFIG_USE_THEME_DEFAULT%
    CFG.PICKER_LOUPE_RECT_WIDTH% = CONFIG_USE_THEME_DEFAULT%
    CFG.PICKER_LOUPE_RECT_HEIGHT% = CONFIG_USE_THEME_DEFAULT%
    CFG.PICKER_LOUPE_RGBA_X% = CONFIG_USE_THEME_DEFAULT%
    CFG.PICKER_LOUPE_RGBA_Y% = CONFIG_USE_THEME_DEFAULT%
    CFG.PICKER_LOUPE_FONT$ = ""
    CFG.PICKER_LOUPE_FONT_SIZE% = CONFIG_USE_THEME_DEFAULT%
    CFG.PICKER_LOUPE_FONT_FG~& = 0
    CFG.PICKER_LOUPE_FONT_BG~& = 0
    CFG.PICKER_LOUPE_FONT_STROKE_FG~& = 0
    CFG.PICKER_LOUPE_FONT_STROKE_WIDTH% = CONFIG_USE_THEME_DEFAULT%
    CFG.PICKER_LOUPE_RECT_STROKE_FG~& = 0
    CFG.PICKER_LOUPE_RECT_STROKE_WIDTH% = CONFIG_USE_THEME_DEFAULT%
    CFG.PICKER_LOUPE_PIXEL_PICKUP_COLOR~& = 0
    ' Grid geometry mode (0=square default)
    CFG.GRID_MODE% = 0           ' 0 = square
    CFG.GRID_CELL_FILL% = 0       ' 0 = off (normal flood fill)
    ' Grid angle (0 = use theme default)
    CFG.GRID_ANGLE! = 0          ' 0 = use theme default
    ' Pixel grid settings (0 = use theme defaults)
    CFG.PIXELGRID_COLOR_FG~& = 0  ' 0 = use theme default
    CFG.PIXELGRID_OPACITY% = 0    ' 0 = use theme default
    ' Transparency checkerboard settings
    CFG.TRANSPARENCY_CHECK_COLOR1~& = _RGB32(192, 192, 192) ' Light gray
    CFG.TRANSPARENCY_CHECK_COLOR2~& = _RGB32(255, 255, 255) ' White
    CFG.TRANSPARENCY_CHECK_SIZE_X% = 0 ' 0 = use theme default
    CFG.TRANSPARENCY_CHECK_SIZE_Y% = 0 ' 0 = use theme default
    ' Scrollbar settings
    CFG.SCROLLBAR_BG~& = 0            ' 0 = default (dark gray)
    CFG.SCROLLBAR_HANDLE_FG~& = 0     ' 0 = default (light gray)
    CFG.SCROLLBAR_OPACITY% = 0         ' 0 = default (180)
    ' Sound / music settings
    CFG.SOUNDS_ENABLED% = FALSE  ' Sounds off by default
    CFG.SYSTEM_CURSORS_ENABLED% = TRUE ' Use OS system cursors for resize/hand/text/move by default
    CFG.TOOLTIP_HOVER_DELAY_MS% = 500 ' Show tooltip after 500ms hover
    CFG.TOOLTIPS_DISABLED% = FALSE ' Tooltips enabled by default
    CFG.SOUNDS_VOLUME%  = 35     ' 35% volume default
    CFG.SOUNDS_MUTED%   = FALSE  ' SFX not muted by default
    CFG.MUSIC_ENABLED%  = FALSE  ' Music off by default
    CFG.MUSIC_VOLUME%   = 35     ' 35% music volume default
    CFG.MUSIC_MUTED%    = FALSE  ' Music not muted by default
    ' Default startup settings
    CFG.DEFAULT_TOOL% = 1 ' Default to brush tool (TOOL_BRUSH = 1)
    CFG.DEFAULT_BRUSH_SIZE% = 1 ' Default brush size index 1 = 1px
    CFG.DEFAULT_BRUSH_SHAPE% = 1 ' Default brush shape 1=square (0=circle)
    CFG.DEFAULT_DRAW_MODE% = 1 ' Default to color/brush painting mode
    CFG.DEFAULT_BIN_MODE% = 1 ' Default visible bins panel = brush bins
    CFG.DEFAULT_LAYER_BG_COLOR~& = _RGBA32(0, 0, 0, 0) ' Transparent by default
    CFG.BAS_EXPORT_BG_COLOR~& = _RGBA32(255, 0, 255, 255) ' High-visibility magenta export background
    CFG.BAS_WIP_ENABLED% = FALSE ' Live WIP BAS stream disabled by default
    CFG.DEFAULT_SAVE_DIR$ = "" ' Empty = use current directory
    CFG.DEFAULT_OPEN_DIR$ = "" ' Empty = use current directory
    ' Per-operation last dirs (empty = use DEFAULT_OPEN_DIR/DEFAULT_SAVE_DIR as fallback)
    CFG.LAST_DIR_OPEN$ = ""
    CFG.LAST_DIR_SAVE$ = ""
    CFG.LAST_DIR_IMPORT$ = ""
    CFG.LAST_DIR_EXPORT_BRUSH$ = ""
    CFG.LAST_DIR_EXPORT_LAYER$ = ""
    CFG.LAST_DIR_EXTRACT$ = ""
    CFG.LAST_DIR_PALETTE$ = ""
    CFG.TEMPLATE_DIR$ = "ASSETS/TEMPLATES"         ' Empty = use current directory for templates
    ' User palette visibility settings
    CFG.PALETTE_SHOW_LOSPEC% = TRUE   ' Show Lospec palettes in picker by default
    CFG.PALETTE_SHOW_CREATED% = TRUE  ' Show Created palettes in picker by default
    CFG.PALETTE_CREATE_MAX_COLORS% = 32 ' Default max colors for Create from Image
    ' Preview Window settings
    CFG.PREVIEW_VISIBLE% = FALSE  ' Preview window hidden by default
    CFG.PREVIEW_X%       = -1    ' -1 = auto-position on first open
    CFG.PREVIEW_Y%       = -1    ' -1 = auto-position on first open
    CFG.PREVIEW_W%       = 200   ' Default preview width in pixels
    CFG.PREVIEW_H%       = 200   ' Default preview height in pixels
    CFG.PREVIEW_FOLLOW%  = TRUE  ' Follow-pointer mode on by default
    CFG.PREVIEW_ZOOM!    = 2.0   ' 2:1 zoom by default
    CFG.PREVIEW_PAN_X!   = 0.0   ' Pan X default
    CFG.PREVIEW_PAN_Y!   = 0.0   ' Pan Y default
    CFG.PREVIEW_MODE%    = 0     ' 0=Follow, 1=Floating
    CFG.PREVIEW_COLOR_PICK% = FALSE ' Color picking disabled by default
    CFG.PREVIEW_BIN_QUICK_LOOK% = FALSE ' Bin Quick Look disabled by default
    CFG.PREVIEW_FLOAT_IMAGE_PATH$ = "" ' No floating image by default
    CFG.PREVIEW_FLOAT_LAST_DIR$ = ""   ' No last dir by default
    CFG.PIXEL_ANALYZER_CONFIDENCE% = 60 ' Pixel analyzer default confidence threshold percent
    ' Edit Bar settings
    CFG.EDIT_BAR_VISIBLE% = FALSE  ' Edit bar hidden by default
    CFG.EDIT_BAR_DOCK_POSITION$ = "RIGHT" ' Dock on right side by default
    ' Advanced Bar settings
    CFG.ADV_BAR_VISIBLE% = FALSE  ' Advanced bar hidden by default
    CFG.ADV_BAR_DOCK_POSITION$ = "RIGHT" ' Dock on right side by default
    ' Default drawer set files
    CFG.DEFAULT_DSET_BRUSHES_FILE$ = "ASSETS/DSETS/BRUSHES/mariopaint-custom.dset"   ' Empty = use built-in theme samples
    CFG.DEFAULT_DSET_PATTERNS_FILE$ = "ASSETS/DSETS/PATTERNS/default-pattern-set.dset" ' Empty = use built-in theme samples
    CFG.DEFAULT_DSET_GRADIENTS_FILE$ = "ASSETS/DSETS/GRADIENTS/default-gradient-set.dset" ' Empty = use built-in gradient samples
    ' Canvas size settings
    CFG.DEFAULT_CANVAS_SIZE_W% = 320   ' Default canvas width (320px)
    CFG.DEFAULT_CANVAS_SIZE_H% = 200  ' Default canvas height (200px)
    CFG.CANVAS_APRON_COLOR~& = _RGB32(48, 48, 48) ' Dark gray apron around canvas
    ' Text tool default font settings
    CFG.FONT_DEFAULT_FONT$ = ""  ' Empty = use Tiny5 Regular (program default)
    CFG.FONT_DEFAULT_SIZE% = 0   ' 0 = use program default (8)
    CFG.CHARMAP_CELLS_PER_ROW% = 16
    CFG.CHARMAP_ZOOM_LEVEL! = 1.0
    CFG.CHARMAP_MIN_FONT_SIZE% = 4
    CFG.CHARMAP_MAX_FONT_SIZE% = 16
    ' Font source toggles â€” all ON by default
    CFG.FONTS_INCLUDE_OS_INSTALLED% = TRUE
    CFG.FONTS_INCLUDE_DRAW_BITMAP% = TRUE
    CFG.FONTS_INCLUDE_DRAW_EXTRAS% = TRUE
    CFG.FONTS_INCLUDE_USER% = TRUE
    CFG.FONTS_INCLUDE_USER_BITMAP% = TRUE
    ' Smart Guides: off by default
    CFG.SMART_GUIDES_ENABLED% = FALSE
    CFG.SMART_GUIDES_SNAP% = FALSE
    CFG.SMART_GUIDES_DISTANCE% = 0  ' 0 = use theme default
    CFG.SMART_GUIDES_COLOR_FG~& = 0  ' 0 = use theme
    CFG.SMART_GUIDES_OPACITY% = 0    ' 0 = use theme
END SUB


''<br>' Validate palette strip configuration and apply safe defaults if invalid
'
SUB CONFIG_validate_palette_strip ()
    ' Validate chip dimensions (minimum 6x6, maximum 32x32)
    IF CFG.PALETTE_CHIP_WIDTH% < 6 OR CFG.PALETTE_CHIP_WIDTH% > 32 THEN
        CFG.PALETTE_CHIP_WIDTH% = 10 ' Safe default
    END IF
    IF CFG.PALETTE_CHIP_HEIGHT% < 6 OR CFG.PALETTE_CHIP_HEIGHT% > 32 THEN
        CFG.PALETTE_CHIP_HEIGHT% = 10 ' Safe default
    END IF
    
    ' Validate chips per row (minimum 4, maximum 128)
    IF CFG.PALETTE_MAX_CHIPS_PER_ROW% < 4 OR CFG.PALETTE_MAX_CHIPS_PER_ROW% > 128 THEN
        CFG.PALETTE_MAX_CHIPS_PER_ROW% = 64 ' Safe default
    END IF
    
    ' Validate rows (minimum 1, maximum 8)
    IF CFG.PALETTE_MAX_ROWS% < 1 OR CFG.PALETTE_MAX_ROWS% > 8 THEN
        CFG.PALETTE_MAX_ROWS% = 3 ' Safe default
    END IF
    
    ' Validate min rows (1 to max rows)
    IF CFG.PALETTE_MIN_ROWS% < 1 OR CFG.PALETTE_MIN_ROWS% > CFG.PALETTE_MAX_ROWS% THEN
        CFG.PALETTE_MIN_ROWS% = 1 ' Safe default
    END IF
    
    ' Validate chips per row threshold (4 to max chips per row)
    IF CFG.PALETTE_CHIPS_ROW_THRESHOLD% < 4 OR CFG.PALETTE_CHIPS_ROW_THRESHOLD% > CFG.PALETTE_MAX_CHIPS_PER_ROW% THEN
        CFG.PALETTE_CHIPS_ROW_THRESHOLD% = 16 ' Safe default
    END IF
END SUB


''
' Load configuration from disk
' If file doesn't exist, use defaults and create it
' 
SUB CONFIG_load ()
    DIM fh AS INTEGER
    DIM configLine AS STRING
    DIM configKey AS STRING
    DIM configValue AS STRING
    DIM eqPos AS INTEGER
    
    ' Set defaults first
    CONFIG_set_defaults
    
    ' Check if config file exists
    IF NOT _FILEEXISTS(CONFIG_FILE_PATH$) THEN
        ' File doesn't exist â€” defer save until after SCREEN_init resolves viewport
        ' so SCREEN_WIDTH/HEIGHT get the actual auto-detected values, not 0
        CONFIG_NEEDS_INITIAL_SAVE% = TRUE
        EXIT SUB
    END IF
    
    ' Open config file for reading
    fh% = FREEFILE
    OPEN CONFIG_FILE_PATH$ FOR INPUT AS #fh%
    
    ' Read line by line
    DO WHILE NOT EOF(fh%)
        LINE INPUT #fh%, configLine$
        
        ' Skip empty lines and comments
        configLine$ = _TRIM$(configLine$)
        IF LEN(configLine$) = 0 OR LEFT$(configLine$, 1) = "#" OR LEFT$(configLine$, 1) = ";" THEN
            ' Skip this line
        ELSE
            ' Parse key=value
            eqPos% = INSTR(configLine$, "=")
            IF eqPos% > 0 THEN
                configKey$ = _TRIM$(LEFT$(configLine$, eqPos% - 1))
                configValue$ = _TRIM$(MID$(configLine$, eqPos% + 1))
                
                ' Apply configuration values
                SELECT CASE UCASE$(configKey$)
                    CASE "THEME"
                        CFG.THEME$ = configValue$
                    CASE "FULLSCREEN"
                        CFG.FULLSCREEN% = VAL(configValue$)
                    CASE "DISPLAY_SCALE"
                        CFG.DISPLAY_SCALE% = VAL(configValue$)
                    CASE "DISPLAY_SCALE_MAX"
                        CFG.DISPLAY_SCALE_MAX% = VAL(configValue$)
                    CASE "TOOLBAR_SCALE"
                        CFG.TOOLBAR_SCALE% = VAL(configValue$)
                    CASE "FD_FONT_SCALE"
                        CFG.FD_FONT_SCALE% = VAL(configValue$)
                    CASE "FD_FONT"
                        CFG.FD_FONT% = VAL(configValue$)
                    CASE "FD_DIALOG_W"
                        CFG.FD_DIALOG_W% = VAL(configValue$)
                    CASE "FD_DIALOG_H"
                        CFG.FD_DIALOG_H% = VAL(configValue$)
                    CASE "NUDGE_N"
                        CFG.NUDGE_N% = VAL(configValue$)
                    CASE "NUM_CUSTOM_BRUSHES"
                        CFG.NUM_CUSTOM_BRUSHES% = VAL(configValue$)
                    CASE "NUM_LAYERS"
                        CFG.NUM_LAYERS% = VAL(configValue$)
                    CASE "FPS_LIMIT"
                        CFG.FPS_LIMIT% = VAL(configValue$)
                    CASE "FPS_IDLE"
                        CFG.FPS_IDLE% = VAL(configValue$)
                    CASE "FPS_CURSOR"
                        CFG.FPS_CURSOR% = VAL(configValue$)
                    CASE "FPS_DIALOG"
                        CFG.FPS_DIALOG% = VAL(configValue$)
                    CASE "SCREEN_WIDTH"
                        CFG.SCREEN_WIDTH% = VAL(configValue$)
                    CASE "SCREEN_HEIGHT"
                        CFG.SCREEN_HEIGHT% = VAL(configValue$)
                    CASE "BAS_WIP_ENABLED"
                        CFG.BAS_WIP_ENABLED% = VAL(configValue$)
                    CASE "WIN_MIN_WIDTH"
                        CFG.WIN_MIN_WIDTH% = VAL(configValue$)
                    CASE "WIN_MIN_HEIGHT"
                        CFG.WIN_MIN_HEIGHT% = VAL(configValue$)
                    CASE "WIN_MAX_WIDTH"
                        CFG.WIN_MAX_WIDTH% = VAL(configValue$)
                    CASE "WIN_MAX_HEIGHT"
                        CFG.WIN_MAX_HEIGHT% = VAL(configValue$)
                    CASE "DEFAULT_PALETTE"
                        CFG.DEFAULT_PALETTE$ = configValue$
                    CASE "PALETTE_CHIP_WIDTH"
                        CFG.PALETTE_CHIP_WIDTH% = VAL(configValue$)
                    CASE "PALETTE_CHIP_HEIGHT"
                        CFG.PALETTE_CHIP_HEIGHT% = VAL(configValue$)
                    CASE "PALETTE_MAX_CHIPS_PER_ROW"
                        CFG.PALETTE_MAX_CHIPS_PER_ROW% = VAL(configValue$)
                    CASE "PALETTE_MAX_ROWS"
                        CFG.PALETTE_MAX_ROWS% = VAL(configValue$)
                    CASE "PALETTE_MIN_ROWS"
                        CFG.PALETTE_MIN_ROWS% = VAL(configValue$)
                    CASE "PALETTE_CHIPS_ROW_THRESHOLD"
                        CFG.PALETTE_CHIPS_ROW_THRESHOLD% = VAL(configValue$)
                    CASE "PALETTE_DEFAULT_BG_TRANSPARENT"
                        CFG.PALETTE_DEFAULT_BG_TRANSPARENT% = (UCASE$(_TRIM$(configValue$)) = "TRUE" OR VAL(configValue$) <> 0)
                    CASE "PALETTE_PICKER_CHIP_SIZE"
                        CFG.PALETTE_PICKER_CHIP_SIZE% = VAL(configValue$)
                    CASE "PALETTE_PICKER_CHIP_PADDING"
                        CFG.PALETTE_PICKER_CHIP_PADDING% = VAL(configValue$)
                    CASE "PALETTE_PICKER_COLUMNS"
                        CFG.PALETTE_PICKER_COLUMNS% = VAL(configValue$)
                    CASE "ANGLE_SNAP_DEGREES"
                        CFG.ANGLE_SNAP_DEGREES% = VAL(configValue$)
                    CASE "ANGLE_SNAP_PIXEL_ART"
                        CFG.ANGLE_SNAP_PIXEL_ART% = (UCASE$(configValue$) = "TRUE" OR configValue$ = "1")
                    CASE "LAYER_PANEL_WIDTH"
                        CFG.LAYER_PANEL_WIDTH% = VAL(configValue$)
                    CASE "LAYER_NAME_MAX_LEN"
                        CFG.LAYER_NAME_MAX_LEN% = VAL(configValue$)
                    CASE "LAYERS_PANEL_DOCK_EDGE"
                        CFG.LAYERS_PANEL_DOCK_EDGE = UCASE$(_TRIM$(configValue$))
                    CASE "TOOLBOX_DOCK_EDGE"
                        CFG.TOOLBOX_DOCK_EDGE = UCASE$(_TRIM$(configValue$))
                    CASE "GRID_COLOR_FG"
                        CFG.GRID_COLOR_FG~& = _RGB32(VAL("&H" + LEFT$(configValue$, 2)), VAL("&H" + MID$(configValue$, 3, 2)), VAL("&H" + RIGHT$(configValue$, 2)))
                    CASE "GRID_OPACITY"
                        CFG.GRID_OPACITY% = VAL(configValue$)
                    CASE "GRID_SIZE_X"
                        CFG.GRID_SIZE_X% = VAL(configValue$)
                    CASE "GRID_SIZE_Y"
                        CFG.GRID_SIZE_Y% = VAL(configValue$)
                    CASE "CROSSHAIR_FG"
                        CFG.CROSSHAIR_FG~& = _RGB32(VAL("&H" + LEFT$(configValue$, 2)), VAL("&H" + MID$(configValue$, 3, 2)), VAL("&H" + RIGHT$(configValue$, 2)))
                    CASE "CROSSHAIR_OPACITY"
                        CFG.CROSSHAIR_OPACITY% = VAL(configValue$)
                    CASE "CROSSHAIR_FONT"
                        CFG.CROSSHAIR_FONT$ = configValue$
                    CASE "CROSSHAIR_FONT_SIZE"
                        CFG.CROSSHAIR_FONT_SIZE% = VAL(configValue$)
                    CASE "CROSSHAIR_FONT_FG"
                        CFG.CROSSHAIR_FONT_FG~& = _RGB32(VAL("&H" + LEFT$(configValue$, 2)), VAL("&H" + MID$(configValue$, 3, 2)), VAL("&H" + RIGHT$(configValue$, 2)))
                    CASE "CROSSHAIR_FONT_STROKE_FG"
                        CFG.CROSSHAIR_FONT_STROKE_FG~& = _RGB32(VAL("&H" + LEFT$(configValue$, 2)), VAL("&H" + MID$(configValue$, 3, 2)), VAL("&H" + RIGHT$(configValue$, 2)))
                    CASE "CROSSHAIR_FONT_STROKE_WIDTH"
                        CFG.CROSSHAIR_FONT_STROKE_WIDTH% = VAL(configValue$)
                    CASE "CROSSHAIR_FONT_OFFSET_X"
                        CFG.CROSSHAIR_FONT_OFFSET_X% = VAL(configValue$)
                    CASE "CROSSHAIR_FONT_OFFSET_Y"
                        CFG.CROSSHAIR_FONT_OFFSET_Y% = VAL(configValue$)
                    CASE "CROSSHAIR_ANGLE"
                        CFG.CROSSHAIR_ANGLE! = VAL(configValue$)
                    CASE "CROSSHAIR_OUTLINE_FG"
                        CFG.CROSSHAIR_OUTLINE_FG~& = _RGB32(VAL("&H" + LEFT$(configValue$, 2)), VAL("&H" + MID$(configValue$, 3, 2)), VAL("&H" + RIGHT$(configValue$, 2)))
                    CASE "CROSSHAIR_OUTLINE_OPACITY"
                        CFG.CROSSHAIR_OUTLINE_OPACITY% = VAL(configValue$)
                    CASE "CROSSHAIR_OUTLINE_WIDTH"
                        CFG.CROSSHAIR_OUTLINE_WIDTH% = VAL(configValue$)
                    CASE "PICKER_LOUPE_ZOOM_LEVEL"
                        CFG.PICKER_LOUPE_ZOOM_LEVEL% = VAL(configValue$)
                    CASE "PICKER_LOUPE_RECT_X_OFFSET"
                        CFG.PICKER_LOUPE_RECT_X_OFFSET% = VAL(configValue$)
                    CASE "PICKER_LOUPE_RECT_Y_OFFSET"
                        CFG.PICKER_LOUPE_RECT_Y_OFFSET% = VAL(configValue$)
                    CASE "PICKER_LOUPE_RECT_WIDTH"
                        CFG.PICKER_LOUPE_RECT_WIDTH% = VAL(configValue$)
                    CASE "PICKER_LOUPE_RECT_HEIGHT"
                        CFG.PICKER_LOUPE_RECT_HEIGHT% = VAL(configValue$)
                    CASE "PICKER_LOUPE_RGBA_X"
                        CFG.PICKER_LOUPE_RGBA_X% = VAL(configValue$)
                    CASE "PICKER_LOUPE_RGBA_Y"
                        CFG.PICKER_LOUPE_RGBA_Y% = VAL(configValue$)
                    CASE "PICKER_LOUPE_FONT"
                        CFG.PICKER_LOUPE_FONT$ = configValue$
                    CASE "PICKER_LOUPE_FONT_SIZE"
                        CFG.PICKER_LOUPE_FONT_SIZE% = VAL(configValue$)
                    CASE "PICKER_LOUPE_FONT_FG"
                        CFG.PICKER_LOUPE_FONT_FG~& = _RGB32(VAL("&H" + LEFT$(configValue$, 2)), VAL("&H" + MID$(configValue$, 3, 2)), VAL("&H" + RIGHT$(configValue$, 2)))
                    CASE "PICKER_LOUPE_FONT_BG"
                        CFG.PICKER_LOUPE_FONT_BG~& = _RGB32(VAL("&H" + LEFT$(configValue$, 2)), VAL("&H" + MID$(configValue$, 3, 2)), VAL("&H" + RIGHT$(configValue$, 2)))
                    CASE "PICKER_LOUPE_FONT_STROKE_FG"
                        CFG.PICKER_LOUPE_FONT_STROKE_FG~& = _RGB32(VAL("&H" + LEFT$(configValue$, 2)), VAL("&H" + MID$(configValue$, 3, 2)), VAL("&H" + RIGHT$(configValue$, 2)))
                    CASE "PICKER_LOUPE_FONT_STROKE_WIDTH"
                        CFG.PICKER_LOUPE_FONT_STROKE_WIDTH% = VAL(configValue$)
                    CASE "PICKER_LOUPE_RECT_STROKE_FG"
                        CFG.PICKER_LOUPE_RECT_STROKE_FG~& = _RGB32(VAL("&H" + LEFT$(configValue$, 2)), VAL("&H" + MID$(configValue$, 3, 2)), VAL("&H" + RIGHT$(configValue$, 2)))
                    CASE "PICKER_LOUPE_RECT_STROKE_WIDTH"
                        CFG.PICKER_LOUPE_RECT_STROKE_WIDTH% = VAL(configValue$)
                    CASE "PICKER_LOUPE_PIXEL_PICKUP_COLOR"
                        CFG.PICKER_LOUPE_PIXEL_PICKUP_COLOR~& = _RGB32(VAL("&H" + LEFT$(configValue$, 2)), VAL("&H" + MID$(configValue$, 3, 2)), VAL("&H" + RIGHT$(configValue$, 2)))
                    CASE "GRID_MODE"
                        CFG.GRID_MODE% = VAL(configValue$)
                    CASE "GRID_CELL_FILL"
                        CFG.GRID_CELL_FILL% = VAL(configValue$)
                    CASE "GRID_ANGLE"
                        CFG.GRID_ANGLE! = VAL(configValue$)
                    CASE "PIXELGRID_COLOR_FG"
                        CFG.PIXELGRID_COLOR_FG~& = _RGB32(VAL("&H" + LEFT$(configValue$, 2)), VAL("&H" + MID$(configValue$, 3, 2)), VAL("&H" + RIGHT$(configValue$, 2)))
                    CASE "PIXELGRID_OPACITY"
                        CFG.PIXELGRID_OPACITY% = VAL(configValue$)
                    CASE "TRANSPARENCY_CHECK_COLOR1"
                        CFG.TRANSPARENCY_CHECK_COLOR1~& = _RGB32(VAL("&H" + LEFT$(configValue$, 2)), VAL("&H" + MID$(configValue$, 3, 2)), VAL("&H" + RIGHT$(configValue$, 2)))
                    CASE "TRANSPARENCY_CHECK_COLOR2"
                        CFG.TRANSPARENCY_CHECK_COLOR2~& = _RGB32(VAL("&H" + LEFT$(configValue$, 2)), VAL("&H" + MID$(configValue$, 3, 2)), VAL("&H" + RIGHT$(configValue$, 2)))
                    CASE "TRANSPARENCY_CHECK_SIZE"
                        ' Legacy single size: apply to both X and Y
                        CFG.TRANSPARENCY_CHECK_SIZE_X% = VAL(configValue$)
                        CFG.TRANSPARENCY_CHECK_SIZE_Y% = VAL(configValue$)
                    CASE "TRANSPARENCY_CHECK_SIZE_X"
                        CFG.TRANSPARENCY_CHECK_SIZE_X% = VAL(configValue$)
                    CASE "TRANSPARENCY_CHECK_SIZE_Y"
                        CFG.TRANSPARENCY_CHECK_SIZE_Y% = VAL(configValue$)
                    CASE "SCROLLBAR_BG"
                        CFG.SCROLLBAR_BG~& = _RGB32(VAL("&H" + LEFT$(configValue$, 2)), VAL("&H" + MID$(configValue$, 3, 2)), VAL("&H" + RIGHT$(configValue$, 2)))
                    CASE "SCROLLBAR_HANDLE_FG"
                        CFG.SCROLLBAR_HANDLE_FG~& = _RGB32(VAL("&H" + LEFT$(configValue$, 2)), VAL("&H" + MID$(configValue$, 3, 2)), VAL("&H" + RIGHT$(configValue$, 2)))
                    CASE "SCROLLBAR_OPACITY"
                        CFG.SCROLLBAR_OPACITY% = VAL(configValue$)
                    CASE "SYSTEM_CURSORS"
                        CFG.SYSTEM_CURSORS_ENABLED% = (UCASE$(configValue$) = "TRUE" OR configValue$ = "1")
                    CASE "TOOLTIP_HOVER_DELAY"
                        CFG.TOOLTIP_HOVER_DELAY_MS% = VAL(configValue$)
                        IF CFG.TOOLTIP_HOVER_DELAY_MS% < 0 THEN CFG.TOOLTIP_HOVER_DELAY_MS% = 0
                        IF CFG.TOOLTIP_HOVER_DELAY_MS% > 5000 THEN CFG.TOOLTIP_HOVER_DELAY_MS% = 5000
                    CASE "TOOLTIPS_DISABLED"
                        CFG.TOOLTIPS_DISABLED% = (UCASE$(configValue$) = "TRUE" OR configValue$ = "1")
                    CASE "FONTS_INCLUDE_OS_INSTALLED"
                        CFG.FONTS_INCLUDE_OS_INSTALLED% = (UCASE$(configValue$) = "TRUE" OR configValue$ = "1")
                    CASE "FONTS_INCLUDE_DRAW_BITMAP"
                        CFG.FONTS_INCLUDE_DRAW_BITMAP% = (UCASE$(configValue$) = "TRUE" OR configValue$ = "1")
                    CASE "FONTS_INCLUDE_DRAW_EXTRAS"
                        CFG.FONTS_INCLUDE_DRAW_EXTRAS% = (UCASE$(configValue$) = "TRUE" OR configValue$ = "1")
                    CASE "FONTS_INCLUDE_USER"
                        CFG.FONTS_INCLUDE_USER% = (UCASE$(configValue$) = "TRUE" OR configValue$ = "1")
                    CASE "FONTS_INCLUDE_USER_BITMAP"
                        CFG.FONTS_INCLUDE_USER_BITMAP% = (UCASE$(configValue$) = "TRUE" OR configValue$ = "1")
                    CASE "SMART_GUIDES_ENABLED"
                        CFG.SMART_GUIDES_ENABLED% = (UCASE$(configValue$) = "TRUE" OR configValue$ = "1")
                    CASE "SMART_GUIDES_SNAP"
                        CFG.SMART_GUIDES_SNAP% = (UCASE$(configValue$) = "TRUE" OR configValue$ = "1")
                    CASE "SMART_GUIDES_DISTANCE"
                        CFG.SMART_GUIDES_DISTANCE% = VAL(configValue$)
                    CASE "SMART_GUIDES_COLOR_FG"
                        IF LEN(configValue$) = 6 THEN
                            CFG.SMART_GUIDES_COLOR_FG~& = _RGB32(VAL("&H" + LEFT$(configValue$, 2)), VAL("&H" + MID$(configValue$, 3, 2)), VAL("&H" + RIGHT$(configValue$, 2)))
                        END IF
                    CASE "SMART_GUIDES_OPACITY"
                        CFG.SMART_GUIDES_OPACITY% = VAL(configValue$)
                    CASE "FONT_DEFAULT_FONT"
                        CFG.FONT_DEFAULT_FONT$ = configValue$
                    CASE "FONT_DEFAULT_SIZE"
                        CFG.FONT_DEFAULT_SIZE% = VAL(configValue$)
                        IF CFG.FONT_DEFAULT_SIZE% < 0 THEN CFG.FONT_DEFAULT_SIZE% = 0
                        IF CFG.FONT_DEFAULT_SIZE% > 128 THEN CFG.FONT_DEFAULT_SIZE% = 128
                    CASE "SOUNDS_ENABLED"
                        CFG.SOUNDS_ENABLED% = (UCASE$(configValue$) = "TRUE" OR configValue$ = "1")
                    CASE "SOUNDS_VOLUME"
                        CFG.SOUNDS_VOLUME% = VAL(configValue$)
                        IF CFG.SOUNDS_VOLUME% < 0  THEN CFG.SOUNDS_VOLUME% = 0
                        IF CFG.SOUNDS_VOLUME% > 100 THEN CFG.SOUNDS_VOLUME% = 100
                    CASE "MUSIC_ENABLED"
                        CFG.MUSIC_ENABLED% = (UCASE$(configValue$) = "TRUE" OR configValue$ = "1")
                    CASE "SOUNDS_MUTED"
                        CFG.SOUNDS_MUTED% = (UCASE$(configValue$) = "TRUE" OR configValue$ = "1")
                    CASE "MUSIC_VOLUME"
                        CFG.MUSIC_VOLUME% = VAL(configValue$)
                        IF CFG.MUSIC_VOLUME% < 0  THEN CFG.MUSIC_VOLUME% = 0
                        IF CFG.MUSIC_VOLUME% > 100 THEN CFG.MUSIC_VOLUME% = 100
                    CASE "MUSIC_MUTED"
                        CFG.MUSIC_MUTED% = (UCASE$(configValue$) = "TRUE" OR configValue$ = "1")
                    CASE "DEFAULT_TOOL"
                        CFG.DEFAULT_TOOL% = VAL(configValue$)
                    CASE "DEFAULT_BRUSH_SIZE"
                        CFG.DEFAULT_BRUSH_SIZE% = VAL(configValue$)
                    CASE "DEFAULT_BRUSH_SHAPE"
                        CFG.DEFAULT_BRUSH_SHAPE% = VAL(configValue$)
                    CASE "DEFAULT_DRAW_MODE"
                        CFG.DEFAULT_DRAW_MODE% = VAL(configValue$)
                    CASE "DEFAULT_BIN_MODE"
                        CFG.DEFAULT_BIN_MODE% = VAL(configValue$)
                    CASE "DEFAULT_LAYER_BG_COLOR"
                        CFG.DEFAULT_LAYER_BG_COLOR~& = _RGBA32(VAL("&H" + LEFT$(configValue$, 2)), VAL("&H" + MID$(configValue$, 3, 2)), VAL("&H" + MID$(configValue$, 5, 2)), VAL("&H" + RIGHT$(configValue$, 2)))
                    CASE "BAS_EXPORT_BG_COLOR"
                        CFG.BAS_EXPORT_BG_COLOR~& = _RGBA32(VAL("&H" + LEFT$(configValue$, 2)), VAL("&H" + MID$(configValue$, 3, 2)), VAL("&H" + MID$(configValue$, 5, 2)), VAL("&H" + RIGHT$(configValue$, 2)))
                    CASE "DEFAULT_SAVE_DIR"
                        CFG.DEFAULT_SAVE_DIR$ = configValue$
                    CASE "DEFAULT_OPEN_DIR"
                        CFG.DEFAULT_OPEN_DIR$ = configValue$
                    CASE "LAST_DIR_OPEN"
                        CFG.LAST_DIR_OPEN$ = configValue$
                    CASE "LAST_DIR_SAVE"
                        CFG.LAST_DIR_SAVE$ = configValue$
                    CASE "LAST_DIR_IMPORT"
                        CFG.LAST_DIR_IMPORT$ = configValue$
                    CASE "LAST_DIR_EXPORT_BRUSH"
                        CFG.LAST_DIR_EXPORT_BRUSH$ = configValue$
                    CASE "LAST_DIR_EXPORT_LAYER"
                        CFG.LAST_DIR_EXPORT_LAYER$ = configValue$
                    CASE "LAST_DIR_EXTRACT"
                        CFG.LAST_DIR_EXTRACT$ = configValue$
                    CASE "LAST_DIR_PALETTE"
                        CFG.LAST_DIR_PALETTE$ = configValue$
                    CASE "TEMPLATE_DIR"
                        CFG.TEMPLATE_DIR$ = configValue$
                    CASE "PALETTE_SHOW_LOSPEC"
                        CFG.PALETTE_SHOW_LOSPEC% = VAL(configValue$)
                    CASE "PALETTE_SHOW_CREATED"
                        CFG.PALETTE_SHOW_CREATED% = VAL(configValue$)
                    CASE "PALETTE_CREATE_MAX_COLORS"
                        CFG.PALETTE_CREATE_MAX_COLORS% = VAL(configValue$)
                    CASE "PREVIEW_VISIBLE"
                        CFG.PREVIEW_VISIBLE% = VAL(configValue$)
                    CASE "PREVIEW_X"
                        CFG.PREVIEW_X% = VAL(configValue$)
                    CASE "PREVIEW_Y"
                        CFG.PREVIEW_Y% = VAL(configValue$)
                    CASE "PREVIEW_W"
                        CFG.PREVIEW_W% = VAL(configValue$)
                    CASE "PREVIEW_H"
                        CFG.PREVIEW_H% = VAL(configValue$)
                    CASE "PREVIEW_FOLLOW"
                        CFG.PREVIEW_FOLLOW% = VAL(configValue$)
                    CASE "PREVIEW_ZOOM"
                        CFG.PREVIEW_ZOOM! = VAL(configValue$)
                    CASE "PREVIEW_PAN_X"
                        CFG.PREVIEW_PAN_X! = VAL(configValue$)
                    CASE "PREVIEW_PAN_Y"
                        CFG.PREVIEW_PAN_Y! = VAL(configValue$)
                    CASE "PREVIEW_MODE"
                        CFG.PREVIEW_MODE% = VAL(configValue$)
                    CASE "PREVIEW_COLOR_PICK"
                        CFG.PREVIEW_COLOR_PICK% = VAL(configValue$)
                    CASE "PREVIEW_BIN_QUICK_LOOK"
                        CFG.PREVIEW_BIN_QUICK_LOOK% = VAL(configValue$)
                    CASE "PREVIEW_FLOAT_IMAGE_PATH"
                        CFG.PREVIEW_FLOAT_IMAGE_PATH$ = configValue$
                    CASE "PREVIEW_FLOAT_LAST_DIR"
                        CFG.PREVIEW_FLOAT_LAST_DIR$ = configValue$
                    CASE "PIXEL_ANALYZER_CONFIDENCE"
                        CFG.PIXEL_ANALYZER_CONFIDENCE% = VAL(configValue$)
                        IF CFG.PIXEL_ANALYZER_CONFIDENCE% < 10 THEN CFG.PIXEL_ANALYZER_CONFIDENCE% = 10
                        IF CFG.PIXEL_ANALYZER_CONFIDENCE% > 90 THEN CFG.PIXEL_ANALYZER_CONFIDENCE% = 90
                    CASE "EDIT_BAR_VISIBLE"
                        CFG.EDIT_BAR_VISIBLE% = VAL(configValue$)
                    CASE "EDIT_BAR_DOCK_POSITION"
                        CFG.EDIT_BAR_DOCK_POSITION$ = UCASE$(_TRIM$(configValue$))
                    CASE "ADV_BAR_VISIBLE"
                        CFG.ADV_BAR_VISIBLE% = VAL(configValue$)
                    CASE "ADV_BAR_DOCK_POSITION"
                        CFG.ADV_BAR_DOCK_POSITION$ = UCASE$(_TRIM$(configValue$))
                    CASE "CHARMAP_VISIBLE"
                        CFG.CHARMAP_VISIBLE% = VAL(configValue$)
                    CASE "CHARMAP_PANEL_DOCK_EDGE"
                        CFG.CHARMAP_PANEL_DOCK_EDGE$ = UCASE$(_TRIM$(configValue$))
                    CASE "CHARMAP_CELLS_PER_ROW"
                        CFG.CHARMAP_CELLS_PER_ROW% = VAL(configValue$)
                    CASE "CHARMAP_ZOOM_LEVEL"
                        CFG.CHARMAP_ZOOM_LEVEL! = VAL(configValue$)
                    CASE "CHARMAP_CELL_W"
                        CFG.CHARMAP_CELL_W% = VAL(configValue$)
                    CASE "CHARMAP_CELL_H"
                        CFG.CHARMAP_CELL_H% = VAL(configValue$)
                    CASE "CHARMAP_CELL_PADDING"
                        CFG.CHARMAP_CELL_PADDING% = VAL(configValue$)
                    CASE "CHARMAP_DEFAULT_FONT"
                        CFG.CHARMAP_DEFAULT_FONT$ = configValue$
                    CASE "CHARMAP_MIN_FONT_SIZE"
                        CFG.CHARMAP_MIN_FONT_SIZE% = VAL(configValue$)
                    CASE "CHARMAP_MAX_FONT_SIZE"
                        CFG.CHARMAP_MAX_FONT_SIZE% = VAL(configValue$)
                    CASE "CHARMAP_CHAR_SELECTED"
                        CFG.CHARMAP_CHAR_SELECTED% = VAL(configValue$)
                    CASE "CHARMAP_USE_CHARS"
                        CFG.CHARMAP_USE_CHARS% = VAL(configValue$)
                    CASE "CHAR_GRID_WIDTH"
                        CFG.CHAR_GRID_WIDTH% = VAL(configValue$)
                    CASE "CHAR_GRID_HEIGHT"
                        CFG.CHAR_GRID_HEIGHT% = VAL(configValue$)
                    CASE "CHAR_GRID_OPACITY"
                        CFG.CHAR_GRID_OPACITY% = VAL(configValue$)
                    CASE "CHAR_GRID_COLOR_FG"
                        CFG.CHAR_GRID_COLOR_FG~& = _RGB32(VAL("&H" + LEFT$(configValue$, 2)), VAL("&H" + MID$(configValue$, 3, 2)), VAL("&H" + RIGHT$(configValue$, 2)))
                    CASE "CHARMAP_TAB_CHARS"
                        CFG.CHARMAP_TAB_CHARS% = VAL(configValue$)
                    CASE "DEFAULT_DSET_BRUSHES_FILE"
                        CFG.DEFAULT_DSET_BRUSHES_FILE$ = configValue$
                    CASE "DEFAULT_DSET_PATTERNS_FILE"
                        CFG.DEFAULT_DSET_PATTERNS_FILE$ = configValue$
                    CASE "DEFAULT_DSET_GRADIENTS_FILE"
                        CFG.DEFAULT_DSET_GRADIENTS_FILE$ = configValue$
                    CASE "DEFAULT_CANVAS_SIZE_W"
                        CFG.DEFAULT_CANVAS_SIZE_W% = VAL(configValue$)
                    CASE "DEFAULT_CANVAS_SIZE_H"
                        CFG.DEFAULT_CANVAS_SIZE_H% = VAL(configValue$)
                    CASE "CANVAS_APRON_COLOR"
                        CFG.CANVAS_APRON_COLOR~& = _RGB32(VAL("&H" + LEFT$(configValue$, 2)), VAL("&H" + MID$(configValue$, 3, 2)), VAL("&H" + RIGHT$(configValue$, 2)))
                    CASE ELSE
                        ' Check for RECENT_FILE_N pattern
                        IF LEFT$(configKey$, 12) = "RECENT_FILE_" THEN
                            DIM rcfNum AS INTEGER
                            rcfNum% = VAL(MID$(configKey$, 13))
                            IF rcfNum% >= 1 AND rcfNum% <= RECENT_FILES_MAX THEN
                                RECENT_FILES(rcfNum%) = configValue$
                                IF rcfNum% > RECENT_FILE_COUNT% THEN RECENT_FILE_COUNT% = rcfNum%
                            END IF
                        ' Check for RECENT_PREVIEW_FILE_N pattern
                        ELSEIF LEFT$(configKey$, 20) = "RECENT_PREVIEW_FILE_" THEN
                            DIM rpfNum AS INTEGER
                            rpfNum% = VAL(MID$(configKey$, 21))
                            IF rpfNum% >= 1 AND rpfNum% <= RECENT_PREVIEW_MAX THEN
                                RECENT_PREVIEW_FILES(rpfNum%) = configValue$
                                IF rpfNum% > RECENT_PREVIEW_COUNT% THEN RECENT_PREVIEW_COUNT% = rpfNum%
                            END IF
                        END IF
                END SELECT
            END IF
        END IF
    LOOP
    
    CLOSE #fh%
    
    ' Validate all configuration settings
    CFG_validate

    ' NOTE: CONFIG_upgrade is deferred to SCREEN_init (after screen exists)
    ' because it uses DRAW_alert which requires a valid screen 0.
END SUB


''
' Apply startup defaults from config AFTER all modules are initialized
' This must be called from DRAW.BAS after all includes are processed
' since it depends on global variables from other modules being initialized
'
SUB CONFIG_apply_startup_defaults ()
    ' Apply default tool (only if valid tool constant)
    IF CFG.DEFAULT_TOOL% >= 0 AND CFG.DEFAULT_TOOL% <= 12 THEN
        CURRENT_TOOL% = CFG.DEFAULT_TOOL%
        PREVIOUS_TOOL% = CFG.DEFAULT_TOOL%
    END IF

    ' Keep tool activation state aligned with the startup tool selection.
    IF CURRENT_TOOL% = TOOL_FILL THEN
        FILL_activate
    ELSE
        FILL_deactivate
    END IF
    IF CURRENT_TOOL% = TOOL_PICKER THEN
        PICKER_activate
    ELSE
        PICKER_deactivate
    END IF
    
    ' Apply default brush size (index 1-25)
    IF CFG.DEFAULT_BRUSH_SIZE% >= 1 AND CFG.DEFAULT_BRUSH_SIZE% <= 25 THEN
        BRUSH_SIZE.CURRENT = CFG.DEFAULT_BRUSH_SIZE%
    END IF
    
    ' Apply default brush shape (0=circle, 1=square -> internal: 0=circle, -1=square)
    IF CFG.DEFAULT_BRUSH_SHAPE% = 0 THEN
        BRUSH_SIZE.SHAPE = 0  ' Circle
    ELSE
        BRUSH_SIZE.SHAPE = -1 ' Square (QB64-PE TRUE = -1)
    END IF

    DRAWER_apply_config_defaults
    
    ' Seed per-operation dirs from legacy defaults if not explicitly set
    IF CFG.LAST_DIR_OPEN$ = "" AND CFG.DEFAULT_OPEN_DIR$ <> "" THEN
        CFG.LAST_DIR_OPEN$ = CFG.DEFAULT_OPEN_DIR$
    END IF
    IF CFG.LAST_DIR_SAVE$ = "" AND CFG.DEFAULT_SAVE_DIR$ <> "" THEN
        CFG.LAST_DIR_SAVE$ = CFG.DEFAULT_SAVE_DIR$
    END IF
    IF CFG.LAST_DIR_IMPORT$ = "" AND CFG.DEFAULT_OPEN_DIR$ <> "" THEN
        CFG.LAST_DIR_IMPORT$ = CFG.DEFAULT_OPEN_DIR$
    END IF
    ' Keep LAST_DIRECTORY$ for any code that still references it
    IF CFG.DEFAULT_SAVE_DIR$ <> "" AND LAST_DIRECTORY$ = "" THEN
        LAST_DIRECTORY$ = CFG.DEFAULT_SAVE_DIR$
    END IF
END SUB


''
' Validate ALL configuration values and apply safe defaults if invalid
' Uses _LOGWARN to report corrected values
'
SUB CFG_validate ()
    ' Validate FPS limits
    IF CFG.FPS_LIMIT% < 1 OR CFG.FPS_LIMIT% > 1000 THEN
        ERR_warn "Config: FPS_LIMIT out of range (" + _TRIM$(STR$(CFG.FPS_LIMIT%)) + "), using default 60"
        CFG.FPS_LIMIT% = 60
    END IF
    IF CFG.FPS_IDLE% < 1 OR CFG.FPS_IDLE% > 1000 THEN
        ERR_warn "Config: FPS_IDLE out of range (" + _TRIM$(STR$(CFG.FPS_IDLE%)) + "), using default 15"
        CFG.FPS_IDLE% = 15
    END IF
    IF CFG.FPS_CURSOR% < 1 OR CFG.FPS_CURSOR% > 1000 THEN
        ERR_warn "Config: FPS_CURSOR out of range (" + _TRIM$(STR$(CFG.FPS_CURSOR%)) + "), using default 240"
        CFG.FPS_CURSOR% = 240
    END IF
    IF CFG.FPS_DIALOG% < 1 OR CFG.FPS_DIALOG% > 1000 THEN
        ERR_warn "Config: FPS_DIALOG out of range (" + _TRIM$(STR$(CFG.FPS_DIALOG%)) + "), using default 60"
        CFG.FPS_DIALOG% = 60
    END IF
    
    ' Validate display scale max (1-8, default 8)
    IF CFG.DISPLAY_SCALE_MAX% < 1 OR CFG.DISPLAY_SCALE_MAX% > 8 THEN
        ERR_warn "Config: DISPLAY_SCALE_MAX out of range (" + _TRIM$(STR$(CFG.DISPLAY_SCALE_MAX%)) + "), using default 8"
        CFG.DISPLAY_SCALE_MAX% = 8
    END IF
    
    ' Validate display scale (0-8, where 0 = auto-detect)
    IF CFG.DISPLAY_SCALE% < 0 OR CFG.DISPLAY_SCALE% > CFG.DISPLAY_SCALE_MAX% THEN
        ERR_warn "Config: DISPLAY_SCALE out of range (" + _TRIM$(STR$(CFG.DISPLAY_SCALE%)) + "), using auto-detect"
        CFG.DISPLAY_SCALE% = 0
    END IF
    
    ' Validate toolbar scale (0=auto, 1-4 explicit)
    IF CFG.TOOLBAR_SCALE% < 0 OR CFG.TOOLBAR_SCALE% > 4 THEN
        ERR_warn "Config: TOOLBAR_SCALE out of range (" + _TRIM$(STR$(CFG.TOOLBAR_SCALE%)) + "), using auto"
        CFG.TOOLBAR_SCALE% = 0
    END IF
    IF CFG.FD_FONT_SCALE% < 1 OR CFG.FD_FONT_SCALE% > 4 THEN
        CFG.FD_FONT_SCALE% = 1
    END IF
    IF CFG.FD_FONT% <> 8 AND CFG.FD_FONT% <> 16 THEN CFG.FD_FONT% = 16
    IF CFG.FD_DIALOG_W% < 0 THEN CFG.FD_DIALOG_W% = 0
    IF CFG.FD_DIALOG_H% < 0 THEN CFG.FD_DIALOG_H% = 0
    
    ' Validate nudge amount (1-100, default 10)
    IF CFG.NUDGE_N% < 1 OR CFG.NUDGE_N% > 100 THEN
        ERR_warn "Config: NUDGE_N out of range (" + _TRIM$(STR$(CFG.NUDGE_N%)) + "), using default 10"
        CFG.NUDGE_N% = 10
    END IF
    
    ' Validate number of layers (1-64, default 32)
    IF CFG.NUM_LAYERS% < 1 OR CFG.NUM_LAYERS% > 64 THEN
        ERR_warn "Config: NUM_LAYERS out of range (" + _TRIM$(STR$(CFG.NUM_LAYERS%)) + "), using default 32"
        CFG.NUM_LAYERS% = 32
    END IF
    
    ' Validate number of custom brushes (1-16, default 4)
    IF CFG.NUM_CUSTOM_BRUSHES% < 1 OR CFG.NUM_CUSTOM_BRUSHES% > 16 THEN
        ERR_warn "Config: NUM_CUSTOM_BRUSHES out of range (" + _TRIM$(STR$(CFG.NUM_CUSTOM_BRUSHES%)) + "), using default 4"
        CFG.NUM_CUSTOM_BRUSHES% = 4
    END IF
    
    ' Validate screen dimensions (0 = auto, or minimum 16x16)
    IF CFG.SCREEN_WIDTH% <> 0 AND CFG.SCREEN_WIDTH% < 16 THEN
        ERR_warn "Config: SCREEN_WIDTH too small (" + _TRIM$(STR$(CFG.SCREEN_WIDTH%)) + "), using auto-detect"
        CFG.SCREEN_WIDTH% = 0
    END IF
    IF CFG.SCREEN_HEIGHT% <> 0 AND CFG.SCREEN_HEIGHT% < 16 THEN
        ERR_warn "Config: SCREEN_HEIGHT too small (" + _TRIM$(STR$(CFG.SCREEN_HEIGHT%)) + "), using auto-detect"
        CFG.SCREEN_HEIGHT% = 0
    END IF
    
    ' Validate window minimum dimensions (0=use default 320x200, min 64)
    IF CFG.WIN_MIN_WIDTH% < 0 THEN CFG.WIN_MIN_WIDTH% = 0
    IF CFG.WIN_MIN_WIDTH% > 0 AND CFG.WIN_MIN_WIDTH% < 64 THEN
        ERR_warn "Config: WIN_MIN_WIDTH too small (" + _TRIM$(STR$(CFG.WIN_MIN_WIDTH%)) + "), using 64"
        CFG.WIN_MIN_WIDTH% = 64
    END IF
    IF CFG.WIN_MIN_HEIGHT% < 0 THEN CFG.WIN_MIN_HEIGHT% = 0
    IF CFG.WIN_MIN_HEIGHT% > 0 AND CFG.WIN_MIN_HEIGHT% < 64 THEN
        ERR_warn "Config: WIN_MIN_HEIGHT too small (" + _TRIM$(STR$(CFG.WIN_MIN_HEIGHT%)) + "), using 64"
        CFG.WIN_MIN_HEIGHT% = 64
    END IF
    
    ' Validate window maximum dimensions (0=unlimited)
    IF CFG.WIN_MAX_WIDTH% < 0 THEN CFG.WIN_MAX_WIDTH% = 0
    IF CFG.WIN_MAX_WIDTH% > 0 AND CFG.WIN_MAX_WIDTH% < 64 THEN
        ERR_warn "Config: WIN_MAX_WIDTH too small (" + _TRIM$(STR$(CFG.WIN_MAX_WIDTH%)) + "), using unlimited"
        CFG.WIN_MAX_WIDTH% = 0
    END IF
    IF CFG.WIN_MAX_HEIGHT% < 0 THEN CFG.WIN_MAX_HEIGHT% = 0
    IF CFG.WIN_MAX_HEIGHT% > 0 AND CFG.WIN_MAX_HEIGHT% < 64 THEN
        ERR_warn "Config: WIN_MAX_HEIGHT too small (" + _TRIM$(STR$(CFG.WIN_MAX_HEIGHT%)) + "), using unlimited"
        CFG.WIN_MAX_HEIGHT% = 0
    END IF
    
    ' Ensure max >= min when both are set
    IF CFG.WIN_MAX_WIDTH% > 0 AND CFG.WIN_MIN_WIDTH% > 0 AND CFG.WIN_MAX_WIDTH% < CFG.WIN_MIN_WIDTH% THEN
        ERR_warn "Config: WIN_MAX_WIDTH < WIN_MIN_WIDTH, using unlimited"
        CFG.WIN_MAX_WIDTH% = 0
    END IF
    IF CFG.WIN_MAX_HEIGHT% > 0 AND CFG.WIN_MIN_HEIGHT% > 0 AND CFG.WIN_MAX_HEIGHT% < CFG.WIN_MIN_HEIGHT% THEN
        ERR_warn "Config: WIN_MAX_HEIGHT < WIN_MIN_HEIGHT, using unlimited"
        CFG.WIN_MAX_HEIGHT% = 0
    END IF
    
    ' Validate angle snap degrees (valid options: 15, 30, 45, 90)
    SELECT CASE CFG.ANGLE_SNAP_DEGREES%
        CASE 15, 30, 45, 90
            ' Valid values
        CASE ELSE
            ERR_warn "Config: ANGLE_SNAP_DEGREES invalid (" + _TRIM$(STR$(CFG.ANGLE_SNAP_DEGREES%)) + "), using default 45"
            CFG.ANGLE_SNAP_DEGREES% = 45
    END SELECT
    
    ' Validate palette picker settings
    IF CFG.PALETTE_PICKER_CHIP_SIZE% < 8 OR CFG.PALETTE_PICKER_CHIP_SIZE% > 48 THEN
        ERR_warn "Config: PALETTE_PICKER_CHIP_SIZE out of range, using default 10"
        CFG.PALETTE_PICKER_CHIP_SIZE% = 10
    END IF
    IF CFG.PALETTE_PICKER_CHIP_PADDING% < 1 OR CFG.PALETTE_PICKER_CHIP_PADDING% > 16 THEN
        ERR_warn "Config: PALETTE_PICKER_CHIP_PADDING out of range, using default 2"
        CFG.PALETTE_PICKER_CHIP_PADDING% = 2
    END IF
    IF CFG.PALETTE_PICKER_COLUMNS% < 8 OR CFG.PALETTE_PICKER_COLUMNS% > 64 THEN
        ERR_warn "Config: PALETTE_PICKER_COLUMNS out of range, using default 32"
        CFG.PALETTE_PICKER_COLUMNS% = 32
    END IF
    ' Validate palette create max colors (1-256)
    IF CFG.PALETTE_CREATE_MAX_COLORS% < 1 OR CFG.PALETTE_CREATE_MAX_COLORS% > 256 THEN
        CFG.PALETTE_CREATE_MAX_COLORS% = 32
    END IF
    
    ' Validate layer panel width (min 40, max 400)
    IF CFG.LAYER_PANEL_WIDTH% < 40 OR CFG.LAYER_PANEL_WIDTH% > 400 THEN
        ERR_warn "Config: LAYER_PANEL_WIDTH out of range (" + _TRIM$(STR$(CFG.LAYER_PANEL_WIDTH%)) + "), using default 100"
        CFG.LAYER_PANEL_WIDTH% = 100
    END IF

    ' Validate dock edge values
    IF CFG.LAYERS_PANEL_DOCK_EDGE <> "LEFT" AND CFG.LAYERS_PANEL_DOCK_EDGE <> "RIGHT" THEN
        ERR_warn "Config: LAYERS_PANEL_DOCK_EDGE invalid (" + _TRIM$(CFG.LAYERS_PANEL_DOCK_EDGE) + "), using LEFT"
        CFG.LAYERS_PANEL_DOCK_EDGE = "LEFT"
    END IF
    IF CFG.TOOLBOX_DOCK_EDGE <> "LEFT" AND CFG.TOOLBOX_DOCK_EDGE <> "RIGHT" THEN
        ERR_warn "Config: TOOLBOX_DOCK_EDGE invalid (" + _TRIM$(CFG.TOOLBOX_DOCK_EDGE) + "), using RIGHT"
        CFG.TOOLBOX_DOCK_EDGE = "RIGHT"
    END IF

    ' Validate layer name max length (1-64, default 16)
    IF CFG.LAYER_NAME_MAX_LEN% < 1 OR CFG.LAYER_NAME_MAX_LEN% > LAYER_NAME_HARD_MAX THEN
        ERR_warn "Config: LAYER_NAME_MAX_LEN out of range (" + _TRIM$(STR$(CFG.LAYER_NAME_MAX_LEN%)) + "), using default 16"
        CFG.LAYER_NAME_MAX_LEN% = 16
    END IF

    ' Validate grid opacity (0=use theme, 1-255=explicit alpha)
    IF CFG.GRID_OPACITY% < 0 OR CFG.GRID_OPACITY% > 255 THEN
        ERR_warn "Config: GRID_OPACITY out of range (" + _TRIM$(STR$(CFG.GRID_OPACITY%)) + "), using theme default"
        CFG.GRID_OPACITY% = 0
    END IF

    ' Validate grid size X (1-256, default 10)
    IF CFG.GRID_SIZE_X% < 1 OR CFG.GRID_SIZE_X% > 256 THEN
        ERR_warn "Config: GRID_SIZE_X out of range (" + _TRIM$(STR$(CFG.GRID_SIZE_X%)) + "), using default 10"
        CFG.GRID_SIZE_X% = 10
    END IF

    ' Validate grid size Y (1-256, default 10)
    IF CFG.GRID_SIZE_Y% < 1 OR CFG.GRID_SIZE_Y% > 256 THEN
        ERR_warn "Config: GRID_SIZE_Y out of range (" + _TRIM$(STR$(CFG.GRID_SIZE_Y%)) + "), using default 10"
        CFG.GRID_SIZE_Y% = 10
    END IF

    ' Validate crosshair opacity (0=use theme, 1-255=explicit alpha)
    IF CFG.CROSSHAIR_OPACITY% < 0 OR CFG.CROSSHAIR_OPACITY% > 255 THEN
        ERR_warn "Config: CROSSHAIR_OPACITY out of range (" + _TRIM$(STR$(CFG.CROSSHAIR_OPACITY%)) + "), using theme default"
        CFG.CROSSHAIR_OPACITY% = 0
    END IF

    IF CFG.CROSSHAIR_FONT_SIZE% <> CONFIG_USE_THEME_DEFAULT% THEN
        IF CFG.CROSSHAIR_FONT_SIZE% < 4 OR CFG.CROSSHAIR_FONT_SIZE% > 64 THEN
            ERR_warn "Config: CROSSHAIR_FONT_SIZE out of range (" + _TRIM$(STR$(CFG.CROSSHAIR_FONT_SIZE%)) + "), using theme default"
            CFG.CROSSHAIR_FONT_SIZE% = CONFIG_USE_THEME_DEFAULT%
        END IF
    END IF

    IF CFG.CROSSHAIR_FONT_STROKE_WIDTH% <> CONFIG_USE_THEME_DEFAULT% THEN
        IF CFG.CROSSHAIR_FONT_STROKE_WIDTH% < 0 OR CFG.CROSSHAIR_FONT_STROKE_WIDTH% > 8 THEN
            ERR_warn "Config: CROSSHAIR_FONT_STROKE_WIDTH out of range (" + _TRIM$(STR$(CFG.CROSSHAIR_FONT_STROKE_WIDTH%)) + "), using theme default"
            CFG.CROSSHAIR_FONT_STROKE_WIDTH% = CONFIG_USE_THEME_DEFAULT%
        END IF
    END IF

    ' Validate crosshair angle (0=use theme, -360 to 360 degrees)
    IF CFG.CROSSHAIR_ANGLE! < -360 OR CFG.CROSSHAIR_ANGLE! > 360 THEN
        ERR_warn "Config: CROSSHAIR_ANGLE out of range (" + _TRIM$(STR$(CFG.CROSSHAIR_ANGLE!)) + "), using theme default"
        CFG.CROSSHAIR_ANGLE! = 0
    END IF

    ' Validate crosshair outline settings
    IF CFG.CROSSHAIR_OUTLINE_OPACITY% < 0 OR CFG.CROSSHAIR_OUTLINE_OPACITY% > 255 THEN
        ERR_warn "Config: CROSSHAIR_OUTLINE_OPACITY out of range (" + _TRIM$(STR$(CFG.CROSSHAIR_OUTLINE_OPACITY%)) + "), using theme default"
        CFG.CROSSHAIR_OUTLINE_OPACITY% = 0
    END IF
    IF CFG.CROSSHAIR_OUTLINE_WIDTH% <> CONFIG_USE_THEME_DEFAULT% THEN
        IF CFG.CROSSHAIR_OUTLINE_WIDTH% < 0 OR CFG.CROSSHAIR_OUTLINE_WIDTH% > 8 THEN
            ERR_warn "Config: CROSSHAIR_OUTLINE_WIDTH out of range (" + _TRIM$(STR$(CFG.CROSSHAIR_OUTLINE_WIDTH%)) + "), using theme default"
            CFG.CROSSHAIR_OUTLINE_WIDTH% = CONFIG_USE_THEME_DEFAULT%
        END IF
    END IF

    ' Validate picker loupe settings
    IF CFG.PICKER_LOUPE_ZOOM_LEVEL% <> CONFIG_USE_THEME_DEFAULT% THEN
        IF CFG.PICKER_LOUPE_ZOOM_LEVEL% < 1 OR CFG.PICKER_LOUPE_ZOOM_LEVEL% > 64 THEN
            ERR_warn "Config: PICKER_LOUPE_ZOOM_LEVEL out of range (" + _TRIM$(STR$(CFG.PICKER_LOUPE_ZOOM_LEVEL%)) + "), using theme default"
            CFG.PICKER_LOUPE_ZOOM_LEVEL% = CONFIG_USE_THEME_DEFAULT%
        END IF
    END IF
    IF CFG.PICKER_LOUPE_RECT_X_OFFSET% <> CONFIG_USE_THEME_DEFAULT% THEN
        IF CFG.PICKER_LOUPE_RECT_X_OFFSET% < -1024 OR CFG.PICKER_LOUPE_RECT_X_OFFSET% > 1024 THEN
            ERR_warn "Config: PICKER_LOUPE_RECT_X_OFFSET out of range (" + _TRIM$(STR$(CFG.PICKER_LOUPE_RECT_X_OFFSET%)) + "), using theme default"
            CFG.PICKER_LOUPE_RECT_X_OFFSET% = CONFIG_USE_THEME_DEFAULT%
        END IF
    END IF
    IF CFG.PICKER_LOUPE_RECT_Y_OFFSET% <> CONFIG_USE_THEME_DEFAULT% THEN
        IF CFG.PICKER_LOUPE_RECT_Y_OFFSET% < -1024 OR CFG.PICKER_LOUPE_RECT_Y_OFFSET% > 1024 THEN
            ERR_warn "Config: PICKER_LOUPE_RECT_Y_OFFSET out of range (" + _TRIM$(STR$(CFG.PICKER_LOUPE_RECT_Y_OFFSET%)) + "), using theme default"
            CFG.PICKER_LOUPE_RECT_Y_OFFSET% = CONFIG_USE_THEME_DEFAULT%
        END IF
    END IF
    IF CFG.PICKER_LOUPE_RECT_WIDTH% <> CONFIG_USE_THEME_DEFAULT% THEN
        IF CFG.PICKER_LOUPE_RECT_WIDTH% < 24 OR CFG.PICKER_LOUPE_RECT_WIDTH% > 512 THEN
            ERR_warn "Config: PICKER_LOUPE_RECT_WIDTH out of range (" + _TRIM$(STR$(CFG.PICKER_LOUPE_RECT_WIDTH%)) + "), using theme default"
            CFG.PICKER_LOUPE_RECT_WIDTH% = CONFIG_USE_THEME_DEFAULT%
        END IF
    END IF
    IF CFG.PICKER_LOUPE_RECT_HEIGHT% <> CONFIG_USE_THEME_DEFAULT% THEN
        IF CFG.PICKER_LOUPE_RECT_HEIGHT% < 24 OR CFG.PICKER_LOUPE_RECT_HEIGHT% > 512 THEN
            ERR_warn "Config: PICKER_LOUPE_RECT_HEIGHT out of range (" + _TRIM$(STR$(CFG.PICKER_LOUPE_RECT_HEIGHT%)) + "), using theme default"
            CFG.PICKER_LOUPE_RECT_HEIGHT% = CONFIG_USE_THEME_DEFAULT%
        END IF
    END IF
    IF CFG.PICKER_LOUPE_RGBA_X% <> CONFIG_USE_THEME_DEFAULT% THEN
        IF CFG.PICKER_LOUPE_RGBA_X% < -1024 OR CFG.PICKER_LOUPE_RGBA_X% > 1024 THEN
            ERR_warn "Config: PICKER_LOUPE_RGBA_X out of range (" + _TRIM$(STR$(CFG.PICKER_LOUPE_RGBA_X%)) + "), using theme default"
            CFG.PICKER_LOUPE_RGBA_X% = CONFIG_USE_THEME_DEFAULT%
        END IF
    END IF
    IF CFG.PICKER_LOUPE_RGBA_Y% <> CONFIG_USE_THEME_DEFAULT% THEN
        IF CFG.PICKER_LOUPE_RGBA_Y% < -1024 OR CFG.PICKER_LOUPE_RGBA_Y% > 1024 THEN
            ERR_warn "Config: PICKER_LOUPE_RGBA_Y out of range (" + _TRIM$(STR$(CFG.PICKER_LOUPE_RGBA_Y%)) + "), using theme default"
            CFG.PICKER_LOUPE_RGBA_Y% = CONFIG_USE_THEME_DEFAULT%
        END IF
    END IF
    IF CFG.PICKER_LOUPE_FONT_SIZE% <> CONFIG_USE_THEME_DEFAULT% THEN
        IF CFG.PICKER_LOUPE_FONT_SIZE% < 4 OR CFG.PICKER_LOUPE_FONT_SIZE% > 64 THEN
            ERR_warn "Config: PICKER_LOUPE_FONT_SIZE out of range (" + _TRIM$(STR$(CFG.PICKER_LOUPE_FONT_SIZE%)) + "), using theme default"
            CFG.PICKER_LOUPE_FONT_SIZE% = CONFIG_USE_THEME_DEFAULT%
        END IF
    END IF
    IF CFG.PICKER_LOUPE_FONT_STROKE_WIDTH% <> CONFIG_USE_THEME_DEFAULT% THEN
        IF CFG.PICKER_LOUPE_FONT_STROKE_WIDTH% < 0 OR CFG.PICKER_LOUPE_FONT_STROKE_WIDTH% > 8 THEN
            ERR_warn "Config: PICKER_LOUPE_FONT_STROKE_WIDTH out of range (" + _TRIM$(STR$(CFG.PICKER_LOUPE_FONT_STROKE_WIDTH%)) + "), using theme default"
            CFG.PICKER_LOUPE_FONT_STROKE_WIDTH% = CONFIG_USE_THEME_DEFAULT%
        END IF
    END IF
    IF CFG.PICKER_LOUPE_RECT_STROKE_WIDTH% <> CONFIG_USE_THEME_DEFAULT% THEN
        IF CFG.PICKER_LOUPE_RECT_STROKE_WIDTH% < 1 OR CFG.PICKER_LOUPE_RECT_STROKE_WIDTH% > 16 THEN
            ERR_warn "Config: PICKER_LOUPE_RECT_STROKE_WIDTH out of range (" + _TRIM$(STR$(CFG.PICKER_LOUPE_RECT_STROKE_WIDTH%)) + "), using theme default"
            CFG.PICKER_LOUPE_RECT_STROKE_WIDTH% = CONFIG_USE_THEME_DEFAULT%
        END IF
    END IF

    ' Validate grid mode (0-3)
    IF CFG.GRID_MODE% < 0 OR CFG.GRID_MODE% >= GRID_MODE_COUNT THEN
        ERR_warn "Config: GRID_MODE out of range (" + _TRIM$(STR$(CFG.GRID_MODE%)) + "), using square"
        CFG.GRID_MODE% = 0
    END IF

    ' Validate grid angle (0=use theme, -360 to 360 degrees)
    IF CFG.GRID_ANGLE! < -360 OR CFG.GRID_ANGLE! > 360 THEN
        ERR_warn "Config: GRID_ANGLE out of range (" + _TRIM$(STR$(CFG.GRID_ANGLE!)) + "), using theme default"
        CFG.GRID_ANGLE! = 0
    END IF

    ' Validate pixel grid opacity (0=use theme, 1-255=explicit alpha)
    IF CFG.PIXELGRID_OPACITY% < 0 OR CFG.PIXELGRID_OPACITY% > 255 THEN
        ERR_warn "Config: PIXELGRID_OPACITY out of range (" + _TRIM$(STR$(CFG.PIXELGRID_OPACITY%)) + "), using theme default"
        CFG.PIXELGRID_OPACITY% = 0
    END IF
    
    ' Validate transparency checkerboard size X (0=use theme, 1-64=explicit)
    IF CFG.TRANSPARENCY_CHECK_SIZE_X% < 0 OR CFG.TRANSPARENCY_CHECK_SIZE_X% > 64 THEN
        ERR_warn "Config: TRANSPARENCY_CHECK_SIZE_X out of range (" + _TRIM$(STR$(CFG.TRANSPARENCY_CHECK_SIZE_X%)) + "), using theme default"
        CFG.TRANSPARENCY_CHECK_SIZE_X% = 0
    END IF

    ' Validate transparency checkerboard size Y (0=use theme, 1-64=explicit)
    IF CFG.TRANSPARENCY_CHECK_SIZE_Y% < 0 OR CFG.TRANSPARENCY_CHECK_SIZE_Y% > 64 THEN
        ERR_warn "Config: TRANSPARENCY_CHECK_SIZE_Y out of range (" + _TRIM$(STR$(CFG.TRANSPARENCY_CHECK_SIZE_Y%)) + "), using theme default"
        CFG.TRANSPARENCY_CHECK_SIZE_Y% = 0
    END IF
    
    ' Validate scrollbar opacity (0=default, 1-255=explicit)
    IF CFG.SCROLLBAR_OPACITY% < 0 OR CFG.SCROLLBAR_OPACITY% > 255 THEN
        ERR_warn "Config: SCROLLBAR_OPACITY out of range (" + _TRIM$(STR$(CFG.SCROLLBAR_OPACITY%)) + "), using default 180"
        CFG.SCROLLBAR_OPACITY% = 0
    END IF
    
    ' Validate default tool (1-12 for valid tool constants, or 0 for null)
    IF CFG.DEFAULT_TOOL% < 0 OR CFG.DEFAULT_TOOL% > 12 THEN
        ERR_warn "Config: DEFAULT_TOOL out of range (" + _TRIM$(STR$(CFG.DEFAULT_TOOL%)) + "), using default 3 (dot)"
        CFG.DEFAULT_TOOL% = 3
    END IF
    
    ' Validate default brush size (1-25, index into brush sizes array)
    IF CFG.DEFAULT_BRUSH_SIZE% < 1 OR CFG.DEFAULT_BRUSH_SIZE% > 25 THEN
        ERR_warn "Config: DEFAULT_BRUSH_SIZE out of range (" + _TRIM$(STR$(CFG.DEFAULT_BRUSH_SIZE%)) + "), using default 1"
        CFG.DEFAULT_BRUSH_SIZE% = 1
    END IF
    
    ' Validate default brush shape (0=circle, 1=square)
    IF CFG.DEFAULT_BRUSH_SHAPE% < 0 OR CFG.DEFAULT_BRUSH_SHAPE% > 1 THEN
        ERR_warn "Config: DEFAULT_BRUSH_SHAPE out of range (" + _TRIM$(STR$(CFG.DEFAULT_BRUSH_SHAPE%)) + "), using default 1 (square)"
        CFG.DEFAULT_BRUSH_SHAPE% = 1
    END IF

    IF CFG.DEFAULT_DRAW_MODE% < 1 OR CFG.DEFAULT_DRAW_MODE% > 3 THEN
        ERR_warn "Config: DEFAULT_DRAW_MODE out of range (" + _TRIM$(STR$(CFG.DEFAULT_DRAW_MODE%)) + "), using default 1 (color)"
        CFG.DEFAULT_DRAW_MODE% = 1
    END IF

    IF CFG.DEFAULT_BIN_MODE% < 1 OR CFG.DEFAULT_BIN_MODE% > 3 THEN
        ERR_warn "Config: DEFAULT_BIN_MODE out of range (" + _TRIM$(STR$(CFG.DEFAULT_BIN_MODE%)) + "), using default 1 (brush bins)"
        CFG.DEFAULT_BIN_MODE% = 1
    END IF

    IF CFG.CHARMAP_CELLS_PER_ROW% < 4 OR CFG.CHARMAP_CELLS_PER_ROW% > 16 THEN
        ERR_warn "Config: CHARMAP_CELLS_PER_ROW out of range (" + _TRIM$(STR$(CFG.CHARMAP_CELLS_PER_ROW%)) + "), using default 16"
        CFG.CHARMAP_CELLS_PER_ROW% = 16
    END IF

    IF CFG.CHARMAP_ZOOM_LEVEL! < 0.25 OR CFG.CHARMAP_ZOOM_LEVEL! > 4.0 THEN
        ERR_warn "Config: CHARMAP_ZOOM_LEVEL out of range (" + _TRIM$(STR$(CFG.CHARMAP_ZOOM_LEVEL!)) + "), using default 1.0"
        CFG.CHARMAP_ZOOM_LEVEL! = 1.0
    END IF

    IF CFG.CHARMAP_MIN_FONT_SIZE% < 4 OR CFG.CHARMAP_MIN_FONT_SIZE% > 128 THEN
        ERR_warn "Config: CHARMAP_MIN_FONT_SIZE out of range (" + _TRIM$(STR$(CFG.CHARMAP_MIN_FONT_SIZE%)) + "), using default 4"
        CFG.CHARMAP_MIN_FONT_SIZE% = 4
    END IF

    IF CFG.CHARMAP_MAX_FONT_SIZE% < 4 OR CFG.CHARMAP_MAX_FONT_SIZE% > 128 THEN
        ERR_warn "Config: CHARMAP_MAX_FONT_SIZE out of range (" + _TRIM$(STR$(CFG.CHARMAP_MAX_FONT_SIZE%)) + "), using default 16"
        CFG.CHARMAP_MAX_FONT_SIZE% = 16
    END IF

    IF CFG.CHARMAP_MAX_FONT_SIZE% < CFG.CHARMAP_MIN_FONT_SIZE% THEN
        ERR_warn "Config: CHARMAP_MAX_FONT_SIZE < CHARMAP_MIN_FONT_SIZE, using min value"
        CFG.CHARMAP_MAX_FONT_SIZE% = CFG.CHARMAP_MIN_FONT_SIZE%
    END IF
    
    ' Also validate palette strip settings
    CONFIG_validate_palette_strip
END SUB


''
' Save current configuration to disk
' 
SUB CONFIG_save ()
    DIM fh AS INTEGER
    
    fh% = FREEFILE
    OPEN CONFIG_FILE_PATH$ FOR OUTPUT AS #fh%
    
    ' Write header comment
    PRINT #fh%, "# DRAW Configuration File"
    PRINT #fh%, "# Auto-generated by DRAW"
    PRINT #fh%, "# Edit values as needed, changes will be loaded on next run"
    PRINT #fh%, ""
    
    ' Write configuration values
    PRINT #fh%, "# Theme name (default: DEFAULT)"
    PRINT #fh%, "THEME=" + CFG.THEME$
    PRINT #fh%, ""
    
    PRINT #fh%, "# Fullscreen mode (1=true, 0=false)"
    PRINT #fh%, "FULLSCREEN=" + _TRIM$(STR$(CFG.FULLSCREEN%))
    PRINT #fh%, ""
    
    PRINT #fh%, "# Display scale multiplier (0=auto-detect from desktop, 1-8=explicit)"
    PRINT #fh%, "# Auto-detect: 4K=4x, 1440p=3x, 1080p=2x, else 1x"
    IF CFG.DISPLAY_SCALE% > 0 THEN
        PRINT #fh%, "DISPLAY_SCALE=" + _TRIM$(STR$(CFG.DISPLAY_SCALE%))
    ELSE
        ' Save resolved value so reload is consistent with SCREEN_WIDTH/HEIGHT
        PRINT #fh%, "DISPLAY_SCALE=" + _TRIM$(STR$(SCRN.displayScale%))
    END IF
    PRINT #fh%, ""
    
    PRINT #fh%, "# Maximum display scale multiplier (1-8, default: 8)"
    PRINT #fh%, "DISPLAY_SCALE_MAX=" + _TRIM$(STR$(CFG.DISPLAY_SCALE_MAX%))
    PRINT #fh%, ""
    
    PRINT #fh%, "# Screen dimensions (0=auto-detect from desktop resolution)"
    PRINT #fh%, "# When 0, auto-detects viewport from desktop size / display scale"
    IF CFG.SCREEN_WIDTH% > 0 THEN
        PRINT #fh%, "SCREEN_WIDTH=" + _TRIM$(STR$(CFG.SCREEN_WIDTH%))
    ELSE
        PRINT #fh%, "SCREEN_WIDTH=" + _TRIM$(STR$(SCRN.w&))
    END IF
    IF CFG.SCREEN_HEIGHT% > 0 THEN
        PRINT #fh%, "SCREEN_HEIGHT=" + _TRIM$(STR$(CFG.SCREEN_HEIGHT%))
    ELSE
        PRINT #fh%, "SCREEN_HEIGHT=" + _TRIM$(STR$(SCRN.h&))
    END IF
    PRINT #fh%, ""

    PRINT #fh%, "# Live WIP BAS stream in DEV/<name>-wip.bas (1=enabled, 0=disabled)"
    PRINT #fh%, "BAS_WIP_ENABLED=" + _TRIM$(STR$(CFG.BAS_WIP_ENABLED%))
    PRINT #fh%, ""
    
    PRINT #fh%, "# Window viewport minimum size (0=default: 320x200)"
    PRINT #fh%, "# When loading small images, viewport never shrinks below this"
    PRINT #fh%, "WIN_MIN_WIDTH=" + _TRIM$(STR$(CFG.WIN_MIN_WIDTH%))
    PRINT #fh%, "WIN_MIN_HEIGHT=" + _TRIM$(STR$(CFG.WIN_MIN_HEIGHT%))
    PRINT #fh%, ""
    
    PRINT #fh%, "# Window viewport maximum size (0=unlimited, grows to fit canvas)"
    PRINT #fh%, "# When loading large images, viewport caps at this size"
    PRINT #fh%, "# Canvas larger than viewport is navigable via scrollbars or middle-click pan"
    PRINT #fh%, "WIN_MAX_WIDTH=" + _TRIM$(STR$(CFG.WIN_MAX_WIDTH%))
    PRINT #fh%, "WIN_MAX_HEIGHT=" + _TRIM$(STR$(CFG.WIN_MAX_HEIGHT%))
    PRINT #fh%, ""
    
    ' Validate and save toolbar scale
    IF CFG.TOOLBAR_SCALE% < 0 THEN CFG.TOOLBAR_SCALE% = 0
    IF CFG.TOOLBAR_SCALE% > 4 THEN CFG.TOOLBAR_SCALE% = 4
    PRINT #fh%, "# Toolbar icon scale multiplier (0=auto, 1-4 explicit)"
    PRINT #fh%, "# 0 = auto-detect from viewport size"
    PRINT #fh%, "# 1 = 11x11 icons, 2 = 22x22, 3 = 33x33, 4 = 44x44"
    ' Save resolved value for consistency
    DIM tbScaleToSave AS INTEGER
    IF CFG.TOOLBAR_SCALE% > 0 THEN
        tbScaleToSave% = CFG.TOOLBAR_SCALE%
    ELSE
        tbScaleToSave% = 1 ' fallback if somehow not resolved
    END IF
    PRINT #fh%, "TOOLBAR_SCALE=" + _TRIM$(STR$(tbScaleToSave%))
    PRINT #fh%, ""
    
    PRINT #fh%, "# File dialog font scale multiplier (1-4, default 1)"
    PRINT #fh%, "# Controls text size in all file open/save dialogs"
    IF CFG.FD_FONT_SCALE% < 1 THEN CFG.FD_FONT_SCALE% = 1
    IF CFG.FD_FONT_SCALE% > 4 THEN CFG.FD_FONT_SCALE% = 4
    PRINT #fh%, "FD_FONT_SCALE=" + _TRIM$(STR$(CFG.FD_FONT_SCALE%))
    PRINT #fh%, ""
    
    PRINT #fh%, "# File dialog font (8=8x8 compact, 16=8x16 standard)"
    IF CFG.FD_FONT% <> 8 AND CFG.FD_FONT% <> 16 THEN CFG.FD_FONT% = 16
    PRINT #fh%, "FD_FONT=" + _TRIM$(STR$(CFG.FD_FONT%))
    PRINT #fh%, ""
    
    PRINT #fh%, "# File dialog size in logical pixels (0=auto, scales to ~60%%x70%% of screen)"
    PRINT #fh%, "# Minimum: 300x350. Actual pixel size = value * TOOLBAR_SCALE"
    IF CFG.FD_DIALOG_W% < 0 THEN CFG.FD_DIALOG_W% = 0
    IF CFG.FD_DIALOG_H% < 0 THEN CFG.FD_DIALOG_H% = 0
    PRINT #fh%, "FD_DIALOG_W=" + _TRIM$(STR$(CFG.FD_DIALOG_W%))
    PRINT #fh%, "FD_DIALOG_H=" + _TRIM$(STR$(CFG.FD_DIALOG_H%))
    PRINT #fh%, ""
    
    PRINT #fh%, "# Default palette file (empty=use built-in default)"
    PRINT #fh%, "DEFAULT_PALETTE=" + CFG.DEFAULT_PALETTE$
    PRINT #fh%, ""
    
    PRINT #fh%, "# Nudge amount for arrow key movements"
    PRINT #fh%, "NUDGE_N=" + _TRIM$(STR$(CFG.NUDGE_N%))
    PRINT #fh%, ""
    
    PRINT #fh%, "# Number of custom brush slots"
    PRINT #fh%, "NUM_CUSTOM_BRUSHES=" + _TRIM$(STR$(CFG.NUM_CUSTOM_BRUSHES%))
    PRINT #fh%, ""
    
    PRINT #fh%, "# Number of layers"
    PRINT #fh%, "NUM_LAYERS=" + _TRIM$(STR$(CFG.NUM_LAYERS%))
    PRINT #fh%, ""
    
    PRINT #fh%, "# FPS limits (valid range: 1-1000)"
    PRINT #fh%, "# FPS_LIMIT: Active drawing frame rate â€” used during painting, tool use, and other"
    PRINT #fh%, "#   non-idle activity. Higher = smoother drawing, more CPU. (default: 60)"
    PRINT #fh%, "FPS_LIMIT=" + _TRIM$(STR$(CFG.FPS_LIMIT%))
    PRINT #fh%, ""
    PRINT #fh%, "# FPS_IDLE: Throttled rate when nothing is happening â€” no input, no mouse movement,"
    PRINT #fh%, "#   no active tool, no GUI changes. Saves CPU when DRAW is sitting idle. (default: 15)"
    PRINT #fh%, "FPS_IDLE=" + _TRIM$(STR$(CFG.FPS_IDLE%))
    PRINT #fh%, ""
    PRINT #fh%, "# FPS_CURSOR: Rate when only the cursor is blinking or animating (e.g., text cursor"
    PRINT #fh%, "#   blink) but no other activity. Between idle and full active. (default: 20)"
    PRINT #fh%, "FPS_CURSOR=" + _TRIM$(STR$(CFG.FPS_CURSOR%))
    PRINT #fh%, ""
    PRINT #fh%, "# FPS_DIALOG: Rate for modal dialog loops (color picker, message boxes, etc.)"
    PRINT #fh%, "#   These run their own _LIMIT independent of the main loop. (default: 60)"
    PRINT #fh%, "FPS_DIALOG=" + _TRIM$(STR$(CFG.FPS_DIALOG%))
    PRINT #fh%, ""
    
    PRINT #fh%, "# Palette strip chip dimensions (width x height in pixels)"
    PRINT #fh%, "# Valid range: 6-32 pixels (default: 10x10)"
    PRINT #fh%, "PALETTE_CHIP_WIDTH=" + _TRIM$(STR$(CFG.PALETTE_CHIP_WIDTH%))
    PRINT #fh%, "PALETTE_CHIP_HEIGHT=" + _TRIM$(STR$(CFG.PALETTE_CHIP_HEIGHT%))
    PRINT #fh%, ""
    
    PRINT #fh%, "# Palette strip layout"
    PRINT #fh%, "# Max chips per row: 4-128 (default: 64)"
    PRINT #fh%, "PALETTE_MAX_CHIPS_PER_ROW=" + _TRIM$(STR$(CFG.PALETTE_MAX_CHIPS_PER_ROW%))
    PRINT #fh%, ""
    PRINT #fh%, "# Max rows: 1-8 (default: 3)"
    PRINT #fh%, "PALETTE_MAX_ROWS=" + _TRIM$(STR$(CFG.PALETTE_MAX_ROWS%))
    PRINT #fh%, ""
    PRINT #fh%, "# Min rows to always display: 1-8 (default: 1)"
    PRINT #fh%, "PALETTE_MIN_ROWS=" + _TRIM$(STR$(CFG.PALETTE_MIN_ROWS%))
    PRINT #fh%, ""
    PRINT #fh%, "# Create new row every N chips (default: 16)"
    PRINT #fh%, "# Example: 16 means 16 chips = 1 row, 17-32 = 2 rows, 33-48 = 3 rows"
    PRINT #fh%, "PALETTE_CHIPS_ROW_THRESHOLD=" + _TRIM$(STR$(CFG.PALETTE_CHIPS_ROW_THRESHOLD%))
    PRINT #fh%, ""
    PRINT #fh%, "# Default background transparent (TRUE/FALSE, default: TRUE)"
    IF CFG.PALETTE_DEFAULT_BG_TRANSPARENT% THEN
        PRINT #fh%, "PALETTE_DEFAULT_BG_TRANSPARENT=TRUE"
    ELSE
        PRINT #fh%, "PALETTE_DEFAULT_BG_TRANSPARENT=FALSE"
    END IF
    PRINT #fh%, ""
    
    ' Validate and save palette picker chip size
    IF CFG.PALETTE_PICKER_CHIP_SIZE% < 8 THEN CFG.PALETTE_PICKER_CHIP_SIZE% = 8
    IF CFG.PALETTE_PICKER_CHIP_SIZE% > 48 THEN CFG.PALETTE_PICKER_CHIP_SIZE% = 48
    PRINT #fh%, "# Palette picker chip size in pixels (8-48, default: 10)"
    PRINT #fh%, "PALETTE_PICKER_CHIP_SIZE=" + _TRIM$(STR$(CFG.PALETTE_PICKER_CHIP_SIZE%))
    PRINT #fh%, ""
    
    ' Validate and save palette picker chip padding
    IF CFG.PALETTE_PICKER_CHIP_PADDING% < 1 THEN CFG.PALETTE_PICKER_CHIP_PADDING% = 1
    IF CFG.PALETTE_PICKER_CHIP_PADDING% > 16 THEN CFG.PALETTE_PICKER_CHIP_PADDING% = 16
    PRINT #fh%, "# Palette picker chip padding in pixels (1-16, default: 2)"
    PRINT #fh%, "PALETTE_PICKER_CHIP_PADDING=" + _TRIM$(STR$(CFG.PALETTE_PICKER_CHIP_PADDING%))
    PRINT #fh%, ""
    
    ' Validate and save palette picker columns
    IF CFG.PALETTE_PICKER_COLUMNS% < 8 THEN CFG.PALETTE_PICKER_COLUMNS% = 8
    IF CFG.PALETTE_PICKER_COLUMNS% > 64 THEN CFG.PALETTE_PICKER_COLUMNS% = 64
    PRINT #fh%, "# Palette picker number of columns (8-64, default: 32)"
    PRINT #fh%, "PALETTE_PICKER_COLUMNS=" + _TRIM$(STR$(CFG.PALETTE_PICKER_COLUMNS%))
    PRINT #fh%, ""
    
    ' Validate and save angle snap degrees
    IF CFG.ANGLE_SNAP_DEGREES% < 1 THEN CFG.ANGLE_SNAP_DEGREES% = 1
    IF CFG.ANGLE_SNAP_DEGREES% > 90 THEN CFG.ANGLE_SNAP_DEGREES% = 90
    PRINT #fh%, "# Angle snap increment in degrees when holding Ctrl+Shift while drawing lines (default: 45)"
    PRINT #fh%, "# Common values: 15 (24 angles), 30 (12 angles), 45 (8 angles), 90 (4 angles)"
    PRINT #fh%, "# Ignored when ANGLE_SNAP_PIXEL_ART is enabled"
    PRINT #fh%, "ANGLE_SNAP_DEGREES=" + _TRIM$(STR$(CFG.ANGLE_SNAP_DEGREES%))
    PRINT #fh%, ""
    PRINT #fh%, "# Pixel art angle snap mode (TRUE/FALSE, default: FALSE)"
    PRINT #fh%, "# When TRUE, snaps to pixel-art-friendly angles based on integer slope ratios:"
    PRINT #fh%, "# 0, 11.3(5:1), 14.0(4:1), 18.4(3:1), 26.6(2:1), 45(1:1), 63.4(1:2), 71.6(1:3), 76.0(1:4), 78.7(1:5), 90"
    IF CFG.ANGLE_SNAP_PIXEL_ART% THEN
        PRINT #fh%, "ANGLE_SNAP_PIXEL_ART=TRUE"
    ELSE
        PRINT #fh%, "ANGLE_SNAP_PIXEL_ART=FALSE"
    END IF
    PRINT #fh%, ""
    
    ' Validate and save layer panel width
    IF CFG.LAYER_PANEL_WIDTH% < 40 THEN CFG.LAYER_PANEL_WIDTH% = 40
    IF CFG.LAYER_PANEL_WIDTH% > 400 THEN CFG.LAYER_PANEL_WIDTH% = 400
    PRINT #fh%, "# Layer panel width in pixels (40-400, default: 100)"
    PRINT #fh%, "LAYER_PANEL_WIDTH=" + _TRIM$(STR$(CFG.LAYER_PANEL_WIDTH%))
    PRINT #fh%, ""
    ' Dock edge settings
    IF CFG.LAYERS_PANEL_DOCK_EDGE <> "LEFT" AND CFG.LAYERS_PANEL_DOCK_EDGE <> "RIGHT" THEN CFG.LAYERS_PANEL_DOCK_EDGE = "LEFT"
    IF CFG.TOOLBOX_DOCK_EDGE <> "LEFT" AND CFG.TOOLBOX_DOCK_EDGE <> "RIGHT" THEN CFG.TOOLBOX_DOCK_EDGE = "RIGHT"
    PRINT #fh%, "# Layer panel dock edge (LEFT or RIGHT, default: LEFT)"
    PRINT #fh%, "LAYERS_PANEL_DOCK_EDGE=" + _TRIM$(CFG.LAYERS_PANEL_DOCK_EDGE)
    PRINT #fh%, ""
    PRINT #fh%, "# Toolbox stack dock edge (LEFT or RIGHT, default: RIGHT)"
    PRINT #fh%, "TOOLBOX_DOCK_EDGE=" + _TRIM$(CFG.TOOLBOX_DOCK_EDGE)
    PRINT #fh%, ""
    
    ' Save grid settings
    IF CFG.GRID_COLOR_FG~& <> 0 THEN
        DIM gr AS INTEGER, gg AS INTEGER, gb AS INTEGER
        gr% = _RED32(CFG.GRID_COLOR_FG~&)
        gg% = _GREEN32(CFG.GRID_COLOR_FG~&)
        gb% = _BLUE32(CFG.GRID_COLOR_FG~&)
        PRINT #fh%, "# Grid foreground color (hex RGB, e.g., FAFAFA for bright white)"
        PRINT #fh%, "# Leave commented out or omit to use theme default"
        PRINT #fh%, "GRID_COLOR_FG=" + RIGHT$("0" + HEX$(gr%), 2) + RIGHT$("0" + HEX$(gg%), 2) + RIGHT$("0" + HEX$(gb%), 2)
    ELSE
        PRINT #fh%, "# Grid foreground color (hex RGB, e.g., FAFAFA for bright white)"
        PRINT #fh%, "# Omit or set to 000000 to use theme default"
        PRINT #fh%, "#GRID_COLOR_FG="
    END IF
    PRINT #fh%, ""
    IF CFG.GRID_OPACITY% > 0 THEN
        PRINT #fh%, "# Grid line opacity (1-255, default: 38 ~15%)"
        PRINT #fh%, "# Omit or set to 0 to use theme default"
        PRINT #fh%, "GRID_OPACITY=" + _TRIM$(STR$(CFG.GRID_OPACITY%))
    ELSE
        PRINT #fh%, "# Grid line opacity (1-255, default: 38 ~15%)"
        PRINT #fh%, "# Omit or set to 0 to use theme default"
        PRINT #fh%, "#GRID_OPACITY="
    END IF
    PRINT #fh%, ""
    PRINT #fh%, "# Grid cell width in pixels (1-256, default: 10)"
    IF CFG.GRID_SIZE_X% > 0 THEN
        PRINT #fh%, "GRID_SIZE_X=" + _TRIM$(STR$(CFG.GRID_SIZE_X%))
    ELSE
        PRINT #fh%, "GRID_SIZE_X=10"
    END IF
    PRINT #fh%, ""
    PRINT #fh%, "# Grid cell height in pixels (1-256, default: 10)"
    IF CFG.GRID_SIZE_Y% > 0 THEN
        PRINT #fh%, "GRID_SIZE_Y=" + _TRIM$(STR$(CFG.GRID_SIZE_Y%))
    ELSE
        PRINT #fh%, "GRID_SIZE_Y=10"
    END IF
    PRINT #fh%, ""
    
    ' Save crosshair settings
    IF CFG.CROSSHAIR_FG~& <> 0 THEN
        DIM chr AS INTEGER, chg AS INTEGER, chb AS INTEGER
        chr% = _RED32(CFG.CROSSHAIR_FG~&)
        chg% = _GREEN32(CFG.CROSSHAIR_FG~&)
        chb% = _BLUE32(CFG.CROSSHAIR_FG~&)
        PRINT #fh%, "# Crosshair line color (hex RGB, e.g., 808080 for medium gray)"
        PRINT #fh%, "# Omit or set to 000000 to use theme default"
        PRINT #fh%, "CROSSHAIR_FG=" + RIGHT$("0" + HEX$(chr%), 2) + RIGHT$("0" + HEX$(chg%), 2) + RIGHT$("0" + HEX$(chb%), 2)
    ELSE
        PRINT #fh%, "# Crosshair line color (hex RGB, e.g., 808080 for medium gray)"
        PRINT #fh%, "# Omit or set to 000000 to use theme default"
        PRINT #fh%, "#CROSSHAIR_FG="
    END IF
    PRINT #fh%, ""
    IF CFG.CROSSHAIR_OPACITY% > 0 THEN
        PRINT #fh%, "# Crosshair line opacity (1-255, default: 128 ~50%)"
        PRINT #fh%, "# Omit or set to 0 to use theme default"
        PRINT #fh%, "CROSSHAIR_OPACITY=" + _TRIM$(STR$(CFG.CROSSHAIR_OPACITY%))
    ELSE
        PRINT #fh%, "# Crosshair line opacity (1-255, default: 128 ~50%)"
        PRINT #fh%, "# Omit or set to 0 to use theme default"
        PRINT #fh%, "#CROSSHAIR_OPACITY="
    END IF
    PRINT #fh%, ""
    IF CFG.CROSSHAIR_FONT$ <> "" THEN
        PRINT #fh%, "# Crosshair coordinate font filename (empty = use theme/global font)"
        PRINT #fh%, "CROSSHAIR_FONT=" + CFG.CROSSHAIR_FONT$
    ELSE
        PRINT #fh%, "# Crosshair coordinate font filename (empty = use theme/global font)"
        PRINT #fh%, "#CROSSHAIR_FONT="
    END IF
    PRINT #fh%, ""
    IF CFG.CROSSHAIR_FONT_SIZE% <> CONFIG_USE_THEME_DEFAULT% THEN
        PRINT #fh%, "# Crosshair coordinate font size in pixels (4-64)"
        PRINT #fh%, "# Omit or comment out to use theme default"
        PRINT #fh%, "CROSSHAIR_FONT_SIZE=" + _TRIM$(STR$(CFG.CROSSHAIR_FONT_SIZE%))
    ELSE
        PRINT #fh%, "# Crosshair coordinate font size in pixels (4-64)"
        PRINT #fh%, "# Omit or comment out to use theme default"
        PRINT #fh%, "#CROSSHAIR_FONT_SIZE="
    END IF
    PRINT #fh%, ""
    IF CFG.CROSSHAIR_FONT_FG~& <> 0 THEN
        DIM cfr AS INTEGER, cffg AS INTEGER, cfb AS INTEGER
        cfr% = _RED32(CFG.CROSSHAIR_FONT_FG~&)
        cffg% = _GREEN32(CFG.CROSSHAIR_FONT_FG~&)
        cfb% = _BLUE32(CFG.CROSSHAIR_FONT_FG~&)
        PRINT #fh%, "# Crosshair coordinate text color (hex RGB, e.g., FFFFFF for white)"
        PRINT #fh%, "# Omit or set to 000000 to use theme default"
        PRINT #fh%, "CROSSHAIR_FONT_FG=" + RIGHT$("0" + HEX$(cfr%), 2) + RIGHT$("0" + HEX$(cffg%), 2) + RIGHT$("0" + HEX$(cfb%), 2)
    ELSE
        PRINT #fh%, "# Crosshair coordinate text color (hex RGB, e.g., FFFFFF for white)"
        PRINT #fh%, "# Omit or set to 000000 to use theme default"
        PRINT #fh%, "#CROSSHAIR_FONT_FG="
    END IF
    PRINT #fh%, ""
    IF CFG.CROSSHAIR_FONT_STROKE_FG~& <> 0 THEN
        DIM cfsr AS INTEGER, cfsg AS INTEGER, cfsb AS INTEGER
        cfsr% = _RED32(CFG.CROSSHAIR_FONT_STROKE_FG~&)
        cfsg% = _GREEN32(CFG.CROSSHAIR_FONT_STROKE_FG~&)
        cfsb% = _BLUE32(CFG.CROSSHAIR_FONT_STROKE_FG~&)
        PRINT #fh%, "# Crosshair coordinate outline color (hex RGB, e.g., 000000 for black)"
        PRINT #fh%, "# Omit or set to 000000 to use theme default"
        PRINT #fh%, "CROSSHAIR_FONT_STROKE_FG=" + RIGHT$("0" + HEX$(cfsr%), 2) + RIGHT$("0" + HEX$(cfsg%), 2) + RIGHT$("0" + HEX$(cfsb%), 2)
    ELSE
        PRINT #fh%, "# Crosshair coordinate outline color (hex RGB, e.g., 000000 for black)"
        PRINT #fh%, "# Omit or set to 000000 to use theme default"
        PRINT #fh%, "#CROSSHAIR_FONT_STROKE_FG="
    END IF
    PRINT #fh%, ""
    IF CFG.CROSSHAIR_FONT_STROKE_WIDTH% <> CONFIG_USE_THEME_DEFAULT% THEN
        PRINT #fh%, "# Crosshair coordinate outline width in pixels (0-8)"
        PRINT #fh%, "# Omit or comment out to use theme default"
        PRINT #fh%, "CROSSHAIR_FONT_STROKE_WIDTH=" + _TRIM$(STR$(CFG.CROSSHAIR_FONT_STROKE_WIDTH%))
    ELSE
        PRINT #fh%, "# Crosshair coordinate outline width in pixels (0-8)"
        PRINT #fh%, "# Omit or comment out to use theme default"
        PRINT #fh%, "#CROSSHAIR_FONT_STROKE_WIDTH="
    END IF
    PRINT #fh%, ""
    IF CFG.CROSSHAIR_ANGLE! <> 0 THEN
        PRINT #fh%, "# Crosshair rotation angle in degrees (-360 to 360, default: 0)"
        PRINT #fh%, "# Omit or set to 0 to use theme default"
        PRINT #fh%, "CROSSHAIR_ANGLE=" + _TRIM$(STR$(CFG.CROSSHAIR_ANGLE!))
    ELSE
        PRINT #fh%, "# Crosshair rotation angle in degrees (-360 to 360, default: 0)"
        PRINT #fh%, "# Omit or set to 0 to use theme default"
        PRINT #fh%, "#CROSSHAIR_ANGLE="
    END IF
    PRINT #fh%, ""
    IF CFG.CROSSHAIR_OUTLINE_FG~& <> 0 THEN
        DIM cor AS INTEGER, cog AS INTEGER, cob AS INTEGER
        cor% = _RED32(CFG.CROSSHAIR_OUTLINE_FG~&)
        cog% = _GREEN32(CFG.CROSSHAIR_OUTLINE_FG~&)
        cob% = _BLUE32(CFG.CROSSHAIR_OUTLINE_FG~&)
        PRINT #fh%, "# Crosshair outline stroke color (hex RGB, e.g., 000000 for black)"
        PRINT #fh%, "# Omit or set to 000000 to use theme default"
        PRINT #fh%, "CROSSHAIR_OUTLINE_FG=" + RIGHT$("0" + HEX$(cor%), 2) + RIGHT$("0" + HEX$(cog%), 2) + RIGHT$("0" + HEX$(cob%), 2)
    ELSE
        PRINT #fh%, "# Crosshair outline stroke color (hex RGB, e.g., 000000 for black)"
        PRINT #fh%, "# Omit or set to 000000 to use theme default"
        PRINT #fh%, "#CROSSHAIR_OUTLINE_FG="
    END IF
    PRINT #fh%, ""
    IF CFG.CROSSHAIR_OUTLINE_OPACITY% > 0 THEN
        PRINT #fh%, "# Crosshair outline stroke opacity (0-255, 0=use theme default)"
        PRINT #fh%, "CROSSHAIR_OUTLINE_OPACITY=" + _TRIM$(STR$(CFG.CROSSHAIR_OUTLINE_OPACITY%))
    ELSE
        PRINT #fh%, "# Crosshair outline stroke opacity (0-255, 0=use theme default)"
        PRINT #fh%, "#CROSSHAIR_OUTLINE_OPACITY="
    END IF
    PRINT #fh%, ""
    IF CFG.CROSSHAIR_OUTLINE_WIDTH% <> CONFIG_USE_THEME_DEFAULT% THEN
        PRINT #fh%, "# Crosshair outline stroke width in pixels (0-8, omit=use theme default)"
        PRINT #fh%, "CROSSHAIR_OUTLINE_WIDTH=" + _TRIM$(STR$(CFG.CROSSHAIR_OUTLINE_WIDTH%))
    ELSE
        PRINT #fh%, "# Crosshair outline stroke width in pixels (0-8, omit=use theme default)"
        PRINT #fh%, "#CROSSHAIR_OUTLINE_WIDTH="
    END IF
    PRINT #fh%, ""
    PRINT #fh%, "# Crosshair coordinate text offset from the cursor in screen pixels"
    PRINT #fh%, "# Positive X moves the label right, positive Y moves it down"
    PRINT #fh%, "# Omit or comment out to use theme default (typically 4,4)"
    IF CFG.CROSSHAIR_FONT_OFFSET_X% <> CONFIG_USE_THEME_DEFAULT% THEN
        PRINT #fh%, "CROSSHAIR_FONT_OFFSET_X=" + _TRIM$(STR$(CFG.CROSSHAIR_FONT_OFFSET_X%))
    ELSE
        PRINT #fh%, "#CROSSHAIR_FONT_OFFSET_X="
    END IF
    IF CFG.CROSSHAIR_FONT_OFFSET_Y% <> CONFIG_USE_THEME_DEFAULT% THEN
        PRINT #fh%, "CROSSHAIR_FONT_OFFSET_Y=" + _TRIM$(STR$(CFG.CROSSHAIR_FONT_OFFSET_Y%))
    ELSE
        PRINT #fh%, "#CROSSHAIR_FONT_OFFSET_Y="
    END IF
    PRINT #fh%, ""

    PRINT #fh%, "# Picker loupe settings"
    PRINT #fh%, "# Zoom factor for the cursor loupe (1-64, default: 8)"
    PRINT #fh%, "# Omit or comment out to use theme default"
    IF CFG.PICKER_LOUPE_ZOOM_LEVEL% <> CONFIG_USE_THEME_DEFAULT% THEN
        PRINT #fh%, "PICKER_LOUPE_ZOOM_LEVEL=" + _TRIM$(STR$(CFG.PICKER_LOUPE_ZOOM_LEVEL%))
    ELSE
        PRINT #fh%, "#PICKER_LOUPE_ZOOM_LEVEL="
    END IF
    PRINT #fh%, ""
    PRINT #fh%, "# Loupe rectangle X/Y offset from the mouse cursor in screen pixels"
    PRINT #fh%, "# Omit or comment out to use theme default"
    IF CFG.PICKER_LOUPE_RECT_X_OFFSET% <> CONFIG_USE_THEME_DEFAULT% THEN
        PRINT #fh%, "PICKER_LOUPE_RECT_X_OFFSET=" + _TRIM$(STR$(CFG.PICKER_LOUPE_RECT_X_OFFSET%))
    ELSE
        PRINT #fh%, "#PICKER_LOUPE_RECT_X_OFFSET="
    END IF
    IF CFG.PICKER_LOUPE_RECT_Y_OFFSET% <> CONFIG_USE_THEME_DEFAULT% THEN
        PRINT #fh%, "PICKER_LOUPE_RECT_Y_OFFSET=" + _TRIM$(STR$(CFG.PICKER_LOUPE_RECT_Y_OFFSET%))
    ELSE
        PRINT #fh%, "#PICKER_LOUPE_RECT_Y_OFFSET="
    END IF
    PRINT #fh%, ""
    PRINT #fh%, "# Loupe rectangle size in screen pixels"
    PRINT #fh%, "# Omit or comment out to use theme default"
    IF CFG.PICKER_LOUPE_RECT_WIDTH% <> CONFIG_USE_THEME_DEFAULT% THEN
        PRINT #fh%, "PICKER_LOUPE_RECT_WIDTH=" + _TRIM$(STR$(CFG.PICKER_LOUPE_RECT_WIDTH%))
    ELSE
        PRINT #fh%, "#PICKER_LOUPE_RECT_WIDTH="
    END IF
    IF CFG.PICKER_LOUPE_RECT_HEIGHT% <> CONFIG_USE_THEME_DEFAULT% THEN
        PRINT #fh%, "PICKER_LOUPE_RECT_HEIGHT=" + _TRIM$(STR$(CFG.PICKER_LOUPE_RECT_HEIGHT%))
    ELSE
        PRINT #fh%, "#PICKER_LOUPE_RECT_HEIGHT="
    END IF
    PRINT #fh%, ""
    PRINT #fh%, "# RGBA text position relative to the loupe rectangle origin"
    PRINT #fh%, "# Omit or comment out to use theme default"
    IF CFG.PICKER_LOUPE_RGBA_X% <> CONFIG_USE_THEME_DEFAULT% THEN
        PRINT #fh%, "PICKER_LOUPE_RGBA_X=" + _TRIM$(STR$(CFG.PICKER_LOUPE_RGBA_X%))
    ELSE
        PRINT #fh%, "#PICKER_LOUPE_RGBA_X="
    END IF
    IF CFG.PICKER_LOUPE_RGBA_Y% <> CONFIG_USE_THEME_DEFAULT% THEN
        PRINT #fh%, "PICKER_LOUPE_RGBA_Y=" + _TRIM$(STR$(CFG.PICKER_LOUPE_RGBA_Y%))
    ELSE
        PRINT #fh%, "#PICKER_LOUPE_RGBA_Y="
    END IF
    PRINT #fh%, ""
    PRINT #fh%, "# Picker loupe font filename (empty or omitted = use theme loupe font, then GLOBAL_FONT_FILE)"
    IF _TRIM$(CFG.PICKER_LOUPE_FONT$) <> "" THEN
        PRINT #fh%, "PICKER_LOUPE_FONT=" + CFG.PICKER_LOUPE_FONT$
    ELSE
        PRINT #fh%, "#PICKER_LOUPE_FONT="
    END IF
    PRINT #fh%, ""
    PRINT #fh%, "# Picker loupe font size in pixels"
    PRINT #fh%, "# Omit or comment out to use theme default"
    IF CFG.PICKER_LOUPE_FONT_SIZE% <> CONFIG_USE_THEME_DEFAULT% THEN
        PRINT #fh%, "PICKER_LOUPE_FONT_SIZE=" + _TRIM$(STR$(CFG.PICKER_LOUPE_FONT_SIZE%))
    ELSE
        PRINT #fh%, "#PICKER_LOUPE_FONT_SIZE="
    END IF
    PRINT #fh%, ""
    DIM plfr AS INTEGER, plfg AS INTEGER, plfb AS INTEGER
    DIM plbr AS INTEGER, plbg AS INTEGER, plbb AS INTEGER
    DIM pltr AS INTEGER, pltg AS INTEGER, pltb AS INTEGER
    DIM pltw AS INTEGER
    DIM plsr AS INTEGER, plsg AS INTEGER, plsb AS INTEGER
    DIM plpr AS INTEGER, plpg AS INTEGER, plpb AS INTEGER
    plfr% = _RED32(CFG.PICKER_LOUPE_FONT_FG~&)
    plfg% = _GREEN32(CFG.PICKER_LOUPE_FONT_FG~&)
    plfb% = _BLUE32(CFG.PICKER_LOUPE_FONT_FG~&)
    plbr% = _RED32(CFG.PICKER_LOUPE_FONT_BG~&)
    plbg% = _GREEN32(CFG.PICKER_LOUPE_FONT_BG~&)
    plbb% = _BLUE32(CFG.PICKER_LOUPE_FONT_BG~&)
    pltr% = _RED32(CFG.PICKER_LOUPE_FONT_STROKE_FG~&)
    pltg% = _GREEN32(CFG.PICKER_LOUPE_FONT_STROKE_FG~&)
    pltb% = _BLUE32(CFG.PICKER_LOUPE_FONT_STROKE_FG~&)
    pltw% = CFG.PICKER_LOUPE_FONT_STROKE_WIDTH%
    plsr% = _RED32(CFG.PICKER_LOUPE_RECT_STROKE_FG~&)
    plsg% = _GREEN32(CFG.PICKER_LOUPE_RECT_STROKE_FG~&)
    plsb% = _BLUE32(CFG.PICKER_LOUPE_RECT_STROKE_FG~&)
    plpr% = _RED32(CFG.PICKER_LOUPE_PIXEL_PICKUP_COLOR~&)
    plpg% = _GREEN32(CFG.PICKER_LOUPE_PIXEL_PICKUP_COLOR~&)
    plpb% = _BLUE32(CFG.PICKER_LOUPE_PIXEL_PICKUP_COLOR~&)
    PRINT #fh%, "# Picker loupe RGBA text foreground color (hex RGB)"
    PRINT #fh%, "# Omit or set to 000000 to use theme default"
    IF CFG.PICKER_LOUPE_FONT_FG~& <> 0 THEN
        PRINT #fh%, "PICKER_LOUPE_FONT_FG=" + RIGHT$("0" + HEX$(plfr%), 2) + RIGHT$("0" + HEX$(plfg%), 2) + RIGHT$("0" + HEX$(plfb%), 2)
    ELSE
        PRINT #fh%, "#PICKER_LOUPE_FONT_FG="
    END IF
    PRINT #fh%, "# Picker loupe RGBA text / panel background color (hex RGB)"
    PRINT #fh%, "# Omit or set to 000000 to use theme default"
    IF CFG.PICKER_LOUPE_FONT_BG~& <> 0 THEN
        PRINT #fh%, "PICKER_LOUPE_FONT_BG=" + RIGHT$("0" + HEX$(plbr%), 2) + RIGHT$("0" + HEX$(plbg%), 2) + RIGHT$("0" + HEX$(plbb%), 2)
    ELSE
        PRINT #fh%, "#PICKER_LOUPE_FONT_BG="
    END IF
    PRINT #fh%, "# Picker loupe RGBA text stroke color (hex RGB)"
    PRINT #fh%, "# Omit or set to 000000 to use theme default"
    IF CFG.PICKER_LOUPE_FONT_STROKE_FG~& <> 0 THEN
        PRINT #fh%, "PICKER_LOUPE_FONT_STROKE_FG=" + RIGHT$("0" + HEX$(pltr%), 2) + RIGHT$("0" + HEX$(pltg%), 2) + RIGHT$("0" + HEX$(pltb%), 2)
    ELSE
        PRINT #fh%, "#PICKER_LOUPE_FONT_STROKE_FG="
    END IF
    PRINT #fh%, "# Picker loupe RGBA text stroke width in pixels (0 disables outline)"
    PRINT #fh%, "# Omit or comment out to use theme default"
    IF CFG.PICKER_LOUPE_FONT_STROKE_WIDTH% <> CONFIG_USE_THEME_DEFAULT% THEN
        PRINT #fh%, "PICKER_LOUPE_FONT_STROKE_WIDTH=" + _TRIM$(STR$(pltw%))
    ELSE
        PRINT #fh%, "#PICKER_LOUPE_FONT_STROKE_WIDTH="
    END IF
    PRINT #fh%, "# Picker loupe rectangle stroke color (hex RGB)"
    PRINT #fh%, "# Omit or set to 000000 to use theme default"
    IF CFG.PICKER_LOUPE_RECT_STROKE_FG~& <> 0 THEN
        PRINT #fh%, "PICKER_LOUPE_RECT_STROKE_FG=" + RIGHT$("0" + HEX$(plsr%), 2) + RIGHT$("0" + HEX$(plsg%), 2) + RIGHT$("0" + HEX$(plsb%), 2)
    ELSE
        PRINT #fh%, "#PICKER_LOUPE_RECT_STROKE_FG="
    END IF
    PRINT #fh%, "# Picker loupe rectangle stroke width in pixels"
    PRINT #fh%, "# Omit or comment out to use theme default"
    IF CFG.PICKER_LOUPE_RECT_STROKE_WIDTH% <> CONFIG_USE_THEME_DEFAULT% THEN
        PRINT #fh%, "PICKER_LOUPE_RECT_STROKE_WIDTH=" + _TRIM$(STR$(CFG.PICKER_LOUPE_RECT_STROKE_WIDTH%))
    ELSE
        PRINT #fh%, "#PICKER_LOUPE_RECT_STROKE_WIDTH="
    END IF
    PRINT #fh%, "# Picker loupe pickup marker color (hex RGB)"
    PRINT #fh%, "# Omit or set to 000000 to use theme default"
    IF CFG.PICKER_LOUPE_PIXEL_PICKUP_COLOR~& <> 0 THEN
        PRINT #fh%, "PICKER_LOUPE_PIXEL_PICKUP_COLOR=" + RIGHT$("0" + HEX$(plpr%), 2) + RIGHT$("0" + HEX$(plpg%), 2) + RIGHT$("0" + HEX$(plpb%), 2)
    ELSE
        PRINT #fh%, "#PICKER_LOUPE_PIXEL_PICKUP_COLOR="
    END IF
    PRINT #fh%, ""

    ' Save grid mode
    IF CFG.GRID_MODE% <> 0 THEN
        PRINT #fh%, "# Grid geometry mode (0=square, 1=diagonal, 2=isometric, 3=hex)"
        PRINT #fh%, "GRID_MODE=" + _TRIM$(STR$(CFG.GRID_MODE%))
    ELSE
        PRINT #fh%, "# Grid geometry mode (0=square, 1=diagonal, 2=isometric, 3=hex)"
        PRINT #fh%, "#GRID_MODE="
    END IF
    PRINT #fh%, ""
    ' Save grid cell fill mode
    IF CFG.GRID_CELL_FILL% <> 0 THEN
        PRINT #fh%, "# Grid cell fill mode (0=off, 1=on)"
        PRINT #fh%, "GRID_CELL_FILL=1"
    ELSE
        PRINT #fh%, "# Grid cell fill mode (0=off, 1=on)"
        PRINT #fh%, "#GRID_CELL_FILL="
    END IF
    PRINT #fh%, ""
    IF CFG.GRID_ANGLE! <> 0 THEN
        PRINT #fh%, "# Grid rotation angle in degrees (-360 to 360, default: 0)"
        PRINT #fh%, "# Omit or set to 0 to use theme default"
        PRINT #fh%, "# Use 30 for isometric (30-60-90), 45 for diagonal diamond grid"
        PRINT #fh%, "GRID_ANGLE=" + _TRIM$(STR$(CFG.GRID_ANGLE!))
    ELSE
        PRINT #fh%, "# Grid rotation angle in degrees (-360 to 360, default: 0)"
        PRINT #fh%, "# Omit or set to 0 to use theme default"
        PRINT #fh%, "# Use 30 for isometric (30-60-90), 45 for diagonal diamond grid"
        PRINT #fh%, "#GRID_ANGLE="
    END IF
    PRINT #fh%, ""
    ' Save pixel grid settings
    IF CFG.PIXELGRID_COLOR_FG~& <> 0 THEN
        DIM pgr AS INTEGER, pgg AS INTEGER, pgb AS INTEGER
        pgr% = _RED32(CFG.PIXELGRID_COLOR_FG~&)
        pgg% = _GREEN32(CFG.PIXELGRID_COLOR_FG~&)
        pgb% = _BLUE32(CFG.PIXELGRID_COLOR_FG~&)
        PRINT #fh%, "# Pixel grid line color (hex RGB, e.g., 505050 for dark gray)"
        PRINT #fh%, "# Omit or set to 000000 to use theme default"
        PRINT #fh%, "PIXELGRID_COLOR_FG=" + RIGHT$("0" + HEX$(pgr%), 2) + RIGHT$("0" + HEX$(pgg%), 2) + RIGHT$("0" + HEX$(pgb%), 2)
    ELSE
        PRINT #fh%, "# Pixel grid line color (hex RGB, e.g., 505050 for dark gray)"
        PRINT #fh%, "# Omit or set to 000000 to use theme default"
        PRINT #fh%, "#PIXELGRID_COLOR_FG="
    END IF
    PRINT #fh%, ""
    IF CFG.PIXELGRID_OPACITY% > 0 THEN
        PRINT #fh%, "# Pixel grid line opacity (1-255, default: 64 ~25%)"
        PRINT #fh%, "# Omit or set to 0 to use theme default"
        PRINT #fh%, "PIXELGRID_OPACITY=" + _TRIM$(STR$(CFG.PIXELGRID_OPACITY%))
    ELSE
        PRINT #fh%, "# Pixel grid line opacity (1-255, default: 64 ~25%)"
        PRINT #fh%, "# Omit or set to 0 to use theme default"
        PRINT #fh%, "#PIXELGRID_OPACITY="
    END IF
    PRINT #fh%, ""
    
    ' Save transparency checkerboard settings
    DIM r1 AS INTEGER, g1 AS INTEGER, b1 AS INTEGER
    DIM r2 AS INTEGER, g2 AS INTEGER, b2 AS INTEGER
    r1% = _RED32(CFG.TRANSPARENCY_CHECK_COLOR1~&)
    g1% = _GREEN32(CFG.TRANSPARENCY_CHECK_COLOR1~&)
    b1% = _BLUE32(CFG.TRANSPARENCY_CHECK_COLOR1~&)
    r2% = _RED32(CFG.TRANSPARENCY_CHECK_COLOR2~&)
    g2% = _GREEN32(CFG.TRANSPARENCY_CHECK_COLOR2~&)
    b2% = _BLUE32(CFG.TRANSPARENCY_CHECK_COLOR2~&)
    PRINT #fh%, "# Transparency checkerboard colors (hex RGB, e.g., C0C0C0 for light gray)"
    PRINT #fh%, "TRANSPARENCY_CHECK_COLOR1=" + RIGHT$("0" + HEX$(r1%), 2) + RIGHT$("0" + HEX$(g1%), 2) + RIGHT$("0" + HEX$(b1%), 2)
    PRINT #fh%, "TRANSPARENCY_CHECK_COLOR2=" + RIGHT$("0" + HEX$(r2%), 2) + RIGHT$("0" + HEX$(g2%), 2) + RIGHT$("0" + HEX$(b2%), 2)
    PRINT #fh%, ""
    
    ' Validate and save transparency checkerboard size
    DIM tcsx AS INTEGER, tcsy AS INTEGER
    ' Resolve effective sizes: config overrides theme
    IF CFG.TRANSPARENCY_CHECK_SIZE_X% > 0 THEN
        tcsx% = CFG.TRANSPARENCY_CHECK_SIZE_X%
    ELSE
        tcsx% = THEME.TRANSPARENCY_check_size_x%
    END IF
    IF CFG.TRANSPARENCY_CHECK_SIZE_Y% > 0 THEN
        tcsy% = CFG.TRANSPARENCY_CHECK_SIZE_Y%
    ELSE
        tcsy% = THEME.TRANSPARENCY_check_size_y%
    END IF
    IF tcsx% < 2 THEN tcsx% = 2
    IF tcsx% > 64 THEN tcsx% = 64
    IF tcsy% < 2 THEN tcsy% = 2
    IF tcsy% > 64 THEN tcsy% = 64
    IF CFG.TRANSPARENCY_CHECK_SIZE_X% > 0 THEN
        PRINT #fh%, "# Transparency checkerboard square width in pixels (1-64, default: 8)"
        PRINT #fh%, "# Omit or set to 0 to use theme default"
        PRINT #fh%, "TRANSPARENCY_CHECK_SIZE_X=" + _TRIM$(STR$(tcsx%))
    ELSE
        PRINT #fh%, "# Transparency checkerboard square width in pixels (1-64, default: 8)"
        PRINT #fh%, "# Omit or set to 0 to use theme default"
        PRINT #fh%, "#TRANSPARENCY_CHECK_SIZE_X="
    END IF
    PRINT #fh%, ""
    IF CFG.TRANSPARENCY_CHECK_SIZE_Y% > 0 THEN
        PRINT #fh%, "# Transparency checkerboard square height in pixels (1-64, default: 8)"
        PRINT #fh%, "# Omit or set to 0 to use theme default"
        PRINT #fh%, "TRANSPARENCY_CHECK_SIZE_Y=" + _TRIM$(STR$(tcsy%))
    ELSE
        PRINT #fh%, "# Transparency checkerboard square height in pixels (1-64, default: 8)"
        PRINT #fh%, "# Omit or set to 0 to use theme default"
        PRINT #fh%, "#TRANSPARENCY_CHECK_SIZE_Y="
    END IF
    PRINT #fh%, ""
    
    ' Save scrollbar settings
    PRINT #fh%, "# Scrollbar track background color (hex RGB, e.g., 333333 for dark gray)"
    PRINT #fh%, "# Omit or set to 000000 to use default"
    IF CFG.SCROLLBAR_BG~& <> 0 THEN
        DIM sbR AS INTEGER, sbG AS INTEGER, sbB AS INTEGER
        sbR% = _RED32(CFG.SCROLLBAR_BG~&)
        sbG% = _GREEN32(CFG.SCROLLBAR_BG~&)
        sbB% = _BLUE32(CFG.SCROLLBAR_BG~&)
        PRINT #fh%, "SCROLLBAR_BG=" + RIGHT$("0" + HEX$(sbR%), 2) + RIGHT$("0" + HEX$(sbG%), 2) + RIGHT$("0" + HEX$(sbB%), 2)
    ELSE
        PRINT #fh%, "#SCROLLBAR_BG="
    END IF
    PRINT #fh%, ""
    PRINT #fh%, "# Scrollbar thumb/handle color (hex RGB, e.g., C8C8C8 for light gray)"
    PRINT #fh%, "# Omit or set to 000000 to use default"
    IF CFG.SCROLLBAR_HANDLE_FG~& <> 0 THEN
        DIM shR AS INTEGER, shG AS INTEGER, shB AS INTEGER
        shR% = _RED32(CFG.SCROLLBAR_HANDLE_FG~&)
        shG% = _GREEN32(CFG.SCROLLBAR_HANDLE_FG~&)
        shB% = _BLUE32(CFG.SCROLLBAR_HANDLE_FG~&)
        PRINT #fh%, "SCROLLBAR_HANDLE_FG=" + RIGHT$("0" + HEX$(shR%), 2) + RIGHT$("0" + HEX$(shG%), 2) + RIGHT$("0" + HEX$(shB%), 2)
    ELSE
        PRINT #fh%, "#SCROLLBAR_HANDLE_FG="
    END IF
    PRINT #fh%, ""
    PRINT #fh%, "# Scrollbar overall opacity (1-255, default: 180)"
    PRINT #fh%, "# Omit or set to 0 to use default"
    IF CFG.SCROLLBAR_OPACITY% > 0 THEN
        PRINT #fh%, "SCROLLBAR_OPACITY=" + _TRIM$(STR$(CFG.SCROLLBAR_OPACITY%))
    ELSE
        PRINT #fh%, "#SCROLLBAR_OPACITY="
    END IF
    PRINT #fh%, ""
    
    ' Save sound / music settings
    PRINT #fh%, "# Audio settings"
    IF CFG.SOUNDS_ENABLED% THEN
        PRINT #fh%, "SOUNDS_ENABLED=TRUE"
    ELSE
        PRINT #fh%, "SOUNDS_ENABLED=FALSE"
    END IF
    IF CFG.SOUNDS_VOLUME% < 0  THEN CFG.SOUNDS_VOLUME% = 0
    IF CFG.SOUNDS_VOLUME% > 100 THEN CFG.SOUNDS_VOLUME% = 100
    PRINT #fh%, "SOUNDS_VOLUME=" + _TRIM$(STR$(CFG.SOUNDS_VOLUME%))
    IF CFG.SOUNDS_MUTED% THEN
        PRINT #fh%, "SOUNDS_MUTED=TRUE"
    ELSE
        PRINT #fh%, "SOUNDS_MUTED=FALSE"
    END IF
    IF CFG.MUSIC_ENABLED% THEN
        PRINT #fh%, "MUSIC_ENABLED=TRUE"
    ELSE
        PRINT #fh%, "MUSIC_ENABLED=FALSE"
    END IF
    IF CFG.MUSIC_VOLUME% < 0  THEN CFG.MUSIC_VOLUME% = 0
    IF CFG.MUSIC_VOLUME% > 100 THEN CFG.MUSIC_VOLUME% = 100
    PRINT #fh%, "MUSIC_VOLUME=" + _TRIM$(STR$(CFG.MUSIC_VOLUME%))
    IF CFG.MUSIC_MUTED% THEN
        PRINT #fh%, "MUSIC_MUTED=TRUE"
    ELSE
        PRINT #fh%, "MUSIC_MUTED=FALSE"
    END IF
    PRINT #fh%, ""

    ' System cursor settings
    PRINT #fh%, "# Use OS system cursors for non-canvas areas (TRUE/FALSE, default: TRUE)"
    PRINT #fh%, "# When TRUE: OS arrow over toolbar/panels; text=I-beam, shapes=crosshair, resize=arrows over canvas"
    PRINT #fh%, "# When FALSE: always use custom PNG cursors"
    IF CFG.SYSTEM_CURSORS_ENABLED% THEN
        PRINT #fh%, "SYSTEM_CURSORS=TRUE"
    ELSE
        PRINT #fh%, "SYSTEM_CURSORS=FALSE"
    END IF
    PRINT #fh%, ""

    ' Tooltip settings
    PRINT #fh%, "# Tooltip hover delay in milliseconds (0=instant, default: 500)"
    PRINT #fh%, "TOOLTIP_HOVER_DELAY=" + _TRIM$(STR$(CFG.TOOLTIP_HOVER_DELAY_MS%))
    IF CFG.TOOLTIPS_DISABLED% THEN
        PRINT #fh%, "TOOLTIPS_DISABLED=TRUE"
    ELSE
        PRINT #fh%, "TOOLTIPS_DISABLED=FALSE"
    END IF
    PRINT #fh%, ""

    ' Save default startup settings
    PRINT #fh%, "# Default startup settings"
    PRINT #fh%, ""
    
    ' Default tool
    IF CFG.DEFAULT_TOOL% < 0 THEN CFG.DEFAULT_TOOL% = 0
    IF CFG.DEFAULT_TOOL% > 12 THEN CFG.DEFAULT_TOOL% = 12
    PRINT #fh%, "# Default tool on startup (0=null, 1=brush, 2=fill, 3=dot, 4=line, 5=marquee,"
    PRINT #fh%, "#   6=polygon, 7=rect, 8=ellipse, 9=rect_filled, 10=ellipse_filled, 11=picker, 12=polygon_filled)"
    PRINT #fh%, "DEFAULT_TOOL=" + _TRIM$(STR$(CFG.DEFAULT_TOOL%))
    PRINT #fh%, ""
    
    ' Default brush size
    IF CFG.DEFAULT_BRUSH_SIZE% < 1 THEN CFG.DEFAULT_BRUSH_SIZE% = 1
    IF CFG.DEFAULT_BRUSH_SIZE% > 25 THEN CFG.DEFAULT_BRUSH_SIZE% = 25
    PRINT #fh%, "# Default brush size index (1-25, where 1=1px, 2=3px, 3=5px, etc.)"
    PRINT #fh%, "DEFAULT_BRUSH_SIZE=" + _TRIM$(STR$(CFG.DEFAULT_BRUSH_SIZE%))
    PRINT #fh%, ""
    
    ' Default brush shape
    IF CFG.DEFAULT_BRUSH_SHAPE% < 0 THEN CFG.DEFAULT_BRUSH_SHAPE% = 0
    IF CFG.DEFAULT_BRUSH_SHAPE% > 1 THEN CFG.DEFAULT_BRUSH_SHAPE% = 1
    PRINT #fh%, "# Default brush shape (0=circle, 1=square)"
    PRINT #fh%, "DEFAULT_BRUSH_SHAPE=" + _TRIM$(STR$(CFG.DEFAULT_BRUSH_SHAPE%))
    PRINT #fh%, ""

    IF CFG.DEFAULT_DRAW_MODE% < 1 THEN CFG.DEFAULT_DRAW_MODE% = 1
    IF CFG.DEFAULT_DRAW_MODE% > 3 THEN CFG.DEFAULT_DRAW_MODE% = 3
    PRINT #fh%, "# Default paint mode (1=color, 2=gradient, 3=pattern)"
    PRINT #fh%, "DEFAULT_DRAW_MODE=" + _TRIM$(STR$(CFG.DEFAULT_DRAW_MODE%))
    PRINT #fh%, ""

    IF CFG.DEFAULT_BIN_MODE% < 1 THEN CFG.DEFAULT_BIN_MODE% = 1
    IF CFG.DEFAULT_BIN_MODE% > 3 THEN CFG.DEFAULT_BIN_MODE% = 3
    PRINT #fh%, "# Default visible bins panel (1=brush, 2=pattern, 3=gradient)"
    PRINT #fh%, "DEFAULT_BIN_MODE=" + _TRIM$(STR$(CFG.DEFAULT_BIN_MODE%))
    PRINT #fh%, ""
    
    ' Default layer background color (RGBA hex)
    DIM lr AS INTEGER, lg AS INTEGER, lb AS INTEGER, la AS INTEGER
    lr% = _RED32(CFG.DEFAULT_LAYER_BG_COLOR~&)
    lg% = _GREEN32(CFG.DEFAULT_LAYER_BG_COLOR~&)
    lb% = _BLUE32(CFG.DEFAULT_LAYER_BG_COLOR~&)
    la% = _ALPHA32(CFG.DEFAULT_LAYER_BG_COLOR~&)
    PRINT #fh%, "# Default layer background color (hex RRGGBBAA, e.g., 00000000 for transparent)"
    PRINT #fh%, "DEFAULT_LAYER_BG_COLOR=" + RIGHT$("0" + HEX$(lr%), 2) + RIGHT$("0" + HEX$(lg%), 2) + RIGHT$("0" + HEX$(lb%), 2) + RIGHT$("0" + HEX$(la%), 2)
    PRINT #fh%, ""

    ' Generated BAS export background color (RGBA hex)
    DIM ber AS INTEGER, beg AS INTEGER, beb AS INTEGER, bea AS INTEGER
    ber% = _RED32(CFG.BAS_EXPORT_BG_COLOR~&)
    beg% = _GREEN32(CFG.BAS_EXPORT_BG_COLOR~&)
    beb% = _BLUE32(CFG.BAS_EXPORT_BG_COLOR~&)
    bea% = _ALPHA32(CFG.BAS_EXPORT_BG_COLOR~&)
    PRINT #fh%, "# Generated BAS export screen background color (hex RRGGBBAA, default: FF00FFFF magenta)"
    PRINT #fh%, "BAS_EXPORT_BG_COLOR=" + RIGHT$("0" + HEX$(ber%), 2) + RIGHT$("0" + HEX$(beg%), 2) + RIGHT$("0" + HEX$(beb%), 2) + RIGHT$("0" + HEX$(bea%), 2)
    PRINT #fh%, ""
    
    ' Default directories
    PRINT #fh%, "# Default directory for save dialogs (empty = use last directory or current)"
    PRINT #fh%, "DEFAULT_SAVE_DIR=" + CFG.DEFAULT_SAVE_DIR$
    PRINT #fh%, ""
    
    PRINT #fh%, "# Default directory for open dialogs (empty = use last directory or current)"
    PRINT #fh%, "DEFAULT_OPEN_DIR=" + CFG.DEFAULT_OPEN_DIR$
    PRINT #fh%, ""

    ' Per-operation last-used directories
    PRINT #fh%, "# Per-operation last-used directories (auto-updated, empty = use defaults above)"
    PRINT #fh%, "LAST_DIR_OPEN=" + CFG.LAST_DIR_OPEN$
    PRINT #fh%, "LAST_DIR_SAVE=" + CFG.LAST_DIR_SAVE$
    PRINT #fh%, "LAST_DIR_IMPORT=" + CFG.LAST_DIR_IMPORT$
    PRINT #fh%, "LAST_DIR_EXPORT_BRUSH=" + CFG.LAST_DIR_EXPORT_BRUSH$
    PRINT #fh%, "LAST_DIR_EXPORT_LAYER=" + CFG.LAST_DIR_EXPORT_LAYER$
    PRINT #fh%, "LAST_DIR_EXTRACT=" + CFG.LAST_DIR_EXTRACT$
    PRINT #fh%, "LAST_DIR_PALETTE=" + CFG.LAST_DIR_PALETTE$
    PRINT #fh%, ""
    PRINT #fh%, "# Default directory for New from Template dialog (empty = use current directory)"
    PRINT #fh%, "TEMPLATE_DIR=" + CFG.TEMPLATE_DIR$
    PRINT #fh%, ""

    ' User palette visibility settings
    PRINT #fh%, "# Show user-downloaded Lospec palettes in palette picker (1=yes, 0=no)"
    PRINT #fh%, "PALETTE_SHOW_LOSPEC=" + _TRIM$(STR$(CFG.PALETTE_SHOW_LOSPEC%))
    PRINT #fh%, ""
    PRINT #fh%, "# Show user-created palettes in palette picker (1=yes, 0=no)"
    PRINT #fh%, "PALETTE_SHOW_CREATED=" + _TRIM$(STR$(CFG.PALETTE_SHOW_CREATED%))
    PRINT #fh%, ""
    PRINT #fh%, "# Default max colors when creating palette from image (1-256)"
    PRINT #fh%, "PALETTE_CREATE_MAX_COLORS=" + _TRIM$(STR$(CFG.PALETTE_CREATE_MAX_COLORS%))
    PRINT #fh%, ""

    ' Preview Window settings
    PRINT #fh%, "# Preview Window: show on startup (1=yes, 0=no)"
    PRINT #fh%, "PREVIEW_VISIBLE=" + _TRIM$(STR$(CFG.PREVIEW_VISIBLE%))
    PRINT #fh%, ""
    PRINT #fh%, "# Preview Window: last position (-1 = auto-position)"
    PRINT #fh%, "PREVIEW_X=" + _TRIM$(STR$(CFG.PREVIEW_X%))
    PRINT #fh%, "PREVIEW_Y=" + _TRIM$(STR$(CFG.PREVIEW_Y%))
    PRINT #fh%, ""
    PRINT #fh%, "# Preview Window: last size"
    PRINT #fh%, "PREVIEW_W=" + _TRIM$(STR$(CFG.PREVIEW_W%))
    PRINT #fh%, "PREVIEW_H=" + _TRIM$(STR$(CFG.PREVIEW_H%))
    PRINT #fh%, ""
    PRINT #fh%, "# Preview Window: follow-pointer mode (1=yes, 0=no)"
    PRINT #fh%, "PREVIEW_FOLLOW=" + _TRIM$(STR$(CFG.PREVIEW_FOLLOW%))
    PRINT #fh%, ""
    PRINT #fh%, "# Preview Window: zoom level (1.0 = 1:1)"
    PRINT #fh%, "PREVIEW_ZOOM=" + _TRIM$(STR$(CFG.PREVIEW_ZOOM!))
    PRINT #fh%, ""
    PRINT #fh%, "# Preview Window: pan position (canvas pixels)"
    PRINT #fh%, "PREVIEW_PAN_X=" + _TRIM$(STR$(CFG.PREVIEW_PAN_X!))
    PRINT #fh%, "PREVIEW_PAN_Y=" + _TRIM$(STR$(CFG.PREVIEW_PAN_Y!))
    PRINT #fh%, ""

    PRINT #fh%, "# Preview Window: mode (0=Follow, 1=Floating Image)"
    PRINT #fh%, "PREVIEW_MODE=" + _TRIM$(STR$(CFG.PREVIEW_MODE%))
    PRINT #fh%, ""
    PRINT #fh%, "# Preview Window: allow color picking from preview (1=yes, 0=no)"
    PRINT #fh%, "PREVIEW_COLOR_PICK=" + _TRIM$(STR$(CFG.PREVIEW_COLOR_PICK%))
    PRINT #fh%, ""
    PRINT #fh%, "# Preview Window: Bin Quick Look on drawer hover (1=yes, 0=no)"
    PRINT #fh%, "PREVIEW_BIN_QUICK_LOOK=" + _TRIM$(STR$(CFG.PREVIEW_BIN_QUICK_LOOK%))
    PRINT #fh%, ""
    PRINT #fh%, "# Preview Window: last loaded floating image path"
    PRINT #fh%, "PREVIEW_FLOAT_IMAGE_PATH=" + CFG.PREVIEW_FLOAT_IMAGE_PATH$
    PRINT #fh%, ""
    PRINT #fh%, "# Preview Window: last directory for Load Image dialog"
    PRINT #fh%, "PREVIEW_FLOAT_LAST_DIR=" + CFG.PREVIEW_FLOAT_LAST_DIR$
    PRINT #fh%, ""

    PRINT #fh%, "# Pixel Analyzer: confidence threshold percent (10-90)"
    IF CFG.PIXEL_ANALYZER_CONFIDENCE% < 10 THEN CFG.PIXEL_ANALYZER_CONFIDENCE% = 10
    IF CFG.PIXEL_ANALYZER_CONFIDENCE% > 90 THEN CFG.PIXEL_ANALYZER_CONFIDENCE% = 90
    PRINT #fh%, "PIXEL_ANALYZER_CONFIDENCE=" + _TRIM$(STR$(CFG.PIXEL_ANALYZER_CONFIDENCE%))
    PRINT #fh%, ""

    ' Edit Bar settings
    PRINT #fh%, "# Edit Bar: show on startup (1=yes, 0=no)"
    PRINT #fh%, "EDIT_BAR_VISIBLE=" + _TRIM$(STR$(CFG.EDIT_BAR_VISIBLE%))
    PRINT #fh%, ""
    PRINT #fh%, "# Edit Bar: dock position (LEFT or RIGHT)"
    PRINT #fh%, "EDIT_BAR_DOCK_POSITION=" + _TRIM$(CFG.EDIT_BAR_DOCK_POSITION$)
    PRINT #fh%, ""

    ' Advanced Bar settings
    PRINT #fh%, "# Advanced Bar: show on startup (1=yes, 0=no)"
    PRINT #fh%, "ADV_BAR_VISIBLE=" + _TRIM$(STR$(CFG.ADV_BAR_VISIBLE%))
    PRINT #fh%, ""
    PRINT #fh%, "# Advanced Bar: dock position (LEFT or RIGHT)"
    PRINT #fh%, "ADV_BAR_DOCK_POSITION=" + _TRIM$(CFG.ADV_BAR_DOCK_POSITION$)
    PRINT #fh%, ""

    ' Character Map settings
    PRINT #fh%, "# Character Map: show on startup (1=yes, 0=no)"
    PRINT #fh%, "CHARMAP_VISIBLE=" + _TRIM$(STR$(CFG.CHARMAP_VISIBLE%))
    PRINT #fh%, ""
    PRINT #fh%, "# Character Map: dock position (LEFT or RIGHT)"
    PRINT #fh%, "CHARMAP_PANEL_DOCK_EDGE=" + _TRIM$(CFG.CHARMAP_PANEL_DOCK_EDGE$)
    PRINT #fh%, ""
    PRINT #fh%, "# Character Map: glyph cells per row (4-16, default 16)"
    PRINT #fh%, "CHARMAP_CELLS_PER_ROW=" + _TRIM$(STR$(CFG.CHARMAP_CELLS_PER_ROW%))
    PRINT #fh%, ""
    PRINT #fh%, "# Character Map: zoom multiplier (0.25-4.0, e.g. 0.5, 1.0, 1.5, 2.0)"
    PRINT #fh%, "CHARMAP_ZOOM_LEVEL=" + _TRIM$(STR$(CFG.CHARMAP_ZOOM_LEVEL!))
    PRINT #fh%, ""
    PRINT #fh%, "# Character Map: cell width (pixels, default 8)"
    PRINT #fh%, "CHARMAP_CELL_W=" + _TRIM$(STR$(CFG.CHARMAP_CELL_W%))
    PRINT #fh%, ""
    PRINT #fh%, "# Character Map: cell height (pixels, default 8)"
    PRINT #fh%, "CHARMAP_CELL_H=" + _TRIM$(STR$(CFG.CHARMAP_CELL_H%))
    PRINT #fh%, ""
    PRINT #fh%, "# Character Map: cell padding (pixels, default 1)"
    PRINT #fh%, "CHARMAP_CELL_PADDING=" + _TRIM$(STR$(CFG.CHARMAP_CELL_PADDING%))
    PRINT #fh%, ""
    PRINT #fh%, "# Character Map: default font (empty = use text tool font)"
    PRINT #fh%, "CHARMAP_DEFAULT_FONT=" + CFG.CHARMAP_DEFAULT_FONT$
    PRINT #fh%, ""
    PRINT #fh%, "# Character Map: minimum preview font size in pixels (4-128, default 4)"
    PRINT #fh%, "CHARMAP_MIN_FONT_SIZE=" + _TRIM$(STR$(CFG.CHARMAP_MIN_FONT_SIZE%))
    PRINT #fh%, ""
    PRINT #fh%, "# Character Map: maximum preview font size in pixels (4-128, default 16)"
    PRINT #fh%, "CHARMAP_MAX_FONT_SIZE=" + _TRIM$(STR$(CFG.CHARMAP_MAX_FONT_SIZE%))
    PRINT #fh%, ""
    PRINT #fh%, "# Character Map: last selected character (0-255, -1=none)"
    PRINT #fh%, "CHARMAP_CHAR_SELECTED=" + _TRIM$(STR$(CFG.CHARMAP_CHAR_SELECTED%))
    ' Note: CHARMAP_USE_CHARS is saved per-document in .draw files, not in global config
    PRINT #fh%, ""
    PRINT #fh%, "# Character Grid: cell width (0 = match font)"
    PRINT #fh%, "CHAR_GRID_WIDTH=" + _TRIM$(STR$(CFG.CHAR_GRID_WIDTH%))
    PRINT #fh%, ""
    PRINT #fh%, "# Character Grid: cell height (0 = match font)"
    PRINT #fh%, "CHAR_GRID_HEIGHT=" + _TRIM$(STR$(CFG.CHAR_GRID_HEIGHT%))
    PRINT #fh%, ""
    PRINT #fh%, "# Character Grid: opacity (0-255, 0 = use theme)"
    PRINT #fh%, "CHAR_GRID_OPACITY=" + _TRIM$(STR$(CFG.CHAR_GRID_OPACITY%))
    PRINT #fh%, ""
    PRINT #fh%, "# Character Grid: line color (hex RGB, empty = use theme)"
    IF CFG.CHAR_GRID_COLOR_FG~& <> 0 THEN
        DIM cgr AS INTEGER, cgg AS INTEGER, cgb AS INTEGER
        cgr% = _RED32(CFG.CHAR_GRID_COLOR_FG~&)
        cgg% = _GREEN32(CFG.CHAR_GRID_COLOR_FG~&)
        cgb% = _BLUE32(CFG.CHAR_GRID_COLOR_FG~&)
        PRINT #fh%, "CHAR_GRID_COLOR_FG=" + RIGHT$("0" + HEX$(cgr%), 2) + RIGHT$("0" + HEX$(cgg%), 2) + RIGHT$("0" + HEX$(cgb%), 2)
    ELSE
        PRINT #fh%, "#CHAR_GRID_COLOR_FG="
    END IF
    PRINT #fh%, ""
    PRINT #fh%, "# Character Map: TAB character width (default 4)"
    PRINT #fh%, "CHARMAP_TAB_CHARS=" + _TRIM$(STR$(CFG.CHARMAP_TAB_CHARS%))
    PRINT #fh%, ""

    ' Default drawer set files
    PRINT #fh%, "# Default drawer set files (.dset) loaded on startup"
    PRINT #fh%, "# Empty = use built-in theme samples. Path relative to DRAW dir or absolute."
    PRINT #fh%, "DEFAULT_DSET_BRUSHES_FILE=" + CFG.DEFAULT_DSET_BRUSHES_FILE$
    PRINT #fh%, "DEFAULT_DSET_PATTERNS_FILE=" + CFG.DEFAULT_DSET_PATTERNS_FILE$
    PRINT #fh%, "DEFAULT_DSET_GRADIENTS_FILE=" + CFG.DEFAULT_DSET_GRADIENTS_FILE$
    PRINT #fh%, ""

    ' Canvas size settings
    PRINT #fh%, "# Default canvas size for new documents (0=fill viewport)"
    PRINT #fh%, "# Canvas is centered within the viewport when smaller"
    PRINT #fh%, "DEFAULT_CANVAS_SIZE_W=" + _TRIM$(STR$(CFG.DEFAULT_CANVAS_SIZE_W%))
    PRINT #fh%, "DEFAULT_CANVAS_SIZE_H=" + _TRIM$(STR$(CFG.DEFAULT_CANVAS_SIZE_H%))
    PRINT #fh%, ""
    PRINT #fh%, "# Background color around canvas when canvas is smaller than viewport"
    PRINT #fh%, "# Hex RGB, e.g., 303030 for dark gray"
    DIM apronR%, apronG%, apronB%
    apronR% = _RED32(CFG.CANVAS_APRON_COLOR~&)
    apronG% = _GREEN32(CFG.CANVAS_APRON_COLOR~&)
    apronB% = _BLUE32(CFG.CANVAS_APRON_COLOR~&)
    PRINT #fh%, "CANVAS_APRON_COLOR=" + RIGHT$("0" + HEX$(apronR%), 2) + RIGHT$("0" + HEX$(apronG%), 2) + RIGHT$("0" + HEX$(apronB%), 2)
    PRINT #fh%, ""

    ' Font source toggles
    PRINT #fh%, "# Font source toggles (TRUE/FALSE)"
    PRINT #fh%, "# Controls which font directories are scanned at startup"
    IF CFG.FONTS_INCLUDE_OS_INSTALLED% THEN
        PRINT #fh%, "FONTS_INCLUDE_OS_INSTALLED=TRUE"
    ELSE
        PRINT #fh%, "FONTS_INCLUDE_OS_INSTALLED=FALSE"
    END IF
    IF CFG.FONTS_INCLUDE_DRAW_BITMAP% THEN
        PRINT #fh%, "FONTS_INCLUDE_DRAW_BITMAP=TRUE"
    ELSE
        PRINT #fh%, "FONTS_INCLUDE_DRAW_BITMAP=FALSE"
    END IF
    IF CFG.FONTS_INCLUDE_DRAW_EXTRAS% THEN
        PRINT #fh%, "FONTS_INCLUDE_DRAW_EXTRAS=TRUE"
    ELSE
        PRINT #fh%, "FONTS_INCLUDE_DRAW_EXTRAS=FALSE"
    END IF
    IF CFG.FONTS_INCLUDE_USER% THEN
        PRINT #fh%, "FONTS_INCLUDE_USER=TRUE"
    ELSE
        PRINT #fh%, "FONTS_INCLUDE_USER=FALSE"
    END IF
    IF CFG.FONTS_INCLUDE_USER_BITMAP% THEN
        PRINT #fh%, "FONTS_INCLUDE_USER_BITMAP=TRUE"
    ELSE
        PRINT #fh%, "FONTS_INCLUDE_USER_BITMAP=FALSE"
    END IF
    PRINT #fh%, ""

    ' Smart Guides
    PRINT #fh%, "# Smart Guides: show alignment guides when moving layers"
    IF CFG.SMART_GUIDES_ENABLED% THEN
        PRINT #fh%, "SMART_GUIDES_ENABLED=TRUE"
    ELSE
        PRINT #fh%, "SMART_GUIDES_ENABLED=FALSE"
    END IF
    IF CFG.SMART_GUIDES_SNAP% THEN
        PRINT #fh%, "SMART_GUIDES_SNAP=TRUE"
    ELSE
        PRINT #fh%, "SMART_GUIDES_SNAP=FALSE"
    END IF
    IF CFG.SMART_GUIDES_DISTANCE% > 0 THEN
        PRINT #fh%, "SMART_GUIDES_DISTANCE=" + _TRIM$(STR$(CFG.SMART_GUIDES_DISTANCE%))
    END IF
    IF CFG.SMART_GUIDES_OPACITY% > 0 THEN
        PRINT #fh%, "SMART_GUIDES_OPACITY=" + _TRIM$(STR$(CFG.SMART_GUIDES_OPACITY%))
    END IF
    IF CFG.SMART_GUIDES_COLOR_FG~& <> 0 THEN
        DIM sgr AS INTEGER, sgg AS INTEGER, sgb AS INTEGER
        sgr% = _RED32(CFG.SMART_GUIDES_COLOR_FG~&)
        sgg% = _GREEN32(CFG.SMART_GUIDES_COLOR_FG~&)
        sgb% = _BLUE32(CFG.SMART_GUIDES_COLOR_FG~&)
        PRINT #fh%, "SMART_GUIDES_COLOR_FG=" + RIGHT$("0" + HEX$(sgr%), 2) + RIGHT$("0" + HEX$(sgg%), 2) + RIGHT$("0" + HEX$(sgb%), 2)
    END IF
    PRINT #fh%, ""

    ' Text tool default font settings
    PRINT #fh%, "# Text tool default font name (empty = use Tiny5 Regular)"
    PRINT #fh%, "# Must match a display name in the font list (e.g., Tiny5 Regular, DejaVu Sans)"
    PRINT #fh%, "FONT_DEFAULT_FONT=" + CFG.FONT_DEFAULT_FONT$
    PRINT #fh%, ""
    PRINT #fh%, "# Text tool default font size in pixels (4-128, 0 = use program default 8)"
    PRINT #fh%, "FONT_DEFAULT_SIZE=" + _TRIM$(STR$(CFG.FONT_DEFAULT_SIZE%))
    PRINT #fh%, ""

    ' Recent files
    PRINT #fh%, "# Recent files (auto-updated, most recent first)"
    DIM rcfI AS INTEGER
    FOR rcfI% = 1 TO RECENT_FILE_COUNT%
        PRINT #fh%, "RECENT_FILE_" + _TRIM$(STR$(rcfI%)) + "=" + RECENT_FILES(rcfI%)
    NEXT rcfI%
    PRINT #fh%, ""

    ' Recent preview images
    PRINT #fh%, "# Recent preview images (auto-updated, most recent first)"
    DIM rpfI AS INTEGER
    FOR rpfI% = 1 TO RECENT_PREVIEW_COUNT%
        PRINT #fh%, "RECENT_PREVIEW_FILE_" + _TRIM$(STR$(rpfI%)) + "=" + RECENT_PREVIEW_FILES(rpfI%)
    NEXT rpfI%
    PRINT #fh%, ""
    
    CLOSE #fh%
END SUB

''
' Extract directory path from a full filepath.
' @param filepath STRING Full path to a file
' @return STRING Directory portion (without trailing separator)
'
FUNCTION CONFIG_extract_dir$ (filepath AS STRING)
    DIM ced_i AS INTEGER
    FOR ced_i% = LEN(filepath$) TO 1 STEP -1
        IF MID$(filepath$, ced_i%, 1) = "/" OR MID$(filepath$, ced_i%, 1) = "\" THEN
            CONFIG_extract_dir$ = LEFT$(filepath$, ced_i% - 1)
            EXIT FUNCTION
        END IF
    NEXT ced_i%
    CONFIG_extract_dir$ = ""
END FUNCTION


''
' Add a file to the top of the recent files list.
' Deduplicates: if file already exists in list, moves it to top.
' Caps at RECENT_FILES_MAX entries.
' @param filepath STRING Full path to the file to add
'
SUB RECENT_add_file (filepath AS STRING)
    IF filepath$ = "" THEN EXIT SUB
    
    ' Check if file already exists in the list
    DIM raf_i AS INTEGER, raf_foundAt AS INTEGER
    raf_foundAt% = 0
    FOR raf_i% = 1 TO RECENT_FILE_COUNT%
        IF RECENT_FILES(raf_i%) = filepath$ THEN
            raf_foundAt% = raf_i%
            EXIT FOR
        END IF
    NEXT raf_i%
    
    ' Shift entries down to make room at position 1
    IF raf_foundAt% > 0 THEN
        ' Move existing entry to top â€” shift entries above it down
        FOR raf_i% = raf_foundAt% TO 2 STEP -1
            RECENT_FILES(raf_i%) = RECENT_FILES(raf_i% - 1)
        NEXT raf_i%
    ELSE
        ' New entry â€” shift everything down, cap at max
        IF RECENT_FILE_COUNT% < RECENT_FILES_MAX THEN
            RECENT_FILE_COUNT% = RECENT_FILE_COUNT% + 1
        END IF
        FOR raf_i% = RECENT_FILE_COUNT% TO 2 STEP -1
            RECENT_FILES(raf_i%) = RECENT_FILES(raf_i% - 1)
        NEXT raf_i%
    END IF
    
    ' Place new entry at top
    RECENT_FILES(1) = filepath$
    
    ' Save config to persist
    CONFIG_save
END SUB


''
' Clear all recent files.
'
SUB RECENT_clear ()
    DIM rc_i AS INTEGER
    FOR rc_i% = 1 TO RECENT_FILES_MAX
        RECENT_FILES(rc_i%) = ""
    NEXT rc_i%
    RECENT_FILE_COUNT% = 0
    CONFIG_save
END SUB


''
' Add a file to the top of the recent preview images list.
' Deduplicates: if file already exists in list, moves it to top.
' Caps at RECENT_PREVIEW_MAX entries.
' @param filepath STRING Full path to the preview image to add
'
SUB RECENT_PREVIEW_add_file (filepath AS STRING)
    IF filepath$ = "" THEN EXIT SUB
    
    ' Check if file already exists in the list
    DIM rpaf_i AS INTEGER, rpaf_foundAt AS INTEGER
    rpaf_foundAt% = 0
    FOR rpaf_i% = 1 TO RECENT_PREVIEW_COUNT%
        IF RECENT_PREVIEW_FILES(rpaf_i%) = filepath$ THEN
            rpaf_foundAt% = rpaf_i%
            EXIT FOR
        END IF
    NEXT rpaf_i%
    
    ' Shift entries down to make room at position 1
    IF rpaf_foundAt% > 0 THEN
        ' Move existing entry to top â€” shift entries above it down
        FOR rpaf_i% = rpaf_foundAt% TO 2 STEP -1
            RECENT_PREVIEW_FILES(rpaf_i%) = RECENT_PREVIEW_FILES(rpaf_i% - 1)
        NEXT rpaf_i%
    ELSE
        ' New entry â€” shift everything down, cap at max
        IF RECENT_PREVIEW_COUNT% < RECENT_PREVIEW_MAX THEN
            RECENT_PREVIEW_COUNT% = RECENT_PREVIEW_COUNT% + 1
        END IF
        FOR rpaf_i% = RECENT_PREVIEW_COUNT% TO 2 STEP -1
            RECENT_PREVIEW_FILES(rpaf_i%) = RECENT_PREVIEW_FILES(rpaf_i% - 1)
        NEXT rpaf_i%
    END IF
    
    ' Place new entry at top
    RECENT_PREVIEW_FILES(1) = filepath$
    
    ' Save config to persist
    CONFIG_save
END SUB


''
' Clear all recent preview images.
'
SUB RECENT_PREVIEW_clear ()
    DIM rpc_i AS INTEGER
    FOR rpc_i% = 1 TO RECENT_PREVIEW_MAX
        RECENT_PREVIEW_FILES(rpc_i%) = ""
    NEXT rpc_i%
    RECENT_PREVIEW_COUNT% = 0
    CONFIG_save
END SUB


''
' Upgrade an existing config file by adding any missing keys from the current defaults.
' Reads the existing config to find which keys are present, generates a fresh default
' config, identifies missing keys (with their comments), and appends them.
' Shows a message box informing the user what was added.
'
SUB CONFIG_upgrade ()
    DIM fh AS INTEGER
    DIM configLine AS STRING
    DIM configKey AS STRING
    DIM eqPos AS INTEGER

    ' --- Step 1: Collect existing keys from current config file ---
    CONST MAX_KEYS = 200
    DIM existingKeys(1 TO MAX_KEYS) AS STRING
    DIM existingKeyCount AS INTEGER
    existingKeyCount% = 0

    IF NOT _FILEEXISTS(CONFIG_FILE_PATH$) THEN
        ' Nothing to upgrade â€” file doesn't exist yet, CONFIG_load will create it
        EXIT SUB
    END IF

    fh% = FREEFILE
    OPEN CONFIG_FILE_PATH$ FOR INPUT AS #fh%
    DO WHILE NOT EOF(fh%)
        LINE INPUT #fh%, configLine$
        configLine$ = _TRIM$(configLine$)
        ' Skip empty/comment lines
        IF LEN(configLine$) > 0 AND LEFT$(configLine$, 1) <> "#" AND LEFT$(configLine$, 1) <> ";" THEN
            eqPos% = INSTR(configLine$, "=")
            IF eqPos% > 0 THEN
                configKey$ = UCASE$(_TRIM$(LEFT$(configLine$, eqPos% - 1)))
                IF existingKeyCount% < MAX_KEYS THEN
                    existingKeyCount% = existingKeyCount% + 1
                    existingKeys(existingKeyCount%) = configKey$
                END IF
            END IF
        END IF
    LOOP
    CLOSE #fh%

    ' --- Step 2: Generate fresh default config into a temp file ---
    DIM tempPath AS STRING
    tempPath$ = CONFIG_FILE_PATH$ + ".upgrade_tmp"

    ' Temporarily swap config path to write defaults to temp file
    DIM savedPath AS STRING
    savedPath$ = CONFIG_FILE_PATH$
    CONFIG_FILE_PATH$ = tempPath$
    CONFIG_save
    CONFIG_FILE_PATH$ = savedPath$

    ' --- Step 3: Read temp file, find lines whose keys are missing ---
    DIM missingLines AS STRING  ' Accumulated lines to append (with comments)
    DIM missingKeys AS STRING   ' List of missing key names for the message
    DIM pendingComments AS STRING ' Comment lines that precede a key
    DIM missingCount AS INTEGER
    missingLines$ = ""
    missingKeys$ = ""
    pendingComments$ = ""
    missingCount% = 0

    fh% = FREEFILE
    OPEN tempPath$ FOR INPUT AS #fh%
    DO WHILE NOT EOF(fh%)
        LINE INPUT #fh%, configLine$

        ' Track comments/blanks â€” they might be headers for the next key
        IF LEN(_TRIM$(configLine$)) = 0 OR LEFT$(_TRIM$(configLine$), 1) = "#" OR LEFT$(_TRIM$(configLine$), 1) = ";" THEN
            pendingComments$ = pendingComments$ + configLine$ + CHR$(10)
        ELSE
            ' This is a key=value line
            eqPos% = INSTR(configLine$, "=")
            IF eqPos% > 0 THEN
                configKey$ = UCASE$(_TRIM$(LEFT$(configLine$, eqPos% - 1)))

                ' Check if this key exists in the original config
                DIM keyFound AS INTEGER
                DIM ki AS INTEGER
                keyFound% = FALSE
                FOR ki% = 1 TO existingKeyCount%
                    IF existingKeys(ki%) = configKey$ THEN
                        keyFound% = TRUE
                        EXIT FOR
                    END IF
                NEXT ki%

                IF NOT keyFound% THEN
                    ' Skip header comment block, RECENT_FILE, and RECENT_PREVIEW_FILE entries
                    IF LEFT$(configKey$, 12) <> "RECENT_FILE_" AND LEFT$(configKey$, 20) <> "RECENT_PREVIEW_FILE_" THEN
                        missingLines$ = missingLines$ + CHR$(10) + pendingComments$ + configLine$ + CHR$(10)
                        missingCount% = missingCount% + 1
                        IF missingKeys$ <> "" THEN missingKeys$ = missingKeys$ + ", "
                        missingKeys$ = missingKeys$ + configKey$
                    END IF
                END IF
            END IF
            pendingComments$ = "" ' Reset â€” these comments belonged to this key
        END IF
    LOOP
    CLOSE #fh%

    ' Clean up temp file
    KILL tempPath$

    ' --- Step 4: Append missing keys to existing config file ---
    IF missingCount% > 0 THEN
        fh% = FREEFILE
        OPEN CONFIG_FILE_PATH$ FOR APPEND AS #fh%
        PRINT #fh%, ""
        PRINT #fh%, "# --- Added by --config-upgrade ---"
        PRINT #fh%, missingLines$;
        CLOSE #fh%

        ' Inform the user
        DIM upgradeMsg AS STRING
        upgradeMsg$ = "Config upgraded: " + _TRIM$(STR$(missingCount%)) + " new setting(s) added to:" + CHR$(10) + CHR$(10)
        upgradeMsg$ = upgradeMsg$ + CONFIG_FILE_PATH$ + CHR$(10) + CHR$(10)
        upgradeMsg$ = upgradeMsg$ + "New keys: " + missingKeys$
        DRAW_alert "Config Upgrade", upgradeMsg$

        ' Re-load the config to pick up any new defaults
        ' (recursive call is safe â€” CMDLINE_CONFIG_UPGRADE% prevents infinite loop)
        CMDLINE_CONFIG_UPGRADE% = FALSE
        CONFIG_load
    ELSE
        DRAW_alert "Config Upgrade", _
            "Config file is up to date -- no new settings to add." + CHR$(10) + CHR$(10) + _
            CONFIG_FILE_PATH$
    END IF
END SUB


''
' Extract just the filename from a full filepath.
' @param filepath STRING Full path to a file
' @return STRING Filename only (no directory)
'
FUNCTION RECENT_extract_filename$ (filepath AS STRING)
    DIM ref_i AS INTEGER
    FOR ref_i% = LEN(filepath$) TO 1 STEP -1
        IF MID$(filepath$, ref_i%, 1) = "/" OR MID$(filepath$, ref_i%, 1) = "\" THEN
            RECENT_extract_filename$ = MID$(filepath$, ref_i% + 1)
            EXIT FUNCTION
        END IF
    NEXT ref_i%
    RECENT_extract_filename$ = filepath$
END FUNCTION