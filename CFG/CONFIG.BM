                        CFG.BROWSER_DEFAULT_ZOOM_LEVEL% = VAL(configValue$)
                    CASE "BROWSER_DEFAULT_SORT_TYPE"
                        CFG.BROWSER_DEFAULT_SORT_TYPE% = VAL(configValue$)
