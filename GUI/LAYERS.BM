''
' DRAW - GUI/LAYERS.BM
' =============================================================================
' Layers management subs and functions.
'
' @author Rick Christy <grymmjack@gmail.com>
'
$INCLUDEONCE


''
' Initialize the layer system
' Creates first layer and loads font
' 
SUB LAYERS_init ()
    DIM i          AS INTEGER
    DIM uiFontSize AS INTEGER
    
    ' Initialize all layer slots to empty
    FOR i% = 1 TO MAX_LAYERS
        LAYERS(i%).historyId&       = 0
        LAYERS(i%).zIndex%          = 0
        LAYERS(i%).imgWidth%        = 0
        LAYERS(i%).imgHeight%       = 0
        LAYERS(i%).imgHandle&       = 0
        LAYERS(i%).visible%         = FALSE
        LAYERS(i%).isSelected%      = FALSE
        LAYERS(i%).lastSelected%    = FALSE
        LAYERS(i%).name             = ""
        LAYERS(i%).opacity%         = 255
        LAYERS(i%).opacityLock%     = FALSE
        LAYERS(i%).opacityCacheImg& = 0
        LAYERS(i%).opacityCacheVal% = 0
        LAYERS(i%).contentDirty%    = FALSE
        LAYERS(i%).layerType%       = LAYER_TYPE_IMAGE
        LAYERS(i%).textDataIdx%     = 0
        LAYERS(i%).parentGroupIdx%  = 0
        LAYERS(i%).collapsed%       = FALSE
        LAYERS(i%).passThrough%     = FALSE
        LAYERS(i%).apronW%          = 0
        LAYERS(i%).apronH%          = 0
        LAYERS(i%).apronCacheImg&   = 0
        LAYERS(i%).apronCacheValid% = FALSE
    NEXT i%
    
    ' Initialize panel state
    LAYER_PANEL.visible%          = TRUE ' Visible by default
    LAYER_PANEL.width%            = CFG.LAYER_PANEL_WIDTH%
    LAYER_PANEL.scrollOffset%     = 0
    LAYER_PANEL.hoverRow%         = -1
    LAYER_PANEL.draggingRow%      = -1
    LAYER_PANEL.dragStartY%       = 0
    LAYER_PANEL.opacityDrag%      = FALSE
    LAYER_PANEL.opacityDragLayer% = 0
    
    ' Load Tiny5 font for panel text
    IF LAYER_PANEL.fontHandle& > 16 THEN _FREEFONT LAYER_PANEL.fontHandle&
    uiFontSize% = THEME.GLOBAL_FONT_SIZE%
    IF uiFontSize% < 1 THEN uiFontSize% = 8
    LAYER_PANEL.fontHandle& = _LOADFONT(THEME_font_path$(THEME.GLOBAL_FONT_FILE$), uiFontSize%, "DONTBLEND")
    IF LAYER_PANEL.fontHandle& < = 0 THEN
        LAYER_PANEL.fontHandle& = 16 ' Fallback to default font
    END IF
    
    ' Initialize layer count and current layer
    LAYER_COUNT%           = 0
    CURRENT_LAYER%         = 0
    NEXT_LAYER_HISTORY_ID& = 1
    NEXT_GROUP_NUM%        = 0
    
    ' Initialize multi-select state (will be properly set once first layer is created)
    DIM msInit AS INTEGER
    FOR msInit% = 1 TO MAX_LAYERS
        MULTI_SELECT_LAYERS(msInit%) = FALSE
    NEXT msInit%
    MULTI_SELECT_COUNT% = 0
    
    ' Create default initial layer (Background)
    DIM defaultLayer AS INTEGER
    defaultLayer% = LAYERS_new%
    IF defaultLayer% > 0 THEN
        LAYERS(defaultLayer%).name = "Background"
        ' Fill background layer with configured default color
        DIM oldDest2 AS LONG
        oldDest2& = _DEST
        _DEST LAYERS(defaultLayer%).imgHandle&
        CLS , CFG.DEFAULT_LAYER_BG_COLOR~&
        ' Copy any existing content from SCRN.PAINTING to the layer
        _PUTIMAGE , SCRN.PAINTING&
        _DEST oldDest2&
    END IF
END SUB


''
' Allocate a stable runtime layer id for the unified history system.
' @return LONG - Unique layer history ID (monotonically increasing)
'
FUNCTION LAYERS_alloc_history_id& ()
    IF NEXT_LAYER_HISTORY_ID& < 1 THEN NEXT_LAYER_HISTORY_ID& = 1
    LAYERS_alloc_history_id& = NEXT_LAYER_HISTORY_ID&
    NEXT_LAYER_HISTORY_ID& = NEXT_LAYER_HISTORY_ID& + 1
END FUNCTION


''
' Recount layers by scanning all 64 slots for valid image handles.
' Safety net to ensure LAYER_COUNT% is always accurate.
' @return INTEGER The actual number of layers with valid imgHandle&
'
FUNCTION LAYERS_recount% ()
    DIM lrc_i AS INTEGER, lrc_c AS INTEGER
    lrc_c% = 0
    FOR lrc_i% = 1 TO MAX_LAYERS
        IF LAYERS(lrc_i%).imgHandle& <> 0 THEN lrc_c% = lrc_c% + 1
    NEXT lrc_i%
    LAYERS_recount% = lrc_c%
END FUNCTION


''
' Show the "max layers reached" alert dialog.
' Call before any operation that would allocate a new layer.
'
SUB LAYERS_show_max_alert ()
    POINTER_hide_for_dialog
    DRAW_alert "Layer Limit Reached", "Can't perform layer operation because all layers used."
    POINTER_show_after_dialog
    MOUSE_cleanup_after_dialog FALSE
END SUB


''
' Create a new layer above the currently selected layer
' Returns the index of the new layer, or 0 if max layers reached
' @return INTEGER - Index of the newly created layer, or 0 on failure
' 
FUNCTION LAYERS_new% ()
    DIM newIndex AS INTEGER
    DIM i        AS INTEGER
    DIM currentZ AS INTEGER
    DIM newZ     AS INTEGER
    ' Check if we've hit the max
    IF LAYER_COUNT% >= CFG.NUM_LAYERS% THEN
        LAYERS_new% = 0
        EXIT FUNCTION
    END IF
    
    ' Find first empty slot
    newIndex% = 0
    FOR i% = 1 TO MAX_LAYERS
        IF LAYERS(i%).imgHandle& = 0 THEN
            newIndex% = i%
            EXIT FOR
        END IF
    NEXT i%
    
    IF newIndex% = 0 THEN
        LAYERS_new% = 0
        EXIT FUNCTION
    END IF
    
    ' Get the zIndex of the currently selected layer
    ' New layer will be inserted directly above it
    DIM hasCurrentLayer AS INTEGER
    hasCurrentLayer% = FALSE
    IF CURRENT_LAYER% > 0 AND CURRENT_LAYER% < = MAX_LAYERS THEN
        IF LAYERS(CURRENT_LAYER%).imgHandle& <> 0 THEN
            hasCurrentLayer% = TRUE
        END IF
    END IF
    
    IF hasCurrentLayer% THEN
        currentZ% = LAYERS(CURRENT_LAYER%).zIndex%
        newZ%     = currentZ% + 1
        
        ' Shift all layers with zIndex > currentZ up by 1 to make room
        FOR i% = 1 TO MAX_LAYERS
            IF LAYERS(i%).imgHandle& <> 0 AND LAYERS(i%).zIndex% > currentZ% THEN
                LAYERS(i%).zIndex% = LAYERS(i%).zIndex% + 1
            END IF
        NEXT i%
    ELSE
        ' No valid current layer, put new layer on top
        newZ% = LAYER_COUNT% + 1
    END IF
    
    ' Create the layer image buffer
    LAYERS(newIndex%).imgWidth%  = SCRN.canvasW&
    LAYERS(newIndex%).imgHeight% = SCRN.canvasH&
    LAYERS(newIndex%).imgHandle& = _NEWIMAGE(SCRN.canvasW&, SCRN.canvasH&, 32)
    LAYERS(newIndex%).apronW%    = 0
    LAYERS(newIndex%).apronH%    = 0
    IF LAYERS(newIndex%).imgHandle& >= -1 THEN
        _LOGERROR "LAYERS_new: _NEWIMAGE failed for layer slot " + STR$(newIndex%) + " (handle=" + STR$(LAYERS(newIndex%).imgHandle&) + ")"
        LAYERS(newIndex%).imgHandle& = 0
        LAYERS_new%                  = 0
        EXIT FUNCTION
    END IF
    
    ' Clear to transparent (new layers are always transparent)
    DIM oldDest AS LONG
    oldDest& = _DEST
    _DEST LAYERS(newIndex%).imgHandle&
    CLS , _RGBA32(0, 0, 0, 0)
    _DEST oldDest&
    
    ' Set default properties
    LAYER_COUNT% = LAYER_COUNT% + 1
    LAYERS(newIndex%).historyId&    = LAYERS_alloc_history_id&
    LAYERS(newIndex%).zIndex%       = newZ% ' Insert above current layer
    LAYERS(newIndex%).visible%      = TRUE
    LAYERS(newIndex%).isSelected%   = FALSE
    LAYERS(newIndex%).lastSelected% = FALSE
    LAYERS(newIndex%).name          = "Layer " + _TRIM$(STR$(LAYER_COUNT%))
    LAYERS(newIndex%).opacity%      = 255
    LAYERS(newIndex%).opacityLock%  = FALSE
    LAYERS(newIndex%).blendMode%    = BLEND_NORMAL
    LAYERS(newIndex%).layerType%    = LAYER_TYPE_IMAGE
    LAYERS(newIndex%).textDataIdx%  = 0
    ' Inherit parent group from the current layer so new layers inside groups stay nested
    IF hasCurrentLayer% THEN
        LAYERS(newIndex%).parentGroupIdx% = LAYERS(CURRENT_LAYER%).parentGroupIdx%
    ELSE
        LAYERS(newIndex%).parentGroupIdx% = 0
    END IF
    LAYERS(newIndex%).collapsed%   = FALSE
    LAYERS(newIndex%).passThrough% = FALSE
    LAYERS(newIndex%).exportMode%  = EXPORT_MODE_VECTOR

    IF NOT HISTORY_IN_PROGRESS% THEN
        HISTORY_record_layer_add LAYERS(newIndex%).historyId&, newIndex%, newZ%, "Layer Add"
    END IF
    
    ' Select the new layer
    LAYERS_select newIndex%
    
    BLEND_invalidate_cache
    INVALIDATE_scene
    LAYERS_new% = newIndex%
END FUNCTION


''
' Create a new layer at the very top of the stack (above all existing layers).
' SHIFT+New Layer button variant.
' @return INTEGER - Index of the newly created layer, or 0 on failure
'
FUNCTION LAYERS_new_at_top% ()
    DIM topIdx AS INTEGER
    DIM topZ   AS INTEGER
    DIM i      AS INTEGER
    ' Find the layer with the highest zIndex (the current topmost layer)
    topIdx% = 0
    topZ%   = 0
    FOR i% = 1 TO MAX_LAYERS
        IF LAYERS(i%).imgHandle& <> 0 THEN
            IF LAYERS(i%).zIndex% > topZ% THEN
                topZ%   = LAYERS(i%).zIndex%
                topIdx% = i%
            END IF
        END IF
    NEXT i%
    ' Temporarily select the topmost layer so LAYERS_new% inserts above it
    IF topIdx% > 0 THEN LAYERS_select topIdx%
    LAYERS_new_at_top% = LAYERS_new%
END FUNCTION


''
' Create a new text layer above the current layer.
' @param x% Canvas X origin for text placement
' @param y% Canvas Y origin for text placement
' @return INTEGER - Layer index, or 0 on failure
'
FUNCTION LAYERS_new_text% (x%, y%)
    LAYERS_new_text% = 0

    DIM newIdx AS INTEGER
    newIdx% = LAYERS_new%
    IF newIdx% = 0 THEN EXIT FUNCTION

    ' Allocate text data
    DIM tdIdx AS INTEGER
    tdIdx% = TEXT_LAYER_alloc%
    IF tdIdx% = 0 THEN
        ' Pool is full — delete the just-created layer
        LAYERS_delete newIdx%
        EXIT FUNCTION
    END IF

    ' Configure as text layer
    LAYERS(newIdx%).layerType%   = LAYER_TYPE_TEXT
    LAYERS(newIdx%).textDataIdx% = tdIdx%
    LAYERS(newIdx%).name         = "Text"

    ' Set text layer defaults
    TEXT_LAYER_DATA(tdIdx%).startX   = x%
    TEXT_LAYER_DATA(tdIdx%).startY   = y%
    TEXT_LAYER_DATA(tdIdx%).fontSize = TEXT_BAR.selectedSize%
    ' Use actual font cell height for leading (TEXT_start_editing overwrites this)
    DIM layInitMW AS INTEGER, layInitMH AS INTEGER, layInitFH AS LONG
    IF TEXT_BAR.selectedFontIdx% >= 0 AND TEXT_BAR.selectedFontIdx% < FONT_LIST_COUNT% THEN
        IF FONT_LIST(TEXT_BAR.selectedFontIdx%).isBuiltIn THEN
            TEXT_LAYER_DATA(tdIdx%).defaultLeading = FONT_LIST(TEXT_BAR.selectedFontIdx%).builtInHandle
        ELSEIF FONT_LIST(TEXT_BAR.selectedFontIdx%).isBitmapFont THEN
            layInitMH% = FONT_LIST(TEXT_BAR.selectedFontIdx%).bitmapGlyphH
            IF layInitMH% < 1 THEN layInitMH% = 16
            TEXT_LAYER_DATA(tdIdx%).defaultLeading = layInitMH%
        ELSEIF TEXT_LAYER_measure_char%(TEXT_BAR.selectedFontIdx%, TEXT_BAR.selectedSize%, FONT_STYLE_REGULAR$, TEXT_BAR.monoActive%, TEXT_BAR.aaActive%, "M", layInitMW%, layInitMH%, layInitFH&) THEN
            TEXT_LAYER_DATA(tdIdx%).defaultLeading = layInitMH%
        ELSE
            TEXT_LAYER_DATA(tdIdx%).defaultLeading = TEXT_BAR.selectedSize% + 1
        END IF
    ELSE
        TEXT_LAYER_DATA(tdIdx%).defaultLeading = TEXT_BAR.selectedSize% + 1
    END IF
    TEXT_LAYER_DATA(tdIdx%).monospace = TEXT_BAR.monoActive%
    TEXT_LAYER_DATA(tdIdx%).dirty     = TRUE

    ' Ensure font list is scanned
    FONT_LIST_scan

    ' Default to first bundled font if available
    IF FONT_LIST_COUNT% > 0 THEN
        TEXT_LAYER_DATA(tdIdx%).fontIdx = 0
    END IF

    LAYERS_new_text% = newIdx%

    ' Recompute export mode now that layerType is TEXT
    FILE_QB64_recompute_export_mode newIdx%
END FUNCTION


''
' Delete a layer
' @param layerIndex INTEGER Index of the layer to delete (1-64)
'
SUB LAYERS_delete (layerIndex AS INTEGER)
    DIM i                AS INTEGER
    DIM deletedZ         AS INTEGER
    DIM deletedHistoryId AS LONG

    ' CRITICAL: Copy parameter to local immediately — QB64 passes by reference.
    ' Callers pass CURRENT_LAYER% which LAYERS_select changes mid-function.
    DIM delSlot AS INTEGER
    delSlot% = layerIndex%
    
    ' Can't delete if only one layer
    IF LAYER_COUNT% < = 1 THEN EXIT SUB
    
    ' Validate index
    IF delSlot% < 1 OR delSlot% > MAX_LAYERS THEN EXIT SUB
    IF LAYERS(delSlot%).imgHandle& = 0 THEN EXIT SUB
    
    ' Cancel any pending/active drag that refers to this layer
    IF LAYER_PANEL.dragLayerIdx% = delSlot% THEN
        LAYER_PANEL_drag_cancel
    END IF
    
    ' Store zIndex before deleting
    deletedZ%         = LAYERS(delSlot%).zIndex%
    deletedHistoryId& = LAYERS(delSlot%).historyId&
    
    IF NOT HISTORY_IN_PROGRESS% THEN
        HISTORY_record_layer_delete deletedHistoryId&, delSlot%, deletedZ%, "Layer Delete"
    END IF

    ' Free text layer data if this is a text layer
    IF LAYERS(delSlot%).layerType% = LAYER_TYPE_TEXT THEN
        IF LAYERS(delSlot%).textDataIdx% > 0 THEN
            TEXT_LAYER_free LAYERS(delSlot%).textDataIdx%
        END IF
    END IF

    ' If this layer was being actively edited, cancel text editing
    IF TEXT.editingTextLayer% = delSlot% THEN
        TEXT.ACTIVE               = FALSE
        TEXT.editingTextLayer%    = 0
        TEXT_BAR.editingLayerIdx% = 0
        FRAME_IDLE%               = FALSE
        GUI_NEEDS_REDRAW%         = TRUE
    END IF

    ' If this is a group, orphan direct children to grandparent (or top-level)
    IF LAYERS(delSlot%).layerType% = LAYER_TYPE_GROUP THEN
        DIM delGrandparent AS INTEGER
        delGrandparent% = LAYERS(delSlot%).parentGroupIdx%
        FOR i% = 1 TO MAX_LAYERS
            IF LAYERS(i%).imgHandle& <> 0 AND LAYERS(i%).parentGroupIdx% = delSlot% THEN
                LAYERS(i%).parentGroupIdx% = delGrandparent%
            END IF
        NEXT i%
    END IF

    ' Free the image
    IF LAYERS(delSlot%).imgHandle& < -1 THEN
        _FREEIMAGE LAYERS(delSlot%).imgHandle&
    END IF
    ' Free opacity cache image
    IF LAYERS(delSlot%).opacityCacheImg& < -1 THEN
        _FREEIMAGE LAYERS(delSlot%).opacityCacheImg&
    END IF
    ' Free apron extraction cache
    IF LAYERS(delSlot%).apronCacheImg& < -1 THEN
        _FREEIMAGE LAYERS(delSlot%).apronCacheImg&
    END IF
    
    ' Clear the slot
    LAYERS(delSlot%).historyId&       = 0
    LAYERS(delSlot%).imgHandle&       = 0
    LAYERS(delSlot%).imgWidth%        = 0
    LAYERS(delSlot%).imgHeight%       = 0
    LAYERS(delSlot%).zIndex%          = 0
    LAYERS(delSlot%).visible%         = FALSE
    LAYERS(delSlot%).isSelected%      = FALSE
    LAYERS(delSlot%).name             = ""
    LAYERS(delSlot%).opacity%         = 255
    LAYERS(delSlot%).opacityLock%     = FALSE
    LAYERS(delSlot%).opacityCacheImg& = 0
    LAYERS(delSlot%).opacityCacheVal% = 0
    LAYERS(delSlot%).contentDirty%    = FALSE
    LAYERS(delSlot%).layerType%       = LAYER_TYPE_IMAGE
    LAYERS(delSlot%).textDataIdx%     = 0
    LAYERS(delSlot%).parentGroupIdx%  = 0
    LAYERS(delSlot%).collapsed%       = FALSE
    LAYERS(delSlot%).passThrough%     = FALSE
    LAYERS(delSlot%).apronW%          = 0
    LAYERS(delSlot%).apronH%          = 0
    LAYERS(delSlot%).apronCacheImg&   = 0
    LAYERS(delSlot%).apronCacheValid% = FALSE
    
    LAYER_COUNT% = LAYER_COUNT% - 1
    ' Adjust zIndex of layers above the deleted one
    FOR i% = 1 TO MAX_LAYERS
        IF LAYERS(i%).imgHandle& <> 0 AND LAYERS(i%).zIndex% > deletedZ% THEN
            LAYERS(i%).zIndex% = LAYERS(i%).zIndex% - 1
        END IF
    NEXT i%
    
    ' Select another layer if the deleted one was selected
    IF CURRENT_LAYER% = delSlot% THEN
        ' Find the layer that is now at the position below where deleted layer was
        ' (which now has zIndex = deletedZ% - 1 after the adjustment above)
        DIM targetZ    AS INTEGER
        DIM foundLayer AS INTEGER
        foundLayer% = 0
        
        ' First try to select the layer that was below (zIndex = deletedZ% - 1)
        targetZ% = deletedZ% - 1
        IF targetZ% >= 1 THEN
            FOR i% = 1 TO MAX_LAYERS
                IF LAYERS(i%).imgHandle& <> 0 AND LAYERS(i%).zIndex% = targetZ% THEN
                    foundLayer% = i%
                    EXIT FOR
                END IF
            NEXT i%
        END IF
        
        ' If no layer below, try the layer that was above (now at deletedZ% after adjustment)
        IF foundLayer% = 0 THEN
            FOR i% = 1 TO MAX_LAYERS
                IF LAYERS(i%).imgHandle& <> 0 AND LAYERS(i%).zIndex% = deletedZ% THEN
                    foundLayer% = i%
                    EXIT FOR
                END IF
            NEXT i%
        END IF
        
        ' Fallback: select any valid layer
        IF foundLayer% = 0 THEN
            FOR i% = 1 TO MAX_LAYERS
                IF LAYERS(i%).imgHandle& <> 0 THEN
                    foundLayer% = i%
                    EXIT FOR
                END IF
            NEXT i%
        END IF
        
        IF foundLayer% > 0 THEN LAYERS_select foundLayer%
    END IF
    
    BLEND_invalidate_cache
    INVALIDATE_scene
END SUB


''
' Duplicate a layer
' @param layerIndex INTEGER Index of the layer to duplicate (1-64)
'
SUB LAYERS_duplicate (layerIndex AS INTEGER)
    DIM newIndex AS INTEGER
    DIM srcImg   AS LONG
    
    ' Validate
    IF layerIndex% < 1 OR layerIndex% > MAX_LAYERS THEN EXIT SUB
    IF LAYERS(layerIndex%).imgHandle& = 0 THEN EXIT SUB
    
    ' ---------------------------------------------------------------
    ' SYMBOL DUPLICATION: parent → create child, child → create sibling
    ' ---------------------------------------------------------------
    IF LAYERS(layerIndex%).layerType% = LAYER_TYPE_SYMBOL_PARENT THEN
        SYMBOL_create_child layerIndex%
        EXIT SUB
    END IF
    IF LAYERS(layerIndex%).layerType% = LAYER_TYPE_SYMBOL_CHILD THEN
        DIM symParentSlot AS INTEGER
        symParentSlot% = SYMBOL_find_parent_slot%(layerIndex%)
        IF symParentSlot% > 0 THEN
            SYMBOL_create_child symParentSlot%
        END IF
        EXIT SUB
    END IF

    ' ---------------------------------------------------------------
    ' GROUP DUPLICATION: duplicate group header + all descendants
    ' ---------------------------------------------------------------
    IF LAYERS(layerIndex%).layerType% = LAYER_TYPE_GROUP THEN
        ' Collect all descendants (sorted by zIndex ascending)
        DIM descBuf(1 TO MAX_LAYERS) AS INTEGER
        DIM descCount AS INTEGER
        descCount% = 0
        LAYERS_group_descendants layerIndex%, descBuf%(), descCount%

        ' Total layers to duplicate = descendants + the group header itself
        DIM totalToDup AS INTEGER
        totalToDup% = descCount% + 1
        IF LAYER_COUNT% + totalToDup% > CFG.NUM_LAYERS% THEN EXIT SUB

        ' Build ordered list: descendants (low z to high z), then group header last
        ' This mirrors the contiguous z layout: children below header
        DIM dupSrc(1 TO MAX_LAYERS) AS INTEGER    ' source slot indices
        DIM dupDst(1 TO MAX_LAYERS) AS INTEGER    ' destination slot indices
        DIM dupI AS INTEGER
        FOR dupI% = 1 TO descCount%
            dupSrc%(dupI%) = descBuf%(dupI%)
        NEXT dupI%
        dupSrc%(totalToDup%) = layerIndex%        ' group header last

        ' Find empty slots for all new layers
        DIM slotSearch AS INTEGER, slotsFound AS INTEGER
        slotsFound% = 0
        FOR slotSearch% = 1 TO MAX_LAYERS
            IF LAYERS(slotSearch%).imgHandle& = 0 THEN
                slotsFound% = slotsFound% + 1
                dupDst%(slotsFound%) = slotSearch%
                IF slotsFound% = totalToDup% THEN EXIT FOR
            END IF
        NEXT slotSearch%
        IF slotsFound% < totalToDup% THEN EXIT SUB  ' Not enough empty slots

        ' Build a mapping from old slot -> new slot for parent pointer remapping
        ' We'll use a simple lookup: for each dup pair, map src -> dst
        DIM parentMap(1 TO MAX_LAYERS) AS INTEGER ' parentMap(oldSlot) = newSlot
        FOR dupI% = 1 TO totalToDup%
            parentMap%(dupSrc%(dupI%)) = dupDst%(dupI%)
        NEXT dupI%

        ' Determine z insertion point: above the group header
        DIM groupTopZ AS INTEGER
        groupTopZ% = LAYERS(layerIndex%).zIndex%
        ' Shift all layers above the group to make room
        DIM shiftI    AS INTEGER
        FOR shiftI% = 1 TO MAX_LAYERS
            IF LAYERS(shiftI%).imgHandle& <> 0 AND LAYERS(shiftI%).zIndex% > groupTopZ% THEN
                LAYERS(shiftI%).zIndex% = LAYERS(shiftI%).zIndex% + totalToDup%
            END IF
        NEXT shiftI%

        ' Begin history group for the entire operation
        IF NOT HISTORY_IN_PROGRESS% THEN HISTORY_begin_group

        ' Duplicate each layer in order
        DIM newZ AS INTEGER
        FOR dupI% = 1 TO totalToDup%
            DIM dSrc AS INTEGER, dDst AS INTEGER
            dSrc% = dupSrc%(dupI%)
            dDst% = dupDst%(dupI%)

            ' Copy image
            LAYERS(dDst%).imgHandle& = _COPYIMAGE(LAYERS(dSrc%).imgHandle&, 32)
            IF LAYERS(dDst%).imgHandle& >= -1 THEN
                _LOGERROR "LAYERS_duplicate: _COPYIMAGE failed for group child src=" + STR$(dSrc%) + " dst=" + STR$(dDst%)
                LAYERS(dDst%).imgHandle& = 0
                ' Rollback: free any already-duplicated layers
                DIM rollI AS INTEGER
                FOR rollI% = 1 TO dupI% - 1
                    IF LAYERS(dupDst%(rollI%)).imgHandle& < -1 THEN
                        _FREEIMAGE LAYERS(dupDst%(rollI%)).imgHandle&
                    END IF
                    LAYERS(dupDst%(rollI%)).imgHandle& = 0
                    LAYER_COUNT% = LAYER_COUNT% - 1
                NEXT rollI%
                IF NOT HISTORY_IN_PROGRESS% THEN HISTORY_end_group
                EXIT SUB
            END IF

            ' Assign z-index: contiguous block above the original group
            newZ% = groupTopZ% + dupI%
            
            ' Copy properties
            LAYER_COUNT% = LAYER_COUNT% + 1
            LAYERS(dDst%).historyId&    = LAYERS_alloc_history_id&
            LAYERS(dDst%).imgWidth%     = _WIDTH(LAYERS(dDst%).imgHandle&)
            LAYERS(dDst%).imgHeight%    = _HEIGHT(LAYERS(dDst%).imgHandle&)
            LAYERS(dDst%).zIndex%       = newZ%
            LAYERS(dDst%).visible%      = LAYERS(dSrc%).visible%
            LAYERS(dDst%).isSelected%   = FALSE
            LAYERS(dDst%).lastSelected% = FALSE
            LAYERS(dDst%).opacity%      = LAYERS(dSrc%).opacity%
            LAYERS(dDst%).opacityLock%  = LAYERS(dSrc%).opacityLock%
            LAYERS(dDst%).blendMode%    = LAYERS(dSrc%).blendMode%
            LAYERS(dDst%).contentDirty% = TRUE
            LAYERS(dDst%).layerType%    = LAYERS(dSrc%).layerType%
            LAYERS(dDst%).collapsed%    = LAYERS(dSrc%).collapsed%
            LAYERS(dDst%).passThrough%  = LAYERS(dSrc%).passThrough%
            LAYERS(dDst%).textDataIdx%  = 0
            LAYERS(dDst%).apronW%       = LAYERS(dSrc%).apronW%
            LAYERS(dDst%).apronH%       = LAYERS(dSrc%).apronH%

            ' Remap parent pointer: if original parent is in the duplication set, point to new copy
            IF LAYERS(dSrc%).parentGroupIdx% > 0 AND LAYERS(dSrc%).parentGroupIdx% < = MAX_LAYERS THEN
                IF parentMap%(LAYERS(dSrc%).parentGroupIdx%) > 0 THEN
                    LAYERS(dDst%).parentGroupIdx% = parentMap%(LAYERS(dSrc%).parentGroupIdx%)
                ELSE
                    ' Parent is outside the duplication set (shouldn't happen for well-formed groups)
                    LAYERS(dDst%).parentGroupIdx% = LAYERS(dSrc%).parentGroupIdx%
                END IF
            ELSE
                ' Top-level group header: inherit source's parent (could be nested in another group)
                LAYERS(dDst%).parentGroupIdx% = LAYERS(dSrc%).parentGroupIdx%
            END IF

            ' Name: append " copy" only to the group header, keep child names as-is
            IF dupI% = totalToDup% THEN
                LAYERS(dDst%).name = _TRIM$(LAYERS(dSrc%).name) + " copy"
                NEXT_GROUP_NUM% = NEXT_GROUP_NUM% + 1
            ELSE
                LAYERS(dDst%).name = LAYERS(dSrc%).name
            END IF

            ' Duplicate text layer data if applicable
            IF LAYERS(dSrc%).layerType% = LAYER_TYPE_TEXT THEN
                IF LAYERS(dSrc%).textDataIdx% > 0 THEN
                    DIM dgNewTextIdx AS INTEGER
                    dgNewTextIdx% = TEXT_LAYER_alloc%
                    IF dgNewTextIdx% > 0 THEN
                        TEXT_LAYER_copy_data LAYERS(dSrc%).textDataIdx%, dgNewTextIdx%
                        LAYERS(dDst%).textDataIdx% = dgNewTextIdx%
                    ELSE
                        LAYERS(dDst%).layerType% = LAYER_TYPE_IMAGE
                    END IF
                END IF
            END IF

            IF NOT HISTORY_IN_PROGRESS% THEN
                HISTORY_record_layer_add LAYERS(dDst%).historyId&, dDst%, newZ%, "Dup Group Child:" + _TRIM$(STR$(LAYERS(dSrc%).historyId&))
            END IF
        NEXT dupI%

        IF NOT HISTORY_IN_PROGRESS% THEN HISTORY_end_group

        ' Fix z-ordering to ensure proper contiguity
        LAYERS_enforce_group_contiguity

        ' Select the new group header (last in dupDst)
        LAYERS_select dupDst%(totalToDup%)

        BLEND_invalidate_cache
        INVALIDATE_scene
        EXIT SUB
    END IF

    ' ---------------------------------------------------------------
    ' SINGLE LAYER DUPLICATION (non-group, original logic)
    ' ---------------------------------------------------------------

    ' Check if we've hit the max layers
    IF LAYER_COUNT% >= CFG.NUM_LAYERS% THEN EXIT SUB
    
    ' Find first empty slot
    newIndex% = 0
    DIM i AS INTEGER
    FOR i% = 1 TO MAX_LAYERS
        IF LAYERS(i%).imgHandle& = 0 THEN
            newIndex% = i%
            EXIT FOR
        END IF
    NEXT i%
    IF newIndex% = 0 THEN EXIT SUB
    
    ' DIRECTLY copy the source layer image (creates a new image with same content)
    srcImg&                      = LAYERS(layerIndex%).imgHandle&
    LAYERS(newIndex%).imgHandle& = _COPYIMAGE(srcImg&, 32)
    IF LAYERS(newIndex%).imgHandle& >= -1 THEN
        _LOGERROR "LAYERS_duplicate: _COPYIMAGE failed from layer " + STR$(layerIndex%) + " to slot " + STR$(newIndex%) + " (src=" + STR$(srcImg&) + ", dst=" + STR$(LAYERS(newIndex%).imgHandle&) + ")"
        LAYERS(newIndex%).imgHandle& = 0
        EXIT SUB
    END IF
    
    ' Insert duplicate just above the source layer in z-order
    DIM dupSrcZ  AS INTEGER
    DIM dupShift AS INTEGER
    dupSrcZ% = LAYERS(layerIndex%).zIndex%
    FOR dupShift% = 1 TO MAX_LAYERS
        IF LAYERS(dupShift%).imgHandle& <> 0 AND LAYERS(dupShift%).zIndex% > dupSrcZ% THEN
            LAYERS(dupShift%).zIndex% = LAYERS(dupShift%).zIndex% + 1
        END IF
    NEXT dupShift%

    ' Set layer properties
    LAYER_COUNT% = LAYER_COUNT% + 1
    LAYERS(newIndex%).historyId&      = LAYERS_alloc_history_id&
    LAYERS(newIndex%).imgWidth%       = _WIDTH(LAYERS(newIndex%).imgHandle&)
    LAYERS(newIndex%).imgHeight%      = _HEIGHT(LAYERS(newIndex%).imgHandle&)
    LAYERS(newIndex%).zIndex%         = dupSrcZ% + 1
    LAYERS(newIndex%).visible%        = LAYERS(layerIndex%).visible%
    LAYERS(newIndex%).isSelected%     = FALSE
    LAYERS(newIndex%).lastSelected%   = FALSE
    LAYERS(newIndex%).name            = _TRIM$(LAYERS(layerIndex%).name) + " copy"
    LAYERS(newIndex%).opacity%        = LAYERS(layerIndex%).opacity%
    LAYERS(newIndex%).opacityLock%    = LAYERS(layerIndex%).opacityLock%
    LAYERS(newIndex%).blendMode%      = LAYERS(layerIndex%).blendMode%
    LAYERS(newIndex%).contentDirty%   = TRUE ' New pixel data needs opacity cache build
    LAYERS(newIndex%).layerType%      = LAYERS(layerIndex%).layerType%
    LAYERS(newIndex%).parentGroupIdx% = LAYERS(layerIndex%).parentGroupIdx%
    LAYERS(newIndex%).apronW%         = LAYERS(layerIndex%).apronW%
    LAYERS(newIndex%).apronH%         = LAYERS(layerIndex%).apronH%

    ' Duplicate text layer data if source is a text layer
    IF LAYERS(layerIndex%).layerType% = LAYER_TYPE_TEXT THEN
        IF LAYERS(layerIndex%).textDataIdx% > 0 THEN
            DIM newTextIdx AS INTEGER
            newTextIdx% = TEXT_LAYER_alloc%
            IF newTextIdx% > 0 THEN
                TEXT_LAYER_copy_data LAYERS(layerIndex%).textDataIdx%, newTextIdx%
                LAYERS(newIndex%).textDataIdx% = newTextIdx%
            ELSE
                ' Pool full — rasterize to image layer
                LAYERS(newIndex%).layerType%   = LAYER_TYPE_IMAGE
                LAYERS(newIndex%).textDataIdx% = 0
            END IF
        END IF
    ELSE
        LAYERS(newIndex%).textDataIdx% = 0
    END IF

    IF NOT HISTORY_IN_PROGRESS% THEN
        HISTORY_record_layer_add LAYERS(newIndex%).historyId&, newIndex%, LAYERS(newIndex%).zIndex%, "Layer Duplicate:" + _TRIM$(STR$(LAYERS(layerIndex%).historyId&))
    END IF
    
    ' Select the new layer
    LAYERS_select newIndex%
    
    BLEND_invalidate_cache
    INVALIDATE_scene
END SUB


''
' Clear a layer (fill with transparency)
' @param layerIndex INTEGER Index of the layer to clear (1-64)
'
SUB LAYERS_clear (layerIndex AS INTEGER)
    DIM oldDest       AS LONG
    DIM clearBefore   AS LONG
    DIM clearRecorded AS INTEGER
    
    ' Validate
    IF layerIndex% < 1 OR layerIndex% > MAX_LAYERS THEN EXIT SUB
    IF LAYERS(layerIndex%).imgHandle& = 0 THEN EXIT SUB

    clearBefore&   = 0
    clearRecorded% = FALSE
    IF NOT HISTORY_IN_PROGRESS% AND LAYERS(layerIndex%).historyId& > 0 AND LAYERS(layerIndex%).imgHandle& < -1 THEN
        clearBefore& = _COPYIMAGE(LAYERS(layerIndex%).imgHandle&, 32)
    END IF
    
    oldDest& = _DEST
    _DEST LAYERS(layerIndex%).imgHandle&
    CLS , _RGBA32(0, 0, 0, 0)
    _DEST oldDest&

    IF clearBefore& < -1 THEN
        HISTORY_record_brush LAYERS(layerIndex%).historyId&, layerIndex%, _RGBA32(0, 0, 0, 0), 0, clearBefore&, "Clear Layer"
        clearRecorded% = TRUE
    END IF
    IF clearRecorded% THEN HISTORY_saved_this_frame% = TRUE
    
    LAYERS(layerIndex%).contentDirty% = TRUE
    INVALIDATE_scene
END SUB


''
' Rename a layer using input dialog
' @param layerIndex INTEGER Index of the layer to rename (1-64)
'
SUB LAYERS_rename (layerIndex AS INTEGER)
    DIM newName AS STRING
    
    ' Validate
    IF layerIndex% < 1 OR layerIndex% > MAX_LAYERS THEN EXIT SUB
    IF LAYERS(layerIndex%).imgHandle& = 0 THEN EXIT SUB
    
    POINTER_hide_for_dialog
    newName$ = DRAW_input_box_ex$("Rename Layer", "Enter new name:", _TRIM$(LAYERS(layerIndex%).name), "Layer name", TRUE)
    POINTER_show_after_dialog
    MOUSE_cleanup_after_dialog FALSE ' Clear buffers but don't move mouse

    IF LEN(newName$) > 0 THEN
        IF _TRIM$(newName$) <> _TRIM$(LAYERS(layerIndex%).name) THEN
            IF NOT HISTORY_IN_PROGRESS% THEN
                HISTORY_record_layer_rename LAYERS(layerIndex%).historyId&, _TRIM$(LAYERS(layerIndex%).name), newName$, "Layer Rename"
            END IF

            ' STRING * 64 field truncates anything longer to 64 chars on assignment.
            LAYERS(layerIndex%).name = newName$
            GUI_NEEDS_REDRAW%        = TRUE
            FRAME_IDLE%              = FALSE
        END IF
    END IF
END SUB


''
' Select a layer as the current working layer
' @param layerIndex INTEGER Index of the layer to select (1-64)
'
SUB LAYERS_select (layerIndex AS INTEGER)
    DIM i AS INTEGER
    
    ' Validate
    IF layerIndex% < 1 OR layerIndex% > MAX_LAYERS THEN EXIT SUB
    IF LAYERS(layerIndex%).imgHandle& = 0 THEN EXIT SUB
    
    ' If MOVE tool is active on a different layer, commit and reset before switching
    IF CURRENT_TOOL% = TOOL_MOVE AND MOVE.ACTIVE AND layerIndex% <> CURRENT_LAYER% THEN
        MOVE_reset ' This applies the transform and cleans up
    END IF
    
    ' Deselect all layers
    FOR i% = 1 TO MAX_LAYERS
        LAYERS(i%).lastSelected% = LAYERS(i%).isSelected%
        LAYERS(i%).isSelected%   = FALSE
    NEXT i%
    
    ' Select the target layer
    LAYERS(layerIndex%).isSelected% = TRUE
    CURRENT_LAYER%                  = layerIndex%
    
    ' Reset multi-select to just this layer (plain select always clears multi-select)
    MULTI_SELECT_clear
    
    GUI_NEEDS_REDRAW% = TRUE
END SUB


''
' Clear multi-layer selection, pinning only CURRENT_LAYER%.
' Invariant: MULTI_SELECT_COUNT% >= 1 after this call.
'
SUB MULTI_SELECT_clear ()
    DIM i AS INTEGER
    FOR i% = 1 TO MAX_LAYERS
        MULTI_SELECT_LAYERS(i%) = FALSE
    NEXT i%
    IF CURRENT_LAYER% >= 1 AND CURRENT_LAYER% < = MAX_LAYERS THEN
        MULTI_SELECT_LAYERS(CURRENT_LAYER%) = TRUE
    END IF
    MULTI_SELECT_COUNT% = 1
END SUB


''
' Returns TRUE if more than one layer is selected (multi-select active).
' @return INTEGER - TRUE if MULTI_SELECT_COUNT% > 1
'
FUNCTION MULTI_SELECT_has_any% ()
    MULTI_SELECT_has_any% = (MULTI_SELECT_COUNT% > 1)
END FUNCTION


''
' Toggle a layer in/out of the multi-select set.
' Invariant: MULTI_SELECT_COUNT% stays >= 1 (cannot deselect last).
' @param layerIndex INTEGER Index of the layer to toggle (1-64)
'
SUB MULTI_SELECT_toggle (layerIndex AS INTEGER)
    IF layerIndex% < 1 OR layerIndex% > MAX_LAYERS THEN EXIT SUB
    IF LAYERS(layerIndex%).imgHandle& = 0 THEN EXIT SUB
    ' Guard: never deselect if it is the only selected layer
    IF MULTI_SELECT_LAYERS(layerIndex%) AND MULTI_SELECT_COUNT% < = 1 THEN EXIT SUB
    IF MULTI_SELECT_LAYERS(layerIndex%) THEN
        MULTI_SELECT_LAYERS(layerIndex%) = FALSE
        MULTI_SELECT_COUNT% = MULTI_SELECT_COUNT% - 1
    ELSE
        MULTI_SELECT_LAYERS(layerIndex%) = TRUE
        MULTI_SELECT_COUNT% = MULTI_SELECT_COUNT% + 1
    END IF
    GUI_NEEDS_REDRAW% = TRUE
END SUB


''
' Get tight bounding box of non-transparent pixels on a layer.
' Returns bx, by, bw, bh via output parameters (0,0,0,0 if layer is empty/invalid).
' @param layerIndex INTEGER Index of the layer to scan (1-64)
' @param bx INTEGER (output) Left X coordinate of the bounding box
' @param by INTEGER (output) Top Y coordinate of the bounding box
' @param bw INTEGER (output) Width of the bounding box in pixels
' @param bh INTEGER (output) Height of the bounding box in pixels
'
SUB LAYER_get_content_bounds (layerIndex AS INTEGER, bx AS INTEGER, by AS INTEGER, bw AS INTEGER, bh AS INTEGER)
    bx% = 0: by% = 0: bw% = 0: bh% = 0
    IF layerIndex% < 1 OR layerIndex% > MAX_LAYERS THEN EXIT SUB
    DIM img AS LONG
    img& = LAYERS(layerIndex%).imgHandle&
    IF img& >= -1 THEN EXIT SUB
    
    DIM imgW AS INTEGER, imgH AS INTEGER
    imgW% = _WIDTH(img&)
    imgH% = _HEIGHT(img&)
    IF imgW% < = 0 OR imgH% < = 0 THEN EXIT SUB
    
    DIM m      AS _MEM
    m = _MEMIMAGE(img&)
    DIM x      AS INTEGER, y AS INTEGER
    DIM minX   AS INTEGER, minY AS INTEGER, maxX AS INTEGER, maxY AS INTEGER
    DIM found  AS INTEGER
    DIM a      AS _UNSIGNED _BYTE
    DIM offset AS _OFFSET
    
    minX% = imgW%: minY% = imgH%: maxX% = -1: maxY% = -1: found% = FALSE
    
    FOR y% = 0 TO imgH% - 1
        FOR x% = 0 TO imgW% - 1
            offset = (y% * imgW% + x%) * 4 + 3 ' Alpha byte offset (BGRA order)
            _MEMGET m, m.OFFSET + offset, a
            IF a > 0 THEN
                IF NOT found% THEN found% = TRUE
                IF x% < minX% THEN minX% = x%
                IF x% > maxX% THEN maxX% = x%
                IF y% < minY% THEN minY% = y%
                IF y% > maxY% THEN maxY% = y%
            END IF
        NEXT x%
    NEXT y%
    
    _MEMFREE m
    
    IF found% THEN
        bx% = minX%
        by% = minY%
        bw% = maxX% - minX% + 1
        bh% = maxY% - minY% + 1
    END IF
END SUB


''
' Translate (shift) pixel content of a layer by (dx, dy) pixels.
' Pixels that shift outside the canvas bounds are clipped (lost).
' @param layerIndex INTEGER Index of the layer to translate (1-64)
' @param dx INTEGER Horizontal offset in pixels (positive = right)
' @param dy INTEGER Vertical offset in pixels (positive = down)
'
SUB LAYER_translate_content (layerIndex AS INTEGER, dx AS INTEGER, dy AS INTEGER)
    IF layerIndex% < 1 OR layerIndex% > MAX_LAYERS THEN EXIT SUB
    IF dx% = 0 AND dy% = 0 THEN EXIT SUB
    DIM img     AS LONG
    img& = LAYERS(layerIndex%).imgHandle&
    IF img& >= -1 THEN EXIT SUB
    DIM imgW    AS INTEGER, imgH AS INTEGER
    imgW% = _WIDTH(img&)
    imgH% = _HEIGHT(img&)
    ' Create a temp buffer, copy src with offset, then blit back raw (no alpha blend)
    DIM tmp     AS LONG
    tmp& = _NEWIMAGE(imgW%, imgH%, 32)
    DIM oldDest AS LONG, oldSrc AS LONG
    oldDest& = _DEST
    oldSrc&  = _SOURCE
    ' Clear temp to transparent, then copy original at offset
    _DEST tmp&
    _DONTBLEND tmp&
    CLS , _RGBA32(0, 0, 0, 0)
    _PUTIMAGE (dx%, dy%), img&, tmp&
    ' Clear original layer and blit back the shifted copy
    _DEST img&
    _DONTBLEND img&
    CLS , _RGBA32(0, 0, 0, 0)
    _PUTIMAGE (0, 0), tmp&, img&
    _BLEND img&
    _DEST oldDest&
    _SOURCE oldSrc&
    IF tmp& < -1 THEN _FREEIMAGE tmp&

    ' Update text layer metadata position if this is a text layer
    IF LAYERS(layerIndex%).layerType% = LAYER_TYPE_TEXT THEN
        DIM tlcTd AS INTEGER
        tlcTd% = LAYERS(layerIndex%).textDataIdx%
        IF tlcTd% >= 1 THEN
            TEXT_LAYER_DATA(tlcTd%).startX = TEXT_LAYER_DATA(tlcTd%).startX + dx%
            TEXT_LAYER_DATA(tlcTd%).startY = TEXT_LAYER_DATA(tlcTd%).startY + dy%
        END IF
    END IF
END SUB


''
' Move a layer up in the stack (increase zIndex)
' @param layerIndex INTEGER Index of the layer to move up (1-64)
'
SUB LAYERS_move_up (layerIndex AS INTEGER)
    DIM i           AS INTEGER
    DIM currentZ    AS INTEGER
    DIM targetIndex AS INTEGER

    ' CRITICAL: Copy parameter to local — QB64 passes by reference.
    DIM mvSlot AS INTEGER
    mvSlot% = layerIndex%
    
    ' Validate
    IF mvSlot% < 1 OR mvSlot% > MAX_LAYERS THEN EXIT SUB
    IF LAYERS(mvSlot%).imgHandle& = 0 THEN EXIT SUB
    
    currentZ% = LAYERS(mvSlot%).zIndex%
    IF currentZ% >= LAYER_COUNT% THEN EXIT SUB  ' Already at top

    ' For group headers: move entire block (header + children) up by swapping
    ' with the block above. If the block above is another group, skip over it entirely.
    IF LAYERS(mvSlot%).layerType% = LAYER_TYPE_GROUP THEN

        ' If this group is nested inside another group, check for boundary escape
        IF LAYERS(mvSlot%).parentGroupIdx% > 0 THEN
            DIM muEscParent AS INTEGER
            muEscParent% = LAYERS(mvSlot%).parentGroupIdx%
            IF muEscParent% >= 1 THEN
                IF muEscParent% < = MAX_LAYERS THEN
                    IF LAYERS(muEscParent%).imgHandle& <> 0 THEN
                        DIM muEscParentZ AS INTEGER
                        muEscParentZ% = LAYERS(muEscParent%).zIndex%
                        IF currentZ% + 1 >= muEscParentZ% THEN
                            ' At top of parent group — escape sub-group block to grandparent
                            DIM muEscGP AS INTEGER
                            muEscGP% = LAYERS(muEscParent%).parentGroupIdx%
                            ' Reparent this sub-group to grandparent
                            LAYERS(mvSlot%).parentGroupIdx% = muEscGP%
                            ' Give the sub-group header a z above the parent header
                            ' so enforce_contiguity places it correctly
                            LAYERS(mvSlot%).zIndex% = muEscParentZ% + 1
                            LAYERS_enforce_group_contiguity
                            IF NOT HISTORY_IN_PROGRESS% THEN
                                HISTORY_record_group_reparent LAYERS(mvSlot%).historyId&, mvSlot%, muEscParent%, muEscGP%, currentZ%, LAYERS(mvSlot%).zIndex%, "Move Group Out"
                            END IF
                            ' Auto-remove empty parent group
                            IF LAYERS_group_child_count%(muEscParent%) = 0 THEN
                                LAYERS_delete muEscParent%
                                IF CURRENT_LAYER% = muEscParent% THEN LAYERS_select mvSlot%
                            END IF
                            BLEND_invalidate_cache
                            GUI_NEEDS_REDRAW% = TRUE
                            EXIT SUB
                        END IF
                    END IF
                END IF
            END IF
        END IF

        DIM grpAboveZ AS INTEGER
        grpAboveZ% = currentZ% + 1
        IF grpAboveZ% > LAYER_COUNT% THEN EXIT SUB
        ' Find layer at z above the header
        targetIndex% = 0
        FOR i% = 1 TO MAX_LAYERS
            IF LAYERS(i%).imgHandle& <> 0 AND LAYERS(i%).zIndex% = grpAboveZ% THEN
                targetIndex% = i%
                EXIT FOR
            END IF
        NEXT i%
        IF targetIndex% > 0 THEN
            ' Determine the top z we need to jump over
            DIM muJumpTopZ AS INTEGER
            muJumpTopZ% = grpAboveZ%
            IF LAYERS(targetIndex%).parentGroupIdx% > 0 THEN
                ' Target is a child of another group — find that group's header z
                DIM muAboveGrp AS INTEGER
                muAboveGrp% = LAYERS(targetIndex%).parentGroupIdx%
                IF muAboveGrp% > 0 THEN
                    IF muAboveGrp% < = MAX_LAYERS THEN
                        IF LAYERS(muAboveGrp%).imgHandle& <> 0 THEN
                            muJumpTopZ% = LAYERS(muAboveGrp%).zIndex%
                        END IF
                    END IF
                END IF
            ELSEIF LAYERS(targetIndex%).layerType% = LAYER_TYPE_GROUP THEN
                ' Target IS a group header — its header z is already grpAboveZ
                ' But that group may have children above. Actually, group header is
                ' always above its children in z-order, so grpAboveZ is the top.
                muJumpTopZ% = grpAboveZ%
            END IF

            ' Count how many z-slots we're jumping
            DIM muBlockSize AS INTEGER
            DIM muGrpLow    AS INTEGER
            muGrpLow% = currentZ%                    ' default = header if no children
            FOR i% = 1 TO MAX_LAYERS
                IF LAYERS(i%).imgHandle& <> 0 THEN
                    IF LAYERS(i%).parentGroupIdx% = mvSlot% THEN
                        IF LAYERS(i%).zIndex% < muGrpLow% THEN muGrpLow% = LAYERS(i%).zIndex%
                    END IF
                END IF
            NEXT i%
            muBlockSize% = currentZ% - muGrpLow% + 1 ' our group block size

            DIM muJumpSize AS INTEGER
            muJumpSize% = muJumpTopZ% - currentZ%    ' how many slots to jump above

            ' Shift: everything between currentZ+1..muJumpTopZ goes down by muBlockSize
            ' Our group block (muGrpLow..currentZ) goes up by muJumpSize
            FOR i% = 1 TO MAX_LAYERS
                IF LAYERS(i%).imgHandle& <> 0 AND i% <> mvSlot% THEN
                    IF LAYERS(i%).zIndex% > currentZ% AND LAYERS(i%).zIndex% < = muJumpTopZ% THEN
                        LAYERS(i%).zIndex% = LAYERS(i%).zIndex% - muBlockSize%
                    ELSEIF LAYERS(i%).parentGroupIdx% = mvSlot% THEN
                        LAYERS(i%).zIndex% = LAYERS(i%).zIndex% + muJumpSize%
                    END IF
                END IF
            NEXT i%
            LAYERS(mvSlot%).zIndex% = currentZ% + muJumpSize%

            LAYERS_enforce_group_contiguity
            IF NOT HISTORY_IN_PROGRESS% THEN
                HISTORY_record_layer_reorder LAYERS(mvSlot%).historyId&, mvSlot%, currentZ%, LAYERS(mvSlot%).zIndex%, "Layer Reorder"
            END IF
        END IF
        BLEND_invalidate_cache
        GUI_NEEDS_REDRAW% = TRUE
        EXIT SUB
    END IF

    ' For child layers inside a group: swap with sibling, or escape group at boundary
    IF LAYERS(mvSlot%).parentGroupIdx% > 0 THEN
        DIM muParent  AS INTEGER
        muParent% = LAYERS(mvSlot%).parentGroupIdx%
        DIM muHeaderZ AS INTEGER
        muHeaderZ% = LAYERS(muParent%).zIndex%
        IF currentZ% + 1 >= muHeaderZ% THEN
            ' At top of group — escape to parent group (or top-level)
            DIM muGrandparent AS INTEGER
            muGrandparent%                  = LAYERS(muParent%).parentGroupIdx%
            LAYERS(mvSlot%).parentGroupIdx% = muGrandparent%
            ' Swap with header: header goes down, child goes to header's z
            LAYERS(muParent%).zIndex% = currentZ%
            LAYERS(mvSlot%).zIndex%   = muHeaderZ%
            LAYERS_enforce_group_contiguity
            IF NOT HISTORY_IN_PROGRESS% THEN
                HISTORY_record_group_reparent LAYERS(mvSlot%).historyId&, mvSlot%, muParent%, muGrandparent%, currentZ%, muHeaderZ%, "Move Out of Group"
            END IF
            ' Auto-remove empty group
            IF LAYERS_group_child_count%(muParent%) = 0 THEN
                LAYERS_delete muParent%
                ' If we were on the deleted group's layer, select the escaped layer
                IF CURRENT_LAYER% = muParent% THEN LAYERS_select mvSlot%
            END IF
        ELSE
            ' Swap with the layer above within group
            targetIndex% = 0
            FOR i% = 1 TO MAX_LAYERS
                IF LAYERS(i%).imgHandle& <> 0 AND LAYERS(i%).zIndex% = currentZ% + 1 THEN
                    targetIndex% = i%
                    EXIT FOR
                END IF
            NEXT i%
            IF targetIndex% > 0 THEN
                LAYERS(mvSlot%).zIndex%      = currentZ% + 1
                LAYERS(targetIndex%).zIndex% = currentZ%
                IF NOT HISTORY_IN_PROGRESS% THEN
                    HISTORY_record_layer_reorder LAYERS(mvSlot%).historyId&, mvSlot%, currentZ%, currentZ% + 1, "Layer Reorder"
                END IF
            END IF
        END IF
        BLEND_invalidate_cache
        GUI_NEEDS_REDRAW% = TRUE
        EXIT SUB
    END IF

    ' Non-grouped layer: skip over entire group blocks when moving up
    DIM newTargetZ AS INTEGER
    newTargetZ% = currentZ% + 1
    ' Check if the layer at newTargetZ is part of a group — skip the entire group
    targetIndex% = 0
    FOR i% = 1 TO MAX_LAYERS
        IF LAYERS(i%).imgHandle& <> 0 AND LAYERS(i%).zIndex% = newTargetZ% THEN
            targetIndex% = i%
            EXIT FOR
        END IF
    NEXT i%
    IF targetIndex% > 0 THEN
        IF LAYERS(targetIndex%).parentGroupIdx% > 0 THEN
            ' Target is a group child — skip to header position
            DIM skipGrpIdx AS INTEGER
            skipGrpIdx% = LAYERS(targetIndex%).parentGroupIdx%
            IF skipGrpIdx% > 0 THEN
                IF skipGrpIdx% < = MAX_LAYERS THEN
                    IF LAYERS(skipGrpIdx%).imgHandle& <> 0 THEN
                        newTargetZ% = LAYERS(skipGrpIdx%).zIndex%
                    END IF
                END IF
            END IF
        ELSEIF LAYERS(targetIndex%).layerType% = LAYER_TYPE_GROUP THEN
            ' Target is a group header with no children below — just swap
            newTargetZ% = LAYERS(targetIndex%).zIndex%
        END IF
    END IF
    IF newTargetZ% > LAYER_COUNT% THEN newTargetZ% = LAYER_COUNT%
    IF newTargetZ% = currentZ% THEN EXIT SUB

    ' Shift layers between old and new position down by 1
    FOR i% = 1 TO MAX_LAYERS
        IF LAYERS(i%).imgHandle& <> 0 AND i% <> mvSlot% THEN
            IF LAYERS(i%).zIndex% > currentZ% AND LAYERS(i%).zIndex% < = newTargetZ% THEN
                LAYERS(i%).zIndex% = LAYERS(i%).zIndex% - 1
            END IF
        END IF
    NEXT i%
    LAYERS(mvSlot%).zIndex% = newTargetZ%
    
    IF NOT HISTORY_IN_PROGRESS% THEN
        HISTORY_record_layer_reorder LAYERS(mvSlot%).historyId&, mvSlot%, currentZ%, newTargetZ%, "Layer Reorder"
    END IF
    
    BLEND_invalidate_cache
    GUI_NEEDS_REDRAW% = TRUE
END SUB


''
' Move a layer down in the stack (decrease zIndex)
' @param layerIndex INTEGER Index of the layer to move down (1-64)
'
SUB LAYERS_move_down (layerIndex AS INTEGER)
    DIM i           AS INTEGER
    DIM currentZ    AS INTEGER
    DIM targetIndex AS INTEGER

    ' CRITICAL: Copy parameter to local — QB64 passes by reference.
    DIM mdSlot AS INTEGER
    mdSlot% = layerIndex%
    
    ' Validate
    IF mdSlot% < 1 OR mdSlot% > MAX_LAYERS THEN EXIT SUB
    IF LAYERS(mdSlot%).imgHandle& = 0 THEN EXIT SUB
    
    currentZ% = LAYERS(mdSlot%).zIndex%
    IF currentZ% < = 1 THEN EXIT SUB  ' Already at bottom

    ' For group headers: move entire block (header + children) down.
    ' If the block below is another group, skip over it entirely.
    IF LAYERS(mdSlot%).layerType% = LAYER_TYPE_GROUP THEN
        ' Find the lowest child z of this group
        DIM grpLowestZ AS INTEGER
        grpLowestZ% = currentZ% ' Default: header z if no children
        FOR i% = 1 TO MAX_LAYERS
            IF LAYERS(i%).imgHandle& <> 0 THEN
                IF LAYERS(i%).parentGroupIdx% = mdSlot% THEN
                    IF LAYERS(i%).zIndex% < grpLowestZ% THEN
                        grpLowestZ% = LAYERS(i%).zIndex%
                    END IF
                END IF
            END IF
        NEXT i%
        DIM grpBelowZ  AS INTEGER
        grpBelowZ% = grpLowestZ% - 1

        ' If this group is nested inside another group, check for boundary escape
        IF LAYERS(mdSlot%).parentGroupIdx% > 0 THEN
            DIM mdEscParent AS INTEGER
            mdEscParent% = LAYERS(mdSlot%).parentGroupIdx%
            IF mdEscParent% >= 1 THEN
                IF mdEscParent% < = MAX_LAYERS THEN
                    IF LAYERS(mdEscParent%).imgHandle& <> 0 THEN
                        ' Check if there are any siblings below us in parent
                        DIM mdHasSibBelow AS INTEGER
                        mdHasSibBelow% = FALSE
                        FOR i% = 1 TO MAX_LAYERS
                            IF LAYERS(i%).imgHandle& <> 0 AND i% <> mdSlot% THEN
                                IF LAYERS(i%).parentGroupIdx% = mdEscParent% THEN
                                    IF LAYERS(i%).zIndex% < grpLowestZ% THEN
                                        mdHasSibBelow% = TRUE
                                        EXIT FOR
                                    END IF
                                END IF
                            END IF
                        NEXT i%
                        IF NOT mdHasSibBelow% THEN
                            ' At bottom of parent group — escape to grandparent
                            DIM mdEscGP AS INTEGER
                            mdEscGP% = LAYERS(mdEscParent%).parentGroupIdx%
                            ' Reparent this sub-group to grandparent
                            LAYERS(mdSlot%).parentGroupIdx% = mdEscGP%
                            ' Give header a z below parents lowest extent so
                            ' enforce_contiguity places it just below parent
                            IF grpBelowZ% >= 1 THEN
                                LAYERS(mdSlot%).zIndex% = grpBelowZ%
                            END IF
                            LAYERS_enforce_group_contiguity
                            IF NOT HISTORY_IN_PROGRESS% THEN
                                HISTORY_record_group_reparent LAYERS(mdSlot%).historyId&, mdSlot%, mdEscParent%, mdEscGP%, currentZ%, LAYERS(mdSlot%).zIndex%, "Move Group Out"
                            END IF
                            ' Auto-remove empty parent group
                            IF LAYERS_group_child_count%(mdEscParent%) = 0 THEN
                                LAYERS_delete mdEscParent%
                                IF CURRENT_LAYER% = mdEscParent% THEN LAYERS_select mdSlot%
                            END IF
                            BLEND_invalidate_cache
                            GUI_NEEDS_REDRAW% = TRUE
                            EXIT SUB
                        END IF
                    END IF
                END IF
            END IF
        END IF

        IF grpBelowZ% < 1 THEN EXIT SUB
        ' Find layer at that z
        targetIndex% = 0
        FOR i% = 1 TO MAX_LAYERS
            IF LAYERS(i%).imgHandle& <> 0 AND LAYERS(i%).zIndex% = grpBelowZ% THEN
                targetIndex% = i%
                EXIT FOR
            END IF
        NEXT i%
        IF targetIndex% > 0 THEN
            ' Determine the bottom z we need to jump over
            DIM mdJumpBotZ AS INTEGER
            mdJumpBotZ% = grpBelowZ%
            IF LAYERS(targetIndex%).layerType% = LAYER_TYPE_GROUP THEN
                ' Target IS a group header — find its lowest child
                DIM mdLowestChild AS INTEGER
                mdLowestChild% = LAYERS(targetIndex%).zIndex%
                FOR i% = 1 TO MAX_LAYERS
                    IF LAYERS(i%).imgHandle& <> 0 THEN
                        IF LAYERS(i%).parentGroupIdx% = targetIndex% THEN
                            IF LAYERS(i%).zIndex% < mdLowestChild% THEN
                                mdLowestChild% = LAYERS(i%).zIndex%
                            END IF
                        END IF
                    END IF
                NEXT i%
                mdJumpBotZ% = mdLowestChild%
            ELSEIF LAYERS(targetIndex%).parentGroupIdx% > 0 THEN
                ' Target is a child of another group — find that group's lowest child
                DIM mdBelowGrp    AS INTEGER
                mdBelowGrp% = LAYERS(targetIndex%).parentGroupIdx%
                IF mdBelowGrp% > 0 THEN
                    IF mdBelowGrp% < = MAX_LAYERS THEN
                        IF LAYERS(mdBelowGrp%).imgHandle& <> 0 THEN
                            DIM mdBGLow AS INTEGER
                            mdBGLow% = LAYERS(mdBelowGrp%).zIndex%
                            FOR i% = 1 TO MAX_LAYERS
                                IF LAYERS(i%).imgHandle& <> 0 THEN
                                    IF LAYERS(i%).parentGroupIdx% = mdBelowGrp% THEN
                                        IF LAYERS(i%).zIndex% < mdBGLow% THEN mdBGLow% = LAYERS(i%).zIndex%
                                    END IF
                                END IF
                            NEXT i%
                            mdJumpBotZ% = mdBGLow%
                        END IF
                    END IF
                END IF
            END IF

            ' Count block sizes
            DIM mdBlockSize AS INTEGER
            mdBlockSize% = currentZ% - grpLowestZ% + 1 ' our group block size

            DIM mdJumpSize AS INTEGER
            mdJumpSize% = grpLowestZ% - mdJumpBotZ%    ' how many slots to jump below

            ' Shift: everything between mdJumpBotZ..grpLowestZ-1 goes up by mdBlockSize
            ' Our group block (grpLowestZ..currentZ) goes down by mdJumpSize
            FOR i% = 1 TO MAX_LAYERS
                IF LAYERS(i%).imgHandle& <> 0 AND i% <> mdSlot% THEN
                    IF LAYERS(i%).zIndex% >= mdJumpBotZ% AND LAYERS(i%).zIndex% < grpLowestZ% THEN
                        LAYERS(i%).zIndex% = LAYERS(i%).zIndex% + mdBlockSize%
                    ELSEIF LAYERS(i%).parentGroupIdx% = mdSlot% THEN
                        LAYERS(i%).zIndex% = LAYERS(i%).zIndex% - mdJumpSize%
                    END IF
                END IF
            NEXT i%
            LAYERS(mdSlot%).zIndex% = currentZ% - mdJumpSize%

            LAYERS_enforce_group_contiguity
            IF NOT HISTORY_IN_PROGRESS% THEN
                HISTORY_record_layer_reorder LAYERS(mdSlot%).historyId&, mdSlot%, currentZ%, LAYERS(mdSlot%).zIndex%, "Layer Reorder"
            END IF
        END IF
        BLEND_invalidate_cache
        GUI_NEEDS_REDRAW% = TRUE
        EXIT SUB
    END IF

    ' For child layers inside a group: swap with sibling, or escape group at boundary
    IF LAYERS(mdSlot%).parentGroupIdx% > 0 THEN
        DIM mdParent  AS INTEGER
        mdParent% = LAYERS(mdSlot%).parentGroupIdx%
        ' Find lowest child z in this group
        DIM mdLowestZ AS INTEGER
        mdLowestZ% = currentZ%
        FOR i% = 1 TO MAX_LAYERS
            IF LAYERS(i%).imgHandle& <> 0 THEN
                IF LAYERS(i%).parentGroupIdx% = mdParent% THEN
                    IF LAYERS(i%).zIndex% < mdLowestZ% THEN
                        mdLowestZ% = LAYERS(i%).zIndex%
                    END IF
                END IF
            END IF
        NEXT i%
        IF currentZ% < = mdLowestZ% THEN
            ' At bottom of group — escape to parent group (or top-level)
            DIM mdGrandparent AS INTEGER
            mdGrandparent%                  = LAYERS(mdParent%).parentGroupIdx%
            LAYERS(mdSlot%).parentGroupIdx% = mdGrandparent%
            DIM mdBelowZ      AS INTEGER
            mdBelowZ% = currentZ% - 1
            IF mdBelowZ% < 1 THEN
                ' Already at bottom of stack — just reparent
                LAYERS_enforce_group_contiguity
                IF NOT HISTORY_IN_PROGRESS% THEN
                    HISTORY_record_group_reparent LAYERS(mdSlot%).historyId&, mdSlot%, mdParent%, mdGrandparent%, currentZ%, currentZ%, "Move Out of Group"
                END IF
            ELSE
                ' Swap with layer below
                targetIndex% = 0
                FOR i% = 1 TO MAX_LAYERS
                    IF LAYERS(i%).imgHandle& <> 0 AND LAYERS(i%).zIndex% = mdBelowZ% THEN
                        targetIndex% = i%
                        EXIT FOR
                    END IF
                NEXT i%
                IF targetIndex% > 0 THEN
                    LAYERS(mdSlot%).zIndex%      = mdBelowZ%
                    LAYERS(targetIndex%).zIndex% = currentZ%
                END IF
                LAYERS_enforce_group_contiguity
                IF NOT HISTORY_IN_PROGRESS% THEN
                    HISTORY_record_group_reparent LAYERS(mdSlot%).historyId&, mdSlot%, mdParent%, mdGrandparent%, currentZ%, mdBelowZ%, "Move Out of Group"
                END IF
            END IF
            ' Auto-remove empty group
            IF LAYERS_group_child_count%(mdParent%) = 0 THEN
                LAYERS_delete mdParent%
                IF CURRENT_LAYER% = mdParent% THEN LAYERS_select mdSlot%
            END IF
        ELSE
            ' Swap with the layer below within group
            targetIndex% = 0
            FOR i% = 1 TO MAX_LAYERS
                IF LAYERS(i%).imgHandle& <> 0 AND LAYERS(i%).zIndex% = currentZ% - 1 THEN
                    targetIndex% = i%
                    EXIT FOR
                END IF
            NEXT i%
            IF targetIndex% > 0 THEN
                LAYERS(mdSlot%).zIndex%      = currentZ% - 1
                LAYERS(targetIndex%).zIndex% = currentZ%
                IF NOT HISTORY_IN_PROGRESS% THEN
                    HISTORY_record_layer_reorder LAYERS(mdSlot%).historyId&, mdSlot%, currentZ%, currentZ% - 1, "Layer Reorder"
                END IF
            END IF
        END IF
        BLEND_invalidate_cache
        GUI_NEEDS_REDRAW% = TRUE
        EXIT SUB
    END IF

    ' Non-grouped layer: skip over entire group blocks when moving down
    DIM newTargetZ AS INTEGER
    newTargetZ% = currentZ% - 1
    ' Check if the layer at newTargetZ is part of a group — skip the entire group
    targetIndex% = 0
    FOR i% = 1 TO MAX_LAYERS
        IF LAYERS(i%).imgHandle& <> 0 AND LAYERS(i%).zIndex% = newTargetZ% THEN
            targetIndex% = i%
            EXIT FOR
        END IF
    NEXT i%
    IF targetIndex% > 0 THEN
        IF LAYERS(targetIndex%).layerType% = LAYER_TYPE_GROUP THEN
            ' Target is a group header — find lowest child and skip to that z
            DIM skipGrpLowest AS INTEGER
            skipGrpLowest% = LAYERS(targetIndex%).zIndex%
            FOR i% = 1 TO MAX_LAYERS
                IF LAYERS(i%).imgHandle& <> 0 THEN
                    IF LAYERS(i%).parentGroupIdx% = targetIndex% THEN
                        IF LAYERS(i%).zIndex% < skipGrpLowest% THEN
                            skipGrpLowest% = LAYERS(i%).zIndex%
                        END IF
                    END IF
                END IF
            NEXT i%
            newTargetZ% = skipGrpLowest%
        ELSEIF LAYERS(targetIndex%).parentGroupIdx% > 0 THEN
            ' Target is a group child — skip to lowest child z of that group
            DIM skipGrpIdx2   AS INTEGER
            skipGrpIdx2% = LAYERS(targetIndex%).parentGroupIdx%
            IF skipGrpIdx2% > 0 THEN
                IF skipGrpIdx2% < = MAX_LAYERS THEN
                    IF LAYERS(skipGrpIdx2%).imgHandle& <> 0 THEN
                        DIM skipGrpLowest2 AS INTEGER
                        skipGrpLowest2% = LAYERS(skipGrpIdx2%).zIndex%
                        FOR i% = 1 TO MAX_LAYERS
                            IF LAYERS(i%).imgHandle& <> 0 THEN
                                IF LAYERS(i%).parentGroupIdx% = skipGrpIdx2% THEN
                                    IF LAYERS(i%).zIndex% < skipGrpLowest2% THEN
                                        skipGrpLowest2% = LAYERS(i%).zIndex%
                                    END IF
                                END IF
                            END IF
                        NEXT i%
                        newTargetZ% = skipGrpLowest2%
                    END IF
                END IF
            END IF
        END IF
    END IF
    IF newTargetZ% < 1 THEN newTargetZ% = 1
    IF newTargetZ% = currentZ% THEN EXIT SUB

    ' Shift layers between new and old position up by 1
    FOR i% = 1 TO MAX_LAYERS
        IF LAYERS(i%).imgHandle& <> 0 AND i% <> mdSlot% THEN
            IF LAYERS(i%).zIndex% >= newTargetZ% AND LAYERS(i%).zIndex% < currentZ% THEN
                LAYERS(i%).zIndex% = LAYERS(i%).zIndex% + 1
            END IF
        END IF
    NEXT i%
    LAYERS(mdSlot%).zIndex% = newTargetZ%
    
    IF NOT HISTORY_IN_PROGRESS% THEN
        HISTORY_record_layer_reorder LAYERS(mdSlot%).historyId&, mdSlot%, currentZ%, newTargetZ%, "Layer Reorder"
    END IF
    
    BLEND_invalidate_cache
    GUI_NEEDS_REDRAW% = TRUE
END SUB


''
' Move a layer to the top of the stack
' @param layerIndex INTEGER Index of the layer to move to the top (1-64)
'
SUB LAYERS_to_top (layerIndex AS INTEGER)
    DIM i        AS INTEGER
    DIM currentZ AS INTEGER
    
    ' Validate
    IF layerIndex% < 1 OR layerIndex% > MAX_LAYERS THEN EXIT SUB
    IF LAYERS(layerIndex%).imgHandle& = 0 THEN EXIT SUB
    
    currentZ% = LAYERS(layerIndex%).zIndex%
    IF currentZ% = LAYER_COUNT% THEN EXIT SUB  ' Already at top
    ' Decrease zIndex of all layers above this one
    FOR i% = 1 TO MAX_LAYERS
        IF LAYERS(i%).imgHandle& <> 0 AND LAYERS(i%).zIndex% > currentZ% THEN
            LAYERS(i%).zIndex% = LAYERS(i%).zIndex% - 1
        END IF
    NEXT i%
    
    ' Set this layer to top
    LAYERS(layerIndex%).zIndex% = LAYER_COUNT%
    IF NOT HISTORY_IN_PROGRESS% THEN
        HISTORY_record_layer_reorder LAYERS(layerIndex%).historyId&, layerIndex%, currentZ%, LAYER_COUNT%, "Layer Reorder"
    END IF
    
    BLEND_invalidate_cache
    GUI_NEEDS_REDRAW% = TRUE
END SUB


''
' Move a layer to the bottom of the stack
' @param layerIndex INTEGER Index of the layer to move to the bottom (1-64)
'
SUB LAYERS_to_bottom (layerIndex AS INTEGER)
    DIM i        AS INTEGER
    DIM currentZ AS INTEGER
    
    ' Validate
    IF layerIndex% < 1 OR layerIndex% > MAX_LAYERS THEN EXIT SUB
    IF LAYERS(layerIndex%).imgHandle& = 0 THEN EXIT SUB
    
    currentZ% = LAYERS(layerIndex%).zIndex%
    IF currentZ% = 1 THEN EXIT SUB  ' Already at bottom
    ' Increase zIndex of all layers below this one
    FOR i% = 1 TO MAX_LAYERS
        IF LAYERS(i%).imgHandle& <> 0 AND LAYERS(i%).zIndex% < currentZ% THEN
            LAYERS(i%).zIndex% = LAYERS(i%).zIndex% + 1
        END IF
    NEXT i%
    
    ' Set this layer to bottom
    LAYERS(layerIndex%).zIndex% = 1
    IF NOT HISTORY_IN_PROGRESS% THEN
        HISTORY_record_layer_reorder LAYERS(layerIndex%).historyId&, layerIndex%, currentZ%, 1, "Layer Reorder"
    END IF
    
    BLEND_invalidate_cache
    GUI_NEEDS_REDRAW% = TRUE
END SUB


''
' Toggle layer visibility
' @param layerIndex INTEGER Index of the layer to toggle visibility on (1-64)
'
SUB LAYERS_toggle_visibility (layerIndex AS INTEGER)
    ' Validate
    IF layerIndex% < 1 OR layerIndex% > MAX_LAYERS THEN EXIT SUB
    IF LAYERS(layerIndex%).imgHandle& = 0 THEN EXIT SUB
    
    LAYERS(layerIndex%).visible% = NOT LAYERS(layerIndex%).visible%
    BLEND_invalidate_visibility layerIndex%
    GUI_NEEDS_REDRAW% = TRUE
END SUB


''
' Set layer opacity
' @param layerIndex INTEGER Index of the layer to update (1-64)
' @param opacity INTEGER Opacity value to set (0-255, clamped)
'
SUB LAYERS_set_opacity (layerIndex AS INTEGER, opacity AS INTEGER)
    DIM clampedOpacity AS INTEGER
    
    ' Validate
    IF layerIndex% < 1 OR layerIndex% > MAX_LAYERS THEN EXIT SUB
    IF LAYERS(layerIndex%).imgHandle& = 0 THEN EXIT SUB
    
    ' Clamp opacity to valid range
    clampedOpacity% = opacity%
    IF clampedOpacity% < 0 THEN clampedOpacity% = 0
    IF clampedOpacity% > 255 THEN clampedOpacity% = 255
    
    LAYERS(layerIndex%).opacity% = clampedOpacity%
    BLEND_COMPOSITE_DIRTY%       = TRUE
    COMPOSITE_BELOW_VALID%       = FALSE
    SCENE_DIRTY%                 = TRUE
    GUI_NEEDS_REDRAW%            = TRUE
END SUB


''
' Toggle opacity lock (draw only on non-transparent pixels)
' @param layerIndex INTEGER Index of the layer to toggle opacity lock on (1-64)
'
SUB LAYERS_toggle_opacity_lock (layerIndex AS INTEGER)
    ' Validate
    IF layerIndex% < 1 OR layerIndex% > MAX_LAYERS THEN EXIT SUB
    IF LAYERS(layerIndex%).imgHandle& = 0 THEN EXIT SUB
    
    LAYERS(layerIndex%).opacityLock% = NOT LAYERS(layerIndex%).opacityLock%
    GUI_NEEDS_REDRAW%                = TRUE
END SUB


''
' Merge current layer down into the layer below it
' @param layerIndex INTEGER Index of the layer to merge down (1-64)
'
SUB LAYERS_merge_down (layerIndex AS INTEGER)
    DIM i           AS INTEGER
    DIM currentZ    AS INTEGER
    DIM targetIndex AS INTEGER
    DIM oldDest     AS LONG
    DIM tempImg     AS LONG

    ' CRITICAL: Copy parameter to local — QB64 passes by reference.
    DIM mrgSlot AS INTEGER
    mrgSlot% = layerIndex%
    
    ' Validate
    IF mrgSlot% < 1 OR mrgSlot% > MAX_LAYERS THEN EXIT SUB
    IF LAYERS(mrgSlot%).imgHandle& = 0 THEN EXIT SUB
    
    currentZ% = LAYERS(mrgSlot%).zIndex%
    IF currentZ% < = 1 THEN EXIT SUB  ' No layer below to merge into
    
    ' Find layer below (zIndex = currentZ - 1)
    targetIndex% = 0
    FOR i% = 1 TO MAX_LAYERS
        IF LAYERS(i%).imgHandle& <> 0 AND LAYERS(i%).zIndex% = currentZ% - 1 THEN
            targetIndex% = i%
            EXIT FOR
        END IF
    NEXT i%
    
    IF targetIndex% = 0 THEN EXIT SUB
    
    ' Record in unified history BEFORE merge (captures both layers' before-state)
    HISTORY_record_layer_merge mrgSlot%, targetIndex%
    
    ' Merge: composite current layer onto target respecting blend mode and opacity
    oldDest& = _DEST
    
    IF LAYERS(mrgSlot%).blendMode% <> BLEND_NORMAL THEN
        ' Non-Normal blend mode: use per-pixel blend composite (handles opacity internally)
        LAYER_blend_composite LAYERS(targetIndex%).imgHandle&, LAYERS(mrgSlot%).imgHandle&, LAYERS(mrgSlot%).blendMode%, LAYERS(mrgSlot%).opacity%
    ELSEIF LAYERS(mrgSlot%).opacity% < 255 THEN
        ' Normal blend with partial opacity: scale alpha per-pixel
        ' _SETALPHA must NOT be used here — it overwrites ALL pixels' alpha including
        ' transparent ones, turning empty pixels into semi-transparent black.
        ' Instead, scale each non-transparent pixel's alpha by (origAlpha * opacity / 255),
        ' matching the same logic used by the renderer's opacity cache.
        tempImg& = _COPYIMAGE(LAYERS(mrgSlot%).imgHandle&, 32)
        DIM mergeMem      AS _MEM
        DIM mergeOffset   AS _OFFSET
        DIM mergePixVal   AS _UNSIGNED LONG
        DIM mergeAlpha    AS _UNSIGNED _BYTE
        DIM mergeNewAlpha AS INTEGER
        mergeMem = _MEMIMAGE(tempImg&)
        FOR mergeOffset = mergeMem.OFFSET TO mergeMem.OFFSET + mergeMem.SIZE - 4 STEP 4
            _MEMGET mergeMem, mergeOffset, mergePixVal~&
            mergeAlpha~%% = _ALPHA32(mergePixVal~&)
            IF mergeAlpha~%% > 0 THEN
                mergeNewAlpha% = (mergeAlpha~%% * LAYERS(mrgSlot%).opacity%) \ 255
                _MEMPUT mergeMem, mergeOffset + 3, mergeNewAlpha% AS _UNSIGNED _BYTE
            END IF
        NEXT mergeOffset
        _MEMFREE mergeMem
        _DEST LAYERS(targetIndex%).imgHandle&
        _BLEND LAYERS(targetIndex%).imgHandle&
        _PUTIMAGE , tempImg&
        IF tempImg& < -1 THEN _FREEIMAGE tempImg&
    ELSE
        ' Normal blend at full opacity
        _DEST LAYERS(targetIndex%).imgHandle&
        _BLEND LAYERS(targetIndex%).imgHandle&
        _PUTIMAGE , LAYERS(mrgSlot%).imgHandle&
    END IF
    
    _DEST oldDest&
    
    ' Mark target layer content dirty (its pixels changed from merge)
    LAYERS(targetIndex%).contentDirty% = TRUE
    
    ' Delete the merged layer (suppress undo save since we already recorded merge state)
    HISTORY_IN_PROGRESS% = TRUE
    LAYERS_delete mrgSlot%
    HISTORY_IN_PROGRESS% = FALSE
    
    ' Select the target layer
    LAYERS_select targetIndex%
    
    INVALIDATE_scene
END SUB


''
' Merge all visible layers into a new layer
' 
SUB LAYERS_merge_visible ()
    DIM newIndex  AS INTEGER
    DIM i         AS INTEGER, z AS INTEGER
    DIM oldDest   AS LONG
    DIM tempImg   AS LONG
    DIM sortedLayers(1 TO MAX_LAYERS) AS INTEGER
    DIM sortCount AS INTEGER
    
    ' Build sorted list of visible layers by zIndex
    sortCount% = 0
    FOR z% = 1 TO LAYER_COUNT%
        FOR i% = 1 TO MAX_LAYERS
            IF LAYERS(i%).imgHandle& <> 0 AND LAYERS(i%).visible% AND LAYERS(i%).zIndex% = z% THEN
                sortCount% = sortCount% + 1
                sortedLayers%(sortCount%) = i%
                EXIT FOR
            END IF
        NEXT i%
    NEXT z%
    
    IF sortCount% < 2 THEN EXIT SUB  ' Need at least 2 visible layers to merge
    
    ' Record in unified history BEFORE merge (captures all source layers' before-state)
    ' Pass 0 as mergedResultSlot — updated after LAYERS_new% succeeds below.
    HISTORY_record_layer_merge_visible sortedLayers%(), sortCount%, 0

    ' Suppress history auto-saves from LAYERS_new% and LAYERS_delete
    HISTORY_IN_PROGRESS% = TRUE

    ' Create new layer for merged result
    newIndex% = LAYERS_new%
    IF newIndex% = 0 THEN
        ' Rollback: remove the history record we just saved
        IF HISTORY.current% > 0 THEN
            DIM mvRbIdx AS INTEGER
            mvRbIdx% = HISTORY.current%
            DIM mvRbSlt AS INTEGER : mvRbSlt% = HISTORY_MV_SLOT(mvRbIdx%)
            IF mvRbSlt% >= 1 THEN HISTORY_MV_free_slot mvRbSlt%
            HISTORY_MV_SLOT(mvRbIdx%)       = 0
            HISTORY_RECORDS(mvRbIdx%).kind% = HISTORY_KIND_NONE
            HISTORY.count% = HISTORY.count% - 1
            HISTORY.current% = HISTORY.current% - 1
        END IF
        HISTORY_IN_PROGRESS% = FALSE
        EXIT SUB
    END IF

    ' Update the history record with the actual merged result slot
    HISTORY_RECORDS(HISTORY.current%).slotIndex% = newIndex%
    HISTORY_merge_update_result_id LAYERS(newIndex%).historyId&
    
    LAYERS(newIndex%).name = "Merged"
    
    ' Composite all visible layers bottom-to-top respecting blend modes
    oldDest& = _DEST
    _DEST LAYERS(newIndex%).imgHandle&
    CLS , _RGBA32(0, 0, 0, 0)
    _BLEND LAYERS(newIndex%).imgHandle&
    
    FOR i% = 1 TO sortCount%
        DIM srcIdx AS INTEGER
        srcIdx% = sortedLayers%(i%)
        
        IF LAYERS(srcIdx%).blendMode% <> BLEND_NORMAL THEN
            ' Non-Normal blend mode: use per-pixel blend composite (handles opacity internally)
            ' Must restore _DEST first since LAYER_blend_composite uses _MEMIMAGE, not _DEST
            _DEST oldDest&
            LAYER_blend_composite LAYERS(newIndex%).imgHandle&, LAYERS(srcIdx%).imgHandle&, LAYERS(srcIdx%).blendMode%, LAYERS(srcIdx%).opacity%
            _DEST LAYERS(newIndex%).imgHandle&
        ELSEIF LAYERS(srcIdx%).opacity% < 255 THEN
            ' Normal blend with partial opacity: scale alpha per-pixel
            tempImg& = _COPYIMAGE(LAYERS(srcIdx%).imgHandle&, 32)
            DIM mvMem      AS _MEM
            DIM mvOffset   AS _OFFSET
            DIM mvPixVal   AS _UNSIGNED LONG
            DIM mvAlpha    AS _UNSIGNED _BYTE
            DIM mvNewAlpha AS INTEGER
            mvMem = _MEMIMAGE(tempImg&)
            FOR mvOffset = mvMem.OFFSET TO mvMem.OFFSET + mvMem.SIZE - 4 STEP 4
                _MEMGET mvMem, mvOffset, mvPixVal~&
                mvAlpha~%% = _ALPHA32(mvPixVal~&)
                IF mvAlpha~%% > 0 THEN
                    mvNewAlpha% = (mvAlpha~%% * LAYERS(srcIdx%).opacity%) \ 255
                    _MEMPUT mvMem, mvOffset + 3, mvNewAlpha% AS _UNSIGNED _BYTE
                END IF
            NEXT mvOffset
            _MEMFREE mvMem
            _PUTIMAGE , tempImg&
            IF tempImg& < -1 THEN _FREEIMAGE tempImg&
        ELSE
            ' Normal blend at full opacity
            _PUTIMAGE , LAYERS(srcIdx%).imgHandle&
        END IF
    NEXT i%
    
    _DEST oldDest&
    
    ' Delete the source visible layers (except the new one)
    ' HISTORY_IN_PROGRESS% is TRUE, so LAYERS_delete won't create undo states
    FOR i% = 1 TO sortCount%
        IF sortedLayers%(i%) <> newIndex% THEN
            LAYERS_delete sortedLayers%(i%)
        END IF
    NEXT i%

    HISTORY_IN_PROGRESS% = FALSE
    
    ' Select the merged layer
    LAYERS_select newIndex%
    
    INVALIDATE_scene
END SUB


''
' Flatten all visible layers and return a new image handle
' Caller is responsible for freeing the returned image
' @return LONG - New image handle containing the flattened result
' 
FUNCTION LAYERS_flatten& ()
    DIM result  AS LONG
    DIM i       AS INTEGER, z AS INTEGER
    DIM oldDest AS LONG
    DIM tempImg AS LONG
    
    result& = _NEWIMAGE(SCRN.canvasW&, SCRN.canvasH&, 32)
    
    oldDest& = _DEST
    _DEST result&
    CLS , _RGBA32(0, 0, 0, 0)
    _BLEND result&
    _DEST oldDest&
    
    ' Composite visible layers bottom-to-top by zIndex
    DIM srcImg AS LONG, apronTmp AS LONG, oldSrc AS LONG, sx AS INTEGER, sy AS INTEGER
    FOR z% = 1 TO LAYER_COUNT%
        FOR i% = 1 TO MAX_LAYERS
            IF LAYERS(i%).imgHandle& <> 0 AND LAYERS(i%).visible% AND LAYERS(i%).zIndex% = z% THEN
                ' APRON: extract canvas region into a compact temp if layer is extended.
                apronTmp& = 0
                IF LAYERS(i%).apronW% > 0 OR LAYERS(i%).apronH% > 0 THEN
                    apronTmp& = _NEWIMAGE(SCRN.canvasW&, SCRN.canvasH&, 32)
                    oldSrc& = _SOURCE
                    _SOURCE LAYERS(i%).imgHandle&
                    DIM olD AS LONG: olD& = _DEST: _DEST apronTmp&
                    sx% = LAYERS(i%).apronW%
                    sy% = LAYERS(i%).apronH%
                    _PUTIMAGE (0, 0)-(SCRN.canvasW& - 1, SCRN.canvasH& - 1), LAYERS(i%).imgHandle&, apronTmp&, (sx%, sy%)-(sx% + SCRN.canvasW& - 1, sy% + SCRN.canvasH& - 1)
                    _DEST olD&
                    _SOURCE oldSrc&
                    srcImg& = apronTmp&
                ELSE
                    srcImg& = LAYERS(i%).imgHandle&
                END IF
                IF LAYERS(i%).blendMode% <> BLEND_NORMAL THEN
                    ' Non-Normal blend: use per-pixel blend composite
                    LAYER_blend_composite result&, srcImg&, LAYERS(i%).blendMode%, LAYERS(i%).opacity%
                ELSE
                    ' Normal blend: standard alpha composite via _PUTIMAGE
                    oldDest& = _DEST
                    _DEST result&
                    IF LAYERS(i%).opacity% < 255 THEN
                        ' Scale alpha per-pixel (not _SETALPHA which overwrites transparent pixels)
                        tempImg& = _COPYIMAGE(srcImg&, 32)
                        DIM flatMem  AS _MEM
                        DIM flatOff  AS _OFFSET
                        DIM flatPix  AS _UNSIGNED LONG
                        DIM flatA    AS _UNSIGNED _BYTE
                        DIM flatNewA AS INTEGER
                        flatMem = _MEMIMAGE(tempImg&)
                        FOR flatOff = flatMem.OFFSET TO flatMem.OFFSET + flatMem.SIZE - 4 STEP 4
                            _MEMGET flatMem, flatOff, flatPix~&
                            flatA~%% = _ALPHA32(flatPix~&)
                            IF flatA~%% > 0 THEN
                                flatNewA% = (flatA~%% * LAYERS(i%).opacity%) \ 255
                                _MEMPUT flatMem, flatOff + 3, flatNewA% AS _UNSIGNED _BYTE
                            END IF
                        NEXT flatOff
                        _MEMFREE flatMem
                        _PUTIMAGE , tempImg&
                        IF tempImg& < -1 THEN _FREEIMAGE tempImg&
                    ELSE
                        _PUTIMAGE , srcImg&
                    END IF
                    _DEST oldDest&
                END IF
                IF apronTmp& < -1 THEN _FREEIMAGE apronTmp&
                EXIT FOR
            END IF
        NEXT i%
    NEXT z%
    
    LAYERS_flatten& = result&
END FUNCTION


''
' Get the current layer's image handle for drawing
' @return LONG - Image handle of the current layer, or SCRN.PAINTING& as fallback
' 
FUNCTION LAYER_current_image& ()
    IF CURRENT_LAYER% >= 1 AND CURRENT_LAYER% < = MAX_LAYERS THEN
        IF LAYERS(CURRENT_LAYER%).imgHandle& <> 0 THEN
            LAYER_current_image& = LAYERS(CURRENT_LAYER%).imgHandle&
            EXIT FUNCTION
        END IF
    END IF
    
    ' Fallback to SCRN.PAINTING if no valid layer
    LAYER_current_image& = SCRN.PAINTING&
END FUNCTION


''
' Render the layer panel
' @param canvasHeight INTEGER Total viewport height used to compute panel bounds
'
SUB LAYER_PANEL_render (canvasHeight AS INTEGER)
    DIM panelX             AS INTEGER, panelY AS INTEGER
    DIM panelW             AS INTEGER, panelH AS INTEGER
    DIM rowY               AS INTEGER
    DIM i                  AS INTEGER, z AS INTEGER
    DIM layerIdx           AS INTEGER
    DIM oldDest            AS LONG
    DIM oldFont            AS LONG
    DIM bgColor            AS _UNSIGNED LONG
    DIM fgColor            AS _UNSIGNED LONG
    DIM rowBg              AS _UNSIGNED LONG
    DIM visibleIcon        AS STRING
    DIM lockIcon           AS STRING
    DIM opacityFill        AS INTEGER
    DIM bottomBarsHeight   AS INTEGER
    DIM listTop            AS INTEGER, listBottom AS INTEGER, listHeight AS INTEGER
    DIM totalContentHeight AS INTEGER
    DIM scrollbarX         AS INTEGER, scrollbarY AS INTEGER, scrollbarH AS INTEGER
    DIM thumbH             AS INTEGER, thumbY AS INTEGER
    DIM maxScroll          AS INTEGER
    
    IF NOT LAYER_PANEL.visible% THEN EXIT SUB
    
    ' Calculate height of bottom bars (status bar + palette strip) only if visible
    IF SCRN.showStatus% THEN
        bottomBarsHeight% = THEME.STATUS_height% + PALETTE_STRIP_get_height%
    ELSE
        bottomBarsHeight% = 0 ' No bottom bars when status bar is hidden
    END IF
    
    panelX%              = SCRN.layerPanelX%
    panelY%              = 0
    panelW%              = LAYER_PANEL.width%
    panelH%              = canvasHeight% - bottomBarsHeight% ' Extend to bottom when status bar hidden
    LAYER_PANEL.panelX1% = panelX%
    LAYER_PANEL.panelX2% = panelX% + panelW% - 1
    
    ' Define areas: header, list area (variable), button area (heights from THEME)
    DIM HEADER_HEIGHT      AS INTEGER : HEADER_HEIGHT = THEME.LAYER_PANEL_header_height%
    DIM BUTTON_AREA_HEIGHT AS INTEGER : BUTTON_AREA_HEIGHT = THEME.LAYER_PANEL_btn_bar_height%
    listTop%    = panelY% + HEADER_HEIGHT
    listBottom% = panelH% - BUTTON_AREA_HEIGHT
    listHeight% = listBottom% - listTop%
    
    ' Calculate total content height (excluding collapsed group children)
    DIM visibleRowCount AS INTEGER
    DIM vri             AS INTEGER, vrIdx AS INTEGER
    visibleRowCount% = 0
    FOR vri% = LAYER_COUNT% TO 1 STEP -1
        FOR vrIdx% = 1 TO MAX_LAYERS
            IF LAYERS(vrIdx%).imgHandle& <> 0 AND LAYERS(vrIdx%).zIndex% = vri% THEN
                ' Skip children of collapsed groups
                DIM vrParent AS INTEGER
                vrParent% = LAYERS(vrIdx%).parentGroupIdx%
                DIM vrSkip   AS INTEGER
                vrSkip% = FALSE
                IF vrParent% > 0 THEN
                    IF vrParent% < = MAX_LAYERS THEN
                        IF LAYERS(vrParent%).imgHandle& <> 0 THEN
                            IF LAYERS(vrParent%).collapsed% THEN vrSkip% = TRUE
                        END IF
                    END IF
                END IF
                IF NOT vrSkip% THEN
                    visibleRowCount% = visibleRowCount% + 1
                END IF
                EXIT FOR
            END IF
        NEXT vrIdx%
    NEXT vri%
    totalContentHeight% = visibleRowCount% * LAYER_ROW_HEIGHT
    
    ' Calculate max scroll offset
    maxScroll% = totalContentHeight% - listHeight%
    IF maxScroll% < 0 THEN maxScroll% = 0
    
    ' Clamp scroll offset
    IF LAYER_PANEL.scrollOffset% > maxScroll% THEN LAYER_PANEL.scrollOffset% = maxScroll%
    IF LAYER_PANEL.scrollOffset% < 0 THEN LAYER_PANEL.scrollOffset% = 0
    
    oldDest& = _DEST
    _DEST SCRN.GUI&
    
    ' Draw panel background
    bgColor~& = THEME.LAYER_PANEL_bg~&
    LINE (panelX%, panelY%)-(panelX% + panelW% - 1, panelY% + panelH% - 1), bgColor~&, BF
    
    ' Draw right border
    LINE (panelX% + panelW% - 1, panelY%)-(panelX% + panelW% - 1, panelY% + panelH% - 1), THEME.LAYER_PANEL_border~&
    
    ' Draw header
    LINE (panelX%, panelY%)-(panelX% + panelW% - 1, panelY% + HEADER_HEIGHT - 1), THEME.LAYER_PANEL_header_bg~&, BF
    
    oldFont& = _FONT
    IF LAYER_PANEL.fontHandle& > 0 THEN _FONT LAYER_PANEL.fontHandle&
    
    COLOR THEME.LAYER_PANEL_header_fg~&, _RGBA32(0, 0, 0, 0)
    IF panelW% >= 60 THEN
        _UPRINTSTRING (panelX% + 4, panelY% + 3), "LAYERS"
    ELSE
        _UPRINTSTRING (panelX% + 2, panelY% + 3), "L"
    END IF
    
    ' Draw layer count in header (only if it won't overlap title)
    IF panelW% >= 60 THEN
        COLOR THEME.LAYER_PANEL_header_fg_dim~&, _RGBA32(0, 0, 0, 0)
        _UPRINTSTRING (panelX% + panelW% - 20, panelY% + 3), _TRIM$(STR$(LAYER_COUNT%))
    END IF
    
    ' Draw layer rows (top to bottom = highest zIndex to lowest)
    ' Only draw rows that are visible in the list area
    rowY% = listTop%
    
    FOR z% = LAYER_COUNT% TO 1 STEP -1
        ' Find layer with this zIndex
        layerIdx% = 0
        FOR i% = 1 TO MAX_LAYERS
            IF LAYERS(i%).imgHandle& <> 0 AND LAYERS(i%).zIndex% = z% THEN
                layerIdx% = i%
                EXIT FOR
            END IF
        NEXT i%
        
        IF layerIdx% > 0 THEN
            ' Skip children of collapsed groups (walk entire ancestor chain)
            DIM lpParent            AS INTEGER
            DIM lpAncestorCollapsed AS INTEGER
            lpParent%            = LAYERS(layerIdx%).parentGroupIdx%
            lpAncestorCollapsed% = FALSE
            DIM lpWalkPar           AS INTEGER
            lpWalkPar% = lpParent%
            DO WHILE lpWalkPar% > 0
                IF lpWalkPar% < = MAX_LAYERS THEN
                    IF LAYERS(lpWalkPar%).imgHandle& <> 0 THEN
                        IF LAYERS(lpWalkPar%).collapsed% THEN
                            lpAncestorCollapsed% = TRUE
                            EXIT DO
                        END IF
                    END IF
                    lpWalkPar% = LAYERS(lpWalkPar%).parentGroupIdx%
                ELSE
                    EXIT DO
                END IF
            LOOP
            IF lpAncestorCollapsed% THEN _CONTINUE

            ' Calculate indentation based on nesting depth
            DIM rowIndent   AS INTEGER
            DIM lpNestDepth AS INTEGER
            DIM lpIndentPx  AS INTEGER
            lpNestDepth% = LAYERS_nesting_depth%(layerIdx%)
            IF CFG.LAYER_GROUP_INDENT% > 0 THEN
                lpIndentPx% = CFG.LAYER_GROUP_INDENT%
            ELSE
                lpIndentPx% = THEME.LAYER_PANEL_group_indent%
            END IF
            rowIndent% = lpNestDepth% * lpIndentPx%

            DIM drawY AS INTEGER
            drawY% = rowY% - LAYER_PANEL.scrollOffset%
            
            ' Only draw if row is visible in list area
            IF drawY% + LAYER_ROW_HEIGHT > listTop% AND drawY% < listBottom% THEN
                ' Clip to list area
                DIM clipTop AS INTEGER, clipBottom AS INTEGER
                clipTop% = drawY%
                IF clipTop% < listTop% THEN clipTop% = listTop%
                clipBottom% = drawY% + LAYER_ROW_HEIGHT - 1
                IF clipBottom% >= listBottom% THEN clipBottom% = listBottom% - 1
                
                ' Group headers get their own background color
                DIM isGroupHeader AS INTEGER
                isGroupHeader% = (LAYERS(layerIdx%).layerType% = LAYER_TYPE_GROUP)
                ' Row background — group headers get special bg; master gets accent;
                '   secondary multi-selected get dimmer tint; others normal/hover.
                IF isGroupHeader% THEN
                    IF layerIdx% = CURRENT_LAYER% THEN
                        rowBg~& = THEME.LAYER_PANEL_row_master_bg~&
                    ELSEIF MULTI_SELECT_LAYERS(layerIdx%) THEN
                        rowBg~& = THEME.LAYER_PANEL_row_multi_sel_bg~&
                    ELSE
                        rowBg~& = THEME.LAYER_PANEL_group_header_bg~&
                    END IF
                ELSEIF layerIdx% = CURRENT_LAYER% THEN
                    rowBg~& = THEME.LAYER_PANEL_row_master_bg~&
                ELSEIF MULTI_SELECT_LAYERS(layerIdx%) THEN
                    rowBg~& = THEME.LAYER_PANEL_row_multi_sel_bg~&
                ELSEIF LAYERS(layerIdx%).layerType% = LAYER_TYPE_SYMBOL_PARENT THEN
                    rowBg~& = THEME.LAYER_PANEL_symbol_parent_bg~&
                ELSEIF LAYERS(layerIdx%).layerType% = LAYER_TYPE_SYMBOL_CHILD THEN
                    rowBg~& = THEME.LAYER_PANEL_symbol_child_bg~&
                ELSEIF LAYER_PANEL.hoverRow% = layerIdx% THEN
                    rowBg~& = THEME.LAYER_PANEL_row_hover_bg~&
                ELSE
                    rowBg~& = THEME.LAYER_PANEL_row_bg~&
                END IF
                LINE (panelX% + 2 + rowIndent%, clipTop%)-(panelX% + panelW% - 12, clipBottom%), rowBg~&, BF
                ' 2px left-edge accent bar to distinguish master (current) layer
                IF layerIdx% = CURRENT_LAYER% THEN
                    LINE (panelX% + 2 + rowIndent%, clipTop%)-(panelX% + 3 + rowIndent%, clipBottom%), THEME.LAYER_PANEL_row_master_accent~&, BF
                END IF
                
                ' Only draw text if fully visible
                IF drawY% >= listTop% AND drawY% + LAYER_ROW_HEIGHT < = listBottom% THEN
                    ' Row content X offset (includes indent for children)
                    DIM rowX AS INTEGER
                    rowX% = panelX% + 3 + rowIndent%

                    IF isGroupHeader% THEN
                        ' === GROUP HEADER ROW ===
                        ' Collapse triangle: right-pointing when collapsed, down when expanded
                        DIM triX AS INTEGER, triY AS INTEGER
                        triX% = rowX%
                        triY% = drawY% + (LAYER_ROW_HEIGHT \ 2)
                        COLOR THEME.LAYER_PANEL_group_collapse_fg~&, _RGBA32(0, 0, 0, 0)
                        IF LAYERS(layerIdx%).collapsed% THEN
                            ' Right-pointing triangle (collapsed)
                            LINE (triX%, triY% - 4)-(triX%, triY% + 4), THEME.LAYER_PANEL_group_collapse_fg~&
                            LINE (triX%, triY% - 4)-(triX% + 4, triY%), THEME.LAYER_PANEL_group_collapse_fg~&
                            LINE (triX%, triY% + 4)-(triX% + 4, triY%), THEME.LAYER_PANEL_group_collapse_fg~&
                        ELSE
                            ' Down-pointing triangle (expanded)
                            LINE (triX%, triY% - 2)-(triX% + 8, triY% - 2), THEME.LAYER_PANEL_group_collapse_fg~&
                            LINE (triX%, triY% - 2)-(triX% + 4, triY% + 2), THEME.LAYER_PANEL_group_collapse_fg~&
                            LINE (triX% + 8, triY% - 2)-(triX% + 4, triY% + 2), THEME.LAYER_PANEL_group_collapse_fg~&
                        END IF

                        ' Visibility toggle (same as normal layers)
                        DIM gVisIcon AS LONG
                        IF LAYERS(layerIdx%).visible% THEN
                            gVisIcon& = LAYER_PANEL.iconVisOn&
                        ELSE
                            gVisIcon& = LAYER_PANEL.iconVisOff&
                        END IF
                        IF gVisIcon& < -1 THEN
                            DIM gviW AS INTEGER, gviH AS INTEGER
                            gviW% = _WIDTH(gVisIcon&)
                            gviH% = _HEIGHT(gVisIcon&)
                            _PUTIMAGE (rowX% + 10, drawY% + (LAYER_ROW_HEIGHT - gviH%) \ 2)-(rowX% + 10 + gviW% - 1, drawY% + (LAYER_ROW_HEIGHT - gviH%) \ 2 + gviH% - 1), gVisIcon&, SCRN.GUI&
                        END IF

                        ' Group blend mode abbreviation — right-aligned at y+4
                        ' (matches normal-layer layout). Pass-through is the default
                        ' for groups, so only show when it's been changed *away* from
                        ' pass-through, OR show the explicit blend mode if set.
                        DIM grpShowBlend  AS INTEGER
                        DIM grpBlendShort AS STRING
                        grpShowBlend% = FALSE
                        IF panelW% >= 80 THEN
                            IF LAYERS(layerIdx%).passThrough% THEN
                                grpShowBlend%  = TRUE
                                grpBlendShort$ = BLEND_mode_short$(BLEND_PASS_THROUGH)
                            ELSEIF LAYERS(layerIdx%).blendMode% <> BLEND_NORMAL THEN
                                grpShowBlend%  = TRUE
                                grpBlendShort$ = BLEND_mode_short$(LAYERS(layerIdx%).blendMode%)
                            END IF
                        END IF

                        ' Group child count — rendered inline next to the name (y+4),
                        ' so the y+12 slot stays empty/unused on group rows.
                        DIM grpChildCnt AS INTEGER
                        DIM grpCountStr AS STRING
                        grpChildCnt% = LAYERS_group_child_count%(layerIdx%)
                        IF grpChildCnt% > 0 AND panelW% >= 80 THEN
                            grpCountStr$ = " (" + _TRIM$(STR$(grpChildCnt%)) + ")"
                        ELSE
                            grpCountStr$ = ""
                        END IF

                        ' Group name (trimmed to fit, leaving room for count + blend abbrev)
                        DIM grpName          AS STRING
                        grpName$ = _TRIM$(LAYERS(layerIdx%).name)
                        ' Char-count cap (display-only)
                        DIM grpNameMaxChars  AS INTEGER
                        grpNameMaxChars% = CFG.LAYER_NAME_MAX_LEN%
                        IF grpNameMaxChars% < 1 THEN grpNameMaxChars% = 20
                        DIM grpNameTruncated AS INTEGER
                        grpNameTruncated% = FALSE
                        IF LEN(grpName$) > grpNameMaxChars% THEN
                            grpName$          = LEFT$(grpName$, grpNameMaxChars%)
                            grpNameTruncated% = TRUE
                        END IF
                        DIM grpAvailW        AS INTEGER
                        grpAvailW% = panelW% - rowIndent% - 24 - 14
                        IF LEN(grpCountStr$) > 0 THEN grpAvailW% = grpAvailW% - _PRINTWIDTH(grpCountStr$)
                        IF grpShowBlend% THEN grpAvailW% = grpAvailW% - _PRINTWIDTH(grpBlendShort$) - 2
                        IF _PRINTWIDTH(grpName$) > grpAvailW% THEN
                            grpNameTruncated% = TRUE
                            DO WHILE LEN(grpName$) > 0 AND _PRINTWIDTH(grpName$ + "...") > grpAvailW%
                                grpName$ = LEFT$(grpName$, LEN(grpName$) - 1)
                            LOOP
                        END IF
                        IF grpNameTruncated% THEN grpName$ = grpName$ + "..."
                        COLOR THEME.LAYER_PANEL_group_header_fg~&, _RGBA32(0, 0, 0, 0)
                        _UPRINTSTRING (rowX% + 22, drawY% + 4), grpName$

                        ' Inline child count after the trimmed group name
                        IF LEN(grpCountStr$) > 0 THEN
                            DIM grpCountX AS INTEGER
                            grpCountX% = rowX% + 22 + _PRINTWIDTH(grpName$)
                            COLOR THEME.LAYER_PANEL_header_fg_dim~&, _RGBA32(0, 0, 0, 0)
                            _UPRINTSTRING (grpCountX%, drawY% + 4), grpCountStr$
                        END IF

                        ' Right-aligned blend abbreviation
                        IF grpShowBlend% THEN
                            DIM grpBlendX AS INTEGER
                            grpBlendX% = panelX% + panelW% - 17 - _PRINTWIDTH(grpBlendShort$)
                            COLOR THEME.LAYER_PANEL_row_fg_blend~&, _RGBA32(0, 0, 0, 0)
                            _UPRINTSTRING (grpBlendX%, drawY% + 4), grpBlendShort$
                        END IF
                    ELSE
                        ' === NORMAL / TEXT LAYER ROW ===
                    ' Visibility toggle (eye icon) - PNG with text fallback
                    DIM visIcon AS LONG
                    IF LAYERS(layerIdx%).visible% THEN
                        visIcon&     = LAYER_PANEL.iconVisOn&
                        fgColor~&    = _RGB32(200, 200, 200)
                        visibleIcon$ = "O" ' Fallback text
                    ELSE
                        visIcon&     = LAYER_PANEL.iconVisOff&
                        fgColor~&    = _RGB32(100, 100, 100)
                        visibleIcon$ = "-" ' Fallback text
                    END IF
                    IF visIcon& < -1 THEN
                        ' Draw PNG icon centered vertically in row
                        DIM viW AS INTEGER, viH AS INTEGER
                        viW% = _WIDTH(visIcon&)
                        viH% = _HEIGHT(visIcon&)
                        _PUTIMAGE (rowX%, drawY% + (LAYER_ROW_HEIGHT - viH%) \ 2)-(rowX% + viW% - 1, drawY% + (LAYER_ROW_HEIGHT - viH%) \ 2 + viH% - 1), visIcon&, SCRN.GUI&
                    ELSE
                        ' Fallback to text
                        COLOR fgColor~&, _RGBA32(0, 0, 0, 0)
                        _UPRINTSTRING (rowX% + 1, drawY% + 4), visibleIcon$
                    END IF
                    
                    ' Opacity lock icon - PNG with text fallback
                    DIM lkIcon AS LONG
                    IF LAYERS(layerIdx%).opacityLock% THEN
                        lkIcon& = LAYER_PANEL.iconLockOn&
                    ELSE
                        lkIcon& = LAYER_PANEL.iconLockOff&
                    END IF
                    IF lkIcon& < -1 THEN
                        ' Draw PNG icon centered vertically in row
                        DIM lkW AS INTEGER, lkH AS INTEGER
                        lkW% = _WIDTH(lkIcon&)
                        lkH% = _HEIGHT(lkIcon&)
                        _PUTIMAGE (rowX% + 11, drawY% + (LAYER_ROW_HEIGHT - lkH%) \ 2)-(rowX% + 11 + lkW% - 1, drawY% + (LAYER_ROW_HEIGHT - lkH%) \ 2 + lkH% - 1), lkIcon&, SCRN.GUI&
                    ELSE
                        ' Fallback to text (only show when locked)
                        IF LAYERS(layerIdx%).opacityLock% THEN
                            lockIcon$ = "L"
                            COLOR _RGB32(255, 180, 0), _RGBA32(0, 0, 0, 0)
                            _UPRINTSTRING (rowX% + 11, drawY% + 4), lockIcon$
                        END IF
                    END IF
                    
                    ' Layer name (fit to available panel space using pixel width)
                    DIM layerName AS STRING
                    DIM availW    AS INTEGER
                    layerName$ = _TRIM$(LAYERS(layerIdx%).name)
                    IF LAYERS(layerIdx%).layerType% = LAYER_TYPE_TEXT THEN
                        layerName$ = "[T] " + layerName$
                    END IF

                    ' Char-count cap (display-only). Anything beyond gets ellipsis-trimmed.
                    DIM layerNameMaxChars        AS INTEGER
                    layerNameMaxChars% = CFG.LAYER_NAME_MAX_LEN%
                    IF layerNameMaxChars% < 1 THEN layerNameMaxChars% = 20
                    DIM layerNameTruncatedByChar AS INTEGER
                    layerNameTruncatedByChar% = FALSE
                    IF LEN(layerName$) > layerNameMaxChars% THEN
                        layerName$                = LEFT$(layerName$, layerNameMaxChars%)
                        layerNameTruncatedByChar% = TRUE
                    END IF

                    ' Pre-compute blend abbreviation so we can shrink availW% to make room.
                    ' Blend is shown right-aligned on the name row (y+4); badge gets y+12 alone.
                    DIM showBlendInd AS INTEGER
                    DIM blendShort   AS STRING
                    DIM blendIndX    AS INTEGER
                    showBlendInd% = FALSE
                    IF panelW% >= 80 THEN
                        IF LAYERS(layerIdx%).layerType% = LAYER_TYPE_GROUP AND LAYERS(layerIdx%).passThrough% THEN
                            showBlendInd% = TRUE
                            blendShort$   = BLEND_mode_short$(BLEND_PASS_THROUGH)
                        ELSEIF LAYERS(layerIdx%).blendMode% <> BLEND_NORMAL THEN
                            showBlendInd% = TRUE
                            blendShort$   = BLEND_mode_short$(LAYERS(layerIdx%).blendMode%)
                        END IF
                    END IF

                    ' availW% = full row width minus left icons (24px) minus opacity bar (14px)
                    ' When a blend abbreviation is present, also subtract its width + 2px gap.
                    availW% = panelW% - rowIndent% - 24 - 14
                    IF showBlendInd% THEN availW% = availW% - _PRINTWIDTH(blendShort$) - 2

                    ' Trim from end until it fits the available pixel width.
                    ' If we had to trim (by char-count cap or by pixel width), append an ellipsis.
                    DIM layerNameTruncated AS INTEGER
                    layerNameTruncated% = layerNameTruncatedByChar%
                    IF _PRINTWIDTH(layerName$) > availW% THEN
                        layerNameTruncated% = TRUE
                        DO WHILE LEN(layerName$) > 0 AND _PRINTWIDTH(layerName$ + "...") > availW%
                            layerName$ = LEFT$(layerName$, LEN(layerName$) - 1)
                        LOOP
                    END IF
                    IF layerNameTruncated% THEN layerName$ = layerName$ + "..."
                    COLOR THEME.LAYER_PANEL_row_fg~&, _RGBA32(0, 0, 0, 0)
                    IF LAYERS(layerIdx%).layerType% = LAYER_TYPE_SYMBOL_PARENT THEN
                        COLOR THEME.LAYER_PANEL_symbol_parent_fg~&, _RGBA32(0, 0, 0, 0)
                    ELSEIF LAYERS(layerIdx%).layerType% = LAYER_TYPE_SYMBOL_CHILD THEN
                        COLOR THEME.LAYER_PANEL_symbol_child_fg~&, _RGBA32(0, 0, 0, 0)
                    END IF
                    _UPRINTSTRING (rowX% + 21, drawY% + 4), layerName$

                    ' Blend mode indicator — right-aligned on the name row (y+4), just left
                    ' of the opacity bar.  Badge occupies y+12 alone so no overlap is possible.
                    IF showBlendInd% THEN
                        ' Right edge of blend text must sit 2px left of the opacity bar.
                        blendIndX% = panelX% + panelW% - 17 - _PRINTWIDTH(blendShort$)
                        COLOR THEME.LAYER_PANEL_row_fg_blend~&, _RGBA32(0, 0, 0, 0)
                        _UPRINTSTRING (blendIndX%, drawY% + 4), blendShort$
                    END IF
                    END IF ' isGroupHeader% ELSE

                    ' Export mode badge (SUB/TXT/IMG) — always on the left at y+12.
                    ' Blend mode has moved to the right side, so no vertical stacking needed.
                    DIM exportBadge AS STRING
                    exportBadge$ = FILE_QB64_export_badge$(layerIdx%)
                    IF LEN(exportBadge$) > 0 THEN
                        DIM badgeY AS INTEGER
                        badgeY% = drawY% + 12
                        IF badgeY% + 8 <= drawY% + LAYER_ROW_HEIGHT THEN
                            COLOR FILE_QB64_badge_color~&(layerIdx%), _RGBA32(0, 0, 0, 0)
                            _UPRINTSTRING (rowX% + 21, badgeY%), exportBadge$
                        END IF
                    END IF

                    ' Opacity bar — vertical bar on right edge of each row
                    ' Fills bottom-to-top: top (drawY%+2) = fully opaque, bottom (drawY%+16) = transparent
                    ' Only show when panel is wide enough (>=80px)
                    IF panelW% >= 80 THEN
                        opacityFill% = INT((LAYERS(layerIdx%).opacity% / 255.0) * 14)
                        ' Track background: 3px wide x 15px tall at panelW%-15 to panelW%-13
                        LINE (panelX% + panelW% - 15, drawY% + 2)-(panelX% + panelW% - 13, drawY% + 16), THEME.LAYER_PANEL_opacity_bar_bg~&, BF
                        ' Fill from bottom up
                        IF opacityFill% > 0 THEN
                            LINE (panelX% + panelW% - 15, drawY% + 16 - opacityFill%)-(panelX% + panelW% - 13, drawY% + 16), THEME.LAYER_PANEL_opacity_bar_fg~&, BF
                        END IF
                    END IF
                END IF
            END IF
            
            rowY% = rowY% + LAYER_ROW_HEIGHT
        END IF
    NEXT z%
    
    ' --- Draw drop target indicator when dragging ---
    IF LAYER_PANEL.isDragging% AND LAYER_PANEL.dropTargetZIndex% >= 1 THEN
        DIM dropY          AS INTEGER
        DIM dropRowFromTop AS INTEGER
        DIM draggedZ       AS INTEGER
        
        draggedZ% = LAYERS(LAYER_PANEL.dragLayerIdx%).zIndex%
        
        ' Draw indicator (dropTargetZIndex is already validated, -1 means no valid target)
        ' Calculate Y position for drop indicator
        ' Count visible rows from top (highest z) down to the target zIndex
        ' This accounts for collapsed group children that skip rows
        DIM dropVisRow AS INTEGER
        DIM dropScanZ  AS INTEGER, dropScanI AS INTEGER, dropScanIdx AS INTEGER
        dropVisRow% = 0
        FOR dropScanZ% = LAYER_COUNT% TO 1 STEP -1
            FOR dropScanI% = 1 TO MAX_LAYERS
                IF LAYERS(dropScanI%).imgHandle& <> 0 AND LAYERS(dropScanI%).zIndex% = dropScanZ% THEN
                    dropScanIdx% = dropScanI%
                    ' Skip children of collapsed groups
                    IF LAYERS(dropScanIdx%).parentGroupIdx% > 0 THEN
                        DIM dropScanP         AS INTEGER
                        dropScanP% = LAYERS(dropScanIdx%).parentGroupIdx%
                        DIM dropScanCollapsed AS INTEGER
                        dropScanCollapsed% = FALSE
                        IF dropScanP% > 0 THEN
                            IF dropScanP% < = MAX_LAYERS THEN
                                IF LAYERS(dropScanP%).imgHandle& <> 0 THEN
                                    IF LAYERS(dropScanP%).collapsed% THEN dropScanCollapsed% = TRUE
                                END IF
                            END IF
                        END IF
                        IF dropScanCollapsed% THEN EXIT FOR
                    END IF
                    IF dropScanZ% = LAYER_PANEL.dropTargetZIndex% THEN GOTO DropIndicatorFound
                    dropVisRow% = dropVisRow% + 1
                    EXIT FOR
                END IF
            NEXT dropScanI%
        NEXT dropScanZ%
        DropIndicatorFound:

        IF LAYER_PANEL.dropTargetZIndex% > draggedZ% THEN
            dropRowFromTop% = dropVisRow%
        ELSE
            dropRowFromTop% = dropVisRow% + 1
        END IF
        dropY% = listTop% + (dropRowFromTop% * LAYER_ROW_HEIGHT) - LAYER_PANEL.scrollOffset%
        
        ' Draw indicator line if visible
        IF dropY% >= listTop% - 2 AND dropY% < = listBottom% + 2 THEN
            LINE (panelX% + 4, dropY%)-(panelX% + panelW% - 14, dropY%), THEME.LAYER_PANEL_drop_line~&
            LINE (panelX% + 4, dropY% - 1)-(panelX% + panelW% - 14, dropY% - 1), THEME.LAYER_PANEL_drop_line2~&
            ' Draw small triangles at ends
            LINE (panelX% + 2, dropY% - 3)-(panelX% + 6, dropY%), THEME.LAYER_PANEL_drop_line~&
            LINE (panelX% + 2, dropY% + 3)-(panelX% + 6, dropY%), THEME.LAYER_PANEL_drop_line~&
            LINE (panelX% + panelW% - 12, dropY% - 3)-(panelX% + panelW% - 16, dropY%), THEME.LAYER_PANEL_drop_line~&
            LINE (panelX% + panelW% - 12, dropY% + 3)-(panelX% + panelW% - 16, dropY%), THEME.LAYER_PANEL_drop_line~&
        END IF
    END IF
    
    ' --- Draw drag cursor preview (mini layer row following mouse) ---
    IF LAYER_PANEL.isDragging% AND LAYER_PANEL.dragLayerIdx% > 0 THEN
        DIM previewY      AS INTEGER
        DIM previewH      AS INTEGER
        DIM dragLayerName AS STRING
        DIM dragLayerZ    AS INTEGER
        
        previewY% = LAYER_PANEL.dragPreviewY% - (LAYER_ROW_HEIGHT \ 2)
        previewH% = LAYER_ROW_HEIGHT
        
        ' Clamp preview to panel bounds
        IF previewY% < listTop% THEN previewY% = listTop%
        IF previewY% + previewH% > listBottom% THEN previewY% = listBottom% - previewH%
        
        dragLayerName$ = RTRIM$(LAYERS(LAYER_PANEL.dragLayerIdx%).name)
        IF LAYERS(LAYER_PANEL.dragLayerIdx%).layerType% = LAYER_TYPE_TEXT THEN
            dragLayerName$ = "[T] " + dragLayerName$
        END IF
        dragLayerZ% = LAYERS(LAYER_PANEL.dragLayerIdx%).zIndex%
        
        ' Draw semi-transparent preview row
        LINE (panelX% + 2, previewY%)-(panelX% + panelW% - 4, previewY% + previewH% - 2), THEME.LAYER_PANEL_drag_fill~&, BF
        LINE (panelX% + 2, previewY%)-(panelX% + panelW% - 4, previewY% + previewH% - 2), THEME.LAYER_PANEL_drag_border~&, B
        
        ' Draw layer name in preview
        COLOR _RGB32(255, 255, 255), _RGBA32(0, 0, 0, 0)
        IF LEN(dragLayerName$) > 12 THEN dragLayerName$ = LEFT$(dragLayerName$, 11) + "~"
        _UPRINTSTRING (panelX% + 26, previewY% + 4), dragLayerName$
    END IF
    
    ' Draw scrollbar if content exceeds list height
    IF totalContentHeight% > listHeight% THEN
        scrollbarX% = panelX% + panelW% - 10
        scrollbarY% = listTop%
        scrollbarH% = listHeight%
        
        ' Scrollbar track
        LINE (scrollbarX%, scrollbarY%)-(scrollbarX% + 7, scrollbarY% + scrollbarH% - 1), THEME.LAYER_PANEL_scrollbar_track~&, BF
        
        ' Scrollbar thumb
        thumbH% = INT((listHeight% / totalContentHeight%) * scrollbarH%)
        IF thumbH% < 20 THEN thumbH% = 20  ' Minimum thumb size
        IF thumbH% > scrollbarH% THEN thumbH% = scrollbarH%
        
        IF maxScroll% > 0 THEN
            thumbY% = scrollbarY% + INT((LAYER_PANEL.scrollOffset% / maxScroll%) * (scrollbarH% - thumbH%))
        ELSE
            thumbY% = scrollbarY%
        END IF
        
        ' Brighten thumb while dragging
        DIM sbThumbDrawColor AS _UNSIGNED LONG
        IF LAYER_PANEL.scrollDragging% THEN
            DIM sbDR AS INTEGER : sbDR% = _RED32(THEME.LAYER_PANEL_scrollbar_thumb~&)
            DIM sbDG AS INTEGER : sbDG% = _GREEN32(THEME.LAYER_PANEL_scrollbar_thumb~&)
            DIM sbDB AS INTEGER : sbDB% = _BLUE32(THEME.LAYER_PANEL_scrollbar_thumb~&)
            sbThumbDrawColor~& = _RGB32(sbDR% + (255 - sbDR%) \ 2, sbDG% + (255 - sbDG%) \ 2, sbDB% + (255 - sbDB%) \ 2)
        ELSE
            sbThumbDrawColor~& = THEME.LAYER_PANEL_scrollbar_thumb~&
        END IF
        LINE (scrollbarX% + 1, thumbY%)-(scrollbarX% + 6, thumbY% + thumbH% - 1), sbThumbDrawColor~&, BF
    END IF
    
    ' Draw separator line above button area
    LINE (panelX%, listBottom%)-(panelX% + panelW% - 1, listBottom%), THEME.LAYER_PANEL_sep~&

    ' Draw button bar background
    LINE (panelX%, listBottom% + 1)-(panelX% + panelW% - 1, panelY% + panelH% - 1), THEME.LAYER_PANEL_btn_bar_bg~&, BF
    
    ' Draw button bar at bottom (5 buttons: ^ v # x +)
    DIM btnY       AS INTEGER
    DIM btnW       AS INTEGER
    DIM btnX       AS INTEGER
    DIM btnSpacing AS INTEGER
    DIM btnEnabled AS INTEGER
    DIM btnIcon    AS LONG
    DIM biW        AS INTEGER, biH AS INTEGER
    
    btnY% = listBottom% + 1
    DIM btnSlotH AS INTEGER: btnSlotH% = BUTTON_AREA_HEIGHT - 1 ' bar height minus 1px separator
    btnSpacing% = 2
    btnW%       = (panelW% - 8 - (5 * btnSpacing%)) \ 6         ' 6 buttons with spacing
    
    ' Button 1: Move Up (^)
    btnX%       = panelX% + 4
    btnEnabled% = FALSE
    IF CURRENT_LAYER% > 0 THEN btnEnabled% = (LAYERS(CURRENT_LAYER%).zIndex% < LAYER_COUNT%)
    btnIcon& = LAYER_PANEL.iconBtnUp&
    IF btnIcon& < -1 THEN
        biW% = _WIDTH(btnIcon&): biH% = _HEIGHT(btnIcon&)
        _PUTIMAGE (btnX% + (btnW% - biW%) \ 2, btnY% + (btnSlotH% - biH%) \ 2)-(btnX% + (btnW% - biW%) \ 2 + biW% - 1, btnY% + (btnSlotH% - biH%) \ 2 + biH% - 1), btnIcon&, SCRN.GUI&
    ELSE
        IF btnEnabled% THEN
            LINE (btnX%, btnY%)-(btnX% + btnW% - 1, btnY% + btnSlotH% - 1), _RGB32(60, 70, 80), BF
        ELSE
            LINE (btnX%, btnY%)-(btnX% + btnW% - 1, btnY% + btnSlotH% - 1), _RGB32(45, 45, 45), BF
        END IF
    END IF
    
    ' Button 2: Move Down (v)
    btnX% = btnX% + btnW% + btnSpacing%
    btnEnabled% = FALSE
    IF CURRENT_LAYER% > 0 THEN btnEnabled% = (LAYERS(CURRENT_LAYER%).zIndex% > 1)
    btnIcon& = LAYER_PANEL.iconBtnDown&
    IF btnIcon& < -1 THEN
        biW% = _WIDTH(btnIcon&): biH% = _HEIGHT(btnIcon&)
        _PUTIMAGE (btnX% + (btnW% - biW%) \ 2, btnY% + (btnSlotH% - biH%) \ 2)-(btnX% + (btnW% - biW%) \ 2 + biW% - 1, btnY% + (btnSlotH% - biH%) \ 2 + biH% - 1), btnIcon&, SCRN.GUI&
    ELSE
        IF btnEnabled% THEN
            LINE (btnX%, btnY%)-(btnX% + btnW% - 1, btnY% + btnSlotH% - 1), _RGB32(60, 70, 80), BF
        ELSE
            LINE (btnX%, btnY%)-(btnX% + btnW% - 1, btnY% + btnSlotH% - 1), _RGB32(45, 45, 45), BF
        END IF
    END IF
    
    ' Button 3: Merge Down (#)
    btnX% = btnX% + btnW% + btnSpacing%
    btnEnabled% = FALSE
    IF CURRENT_LAYER% > 0 THEN btnEnabled% = (LAYERS(CURRENT_LAYER%).zIndex% > 1)
    btnIcon& = LAYER_PANEL.iconBtnMerge&
    IF btnIcon& < -1 THEN
        biW% = _WIDTH(btnIcon&): biH% = _HEIGHT(btnIcon&)
        _PUTIMAGE (btnX% + (btnW% - biW%) \ 2, btnY% + (btnSlotH% - biH%) \ 2)-(btnX% + (btnW% - biW%) \ 2 + biW% - 1, btnY% + (btnSlotH% - biH%) \ 2 + biH% - 1), btnIcon&, SCRN.GUI&
    ELSE
        IF btnEnabled% THEN
            LINE (btnX%, btnY%)-(btnX% + btnW% - 1, btnY% + btnSlotH% - 1), _RGB32(70, 70, 60), BF
        ELSE
            LINE (btnX%, btnY%)-(btnX% + btnW% - 1, btnY% + btnSlotH% - 1), _RGB32(45, 45, 45), BF
        END IF
    END IF
    
    ' Button 4: Delete Layer (x)
    btnX% = btnX% + btnW% + btnSpacing%
    btnEnabled% = (LAYER_COUNT% > 1)
    btnIcon&    = LAYER_PANEL.iconBtnDelete&
    IF btnIcon& < -1 THEN
        biW% = _WIDTH(btnIcon&): biH% = _HEIGHT(btnIcon&)
        _PUTIMAGE (btnX% + (btnW% - biW%) \ 2, btnY% + (btnSlotH% - biH%) \ 2)-(btnX% + (btnW% - biW%) \ 2 + biW% - 1, btnY% + (btnSlotH% - biH%) \ 2 + biH% - 1), btnIcon&, SCRN.GUI&
    ELSE
        IF btnEnabled% THEN
            LINE (btnX%, btnY%)-(btnX% + btnW% - 1, btnY% + btnSlotH% - 1), _RGB32(80, 50, 50), BF
        ELSE
            LINE (btnX%, btnY%)-(btnX% + btnW% - 1, btnY% + btnSlotH% - 1), _RGB32(45, 45, 45), BF
        END IF
    END IF
    ' Drag highlight drawn AFTER icon so it appears in front
    IF LAYER_PANEL.isDragging% AND LAYER_PANEL.dropOnButton% = 4 THEN
        LINE (btnX%, btnY%)-(btnX% + btnW% - 1, btnY% + btnSlotH% - 1), THEME.LAYER_PANEL_btn_drag_delete~&, BF
    END IF
    
    ' Button 5: New Layer (+)
    btnX% = btnX% + btnW% + btnSpacing%
    btnIcon& = LAYER_PANEL.iconBtnAdd&
    IF btnIcon& < -1 THEN
        biW% = _WIDTH(btnIcon&): biH% = _HEIGHT(btnIcon&)
        _PUTIMAGE (btnX% + (btnW% - biW%) \ 2, btnY% + (btnSlotH% - biH%) \ 2)-(btnX% + (btnW% - biW%) \ 2 + biW% - 1, btnY% + (btnSlotH% - biH%) \ 2 + biH% - 1), btnIcon&, SCRN.GUI&
    ELSE
        LINE (btnX%, btnY%)-(btnX% + btnW% - 1, btnY% + btnSlotH% - 1), _RGB32(50, 70, 50), BF
    END IF
    ' Drag highlight drawn AFTER icon so it appears in front
    IF LAYER_PANEL.isDragging% AND LAYER_PANEL.dropOnButton% = 5 THEN
        LINE (btnX%, btnY%)-(btnX% + btnW% - 1, btnY% + btnSlotH% - 1), THEME.LAYER_PANEL_btn_drag_new~&, BF
    END IF

    ' Button 6: New Group (folder)
    btnX% = btnX% + btnW% + btnSpacing%
    btnIcon& = LAYER_PANEL.iconBtnGroup&
    IF btnIcon& < -1 THEN
        biW% = _WIDTH(btnIcon&): biH% = _HEIGHT(btnIcon&)
        _PUTIMAGE (btnX% + (btnW% - biW%) \ 2, btnY% + (btnSlotH% - biH%) \ 2)-(btnX% + (btnW% - biW%) \ 2 + biW% - 1, btnY% + (btnSlotH% - biH%) \ 2 + biH% - 1), btnIcon&, SCRN.GUI&
    ELSE
        LINE (btnX%, btnY%)-(btnX% + btnW% - 1, btnY% + btnSlotH% - 1), _RGB32(50, 60, 80), BF
    END IF
    ' Drag highlight drawn AFTER icon so it appears in front
    IF LAYER_PANEL.isDragging% AND LAYER_PANEL.dropOnButton% = 6 THEN
        LINE (btnX%, btnY%)-(btnX% + btnW% - 1, btnY% + btnSlotH% - 1), THEME.LAYER_PANEL_btn_drag_group~&, BF
    END IF

    _FONT oldFont&
    _DEST oldDest&
END SUB


''
' Check if mouse coordinates are within the layer panel
' @param rawX INTEGER Raw screen X coordinate to test
' @param rawY INTEGER Raw screen Y coordinate to test
' @return INTEGER - TRUE if the point is inside the layer panel bounds
'
FUNCTION LAYER_PANEL_in_bounds% (rawX AS INTEGER, rawY AS INTEGER)
    DIM bottomBarsHeight AS INTEGER
    DIM panelH           AS INTEGER
    
    IF NOT LAYER_PANEL.visible% THEN
        LAYER_PANEL_in_bounds% = FALSE
        EXIT FUNCTION
    END IF
    
    ' Calculate panel height (stops above bottom bars only if visible)
    IF SCRN.showStatus% THEN
        bottomBarsHeight% = THEME.STATUS_height% + PALETTE_STRIP_get_height%
    ELSE
        bottomBarsHeight% = 0
    END IF
    panelH% = SCRN.h& - bottomBarsHeight%
    
    LAYER_PANEL_in_bounds% = (rawX% >= LAYER_PANEL.panelX1% AND rawX% <= LAYER_PANEL.panelX2% AND rawY% >= 0 AND rawY% < panelH%)
END FUNCTION


''
' Map a raw mouse coordinate to the layer slot under the cursor in the layer
' panel list area. Returns 0 if the cursor is outside the panel, over the
' header/button bar, or over an empty area below the last layer row.
' Mirrors the row hit-test logic in LAYER_PANEL_handle_click and accounts for
' collapsed group children being skipped.
' @param rawX INTEGER Raw screen X coordinate
' @param rawY INTEGER Raw screen Y coordinate
' @return INTEGER - Layer slot (1..MAX_LAYERS), or 0 if not over a row
'
FUNCTION LAYER_PANEL_get_row_slot% (rawX AS INTEGER, rawY AS INTEGER)
    LAYER_PANEL_get_row_slot% = 0
    IF NOT LAYER_PANEL.visible% THEN EXIT FUNCTION
    IF NOT LAYER_PANEL_in_bounds%(rawX%, rawY%) THEN EXIT FUNCTION

    DIM bottomBarsHeight AS INTEGER
    IF SCRN.showStatus% THEN
        bottomBarsHeight% = THEME.STATUS_height% + PALETTE_STRIP_get_height%
    ELSE
        bottomBarsHeight% = 0
    END IF
    DIM panelH           AS INTEGER : panelH% = SCRN.h& - bottomBarsHeight%
    DIM listTop          AS INTEGER : listTop% = THEME.LAYER_PANEL_header_height%
    DIM listBot          AS INTEGER : listBot% = panelH% - THEME.LAYER_PANEL_btn_bar_height%
    IF rawY% < listTop% OR rawY% >= listBot% THEN EXIT FUNCTION

    DIM clickY  AS INTEGER : clickY% = rawY% + LAYER_PANEL.scrollOffset%
    DIM rowY    AS INTEGER : rowY% = 16
    DIM z       AS INTEGER, i AS INTEGER, layerIdx AS INTEGER
    DIM walkPar AS INTEGER, ancCollapsed AS INTEGER

    FOR z% = LAYER_COUNT% TO 1 STEP -1
        layerIdx% = 0
        FOR i% = 1 TO MAX_LAYERS
            IF LAYERS(i%).imgHandle& <> 0 AND LAYERS(i%).zIndex% = z% THEN
                layerIdx% = i%
                EXIT FOR
            END IF
        NEXT i%
        IF layerIdx% = 0 THEN _CONTINUE

        ' Skip children of collapsed groups
        ancCollapsed% = FALSE
        walkPar%      = LAYERS(layerIdx%).parentGroupIdx%
        DO WHILE walkPar% > 0
            IF walkPar% <= MAX_LAYERS THEN
                IF LAYERS(walkPar%).imgHandle& <> 0 THEN
                    IF LAYERS(walkPar%).collapsed% THEN
                        ancCollapsed% = TRUE
                        EXIT DO
                    END IF
                END IF
                walkPar% = LAYERS(walkPar%).parentGroupIdx%
            ELSE
                EXIT DO
            END IF
        LOOP
        IF ancCollapsed% THEN _CONTINUE

        IF clickY% >= rowY% AND clickY% < rowY% + LAYER_ROW_HEIGHT THEN
            LAYER_PANEL_get_row_slot% = layerIdx%
            EXIT FUNCTION
        END IF
        rowY% = rowY% + LAYER_ROW_HEIGHT
    NEXT z%
END FUNCTION


''
' Handle click events in the layer panel
' Returns TRUE if click was handled, FALSE otherwise
' @param rawX INTEGER Raw screen X coordinate of the click
' @param rawY INTEGER Raw screen Y coordinate of the click
' @param button INTEGER Mouse button that was clicked (1=left, 2=right, 3=middle)
' @return INTEGER - TRUE if the click was handled by the panel
'
FUNCTION LAYER_PANEL_handle_click% (rawX AS INTEGER, rawY AS INTEGER, button AS INTEGER)
    DIM panelW           AS INTEGER, panelH AS INTEGER
    DIM rowY             AS INTEGER
    DIM i                AS INTEGER, z AS INTEGER
    DIM layerIdx         AS INTEGER
    DIM clickY           AS INTEGER
    DIM bottomBarsHeight AS INTEGER
    ' Note: btnClickedThisPress is no longer needed - the caller (MOUSE.BM) already 
    ' ensures we only get called on fresh clicks (MOUSE.B1% AND NOT MOUSE.OLD_B1%)
    
    IF NOT LAYER_PANEL.visible% THEN
        LAYER_PANEL_handle_click% = FALSE
        EXIT FUNCTION
    END IF

    ' Commit active text editing when clicking in the layer panel.
    ' Without this, TEXT.ACTIVE stays TRUE and blocks KEYBOARD_layers from
    ' processing Ctrl+Shift+G (Group from Selection) and other layer hotkeys.
    IF TEXT.ACTIVE AND CURRENT_TOOL% = TOOL_TEXT THEN
        TEXT_commit
    END IF
    
    ' Calculate panel height (stops above bottom bars only if visible)
    IF SCRN.showStatus% THEN
        bottomBarsHeight% = THEME.STATUS_height% + PALETTE_STRIP_get_height%
    ELSE
        bottomBarsHeight% = 0
    END IF
    panelW% = LAYER_PANEL.width%
    panelH% = SCRN.h& - bottomBarsHeight%

    ' Normalize to panel-local X coordinate
    DIM localRawX AS INTEGER
    localRawX% = rawX% - LAYER_PANEL.panelX1%

    ' Check if click is within panel
    IF localRawX% < 0 OR localRawX% >= panelW% THEN
        LAYER_PANEL_handle_click% = FALSE
        EXIT FUNCTION
    END IF
    
    ' Check for scrollbar click (8px wide strip at right edge of panel)
    DIM sbListTop2 AS INTEGER : sbListTop2% = THEME.LAYER_PANEL_header_height%
    DIM sbListBot2 AS INTEGER : sbListBot2% = panelH% - THEME.LAYER_PANEL_btn_bar_height%
    DIM sbListH2   AS INTEGER : sbListH2% = sbListBot2% - sbListTop2%
    DIM sbTotalH2  AS INTEGER : sbTotalH2% = LAYER_PANEL_visible_row_count% * LAYER_ROW_HEIGHT
    IF sbTotalH2% > sbListH2% THEN
        DIM sbSX2 AS INTEGER: sbSX2% = panelW% - 10
        IF localRawX% >= sbSX2% AND localRawX% < = sbSX2% + 7 AND rawY% >= sbListTop2% AND rawY% < sbListBot2% THEN
            DIM sbMaxScr2 AS INTEGER: sbMaxScr2% = sbTotalH2% - sbListH2%
            IF sbMaxScr2% < 0 THEN sbMaxScr2% = 0
            DIM sbTH2     AS INTEGER
            sbTH2% = INT((sbListH2% / sbTotalH2%) * sbListH2%)
            IF sbTH2% < 20 THEN sbTH2% = 20
            IF sbTH2% > sbListH2% THEN sbTH2% = sbListH2%
            DIM sbTY2     AS INTEGER
            IF sbMaxScr2% > 0 THEN
                sbTY2% = sbListTop2% + INT((LAYER_PANEL.scrollOffset% / sbMaxScr2%) * (sbListH2% - sbTH2%))
            ELSE
                sbTY2% = sbListTop2%
            END IF
            IF rawY% >= sbTY2% AND rawY% < sbTY2% + sbTH2% THEN
                ' Clicked on thumb — start scroll drag
                LAYER_PANEL.scrollDragging%   = TRUE
                LAYER_PANEL.scrollDragOffset% = rawY% - sbTY2%
            ELSE
                ' Clicked on track — jump to position
                DIM sbJmpPos AS SINGLE
                IF sbListH2% - sbTH2% > 0 THEN
                    sbJmpPos! = (rawY% - sbListTop2% - sbTH2% \ 2) / (sbListH2% - sbTH2%)
                    IF sbJmpPos! < 0 THEN sbJmpPos! = 0
                    IF sbJmpPos! > 1.0 THEN sbJmpPos! = 1.0
                    LAYER_PANEL.scrollOffset% = INT(sbJmpPos! * sbMaxScr2%)
                END IF
                INVALIDATE_scene
            END IF
            LAYER_PANEL_handle_click% = TRUE
            EXIT FUNCTION
        END IF
    END IF
    
    ' Check for button bar clicks
    DIM btnY       AS INTEGER
    DIM btnW       AS INTEGER
    DIM btnX       AS INTEGER
    DIM btnSpacing AS INTEGER
    
    btnY% = panelH% - THEME.LAYER_PANEL_btn_bar_height% + 1 ' Matches LAYER_PANEL_render
    DIM btnSlotH2 AS INTEGER: btnSlotH2% = THEME.LAYER_PANEL_btn_bar_height% - 1
    btnSpacing% = 2
    btnW%       = (panelW% - 8 - (5 * btnSpacing%)) \ 6
    
    IF rawY% >= btnY% AND rawY% < btnY% + btnSlotH2% AND button% = 1 THEN
        ' Determine which button was clicked
        DIM clickBtn AS INTEGER
        clickBtn% = -1
        btnX%     = 4

        ' Button 1: Move Up (^)
        IF localRawX% >= btnX% AND localRawX% < btnX% + btnW% THEN
            clickBtn% = 1
        END IF
        btnX% = btnX% + btnW% + btnSpacing%

        ' Button 2: Move Down (v)
        IF localRawX% >= btnX% AND localRawX% < btnX% + btnW% THEN
            clickBtn% = 2
        END IF
        btnX% = btnX% + btnW% + btnSpacing%

        ' Button 3: Merge Down (#)
        IF localRawX% >= btnX% AND localRawX% < btnX% + btnW% THEN
            clickBtn% = 3
        END IF
        btnX% = btnX% + btnW% + btnSpacing%

        ' Button 4: Delete (x)
        IF localRawX% >= btnX% AND localRawX% < btnX% + btnW% THEN
            clickBtn% = 4
        END IF
        btnX% = btnX% + btnW% + btnSpacing%

        ' Button 5: New (+)
        IF localRawX% >= btnX% AND localRawX% < btnX% + btnW% THEN
            clickBtn% = 5
        END IF
        btnX% = btnX% + btnW% + btnSpacing%

        ' Button 6: New Group (folder)
        IF localRawX% >= btnX% AND localRawX% < btnX% + btnW% THEN
            clickBtn% = 6
        END IF
        
        ' Execute button action (only if a button was actually clicked)
        IF clickBtn% > 0 THEN
            DIM btnShiftHeld AS INTEGER
            btnShiftHeld% = (_KEYDOWN(KEY_LSHIFT&) OR _KEYDOWN(KEY_RSHIFT&))
            SELECT CASE clickBtn%
                CASE 1 ' Move Up  |  SHIFT = Move to Top
                    IF CURRENT_LAYER% > 0 THEN
                        SOUND_play SND_LAYER_OP
                        IF btnShiftHeld% THEN
                            LAYERS_to_top CURRENT_LAYER%
                        ELSE
                            LAYERS_move_up CURRENT_LAYER%
                        END IF
                    END IF
                CASE 2 ' Move Down  |  SHIFT = Move to Bottom
                    IF CURRENT_LAYER% > 0 THEN
                        SOUND_play SND_LAYER_OP
                        IF btnShiftHeld% THEN
                            LAYERS_to_bottom CURRENT_LAYER%
                        ELSE
                            LAYERS_move_down CURRENT_LAYER%
                        END IF
                    END IF
                CASE 3 ' Merge Down  |  SHIFT = Flatten (Merge Visible)
                    IF CURRENT_LAYER% > 0 THEN
                        IF btnShiftHeld% THEN
                            LAYERS_merge_visible
                        ELSE
                            LAYERS_merge_down CURRENT_LAYER%
                        END IF
                    END IF
                CASE 4 ' Delete  |  SHIFT = Clear layer pixels (keep layer)
                    IF CURRENT_LAYER% > 0 THEN
                        IF btnShiftHeld% THEN
                            SOUND_play SND_LAYER_OP
                            LAYERS_clear CURRENT_LAYER%
                        ELSE
                            IF LAYER_COUNT% > 1 THEN CMD_execute_action 702
                        END IF
                    END IF
                CASE 5 ' New  |  SHIFT = New layer at top of stack
                    DIM dummy AS INTEGER
                    IF LAYER_COUNT% >= CFG.NUM_LAYERS% THEN
                        LAYERS_show_max_alert
                    ELSEIF btnShiftHeld% THEN
                        dummy% = LAYERS_new_at_top%
                    ELSE
                        dummy% = LAYERS_new%
                    END IF
                CASE 6 ' New Group  |  SHIFT = Group from multi-selection
                    IF LAYER_COUNT% >= CFG.NUM_LAYERS% THEN
                        LAYERS_show_max_alert
                    ELSEIF btnShiftHeld% THEN
                        IF MULTI_SELECT_has_any% THEN
                            SOUND_play SND_LAYER_OP
                            DIM grpFromSelIdx AS INTEGER
                            grpFromSelIdx% = LAYERS_group_from_selection%
                        END IF
                    ELSE
                        SOUND_play SND_LAYER_OP
                        DIM newGrpIdx AS INTEGER
                        newGrpIdx% = LAYERS_new_group%
                    END IF
            END SELECT
        END IF
        
        LAYER_PANEL_handle_click% = TRUE
        EXIT FUNCTION
    END IF
    
    ' Check for layer row clicks
    clickY% = rawY% + LAYER_PANEL.scrollOffset%
    rowY%   = 16 ' Start after header
    
    FOR z% = LAYER_COUNT% TO 1 STEP -1
        ' Find layer with this zIndex
        layerIdx% = 0
        FOR i% = 1 TO MAX_LAYERS
            IF LAYERS(i%).imgHandle& <> 0 AND LAYERS(i%).zIndex% = z% THEN
                layerIdx% = i%
                EXIT FOR
            END IF
        NEXT i%
        
        IF layerIdx% > 0 THEN
            ' Skip children of collapsed groups (walk ancestor chain — must match render loop)
            DIM clickParent       AS INTEGER
            DIM clickAncCollapsed AS INTEGER
            clickAncCollapsed% = FALSE
            clickParent%       = LAYERS(layerIdx%).parentGroupIdx%
            DIM clickWalkPar      AS INTEGER
            clickWalkPar% = clickParent%
            DO WHILE clickWalkPar% > 0
                IF clickWalkPar% < = MAX_LAYERS THEN
                    IF LAYERS(clickWalkPar%).imgHandle& <> 0 THEN
                        IF LAYERS(clickWalkPar%).collapsed% THEN
                            clickAncCollapsed% = TRUE
                            EXIT DO
                        END IF
                    END IF
                    clickWalkPar% = LAYERS(clickWalkPar%).parentGroupIdx%
                ELSE
                    EXIT DO
                END IF
            LOOP
            IF clickAncCollapsed% THEN _CONTINUE

            IF clickY% >= rowY% AND clickY% < rowY% + LAYER_ROW_HEIGHT THEN
                ' Clicked on this layer row
                DIM localX        AS INTEGER
                localX% = rawX% - LAYER_PANEL.panelX1%
                ' Offset for child indent so click zones match rendered icon positions
                DIM clickIndent   AS INTEGER
                DIM clickIndentPx AS INTEGER
                IF CFG.LAYER_GROUP_INDENT% > 0 THEN
                    clickIndentPx% = CFG.LAYER_GROUP_INDENT%
                ELSE
                    clickIndentPx% = THEME.LAYER_PANEL_group_indent%
                END IF
                clickIndent% = LAYERS_nesting_depth%(layerIdx%) * clickIndentPx%
                localX% = localX% - clickIndent%

                IF button% = 1 THEN
                    ' Check for Ctrl+click or Shift+click FIRST — always multi-select
                    ' regardless of which zone (triangle, eye, body) the click lands on
                    DIM ctrlHeld  AS INTEGER
                    DIM shiftHeld AS INTEGER
                    ctrlHeld%  = (_KEYDOWN(KEY_LCTRL&) OR _KEYDOWN(KEY_RCTRL&))
                    shiftHeld% = (_KEYDOWN(KEY_LSHIFT&) OR _KEYDOWN(KEY_RSHIFT&))
                    IF ctrlHeld% OR shiftHeld% THEN
                        IF ctrlHeld% AND LAYERS(layerIdx%).layerType% = LAYER_TYPE_GROUP THEN
                            ' Ctrl+Click on group header: add group + all descendants to multi-select
                            ' (Does NOT clear existing multi-select so cross-group selection works)
                            IF NOT MULTI_SELECT_LAYERS(layerIdx%) THEN
                                MULTI_SELECT_LAYERS(layerIdx%) = TRUE
                                MULTI_SELECT_COUNT% = MULTI_SELECT_COUNT% + 1
                            END IF
                            DIM msGrpI AS INTEGER
                            FOR msGrpI% = 1 TO MAX_LAYERS
                                IF LAYERS(msGrpI%).imgHandle& <> 0 AND msGrpI% <> layerIdx% THEN
                                    DIM msWalk AS INTEGER
                                    msWalk% = LAYERS(msGrpI%).parentGroupIdx%
                                    DO WHILE msWalk% > 0
                                        IF msWalk% = layerIdx% THEN
                                            IF NOT MULTI_SELECT_LAYERS(msGrpI%) THEN
                                                MULTI_SELECT_LAYERS(msGrpI%) = TRUE
                                                MULTI_SELECT_COUNT% = MULTI_SELECT_COUNT% + 1
                                            END IF
                                            EXIT DO
                                        END IF
                                        IF msWalk% < 1 OR msWalk% > MAX_LAYERS THEN EXIT DO
                                        IF LAYERS(msWalk%).imgHandle& = 0 THEN EXIT DO
                                        msWalk% = LAYERS(msWalk%).parentGroupIdx%
                                    LOOP
                                END IF
                            NEXT msGrpI%
                            GUI_NEEDS_REDRAW% = TRUE
                        ELSE
                            ' Toggle this layer in/out of multi-select without changing CURRENT_LAYER%
                            MULTI_SELECT_toggle layerIdx%
                        END IF
                    ELSEIF LAYERS(layerIdx%).layerType% = LAYER_TYPE_GROUP AND localX% < 13 THEN
                        ' Collapse/expand triangle click
                        LAYERS(layerIdx%).collapsed% = NOT LAYERS(layerIdx%).collapsed%
                        GUI_NEEDS_REDRAW%            = TRUE
                        FRAME_IDLE%                  = FALSE
                        SOUND_play SND_LAYER_OP
                    ELSEIF LAYERS(layerIdx%).layerType% = LAYER_TYPE_GROUP AND localX% < 24 THEN
                        ' Group header: eye/visibility zone (13-23)
                        DIM altHeld AS INTEGER
                        $IF MAC THEN
                            altHeld% = MAC_ALT_HELD%
                        $ELSE
                            altHeld% = (_KEYDOWN(KEY_LALT&) OR _KEYDOWN(KEY_RALT&))
                        $END IF
                        IF altHeld% THEN
                            ' Alt+click: solo/unsolo layer
                            IF LAYER_PANEL.soloLayer% = layerIdx% THEN
                                ' Unsolo: restore all saved visibility states
                                DIM ri AS INTEGER
                                FOR ri% = 1 TO MAX_LAYERS
                                    IF LAYERS(ri%).imgHandle& <> 0 THEN
                                        LAYERS(ri%).visible% = ASC(MID$(LAYER_PANEL.savedVisibility, ri%, 1))
                                    END IF
                                NEXT ri%
                                LAYER_PANEL.soloLayer% = 0
                                BLEND_invalidate_visibility 0
                            ELSE
                                ' Solo: save all states, hide all except clicked
                                DIM si AS INTEGER
                                FOR si% = 1 TO MAX_LAYERS
                                    IF LAYERS(si%).imgHandle& <> 0 THEN
                                        IF LAYERS(si%).visible% THEN
                                            MID$(LAYER_PANEL.savedVisibility, si%, 1) = CHR$(1)
                                        ELSE
                                            MID$(LAYER_PANEL.savedVisibility, si%, 1) = CHR$(0)
                                        END IF
                                        IF si% = layerIdx% THEN
                                            LAYERS(si%).visible% = TRUE
                                        ELSE
                                            LAYERS(si%).visible% = FALSE
                                        END IF
                                    END IF
                                NEXT si%
                                LAYER_PANEL.soloLayer% = layerIdx%
                                BLEND_invalidate_visibility 0
                            END IF
                            GUI_NEEDS_REDRAW% = TRUE
                        ELSE
                            ' Normal click: toggle visibility and start swipe
                            LAYERS_toggle_visibility layerIdx%
                            ' Clear solo mode if user manually toggles
                            LAYER_PANEL.soloLayer% = 0
                            ' Start visibility swipe — action matches what we just did
                            LAYER_PANEL.visSwiping%                         = TRUE
                            LAYER_PANEL.visSwipeAction%                     = LAYERS(layerIdx%).visible%
                            LAYER_PANEL.visSwipedLayers                     = STRING$(64, CHR$(0))
                            MID$(LAYER_PANEL.visSwipedLayers, layerIdx%, 1) = CHR$(1)
                        END IF
                    ELSEIF localX% < 14 THEN
                        ' Non-group layers: eye/visibility zone (0-13)
                        DIM altHeld2 AS INTEGER
                        $IF MAC THEN
                            altHeld2% = MAC_ALT_HELD%
                        $ELSE
                            altHeld2% = (_KEYDOWN(KEY_LALT&) OR _KEYDOWN(KEY_RALT&))
                        $END IF
                        IF altHeld2% THEN
                            ' Alt+click: solo/unsolo layer
                            IF LAYER_PANEL.soloLayer% = layerIdx% THEN
                                DIM ri2 AS INTEGER
                                FOR ri2% = 1 TO MAX_LAYERS
                                    IF LAYERS(ri2%).imgHandle& <> 0 THEN
                                        LAYERS(ri2%).visible% = ASC(MID$(LAYER_PANEL.savedVisibility, ri2%, 1))
                                    END IF
                                NEXT ri2%
                                LAYER_PANEL.soloLayer% = 0
                                BLEND_invalidate_visibility 0
                            ELSE
                                DIM si2 AS INTEGER
                                FOR si2% = 1 TO MAX_LAYERS
                                    IF LAYERS(si2%).imgHandle& <> 0 THEN
                                        IF LAYERS(si2%).visible% THEN
                                            MID$(LAYER_PANEL.savedVisibility, si2%, 1) = CHR$(1)
                                        ELSE
                                            MID$(LAYER_PANEL.savedVisibility, si2%, 1) = CHR$(0)
                                        END IF
                                        IF si2% = layerIdx% THEN
                                            LAYERS(si2%).visible% = TRUE
                                        ELSE
                                            LAYERS(si2%).visible% = FALSE
                                        END IF
                                    END IF
                                NEXT si2%
                                LAYER_PANEL.soloLayer% = layerIdx%
                                BLEND_invalidate_visibility 0
                            END IF
                            GUI_NEEDS_REDRAW% = TRUE
                        ELSE
                            ' Normal click: toggle visibility and start swipe
                            LAYERS_toggle_visibility layerIdx%
                            LAYER_PANEL.soloLayer%                          = 0
                            LAYER_PANEL.visSwiping%                         = TRUE
                            LAYER_PANEL.visSwipeAction%                     = LAYERS(layerIdx%).visible%
                            LAYER_PANEL.visSwipedLayers                     = STRING$(64, CHR$(0))
                            MID$(LAYER_PANEL.visSwipedLayers, layerIdx%, 1) = CHR$(1)
                        END IF
                    ELSEIF localX% < 24 THEN
                        ' Lock zone for non-group layers (14-23)
                        DIM ctrlHeldLk AS INTEGER
                        ctrlHeldLk% = (_KEYDOWN(KEY_LCTRL&) OR _KEYDOWN(KEY_RCTRL&))
                        IF ctrlHeldLk% THEN
                            LAYERS_select layerIdx%
                            LAYER_select_non_transparent layerIdx%
                        ELSE
                            LAYERS_toggle_opacity_lock layerIdx%
                        END IF
                    ' Check if clicking vertical opacity bar (3px wide at panelW%-15 to panelW%-13)
                    ELSEIF panelW% >= 80 AND localX% >= panelW% - 17 AND localX% < = panelW% - 11 THEN
                        ' Start vertical opacity drag (top=opaque, bottom=transparent)
                        SOUND_play SND_SLIDER
                        LAYER_PANEL.opacityDrag%      = TRUE
                        LAYER_PANEL.opacityDragLayer% = layerIdx%
                        LAYER_PANEL.opacityDragRowY%  = rowY% - LAYER_PANEL.scrollOffset%
                        DIM initBarY   AS INTEGER
                        initBarY% = rawY% - LAYER_PANEL.opacityDragRowY% - 2
                        IF initBarY% < 0 THEN initBarY% = 0
                        IF initBarY% > 14 THEN initBarY% = 14
                        LAYERS_set_opacity layerIdx%, 255 - INT((initBarY% / 14.0) * 255)
                    ELSE
                        ' Plain click on body: make this the current layer and start drag if eligible
                        ' Double-click: rename layer (triangle already handles group collapse)
                        IF TIMER - MOUSE.B1_CLICK_TIME# < 0.3 THEN
                            MOUSE.B1_CLICK_TIME# = 0                        ' Prevent triple-fire
                            IF MOVE.ACTIVE THEN MOVE_reset
                            LAYERS_select layerIdx%
                            LAYERS_rename layerIdx%
                        ELSE
                            ' Single click: select and start pending drag
                            MOUSE.B1_CLICK_TIME# = TIMER
                            ' Reset active move tool before switching layers to prevent segfault
                            IF MOVE.ACTIVE THEN MOVE_reset
                            LAYERS_select layerIdx%
                            ' Start PENDING drag - will only become active after moving 10+ pixels
                            LAYER_PANEL.dragPending%      = TRUE
                            LAYER_PANEL.isDragging%       = FALSE
                            LAYER_PANEL.dragLayerIdx%     = layerIdx%
                            LAYER_PANEL.dropTargetZIndex% = LAYERS(layerIdx%).zIndex%
                            LAYER_PANEL.dragStartX%       = rawX%
                            LAYER_PANEL.dragStartY%       = rawY%
                            LAYER_PANEL.dragOffsetY%      = clickY% - rowY% ' Offset within row
                            LAYER_PANEL.dragPreviewY%     = rawY%
                            LAYER_PANEL.autoScrollTimer!  = TIMER
                        END IF
                    END IF
                ELSEIF button% = 2 THEN
                    ' Right-click: show layer context menu
                    ' Preserve multi-selection if the right-clicked layer is part of it
                    IF NOT MULTI_SELECT_LAYERS(layerIdx%) THEN
                        LAYERS_select layerIdx%
                    ELSE
                        ' Switch current layer without clearing multi-select
                        CURRENT_LAYER% = layerIdx%
                    END IF
                    LAYER_PANEL_ctx_menu_show layerIdx%, rawX%, rawY%
                    GUI_NEEDS_REDRAW% = TRUE
                    FRAME_IDLE%       = FALSE
                END IF
                
                LAYER_PANEL_handle_click% = TRUE
                EXIT FUNCTION
            END IF
            
            rowY% = rowY% + LAYER_ROW_HEIGHT
        END IF
    NEXT z%
    
    LAYER_PANEL_handle_click% = TRUE ' Click was in panel, just not on anything specific
END FUNCTION


''
' Handle scrollbar thumb drag.
' Called every frame while scrollDragging% is TRUE and B1 is held.
' Recomputes scrollOffset from current mouse Y position.
' @param rawY INTEGER Raw screen Y coordinate of the mouse during drag
'
SUB LAYER_PANEL_handle_scroll_drag (rawY AS INTEGER)
    IF NOT LAYER_PANEL.scrollDragging% THEN EXIT SUB
    ' Compute the same geometry as LAYER_PANEL_render
    DIM sbBBH     AS INTEGER
    IF SCRN.showStatus% THEN
        sbBBH% = THEME.STATUS_height% + PALETTE_STRIP_get_height%
    ELSE
        sbBBH% = 0
    END IF
    DIM sbPanelH  AS INTEGER : sbPanelH% = SCRN.h& - sbBBH%
    DIM sbListTop AS INTEGER : sbListTop% = THEME.LAYER_PANEL_header_height%
    DIM sbListBot AS INTEGER : sbListBot% = sbPanelH% - THEME.LAYER_PANEL_btn_bar_height%
    DIM sbListH   AS INTEGER : sbListH% = sbListBot% - sbListTop%
    DIM sbTotalH  AS INTEGER : sbTotalH% = LAYER_PANEL_visible_row_count% * LAYER_ROW_HEIGHT
    DIM sbMaxScr  AS INTEGER : sbMaxScr% = sbTotalH% - sbListH%
    IF sbMaxScr% < 0 THEN sbMaxScr% = 0

    DIM sbTH AS INTEGER
    IF sbTotalH% > 0 THEN
        sbTH% = INT((sbListH% / sbTotalH%) * sbListH%)
    ELSE
        sbTH% = sbListH%
    END IF
    IF sbTH% < 20 THEN sbTH% = 20
    IF sbTH% > sbListH% THEN sbTH% = sbListH%

    ' Compute new thumb Y from drag position
    DIM sbNewY      AS INTEGER
    sbNewY% = rawY% - LAYER_PANEL.scrollDragOffset%
    IF sbNewY% < sbListTop% THEN sbNewY% = sbListTop%
    DIM sbMaxThumbY AS INTEGER: sbMaxThumbY% = sbListTop% + sbListH% - sbTH%
    IF sbNewY% > sbMaxThumbY% THEN sbNewY% = sbMaxThumbY%

    ' Convert thumb position to scroll offset
    DIM sbThumbRange AS INTEGER: sbThumbRange% = sbListH% - sbTH%
    IF sbThumbRange% > 0 THEN
        LAYER_PANEL.scrollOffset% = INT(((sbNewY% - sbListTop%) / sbThumbRange%) * sbMaxScr%)
    END IF
    IF LAYER_PANEL.scrollOffset% < 0 THEN LAYER_PANEL.scrollOffset% = 0
    IF LAYER_PANEL.scrollOffset% > sbMaxScr% THEN LAYER_PANEL.scrollOffset% = sbMaxScr%

    INVALIDATE_scene
END SUB


''
' Update opacity while dragging the vertical opacity slider.
' Called every frame while opacityDrag% is TRUE and B1 is held.
' Bar spans opacityDragRowY%+2 (top=opaque) to opacityDragRowY%+16 (bottom=transparent).
' @param rawX INTEGER Raw screen X coordinate (unused, vertical drag only)
' @param rawY INTEGER Raw screen Y coordinate used to compute new opacity
'
SUB LAYER_PANEL_handle_opacity_drag (rawX AS INTEGER, rawY AS INTEGER)
    rawX% = rawX% ' only vertical axis used for this drag
    IF NOT LAYER_PANEL.opacityDrag% THEN EXIT SUB
    DIM layerIdx AS INTEGER
    layerIdx% = LAYER_PANEL.opacityDragLayer%
    IF layerIdx% < 1 OR layerIdx% > MAX_LAYERS THEN EXIT SUB
    IF LAYERS(layerIdx%).imgHandle& >= -1 THEN EXIT SUB
    ' Vertical bar: top = fully opaque (255), bottom = transparent (0)
    DIM barY     AS INTEGER
    barY% = rawY% - LAYER_PANEL.opacityDragRowY% - 2
    IF barY% < 0 THEN barY% = 0
    IF barY% > 14 THEN barY% = 14
    LAYERS_set_opacity layerIdx%, 255 - INT((barY% / 14.0) * 255)
END SUB


''
' Handle mouse wheel in the layer panel.
' Also handles opacity adjustment when wheel is over opacity bar.
' @param rawX INTEGER Raw screen X coordinate of the mouse
' @param rawY INTEGER Raw screen Y coordinate of the mouse
' @param delta INTEGER Mouse wheel delta (negative=up, positive=down)
'
SUB LAYER_PANEL_handle_wheel (rawX AS INTEGER, rawY AS INTEGER, delta AS INTEGER)
    DIM panelW             AS INTEGER, panelH AS INTEGER
    DIM bottomBarsHeight   AS INTEGER
    DIM listTop            AS INTEGER, listBottom AS INTEGER
    DIM opacityBarX        AS INTEGER, opacityBarW AS INTEGER
    DIM rowY               AS INTEGER, i AS INTEGER, z AS INTEGER
    DIM layerIdx           AS INTEGER
    DIM HEADER_HEIGHT      AS INTEGER : HEADER_HEIGHT = THEME.LAYER_PANEL_header_height%
    DIM BUTTON_AREA_HEIGHT AS INTEGER : BUTTON_AREA_HEIGHT = THEME.LAYER_PANEL_btn_bar_height%
    
    IF NOT LAYER_PANEL.visible% THEN EXIT SUB
    
    ' Calculate panel dimensions (account for status bar visibility)
    IF SCRN.showStatus% THEN
        bottomBarsHeight% = THEME.STATUS_height% + PALETTE_STRIP_get_height%
    ELSE
        bottomBarsHeight% = 0
    END IF
    panelW%     = LAYER_PANEL.width%
    panelH%     = SCRN.h& - bottomBarsHeight%
    listTop%    = HEADER_HEIGHT
    listBottom% = panelH% - BUTTON_AREA_HEIGHT
    
    ' Vertical opacity bar is at panelW%-15 to panelW%-13 on right side of each row
    opacityBarX% = panelW% - 15
    opacityBarW% = 3
    
    ' Check if mouse is over a vertical opacity bar area (skip when panel too narrow)
    DIM wheelLocalX AS INTEGER
    wheelLocalX% = rawX% - LAYER_PANEL.panelX1%
    IF panelW% >= 80 AND wheelLocalX% >= panelW% - 17 AND wheelLocalX% < = panelW% - 11 THEN
        ' Find which layer row the mouse is over
        rowY% = listTop%
        FOR z% = LAYER_COUNT% TO 1 STEP -1
            layerIdx% = 0
            FOR i% = 1 TO MAX_LAYERS
                IF LAYERS(i%).imgHandle& <> 0 AND LAYERS(i%).zIndex% = z% THEN
                    layerIdx% = i%
                    EXIT FOR
                END IF
            NEXT i%
            
            IF layerIdx% > 0 THEN
                ' Skip children of collapsed groups
                DIM whlParent AS INTEGER
                whlParent% = LAYERS(layerIdx%).parentGroupIdx%
                IF whlParent% > 0 THEN
                    IF whlParent% < = MAX_LAYERS THEN
                        IF LAYERS(whlParent%).imgHandle& <> 0 THEN
                            IF LAYERS(whlParent%).collapsed% THEN _CONTINUE
                        END IF
                    END IF
                END IF

                DIM drawY AS INTEGER
                drawY% = rowY% - LAYER_PANEL.scrollOffset%
                
                ' Check if mouse Y is within this row's vertical opacity bar (drawY%+2 to drawY%+16)
                IF rawY% >= drawY% + 2 AND rawY% < = drawY% + 16 THEN
                    IF drawY% >= listTop% AND drawY% + LAYER_ROW_HEIGHT < = listBottom% THEN
                        ' Adjust opacity - wheel up (negative delta) = more opaque
                        DIM newOpacity AS INTEGER
                        newOpacity% = LAYERS(layerIdx%).opacity% - (delta% * 15) ' 15 per tick
                        IF newOpacity% < 0 THEN newOpacity% = 0
                        IF newOpacity% > 255 THEN newOpacity% = 255
                        LAYERS_set_opacity layerIdx%, newOpacity%
                        SOUND_play SND_SLIDER
                        EXIT SUB                                                 ' Handled opacity, don't scroll
                    END IF
                END IF
                
                rowY% = rowY% + LAYER_ROW_HEIGHT
            END IF
        NEXT z%
    END IF
    
    ' Not over opacity bar - scroll the layer list
    ' Reverse direction: wheel up (negative) = scroll up (see higher layers)
    LAYER_PANEL.scrollOffset% = LAYER_PANEL.scrollOffset% + (delta% * LAYER_ROW_HEIGHT)
    
    ' Clamp scroll offset
    IF LAYER_PANEL.scrollOffset% < 0 THEN LAYER_PANEL.scrollOffset% = 0
    
    DIM maxScroll  AS INTEGER
    DIM listHeight AS INTEGER
    listHeight% = listBottom% - listTop%
    maxScroll%  = (LAYER_PANEL_visible_row_count% * LAYER_ROW_HEIGHT) - listHeight%
    IF maxScroll% < 0 THEN maxScroll% = 0
    IF LAYER_PANEL.scrollOffset% > maxScroll% THEN LAYER_PANEL.scrollOffset% = maxScroll%
    
    GUI_NEEDS_REDRAW% = TRUE
END SUB

''
' Scroll the layer panel so that the given layer index is visible.
' Uses the same dimension math as LAYER_PANEL_handle_wheel.
' @param layerIdx INTEGER Index of the layer to scroll into view (1-64)
'
SUB LAYER_PANEL_scroll_to_layer (layerIdx AS INTEGER)
    IF layerIdx% < 1 OR layerIdx% > MAX_LAYERS THEN EXIT SUB
    IF NOT LAYER_PANEL.visible% THEN EXIT SUB
    DIM lpBottomBars AS INTEGER
    IF SCRN.showStatus% THEN
        lpBottomBars% = THEME.STATUS_height% + PALETTE_STRIP_get_height%
    ELSE
        lpBottomBars% = 0
    END IF
    DIM lpListTop    AS INTEGER : lpListTop% = THEME.LAYER_PANEL_header_height%
    DIM lpListBottom AS INTEGER : lpListBottom% = (SCRN.h& - lpBottomBars%) - THEME.LAYER_PANEL_btn_bar_height%
    DIM lpListH      AS INTEGER : lpListH% = lpListBottom% - lpListTop%
    IF lpListH% < = 0 THEN EXIT SUB
    DIM lpMaxScroll  AS INTEGER
    lpMaxScroll% = (LAYER_PANEL_visible_row_count% * LAYER_ROW_HEIGHT) - lpListH%
    IF lpMaxScroll% < 0 THEN lpMaxScroll% = 0
    ' Row position is based on zIndex (highest zIndex = top row in panel)
    DIM lpRowY       AS INTEGER: lpRowY% = (LAYER_COUNT% - LAYERS(layerIdx%).zIndex%) * LAYER_ROW_HEIGHT
    IF lpRowY% < LAYER_PANEL.scrollOffset% THEN
        LAYER_PANEL.scrollOffset% = lpRowY%
    ELSEIF lpRowY% + LAYER_ROW_HEIGHT > LAYER_PANEL.scrollOffset% + lpListH% THEN
        LAYER_PANEL.scrollOffset% = lpRowY% + LAYER_ROW_HEIGHT - lpListH%
    END IF
    IF LAYER_PANEL.scrollOffset% < 0 THEN LAYER_PANEL.scrollOffset% = 0
    IF LAYER_PANEL.scrollOffset% > lpMaxScroll% THEN LAYER_PANEL.scrollOffset% = lpMaxScroll%
END SUB

''
' Check if layer panel is currently in a drag operation
' @return INTEGER - TRUE if a layer drag is active or pending
' 
FUNCTION LAYER_PANEL_is_dragging% ()
    LAYER_PANEL_is_dragging% = LAYER_PANEL.isDragging% OR LAYER_PANEL.dragPending%
END FUNCTION


''
' Handle visibility swipe - apply show/hide to layers as mouse drags over eye icons
' @param rawX INTEGER Raw screen X coordinate of the mouse
' @param rawY INTEGER Raw screen Y coordinate of the mouse
'
SUB LAYER_PANEL_handle_vis_swipe (rawX AS INTEGER, rawY AS INTEGER)
    DIM panelW             AS INTEGER, panelH AS INTEGER
    DIM bottomBarsHeight   AS INTEGER
    DIM listTop            AS INTEGER, listBottom AS INTEGER
    DIM rowY               AS INTEGER
    DIM i                  AS INTEGER, z AS INTEGER
    DIM layerIdx           AS INTEGER
    DIM HEADER_HEIGHT      AS INTEGER : HEADER_HEIGHT = THEME.LAYER_PANEL_header_height%
    DIM BUTTON_AREA_HEIGHT AS INTEGER : BUTTON_AREA_HEIGHT = THEME.LAYER_PANEL_btn_bar_height%

    IF NOT LAYER_PANEL.visSwiping% THEN EXIT SUB
    IF NOT LAYER_PANEL.visible% THEN
        LAYER_PANEL.visSwiping% = FALSE
        EXIT SUB
    END IF

    ' Calculate panel layout
    IF SCRN.showStatus% THEN
        bottomBarsHeight% = THEME.STATUS_height% + PALETTE_STRIP_get_height%
    ELSE
        bottomBarsHeight% = 0
    END IF
    panelW%     = LAYER_PANEL.width%
    panelH%     = SCRN.h& - bottomBarsHeight%
    listTop%    = HEADER_HEIGHT
    listBottom% = panelH% - BUTTON_AREA_HEIGHT

    ' Only swipe if mouse is in the eye icon column (first 14 pixels)
    DIM swipeLocalX AS INTEGER
    swipeLocalX% = rawX% - LAYER_PANEL.panelX1%
    IF swipeLocalX% >= 14 THEN EXIT SUB

    ' Find which layer row the mouse is over
    DIM clickY AS INTEGER
    clickY% = rawY%
    rowY%   = listTop%

    FOR z% = LAYER_COUNT% TO 1 STEP -1
        layerIdx% = 0
        FOR i% = 1 TO MAX_LAYERS
            IF LAYERS(i%).imgHandle& <> 0 AND LAYERS(i%).zIndex% = z% THEN
                layerIdx% = i%
                EXIT FOR
            END IF
        NEXT i%

        IF layerIdx% > 0 THEN
            ' Skip children of collapsed groups (must match render loop)
            DIM swipeParent AS INTEGER
            swipeParent% = LAYERS(layerIdx%).parentGroupIdx%
            IF swipeParent% > 0 THEN
                IF swipeParent% < = MAX_LAYERS THEN
                    IF LAYERS(swipeParent%).imgHandle& <> 0 THEN
                        IF LAYERS(swipeParent%).collapsed% THEN _CONTINUE
                    END IF
                END IF
            END IF

            DIM drawY AS INTEGER
            drawY% = rowY% - LAYER_PANEL.scrollOffset%

            IF clickY% >= drawY% AND clickY% < drawY% + LAYER_ROW_HEIGHT THEN
                ' Mouse is over this layer row
                ' Only apply if not already swiped this layer
                IF ASC(MID$(LAYER_PANEL.visSwipedLayers, layerIdx%, 1)) = 0 THEN
                    ' Apply swipe action
                    IF LAYER_PANEL.visSwipeAction% THEN
                        LAYERS(layerIdx%).visible% = TRUE
                    ELSE
                        LAYERS(layerIdx%).visible% = FALSE
                    END IF
                    MID$(LAYER_PANEL.visSwipedLayers, layerIdx%, 1) = CHR$(1)
                    BLEND_invalidate_visibility layerIdx%
                    GUI_NEEDS_REDRAW% = TRUE
                END IF
                EXIT SUB
            END IF

            rowY% = rowY% + LAYER_ROW_HEIGHT
        END IF
    NEXT z%
END SUB


''
' End visibility swipe on mouse release
'
SUB LAYER_PANEL_end_vis_swipe ()
    LAYER_PANEL.visSwiping% = FALSE
END SUB


''
' Count the number of visible rows in the layer panel.
' Excludes children of collapsed groups.
' @return INTEGER  Number of visible layer rows
'
FUNCTION LAYER_PANEL_visible_row_count% ()
    DIM vrc AS INTEGER, vrcZ AS INTEGER, vrcI AS INTEGER, vrcIdx AS INTEGER
    vrc% = 0
    FOR vrcZ% = LAYER_COUNT% TO 1 STEP -1
        FOR vrcI% = 1 TO MAX_LAYERS
            IF LAYERS(vrcI%).imgHandle& <> 0 AND LAYERS(vrcI%).zIndex% = vrcZ% THEN
                vrcIdx% = vrcI%
                ' Walk ancestor chain to check for any collapsed ancestor
                DIM vrcCollapsed AS INTEGER
                vrcCollapsed% = FALSE
                DIM vrcWalk      AS INTEGER
                vrcWalk% = LAYERS(vrcIdx%).parentGroupIdx%
                DO WHILE vrcWalk% > 0
                    IF vrcWalk% < = MAX_LAYERS THEN
                        IF LAYERS(vrcWalk%).imgHandle& <> 0 THEN
                            IF LAYERS(vrcWalk%).collapsed% THEN
                                vrcCollapsed% = TRUE
                                EXIT DO
                            END IF
                        END IF
                        vrcWalk% = LAYERS(vrcWalk%).parentGroupIdx%
                    ELSE
                        EXIT DO
                    END IF
                LOOP
                IF vrcCollapsed% THEN EXIT FOR
                vrc% = vrc% + 1
                EXIT FOR
            END IF
        NEXT vrcI%
    NEXT vrcZ%
    LAYER_PANEL_visible_row_count% = vrc%
END FUNCTION


''
' Cancel any ongoing layer drag operation
' 
SUB LAYER_PANEL_drag_cancel ()
    LAYER_PANEL.dragPending%      = FALSE
    LAYER_PANEL.isDragging%       = FALSE
    LAYER_PANEL.dragLayerIdx%     = 0
    LAYER_PANEL.dropTargetZIndex% = -1
    LAYER_PANEL.dropOnButton%     = 0
    LAYER_PANEL.dragOffsetY%      = 0
    LAYER_PANEL.autoScrollTimer!  = 0
    LAYER_PANEL.dragPreviewY%     = 0
    LAYER_PANEL.dragStartX%       = 0
    LAYER_PANEL.dragStartY%       = 0
    GUI_NEEDS_REDRAW%             = TRUE
END SUB


''
' Handle mouse movement during layer drag operation
' Calculates drop target position, handles auto-scroll, and updates preview
' @param rawX INTEGER Raw screen X coordinate of the mouse
' @param rawY INTEGER Raw screen Y coordinate of the mouse
'
SUB LAYER_PANEL_handle_drag (rawX AS INTEGER, rawY AS INTEGER)
    DIM panelW             AS INTEGER, panelH AS INTEGER
    DIM bottomBarsHeight   AS INTEGER
    DIM listTop            AS INTEGER, listBottom AS INTEGER, listHeight AS INTEGER
    DIM targetZIndex       AS INTEGER
    DIM maxScroll          AS INTEGER
    DIM HEADER_HEIGHT      AS INTEGER : HEADER_HEIGHT = THEME.LAYER_PANEL_header_height%
    DIM BUTTON_AREA_HEIGHT AS INTEGER : BUTTON_AREA_HEIGHT = THEME.LAYER_PANEL_btn_bar_height%
    CONST AUTO_SCROLL_ZONE  = 30   ' Pixels from edge to trigger auto-scroll
    CONST AUTO_SCROLL_DELAY = 0.15 ' Seconds before auto-scroll starts
    CONST DRAG_THRESHOLD    = 5    ' Pixels of movement required to start drag
    
    ' Check if we have a pending drag that needs threshold check
    IF LAYER_PANEL.dragPending% THEN
        DIM dy AS INTEGER
        dy% = ABS(rawY% - LAYER_PANEL.dragStartY%) ' Only check vertical movement
        
        IF dy% >= DRAG_THRESHOLD THEN
            ' Threshold exceeded - activate real drag
            LAYER_PANEL.dragPending% = FALSE
            LAYER_PANEL.isDragging%  = TRUE
            ' Continue to process this drag event below
        ELSE
            ' Not enough movement yet - just exit, don't update anything
            EXIT SUB
        END IF
    END IF
    
    IF NOT LAYER_PANEL.isDragging% THEN EXIT SUB
    IF NOT LAYER_PANEL.visible% THEN
        LAYER_PANEL_drag_cancel
        EXIT SUB
    END IF
    
    ' Calculate panel dimensions
    IF SCRN.showStatus% THEN
        bottomBarsHeight% = THEME.STATUS_height% + PALETTE_STRIP_get_height%
    ELSE
        bottomBarsHeight% = 0
    END IF
    panelW%     = LAYER_PANEL.width%
    panelH%     = SCRN.h& - bottomBarsHeight%
    listTop%    = HEADER_HEIGHT
    listBottom% = panelH% - BUTTON_AREA_HEIGHT
    listHeight% = listBottom% - listTop%
    
    ' Update preview Y position (following mouse)
    LAYER_PANEL.dragPreviewY% = rawY%
    
    ' --- Auto-scroll logic ---
    DIM dragVisCount AS INTEGER
    dragVisCount% = LAYER_PANEL_visible_row_count%
    maxScroll%    = (dragVisCount% * LAYER_ROW_HEIGHT) - listHeight%
    IF maxScroll% < 0 THEN maxScroll% = 0
    
    IF rawY% < listTop% + AUTO_SCROLL_ZONE AND rawY% >= 0 THEN
        ' Near top edge - scroll up
        IF TIMER - LAYER_PANEL.autoScrollTimer! > AUTO_SCROLL_DELAY THEN
            IF LAYER_PANEL.scrollOffset% > 0 THEN
                LAYER_PANEL.scrollOffset% = LAYER_PANEL.scrollOffset% - LAYER_ROW_HEIGHT
                IF LAYER_PANEL.scrollOffset% < 0 THEN LAYER_PANEL.scrollOffset% = 0
                LAYER_PANEL.autoScrollTimer! = TIMER - (AUTO_SCROLL_DELAY * 0.7) ' Faster repeat
            END IF
        END IF
    ELSEIF rawY% > listBottom% - AUTO_SCROLL_ZONE AND rawY% < listBottom% THEN
        ' Near bottom edge - scroll down
        IF TIMER - LAYER_PANEL.autoScrollTimer! > AUTO_SCROLL_DELAY THEN
            IF LAYER_PANEL.scrollOffset% < maxScroll% THEN
                LAYER_PANEL.scrollOffset% = LAYER_PANEL.scrollOffset% + LAYER_ROW_HEIGHT
                IF LAYER_PANEL.scrollOffset% > maxScroll% THEN LAYER_PANEL.scrollOffset% = maxScroll%
                LAYER_PANEL.autoScrollTimer! = TIMER - (AUTO_SCROLL_DELAY * 0.7)
            END IF
        END IF
    ELSE
        ' Not in auto-scroll zone, reset timer
        LAYER_PANEL.autoScrollTimer! = TIMER
    END IF
    
    ' --- Calculate drop target zIndex based on mouse position ---
    ' Transform raw Y to content Y (accounting for scroll)
    DIM contentY AS INTEGER
    contentY% = rawY% + LAYER_PANEL.scrollOffset% - listTop%
    
    ' Find which row gap the mouse is closest to
    ' Layers are rendered from highest zIndex to lowest (top to bottom)
    ' So row 0 = layer with zIndex=LAYER_COUNT, row 1 = zIndex=LAYER_COUNT-1, etc.
    ' We want to find the GAP between rows, not the row itself
    ' Gap 0 = above topmost layer (insert at zIndex = LAYER_COUNT + 1, becomes top)
    ' Gap 1 = between layer at zIndex=LAYER_COUNT and zIndex=LAYER_COUNT-1
    ' Gap N = below bottommost layer (insert at zIndex = 1, becomes bottom)
    DIM closestGap AS INTEGER
    closestGap% = INT((contentY% + (LAYER_ROW_HEIGHT \ 2)) / LAYER_ROW_HEIGHT)
    
    ' Clamp gap to valid range (0 to visible row count)
    IF closestGap% < 0 THEN closestGap% = 0
    IF closestGap% > dragVisCount% THEN closestGap% = dragVisCount%
    
    ' Convert gap to target zIndex position by iterating visible rows
    ' Gap 0 = above topmost visible layer, Gap N = below bottommost visible layer
    ' Build mapping from visual position to actual zIndex
    DIM dragGapZ   AS INTEGER, dragGapI AS INTEGER, dragGapIdx AS INTEGER
    DIM dragVisRow AS INTEGER
    dragVisRow%   = 0
    targetZIndex% = 1 ' Default: bottom
    FOR dragGapZ% = LAYER_COUNT% TO 1 STEP -1
        FOR dragGapI% = 1 TO MAX_LAYERS
            IF LAYERS(dragGapI%).imgHandle& <> 0 AND LAYERS(dragGapI%).zIndex% = dragGapZ% THEN
                dragGapIdx% = dragGapI%
                ' Skip children of collapsed groups
                IF LAYERS(dragGapIdx%).parentGroupIdx% > 0 THEN
                    DIM dragGapP         AS INTEGER
                    dragGapP% = LAYERS(dragGapIdx%).parentGroupIdx%
                    DIM dragGapCollapsed AS INTEGER
                    dragGapCollapsed% = FALSE
                    IF dragGapP% > 0 THEN
                        IF dragGapP% < = MAX_LAYERS THEN
                            IF LAYERS(dragGapP%).imgHandle& <> 0 THEN
                                IF LAYERS(dragGapP%).collapsed% THEN dragGapCollapsed% = TRUE
                            END IF
                        END IF
                    END IF
                    IF dragGapCollapsed% THEN EXIT FOR
                END IF
                IF dragVisRow% >= closestGap% THEN
                    targetZIndex% = LAYERS(dragGapIdx%).zIndex%
                    GOTO DragGapFound
                END IF
                dragVisRow% = dragVisRow% + 1
                EXIT FOR
            END IF
        NEXT dragGapI%
    NEXT dragGapZ%
    DragGapFound:
    
    ' Clamp to valid final position range (1 to LAYER_COUNT)
    IF targetZIndex% < 1 THEN targetZIndex% = 1
    IF targetZIndex% > LAYER_COUNT% THEN targetZIndex% = LAYER_COUNT%
    
    ' Check if this is actually a no-op (same position)
    DIM draggedZ AS INTEGER
    draggedZ% = LAYERS(LAYER_PANEL.dragLayerIdx%).zIndex%
    
    ' --- Check if mouse is hovering over a drop-target button (Delete or New) ---
    DIM btnBarTop AS INTEGER
    btnBarTop% = listBottom%
    IF rawY% >= btnBarTop% THEN
        ' Mouse is over the button bar area - check which button slot
        DIM dragBtnW   AS INTEGER, dragBtnSpace AS INTEGER
        DIM dragLocalX AS INTEGER : dragLocalX% = rawX% - LAYER_PANEL.panelX1%
        dragBtnSpace% = 2
        dragBtnW%     = (panelW% - 8 - (5 * dragBtnSpace%)) \ 6
        DIM hoverBtn   AS INTEGER
        hoverBtn% = 0
        DIM bx         AS INTEGER
        bx% = 4
        ' Slot 1: Move Up (^)
        IF dragLocalX% >= bx% AND dragLocalX% < bx% + dragBtnW% THEN hoverBtn% = 1
        bx% = bx% + dragBtnW% + dragBtnSpace%
        ' Slot 2: Move Down (v)
        IF dragLocalX% >= bx% AND dragLocalX% < bx% + dragBtnW% THEN hoverBtn% = 2
        bx% = bx% + dragBtnW% + dragBtnSpace%
        ' Slot 3: Merge Down (#)
        IF dragLocalX% >= bx% AND dragLocalX% < bx% + dragBtnW% THEN hoverBtn% = 3
        bx% = bx% + dragBtnW% + dragBtnSpace%
        ' Slot 4: Delete (x)
        IF dragLocalX% >= bx% AND dragLocalX% < bx% + dragBtnW% THEN hoverBtn% = 4
        bx% = bx% + dragBtnW% + dragBtnSpace%
        ' Slot 5: New (+)
        IF dragLocalX% >= bx% AND dragLocalX% < bx% + dragBtnW% THEN hoverBtn% = 5
        bx% = bx% + dragBtnW% + dragBtnSpace%
        ' Slot 6: New Group (folder)
        IF dragLocalX% >= bx% AND dragLocalX% < bx% + dragBtnW% THEN hoverBtn% = 6

        IF hoverBtn% = 4 OR hoverBtn% = 5 OR hoverBtn% = 6 THEN
            LAYER_PANEL.dropOnButton%     = hoverBtn%
            LAYER_PANEL.dropTargetZIndex% = -1 ' Suppress normal reorder indicator
        ELSE
            LAYER_PANEL.dropOnButton% = 0
            ' Normal reorder logic when over other buttons or non-target area
            IF targetZIndex% = draggedZ% THEN
                LAYER_PANEL.dropTargetZIndex% = -1
            ELSE
                LAYER_PANEL.dropTargetZIndex% = targetZIndex%
            END IF
        END IF
    ELSE
        LAYER_PANEL.dropOnButton% = 0
        ' Only show as "no change" if layer would stay in same position
        IF targetZIndex% = draggedZ% THEN
            ' Already at target position - no visual indicator needed
            LAYER_PANEL.dropTargetZIndex% = -1
        ELSE
            LAYER_PANEL.dropTargetZIndex% = targetZIndex%
        END IF
    END IF
    GUI_NEEDS_REDRAW% = TRUE
END SUB


''
' Handle drop when mouse is released during layer drag
' Moves the layer to the new position
' 
SUB LAYER_PANEL_handle_drop ()
    DIM draggedIdx AS INTEGER
    DIM draggedZ   AS INTEGER
    DIM targetZ    AS INTEGER
    DIM i          AS INTEGER
    
    ' Always cancel pending drag on mouse release, even if not actively dragging
    IF NOT LAYER_PANEL.isDragging% THEN
        LAYER_PANEL_drag_cancel
        EXIT SUB
    END IF
    
    draggedIdx% = LAYER_PANEL.dragLayerIdx%
    draggedZ%   = LAYERS(draggedIdx%).zIndex%
    targetZ%    = LAYER_PANEL.dropTargetZIndex%
    
    ' --- Handle drag-to-button actions (single layer only) ---
    IF LAYER_PANEL.dropOnButton% = 4 THEN
        ' Dragged onto Delete button: delete selected layers (or dragged layer)
        IF LAYER_COUNT% > 1 THEN
            IF MULTI_SELECT_has_any% THEN
                CMD_execute_action 702
            ELSE
                SOUND_play SND_LAYER_OP
                LAYERS_delete draggedIdx%
            END IF
        END IF
        LAYER_PANEL_drag_cancel
        EXIT SUB
    ELSEIF LAYER_PANEL.dropOnButton% = 5 THEN
        ' Dragged onto New Layer button: duplicate the dragged layer above current
        IF LAYER_COUNT% >= CFG.NUM_LAYERS% THEN
            LAYERS_show_max_alert
        ELSE
            SOUND_play SND_LAYER_OP
            LAYERS_select draggedIdx%
            LAYERS_duplicate draggedIdx%
        END IF
        LAYER_PANEL_drag_cancel
        EXIT SUB
    ELSEIF LAYER_PANEL.dropOnButton% = 6 THEN
        ' Dragged onto New Group button: create group from multi-selection or dragged layer
        IF LAYER_COUNT% >= CFG.NUM_LAYERS% THEN
            LAYERS_show_max_alert
        ELSE
            SOUND_play SND_LAYER_OP
            IF MULTI_SELECT_has_any% THEN
                ' Group all multi-selected layers
                DIM grpDropIdx    AS INTEGER
                grpDropIdx% = LAYERS_group_from_selection%
            ELSE
                ' Group just the dragged layer — select it then group from selection
                LAYERS_select draggedIdx%
                DIM grpDropSingle AS INTEGER
                grpDropSingle% = LAYERS_group_from_selection%
            END IF
        END IF
        LAYER_PANEL_drag_cancel
        EXIT SUB
    END IF
    
    ' --- Handle drag onto group header: move into group ---
    IF targetZ% >= 1 AND targetZ% < = LAYER_COUNT% AND targetZ% <> draggedZ% THEN
        DIM dropTargetIdx AS INTEGER
        dropTargetIdx% = 0
        DIM dti           AS INTEGER
        FOR dti% = 1 TO MAX_LAYERS
            IF LAYERS(dti%).imgHandle& <> 0 AND LAYERS(dti%).zIndex% = targetZ% THEN
                dropTargetIdx% = dti%
                EXIT FOR
            END IF
        NEXT dti%
        IF dropTargetIdx% > 0 THEN
            ' Determine the group to move into:
            ' If target IS a group header, use it directly.
            ' If target is a child of a group, use its parent group.
            DIM dropGroupIdx AS INTEGER
            dropGroupIdx% = 0
            IF LAYERS(dropTargetIdx%).layerType% = LAYER_TYPE_GROUP THEN
                dropGroupIdx% = dropTargetIdx%
            ELSEIF LAYERS(dropTargetIdx%).parentGroupIdx% > 0 THEN
                DIM dtpg AS INTEGER
                dtpg% = LAYERS(dropTargetIdx%).parentGroupIdx%
                IF dtpg% >= 1 AND dtpg% < = MAX_LAYERS THEN
                    IF LAYERS(dtpg%).imgHandle& <> 0 THEN
                        IF LAYERS(dtpg%).layerType% = LAYER_TYPE_GROUP THEN
                            dropGroupIdx% = dtpg%
                        END IF
                    END IF
                END IF
            END IF
            IF dropGroupIdx% > 0 THEN
                IF LAYERS(draggedIdx%).parentGroupIdx% <> dropGroupIdx% THEN
                    IF draggedIdx% <> dropGroupIdx% THEN
                        ' Move layer (or group) into this group
                        LAYERS_move_into_group draggedIdx%, dropGroupIdx%
                        SOUND_play SND_DRAG_DROP
                        LAYER_PANEL_drag_cancel
                        EXIT SUB
                    END IF
                END IF
            END IF
        END IF
    END IF

    ' --- Handle drag out of group: if layer is in a group and dropped outside it ---
    IF LAYERS(draggedIdx%).parentGroupIdx% > 0 THEN
        IF targetZ% >= 1 AND targetZ% < = LAYER_COUNT% AND targetZ% <> draggedZ% THEN
            ' Check if drop target is outside the current group
            DIM dropOutTarget AS INTEGER
            dropOutTarget% = 0
            DIM doi           AS INTEGER
            FOR doi% = 1 TO MAX_LAYERS
                IF LAYERS(doi%).imgHandle& <> 0 AND LAYERS(doi%).zIndex% = targetZ% THEN
                    dropOutTarget% = doi%
                    EXIT FOR
                END IF
            NEXT doi%
            DIM outsideGroup  AS INTEGER
            outsideGroup% = TRUE
            IF dropOutTarget% > 0 THEN
                ' If target is the group header itself or another child of the same group, stay in group
                IF dropOutTarget% = LAYERS(draggedIdx%).parentGroupIdx% THEN outsideGroup% = FALSE
                IF LAYERS(dropOutTarget%).parentGroupIdx% = LAYERS(draggedIdx%).parentGroupIdx% THEN outsideGroup% = FALSE
            END IF
            IF outsideGroup% THEN
                LAYERS_move_out_of_group draggedIdx%
                ' Now also reorder to the user's actual target position
                ' (move_out_of_group places above group header, but user may want elsewhere)
                DIM moogNewZ AS INTEGER
                moogNewZ% = LAYERS(draggedIdx%).zIndex%
                IF targetZ% <> moogNewZ% AND targetZ% >= 1 AND targetZ% < = LAYER_COUNT% THEN
                    IF targetZ% > moogNewZ% THEN
                        FOR i% = 1 TO MAX_LAYERS
                            IF LAYERS(i%).imgHandle& <> 0 AND i% <> draggedIdx% THEN
                                IF LAYERS(i%).zIndex% > moogNewZ% AND LAYERS(i%).zIndex% < = targetZ% THEN
                                    LAYERS(i%).zIndex% = LAYERS(i%).zIndex% - 1
                                END IF
                            END IF
                        NEXT i%
                        LAYERS(draggedIdx%).zIndex% = targetZ%
                    ELSE
                        FOR i% = 1 TO MAX_LAYERS
                            IF LAYERS(i%).imgHandle& <> 0 AND i% <> draggedIdx% THEN
                                IF LAYERS(i%).zIndex% >= targetZ% AND LAYERS(i%).zIndex% < moogNewZ% THEN
                                    LAYERS(i%).zIndex% = LAYERS(i%).zIndex% + 1
                                END IF
                            END IF
                        NEXT i%
                        LAYERS(draggedIdx%).zIndex% = targetZ%
                    END IF
                    LAYERS_enforce_group_contiguity
                END IF
                SOUND_play SND_DRAG_DROP
                LAYER_PANEL_drag_cancel
                EXIT SUB
            END IF
        END IF
    END IF

    ' Only move if we have a valid target and it's different from current position
    IF targetZ% >= 1 AND targetZ% < = LAYER_COUNT% AND targetZ% <> draggedZ% THEN
        ' Check if dragging a group header — need to move the whole block
        DIM isDragGroup AS INTEGER
        isDragGroup% = (LAYERS(draggedIdx%).layerType% = LAYER_TYPE_GROUP)

        IF isDragGroup% THEN
            ' Group drag: collect children, compute block size
            DIM grpChildCount AS INTEGER
            grpChildCount% = 0
            DIM gci           AS INTEGER
            FOR gci% = 1 TO MAX_LAYERS
                IF LAYERS(gci%).imgHandle& <> 0 THEN
                    IF LAYERS(gci%).parentGroupIdx% = draggedIdx% THEN
                        grpChildCount% = grpChildCount% + 1
                    END IF
                END IF
            NEXT gci%
            DIM blockSize     AS INTEGER
            blockSize% = 1 + grpChildCount%
            ' The block occupies draggedZ%-grpChildCount% .. draggedZ%
            ' (children below header, contiguous from enforce_group_contiguity)
            DIM blockLow      AS INTEGER
            blockLow% = draggedZ% - grpChildCount%

            ' Determine effective target: where the header should end up
            ' If moving up, the header goes to targetZ%
            ' If moving down, the header goes to targetZ% + grpChildCount%
            ' (because children will be placed below the header)
            DIM effectiveTarget AS INTEGER
            IF targetZ% > draggedZ% THEN
                effectiveTarget% = targetZ%
            ELSE
                effectiveTarget% = targetZ% + grpChildCount%
            END IF
            IF effectiveTarget% < blockSize% THEN effectiveTarget% = blockSize%
            IF effectiveTarget% > LAYER_COUNT% THEN effectiveTarget% = LAYER_COUNT%

            ' Remove the block from z-order: shift other layers to fill the gap
            FOR i% = 1 TO MAX_LAYERS
                IF LAYERS(i%).imgHandle& <> 0 THEN
                    IF LAYERS(i%).parentGroupIdx% <> draggedIdx% AND i% <> draggedIdx% THEN
                        IF LAYERS(i%).zIndex% > draggedZ% THEN
                            LAYERS(i%).zIndex% = LAYERS(i%).zIndex% - blockSize%
                        END IF
                    END IF
                END IF
            NEXT i%

            ' Now the non-block layers occupy 1..(LAYER_COUNT%-blockSize%)
            ' Make room at the target position for the block
            DIM insertAt   AS INTEGER
            insertAt% = effectiveTarget% - blockSize% + 1
            ' Adjust insertAt for the compacted range
            DIM compactMax AS INTEGER
            compactMax% = LAYER_COUNT% - blockSize%
            IF insertAt% > compactMax% + 1 THEN insertAt% = compactMax% + 1
            IF insertAt% < 1 THEN insertAt% = 1

            FOR i% = 1 TO MAX_LAYERS
                IF LAYERS(i%).imgHandle& <> 0 THEN
                    IF LAYERS(i%).parentGroupIdx% <> draggedIdx% AND i% <> draggedIdx% THEN
                        IF LAYERS(i%).zIndex% >= insertAt% THEN
                            LAYERS(i%).zIndex% = LAYERS(i%).zIndex% + blockSize%
                        END IF
                    END IF
                END IF
            NEXT i%

            ' Place the header at the top of the block
            LAYERS(draggedIdx%).zIndex% = insertAt% + grpChildCount%

            ' Let enforce_group_contiguity place children correctly
            LAYERS_enforce_group_contiguity
        ELSE
            ' Single layer move (non-group)
            IF targetZ% > draggedZ% THEN
                ' Moving up (towards higher zIndex / top of list)
                ' Shift layers between old and new position DOWN by 1
                FOR i% = 1 TO MAX_LAYERS
                    IF LAYERS(i%).imgHandle& <> 0 AND i% <> draggedIdx% THEN
                        IF LAYERS(i%).zIndex% > draggedZ% AND LAYERS(i%).zIndex% < = targetZ% THEN
                            LAYERS(i%).zIndex% = LAYERS(i%).zIndex% - 1
                        END IF
                    END IF
                NEXT i%
                LAYERS(draggedIdx%).zIndex% = targetZ%
            ELSE
                ' Moving down (towards lower zIndex / bottom of list)
                ' Shift layers between new and old position UP by 1
                FOR i% = 1 TO MAX_LAYERS
                    IF LAYERS(i%).imgHandle& <> 0 AND i% <> draggedIdx% THEN
                        IF LAYERS(i%).zIndex% >= targetZ% AND LAYERS(i%).zIndex% < draggedZ% THEN
                            LAYERS(i%).zIndex% = LAYERS(i%).zIndex% + 1
                        END IF
                    END IF
                NEXT i%
                LAYERS(draggedIdx%).zIndex% = targetZ%
            END IF

            ' Auto-grouping: if the layer landed in a group's child z-range, adopt it
            ' If the layer was in a group but now outside, remove from group
            DIM autoGrpIdx AS INTEGER
            autoGrpIdx% = 0
            DIM agZ        AS INTEGER
            agZ% = LAYERS(draggedIdx%).zIndex%
            ' Check each group: children occupy z-indices just below the header
            DIM agI        AS INTEGER
            FOR agI% = 1 TO MAX_LAYERS
                IF LAYERS(agI%).imgHandle& <> 0 THEN
                    IF LAYERS(agI%).layerType% = LAYER_TYPE_GROUP AND agI% <> draggedIdx% THEN
                        DIM agHeaderZ AS INTEGER
                        agHeaderZ% = LAYERS(agI%).zIndex%
                        ' Find the lowest child z of this group
                        DIM agLowestZ AS INTEGER
                        agLowestZ% = agHeaderZ% ' Default: no children yet
                        DIM agJ       AS INTEGER
                        FOR agJ% = 1 TO MAX_LAYERS
                            IF LAYERS(agJ%).imgHandle& <> 0 AND agJ% <> draggedIdx% THEN
                                IF LAYERS(agJ%).parentGroupIdx% = agI% THEN
                                    IF LAYERS(agJ%).zIndex% < agLowestZ% THEN
                                        agLowestZ% = LAYERS(agJ%).zIndex%
                                    END IF
                                END IF
                            END IF
                        NEXT agJ%
                        ' Layer is in group range if its z is between lowestChild and header-1
                        IF agZ% >= agLowestZ% AND agZ% < agHeaderZ% THEN
                            autoGrpIdx% = agI%
                            EXIT FOR
                        END IF
                    END IF
                END IF
            NEXT agI%

            IF autoGrpIdx% > 0 THEN
                ' Layer landed inside a group — adopt it
                IF LAYERS(draggedIdx%).parentGroupIdx% <> autoGrpIdx% THEN
                    LAYERS(draggedIdx%).parentGroupIdx% = autoGrpIdx%
                    LAYERS_enforce_group_contiguity
                END IF
            ELSE
                ' Layer landed outside any group — clear parent if it had one
                IF LAYERS(draggedIdx%).parentGroupIdx% > 0 THEN
                    LAYERS(draggedIdx%).parentGroupIdx% = 0
                    LAYERS_enforce_group_contiguity
                END IF
            END IF
        END IF
    END IF
    
    ' End drag operation
    IF targetZ% >= 1 AND targetZ% < = LAYER_COUNT% AND targetZ% <> draggedZ% THEN
        IF NOT HISTORY_IN_PROGRESS% THEN
            HISTORY_record_layer_reorder LAYERS(draggedIdx%).historyId&, draggedIdx%, draggedZ%, targetZ%, "Layer Reorder"
        END IF
        SOUND_play SND_DRAG_DROP
    END IF
    BLEND_invalidate_cache
    GUI_NEEDS_REDRAW% = TRUE
    LAYER_PANEL_drag_cancel
END SUB


''
' Load layer panel icons from theme directory
' Falls back to text rendering if PNGs are missing
' Must be called after CONFIG_load so CFG.THEME$ is available
'
SUB LAYER_PANEL_load_icons ()
    DIM themeDir AS STRING
    themeDir$ = "ASSETS/THEMES/" + _TRIM$(CFG.THEME$) + "/"

    ' Free any previously loaded icons
    LAYER_PANEL_cleanup_icons

    ' Load row icons (visibility toggle)
    LAYER_PANEL.iconVisOn&  = _LOADIMAGE(themeDir$ + "IMAGES/LAYERS/layer-icon-visibility-on.png", 32)
    LAYER_PANEL.iconVisOff& = _LOADIMAGE(themeDir$ + "IMAGES/LAYERS/layer-icon-visibility-off.png", 32)

    ' Load row icons (opacity lock)
    LAYER_PANEL.iconLockOn&  = _LOADIMAGE(themeDir$ + "IMAGES/LAYERS/layer-icon-lock-on.png", 32)
    LAYER_PANEL.iconLockOff& = _LOADIMAGE(themeDir$ + "IMAGES/LAYERS/layer-icon-lock-off.png", 32)

    ' Load bottom button icons
    LAYER_PANEL.iconBtnUp&     = _LOADIMAGE(themeDir$ + "IMAGES/LAYERS/layer-btn-up.png", 32)
    LAYER_PANEL.iconBtnDown&   = _LOADIMAGE(themeDir$ + "IMAGES/LAYERS/layer-btn-down.png", 32)
    LAYER_PANEL.iconBtnMerge&  = _LOADIMAGE(themeDir$ + "IMAGES/LAYERS/layer-btn-merge.png", 32)
    LAYER_PANEL.iconBtnDelete& = _LOADIMAGE(themeDir$ + "IMAGES/LAYERS/layer-btn-delete.png", 32)
    LAYER_PANEL.iconBtnAdd&    = _LOADIMAGE(themeDir$ + "IMAGES/LAYERS/layer-btn-add.png", 32)
    LAYER_PANEL.iconBtnGroup&  = _LOADIMAGE(themeDir$ + "IMAGES/LAYERS/layer-btn-group.png", 32)
END SUB


''
' Free all loaded layer panel icon image handles
'
SUB LAYER_PANEL_cleanup_icons ()
    IF LAYER_PANEL.iconVisOn&    < -1 THEN _FREEIMAGE LAYER_PANEL.iconVisOn&
    IF LAYER_PANEL.iconVisOff&   < -1 THEN _FREEIMAGE LAYER_PANEL.iconVisOff&
    IF LAYER_PANEL.iconLockOn&   < -1 THEN _FREEIMAGE LAYER_PANEL.iconLockOn&
    IF LAYER_PANEL.iconLockOff&  < -1 THEN _FREEIMAGE LAYER_PANEL.iconLockOff&
    IF LAYER_PANEL.iconBtnUp&     < -1 THEN _FREEIMAGE LAYER_PANEL.iconBtnUp&
    IF LAYER_PANEL.iconBtnDown&   < -1 THEN _FREEIMAGE LAYER_PANEL.iconBtnDown&
    IF LAYER_PANEL.iconBtnMerge&  < -1 THEN _FREEIMAGE LAYER_PANEL.iconBtnMerge&
    IF LAYER_PANEL.iconBtnDelete& < -1 THEN _FREEIMAGE LAYER_PANEL.iconBtnDelete&
    IF LAYER_PANEL.iconBtnAdd&    < -1 THEN _FREEIMAGE LAYER_PANEL.iconBtnAdd&
    IF LAYER_PANEL.iconBtnGroup&  < -1 THEN _FREEIMAGE LAYER_PANEL.iconBtnGroup&
    LAYER_PANEL.iconVisOn&     = 0
    LAYER_PANEL.iconVisOff&    = 0
    LAYER_PANEL.iconLockOn&    = 0
    LAYER_PANEL.iconLockOff&   = 0
    LAYER_PANEL.iconBtnUp&     = 0
    LAYER_PANEL.iconBtnDown&   = 0
    LAYER_PANEL.iconBtnMerge&  = 0
    LAYER_PANEL.iconBtnDelete& = 0
    LAYER_PANEL.iconBtnAdd&    = 0
    LAYER_PANEL.iconBtnGroup&  = 0
END SUB


''
' Create a marquee selection from non-transparent pixels of a layer
' CTRL+Left-Click on a layer in the panel calls this.
' Replaces any existing selection.
'
' @param layerIdx INTEGER - Layer index to scan
'
SUB LAYER_select_non_transparent (layerIdx AS INTEGER)
    DIM old_dest    AS LONG, old_source AS LONG
    DIM imgHandle   AS LONG
    DIM w           AS INTEGER, h AS INTEGER
    DIM px          AS INTEGER, py AS INTEGER
    DIM minX        AS INTEGER, minY AS INTEGER, maxX AS INTEGER, maxY AS INTEGER
    DIM mask_color  AS _UNSIGNED LONG
    DIM pixel_color AS _UNSIGNED LONG
    DIM found_any   AS INTEGER
    DIM aW          AS INTEGER, aH AS INTEGER

    ' Validate layer
    IF layerIdx% < 1 OR layerIdx% > MAX_LAYERS THEN EXIT SUB
    imgHandle& = LAYERS(layerIdx%).imgHandle&
    IF imgHandle& = 0 THEN EXIT SUB

    old_dest&    = _DEST
    old_source&  = _SOURCE
    mask_color~& = _RGB32(255, 255, 255)

    ' APRON: scan only the canvas region (offset by apronW/apronH) and produce
    ' a canvas-sized mask in canvas coordinates. Apron pixels are intentionally
    ' excluded — selection is always defined in canvas space.
    aW% = LAYERS(layerIdx%).apronW%
    aH% = LAYERS(layerIdx%).apronH%
    w%  = SCRN.canvasW&
    h%  = SCRN.canvasH&

    ' Clear any existing selection
    MARQUEE_reset
    MAGIC_WAND_reset
    IF MARQUEE.SELECTION_MASK < -1 THEN
        _FREEIMAGE MARQUEE.SELECTION_MASK
        MARQUEE.SELECTION_MASK = 0
    END IF

    ' Create new selection mask (canvas-sized)
    MARQUEE.SELECTION_MASK = _NEWIMAGE(w%, h%, 32)
    IF MARQUEE.SELECTION_MASK >= -1 THEN
        _DEST old_dest&
        _SOURCE old_source&
        EXIT SUB
    END IF

    ' Clear mask to transparent
    _DEST MARQUEE.SELECTION_MASK
    CLS , _RGBA32(0, 0, 0, 0)
    _DONTBLEND MARQUEE.SELECTION_MASK

    ' Scan layer image (canvas region only) and mark non-transparent pixels
    _SOURCE imgHandle&
    minX%      = w%: minY% = h%: maxX% = 0: maxY% = 0
    found_any% = FALSE

    FOR py% = 0 TO h% - 1
        FOR px% = 0 TO w% - 1
            pixel_color~& = POINT(px% + aW%, py% + aH%)
            IF _ALPHA32(pixel_color~&) > 0 THEN
                _DEST MARQUEE.SELECTION_MASK
                PSET (px%, py%), mask_color~&
                IF px% < minX% THEN minX% = px%
                IF px% > maxX% THEN maxX% = px%
                IF py% < minY% THEN minY% = py%
                IF py% > maxY% THEN maxY% = py%
                found_any% = TRUE
                _SOURCE imgHandle&
            END IF
        NEXT px%
    NEXT py%

    _BLEND MARQUEE.SELECTION_MASK
    
    IF found_any% THEN
        ' Set up marquee bounding box from mask bounds
        MARQUEE.WAND_MIN_X         = minX%
        MARQUEE.WAND_MIN_Y         = minY%
        MARQUEE.WAND_MAX_X         = maxX%
        MARQUEE.WAND_MAX_Y         = maxY%
        MARQUEE.BOX.x              = minX%
        MARQUEE.BOX.y              = minY%
        MARQUEE.BOX.w              = maxX% - minX% + 1
        MARQUEE.BOX.h              = maxY% - minY% + 1
        MARQUEE.ACTIVE%            = TRUE
        MARQUEE.INITIALIZED%       = TRUE
        MARQUEE.USER_CREATED       = TRUE
        MARQUEE.WAND_HAS_SELECTION = TRUE
        
        ' Initialize bounding box for the selection
        MARQUEE.CFG.initX = minX%
        MARQUEE.CFG.initY = minY%
        MARQUEE.CFG.initW = maxX% - minX% + 1
        MARQUEE.CFG.initH = maxY% - minY% + 1
        MARQUEE.BOX.x     = MARQUEE.CFG.initX
        MARQUEE.BOX.y     = MARQUEE.CFG.initY
        MARQUEE.BOX.w     = MARQUEE.CFG.initW
        MARQUEE.BOX.h     = MARQUEE.CFG.initH
        MARQUEE.BOX.state = MARQUEE_STATE_IDLE
        
        ' Switch to marquee tool so the selection is visible and usable
        PREVIOUS_TOOL%          = CURRENT_TOOL%
        CURRENT_TOOL%           = TOOL_MARQUEE
        MARQUEE.MAGIC_WAND_MODE = FALSE
    ELSE
        ' No non-transparent pixels found - clean up
        IF MARQUEE.SELECTION_MASK < -1 THEN
            _FREEIMAGE MARQUEE.SELECTION_MASK
            MARQUEE.SELECTION_MASK = 0
        END IF
    END IF
    
    GUI_NEEDS_REDRAW% = TRUE
    _DEST old_dest&
    _SOURCE old_source&
END SUB


''
' Return full name of a blend mode
' @param mode INTEGER Blend mode constant (BLEND_NORMAL, BLEND_MULTIPLY, etc.)
' @return STRING - Display name of the blend mode (e.g. "MULTIPLY")
'
FUNCTION BLEND_mode_name$ (mode AS INTEGER)
    SELECT CASE mode%
        CASE BLEND_PASS_THROUGH : BLEND_mode_name$ = "PASS THROUGH"
        CASE BLEND_NORMAL       : BLEND_mode_name$ = "NORMAL"
        CASE BLEND_MULTIPLY     : BLEND_mode_name$ = "MULTIPLY"
        CASE BLEND_SCREEN       : BLEND_mode_name$ = "SCREEN"
        CASE BLEND_OVERLAY      : BLEND_mode_name$ = "OVERLAY"
        CASE BLEND_ADD          : BLEND_mode_name$ = "ADD"
        CASE BLEND_SUBTRACT     : BLEND_mode_name$ = "SUBTRACT"
        CASE BLEND_DIFFERENCE   : BLEND_mode_name$ = "DIFFERENCE"
        CASE BLEND_DARKEN       : BLEND_mode_name$ = "DARKEN"
        CASE BLEND_LIGHTEN      : BLEND_mode_name$ = "LIGHTEN"
        CASE BLEND_COLOR_DODGE  : BLEND_mode_name$ = "COLOR DODGE"
        CASE BLEND_COLOR_BURN   : BLEND_mode_name$ = "COLOR BURN"
        CASE BLEND_HARD_LIGHT   : BLEND_mode_name$ = "HARD LIGHT"
        CASE BLEND_SOFT_LIGHT   : BLEND_mode_name$ = "SOFT LIGHT"
        CASE BLEND_EXCLUSION    : BLEND_mode_name$ = "EXCLUSION"
        CASE BLEND_VIVID_LIGHT  : BLEND_mode_name$ = "VIVID LIGHT"
        CASE BLEND_LINEAR_LIGHT : BLEND_mode_name$ = "LINEAR LIGHT"
        CASE BLEND_PIN_LIGHT    : BLEND_mode_name$ = "PIN LIGHT"
        CASE BLEND_COLOR        : BLEND_mode_name$ = "COLOR"
        CASE BLEND_LUMINOSITY   : BLEND_mode_name$ = "LUMINOSITY"
        CASE ELSE               : BLEND_mode_name$ = "NORMAL"
    END SELECT
END FUNCTION


''
' Return short 3-char abbreviation of a blend mode
' @param mode INTEGER Blend mode constant (BLEND_NORMAL, BLEND_MULTIPLY, etc.)
' @return STRING - 3-character abbreviation (e.g. "MUL", "SCR")
'
FUNCTION BLEND_mode_short$ (mode AS INTEGER)
    SELECT CASE mode%
        CASE BLEND_PASS_THROUGH : BLEND_mode_short$ = "PT"
        CASE BLEND_NORMAL       : BLEND_mode_short$ = "NRM"
        CASE BLEND_MULTIPLY     : BLEND_mode_short$ = "MUL"
        CASE BLEND_SCREEN       : BLEND_mode_short$ = "SCR"
        CASE BLEND_OVERLAY      : BLEND_mode_short$ = "OVR"
        CASE BLEND_ADD          : BLEND_mode_short$ = "ADD"
        CASE BLEND_SUBTRACT     : BLEND_mode_short$ = "SUB"
        CASE BLEND_DIFFERENCE   : BLEND_mode_short$ = "DIF"
        CASE BLEND_DARKEN       : BLEND_mode_short$ = "DRK"
        CASE BLEND_LIGHTEN      : BLEND_mode_short$ = "LTN"
        CASE BLEND_COLOR_DODGE  : BLEND_mode_short$ = "CDG"
        CASE BLEND_COLOR_BURN   : BLEND_mode_short$ = "CBN"
        CASE BLEND_HARD_LIGHT   : BLEND_mode_short$ = "HDL"
        CASE BLEND_SOFT_LIGHT   : BLEND_mode_short$ = "SFL"
        CASE BLEND_EXCLUSION    : BLEND_mode_short$ = "EXC"
        CASE BLEND_VIVID_LIGHT  : BLEND_mode_short$ = "VVL"
        CASE BLEND_LINEAR_LIGHT : BLEND_mode_short$ = "LNL"
        CASE BLEND_PIN_LIGHT    : BLEND_mode_short$ = "PNL"
        CASE BLEND_COLOR        : BLEND_mode_short$ = "CLR"
        CASE BLEND_LUMINOSITY   : BLEND_mode_short$ = "LUM"
        CASE ELSE               : BLEND_mode_short$ = "NRM"
    END SELECT
END FUNCTION


''
' Check if any visible layer uses non-Normal blend mode
' Returns TRUE if composite buffer approach is needed
' @return INTEGER - TRUE if per-pixel blend compositing is required
'
FUNCTION BLEND_needs_composite% ()
    ' Return cached result if not dirty
    IF NOT BLEND_COMPOSITE_DIRTY% THEN
        BLEND_needs_composite% = BLEND_COMPOSITE_CACHED%
        EXIT FUNCTION
    END IF

    BLEND_HAS_ISOLATED_GROUPS% = FALSE
    DIM blcNeedsComposite AS INTEGER
    blcNeedsComposite% = FALSE
    DIM i                 AS INTEGER
    FOR i% = 1 TO MAX_LAYERS
        IF LAYERS(i%).imgHandle& <> 0 THEN
            IF LAYERS(i%).visible% THEN
                IF LAYERS(i%).blendMode% <> BLEND_NORMAL THEN
                    blcNeedsComposite% = TRUE
                END IF
                ' Isolated groups require composite path
                IF LAYERS(i%).layerType% = LAYER_TYPE_GROUP AND NOT LAYERS(i%).passThrough% THEN
                    BLEND_HAS_ISOLATED_GROUPS% = TRUE
                    blcNeedsComposite%         = TRUE
                END IF
            END IF
        END IF
    NEXT i%
    IF blcNeedsComposite% THEN
        BLEND_COMPOSITE_CACHED% = TRUE
        BLEND_COMPOSITE_DIRTY%  = FALSE
        BLEND_needs_composite%  = TRUE
        EXIT FUNCTION
    END IF
    BLEND_COMPOSITE_CACHED% = FALSE
    BLEND_COMPOSITE_DIRTY%  = FALSE
    BLEND_needs_composite%  = FALSE
END FUNCTION


''
' Invalidate the blend composite cache.
' Call whenever blend modes, visibility, or layer structure changes.
'
SUB BLEND_invalidate_cache ()
    BLEND_COMPOSITE_DIRTY%  = TRUE
    RENDER_ORDER_DIRTY%     = TRUE
    SCENE_DIRTY%            = TRUE
    COMPOSITE_BELOW_VALID%  = FALSE
    COMPOSITE_RESULT_VALID% = FALSE
    ' NOTE: We intentionally do NOT mark all layers contentDirty% here.
    ' contentDirty% controls the per-layer opacity cache, which only depends on
    ' the layer's own pixel data + opacity value. Visibility/structure changes
    ' don't affect individual layer pixel content. Only mark contentDirty% when
    ' actual pixel data changes (e.g. drawing, undo, file load).
END SUB


''
' Lighter invalidation for visibility-only changes (no z-order/structure change).
' Skips RENDER_ORDER rebuild since zIndex order is unchanged.
' Only invalidates COMPOSITE_BELOW_CACHE when the changed layer renders below
' the current layer (i.e. it's part of the cached composite).
' Pass changedLayer% = 0 when multiple layers changed (force full invalidation).
' @param changedLayer INTEGER Index of the layer whose visibility changed (0 for bulk invalidation)
'
SUB BLEND_invalidate_visibility (changedLayer AS INTEGER)
    BLEND_COMPOSITE_DIRTY%  = TRUE
    SCENE_DIRTY%            = TRUE
    COMPOSITE_RESULT_VALID% = FALSE
    IF COMPOSITE_BELOW_VALID% THEN
        IF changedLayer% < 1 OR changedLayer% > MAX_LAYERS OR CURRENT_LAYER% < 1 OR CURRENT_LAYER% > MAX_LAYERS THEN
            COMPOSITE_BELOW_VALID% = FALSE
        ELSEIF LAYERS(changedLayer%).zIndex% < LAYERS(CURRENT_LAYER%).zIndex% THEN
            COMPOSITE_BELOW_VALID% = FALSE
        END IF
        ' Changed layer is above or IS current → below-cache still valid
    END IF
END SUB


''
' Rebuild the pre-sorted render order lookup table.
' Called once per dirty frame instead of O(n×64) scan per frame.
'
SUB RENDER_ORDER_rebuild ()
    DIM rz AS INTEGER, ri AS INTEGER, rc AS INTEGER
    rc% = 0
    FOR rz% = 1 TO LAYER_COUNT%
        FOR ri% = 1 TO MAX_LAYERS
            IF LAYERS(ri%).imgHandle& <> 0 AND LAYERS(ri%).zIndex% = rz% THEN
                rc% = rc% + 1
                RENDER_ORDER%(rc%) = ri%
                EXIT FOR
            END IF
        NEXT ri%
    NEXT rz%
    RENDER_ORDER_COUNT% = rc%
    RENDER_ORDER_DIRTY% = FALSE
END SUB


''
' Composite src image onto dst image using specified blend mode and opacity.
' Both images must be the same dimensions (32-bit color).
' Uses _MEM for fast per-pixel operations.
' @param dst LONG Destination image handle (modified in place)
' @param src LONG Source image handle to composite over dst
' @param blendMode INTEGER Blend mode constant (BLEND_NORMAL, BLEND_MULTIPLY, etc.)
' @param opacity INTEGER Source layer opacity (0-255)
'
SUB LAYER_blend_composite (dst AS LONG, src AS LONG, blendMode AS INTEGER, opacity AS INTEGER)
    DIM dstMem   AS _MEM, srcMem AS _MEM
    DIM pixOff   AS _OFFSET
    DIM dstPix   AS _UNSIGNED LONG, srcPix AS _UNSIGNED LONG
    DIM sA       AS LONG, sR AS LONG, sG AS LONG, sB AS LONG
    DIM dA       AS LONG, dR AS LONG, dG AS LONG, dB AS LONG
    DIM bR       AS LONG, bG AS LONG, bB AS LONG
    DIM rR       AS LONG, rG AS LONG, rB AS LONG, rA AS LONG
    DIM effAlpha AS LONG
    
    IF dst& = 0 OR src& = 0 THEN EXIT SUB
    IF _WIDTH(dst&) <> _WIDTH(src&) OR _HEIGHT(dst&) <> _HEIGHT(src&) THEN EXIT SUB

    dstMem = _MEMIMAGE(dst&)
    srcMem = _MEMIMAGE(src&)

    FOR pixOff = 0 TO srcMem.SIZE - 4 STEP 4
        _MEMGET srcMem, srcMem.OFFSET + pixOff, srcPix~&
        sA& = _ALPHA32(srcPix~&)
        IF sA& = 0 THEN _CONTINUE ' Fully transparent - skip

        ' Apply layer opacity to source alpha (integer math)
        effAlpha& = (sA& * opacity%) \ 255
        IF effAlpha& < = 0 THEN _CONTINUE

        sR& = _RED32(srcPix~&)
        sG& = _GREEN32(srcPix~&)
        sB& = _BLUE32(srcPix~&)

        _MEMGET dstMem, dstMem.OFFSET + pixOff, dstPix~&
        dA& = _ALPHA32(dstPix~&)
        dR& = _RED32(dstPix~&)
        dG& = _GREEN32(dstPix~&)
        dB& = _BLUE32(dstPix~&)

        ' Apply blend formula to get blended RGB
        SELECT CASE blendMode%
            CASE BLEND_MULTIPLY
                bR& = (dR& * sR&) \ 255
                bG& = (dG& * sG&) \ 255
                bB& = (dB& * sB&) \ 255

            CASE BLEND_SCREEN
                bR& = 255 - ((255 - dR&) * (255 - sR&)) \ 255
                bG& = 255 - ((255 - dG&) * (255 - sG&)) \ 255
                bB& = 255 - ((255 - dB&) * (255 - sB&)) \ 255

            CASE BLEND_OVERLAY
                IF dR& < 128 THEN bR& = (2 * dR& * sR&) \ 255 ELSE bR& = 255 - (2 * (255 - dR&) * (255 - sR&)) \ 255
                IF dG& < 128 THEN bG& = (2 * dG& * sG&) \ 255 ELSE bG& = 255 - (2 * (255 - dG&) * (255 - sG&)) \ 255
                IF dB& < 128 THEN bB& = (2 * dB& * sB&) \ 255 ELSE bB& = 255 - (2 * (255 - dB&) * (255 - sB&)) \ 255

            CASE BLEND_ADD
                bR& = dR& + sR& : IF bR& > 255 THEN bR& = 255
                bG& = dG& + sG& : IF bG& > 255 THEN bG& = 255
                bB& = dB& + sB& : IF bB& > 255 THEN bB& = 255

            CASE BLEND_SUBTRACT
                bR& = dR& - sR& : IF bR& < 0 THEN bR& = 0
                bG& = dG& - sG& : IF bG& < 0 THEN bG& = 0
                bB& = dB& - sB& : IF bB& < 0 THEN bB& = 0

            CASE BLEND_DIFFERENCE
                bR& = ABS(dR& - sR&)
                bG& = ABS(dG& - sG&)
                bB& = ABS(dB& - sB&)

            CASE BLEND_DARKEN
                IF dR& < sR& THEN bR& = dR& ELSE bR& = sR&
                IF dG& < sG& THEN bG& = dG& ELSE bG& = sG&
                IF dB& < sB& THEN bB& = dB& ELSE bB& = sB&

            CASE BLEND_LIGHTEN
                IF dR& > sR& THEN bR& = dR& ELSE bR& = sR&
                IF dG& > sG& THEN bG& = dG& ELSE bG& = sG&
                IF dB& > sB& THEN bB& = dB& ELSE bB& = sB&

            CASE BLEND_COLOR_DODGE
                ' d / (1 - s) = d * 255 / (255 - s), clamped
                IF sR& >= 255 THEN bR& = 255 ELSE bR& = (dR& * 255) \ (255 - sR&) : IF bR& > 255 THEN bR& = 255
                IF sG& >= 255 THEN bG& = 255 ELSE bG& = (dG& * 255) \ (255 - sG&) : IF bG& > 255 THEN bG& = 255
                IF sB& >= 255 THEN bB& = 255 ELSE bB& = (dB& * 255) \ (255 - sB&) : IF bB& > 255 THEN bB& = 255

            CASE BLEND_COLOR_BURN
                ' 1 - (1 - d) / s = 255 - (255 - d) * 255 / s, clamped
                IF sR& < = 0 THEN bR& = 0 ELSE bR& = 255 - ((255 - dR&) * 255) \ sR& : IF bR& < 0 THEN bR& = 0
                IF sG& < = 0 THEN bG& = 0 ELSE bG& = 255 - ((255 - dG&) * 255) \ sG& : IF bG& < 0 THEN bG& = 0
                IF sB& < = 0 THEN bB& = 0 ELSE bB& = 255 - ((255 - dB&) * 255) \ sB& : IF bB& < 0 THEN bB& = 0

            CASE BLEND_HARD_LIGHT
                ' Overlay with source and dest swapped
                IF sR& < 128 THEN bR& = (2 * sR& * dR&) \ 255 ELSE bR& = 255 - (2 * (255 - sR&) * (255 - dR&)) \ 255
                IF sG& < 128 THEN bG& = (2 * sG& * dG&) \ 255 ELSE bG& = 255 - (2 * (255 - sG&) * (255 - dG&)) \ 255
                IF sB& < 128 THEN bB& = (2 * sB& * dB&) \ 255 ELSE bB& = 255 - (2 * (255 - sB&) * (255 - dB&)) \ 255

            CASE BLEND_SOFT_LIGHT
                ' Pegtop formula: (1-2s)*d^2/255 + 2s*d, all in 0-255 integer range
                bR& = ((255 - 2 * sR&) * dR& * dR&) \ 65025 + (2 * sR& * dR&) \ 255
                bG& = ((255 - 2 * sG&) * dG& * dG&) \ 65025 + (2 * sG& * dG&) \ 255
                bB& = ((255 - 2 * sB&) * dB& * dB&) \ 65025 + (2 * sB& * dB&) \ 255
                IF bR& < 0 THEN bR& = 0 ELSE IF bR& > 255 THEN bR& = 255
                IF bG& < 0 THEN bG& = 0 ELSE IF bG& > 255 THEN bG& = 255
                IF bB& < 0 THEN bB& = 0 ELSE IF bB& > 255 THEN bB& = 255

            CASE BLEND_EXCLUSION
                ' d + s - 2*d*s/255
                bR& = dR& + sR& - (2 * dR& * sR&) \ 255
                bG& = dG& + sG& - (2 * dG& * sG&) \ 255
                bB& = dB& + sB& - (2 * dB& * sB&) \ 255

            CASE BLEND_VIVID_LIGHT
                ' Color Dodge if s > 128, Color Burn if s <= 128
                IF sR& > 128 THEN
                    DIM vr  AS LONG: vr& = 2 * (sR& - 128): IF vr& >= 255 THEN bR& = 255 ELSE bR& = (dR& * 255) \ (255 - vr&): IF bR& > 255 THEN bR& = 255
                ELSE
                    DIM vr2 AS LONG: vr2& = 2 * sR&: IF vr2& < = 0 THEN bR& = 0 ELSE bR& = 255 - ((255 - dR&) * 255) \ vr2&: IF bR& < 0 THEN bR& = 0
                END IF
                IF sG& > 128 THEN
                    DIM vg  AS LONG: vg& = 2 * (sG& - 128): IF vg& >= 255 THEN bG& = 255 ELSE bG& = (dG& * 255) \ (255 - vg&): IF bG& > 255 THEN bG& = 255
                ELSE
                    DIM vg2 AS LONG: vg2& = 2 * sG&: IF vg2& < = 0 THEN bG& = 0 ELSE bG& = 255 - ((255 - dG&) * 255) \ vg2&: IF bG& < 0 THEN bG& = 0
                END IF
                IF sB& > 128 THEN
                    DIM vb  AS LONG: vb& = 2 * (sB& - 128): IF vb& >= 255 THEN bB& = 255 ELSE bB& = (dB& * 255) \ (255 - vb&): IF bB& > 255 THEN bB& = 255
                ELSE
                    DIM vb2 AS LONG: vb2& = 2 * sB&: IF vb2& < = 0 THEN bB& = 0 ELSE bB& = 255 - ((255 - dB&) * 255) \ vb2&: IF bB& < 0 THEN bB& = 0
                END IF

            CASE BLEND_LINEAR_LIGHT
                ' d + 2*s - 255, clamped
                bR& = dR& + 2 * sR& - 255 : IF bR& < 0 THEN bR& = 0 ELSE IF bR& > 255 THEN bR& = 255
                bG& = dG& + 2 * sG& - 255 : IF bG& < 0 THEN bG& = 0 ELSE IF bG& > 255 THEN bG& = 255
                bB& = dB& + 2 * sB& - 255 : IF bB& < 0 THEN bB& = 0 ELSE IF bB& > 255 THEN bB& = 255

            CASE BLEND_PIN_LIGHT
                ' If s > 128: max(d, 2*s-255), else: min(d, 2*s)
                IF sR& > 128 THEN
                    DIM ps AS LONG: ps& = 2 * sR& - 255: IF dR& > ps& THEN bR& = dR& ELSE bR& = ps&
                ELSE
                    ps& = 2 * sR&: IF dR& < ps& THEN bR& = dR& ELSE bR& = ps&
                END IF
                IF sG& > 128 THEN
                    ps& = 2 * sG& - 255: IF dG& > ps& THEN bG& = dG& ELSE bG& = ps&
                ELSE
                    ps& = 2 * sG&: IF dG& < ps& THEN bG& = dG& ELSE bG& = ps&
                END IF
                IF sB& > 128 THEN
                    ps& = 2 * sB& - 255: IF dB& > ps& THEN bB& = dB& ELSE bB& = ps&
                ELSE
                    ps& = 2 * sB&: IF dB& < ps& THEN bB& = dB& ELSE bB& = ps&
                END IF

            CASE BLEND_COLOR
                ' Source hue+saturation, dest luminosity (Rec. 601)
                DIM srcLum AS LONG, dstLum AS LONG, deltaLum AS LONG
                srcLum&   = (sR& * 77 + sG& * 150 + sB& * 29) \ 256
                dstLum&   = (dR& * 77 + dG& * 150 + dB& * 29) \ 256
                deltaLum& = dstLum& - srcLum&
                bR&       = sR& + deltaLum& : IF bR& < 0 THEN bR& = 0 ELSE IF bR& > 255 THEN bR& = 255
                bG&       = sG& + deltaLum& : IF bG& < 0 THEN bG& = 0 ELSE IF bG& > 255 THEN bG& = 255
                bB&       = sB& + deltaLum& : IF bB& < 0 THEN bB& = 0 ELSE IF bB& > 255 THEN bB& = 255

            CASE BLEND_LUMINOSITY
                ' Source luminosity, dest hue+saturation (Rec. 601)
                DIM srcLum2 AS LONG, dstLum2 AS LONG, deltaLum2 AS LONG
                srcLum2&   = (sR& * 77 + sG& * 150 + sB& * 29) \ 256
                dstLum2&   = (dR& * 77 + dG& * 150 + dB& * 29) \ 256
                deltaLum2& = srcLum2& - dstLum2&
                bR&        = dR& + deltaLum2& : IF bR& < 0 THEN bR& = 0 ELSE IF bR& > 255 THEN bR& = 255
                bG&        = dG& + deltaLum2& : IF bG& < 0 THEN bG& = 0 ELSE IF bG& > 255 THEN bG& = 255
                bB&        = dB& + deltaLum2& : IF bB& < 0 THEN bB& = 0 ELSE IF bB& > 255 THEN bB& = 255

            CASE ELSE
                ' Normal fallback (shouldn't reach here)
                bR& = sR&: bG& = sG&: bB& = sB&
        END SELECT

        ' Mix blended result with base using effective alpha (Porter-Duff "over")
        IF dA& = 0 THEN
            ' No base - use blended color directly with blend alpha
            rR& = bR&: rG& = bG&: rB& = bB&
            rA& = effAlpha&
        ELSE
            ' Composite: result = blended * effAlpha + base * (1 - effAlpha/255)
            rR& = dR& + ((bR& - dR&) * effAlpha&) \ 255
            rG& = dG& + ((bG& - dG&) * effAlpha&) \ 255
            rB& = dB& + ((bB& - dB&) * effAlpha&) \ 255
            rA& = dA& + effAlpha& - (dA& * effAlpha&) \ 255
            IF rA& > 255 THEN rA& = 255
        END IF

        ' Write result pixel
        _MEMPUT dstMem, dstMem.OFFSET + pixOff, _RGBA32(rR&, rG&, rB&, rA&) AS _UNSIGNED LONG
    NEXT pixOff

    _MEMFREE srcMem
    _MEMFREE dstMem
END SUB


''
' Region-based blend composite — same as LAYER_blend_composite but only
' processes the rectangle (rx1,ry1)-(rx2,ry2) in canvas coordinates.
' Falls back to full if region is invalid.
' @param dst LONG Destination image handle (modified in place)
' @param src LONG Source image handle to composite over dst
' @param blendMode INTEGER Blend mode constant (BLEND_NORMAL, BLEND_MULTIPLY, etc.)
' @param opacity INTEGER Source layer opacity (0-255)
' @param rx1 INTEGER Left X of the dirty region (clamped to image bounds)
' @param ry1 INTEGER Top Y of the dirty region (clamped to image bounds)
' @param rx2 INTEGER Right X of the dirty region (clamped to image bounds)
' @param ry2 INTEGER Bottom Y of the dirty region (clamped to image bounds)
'
SUB LAYER_blend_composite_region (dst AS LONG, src AS LONG, blendMode AS INTEGER, opacity AS INTEGER, rx1 AS INTEGER, ry1 AS INTEGER, rx2 AS INTEGER, ry2 AS INTEGER)
    IF dst& = 0 OR src& = 0 THEN EXIT SUB
    DIM imgW AS INTEGER, imgH AS INTEGER
    imgW% = _WIDTH(dst&)
    imgH% = _HEIGHT(dst&)
    IF imgW% <> _WIDTH(src&) OR imgH% <> _HEIGHT(src&) THEN EXIT SUB

    ' Clamp region to image bounds
    DIM cx1 AS INTEGER, cy1 AS INTEGER, cx2 AS INTEGER, cy2 AS INTEGER
    cx1% = rx1%: cy1% = ry1%: cx2% = rx2%: cy2% = ry2%
    IF cx1% < 0 THEN cx1% = 0
    IF cy1% < 0 THEN cy1% = 0
    IF cx2% >= imgW% THEN cx2% = imgW% - 1
    IF cy2% >= imgH% THEN cy2% = imgH% - 1
    IF cx2% < cx1% OR cy2% < cy1% THEN EXIT SUB

    DIM dstMem   AS _MEM, srcMem AS _MEM
    DIM pixOff   AS _OFFSET
    DIM dstPix   AS _UNSIGNED LONG, srcPix AS _UNSIGNED LONG
    DIM sA       AS LONG, sR AS LONG, sG AS LONG, sB AS LONG
    DIM dA       AS LONG, dR AS LONG, dG AS LONG, dB AS LONG
    DIM bR       AS LONG, bG AS LONG, bB AS LONG
    DIM rR       AS LONG, rG AS LONG, rB AS LONG, rA AS LONG
    DIM effAlpha AS LONG
    DIM rowY     AS INTEGER, colX AS INTEGER
    DIM rowOff   AS _OFFSET, stride AS _OFFSET

    dstMem = _MEMIMAGE(dst&)
    srcMem = _MEMIMAGE(src&)
    stride = CLNG(imgW%) * 4

    FOR rowY% = cy1% TO cy2%
        rowOff = CLNG(rowY%) * stride
        FOR colX% = cx1% TO cx2%
            pixOff = rowOff + CLNG(colX%) * 4
            _MEMGET srcMem, srcMem.OFFSET + pixOff, srcPix~&
            sA& = _ALPHA32(srcPix~&)
            IF sA& = 0 THEN _CONTINUE
            effAlpha& = (sA& * opacity%) \ 255
            IF effAlpha& < = 0 THEN _CONTINUE

            sR& = _RED32(srcPix~&): sG& = _GREEN32(srcPix~&): sB& = _BLUE32(srcPix~&)
            _MEMGET dstMem, dstMem.OFFSET + pixOff, dstPix~&
            dA& = _ALPHA32(dstPix~&)
            dR& = _RED32(dstPix~&): dG& = _GREEN32(dstPix~&): dB& = _BLUE32(dstPix~&)

            SELECT CASE blendMode%
                CASE BLEND_MULTIPLY
                    bR& = (dR& * sR&) \ 255: bG& = (dG& * sG&) \ 255: bB& = (dB& * sB&) \ 255
                CASE BLEND_SCREEN
                    bR& = 255 - ((255 - dR&) * (255 - sR&)) \ 255: bG& = 255 - ((255 - dG&) * (255 - sG&)) \ 255: bB& = 255 - ((255 - dB&) * (255 - sB&)) \ 255
                CASE BLEND_OVERLAY
                    IF dR& < 128 THEN bR& = (2 * dR& * sR&) \ 255 ELSE bR& = 255 - (2 * (255 - dR&) * (255 - sR&)) \ 255
                    IF dG& < 128 THEN bG& = (2 * dG& * sG&) \ 255 ELSE bG& = 255 - (2 * (255 - dG&) * (255 - sG&)) \ 255
                    IF dB& < 128 THEN bB& = (2 * dB& * sB&) \ 255 ELSE bB& = 255 - (2 * (255 - dB&) * (255 - sB&)) \ 255
                CASE BLEND_ADD
                    bR& = dR& + sR& : IF bR& > 255 THEN bR& = 255
                    bG& = dG& + sG& : IF bG& > 255 THEN bG& = 255
                    bB& = dB& + sB& : IF bB& > 255 THEN bB& = 255
                CASE BLEND_SUBTRACT
                    bR& = dR& - sR& : IF bR& < 0 THEN bR& = 0
                    bG& = dG& - sG& : IF bG& < 0 THEN bG& = 0
                    bB& = dB& - sB& : IF bB& < 0 THEN bB& = 0
                CASE BLEND_DIFFERENCE
                    bR& = ABS(dR& - sR&): bG& = ABS(dG& - sG&): bB& = ABS(dB& - sB&)
                CASE BLEND_DARKEN
                    IF dR& < sR& THEN bR& = dR& ELSE bR& = sR&
                    IF dG& < sG& THEN bG& = dG& ELSE bG& = sG&
                    IF dB& < sB& THEN bB& = dB& ELSE bB& = sB&
                CASE BLEND_LIGHTEN
                    IF dR& > sR& THEN bR& = dR& ELSE bR& = sR&
                    IF dG& > sG& THEN bG& = dG& ELSE bG& = sG&
                    IF dB& > sB& THEN bB& = dB& ELSE bB& = sB&
                CASE BLEND_COLOR_DODGE
                    IF sR& >= 255 THEN bR& = 255 ELSE bR& = (dR& * 255) \ (255 - sR&) : IF bR& > 255 THEN bR& = 255
                    IF sG& >= 255 THEN bG& = 255 ELSE bG& = (dG& * 255) \ (255 - sG&) : IF bG& > 255 THEN bG& = 255
                    IF sB& >= 255 THEN bB& = 255 ELSE bB& = (dB& * 255) \ (255 - sB&) : IF bB& > 255 THEN bB& = 255
                CASE BLEND_COLOR_BURN
                    IF sR& < = 0 THEN bR& = 0 ELSE bR& = 255 - ((255 - dR&) * 255) \ sR& : IF bR& < 0 THEN bR& = 0
                    IF sG& < = 0 THEN bG& = 0 ELSE bG& = 255 - ((255 - dG&) * 255) \ sG& : IF bG& < 0 THEN bG& = 0
                    IF sB& < = 0 THEN bB& = 0 ELSE bB& = 255 - ((255 - dB&) * 255) \ sB& : IF bB& < 0 THEN bB& = 0
                CASE BLEND_HARD_LIGHT
                    IF sR& < 128 THEN bR& = (2 * sR& * dR&) \ 255 ELSE bR& = 255 - (2 * (255 - sR&) * (255 - dR&)) \ 255
                    IF sG& < 128 THEN bG& = (2 * sG& * dG&) \ 255 ELSE bG& = 255 - (2 * (255 - sG&) * (255 - dG&)) \ 255
                    IF sB& < 128 THEN bB& = (2 * sB& * dB&) \ 255 ELSE bB& = 255 - (2 * (255 - sB&) * (255 - dB&)) \ 255
                CASE BLEND_SOFT_LIGHT
                    bR& = ((255 - 2 * sR&) * dR& * dR&) \ 65025 + (2 * sR& * dR&) \ 255
                    bG& = ((255 - 2 * sG&) * dG& * dG&) \ 65025 + (2 * sG& * dG&) \ 255
                    bB& = ((255 - 2 * sB&) * dB& * dB&) \ 65025 + (2 * sB& * dB&) \ 255
                    IF bR& < 0 THEN bR& = 0 ELSE IF bR& > 255 THEN bR& = 255
                    IF bG& < 0 THEN bG& = 0 ELSE IF bG& > 255 THEN bG& = 255
                    IF bB& < 0 THEN bB& = 0 ELSE IF bB& > 255 THEN bB& = 255
                CASE BLEND_EXCLUSION
                    bR& = dR& + sR& - (2 * dR& * sR&) \ 255
                    bG& = dG& + sG& - (2 * dG& * sG&) \ 255
                    bB& = dB& + sB& - (2 * dB& * sB&) \ 255
                CASE BLEND_VIVID_LIGHT
                    IF sR& > 128 THEN
                        DIM vrr  AS LONG: vrr& = 2 * (sR& - 128): IF vrr& >= 255 THEN bR& = 255 ELSE bR& = (dR& * 255) \ (255 - vrr&): IF bR& > 255 THEN bR& = 255
                    ELSE
                        DIM vrr2 AS LONG: vrr2& = 2 * sR&: IF vrr2& < = 0 THEN bR& = 0 ELSE bR& = 255 - ((255 - dR&) * 255) \ vrr2&: IF bR& < 0 THEN bR& = 0
                    END IF
                    IF sG& > 128 THEN
                        DIM vgr  AS LONG: vgr& = 2 * (sG& - 128): IF vgr& >= 255 THEN bG& = 255 ELSE bG& = (dG& * 255) \ (255 - vgr&): IF bG& > 255 THEN bG& = 255
                    ELSE
                        DIM vgr2 AS LONG: vgr2& = 2 * sG&: IF vgr2& < = 0 THEN bG& = 0 ELSE bG& = 255 - ((255 - dG&) * 255) \ vgr2&: IF bG& < 0 THEN bG& = 0
                    END IF
                    IF sB& > 128 THEN
                        DIM vbr  AS LONG: vbr& = 2 * (sB& - 128): IF vbr& >= 255 THEN bB& = 255 ELSE bB& = (dB& * 255) \ (255 - vbr&): IF bB& > 255 THEN bB& = 255
                    ELSE
                        DIM vbr2 AS LONG: vbr2& = 2 * sB&: IF vbr2& < = 0 THEN bB& = 0 ELSE bB& = 255 - ((255 - dB&) * 255) \ vbr2&: IF bB& < 0 THEN bB& = 0
                    END IF
                CASE BLEND_LINEAR_LIGHT
                    bR& = dR& + 2 * sR& - 255 : IF bR& < 0 THEN bR& = 0 ELSE IF bR& > 255 THEN bR& = 255
                    bG& = dG& + 2 * sG& - 255 : IF bG& < 0 THEN bG& = 0 ELSE IF bG& > 255 THEN bG& = 255
                    bB& = dB& + 2 * sB& - 255 : IF bB& < 0 THEN bB& = 0 ELSE IF bB& > 255 THEN bB& = 255
                CASE BLEND_PIN_LIGHT
                    IF sR& > 128 THEN
                        DIM psr  AS LONG: psr& = 2 * sR& - 255: IF dR& > psr& THEN bR& = dR& ELSE bR& = psr&
                    ELSE
                        psr& = 2 * sR&: IF dR& < psr& THEN bR& = dR& ELSE bR& = psr&
                    END IF
                    IF sG& > 128 THEN
                        psr& = 2 * sG& - 255: IF dG& > psr& THEN bG& = dG& ELSE bG& = psr&
                    ELSE
                        psr& = 2 * sG&: IF dG& < psr& THEN bG& = dG& ELSE bG& = psr&
                    END IF
                    IF sB& > 128 THEN
                        psr& = 2 * sB& - 255: IF dB& > psr& THEN bB& = dB& ELSE bB& = psr&
                    ELSE
                        psr& = 2 * sB&: IF dB& < psr& THEN bB& = dB& ELSE bB& = psr&
                    END IF
                CASE BLEND_COLOR
                    DIM srcLumR  AS LONG, dstLumR AS LONG, deltaLumR AS LONG
                    srcLumR&   = (sR& * 77 + sG& * 150 + sB& * 29) \ 256
                    dstLumR&   = (dR& * 77 + dG& * 150 + dB& * 29) \ 256
                    deltaLumR& = dstLumR& - srcLumR&
                    bR&        = sR& + deltaLumR& : IF bR& < 0 THEN bR& = 0 ELSE IF bR& > 255 THEN bR& = 255
                    bG&        = sG& + deltaLumR& : IF bG& < 0 THEN bG& = 0 ELSE IF bG& > 255 THEN bG& = 255
                    bB&        = sB& + deltaLumR& : IF bB& < 0 THEN bB& = 0 ELSE IF bB& > 255 THEN bB& = 255
                CASE BLEND_LUMINOSITY
                    DIM srcLumR2 AS LONG, dstLumR2 AS LONG, deltaLumR2 AS LONG
                    srcLumR2&   = (sR& * 77 + sG& * 150 + sB& * 29) \ 256
                    dstLumR2&   = (dR& * 77 + dG& * 150 + dB& * 29) \ 256
                    deltaLumR2& = srcLumR2& - dstLumR2&
                    bR&         = dR& + deltaLumR2& : IF bR& < 0 THEN bR& = 0 ELSE IF bR& > 255 THEN bR& = 255
                    bG&         = dG& + deltaLumR2& : IF bG& < 0 THEN bG& = 0 ELSE IF bG& > 255 THEN bG& = 255
                    bB&         = dB& + deltaLumR2& : IF bB& < 0 THEN bB& = 0 ELSE IF bB& > 255 THEN bB& = 255
                CASE ELSE
                    bR& = sR&: bG& = sG&: bB& = sB&
            END SELECT

            IF dA& = 0 THEN
                rR& = bR&: rG& = bG&: rB& = bB&: rA& = effAlpha&
            ELSE
                rR& = dR& + ((bR& - dR&) * effAlpha&) \ 255
                rG& = dG& + ((bG& - dG&) * effAlpha&) \ 255
                rB& = dB& + ((bB& - dB&) * effAlpha&) \ 255
                rA& = dA& + effAlpha& - (dA& * effAlpha&) \ 255
                IF rA& > 255 THEN rA& = 255
            END IF
            _MEMPUT dstMem, dstMem.OFFSET + pixOff, _RGBA32(rR&, rG&, rB&, rA&) AS _UNSIGNED LONG
        NEXT colX%
    NEXT rowY%

    _MEMFREE srcMem
    _MEMFREE dstMem
END SUB


''
' Show blend mode popup for a layer, anchored near (x, y) on screen.
' @param layerIdx INTEGER Index of the layer to change blend mode for (1-64)
' @param x INTEGER Screen X coordinate to anchor the popup near
' @param y INTEGER Screen Y coordinate to anchor the popup near
'
SUB LAYER_PANEL_blend_popup_show (layerIdx AS INTEGER, x AS INTEGER, y AS INTEGER)
    DIM popH         AS INTEGER
    DIM bpsItemCount AS INTEGER
    ' Close context menu if open
    IF LAYER_PANEL.ctxMenuOpen% THEN LAYER_PANEL_ctx_menu_close
    LAYER_PANEL_blend_popup_build layerIdx%
    ' Groups have 2 extra rows (Pass Through + divider)
    IF layerIdx% >= 1 THEN
        IF layerIdx% < = MAX_LAYERS THEN
            IF LAYERS(layerIdx%).layerType% = LAYER_TYPE_GROUP THEN
                bpsItemCount% = BLEND_MODE_COUNT + 3
            ELSE
                bpsItemCount% = BLEND_MODE_COUNT + 1
            END IF
        ELSE
            bpsItemCount% = BLEND_MODE_COUNT + 1
        END IF
    ELSE
        bpsItemCount% = BLEND_MODE_COUNT + 1
    END IF
    POPUP_MENU_place x%, y%, 90, bpsItemCount%, 10, LAYER_PANEL.blendPopupX%, LAYER_PANEL.blendPopupY%, popH%
    LAYER_PANEL.blendPopupOpen%  = TRUE
    LAYER_PANEL.blendPopupLayer% = layerIdx%
    LAYER_PANEL.blendPopupHover% = -1
END SUB

''
' Close blend mode popup.
'
SUB LAYER_PANEL_blend_popup_close ()
    LAYER_PANEL.blendPopupOpen%  = FALSE
    LAYER_PANEL.blendPopupHover% = -1
    GUI_NEEDS_REDRAW%            = TRUE
    FRAME_IDLE%                  = FALSE
END SUB

''
' Render the blend mode popup to SCRN.GUI& (called from SCREEN_render after SkipToPointer).
' Layout for groups: Pass Through (0), divider (1), Normal (2), divider (3), Multiply..Luminosity (4-21).
' Layout for images: Normal (0), divider (1), Multiply..Luminosity (2-19).
'
SUB LAYER_PANEL_blend_popup_render ()
    IF NOT LAYER_PANEL.blendPopupOpen% THEN EXIT SUB
    DIM layerIdx     AS INTEGER: layerIdx% = LAYER_PANEL.blendPopupLayer%
    DIM currentMode  AS INTEGER
    DIM checkedRow   AS INTEGER
    DIM bprIsGroup   AS INTEGER
    DIM bprItemCount AS INTEGER
    bprIsGroup% = FALSE
    IF layerIdx% >= 1 AND layerIdx% < = MAX_LAYERS THEN
        currentMode% = LAYERS(layerIdx%).blendMode%
        IF LAYERS(layerIdx%).layerType% = LAYER_TYPE_GROUP THEN bprIsGroup% = TRUE
    ELSE
        currentMode% = BLEND_NORMAL
    END IF
    LAYER_PANEL_blend_popup_build layerIdx%
    IF bprIsGroup% THEN
        bprItemCount% = BLEND_MODE_COUNT + 3
        IF LAYERS(layerIdx%).passThrough% THEN
            checkedRow% = 0                ' Pass Through row (value = BLEND_PASS_THROUGH_POPUP_VALUE)
        ELSEIF currentMode% = BLEND_NORMAL THEN
            checkedRow% = 2                ' Normal row (after PT + divider)
        ELSE
            checkedRow% = currentMode% + 3 ' mode rows shifted by 2 extra rows
        END IF
    ELSE
        bprItemCount% = BLEND_MODE_COUNT + 1
        IF currentMode% = BLEND_NORMAL THEN
            checkedRow% = 0
        ELSE
            checkedRow% = currentMode% + 1
        END IF
    END IF
    POPUP_MENU_FLAGS(checkedRow%) = POPUP_MENU_FLAGS(checkedRow%) OR POPUP_MENU_FLAG_CHECKED
    POPUP_MENU_render SCRN.CANVAS&, LAYER_PANEL.blendPopupX%, LAYER_PANEL.blendPopupY%, 90, bprItemCount%, 10, LAYER_PANEL.blendPopupHover%, LAYER_PANEL.fontHandle&
END SUB

''
' Hit-test the blend mode popup.
' Returns: mode index 0-18 if a mode item was clicked, BLEND_PASS_THROUGH (-1) for pass-through,
'          -1 if inside popup but on non-clickable area (divider, padding),
'          -2 if outside popup.
' @param rawX INTEGER Raw screen X coordinate to test
' @param rawY INTEGER Raw screen Y coordinate to test
' @return INTEGER - Blend mode index (0-18 or BLEND_PASS_THROUGH), -1 for non-clickable area, -2 for outside
'
FUNCTION LAYER_PANEL_blend_popup_hit% (rawX AS INTEGER, rawY AS INTEGER)
    DIM bphItemCount AS INTEGER
    DIM bphLayer     AS INTEGER
    IF NOT LAYER_PANEL.blendPopupOpen% THEN
        LAYER_PANEL_blend_popup_hit% = -2
        EXIT FUNCTION
    END IF
    bphLayer%     = LAYER_PANEL.blendPopupLayer%
    bphItemCount% = BLEND_MODE_COUNT + 1
    IF bphLayer% >= 1 THEN
        IF bphLayer% < = MAX_LAYERS THEN
            IF LAYERS(bphLayer%).layerType% = LAYER_TYPE_GROUP THEN
                bphItemCount% = BLEND_MODE_COUNT + 3
            END IF
        END IF
    END IF
    LAYER_PANEL_blend_popup_hit% = POPUP_MENU_hit_value%(LAYER_PANEL.blendPopupX%, LAYER_PANEL.blendPopupY%, 90, bphItemCount%, 10, rawX%, rawY%)
END FUNCTION

''
' Update blend popup hover state from current mouse position.
' Called every frame from MOUSE_handle_layer_panel when popup is open.
' @param rawX INTEGER Raw screen X coordinate of the mouse
' @param rawY INTEGER Raw screen Y coordinate of the mouse
'
SUB LAYER_PANEL_blend_popup_hover (rawX AS INTEGER, rawY AS INTEGER)
    IF NOT LAYER_PANEL.blendPopupOpen% THEN EXIT SUB
    DIM prevHover     AS INTEGER : prevHover% = LAYER_PANEL.blendPopupHover%
    DIM bphvLayer     AS INTEGER : bphvLayer% = LAYER_PANEL.blendPopupLayer%
    DIM bphvItemCount AS INTEGER : bphvItemCount% = BLEND_MODE_COUNT + 1
    IF bphvLayer% >= 1 THEN
        IF bphvLayer% < = MAX_LAYERS THEN
            IF LAYERS(bphvLayer%).layerType% = LAYER_TYPE_GROUP THEN
                bphvItemCount% = BLEND_MODE_COUNT + 3
            END IF
        END IF
    END IF
    LAYER_PANEL.blendPopupHover% = POPUP_MENU_hover_row%(LAYER_PANEL.blendPopupX%, LAYER_PANEL.blendPopupY%, 90, bphvItemCount%, 10, rawX%, rawY%)
    IF LAYER_PANEL.blendPopupHover% <> prevHover% THEN
        GUI_NEEDS_REDRAW% = TRUE
        FRAME_IDLE%       = FALSE
    END IF
END SUB

''
' Build the blend mode popup menu items.
' Populates the shared POPUP_MENU system with all available blend modes
' for display in the layer panel.
' Groups: Pass Through (row 0), divider (1), Normal (2), divider (3), modes (4-21).
' Images: Normal (row 0), divider (1), modes (2-19).
'
SUB LAYER_PANEL_blend_popup_build (layerIdx AS INTEGER)
    DIM itemRow    AS INTEGER
    DIM modeIdx    AS INTEGER
    DIM bpbIsGroup AS INTEGER

    POPUP_MENU_clear_items

    bpbIsGroup% = FALSE
    IF layerIdx% >= 1 THEN
        IF layerIdx% < = MAX_LAYERS THEN
            IF LAYERS(layerIdx%).layerType% = LAYER_TYPE_GROUP THEN bpbIsGroup% = TRUE
        END IF
    END IF

    IF bpbIsGroup% THEN
        ' Groups get Pass Through at top, then divider, then Normal, divider, rest
        POPUP_MENU_set_item 0, BLEND_mode_name$(BLEND_PASS_THROUGH), "", BLEND_PASS_THROUGH_POPUP_VALUE, 0
        POPUP_MENU_set_item 1, "", "", -99, POPUP_MENU_FLAG_DIVIDER
        POPUP_MENU_set_item 2, BLEND_mode_name$(BLEND_NORMAL), "", BLEND_NORMAL, 0
        POPUP_MENU_set_item 3, "", "", -99, POPUP_MENU_FLAG_DIVIDER
        FOR itemRow% = 4 TO BLEND_MODE_COUNT + 2
            modeIdx% = itemRow% - 3
            POPUP_MENU_set_item itemRow%, BLEND_mode_name$(modeIdx%), "", modeIdx%, 0
        NEXT itemRow%
    ELSE
        POPUP_MENU_set_item 0, BLEND_mode_name$(BLEND_NORMAL), "", BLEND_NORMAL, 0
        POPUP_MENU_set_item 1, "", "", -99, POPUP_MENU_FLAG_DIVIDER
        FOR itemRow% = 2 TO BLEND_MODE_COUNT
            modeIdx% = itemRow% - 1
            POPUP_MENU_set_item itemRow%, BLEND_mode_name$(modeIdx%), "", modeIdx%, 0
        NEXT itemRow%
    END IF
END SUB


' ============================================================================
' GROUP LAYER OPERATIONS
' ============================================================================

''
' Create a new group layer above the current layer.
' Group layers use a 1x1 sentinel image (no real pixel data) and have
' layerType% = LAYER_TYPE_GROUP. They organize children via parentGroupIdx.
' @return INTEGER - Layer index of the new group, or 0 on failure
'
FUNCTION LAYERS_new_group% ()
    DIM newIndex AS INTEGER
    DIM i        AS INTEGER
    DIM currentZ AS INTEGER
    DIM newZ     AS INTEGER

    LAYERS_new_group% = 0

    ' Check if we've hit the max
    IF LAYER_COUNT% >= CFG.NUM_LAYERS% THEN EXIT FUNCTION

    ' Find first empty slot
    newIndex% = 0
    FOR i% = 1 TO MAX_LAYERS
        IF LAYERS(i%).imgHandle& = 0 THEN
            newIndex% = i%
            EXIT FOR
        END IF
    NEXT i%
    IF newIndex% = 0 THEN EXIT FUNCTION

    ' Insert above current layer (same logic as LAYERS_new%)
    DIM hasCurrentLayer AS INTEGER
    hasCurrentLayer% = FALSE
    IF CURRENT_LAYER% > 0 AND CURRENT_LAYER% < = MAX_LAYERS THEN
        IF LAYERS(CURRENT_LAYER%).imgHandle& <> 0 THEN
            hasCurrentLayer% = TRUE
        END IF
    END IF

    IF hasCurrentLayer% THEN
        currentZ% = LAYERS(CURRENT_LAYER%).zIndex%
        newZ%     = currentZ% + 1
        FOR i% = 1 TO MAX_LAYERS
            IF LAYERS(i%).imgHandle& <> 0 AND LAYERS(i%).zIndex% > currentZ% THEN
                LAYERS(i%).zIndex% = LAYERS(i%).zIndex% + 1
            END IF
        NEXT i%
    ELSE
        newZ% = LAYER_COUNT% + 1
    END IF

    ' Create 1x1 sentinel image (groups have no real pixel data)
    LAYERS(newIndex%).imgHandle& = _NEWIMAGE(1, 1, 32)
    IF LAYERS(newIndex%).imgHandle& >= -1 THEN
        LAYERS(newIndex%).imgHandle& = 0
        EXIT FUNCTION
    END IF
    DIM oldDest AS LONG
    oldDest& = _DEST
    _DEST LAYERS(newIndex%).imgHandle&
    CLS , _RGBA32(0, 0, 0, 0)
    _DEST oldDest&

    ' Set group properties
    LAYER_COUNT% = LAYER_COUNT% + 1
    NEXT_GROUP_NUM% = NEXT_GROUP_NUM% + 1
    LAYERS(newIndex%).historyId&    = LAYERS_alloc_history_id&
    LAYERS(newIndex%).imgWidth%     = 1
    LAYERS(newIndex%).imgHeight%    = 1
    LAYERS(newIndex%).apronW%       = 0
    LAYERS(newIndex%).apronH%       = 0
    LAYERS(newIndex%).zIndex%       = newZ%
    LAYERS(newIndex%).visible%      = TRUE
    LAYERS(newIndex%).isSelected%   = FALSE
    LAYERS(newIndex%).lastSelected% = FALSE
    LAYERS(newIndex%).name          = "Group " + _TRIM$(STR$(NEXT_GROUP_NUM%))
    LAYERS(newIndex%).opacity%      = 255
    LAYERS(newIndex%).opacityLock%  = FALSE
    LAYERS(newIndex%).blendMode%    = BLEND_NORMAL
    LAYERS(newIndex%).layerType%    = LAYER_TYPE_GROUP
    LAYERS(newIndex%).textDataIdx%  = 0
    ' Inherit parent group from the current layer so new groups inside groups stay nested
    IF hasCurrentLayer% THEN
        LAYERS(newIndex%).parentGroupIdx% = LAYERS(CURRENT_LAYER%).parentGroupIdx%
    ELSE
        LAYERS(newIndex%).parentGroupIdx% = 0
    END IF
    LAYERS(newIndex%).collapsed%   = FALSE
    LAYERS(newIndex%).passThrough% = TRUE

    IF NOT HISTORY_IN_PROGRESS% THEN
        HISTORY_record_layer_add LAYERS(newIndex%).historyId&, newIndex%, newZ%, "Group Add"
    END IF

    LAYERS_select newIndex%
    BLEND_invalidate_cache
    INVALIDATE_scene
    LAYERS_new_group% = newIndex%
END FUNCTION


''
' Create a group from the current multi-selection.
' Multi-selected layers are moved into the new group. The group header is
' placed at the topmost selected layer's zIndex position.
' @return INTEGER - Layer index of the new group, or 0 on failure
'
FUNCTION LAYERS_group_from_selection% ()
    DIM i        AS INTEGER
    DIM topZ     AS INTEGER
    DIM selCount AS INTEGER
    DIM groupIdx AS INTEGER

    LAYERS_group_from_selection% = 0

    ' Save multi-selection state BEFORE any operation that might clear it
    DIM savedSel(1 TO MAX_LAYERS) AS INTEGER
    FOR i% = 1 TO MAX_LAYERS
        savedSel%(i%) = MULTI_SELECT_LAYERS(i%)
    NEXT i%

    ' Expand selection: if a group is selected, also select all its descendants
    ' so they move into the new group together with their parent group
    DIM expandChanged AS INTEGER
    DO
        expandChanged% = FALSE
        FOR i% = 1 TO MAX_LAYERS
            IF LAYERS(i%).imgHandle& <> 0 AND NOT savedSel%(i%) THEN
                ' If this layer's parent is selected, include it too
                DIM walkPar AS INTEGER
                walkPar% = LAYERS(i%).parentGroupIdx%
                DO WHILE walkPar% > 0 AND walkPar% < = MAX_LAYERS
                    IF savedSel%(walkPar%) THEN
                        savedSel%(i%)  = TRUE
                        expandChanged% = TRUE
                        EXIT DO
                    END IF
                    walkPar% = LAYERS(walkPar%).parentGroupIdx%
                LOOP
            END IF
        NEXT i%
    LOOP WHILE expandChanged%

    ' Count selected layers, find the topmost zIndex, and determine common parent
    ' Only count top-level selected layers (those whose parent is NOT also selected)
    ' for the common-parent calculation
    DIM commonParent    AS INTEGER
    DIM gfsParentsMatch AS INTEGER
    selCount%        = 0
    topZ%            = 0
    commonParent%    = -1
    gfsParentsMatch% = TRUE
    FOR i% = 1 TO MAX_LAYERS
        IF LAYERS(i%).imgHandle& <> 0 AND savedSel%(i%) THEN
            selCount% = selCount% + 1
            IF LAYERS(i%).zIndex% > topZ% THEN topZ% = LAYERS(i%).zIndex%
            ' For common parent: only consider layers whose immediate parent is NOT selected
            ' (these are the "roots" of the selection)
            DIM gfsIsRoot AS INTEGER
            gfsIsRoot% = FALSE
            IF LAYERS(i%).parentGroupIdx% = 0 THEN
                gfsIsRoot% = TRUE
            ELSEIF NOT savedSel%(LAYERS(i%).parentGroupIdx%) THEN
                gfsIsRoot% = TRUE
            END IF
            IF gfsIsRoot% THEN
                IF commonParent% = -1 THEN
                    commonParent% = LAYERS(i%).parentGroupIdx%
                ELSEIF LAYERS(i%).parentGroupIdx% <> commonParent% THEN
                    gfsParentsMatch% = FALSE
                END IF
            END IF
        END IF
    NEXT i%

    ' Need at least 1 layer to group
    IF selCount% < 1 THEN EXIT FUNCTION

    ' Check nesting depth — creating a new parent group adds 1 level to all descendants
    DIM maxDepth AS INTEGER
    maxDepth% = 0
    FOR i% = 1 TO MAX_LAYERS
        IF LAYERS(i%).imgHandle& <> 0 AND savedSel%(i%) THEN
            DIM gfsDepth AS INTEGER
            gfsDepth% = LAYERS_nesting_depth%(i%)
            IF gfsDepth% > maxDepth% THEN maxDepth% = gfsDepth%
        END IF
    NEXT i%
    IF maxDepth% + 1 > MAX_GROUP_NESTING THEN EXIT FUNCTION

    ' If all selected root layers share the same parent, the new group inherits it
    ' Otherwise default to top-level (0)
    IF commonParent% = -1 OR NOT gfsParentsMatch% THEN commonParent% = 0

    ' Create the group header — temporarily select the topmost selected layer
    ' so LAYERS_new_group% inserts above it
    DIM prevLayer AS INTEGER
    prevLayer% = CURRENT_LAYER%
    FOR i% = 1 TO MAX_LAYERS
        IF LAYERS(i%).imgHandle& <> 0 AND LAYERS(i%).zIndex% = topZ% THEN
            LAYERS_select i%
            EXIT FOR
        END IF
    NEXT i%

    HISTORY_begin_group

    groupIdx% = LAYERS_new_group%
    IF groupIdx% = 0 THEN
        HISTORY_end_group
        EXIT FUNCTION
    END IF

    ' Parent the new group to the common parent of selected layers
    ' LAYERS_new_group% inherits parentGroupIdx from CURRENT_LAYER%, which may
    ' be wrong when selected layers span different groups (common parent = root).
    DIM gfsOldGroupParent AS INTEGER
    gfsOldGroupParent% = LAYERS(groupIdx%).parentGroupIdx%
    IF gfsOldGroupParent% <> commonParent% THEN
        LAYERS(groupIdx%).parentGroupIdx% = commonParent%
        HISTORY_record_group_reparent LAYERS(groupIdx%).historyId&, groupIdx%, gfsOldGroupParent%, commonParent%, LAYERS(groupIdx%).zIndex%, LAYERS(groupIdx%).zIndex%, "Group Nest"
    END IF

    ' Move selected layers into the group
    ' Only reparent "root" selected layers (those whose parent is NOT selected);
    ' children of selected groups keep their existing parent.
    DIM groupZ AS INTEGER
    groupZ% = LAYERS(groupIdx%).zIndex%

    ' Build sorted list of ALL selected layers by zIndex (ascending)
    DIM sortBuf(1 TO MAX_LAYERS) AS INTEGER
    DIM sortN       AS INTEGER
    sortN% = 0
    FOR i% = 1 TO MAX_LAYERS
        IF LAYERS(i%).imgHandle& <> 0 AND i% <> groupIdx% AND savedSel%(i%) THEN
            sortN% = sortN% + 1
            sortBuf%(sortN%) = i%
        END IF
    NEXT i%
    ' Simple insertion sort by zIndex
    DIM j           AS INTEGER, tmpSort AS INTEGER
    DIM gfsSortCont AS INTEGER
    FOR i% = 2 TO sortN%
        tmpSort%     = sortBuf%(i%)
        j%           = i% - 1
        gfsSortCont% = TRUE
        DO WHILE j% >= 1 AND gfsSortCont%
            IF LAYERS(sortBuf%(j%)).zIndex% > LAYERS(tmpSort%).zIndex% THEN
                sortBuf%(j% + 1) = sortBuf%(j%)
                j% = j% - 1
            ELSE
                gfsSortCont% = FALSE
            END IF
        LOOP
        sortBuf%(j% + 1) = tmpSort%
    NEXT i%

    ' Reparent root selected layers to the new group; leave descendants' parents intact
    FOR i% = 1 TO sortN%
        DIM gfsLayerIdx   AS INTEGER : gfsLayerIdx% = sortBuf%(i%)
        DIM gfsOldParent  AS INTEGER : gfsOldParent% = LAYERS(gfsLayerIdx%).parentGroupIdx%
        ' Only reparent if this layer's current parent is NOT in the selection
        ' (i.e., it's a "root" of the selected subtree)
        DIM gfsDoReparent AS INTEGER
        gfsDoReparent% = FALSE
        IF gfsOldParent% = 0 THEN
            gfsDoReparent% = TRUE
        ELSEIF NOT savedSel%(gfsOldParent%) THEN
            gfsDoReparent% = TRUE
        END IF
        IF gfsDoReparent% THEN
            HISTORY_record_group_reparent LAYERS(gfsLayerIdx%).historyId&, gfsLayerIdx%, gfsOldParent%, groupIdx%, LAYERS(gfsLayerIdx%).zIndex%, LAYERS(gfsLayerIdx%).zIndex%, "Group Child"
            LAYERS(gfsLayerIdx%).parentGroupIdx% = groupIdx%
        END IF
    NEXT i%

    ' Enforce contiguity — children below group header in zIndex order
    LAYERS_enforce_group_contiguity

    HISTORY_end_group

    LAYERS_select groupIdx%
    BLEND_invalidate_cache
    INVALIDATE_scene
    LAYERS_group_from_selection% = groupIdx%
END FUNCTION


''
' Remove a group container, promoting direct children to the parent group (or top-level).
' Children keep their relative zIndex order. The group layer is deleted.
' @param groupIdx% Layer index of the group to ungroup
'
SUB LAYERS_ungroup (groupIdx AS INTEGER)
    DIM i AS INTEGER

    ' CRITICAL: Copy parameter to local — QB64 passes by reference.
    DIM ugSlot AS INTEGER
    ugSlot% = groupIdx%

    ' Validate
    IF ugSlot% < 1 OR ugSlot% > MAX_LAYERS THEN EXIT SUB
    IF LAYERS(ugSlot%).imgHandle& = 0 THEN EXIT SUB
    IF LAYERS(ugSlot%).layerType% <> LAYER_TYPE_GROUP THEN EXIT SUB

    HISTORY_begin_group

    ' Promote direct children to this group's parent (grandparent or 0)
    DIM ugNewParent AS INTEGER
    ugNewParent% = LAYERS(ugSlot%).parentGroupIdx%
    FOR i% = 1 TO MAX_LAYERS
        IF LAYERS(i%).imgHandle& <> 0 AND LAYERS(i%).parentGroupIdx% = ugSlot% THEN
            DIM ugOldZ AS INTEGER: ugOldZ% = LAYERS(i%).zIndex%
            HISTORY_record_group_reparent LAYERS(i%).historyId&, i%, ugSlot%, ugNewParent%, ugOldZ%, ugOldZ%, "Ungroup Child"
            LAYERS(i%).parentGroupIdx% = ugNewParent%
        END IF
    NEXT i%

    ' Delete the group header
    LAYERS_delete ugSlot%

    HISTORY_end_group

    BLEND_invalidate_cache
    INVALIDATE_scene
END SUB


''
' Move a layer into a group. Sets parentGroupIdx and adjusts zIndex
' so the layer is contiguous within the group's range.
' @param layerIdx% Layer to move into the group
' @param groupIdx% Target group layer index
'
SUB LAYERS_move_into_group (layerIdx AS INTEGER, groupIdx AS INTEGER)
    ' Validate both indices
    IF layerIdx% < 1 OR layerIdx% > MAX_LAYERS THEN EXIT SUB
    IF groupIdx% < 1 OR groupIdx% > MAX_LAYERS THEN EXIT SUB
    IF LAYERS(layerIdx%).imgHandle& = 0 THEN EXIT SUB
    IF LAYERS(groupIdx%).imgHandle& = 0 THEN EXIT SUB
    IF LAYERS(groupIdx%).layerType% <> LAYER_TYPE_GROUP THEN EXIT SUB

    ' Prevent circular nesting: can't move a group into itself or any descendant
    IF layerIdx% = groupIdx% THEN EXIT SUB
    IF LAYERS(layerIdx%).layerType% = LAYER_TYPE_GROUP THEN
        ' Walk up from groupIdx to make sure layerIdx is not an ancestor
        DIM migCheckParent AS INTEGER
        migCheckParent% = LAYERS(groupIdx%).parentGroupIdx%
        DO WHILE migCheckParent% > 0
            IF migCheckParent% = layerIdx% THEN EXIT SUB  ' Would create cycle
            IF migCheckParent% < 1 OR migCheckParent% > MAX_LAYERS THEN EXIT DO
            IF LAYERS(migCheckParent%).imgHandle& = 0 THEN EXIT DO
            migCheckParent% = LAYERS(migCheckParent%).parentGroupIdx%
        LOOP
    END IF

    ' Enforce max nesting depth
    DIM migTargetDepth AS INTEGER
    migTargetDepth% = LAYERS_nesting_depth%(groupIdx%) + 1
    IF LAYERS(layerIdx%).layerType% = LAYER_TYPE_GROUP THEN
        ' A group being nested adds its own max-child depth
        DIM migMaxChildDepth AS INTEGER
        DIM migScanChild     AS INTEGER
        migMaxChildDepth% = 0
        FOR migScanChild% = 1 TO MAX_LAYERS
            IF LAYERS(migScanChild%).imgHandle& <> 0 THEN
                IF LAYERS(migScanChild%).parentGroupIdx% = layerIdx% THEN
                    DIM migChildD AS INTEGER
                    migChildD% = LAYERS_nesting_depth%(migScanChild%) - LAYERS_nesting_depth%(layerIdx%)
                    IF migChildD% > migMaxChildDepth% THEN migMaxChildDepth% = migChildD%
                END IF
            END IF
        NEXT migScanChild%
        IF migTargetDepth% + migMaxChildDepth% > MAX_GROUP_NESTING THEN EXIT SUB
    ELSE
        IF migTargetDepth% > MAX_GROUP_NESTING THEN EXIT SUB
    END IF

    ' Already in this group?
    IF LAYERS(layerIdx%).parentGroupIdx% = groupIdx% THEN EXIT SUB

    DIM migOldParent AS INTEGER : migOldParent% = LAYERS(layerIdx%).parentGroupIdx%
    DIM migOldZ      AS INTEGER : migOldZ% = LAYERS(layerIdx%).zIndex%

    LAYERS(layerIdx%).parentGroupIdx% = groupIdx%
    LAYERS_enforce_group_contiguity

    IF NOT HISTORY_IN_PROGRESS% THEN
        HISTORY_record_group_reparent LAYERS(layerIdx%).historyId&, layerIdx%, migOldParent%, groupIdx%, migOldZ%, LAYERS(layerIdx%).zIndex%, "Move to Group"
    END IF

    BLEND_invalidate_cache
    INVALIDATE_scene
    GUI_NEEDS_REDRAW% = TRUE
END SUB


''
' Move a layer out of its group to the parent group (or top-level if none).
' The layer is placed just above the group header in zIndex order.
' @param layerIdx% Layer to remove from its group
'
SUB LAYERS_move_out_of_group (layerIdx AS INTEGER)
    DIM groupIdx AS INTEGER

    IF layerIdx% < 1 OR layerIdx% > MAX_LAYERS THEN EXIT SUB
    IF LAYERS(layerIdx%).imgHandle& = 0 THEN EXIT SUB

    groupIdx% = LAYERS(layerIdx%).parentGroupIdx%
    IF groupIdx% = 0 THEN EXIT SUB  ' Not in a group

    DIM mogOldParent AS INTEGER : mogOldParent% = groupIdx%
    DIM mogOldZ      AS INTEGER : mogOldZ% = LAYERS(layerIdx%).zIndex%

    ' Reparent to grandparent (or 0 for top-level)
    DIM mogNewParent AS INTEGER
    mogNewParent%                     = LAYERS(groupIdx%).parentGroupIdx%
    LAYERS(layerIdx%).parentGroupIdx% = mogNewParent%

    ' Place layer just above the group header
    DIM groupZ AS INTEGER
    groupZ% = LAYERS(groupIdx%).zIndex%
    DIM i      AS INTEGER
    ' Shift everything above group header up by 1 to make room
    FOR i% = 1 TO MAX_LAYERS
        IF LAYERS(i%).imgHandle& <> 0 AND LAYERS(i%).zIndex% > groupZ% THEN
            LAYERS(i%).zIndex% = LAYERS(i%).zIndex% + 1
        END IF
    NEXT i%
    LAYERS(layerIdx%).zIndex% = groupZ% + 1

    LAYERS_enforce_group_contiguity

    IF NOT HISTORY_IN_PROGRESS% THEN
        HISTORY_record_group_reparent LAYERS(layerIdx%).historyId&, layerIdx%, mogOldParent%, mogNewParent%, mogOldZ%, LAYERS(layerIdx%).zIndex%, "Move from Group"
    END IF

    BLEND_invalidate_cache
    INVALIDATE_scene
    GUI_NEEDS_REDRAW% = TRUE
END SUB


''
' Count children in a group.
' @param groupIdx% Group layer index
' @return INTEGER Number of children whose parentGroupIdx matches
'
FUNCTION LAYERS_group_child_count% (groupIdx AS INTEGER)
    DIM i   AS INTEGER
    DIM cnt AS INTEGER
    cnt% = 0
    IF groupIdx% < 1 OR groupIdx% > MAX_LAYERS THEN
        LAYERS_group_child_count% = 0
        EXIT FUNCTION
    END IF
    FOR i% = 1 TO MAX_LAYERS
        IF LAYERS(i%).imgHandle& <> 0 AND LAYERS(i%).parentGroupIdx% = groupIdx% THEN
            cnt% = cnt% + 1
        END IF
    NEXT i%
    LAYERS_group_child_count% = cnt%
END FUNCTION


''
' Get ALL descendants of a group recursively, sorted by zIndex ascending.
' Includes children, grandchildren, etc. — every layer whose ancestor chain
' passes through groupIdx%. Does NOT include groupIdx% itself.
' @param groupIdx% Group layer index (root of subtree)
' @param outArray%() Pre-allocated array (1 TO MAX_LAYERS) to receive descendant indices
' @param outCount% Returns the number of descendants found
'
SUB LAYERS_group_descendants (groupIdx AS INTEGER, outArray() AS INTEGER, outCount AS INTEGER)
    DIM gdI   AS INTEGER
    DIM gdJ   AS INTEGER
    DIM gdTmp AS INTEGER
    outCount% = 0

    IF groupIdx% < 1 OR groupIdx% > MAX_LAYERS THEN EXIT SUB

    ' Collect all layers whose ancestor chain includes groupIdx%
    FOR gdI% = 1 TO MAX_LAYERS
        IF LAYERS(gdI%).imgHandle& <> 0 AND gdI% <> groupIdx% THEN
            ' Walk up parent chain to see if this layer descends from groupIdx%
            DIM gdWalk  AS INTEGER
            gdWalk% = LAYERS(gdI%).parentGroupIdx%
            DIM gdFound AS INTEGER
            gdFound% = FALSE
            DIM gdSafe  AS INTEGER
            gdSafe% = 0
            DO WHILE gdWalk% > 0 AND gdSafe% < MAX_GROUP_NESTING
                IF gdWalk% = groupIdx% THEN
                    gdFound% = TRUE
                    EXIT DO
                END IF
                IF gdWalk% < 1 OR gdWalk% > MAX_LAYERS THEN EXIT DO
                IF LAYERS(gdWalk%).imgHandle& = 0 THEN EXIT DO
                gdWalk% = LAYERS(gdWalk%).parentGroupIdx%
                gdSafe% = gdSafe% + 1
            LOOP
            IF gdFound% THEN
                outCount% = outCount% + 1
                outArray%(outCount%) = gdI%
            END IF
        END IF
    NEXT gdI%

    ' Sort by zIndex ascending (insertion sort)
    DIM gdSortCont AS INTEGER
    FOR gdI% = 2 TO outCount%
        gdTmp%      = outArray%(gdI%)
        gdJ%        = gdI% - 1
        gdSortCont% = TRUE
        DO WHILE gdJ% >= 1 AND gdSortCont%
            IF LAYERS(outArray%(gdJ%)).zIndex% > LAYERS(gdTmp%).zIndex% THEN
                outArray%(gdJ% + 1) = outArray%(gdJ%)
                gdJ% = gdJ% - 1
            ELSE
                gdSortCont% = FALSE
            END IF
        LOOP
        outArray%(gdJ% + 1) = gdTmp%
    NEXT gdI%
END SUB


''
' Get sorted list of child layer indices for a group (sorted by zIndex ascending).
' @param groupIdx% Group layer index
' @param outArray%() Pre-allocated array (1 TO MAX_LAYERS) to receive child indices
' @param outCount% Returns the number of children found
'
SUB LAYERS_group_children (groupIdx AS INTEGER, outArray() AS INTEGER, outCount AS INTEGER)
    DIM i       AS INTEGER
    DIM j       AS INTEGER
    DIM tmpSwap AS INTEGER
    outCount% = 0

    IF groupIdx% < 1 OR groupIdx% > MAX_LAYERS THEN EXIT SUB

    ' Collect children
    FOR i% = 1 TO MAX_LAYERS
        IF LAYERS(i%).imgHandle& <> 0 AND LAYERS(i%).parentGroupIdx% = groupIdx% THEN
            outCount% = outCount% + 1
            outArray%(outCount%) = i%
        END IF
    NEXT i%

    ' Sort by zIndex ascending (insertion sort)
    DIM gcSortCont AS INTEGER
    FOR i% = 2 TO outCount%
        tmpSwap%    = outArray%(i%)
        j%          = i% - 1
        gcSortCont% = TRUE
        DO WHILE j% >= 1 AND gcSortCont%
            IF LAYERS(outArray%(j%)).zIndex% > LAYERS(tmpSwap%).zIndex% THEN
                outArray%(j% + 1) = outArray%(j%)
                j% = j% - 1
            ELSE
                gcSortCont% = FALSE
            END IF
        LOOP
        outArray%(j% + 1) = tmpSwap%
    NEXT i%
END SUB


''
' Get the zIndex range for a group (including group header and all children).
' @param groupIdx% Group layer index
' @param outMinZ% Returns the minimum zIndex in the group
' @param outMaxZ% Returns the maximum zIndex in the group
'
SUB LAYERS_group_zIndex_range (groupIdx AS INTEGER, outMinZ AS INTEGER, outMaxZ AS INTEGER)
    DIM i AS INTEGER
    outMinZ% = 9999
    outMaxZ% = 0

    IF groupIdx% < 1 OR groupIdx% > MAX_LAYERS THEN EXIT SUB
    IF LAYERS(groupIdx%).imgHandle& = 0 THEN EXIT SUB

    ' Include the group header itself
    outMinZ% = LAYERS(groupIdx%).zIndex%
    outMaxZ% = LAYERS(groupIdx%).zIndex%

    ' Scan children
    FOR i% = 1 TO MAX_LAYERS
        IF LAYERS(i%).imgHandle& <> 0 AND LAYERS(i%).parentGroupIdx% = groupIdx% THEN
            IF LAYERS(i%).zIndex% < outMinZ% THEN outMinZ% = LAYERS(i%).zIndex%
            IF LAYERS(i%).zIndex% > outMaxZ% THEN outMaxZ% = LAYERS(i%).zIndex%
        END IF
    NEXT i%
END SUB


''
' Enforce that all children of each group have contiguous zIndices
' with the group header at the top of its children's range.
' Supports nested groups: child groups are recursively expanded so their
' sub-children appear contiguously below them, before the parent group header.
' Called after any reorder/add/delete that might break contiguity.
'
SUB LAYERS_enforce_group_contiguity ()
    ' Rebuild all zIndex values so that:
    ' 1. Non-grouped layers and group headers maintain their relative order
    ' 2. Group children (recursively) are placed contiguously just below group header
    ' 3. No duplicate zIndex values exist

    DIM i AS INTEGER
    DIM j AS INTEGER

    ' --- Helper: sort a sub-range of a buffer by zIndex ascending (insertion sort) ---
    ' We'll use shared local arrays and inline the sort since QB64 doesn't have closures.

    ' --- Step 1: Collect top-level layers (parentGroupIdx = 0), sorted by zIndex ---
    DIM topBuf(1 TO MAX_LAYERS) AS INTEGER
    DIM topCount AS INTEGER
    topCount% = 0
    FOR i% = 1 TO MAX_LAYERS
        IF LAYERS(i%).imgHandle& = 0 THEN _CONTINUE
        IF LAYERS(i%).parentGroupIdx% > 0 THEN _CONTINUE
        topCount% = topCount% + 1
        topBuf%(topCount%) = i%
    NEXT i%

    ' Sort topBuf by zIndex ascending
    DIM tmpSwap  AS INTEGER
    DIM sortCont AS INTEGER
    FOR i% = 2 TO topCount%
        tmpSwap%  = topBuf%(i%)
        j%        = i% - 1
        sortCont% = TRUE
        DO WHILE j% >= 1 AND sortCont%
            IF LAYERS(topBuf%(j%)).zIndex% > LAYERS(tmpSwap%).zIndex% THEN
                topBuf%(j% + 1) = topBuf%(j%)
                j% = j% - 1
            ELSE
                sortCont% = FALSE
            END IF
        LOOP
        topBuf%(j% + 1) = tmpSwap%
    NEXT i%

    ' --- Step 2: Build final z-order using iterative DFS with manual stack ---
    ' For each top-level item: if it's a group, recursively emit its children
    ' (depth-first), then emit the group header itself. Child groups within
    ' are handled the same way — their sub-children come first, then the child
    ' group header, all before the parent group header.
    DIM finalOrder(1 TO MAX_LAYERS) AS INTEGER
    DIM finalCount AS INTEGER
    finalCount% = 0

    ' DFS stack: each entry is a layer index to process.
    ' We push items in reverse order so they come out in forward order.
    DIM dfsStack(1 TO MAX_LAYERS) AS INTEGER
    DIM dfsTop AS INTEGER
    dfsTop% = 0

    ' Temp buffer for gathering + sorting children of a group
    DIM childBuf(1 TO MAX_LAYERS) AS INTEGER
    DIM childCount AS INTEGER

    ' Push top-level items in REVERSE order (so first pops first)
    FOR i% = topCount% TO 1 STEP -1
        dfsTop% = dfsTop% + 1
        dfsStack%(dfsTop%) = topBuf%(i%)
    NEXT i%

    DO WHILE dfsTop% > 0
        DIM stackVal AS INTEGER
        stackVal% = dfsStack%(dfsTop%)
        dfsTop% = dfsTop% - 1

        IF stackVal% < 0 THEN
            ' Negative = group header emit pass, just add to output
            finalCount% = finalCount% + 1
            finalOrder%(finalCount%) = -stackVal%
        ELSE
            DIM curIdx AS INTEGER
            curIdx% = stackVal%
            IF LAYERS(curIdx%).layerType% = LAYER_TYPE_GROUP THEN
                ' Gather direct children of this group
                childCount% = 0
                FOR i% = 1 TO MAX_LAYERS
                    IF LAYERS(i%).imgHandle& <> 0 THEN
                        IF LAYERS(i%).parentGroupIdx% = curIdx% THEN
                            childCount% = childCount% + 1
                            childBuf%(childCount%) = i%
                        END IF
                    END IF
                NEXT i%

                ' Sort children by zIndex ascending
                FOR i% = 2 TO childCount%
                    tmpSwap%  = childBuf%(i%)
                    j%        = i% - 1
                    sortCont% = TRUE
                    DO WHILE j% >= 1 AND sortCont%
                        IF LAYERS(childBuf%(j%)).zIndex% > LAYERS(tmpSwap%).zIndex% THEN
                            childBuf%(j% + 1) = childBuf%(j%)
                            j% = j% - 1
                        ELSE
                            sortCont% = FALSE
                        END IF
                    LOOP
                    childBuf%(j% + 1) = tmpSwap%
                NEXT i%

                ' Push group header (negative = emit directly), then children reversed
                dfsTop% = dfsTop% + 1
                dfsStack%(dfsTop%) = -curIdx%
                FOR i% = childCount% TO 1 STEP -1
                    dfsTop% = dfsTop% + 1
                    dfsStack%(dfsTop%) = childBuf%(i%)
                NEXT i%
            ELSE
                ' Non-group layer — emit directly
                finalCount% = finalCount% + 1
                finalOrder%(finalCount%) = curIdx%
            END IF
        END IF
    LOOP

    ' --- Step 3: Assign contiguous zIndex 1..finalCount ---
    FOR i% = 1 TO finalCount%
        LAYERS(finalOrder%(i%)).zIndex% = i%
    NEXT i%

    ' Update LAYER_COUNT if needed
    IF finalCount% > 0 AND finalCount% <> LAYER_COUNT% THEN
        LAYER_COUNT% = finalCount%
    END IF

    ' Rebuild render order after contiguity fix
    RENDER_ORDER_DIRTY% = TRUE
END SUB


''
' Merge all children of a group into a single image layer.
' The group container and all children are deleted; replaced by one image layer.
' @param groupIdx% Group layer index to merge
'
SUB LAYERS_merge_group (groupIdx AS INTEGER)
    DIM i          AS INTEGER
    DIM oldDest    AS LONG
    DIM tempImg    AS LONG
    DIM childBuf(1 TO MAX_LAYERS) AS INTEGER
    DIM childCount AS INTEGER

    ' CRITICAL: Copy parameter to local variable immediately.
    ' groupIdx% is passed by reference (QB64 default).  Callers pass
    ' CURRENT_LAYER%, which LAYERS_select (called inside LAYERS_new%)
    ' can change mid-function, corrupting our reference.
    DIM grpSlot AS INTEGER
    grpSlot% = groupIdx%

    ' Save group name before any deletions
    DIM grpName AS STRING
    grpName$ = LAYERS(grpSlot%).name

    ' Save group's blend mode and opacity so the merged result inherits them
    DIM grpBlendMode AS INTEGER
    DIM grpOpacity   AS INTEGER
    grpBlendMode% = LAYERS(grpSlot%).blendMode%
    grpOpacity%   = LAYERS(grpSlot%).opacity%

    ' Validate
    IF grpSlot% < 1 OR grpSlot% > MAX_LAYERS THEN EXIT SUB
    IF LAYERS(grpSlot%).imgHandle& = 0 THEN EXIT SUB
    IF LAYERS(grpSlot%).layerType% <> LAYER_TYPE_GROUP THEN EXIT SUB

    ' Get ALL descendants (recursive), sorted by zIndex ascending (bottom to top)
    childCount% = 0
    LAYERS_group_descendants grpSlot%, childBuf%(), childCount%
    IF childCount% = 0 THEN
        ' Empty group — just delete the group header
        LAYERS_delete grpSlot%
        EXIT SUB
    END IF

    ' Record history BEFORE performing the merge (snapshot all children + group header)
    IF NOT HISTORY_IN_PROGRESS% THEN
        HISTORY_record_merge_group grpSlot%, childBuf%(), childCount%
    END IF

    ' Create a temporary composite image
    tempImg& = _NEWIMAGE(SCRN.canvasW&, SCRN.canvasH&, 32)
    IF tempImg& >= -1 THEN EXIT SUB
    oldDest& = _DEST
    _DEST tempImg&
    CLS , _RGBA32(0, 0, 0, 0)
    _DEST oldDest&

    ' Composite non-group children bottom-to-top (skip group headers — they're 1x1 sentinels)
    FOR i% = 1 TO childCount%
        DIM cIdx AS INTEGER
        cIdx% = childBuf%(i%)
        IF LAYERS(cIdx%).layerType% = LAYER_TYPE_GROUP THEN _CONTINUE
        IF LAYERS(cIdx%).imgHandle& < -1 AND LAYERS(cIdx%).visible% THEN
            IF LAYERS(cIdx%).layerType% = LAYER_TYPE_TEXT AND LAYERS(cIdx%).textDataIdx% > 0 THEN
                TEXT_LAYER_render cIdx%, LAYERS(cIdx%).imgHandle&
            END IF
            IF LAYERS(cIdx%).blendMode% <> BLEND_NORMAL THEN
                LAYER_blend_composite tempImg&, LAYERS(cIdx%).imgHandle&, LAYERS(cIdx%).blendMode%, LAYERS(cIdx%).opacity%
            ELSEIF LAYERS(cIdx%).opacity% < 255 THEN
                DIM tempChild AS LONG
                tempChild& = _COPYIMAGE(LAYERS(cIdx%).imgHandle&, 32)
                DIM mrgMem    AS _MEM
                DIM mrgOff    AS _OFFSET
                DIM mrgPix    AS _UNSIGNED LONG
                DIM mrgA      AS _UNSIGNED _BYTE
                DIM mrgNA     AS INTEGER
                mrgMem = _MEMIMAGE(tempChild&)
                FOR mrgOff = mrgMem.OFFSET TO mrgMem.OFFSET + mrgMem.SIZE - 4 STEP 4
                    _MEMGET mrgMem, mrgOff, mrgPix~&
                    mrgA~%% = _ALPHA32(mrgPix~&)
                    IF mrgA~%% > 0 THEN
                        mrgNA% = (mrgA~%% * LAYERS(cIdx%).opacity%) \ 255
                        _MEMPUT mrgMem, mrgOff + 3, mrgNA% AS _UNSIGNED _BYTE
                    END IF
                NEXT mrgOff
                _MEMFREE mrgMem
                oldDest& = _DEST
                _DEST tempImg&
                _BLEND tempImg&
                _PUTIMAGE , tempChild&
                _DEST oldDest&
                IF tempChild& < -1 THEN _FREEIMAGE tempChild&
            ELSE
                oldDest& = _DEST
                _DEST tempImg&
                _BLEND tempImg&
                _PUTIMAGE , LAYERS(cIdx%).imgHandle&
                _DEST oldDest&
            END IF
        END IF
    NEXT i%

    ' Delete all descendants (suppress history for each — we recorded above)
    DIM mgWasInProgress AS INTEGER
    mgWasInProgress%     = HISTORY_IN_PROGRESS%
    HISTORY_IN_PROGRESS% = TRUE
    FOR i% = childCount% TO 1 STEP -1
        IF LAYERS(childBuf%(i%)).imgHandle& <> 0 THEN
            LAYERS_delete childBuf%(i%)
        END IF
    NEXT i%

    ' Create a new image layer BEFORE deleting the group header.
    ' LAYERS_delete refuses to delete the last layer (LAYER_COUNT <= 1),
    ' so we must ensure another layer exists first.
    ' Select the group header so LAYERS_new% inserts at the correct z-position
    ' (child deletions above may have moved CURRENT_LAYER% elsewhere).
    LAYERS_select grpSlot%
    DIM newIdx AS INTEGER
    newIdx% = LAYERS_new%
    IF newIdx% > 0 THEN
        IF LAYERS(newIdx%).imgHandle& < -1 THEN _FREEIMAGE LAYERS(newIdx%).imgHandle&
        LAYERS(newIdx%).imgHandle&    = tempImg&
        LAYERS(newIdx%).imgWidth%     = _WIDTH(tempImg&)
        LAYERS(newIdx%).imgHeight%    = _HEIGHT(tempImg&)
        LAYERS(newIdx%).apronW%       = 0
        LAYERS(newIdx%).apronH%       = 0
        LAYERS(newIdx%).name          = grpName$
        LAYERS(newIdx%).contentDirty% = TRUE
        ' Inherit group's blend mode and opacity
        LAYERS(newIdx%).blendMode% = grpBlendMode%
        LAYERS(newIdx%).opacity%   = grpOpacity%
        ' Ensure merged layer is NOT inside the group we're about to delete
        LAYERS(newIdx%).parentGroupIdx% = LAYERS(grpSlot%).parentGroupIdx%
    ELSE
        IF tempImg& < -1 THEN _FREEIMAGE tempImg&
    END IF

    ' Now delete the group header (LAYER_COUNT > 1 since we just added the merged layer)
    IF LAYERS(grpSlot%).imgHandle& <> 0 THEN
        LAYERS_delete grpSlot%
    END IF
    HISTORY_IN_PROGRESS% = mgWasInProgress%

    ' Update the history record with the merged result layer's ID and slot
    IF NOT mgWasInProgress% AND newIdx% > 0 THEN
        HISTORY_merge_group_update_result LAYERS(newIdx%).historyId&, newIdx%
    END IF

    IF newIdx% > 0 THEN LAYERS_select newIdx%
    BLEND_invalidate_cache
    INVALIDATE_scene
END SUB


''
' Select all descendants + the group header via multi-select (recursive).
' @param groupIdx% Group layer index
'
SUB LAYERS_select_group (groupIdx AS INTEGER)
    DIM i AS INTEGER

    ' CRITICAL: Copy parameter to local — QB64 passes by reference.
    DIM sgSlot AS INTEGER
    sgSlot% = groupIdx%

    IF sgSlot% < 1 OR sgSlot% > MAX_LAYERS THEN EXIT SUB
    IF LAYERS(sgSlot%).imgHandle& = 0 THEN EXIT SUB
    IF LAYERS(sgSlot%).layerType% <> LAYER_TYPE_GROUP THEN EXIT SUB

    ' Select the group header first
    LAYERS_select sgSlot%
    MULTI_SELECT_clear

    ' Add all descendants to multi-select (walk parent chain for each layer)
    FOR i% = 1 TO MAX_LAYERS
        IF LAYERS(i%).imgHandle& <> 0 AND i% <> sgSlot% THEN
            DIM sgWalk AS INTEGER
            sgWalk% = LAYERS(i%).parentGroupIdx%
            DO WHILE sgWalk% > 0
                IF sgWalk% = sgSlot% THEN
                    MULTI_SELECT_LAYERS(i%) = TRUE
                    MULTI_SELECT_COUNT% = MULTI_SELECT_COUNT% + 1
                    EXIT DO
                END IF
                IF sgWalk% < 1 OR sgWalk% > MAX_LAYERS THEN EXIT DO
                IF LAYERS(sgWalk%).imgHandle& = 0 THEN EXIT DO
                sgWalk% = LAYERS(sgWalk%).parentGroupIdx%
            LOOP
        END IF
    NEXT i%

    GUI_NEEDS_REDRAW% = TRUE
END SUB


''
' Delete a group — asks the user whether to delete contents or ungroup.
' @param groupIdx% Group layer index
'
SUB LAYERS_delete_group (groupIdx AS INTEGER)
    DIM childCount AS INTEGER
    DIM result     AS INTEGER

    ' CRITICAL: Copy parameter to local — QB64 passes by reference.
    DIM dgSlot AS INTEGER
    dgSlot% = groupIdx%

    IF dgSlot% < 1 OR dgSlot% > MAX_LAYERS THEN EXIT SUB
    IF LAYERS(dgSlot%).imgHandle& = 0 THEN EXIT SUB
    IF LAYERS(dgSlot%).layerType% <> LAYER_TYPE_GROUP THEN EXIT SUB

    childCount% = LAYERS_group_child_count%(dgSlot%)

    IF childCount% = 0 THEN
        ' Empty group — just delete
        LAYERS_delete dgSlot%
        EXIT SUB
    END IF

    ' Ask user via DRAW's own message box
    result% = DRAW_message_box%("Delete Group", "Group has" + STR$(childCount%) + " layer(s)." + CHR$(10) + CHR$(10) + "Yes = Delete group and all contents" + CHR$(10) + "No = Ungroup (keep layers)" + CHR$(10) + "Cancel = Do nothing", MB_BTN_YES_NO_CANCEL, MB_ICON_QUESTION)

    IF result% = MB_RESULT_1 THEN
        ' Yes: Delete all descendants recursively
        HISTORY_begin_group
        DIM i      AS INTEGER
        DIM dgPass AS INTEGER
        ' Delete in multiple passes: leaf layers first, then sub-groups, then header
        ' (deleting a group orphans its children, so we delete bottom-up by depth)
        FOR dgPass% = MAX_GROUP_NESTING TO 1 STEP -1
            FOR i% = 1 TO MAX_LAYERS
                IF LAYERS(i%).imgHandle& <> 0 AND LAYERS(i%).parentGroupIdx% <> 0 THEN
                    ' Check if this is a descendant of dgSlot at any depth
                    DIM dgWalk   AS INTEGER
                    dgWalk% = LAYERS(i%).parentGroupIdx%
                    DIM dgIsDesc AS INTEGER
                    dgIsDesc% = FALSE
                    DO WHILE dgWalk% > 0
                        IF dgWalk% = dgSlot% THEN dgIsDesc% = TRUE: EXIT DO
                        IF dgWalk% < 1 OR dgWalk% > MAX_LAYERS THEN EXIT DO
                        IF LAYERS(dgWalk%).imgHandle& = 0 THEN EXIT DO
                        dgWalk% = LAYERS(dgWalk%).parentGroupIdx%
                    LOOP
                    IF dgIsDesc% THEN
                        IF LAYERS_nesting_depth%(i%) >= dgPass% THEN
                            LAYERS_delete i%
                        END IF
                    END IF
                END IF
            NEXT i%
        NEXT dgPass%
        ' Delete remaining direct children and the group header itself
        FOR i% = 1 TO MAX_LAYERS
            IF LAYERS(i%).imgHandle& <> 0 AND LAYERS(i%).parentGroupIdx% = dgSlot% THEN
                LAYERS_delete i%
            END IF
        NEXT i%
        LAYERS_delete dgSlot%
        HISTORY_end_group
        BLEND_invalidate_cache
        INVALIDATE_scene
    ELSEIF result% = MB_RESULT_2 THEN
        ' No: Ungroup (keep layers)
        LAYERS_ungroup dgSlot%
    END IF
    ' Cancel / X close = do nothing
END SUB


''
' Toggle visibility of a group and all its descendants (recursive).
' When hiding: saves each descendant's current visibility state.
' When showing: restores saved visibility states.
' @param groupIdx% Group layer index
'
SUB LAYERS_toggle_group_visibility (groupIdx AS INTEGER)
    DIM i AS INTEGER

    IF groupIdx% < 1 OR groupIdx% > MAX_LAYERS THEN EXIT SUB
    IF LAYERS(groupIdx%).imgHandle& = 0 THEN EXIT SUB
    IF LAYERS(groupIdx%).layerType% <> LAYER_TYPE_GROUP THEN EXIT SUB

    DIM newVis AS INTEGER
    newVis%                    = NOT LAYERS(groupIdx%).visible%
    LAYERS(groupIdx%).visible% = newVis%

    IF newVis% THEN
        ' Restore saved visibility states for all descendants
        FOR i% = 1 TO MAX_LAYERS
            IF LAYERS(i%).imgHandle& <> 0 AND i% <> groupIdx% THEN
                ' Walk parent chain to see if descendant of groupIdx
                DIM tgvWalk    AS INTEGER
                DIM tgvIsDesc  AS INTEGER
                tgvIsDesc% = FALSE
                tgvWalk%   = LAYERS(i%).parentGroupIdx%
                DO WHILE tgvWalk% > 0
                    IF tgvWalk% = groupIdx% THEN tgvIsDesc% = TRUE: EXIT DO
                    IF tgvWalk% < 1 OR tgvWalk% > MAX_LAYERS THEN EXIT DO
                    IF LAYERS(tgvWalk%).imgHandle& = 0 THEN EXIT DO
                    tgvWalk% = LAYERS(tgvWalk%).parentGroupIdx%
                LOOP
                IF tgvIsDesc% THEN
                    IF i% < = LEN(LAYER_PANEL.savedVisibility$) THEN
                        LAYERS(i%).visible% = (ASC(MID$(LAYER_PANEL.savedVisibility$, i%, 1)) <> 0)
                    ELSE
                        LAYERS(i%).visible% = TRUE
                    END IF
                END IF
            END IF
        NEXT i%
    ELSE
        ' Save current visibility states before hiding all descendants
        IF LEN(LAYER_PANEL.savedVisibility$) < MAX_LAYERS THEN
            LAYER_PANEL.savedVisibility$ = LAYER_PANEL.savedVisibility$ + STRING$(MAX_LAYERS - LEN(LAYER_PANEL.savedVisibility$), CHR$(0))
        END IF
        FOR i% = 1 TO MAX_LAYERS
            IF LAYERS(i%).imgHandle& <> 0 AND i% <> groupIdx% THEN
                DIM tgvWalk2   AS INTEGER
                DIM tgvIsDesc2 AS INTEGER
                tgvIsDesc2% = FALSE
                tgvWalk2%   = LAYERS(i%).parentGroupIdx%
                DO WHILE tgvWalk2% > 0
                    IF tgvWalk2% = groupIdx% THEN tgvIsDesc2% = TRUE: EXIT DO
                    IF tgvWalk2% < 1 OR tgvWalk2% > MAX_LAYERS THEN EXIT DO
                    IF LAYERS(tgvWalk2%).imgHandle& = 0 THEN EXIT DO
                    tgvWalk2% = LAYERS(tgvWalk2%).parentGroupIdx%
                LOOP
                IF tgvIsDesc2% THEN
                    MID$(LAYER_PANEL.savedVisibility$, i%, 1) = CHR$(ABS(LAYERS(i%).visible%))
                    LAYERS(i%).visible%                       = FALSE
                END IF
            END IF
        NEXT i%
    END IF

    BLEND_invalidate_cache
    INVALIDATE_scene
    GUI_NEEDS_REDRAW% = TRUE
END SUB


''
' Get the nesting depth of a layer (0 = top-level, 1 = inside one group, etc.)
' Follows parentGroupIdx chain up to the root. Caps at MAX_GROUP_NESTING to
' prevent infinite loops from corrupt data.
' @param layerIdx% Layer index
' @return INTEGER Nesting depth (0 = top-level)
'
FUNCTION LAYERS_nesting_depth% (layerIdx AS INTEGER)
    DIM depth AS INTEGER
    DIM cur   AS INTEGER
    depth% = 0
    IF layerIdx% < 1 OR layerIdx% > MAX_LAYERS THEN
        LAYERS_nesting_depth% = 0
        EXIT FUNCTION
    END IF
    cur% = LAYERS(layerIdx%).parentGroupIdx%
    DO WHILE cur% > 0 AND depth% < MAX_GROUP_NESTING
        depth% = depth% + 1
        IF cur% < 1 OR cur% > MAX_LAYERS THEN EXIT DO
        IF LAYERS(cur%).imgHandle& = 0 THEN EXIT DO
        cur% = LAYERS(cur%).parentGroupIdx%
    LOOP
    LAYERS_nesting_depth% = depth%
END FUNCTION


' =============================================================================
' Layer Panel Context Menu (right-click on layer row)
' =============================================================================

''
' Build the context menu items for the given layer.
' @param layerIdx INTEGER Layer the context menu was invoked on
' @param itemCount INTEGER [out] Total number of menu items built
'
SUB LAYER_PANEL_ctx_menu_build (layerIdx AS INTEGER, itemCount AS INTEGER)
    DIM flags       AS INTEGER
    DIM isGroup     AS INTEGER
    DIM isTextLayer AS INTEGER
    DIM inGroup     AS INTEGER
    DIM hasMultiSel AS INTEGER
    DIM modeIdx     AS INTEGER

    POPUP_MENU_clear_items
    itemCount% = 0

    IF layerIdx% < 1 OR layerIdx% > MAX_LAYERS THEN EXIT SUB
    IF LAYERS(layerIdx%).imgHandle& = 0 THEN EXIT SUB

    isGroup%     = (LAYERS(layerIdx%).layerType% = LAYER_TYPE_GROUP)
    isTextLayer% = (LAYERS(layerIdx%).layerType% = LAYER_TYPE_TEXT)
    inGroup%     = (LAYERS(layerIdx%).parentGroupIdx% > 0)
    hasMultiSel% = (MULTI_SELECT_COUNT% >= 2)

    ' --- Blend modes (Pass Through first for groups, then Normal, divider, rest) ---
    IF isGroup% THEN
        POPUP_MENU_set_item itemCount%, BLEND_mode_name$(BLEND_PASS_THROUGH), "", BLEND_PASS_THROUGH_POPUP_VALUE, 0
        itemCount% = itemCount% + 1

        POPUP_MENU_set_item itemCount%, "", "", -99, POPUP_MENU_FLAG_DIVIDER
        itemCount% = itemCount% + 1
    END IF

    POPUP_MENU_set_item itemCount%, BLEND_mode_name$(BLEND_NORMAL), "", BLEND_NORMAL, 0
    itemCount% = itemCount% + 1

    POPUP_MENU_set_item itemCount%, "", "", -99, POPUP_MENU_FLAG_DIVIDER
    itemCount% = itemCount% + 1

    FOR modeIdx% = 1 TO BLEND_MODE_COUNT - 1
        POPUP_MENU_set_item itemCount%, BLEND_mode_name$(modeIdx%), "", modeIdx%, 0
        itemCount% = itemCount% + 1
    NEXT modeIdx%

    POPUP_MENU_set_item itemCount%, "", "", -1, POPUP_MENU_FLAG_DIVIDER
    itemCount% = itemCount% + 1

    ' --- Layer operations ---
    POPUP_MENU_set_item itemCount%, "RENAME LAYER", "D-Click", 726, 0
    itemCount% = itemCount% + 1

    POPUP_MENU_set_item itemCount%, "DUPLICATE", "Ctrl+Shift+D", 707, 0
    itemCount% = itemCount% + 1

    POPUP_MENU_set_item itemCount%, "DELETE", "Ctrl+Shift+Del", 702, 0
    itemCount% = itemCount% + 1

    ' Merge Down — disabled for groups or bottom layer
    flags% = 0
    IF isGroup% THEN flags% = POPUP_MENU_FLAG_DISABLED
    POPUP_MENU_set_item itemCount%, "MERGE DOWN", "Ctrl+Alt+E", 705, flags%
    itemCount% = itemCount% + 1

    ' Merge Selected — disabled if no multi-select
    flags% = 0
    IF NOT hasMultiSel% THEN flags% = POPUP_MENU_FLAG_DISABLED
    POPUP_MENU_set_item itemCount%, "MERGE SELECTED", "Ctrl+Alt+Shift+E", 706, flags%
    itemCount% = itemCount% + 1

    ' Rasterize Text Layer — only enabled for text layers
    flags% = 0
    IF NOT isTextLayer% THEN flags% = POPUP_MENU_FLAG_DISABLED
    POPUP_MENU_set_item itemCount%, "RASTERIZE TEXT", "", 713, flags%
    itemCount% = itemCount% + 1

    POPUP_MENU_set_item itemCount%, "", "", -1, POPUP_MENU_FLAG_DIVIDER
    itemCount% = itemCount% + 1

    ' --- Group operations ---
    POPUP_MENU_set_item itemCount%, "NEW GROUP", "Ctrl+G", 720, 0
    itemCount% = itemCount% + 1

    ' Group from Selection — disabled if no multi-select
    flags% = 0
    IF NOT hasMultiSel% THEN flags% = POPUP_MENU_FLAG_DISABLED
    POPUP_MENU_set_item itemCount%, "GROUP FROM SELECTION", "Ctrl+Shift+G", 721, flags%
    itemCount% = itemCount% + 1

    ' Ungroup — only enabled for group headers
    flags% = 0
    IF NOT isGroup% THEN flags% = POPUP_MENU_FLAG_DISABLED
    POPUP_MENU_set_item itemCount%, "UNGROUP", "Ctrl+Shift+U", 722, flags%
    itemCount% = itemCount% + 1

    ' Merge Group — only enabled for group headers
    flags% = 0
    IF NOT isGroup% THEN flags% = POPUP_MENU_FLAG_DISABLED
    POPUP_MENU_set_item itemCount%, "MERGE GROUP", "", 723, flags%
    itemCount% = itemCount% + 1

    ' Select All in Group — enabled if this is a group or a group child
    flags% = 0
    IF NOT isGroup% AND NOT inGroup% THEN flags% = POPUP_MENU_FLAG_DISABLED
    POPUP_MENU_set_item itemCount%, "SELECT ALL IN GROUP", "", 725, flags%
    itemCount% = itemCount% + 1

    POPUP_MENU_set_item itemCount%, "", "", -1, POPUP_MENU_FLAG_DIVIDER
    itemCount% = itemCount% + 1

    ' Selection from Layer Group — enabled if group or inside a group
    flags% = 0
    IF NOT isGroup% AND NOT inGroup% THEN flags% = POPUP_MENU_FLAG_DISABLED
    POPUP_MENU_set_item itemCount%, "SELECTION FROM GROUP", "", 727, flags%
    itemCount% = itemCount% + 1

    ' Selection from Layer — enabled for non-group layers
    flags% = 0
    IF isGroup% THEN flags% = POPUP_MENU_FLAG_DISABLED
    POPUP_MENU_set_item itemCount%, "SELECTION FROM LAYER", "", 728, flags%
    itemCount% = itemCount% + 1

    ' --- Symbol operations ---
    DIM isSymParent AS INTEGER, isSymChild AS INTEGER
    isSymParent% = (LAYERS(layerIdx%).layerType% = LAYER_TYPE_SYMBOL_PARENT)
    isSymChild%  = (LAYERS(layerIdx%).layerType% = LAYER_TYPE_SYMBOL_CHILD)

    IF isSymParent% OR isSymChild% THEN
        POPUP_MENU_set_item itemCount%, "", "", -1, POPUP_MENU_FLAG_DIVIDER
        itemCount% = itemCount% + 1
    END IF

    ' Convert to Symbol — only enabled for plain IMAGE layers
    IF NOT isGroup% AND NOT isTextLayer% AND NOT isSymParent% AND NOT isSymChild% THEN
        POPUP_MENU_set_item itemCount%, "CONVERT TO SYMBOL", "", 730, 0
        itemCount% = itemCount% + 1
    END IF

    ' Create Instance — only enabled for symbol parents
    flags% = 0
    IF NOT isSymParent% THEN flags% = POPUP_MENU_FLAG_DISABLED
    IF isSymParent% THEN
        POPUP_MENU_set_item itemCount%, "CREATE INSTANCE", "", 732, flags%
        itemCount% = itemCount% + 1
    END IF

    ' Sync Symbols — always available if symbol parent or child
    IF isSymParent% OR isSymChild% THEN
        POPUP_MENU_set_item itemCount%, "SYNC SYMBOLS", "", 733, 0
        itemCount% = itemCount% + 1
    END IF

    ' Rasterize Symbol — only for parents
    IF isSymParent% THEN
        POPUP_MENU_set_item itemCount%, "RASTERIZE SYMBOL", "", 734, 0
        itemCount% = itemCount% + 1
    END IF

    ' Detach Instance — only for children
    IF isSymChild% THEN
        POPUP_MENU_set_item itemCount%, "DETACH INSTANCE", "", 735, 0
        itemCount% = itemCount% + 1
    END IF

    ' Select Parent — only for children
    IF isSymChild% THEN
        POPUP_MENU_set_item itemCount%, "SELECT PARENT", "", 736, 0
        itemCount% = itemCount% + 1
    END IF
END SUB


''
' Show the layer context menu anchored near (x, y) on screen.
' @param layerIdx INTEGER Layer index the context menu was invoked on
' @param x INTEGER Screen X coordinate to anchor the popup near
' @param y INTEGER Screen Y coordinate to anchor the popup near
'
SUB LAYER_PANEL_ctx_menu_show (layerIdx AS INTEGER, x AS INTEGER, y AS INTEGER)
    DIM popH      AS INTEGER
    DIM popupFont AS LONG

    ' Close blend popup if open
    IF LAYER_PANEL.blendPopupOpen% THEN LAYER_PANEL_blend_popup_close

    LAYER_PANEL_ctx_menu_build layerIdx%, LAYER_PANEL.ctxMenuItems%

    IF MENU_BAR.fontHandle& > 0 THEN
        popupFont& = MENU_BAR.fontHandle&
    ELSEIF LAYER_PANEL.fontHandle& > 0 THEN
        popupFont& = LAYER_PANEL.fontHandle&
    ELSE
        popupFont& = 0
    END IF

    LAYER_PANEL.ctxMenuW% = POPUP_MENU_measure_width%(LAYER_PANEL.ctxMenuItems%, popupFont&)
    POPUP_MENU_place x%, y%, LAYER_PANEL.ctxMenuW%, LAYER_PANEL.ctxMenuItems%, LAYER_CTX_ITEM_H, LAYER_PANEL.ctxMenuX%, LAYER_PANEL.ctxMenuY%, popH%
    LAYER_PANEL.ctxMenuOpen%  = TRUE
    LAYER_PANEL.ctxMenuLayer% = layerIdx%
    LAYER_PANEL.ctxMenuHover% = -1
    GUI_NEEDS_REDRAW%         = TRUE
    FRAME_IDLE%               = FALSE
END SUB


''
' Close the layer context menu and reset its state.
'
SUB LAYER_PANEL_ctx_menu_close ()
    LAYER_PANEL.ctxMenuOpen%  = FALSE
    LAYER_PANEL.ctxMenuLayer% = 0
    LAYER_PANEL.ctxMenuHover% = -1
    GUI_NEEDS_REDRAW%         = TRUE
    FRAME_IDLE%               = FALSE
END SUB


''
' Render the layer context menu onto SCRN.CANVAS&.
'
SUB LAYER_PANEL_ctx_menu_render ()
    DIM popupFont   AS LONG
    DIM currentMode AS INTEGER
    DIM checkedRow  AS INTEGER
    DIM ctxLayer    AS INTEGER

    IF NOT LAYER_PANEL.ctxMenuOpen% THEN EXIT SUB

    ctxLayer% = LAYER_PANEL.ctxMenuLayer%
    LAYER_PANEL_ctx_menu_build ctxLayer%, LAYER_PANEL.ctxMenuItems%

    ' Mark the active blend mode row with a checkmark
    DIM ctxIsGroup AS INTEGER
    ctxIsGroup% = FALSE
    IF ctxLayer% >= 1 AND ctxLayer% < = MAX_LAYERS THEN
        currentMode% = LAYERS(ctxLayer%).blendMode%
        IF LAYERS(ctxLayer%).layerType% = LAYER_TYPE_GROUP THEN ctxIsGroup% = TRUE
    ELSE
        currentMode% = BLEND_NORMAL
    END IF
    IF ctxIsGroup% THEN
        ' Groups: PT(0), div(1), Normal(2), div(3), modes(4+)
        IF LAYERS(ctxLayer%).passThrough% THEN
            checkedRow% = 0                ' Pass Through row
        ELSEIF currentMode% = BLEND_NORMAL THEN
            checkedRow% = 2                ' Normal row
        ELSE
            checkedRow% = currentMode% + 3 ' modes shifted by 2 extra rows
        END IF
    ELSE
        IF currentMode% = BLEND_NORMAL THEN
            checkedRow% = 0
        ELSE
            checkedRow% = currentMode% + 1 ' +1 for divider row after Normal
        END IF
    END IF
    POPUP_MENU_FLAGS(checkedRow%) = POPUP_MENU_FLAGS(checkedRow%) OR POPUP_MENU_FLAG_CHECKED

    IF MENU_BAR.fontHandle& > 0 THEN
        popupFont& = MENU_BAR.fontHandle&
    ELSEIF LAYER_PANEL.fontHandle& > 0 THEN
        popupFont& = LAYER_PANEL.fontHandle&
    ELSE
        popupFont& = 0
    END IF

    POPUP_MENU_render SCRN.CANVAS&, LAYER_PANEL.ctxMenuX%, LAYER_PANEL.ctxMenuY%, LAYER_PANEL.ctxMenuW%, LAYER_PANEL.ctxMenuItems%, LAYER_CTX_ITEM_H, LAYER_PANEL.ctxMenuHover%, popupFont&
END SUB


''
' Hit-test the layer context menu.
' Returns: action value if an enabled item was clicked,
'          -1 if inside popup but on non-clickable area,
'          -2 if outside popup.
' @param rawX INTEGER Raw screen X coordinate to test
' @param rawY INTEGER Raw screen Y coordinate to test
' @return INTEGER - Action value, -1 for non-clickable, -2 for outside
'
FUNCTION LAYER_PANEL_ctx_menu_hit% (rawX AS INTEGER, rawY AS INTEGER)
    IF NOT LAYER_PANEL.ctxMenuOpen% THEN
        LAYER_PANEL_ctx_menu_hit% = -2
        EXIT FUNCTION
    END IF
    LAYER_PANEL_ctx_menu_hit% = POPUP_MENU_hit_value%(LAYER_PANEL.ctxMenuX%, LAYER_PANEL.ctxMenuY%, LAYER_PANEL.ctxMenuW%, LAYER_PANEL.ctxMenuItems%, LAYER_CTX_ITEM_H, rawX%, rawY%)
END FUNCTION


''
' Update context menu hover state from current mouse position.
' @param rawX INTEGER Raw screen X coordinate of the mouse
' @param rawY INTEGER Raw screen Y coordinate of the mouse
'
SUB LAYER_PANEL_ctx_menu_hover (rawX AS INTEGER, rawY AS INTEGER)
    DIM prevHover AS INTEGER

    IF NOT LAYER_PANEL.ctxMenuOpen% THEN EXIT SUB

    prevHover%                = LAYER_PANEL.ctxMenuHover%
    LAYER_PANEL.ctxMenuHover% = POPUP_MENU_hover_row%(LAYER_PANEL.ctxMenuX%, LAYER_PANEL.ctxMenuY%, LAYER_PANEL.ctxMenuW%, LAYER_PANEL.ctxMenuItems%, LAYER_CTX_ITEM_H, rawX%, rawY%)
    IF LAYER_PANEL.ctxMenuHover% <> prevHover% AND LAYER_PANEL.ctxMenuHover% >= 0 THEN
        SOUND_play SND_MENU_HOVER
        GUI_NEEDS_REDRAW% = TRUE
        FRAME_IDLE%       = FALSE
    ELSEIF LAYER_PANEL.ctxMenuHover% <> prevHover% THEN
        GUI_NEEDS_REDRAW% = TRUE
        FRAME_IDLE%       = FALSE
    END IF
END SUB


''
' Execute a layer context menu action.
' @param actionValue INTEGER Action ID to execute
'
SUB LAYER_PANEL_ctx_menu_activate (actionValue AS INTEGER)
    LAYER_PANEL_ctx_menu_close
    IF actionValue% > 0 THEN
        CMD_execute_action actionValue%
    END IF
END SUB


' ===========================================================================
' APRON SUPPORT — Hybrid lazy-promote model
' ===========================================================================
' A layer is "compact" while LAYERS(i%).apronW%/apronH% are 0 (default).
' When content needs to live off-canvas (Move/Transform past edge, paint past
' edge), the layer is promoted to an apron-extended buffer of size
'   (canvasW + 2*apronW) x (canvasH + 2*apronH)
' Canvas-coord (cx,cy) maps to buffer-coord (cx + apronW, cy + apronH).
' Apron pixels are session-only — culled on save (DRW + all export formats).
' ===========================================================================


''
' Recompute global APRON_W%/APRON_H% from CFG. Called whenever the canvas
' dimensions change (new doc, file load, canvas resize) or when the user
' toggles APRON_ENABLED / changes APRON_SIZE_RATIO at runtime.
'
' This sets the GLOBAL default apron size used when promoting NEW layers.
' Existing extended layers keep their own apronW/apronH until rebuilt.
'
SUB APRON_recompute_global_dims ()
    IF NOT CFG.APRON_ENABLED% THEN
        APRON_W% = 0
        APRON_H% = 0
        EXIT SUB
    END IF
    DIM r AS SINGLE
    r! = CFG.APRON_SIZE_RATIO!
    IF r! < 0.0 THEN r! = 0.0
    IF r! > 2.0 THEN r! = 2.0
    APRON_W% = INT(SCRN.canvasW& * r!)
    APRON_H% = INT(SCRN.canvasH& * r!)
    IF APRON_W% < 0 THEN APRON_W% = 0
    IF APRON_H% < 0 THEN APRON_H% = 0
END SUB


''
' Convert canvas X coordinate to layer-buffer X coordinate for the given
' layer. For a compact layer (apronW% = 0) this is a passthrough.
' For an extended layer, it offsets by the layer's apronW%.
'
FUNCTION LAYERS_canvas_to_buf_x% (canvasX AS INTEGER, layerIdx AS INTEGER)
    LAYERS_canvas_to_buf_x% = canvasX% + LAYERS(layerIdx%).apronW%
END FUNCTION


''
' Convert canvas Y coordinate to layer-buffer Y coordinate for the given
' layer. Mirror of LAYERS_canvas_to_buf_x%.
'
FUNCTION LAYERS_canvas_to_buf_y% (canvasY AS INTEGER, layerIdx AS INTEGER)
    LAYERS_canvas_to_buf_y% = canvasY% + LAYERS(layerIdx%).apronH%
END FUNCTION


''
' TRUE if the given layer has been promoted to an apron-extended buffer.
'
FUNCTION LAYERS_is_extended% (layerIdx AS INTEGER)
    IF layerIdx% < 1 OR layerIdx% > MAX_LAYERS THEN
        LAYERS_is_extended% = FALSE
        EXIT FUNCTION
    END IF
    LAYERS_is_extended% = (LAYERS(layerIdx%).apronW% > 0 OR LAYERS(layerIdx%).apronH% > 0)
END FUNCTION


''
' Promote a compact layer to an apron-extended buffer.
' Allocates a new image of size (canvasW + 2*APRON_W, canvasH + 2*APRON_H),
' clears it transparent, copies existing canvas content to (APRON_W, APRON_H),
' frees the old image and any opacity cache, and updates layer fields.
'
' No-op cases:
'   - Apron disabled (APRON_W = 0 AND APRON_H = 0)
'   - Layer already extended (apronW > 0 OR apronH > 0)
'   - Group/folder sentinel (layerType = LAYER_TYPE_GROUP)
'   - Invalid layer index or null image handle
'
SUB LAYERS_promote_to_extended (layerIdx AS INTEGER)
    IF layerIdx% < 1 OR layerIdx% > MAX_LAYERS THEN EXIT SUB
    ' Refresh global apron dims so a canvas resize since last promote takes effect.
    APRON_recompute_global_dims
    IF APRON_W% = 0 AND APRON_H% = 0 THEN EXIT SUB
    IF LAYERS(layerIdx%).imgHandle& >= -1 THEN EXIT SUB
    IF LAYERS(layerIdx%).layerType% = LAYER_TYPE_GROUP THEN EXIT SUB
    IF LAYERS(layerIdx%).apronW% > 0 OR LAYERS(layerIdx%).apronH% > 0 THEN EXIT SUB

    DIM newW AS LONG, newH AS LONG
    newW& = SCRN.canvasW& + 2 * APRON_W%
    newH& = SCRN.canvasH& + 2 * APRON_H%

    DIM newImg AS LONG
    newImg& = _NEWIMAGE(newW&, newH&, 32)
    IF newImg& >= -1 THEN EXIT SUB ' allocation failed — leave layer compact

    DIM oldDest AS LONG
    oldDest& = _DEST
    _DEST newImg&
    CLS , _RGBA32(0, 0, 0, 0)
    _DEST oldDest&

    ' Copy canvas-sized old content into the canvas region of the extended buffer.
    _PUTIMAGE (APRON_W%, APRON_H%), LAYERS(layerIdx%).imgHandle&, newImg&

    ' Swap in new image, free old.
    _FREEIMAGE LAYERS(layerIdx%).imgHandle&
    LAYERS(layerIdx%).imgHandle&    = newImg&
    LAYERS(layerIdx%).imgWidth%     = newW&
    LAYERS(layerIdx%).imgHeight%    = newH&
    LAYERS(layerIdx%).apronW%       = APRON_W%
    LAYERS(layerIdx%).apronH%       = APRON_H%
    LAYERS(layerIdx%).contentDirty% = TRUE

    ' Invalidate opacity cache — its size no longer matches.
    IF LAYERS(layerIdx%).opacityCacheImg& < -1 THEN
        _FREEIMAGE LAYERS(layerIdx%).opacityCacheImg&
    END IF
    LAYERS(layerIdx%).opacityCacheImg& = 0

    ' Invalidate apron extraction cache — size no longer matches (or stale content).
    IF LAYERS(layerIdx%).apronCacheImg& < -1 THEN
        _FREEIMAGE LAYERS(layerIdx%).apronCacheImg&
    END IF
    LAYERS(layerIdx%).apronCacheImg&     = 0
    LAYERS(layerIdx%).apronCacheValid%   = FALSE
END SUB


''
' Demote an apron-extended layer back to a compact (canvas-sized) buffer.
' Allocates a new canvas-sized image, copies only the canvas-region pixels
' from the extended buffer (apronW, apronH)-(apronW+canvasW-1, apronH+canvasH-1),
' discarding any pixels that lived in the apron border.
'
' No-op cases:
'   - Layer already compact (apronW = 0 AND apronH = 0)
'   - Group/folder sentinel
'   - Invalid layer index or null image handle
'
SUB LAYERS_demote_to_compact (layerIdx AS INTEGER)
    IF layerIdx% < 1 OR layerIdx% > MAX_LAYERS THEN EXIT SUB
    IF LAYERS(layerIdx%).imgHandle& >= -1 THEN EXIT SUB
    IF LAYERS(layerIdx%).layerType% = LAYER_TYPE_GROUP THEN EXIT SUB
    IF LAYERS(layerIdx%).apronW% = 0 AND LAYERS(layerIdx%).apronH% = 0 THEN EXIT SUB

    DIM aW AS INTEGER, aH AS INTEGER
    aW% = LAYERS(layerIdx%).apronW%
    aH% = LAYERS(layerIdx%).apronH%

    DIM newImg AS LONG
    newImg& = _NEWIMAGE(SCRN.canvasW&, SCRN.canvasH&, 32)
    IF newImg& >= -1 THEN EXIT SUB

    DIM oldDest AS LONG
    oldDest& = _DEST
    _DEST newImg&
    CLS , _RGBA32(0, 0, 0, 0)
    _DEST oldDest&

    ' Copy the canvas region from the extended buffer.
    _PUTIMAGE (0, 0)-(SCRN.canvasW& - 1, SCRN.canvasH& - 1), LAYERS(layerIdx%).imgHandle&, newImg&, (aW%, aH%)-(aW% + SCRN.canvasW& - 1, aH% + SCRN.canvasH& - 1)

    _FREEIMAGE LAYERS(layerIdx%).imgHandle&
    LAYERS(layerIdx%).imgHandle&    = newImg&
    LAYERS(layerIdx%).imgWidth%     = SCRN.canvasW&
    LAYERS(layerIdx%).imgHeight%    = SCRN.canvasH&
    LAYERS(layerIdx%).apronW%       = 0
    LAYERS(layerIdx%).apronH%       = 0
    LAYERS(layerIdx%).contentDirty% = TRUE

    IF LAYERS(layerIdx%).opacityCacheImg& < -1 THEN
        _FREEIMAGE LAYERS(layerIdx%).opacityCacheImg&
    END IF
    LAYERS(layerIdx%).opacityCacheImg& = 0

    ' Invalidate apron extraction cache — content (and size) just changed.
    IF LAYERS(layerIdx%).apronCacheImg& < -1 THEN
        _FREEIMAGE LAYERS(layerIdx%).apronCacheImg&
    END IF
    LAYERS(layerIdx%).apronCacheImg&     = 0
    LAYERS(layerIdx%).apronCacheValid%   = FALSE
END SUB


''
' Promote ALL non-group layers to apron-extended buffers using the current
' global APRON_W%/APRON_H%. Used when toggling APRON_ENABLED on or after a
' canvas resize that changes apron dims.
'
SUB LAYERS_promote_all ()
    IF APRON_W% = 0 AND APRON_H% = 0 THEN EXIT SUB
    DIM i AS INTEGER
    FOR i% = 1 TO MAX_LAYERS
        IF LAYERS(i%).imgHandle& < -1 THEN
            IF LAYERS(i%).layerType% <> LAYER_TYPE_GROUP THEN
                IF LAYERS(i%).apronW% = 0 AND LAYERS(i%).apronH% = 0 THEN
                    LAYERS_promote_to_extended i%
                END IF
            END IF
        END IF
    NEXT i%
END SUB


''
' Demote ALL extended layers back to compact buffers. Used when disabling
' apron, before save (cull-on-save), or before canvas resize.
'
SUB LAYERS_demote_all ()
    DIM i AS INTEGER
    FOR i% = 1 TO MAX_LAYERS
        IF LAYERS(i%).imgHandle& < -1 THEN
            IF LAYERS(i%).apronW% > 0 OR LAYERS(i%).apronH% > 0 THEN
                LAYERS_demote_to_compact i%
            END IF
        END IF
    NEXT i%
END SUB
