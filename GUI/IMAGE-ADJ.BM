        oPixSize% = pixSize%
        pixSize% = DIALOG_slider_drag%(ctx, IMGDLG_SX, IMGDLG_track_y%(ctx, 0), IMGDLG_SW, 14, pixSize%, 2, 32)
        pixSize% = DIALOG_slider_wheel%(ctx, IMGDLG_SX, IMGDLG_track_y%(ctx, 0), IMGDLG_SW, 14, pixSize%, 2, 32)
        IF pixSize% <> oPixSize% THEN ctx.previewDirty% = TRUE
