''
' DRAW - GUI/DRAWER.BM
' =============================================================================

$INCLUDEONCE

''
' Initialize the drawer panel state and gradient presets.
' Sets default mode to brush, clears context menu, and loads gradient definitions.
'
SUB DRAWER_init ()
    DITHER_init
    DRAWER.visible% = TRUE
    DRAWER.mode% = DRAWER_MODE_BRUSH
    DRAWER.paintMode% = 1
    DRAWER.panelX1% = 0
    DRAWER.panelY1% = 0
    DRAWER.panelX2% = 0
    DRAWER.panelY2% = 0
    DRAWER.miniPaletteOffset% = 0
    DRAWER.brushSelected% = 1
    DRAWER.patternSelected% = 1
    DRAWER.gradientSelected% = 1
    DRAWER.paletteFGX% = -1
    DRAWER.paletteFGY% = -1
    DRAWER.paletteBGX% = -1
    DRAWER.paletteBGY% = -1
    DRAWER.contextMenuOpen% = FALSE
    DRAWER.contextMenuSlot% = 0
    DRAWER.contextMenuX% = 0
    DRAWER.contextMenuY% = 0
    DRAWER.contextMenuW% = 0
    DRAWER.contextMenuHover% = -1
    DRAWER.samplesLoaded% = FALSE
    DRAWER.loadedTheme = ""
    DRAWER_DEFERRED_IMPORT_SLOT% = 0
    DRAWER_DEFERRED_IMPORT_MODE% = DRAWER_MODE_NONE
    GRAD_CTX_clear
    GRAD_DEF_init_presets
END SUB

''
' Reset the drawer panel to its initial state.
' Frees all loaded sample images and reinitializes.
'
SUB DRAWER_reset ()
    DRAWER_free_samples
    DRAWER_init
END SUB

''
' Free all loaded sample images across brush, pattern, and gradient slots.
' Also frees the mini palette images and marks samples as unloaded.
'
SUB DRAWER_free_samples ()
    DIM i AS INTEGER
    FOR i% = 1 TO DRAWER_SLOT_COUNT
        IF DRAWER_BRUSH_SLOTS(i%).IMG < -1 THEN _FREEIMAGE DRAWER_BRUSH_SLOTS(i%).IMG
        DRAWER_BRUSH_SLOTS(i%).IMG = 0
        DRAWER_BRUSH_SLOTS(i%).W = 0
        DRAWER_BRUSH_SLOTS(i%).H = 0

        IF DRAWER_PATTERN_SLOTS(i%) < -1 THEN _FREEIMAGE DRAWER_PATTERN_SLOTS(i%)
        DRAWER_PATTERN_SLOTS(i%) = 0
        DRAWER_PATTERN_HAS(i%) = FALSE
        DRAWER_PATTERN_1BIT(i%) = FALSE
        DRAWER_PATTERN_1BIT_FG(i%) = 0
        DRAWER_PATTERN_1BIT_HAS_BG(i%) = FALSE

        IF DRAWER_GRADIENT_SLOTS(i%) < -1 THEN _FREEIMAGE DRAWER_GRADIENT_SLOTS(i%)
        DRAWER_GRADIENT_SLOTS(i%) = 0
        DRAWER_GRADIENT_HAS(i%) = FALSE
        DRAWER_GRADIENT_CUSTOM(i%) = FALSE
    NEXT i%

    IF DRAWER_PALETTE_IMG& < -1 THEN _FREEIMAGE DRAWER_PALETTE_IMG&
    IF DRAWER_PALETTE_LEFT_IMG& < -1 THEN _FREEIMAGE DRAWER_PALETTE_LEFT_IMG&
    IF DRAWER_PALETTE_RIGHT_IMG& < -1 THEN _FREEIMAGE DRAWER_PALETTE_RIGHT_IMG&
    DRAWER_PALETTE_IMG& = 0
    DRAWER_PALETTE_LEFT_IMG& = 0
    DRAWER_PALETTE_RIGHT_IMG& = 0

    DRAWER.samplesLoaded% = FALSE
    DRAWER.loadedTheme = ""
END SUB

''
' Load a theme image from the active theme directory with DEFAULT fallback.
' @param subdir STRING Subdirectory within the theme folder (e.g. "IMAGES/PATTERNS")
' @param filename STRING Image filename to load (e.g. "pattern-0.png")
' @return LONG - image handle on success, 0 if file not found
'
FUNCTION DRAWER_load_theme_image& (subdir AS STRING, filename AS STRING)
    DIM primaryPath AS STRING
    DIM fallbackPath AS STRING

    primaryPath$ = "ASSETS/THEMES/" + _TRIM$(CFG.THEME$) + "/" + subdir$ + "/" + filename$
    fallbackPath$ = "ASSETS/THEMES/DEFAULT/" + subdir$ + "/" + filename$

    IF _FILEEXISTS(primaryPath$) THEN
        DRAWER_load_theme_image& = _LOADIMAGE(primaryPath$, 32)
    ELSEIF _FILEEXISTS(fallbackPath$) THEN
        DRAWER_load_theme_image& = _LOADIMAGE(fallbackPath$, 32)
    ELSE
        DRAWER_load_theme_image& = 0
    END IF
END FUNCTION

''
' Create a 128x128 preview image for a gradient slot by rendering its color
' stops using the slot's spatial family.
' @param slotIndex INTEGER Gradient slot index (1..DRAWER_SLOT_COUNT)
' @return LONG - newly allocated image handle with the rendered gradient
'
FUNCTION DRAWER_create_gradient_sample& (slotIndex AS INTEGER)
    DIM img AS LONG
    DIM oldDest AS LONG
    DIM x AS INTEGER
    DIM y AS INTEGER
    DIM t AS SINGLE
    DIM w AS INTEGER
    DIM h AS INTEGER
    DIM c AS _UNSIGNED LONG

    w% = 128
    h% = 128

    img& = _NEWIMAGE(w%, h%, 32)
    oldDest& = _DEST
    _DEST img&
    CLS , _RGBA32(0, 0, 0, 0)

    FOR y% = 0 TO h% - 1
        FOR x% = 0 TO w% - 1
            t! = DRAWER_gradient_eval_t!(slotIndex%, x%, y%, w%, h%)
            c~& = GRAD_DEF_eval_color~&(slotIndex%, t!)
            PSET (x%, y%), c~&
        NEXT x%
    NEXT y%

    _DEST oldDest&
    DRAWER_create_gradient_sample& = img&
END FUNCTION

''
' Evaluate the gradient parameter t at a pixel position based on the slot's
' spatial family (horizontal, vertical, radial, diamond, etc.).
' @param slotIndex INTEGER Gradient slot index (determines which family to use)
' @param x INTEGER Horizontal pixel coordinate within the gradient area
' @param y INTEGER Vertical pixel coordinate within the gradient area
' @param w INTEGER Total width of the gradient area in pixels
' @param h INTEGER Total height of the gradient area in pixels
' @return SINGLE - normalized gradient parameter t clamped to 0.0..1.0
'
FUNCTION DRAWER_gradient_eval_t! (slotIndex AS INTEGER, x AS INTEGER, y AS INTEGER, w AS INTEGER, h AS INTEGER)
    DIM u AS SINGLE
    DIM v AS SINGLE
    DIM dx AS SINGLE
    DIM dy AS SINGLE
    DIM family AS INTEGER
    DIM result AS SINGLE

    IF w% > 1 THEN u! = x% / (w% - 1) ELSE u! = 0
    IF h% > 1 THEN v! = y% / (h% - 1) ELSE v! = 0

    family% = GRAD_DEFS(slotIndex%).family%
    IF family% < 1 OR family% > 8 THEN family% = ((slotIndex% - 1) MOD 8) + 1
    SELECT CASE family%
        CASE 1
            result! = u!
        CASE 2
            result! = v!
        CASE 3
            result! = (u! + v!) / 2
        CASE 4
            result! = (u! + (1! - v!)) / 2
        CASE 5
            dx! = u! - .5
            dy! = v! - .5
            result! = SQR(dx! * dx! + dy! * dy!) / .7071068
        CASE 6
            result! = ABS((u! - .5) * 2)
        CASE 7
            result! = ABS((v! - .5) * 2)
        CASE ELSE
            result! = ABS(u! - .5) + ABS(v! - .5)
    END SELECT

    IF result! < 0 THEN result! = 0
    IF result! > 1 THEN result! = 1
    DRAWER_gradient_eval_t! = result!
END FUNCTION

''
' Linearly interpolate between two RGBA colors by factor t.
' @param c1 _UNSIGNED LONG Start color (at t=0)
' @param c2 _UNSIGNED LONG End color (at t=1)
' @param t SINGLE Interpolation factor, clamped internally to 0.0..1.0
' @return _UNSIGNED LONG - blended RGBA color
'
FUNCTION DRAWER_gradient_lerp_color~& (c1 AS _UNSIGNED LONG, c2 AS _UNSIGNED LONG, t AS SINGLE)
    DIM u AS SINGLE
    DIM r AS INTEGER
    DIM g AS INTEGER
    DIM b AS INTEGER
    DIM a AS INTEGER

    u! = t!
    IF u! < 0 THEN u! = 0
    IF u! > 1 THEN u! = 1

    r% = INT(_RED32(c1~&) + ((_RED32(c2~&) - _RED32(c1~&)) * u!) + .5)
    g% = INT(_GREEN32(c1~&) + ((_GREEN32(c2~&) - _GREEN32(c1~&)) * u!) + .5)
    b% = INT(_BLUE32(c1~&) + ((_BLUE32(c2~&) - _BLUE32(c1~&)) * u!) + .5)
    a% = INT(_ALPHA32(c1~&) + ((_ALPHA32(c2~&) - _ALPHA32(c1~&)) * u!) + .5)
    DRAWER_gradient_lerp_color~& = _RGBA32(r%, g%, b%, a%)
END FUNCTION

''
' Apply an opacity stop's alpha value to a color by scaling its existing alpha.
' @param c _UNSIGNED LONG Source RGBA color
' @param stopAlpha INTEGER Opacity stop value (0..255); 255 returns color unchanged
' @return _UNSIGNED LONG - color with alpha channel scaled by stopAlpha
'
FUNCTION GRAD_with_stop_alpha~& (c AS _UNSIGNED LONG, stopAlpha AS INTEGER)
    IF stopAlpha% >= 255 THEN
        GRAD_with_stop_alpha~& = c~&
    ELSE
        DIM gsaA AS INTEGER
        gsaA% = INT(_ALPHA32(c~&) * stopAlpha% / 255)
        IF gsaA% < 0 THEN gsaA% = 0
        IF gsaA% > 255 THEN gsaA% = 255
        GRAD_with_stop_alpha~& = _RGBA32(_RED32(c~&), _GREEN32(c~&), _BLUE32(c~&), gsaA%)
    END IF
END FUNCTION

''
' Sample a built-in gradient preset's color at parameter t.
' Slots 1-8 use FG/BG colors; slots 9-15 are fixed palettes (rainbow,
' ocean, sunset, fire, steel, forest, neon); slot 16+ default to grayscale.
' @param slotIndex INTEGER Gradient slot index (1..DRAWER_SLOT_COUNT)
' @param t SINGLE Gradient parameter in range 0.0 to 1.0
' @return _UNSIGNED LONG - sampled RGBA color at the given position
'
FUNCTION DRAWER_gradient_sample_stop~& (slotIndex AS INTEGER, t AS SINGLE)
    DIM c0 AS _UNSIGNED LONG
    DIM c1 AS _UNSIGNED LONG
    DIM c2 AS _UNSIGNED LONG
    DIM c3 AS _UNSIGNED LONG
    DIM u AS SINGLE

    u! = t!
    IF u! < 0 THEN u! = 0
    IF u! > 1 THEN u! = 1

    SELECT CASE slotIndex%
        CASE 1
            DRAWER_gradient_sample_stop~& = DRAWER_gradient_lerp_color~&(PAINT_COLOR~&, PAINT_BG_COLOR~&, u!)
        CASE 2
            DRAWER_gradient_sample_stop~& = DRAWER_gradient_lerp_color~&(PAINT_BG_COLOR~&, PAINT_COLOR~&, u!)
        CASE 3
            c1~& = _RGB32(255, 255, 255)
            IF u! < .5 THEN
                DRAWER_gradient_sample_stop~& = DRAWER_gradient_lerp_color~&(PAINT_COLOR~&, c1~&, u! / .5)
            ELSE
                DRAWER_gradient_sample_stop~& = DRAWER_gradient_lerp_color~&(c1~&, PAINT_BG_COLOR~&, (u! - .5) / .5)
            END IF
        CASE 4
            c1~& = _RGB32(0, 0, 0)
            IF u! < .5 THEN
                DRAWER_gradient_sample_stop~& = DRAWER_gradient_lerp_color~&(PAINT_COLOR~&, c1~&, u! / .5)
            ELSE
                DRAWER_gradient_sample_stop~& = DRAWER_gradient_lerp_color~&(c1~&, PAINT_BG_COLOR~&, (u! - .5) / .5)
            END IF
        CASE 5
            c1~& = DRAWER_gradient_lerp_color~&(PAINT_COLOR~&, _RGB32(255, 255, 255), .5)
            c2~& = DRAWER_gradient_lerp_color~&(PAINT_BG_COLOR~&, _RGB32(255, 255, 255), .5)
            IF u! < .5 THEN
                DRAWER_gradient_sample_stop~& = DRAWER_gradient_lerp_color~&(c1~&, PAINT_COLOR~&, u! / .5)
            ELSE
                DRAWER_gradient_sample_stop~& = DRAWER_gradient_lerp_color~&(PAINT_COLOR~&, c2~&, (u! - .5) / .5)
            END IF
        CASE 6
            c1~& = DRAWER_gradient_lerp_color~&(PAINT_COLOR~&, PAINT_BG_COLOR~&, .5)
            IF u! < .5 THEN
                DRAWER_gradient_sample_stop~& = DRAWER_gradient_lerp_color~&(PAINT_COLOR~&, c1~&, u! / .5)
            ELSE
                DRAWER_gradient_sample_stop~& = DRAWER_gradient_lerp_color~&(c1~&, PAINT_BG_COLOR~&, (u! - .5) / .5)
            END IF
        CASE 7
            c1~& = DRAWER_gradient_lerp_color~&(PAINT_BG_COLOR~&, PAINT_COLOR~&, .5)
            IF u! < .5 THEN
                DRAWER_gradient_sample_stop~& = DRAWER_gradient_lerp_color~&(PAINT_BG_COLOR~&, c1~&, u! / .5)
            ELSE
                DRAWER_gradient_sample_stop~& = DRAWER_gradient_lerp_color~&(c1~&, PAINT_COLOR~&, (u! - .5) / .5)
            END IF
        CASE 8
            c1~& = DRAWER_gradient_lerp_color~&(PAINT_COLOR~&, _RGB32(255, 255, 255), .35)
            c2~& = DRAWER_gradient_lerp_color~&(PAINT_BG_COLOR~&, _RGB32(255, 255, 255), .35)
            IF u! < .33 THEN
                DRAWER_gradient_sample_stop~& = DRAWER_gradient_lerp_color~&(PAINT_COLOR~&, c1~&, u! / .33)
            ELSEIF u! < .66 THEN
                DRAWER_gradient_sample_stop~& = DRAWER_gradient_lerp_color~&(c1~&, c2~&, (u! - .33) / .33)
            ELSE
                DRAWER_gradient_sample_stop~& = DRAWER_gradient_lerp_color~&(c2~&, PAINT_BG_COLOR~&, (u! - .66) / .34)
            END IF
        CASE 9
            c0~& = _RGB32(255, 0, 0)
            c1~& = _RGB32(255, 255, 0)
            c2~& = _RGB32(0, 255, 0)
            c3~& = _RGB32(0, 255, 255)
            IF u! < .3333 THEN
                DRAWER_gradient_sample_stop~& = DRAWER_gradient_lerp_color~&(c0~&, c1~&, u! / .3333)
            ELSEIF u! < .6666 THEN
                DRAWER_gradient_sample_stop~& = DRAWER_gradient_lerp_color~&(c1~&, c2~&, (u! - .3333) / .3333)
            ELSE
                DRAWER_gradient_sample_stop~& = DRAWER_gradient_lerp_color~&(c2~&, c3~&, (u! - .6666) / .3334)
            END IF
        CASE 10
            c0~& = _RGB32(18, 36, 84)
            c1~& = _RGB32(28, 140, 196)
            c2~& = _RGB32(120, 232, 255)
            c3~& = _RGB32(255, 255, 255)
            IF u! < .3333 THEN
                DRAWER_gradient_sample_stop~& = DRAWER_gradient_lerp_color~&(c0~&, c1~&, u! / .3333)
            ELSEIF u! < .6666 THEN
                DRAWER_gradient_sample_stop~& = DRAWER_gradient_lerp_color~&(c1~&, c2~&, (u! - .3333) / .3333)
            ELSE
                DRAWER_gradient_sample_stop~& = DRAWER_gradient_lerp_color~&(c2~&, c3~&, (u! - .6666) / .3334)
            END IF
        CASE 11
            c0~& = _RGB32(54, 12, 86)
            c1~& = _RGB32(186, 48, 120)
            c2~& = _RGB32(255, 138, 72)
            c3~& = _RGB32(255, 228, 120)
            IF u! < .3333 THEN
                DRAWER_gradient_sample_stop~& = DRAWER_gradient_lerp_color~&(c0~&, c1~&, u! / .3333)
            ELSEIF u! < .6666 THEN
                DRAWER_gradient_sample_stop~& = DRAWER_gradient_lerp_color~&(c1~&, c2~&, (u! - .3333) / .3333)
            ELSE
                DRAWER_gradient_sample_stop~& = DRAWER_gradient_lerp_color~&(c2~&, c3~&, (u! - .6666) / .3334)
            END IF
        CASE 12
            c0~& = _RGB32(0, 0, 0)
            c1~& = _RGB32(130, 0, 0)
            c2~& = _RGB32(255, 128, 0)
            c3~& = _RGB32(255, 255, 160)
            IF u! < .3333 THEN
                DRAWER_gradient_sample_stop~& = DRAWER_gradient_lerp_color~&(c0~&, c1~&, u! / .3333)
            ELSEIF u! < .6666 THEN
                DRAWER_gradient_sample_stop~& = DRAWER_gradient_lerp_color~&(c1~&, c2~&, (u! - .3333) / .3333)
            ELSE
                DRAWER_gradient_sample_stop~& = DRAWER_gradient_lerp_color~&(c2~&, c3~&, (u! - .6666) / .3334)
            END IF
        CASE 13
            c0~& = _RGB32(18, 52, 86)
            c1~& = _RGB32(64, 128, 160)
            c2~& = _RGB32(160, 208, 216)
            c3~& = _RGB32(255, 255, 255)
            IF u! < .3333 THEN
                DRAWER_gradient_sample_stop~& = DRAWER_gradient_lerp_color~&(c0~&, c1~&, u! / .3333)
            ELSEIF u! < .6666 THEN
                DRAWER_gradient_sample_stop~& = DRAWER_gradient_lerp_color~&(c1~&, c2~&, (u! - .3333) / .3333)
            ELSE
                DRAWER_gradient_sample_stop~& = DRAWER_gradient_lerp_color~&(c2~&, c3~&, (u! - .6666) / .3334)
            END IF
        CASE 14
            c0~& = _RGB32(16, 64, 24)
            c1~& = _RGB32(74, 160, 74)
            c2~& = _RGB32(186, 224, 120)
            c3~& = _RGB32(255, 246, 202)
            IF u! < .3333 THEN
                DRAWER_gradient_sample_stop~& = DRAWER_gradient_lerp_color~&(c0~&, c1~&, u! / .3333)
            ELSEIF u! < .6666 THEN
                DRAWER_gradient_sample_stop~& = DRAWER_gradient_lerp_color~&(c1~&, c2~&, (u! - .3333) / .3333)
            ELSE
                DRAWER_gradient_sample_stop~& = DRAWER_gradient_lerp_color~&(c2~&, c3~&, (u! - .6666) / .3334)
            END IF
        CASE 15
            c0~& = _RGB32(32, 0, 56)
            c1~& = _RGB32(86, 0, 130)
            c2~& = _RGB32(208, 64, 176)
            c3~& = _RGB32(255, 180, 220)
            IF u! < .3333 THEN
                DRAWER_gradient_sample_stop~& = DRAWER_gradient_lerp_color~&(c0~&, c1~&, u! / .3333)
            ELSEIF u! < .6666 THEN
                DRAWER_gradient_sample_stop~& = DRAWER_gradient_lerp_color~&(c1~&, c2~&, (u! - .3333) / .3333)
            ELSE
                DRAWER_gradient_sample_stop~& = DRAWER_gradient_lerp_color~&(c2~&, c3~&, (u! - .6666) / .3334)
            END IF
        CASE ELSE
            c0~& = _RGB32(0, 0, 0)
            c1~& = _RGB32(96, 96, 96)
            c2~& = _RGB32(192, 192, 192)
            c3~& = _RGB32(255, 255, 255)
            IF u! < .3333 THEN
                DRAWER_gradient_sample_stop~& = DRAWER_gradient_lerp_color~&(c0~&, c1~&, u! / .3333)
            ELSEIF u! < .6666 THEN
                DRAWER_gradient_sample_stop~& = DRAWER_gradient_lerp_color~&(c1~&, c2~&, (u! - .3333) / .3333)
            ELSE
                DRAWER_gradient_sample_stop~& = DRAWER_gradient_lerp_color~&(c2~&, c3~&, (u! - .6666) / .3334)
            END IF
    END SELECT
END FUNCTION

' ---------------------------------------------------------------------------
' Gradient definition helpers
' ---------------------------------------------------------------------------

''
' Set a single color stop's position and color in a gradient definition.
' @param slotIndex INTEGER Gradient slot index (1..DRAWER_SLOT_COUNT)
' @param stopIndex INTEGER Stop index within the slot (1..GRADIENT_MAX_STOPS)
' @param stopPos SINGLE Normalized position along the gradient (0.0..1.0)
' @param c _UNSIGNED LONG RGBA color for this stop
'
SUB GRAD_DEF_set_stop (slotIndex AS INTEGER, stopIndex AS INTEGER, stopPos AS SINGLE, c AS _UNSIGNED LONG)
    IF slotIndex% < 1 OR slotIndex% > DRAWER_SLOT_COUNT THEN EXIT SUB
    IF stopIndex% < 1 OR stopIndex% > GRADIENT_MAX_STOPS THEN EXIT SUB
    GRAD_COLOR_STOPS(slotIndex%, stopIndex%).position = stopPos!
    GRAD_COLOR_STOPS(slotIndex%, stopIndex%).clr = c~&
END SUB

''
' Initialize all gradient slots with built-in preset definitions.
' Slots 1-8 are FG/BG-based parametric presets; slots 9-16 are fixed-color
' presets (rainbow, ocean, sunset, fire, steel, forest, neon, grayscale).
'
SUB GRAD_DEF_init_presets ()
    DIM i AS INTEGER
    DIM s AS INTEGER

    ' Clear all definitions first
    FOR i% = 1 TO DRAWER_SLOT_COUNT
        GRAD_DEFS(i%).family% = ((i% - 1) MOD 8) + 1
        GRAD_DEFS(i%).colorCount% = 0
        GRAD_DEFS(i%).opacityCount% = 0
        GRAD_DEFS(i%).usesFG% = FALSE
        GRAD_DEFS(i%).usesBG% = FALSE
        GRAD_DEFS(i%).previewDirty% = TRUE
        GRAD_DEFS(i%).gName = ""
        GRAD_DEFS(i%).ditherMode% = DITHER_NONE
        GRAD_DEFS(i%).ditherStrength! = 0.5
        FOR s% = 1 TO GRADIENT_MAX_STOPS
            GRAD_COLOR_STOPS(i%, s%).position = 0
            GRAD_COLOR_STOPS(i%, s%).clr = 0
            GRAD_OPACITY_STOPS(i%, s%).position = 0
            GRAD_OPACITY_STOPS(i%, s%).opacity% = 255
            GRAD_STOP_TYPES(i%, s%) = GRAD_STOP_USER
        NEXT s%
    NEXT i%

    ' Slot 1: FG -> BG
    GRAD_DEFS(1).colorCount% = 2
    GRAD_DEFS(1).usesFG% = TRUE: GRAD_DEFS(1).usesBG% = TRUE
    GRAD_DEFS(1).gName = "FG to BG"
    GRAD_DEF_set_stop 1, 1, 0.0, PAINT_COLOR~&
    GRAD_STOP_TYPES(1, 1) = GRAD_STOP_FG
    GRAD_DEF_set_stop 1, 2, 1.0, PAINT_BG_COLOR~&
    GRAD_STOP_TYPES(1, 2) = GRAD_STOP_BG

    ' Slot 2: BG -> FG
    GRAD_DEFS(2).colorCount% = 2
    GRAD_DEFS(2).usesFG% = TRUE: GRAD_DEFS(2).usesBG% = TRUE
    GRAD_DEFS(2).gName = "BG to FG"
    GRAD_DEF_set_stop 2, 1, 0.0, PAINT_BG_COLOR~&
    GRAD_STOP_TYPES(2, 1) = GRAD_STOP_BG
    GRAD_DEF_set_stop 2, 2, 1.0, PAINT_COLOR~&
    GRAD_STOP_TYPES(2, 2) = GRAD_STOP_FG

    ' Slot 3: FG -> White -> BG
    GRAD_DEFS(3).colorCount% = 3
    GRAD_DEFS(3).usesFG% = TRUE: GRAD_DEFS(3).usesBG% = TRUE
    GRAD_DEFS(3).gName = "FG White BG"
    GRAD_DEF_set_stop 3, 1, 0.0, PAINT_COLOR~&
    GRAD_STOP_TYPES(3, 1) = GRAD_STOP_FG
    GRAD_DEF_set_stop 3, 2, 0.5, _RGB32(255, 255, 255)
    GRAD_DEF_set_stop 3, 3, 1.0, PAINT_BG_COLOR~&
    GRAD_STOP_TYPES(3, 3) = GRAD_STOP_BG

    ' Slot 4: FG -> Black -> BG
    GRAD_DEFS(4).colorCount% = 3
    GRAD_DEFS(4).usesFG% = TRUE: GRAD_DEFS(4).usesBG% = TRUE
    GRAD_DEFS(4).gName = "FG Black BG"
    GRAD_DEF_set_stop 4, 1, 0.0, PAINT_COLOR~&
    GRAD_STOP_TYPES(4, 1) = GRAD_STOP_FG
    GRAD_DEF_set_stop 4, 2, 0.5, _RGB32(0, 0, 0)
    GRAD_DEF_set_stop 4, 3, 1.0, PAINT_BG_COLOR~&
    GRAD_STOP_TYPES(4, 3) = GRAD_STOP_BG

    ' Slot 5: FG-light -> FG -> BG-light
    GRAD_DEFS(5).colorCount% = 3
    GRAD_DEFS(5).usesFG% = TRUE: GRAD_DEFS(5).usesBG% = TRUE
    GRAD_DEFS(5).gName = "FG Light BG"
    GRAD_DEF_set_stop 5, 1, 0.0, DRAWER_gradient_lerp_color~&(PAINT_COLOR~&, _RGB32(255, 255, 255), .5)
    GRAD_STOP_TYPES(5, 1) = GRAD_STOP_FG
    GRAD_DEF_set_stop 5, 2, 0.5, PAINT_COLOR~&
    GRAD_STOP_TYPES(5, 2) = GRAD_STOP_FG
    GRAD_DEF_set_stop 5, 3, 1.0, DRAWER_gradient_lerp_color~&(PAINT_BG_COLOR~&, _RGB32(255, 255, 255), .5)
    GRAD_STOP_TYPES(5, 3) = GRAD_STOP_BG

    ' Slot 6: FG -> FG+BG mid -> BG
    GRAD_DEFS(6).colorCount% = 3
    GRAD_DEFS(6).usesFG% = TRUE: GRAD_DEFS(6).usesBG% = TRUE
    GRAD_DEFS(6).gName = "FG Mid BG"
    GRAD_DEF_set_stop 6, 1, 0.0, PAINT_COLOR~&
    GRAD_STOP_TYPES(6, 1) = GRAD_STOP_FG
    GRAD_DEF_set_stop 6, 2, 0.5, DRAWER_gradient_lerp_color~&(PAINT_COLOR~&, PAINT_BG_COLOR~&, .5)
    GRAD_DEF_set_stop 6, 3, 1.0, PAINT_BG_COLOR~&
    GRAD_STOP_TYPES(6, 3) = GRAD_STOP_BG

    ' Slot 7: BG -> BG+FG mid -> FG
    GRAD_DEFS(7).colorCount% = 3
    GRAD_DEFS(7).usesFG% = TRUE: GRAD_DEFS(7).usesBG% = TRUE
    GRAD_DEFS(7).gName = "BG Mid FG"
    GRAD_DEF_set_stop 7, 1, 0.0, PAINT_BG_COLOR~&
    GRAD_STOP_TYPES(7, 1) = GRAD_STOP_BG
    GRAD_DEF_set_stop 7, 2, 0.5, DRAWER_gradient_lerp_color~&(PAINT_BG_COLOR~&, PAINT_COLOR~&, .5)
    GRAD_DEF_set_stop 7, 3, 1.0, PAINT_COLOR~&
    GRAD_STOP_TYPES(7, 3) = GRAD_STOP_FG

    ' Slot 8: FG -> FG-light -> BG-light -> BG (4-stop)
    GRAD_DEFS(8).colorCount% = 4
    GRAD_DEFS(8).usesFG% = TRUE: GRAD_DEFS(8).usesBG% = TRUE
    GRAD_DEFS(8).gName = "FG Soft BG"
    GRAD_DEF_set_stop 8, 1, 0.0, PAINT_COLOR~&
    GRAD_STOP_TYPES(8, 1) = GRAD_STOP_FG
    GRAD_DEF_set_stop 8, 2, 0.33, DRAWER_gradient_lerp_color~&(PAINT_COLOR~&, _RGB32(255, 255, 255), .35)
    GRAD_STOP_TYPES(8, 2) = GRAD_STOP_FG
    GRAD_DEF_set_stop 8, 3, 0.66, DRAWER_gradient_lerp_color~&(PAINT_BG_COLOR~&, _RGB32(255, 255, 255), .35)
    GRAD_STOP_TYPES(8, 3) = GRAD_STOP_BG
    GRAD_DEF_set_stop 8, 4, 1.0, PAINT_BG_COLOR~&
    GRAD_STOP_TYPES(8, 4) = GRAD_STOP_BG

    ' Slot 9: Rainbow (red -> yellow -> green -> cyan)
    GRAD_DEFS(9).colorCount% = 4
    GRAD_DEFS(9).gName = "Rainbow"
    GRAD_DEF_set_stop 9, 1, 0.0, _RGB32(255, 0, 0)
    GRAD_DEF_set_stop 9, 2, 0.3333, _RGB32(255, 255, 0)
    GRAD_DEF_set_stop 9, 3, 0.6666, _RGB32(0, 255, 0)
    GRAD_DEF_set_stop 9, 4, 1.0, _RGB32(0, 255, 255)

    ' Slot 10: Ocean
    GRAD_DEFS(10).colorCount% = 4
    GRAD_DEFS(10).gName = "Ocean"
    GRAD_DEF_set_stop 10, 1, 0.0, _RGB32(18, 36, 84)
    GRAD_DEF_set_stop 10, 2, 0.3333, _RGB32(28, 140, 196)
    GRAD_DEF_set_stop 10, 3, 0.6666, _RGB32(120, 232, 255)
    GRAD_DEF_set_stop 10, 4, 1.0, _RGB32(255, 255, 255)

    ' Slot 11: Sunset
    GRAD_DEFS(11).colorCount% = 4
    GRAD_DEFS(11).gName = "Sunset"
    GRAD_DEF_set_stop 11, 1, 0.0, _RGB32(54, 12, 86)
    GRAD_DEF_set_stop 11, 2, 0.3333, _RGB32(186, 48, 120)
    GRAD_DEF_set_stop 11, 3, 0.6666, _RGB32(255, 138, 72)
    GRAD_DEF_set_stop 11, 4, 1.0, _RGB32(255, 228, 120)

    ' Slot 12: Fire
    GRAD_DEFS(12).colorCount% = 4
    GRAD_DEFS(12).gName = "Fire"
    GRAD_DEF_set_stop 12, 1, 0.0, _RGB32(0, 0, 0)
    GRAD_DEF_set_stop 12, 2, 0.3333, _RGB32(130, 0, 0)
    GRAD_DEF_set_stop 12, 3, 0.6666, _RGB32(255, 128, 0)
    GRAD_DEF_set_stop 12, 4, 1.0, _RGB32(255, 255, 160)

    ' Slot 13: Steel
    GRAD_DEFS(13).colorCount% = 4
    GRAD_DEFS(13).gName = "Steel"
    GRAD_DEF_set_stop 13, 1, 0.0, _RGB32(18, 52, 86)
    GRAD_DEF_set_stop 13, 2, 0.3333, _RGB32(64, 128, 160)
    GRAD_DEF_set_stop 13, 3, 0.6666, _RGB32(160, 208, 216)
    GRAD_DEF_set_stop 13, 4, 1.0, _RGB32(255, 255, 255)

    ' Slot 14: Forest
    GRAD_DEFS(14).colorCount% = 4
    GRAD_DEFS(14).gName = "Forest"
    GRAD_DEF_set_stop 14, 1, 0.0, _RGB32(16, 64, 24)
    GRAD_DEF_set_stop 14, 2, 0.3333, _RGB32(74, 160, 74)
    GRAD_DEF_set_stop 14, 3, 0.6666, _RGB32(186, 224, 120)
    GRAD_DEF_set_stop 14, 4, 1.0, _RGB32(255, 246, 202)

    ' Slot 15: Neon
    GRAD_DEFS(15).colorCount% = 4
    GRAD_DEFS(15).gName = "Neon"
    GRAD_DEF_set_stop 15, 1, 0.0, _RGB32(32, 0, 56)
    GRAD_DEF_set_stop 15, 2, 0.3333, _RGB32(86, 0, 130)
    GRAD_DEF_set_stop 15, 3, 0.6666, _RGB32(208, 64, 176)
    GRAD_DEF_set_stop 15, 4, 1.0, _RGB32(255, 180, 220)

    ' Slot 16: Grayscale
    GRAD_DEFS(16).colorCount% = 4
    GRAD_DEFS(16).gName = "Grayscale"
    GRAD_DEF_set_stop 16, 1, 0.0, _RGB32(0, 0, 0)
    GRAD_DEF_set_stop 16, 2, 0.3333, _RGB32(96, 96, 96)
    GRAD_DEF_set_stop 16, 3, 0.6666, _RGB32(192, 192, 192)
    GRAD_DEF_set_stop 16, 4, 1.0, _RGB32(255, 255, 255)
END SUB

''
' Refresh color stop values for gradients that reference FG or BG colors.
' Called when PAINT_COLOR or PAINT_BG_COLOR changes to keep parametric
' presets in sync. Preserves existing alpha on each stop.
'
SUB GRAD_DEF_update_fg_bg_stops ()
    ' Refresh stop colors for presets that reference FG/BG
    ' Only updates RGB of stops typed as FG or BG, preserving position and alpha
    DIM i AS INTEGER
    DIM j AS INTEGER
    DIM stopAlpha AS INTEGER

    FOR i% = 1 TO DRAWER_SLOT_COUNT
        IF GRAD_DEFS(i%).usesFG% OR GRAD_DEFS(i%).usesBG% THEN
            GRAD_DEFS(i%).previewDirty% = TRUE
            FOR j% = 1 TO GRAD_DEFS(i%).colorCount%
                SELECT CASE GRAD_STOP_TYPES(i%, j%)
                    CASE GRAD_STOP_FG
                        stopAlpha% = _ALPHA32(GRAD_COLOR_STOPS(i%, j%).clr)
                        GRAD_COLOR_STOPS(i%, j%).clr = _RGBA32(_RED32(PAINT_COLOR~&), _GREEN32(PAINT_COLOR~&), _BLUE32(PAINT_COLOR~&), stopAlpha%)
                    CASE GRAD_STOP_BG
                        stopAlpha% = _ALPHA32(GRAD_COLOR_STOPS(i%, j%).clr)
                        GRAD_COLOR_STOPS(i%, j%).clr = _RGBA32(_RED32(PAINT_BG_COLOR~&), _GREEN32(PAINT_BG_COLOR~&), _BLUE32(PAINT_BG_COLOR~&), stopAlpha%)
                END SELECT
            NEXT j%
        END IF
    NEXT i%
END SUB

''
' Evaluate a gradient definition's color at parameter t using its color stops.
' Interpolates between the two bracketing stops at the given position.
' @param slotIndex INTEGER Gradient slot index (1..DRAWER_SLOT_COUNT)
' @param t SINGLE Gradient parameter in range 0.0 to 1.0
' @return _UNSIGNED LONG - interpolated RGBA color
'
FUNCTION GRAD_DEF_eval_color~& (slotIndex AS INTEGER, t AS SINGLE)
    ' Evaluate gradient definition at parameter t using its color stops
    DIM u AS SINGLE
    DIM count AS INTEGER
    DIM i AS INTEGER
    DIM segT AS SINGLE

    IF slotIndex% < 1 OR slotIndex% > DRAWER_SLOT_COUNT THEN
        GRAD_DEF_eval_color~& = _RGB32(0, 0, 0)
        EXIT FUNCTION
    END IF

    count% = GRAD_DEFS(slotIndex%).colorCount%
    IF count% < 1 THEN
        GRAD_DEF_eval_color~& = _RGB32(0, 0, 0)
        EXIT FUNCTION
    END IF

    u! = t!
    IF u! < 0 THEN u! = 0
    IF u! > 1 THEN u! = 1

    ' Single stop: solid color
    IF count% = 1 THEN
        GRAD_DEF_eval_color~& = GRAD_COLOR_STOPS(slotIndex%, 1).clr
        EXIT FUNCTION
    END IF

    ' Before first stop
    IF u! <= GRAD_COLOR_STOPS(slotIndex%, 1).position THEN
        GRAD_DEF_eval_color~& = GRAD_COLOR_STOPS(slotIndex%, 1).clr
        EXIT FUNCTION
    END IF

    ' After last stop
    IF u! >= GRAD_COLOR_STOPS(slotIndex%, count%).position THEN
        GRAD_DEF_eval_color~& = GRAD_COLOR_STOPS(slotIndex%, count%).clr
        EXIT FUNCTION
    END IF

    ' Find the segment containing u
    FOR i% = 1 TO count% - 1
        IF u! >= GRAD_COLOR_STOPS(slotIndex%, i%).position AND u! <= GRAD_COLOR_STOPS(slotIndex%, i% + 1).position THEN
            DIM spanLen AS SINGLE
            spanLen! = GRAD_COLOR_STOPS(slotIndex%, i% + 1).position - GRAD_COLOR_STOPS(slotIndex%, i%).position
            IF spanLen! > 0 THEN
                segT! = (u! - GRAD_COLOR_STOPS(slotIndex%, i%).position) / spanLen!
            ELSE
                segT! = 0
            END IF
            GRAD_DEF_eval_color~& = DRAWER_gradient_lerp_color~&(GRAD_COLOR_STOPS(slotIndex%, i%).clr, GRAD_COLOR_STOPS(slotIndex%, i% + 1).clr, segT!)
            EXIT FUNCTION
        END IF
    NEXT i%

    ' Fallback
    GRAD_DEF_eval_color~& = GRAD_COLOR_STOPS(slotIndex%, count%).clr
END FUNCTION

''
' Evaluate a gradient definition's opacity at parameter t using opacity stops.
' Returns 255 (fully opaque) when no opacity stops are defined.
' @param slotIndex INTEGER Gradient slot index (1..DRAWER_SLOT_COUNT)
' @param t SINGLE Gradient parameter in range 0.0 to 1.0
' @return INTEGER - interpolated opacity value (0..255)
'
FUNCTION GRAD_DEF_eval_opacity% (slotIndex AS INTEGER, t AS SINGLE)
    ' Evaluate gradient opacity stops at parameter t, returns 0..255
    DIM opCount AS INTEGER
    DIM opU AS SINGLE
    DIM opI AS INTEGER
    DIM opSegT AS SINGLE
    DIM opSpan AS SINGLE

    IF slotIndex% < 1 OR slotIndex% > DRAWER_SLOT_COUNT THEN
        GRAD_DEF_eval_opacity% = 255
        EXIT FUNCTION
    END IF

    opCount% = GRAD_DEFS(slotIndex%).opacityCount%
    IF opCount% < 1 THEN
        GRAD_DEF_eval_opacity% = 255
        EXIT FUNCTION
    END IF

    opU! = t!
    IF opU! < 0 THEN opU! = 0
    IF opU! > 1 THEN opU! = 1

    ' Single stop
    IF opCount% = 1 THEN
        GRAD_DEF_eval_opacity% = GRAD_OPACITY_STOPS(slotIndex%, 1).opacity%
        EXIT FUNCTION
    END IF

    ' Before first stop
    IF opU! <= GRAD_OPACITY_STOPS(slotIndex%, 1).position THEN
        GRAD_DEF_eval_opacity% = GRAD_OPACITY_STOPS(slotIndex%, 1).opacity%
        EXIT FUNCTION
    END IF

    ' After last stop
    IF opU! >= GRAD_OPACITY_STOPS(slotIndex%, opCount%).position THEN
        GRAD_DEF_eval_opacity% = GRAD_OPACITY_STOPS(slotIndex%, opCount%).opacity%
        EXIT FUNCTION
    END IF

    ' Find the segment containing opU
    FOR opI% = 1 TO opCount% - 1
        IF opU! >= GRAD_OPACITY_STOPS(slotIndex%, opI%).position AND opU! <= GRAD_OPACITY_STOPS(slotIndex%, opI% + 1).position THEN
            opSpan! = GRAD_OPACITY_STOPS(slotIndex%, opI% + 1).position - GRAD_OPACITY_STOPS(slotIndex%, opI%).position
            IF opSpan! > 0 THEN
                opSegT! = (opU! - GRAD_OPACITY_STOPS(slotIndex%, opI%).position) / opSpan!
            ELSE
                opSegT! = 0
            END IF
            DIM opA AS INTEGER, opB AS INTEGER
            opA% = GRAD_OPACITY_STOPS(slotIndex%, opI%).opacity%
            opB% = GRAD_OPACITY_STOPS(slotIndex%, opI% + 1).opacity%
            GRAD_DEF_eval_opacity% = INT(opA% + (opB% - opA%) * opSegT! + .5)
            EXIT FUNCTION
        END IF
    NEXT opI%

    ' Fallback
    GRAD_DEF_eval_opacity% = GRAD_OPACITY_STOPS(slotIndex%, opCount%).opacity%
END FUNCTION

''
' Rebuild a gradient slot's cached preview image from its definition.
' Renders a 128x128 image applying color stops, opacity stops, and dithering.
' Replaces any existing preview image for the slot.
' @param slotIndex INTEGER Gradient slot index (1..DRAWER_SLOT_COUNT)
'
SUB GRAD_DEF_rebuild_preview (slotIndex AS INTEGER)
    ' Rebuild a slot's cached preview image from its definition
    DIM img AS LONG
    DIM oldDest AS LONG
    DIM x AS INTEGER
    DIM y AS INTEGER
    DIM t AS SINGLE
    DIM w AS INTEGER
    DIM h AS INTEGER
    DIM c AS _UNSIGNED LONG

    IF slotIndex% < 1 OR slotIndex% > DRAWER_SLOT_COUNT THEN EXIT SUB

    w% = 128
    h% = 128

    img& = _NEWIMAGE(w%, h%, 32)
    IF img& >= -1 THEN EXIT SUB

    oldDest& = _DEST
    _DEST img&
    CLS , _RGBA32(0, 0, 0, 0)

    FOR y% = 0 TO h% - 1
        FOR x% = 0 TO w% - 1
            t! = DRAWER_gradient_eval_t!(slotIndex%, x%, y%, w%, h%)
            ' Apply dithering if enabled for this slot
            IF GRAD_DEFS(slotIndex%).ditherMode% <> DITHER_NONE AND GRAD_DEFS(slotIndex%).colorCount% >= 2 THEN
                DIM rpCount AS INTEGER
                DIM rpI AS INTEGER
                DIM rpSegT AS SINGLE
                DIM rpSpan AS SINGLE
                DIM rpThr AS SINGLE
                DIM rpStr AS SINGLE
                rpCount% = GRAD_DEFS(slotIndex%).colorCount%
                rpStr! = GRAD_DEFS(slotIndex%).ditherStrength!

                IF t! <= GRAD_COLOR_STOPS(slotIndex%, 1).position THEN
                    c~& = GRAD_COLOR_STOPS(slotIndex%, 1).clr
                ELSEIF t! >= GRAD_COLOR_STOPS(slotIndex%, rpCount%).position THEN
                    c~& = GRAD_COLOR_STOPS(slotIndex%, rpCount%).clr
                ELSE
                    c~& = GRAD_COLOR_STOPS(slotIndex%, rpCount%).clr
                    FOR rpI% = 1 TO rpCount% - 1
                        IF t! >= GRAD_COLOR_STOPS(slotIndex%, rpI%).position AND t! <= GRAD_COLOR_STOPS(slotIndex%, rpI% + 1).position THEN
                            rpSpan! = GRAD_COLOR_STOPS(slotIndex%, rpI% + 1).position - GRAD_COLOR_STOPS(slotIndex%, rpI%).position
                            IF rpSpan! > 0 THEN rpSegT! = (t! - GRAD_COLOR_STOPS(slotIndex%, rpI%).position) / rpSpan! ELSE rpSegT! = 0
                            rpThr! = DITHER_get_threshold!(GRAD_DEFS(slotIndex%).ditherMode%, x%, y%)
                            ' Blend smooth lerp with binary dither by strength
                            DIM rpSmooth AS _UNSIGNED LONG
                            DIM rpDither AS _UNSIGNED LONG
                            rpSmooth~& = DRAWER_gradient_lerp_color~&(GRAD_COLOR_STOPS(slotIndex%, rpI%).clr, GRAD_COLOR_STOPS(slotIndex%, rpI% + 1).clr, rpSegT!)
                            IF rpSegT! < rpThr! THEN rpDither~& = GRAD_COLOR_STOPS(slotIndex%, rpI%).clr ELSE rpDither~& = GRAD_COLOR_STOPS(slotIndex%, rpI% + 1).clr
                            IF rpStr! >= 1 THEN
                                c~& = rpDither~&
                            ELSEIF rpStr! <= 0 THEN
                                c~& = rpSmooth~&
                            ELSE
                                DIM rpFR AS INTEGER, rpFG AS INTEGER, rpFB AS INTEGER
                                rpFR% = _RED32(rpSmooth~&) + INT((_RED32(rpDither~&) - _RED32(rpSmooth~&)) * rpStr! + .5)
                                rpFG% = _GREEN32(rpSmooth~&) + INT((_GREEN32(rpDither~&) - _GREEN32(rpSmooth~&)) * rpStr! + .5)
                                rpFB% = _BLUE32(rpSmooth~&) + INT((_BLUE32(rpDither~&) - _BLUE32(rpSmooth~&)) * rpStr! + .5)
                                c~& = _RGB32(rpFR%, rpFG%, rpFB%)
                            END IF
                            EXIT FOR
                        END IF
                    NEXT rpI%
                END IF
            ELSE
                c~& = GRAD_DEF_eval_color~&(slotIndex%, t!)
            END IF
            ' Apply opacity stops
            DIM rpAlpha AS INTEGER
            rpAlpha% = GRAD_DEF_eval_opacity%(slotIndex%, t!)
            c~& = GRAD_with_stop_alpha~&(c~&, rpAlpha%)
            PSET (x%, y%), c~&
        NEXT x%
    NEXT y%

    _DEST oldDest&

    ' Free old preview and replace
    IF DRAWER_GRADIENT_SLOTS(slotIndex%) < -1 THEN _FREEIMAGE DRAWER_GRADIENT_SLOTS(slotIndex%)
    DRAWER_GRADIENT_SLOTS(slotIndex%) = img&
    DRAWER_GRADIENT_HAS(slotIndex%) = TRUE
    GRAD_DEFS(slotIndex%).previewDirty% = FALSE
END SUB

''
' Set the operation-bounded gradient context rectangle.
' Coordinates are auto-sorted so X1 <= X2 and Y1 <= Y2.
' @param x1 INTEGER Left or right edge of the operation area
' @param y1 INTEGER Top or bottom edge of the operation area
' @param x2 INTEGER Opposite horizontal edge of the operation area
' @param y2 INTEGER Opposite vertical edge of the operation area
'
SUB GRAD_CTX_set (x1 AS INTEGER, y1 AS INTEGER, x2 AS INTEGER, y2 AS INTEGER)
    ' Set operation-bounded gradient context
    IF x1% <= x2% THEN
        GRAD_CTX.boundsX1% = x1%
        GRAD_CTX.boundsX2% = x2%
    ELSE
        GRAD_CTX.boundsX1% = x2%
        GRAD_CTX.boundsX2% = x1%
    END IF
    IF y1% <= y2% THEN
        GRAD_CTX.boundsY1% = y1%
        GRAD_CTX.boundsY2% = y2%
    ELSE
        GRAD_CTX.boundsY1% = y2%
        GRAD_CTX.boundsY2% = y1%
    END IF
    GRAD_CTX.active% = TRUE
END SUB

''
' Clear the gradient context, resetting bounds to zero and marking inactive.
'
SUB GRAD_CTX_clear ()
    GRAD_CTX.boundsX1% = 0
    GRAD_CTX.boundsY1% = 0
    GRAD_CTX.boundsX2% = 0
    GRAD_CTX.boundsY2% = 0
    GRAD_CTX.active% = FALSE
END SUB

''
' Expand the active gradient context bounds to include a new point.
' Does nothing if the context is not active.
' @param x INTEGER Canvas X coordinate to include in bounds
' @param y INTEGER Canvas Y coordinate to include in bounds
'
SUB GRAD_CTX_expand (x AS INTEGER, y AS INTEGER)
    ' Expand active gradient context bounds to include point (x,y)
    IF NOT GRAD_CTX.active% THEN EXIT SUB
    IF x% < GRAD_CTX.boundsX1% THEN GRAD_CTX.boundsX1% = x%
    IF y% < GRAD_CTX.boundsY1% THEN GRAD_CTX.boundsY1% = y%
    IF x% > GRAD_CTX.boundsX2% THEN GRAD_CTX.boundsX2% = x%
    IF y% > GRAD_CTX.boundsY2% THEN GRAD_CTX.boundsY2% = y%
END SUB

''
' Resolve a gradient color at canvas position (x,y) using operation-bounded
' context. Maps the position to the slot's spatial family, then evaluates
' color stops with optional dithering and opacity.
' @param x INTEGER Canvas X coordinate of the pixel being painted
' @param y INTEGER Canvas Y coordinate of the pixel being painted
' @param baseColor _UNSIGNED LONG Fallback color used when gradient is not active
' @param ctx GRADIENT_CONTEXT Gradient context providing the operation bounding rectangle
' @return _UNSIGNED LONG - resolved RGBA color with opacity applied
'
FUNCTION DRAWER_resolve_gradient_color~& (x AS INTEGER, y AS INTEGER, baseColor AS _UNSIGNED LONG, ctx AS GRADIENT_CONTEXT)
    ' Context-aware gradient resolver: maps (x,y) to gradient color using operation bounds
    DIM slotIdx AS INTEGER
    DIM t AS SINGLE
    DIM boundsW AS INTEGER
    DIM boundsH AS INTEGER
    DIM localX AS INTEGER
    DIM localY AS INTEGER
    DIM family AS INTEGER
    DIM u AS SINGLE
    DIM v AS SINGLE
    DIM dx AS SINGLE
    DIM dy AS SINGLE

    IF _ALPHA32(baseColor~&) = 0 THEN
        DRAWER_resolve_gradient_color~& = baseColor~&
        EXIT FUNCTION
    END IF

    IF DRAWER.paintMode% <> 2 THEN
        DRAWER_resolve_gradient_color~& = PAINT_apply_opacity~&(baseColor~&)
        EXIT FUNCTION
    END IF

    slotIdx% = DRAWER.gradientSelected%
    IF slotIdx% < 1 OR slotIdx% > DRAWER_SLOT_COUNT THEN
        DRAWER_resolve_gradient_color~& = PAINT_apply_opacity~&(baseColor~&)
        EXIT FUNCTION
    END IF

    ' Compute local coordinates relative to context bounds
    boundsW% = ctx.boundsX2% - ctx.boundsX1%
    boundsH% = ctx.boundsY2% - ctx.boundsY1%
    IF boundsW% < 1 THEN boundsW% = 1
    IF boundsH% < 1 THEN boundsH% = 1

    localX% = x% - ctx.boundsX1%
    localY% = y% - ctx.boundsY1%

    ' Evaluate spatial family using local coordinates
    family% = GRAD_DEFS(slotIdx%).family%
    IF family% < GRADIENT_FAMILY_HORIZONTAL OR family% > GRADIENT_FAMILY_DIAMOND THEN family% = GRADIENT_FAMILY_HORIZONTAL
    IF boundsW% > 0 THEN u! = localX% / boundsW% ELSE u! = 0
    IF boundsH% > 0 THEN v! = localY% / boundsH% ELSE v! = 0

    SELECT CASE family%
        CASE GRADIENT_FAMILY_HORIZONTAL
            t! = u!
        CASE GRADIENT_FAMILY_VERTICAL
            t! = v!
        CASE GRADIENT_FAMILY_DIAGONAL
            t! = (u! + v!) / 2
        CASE GRADIENT_FAMILY_ANTI_DIAG
            t! = (u! + (1! - v!)) / 2
        CASE GRADIENT_FAMILY_RADIAL
            dx! = u! - .5
            dy! = v! - .5
            t! = SQR(dx! * dx! + dy! * dy!) / .7071068
        CASE GRADIENT_FAMILY_REFLECTED_H
            t! = ABS((u! - .5) * 2)
        CASE GRADIENT_FAMILY_REFLECTED_V
            t! = ABS((v! - .5) * 2)
        CASE ELSE
            t! = ABS(u! - .5) + ABS(v! - .5)
    END SELECT

    IF t! < 0 THEN t! = 0
    IF t! > 1 THEN t! = 1

    ' Evaluate opacity stops at this t value
    DIM gradAlpha AS INTEGER
    gradAlpha% = GRAD_DEF_eval_opacity%(slotIdx%, t!)

    ' Custom gradients without color stops: sample from the slot image using t
    IF GRAD_DEFS(slotIdx%).colorCount% < 1 THEN
        IF DRAWER_GRADIENT_CUSTOM(slotIdx%) AND DRAWER_GRADIENT_SLOTS(slotIdx%) < -1 THEN
            DIM ciSrc AS LONG
            DIM ciW AS INTEGER
            DIM ciSX AS INTEGER
            DIM ciOldSrc AS LONG
            DIM ciColor AS _UNSIGNED LONG
            ciSrc& = DRAWER_GRADIENT_SLOTS(slotIdx%)
            ciW% = _WIDTH(ciSrc&)
            IF ciW% > 0 THEN
                ciSX% = INT(t! * (ciW% - 1) + .5)
                IF ciSX% < 0 THEN ciSX% = 0
                IF ciSX% >= ciW% THEN ciSX% = ciW% - 1
                ciOldSrc& = _SOURCE
                _SOURCE ciSrc&
                ciColor~& = POINT(ciSX%, 0)
                _SOURCE ciOldSrc&
                DRAWER_resolve_gradient_color~& = PAINT_apply_opacity~&(GRAD_with_stop_alpha~&(ciColor~&, gradAlpha%))
                EXIT FUNCTION
            END IF
        END IF
        DRAWER_resolve_gradient_color~& = PAINT_apply_opacity~&(baseColor~&)
        EXIT FUNCTION
    END IF

    ' Apply dithering if enabled for this gradient slot
    IF GRAD_DEFS(slotIdx%).ditherMode% <> DITHER_NONE AND GRAD_DEFS(slotIdx%).colorCount% >= 2 THEN
        DIM gdCount AS INTEGER
        DIM gdI AS INTEGER
        DIM gdSegT AS SINGLE
        DIM gdSpan AS SINGLE
        DIM gdThreshold AS SINGLE
        DIM gdStrength AS SINGLE
        DIM gdColorA AS _UNSIGNED LONG
        DIM gdColorB AS _UNSIGNED LONG

        gdCount% = GRAD_DEFS(slotIdx%).colorCount%
        gdStrength! = GRAD_DEFS(slotIdx%).ditherStrength!

        ' Before first stop
        IF t! <= GRAD_COLOR_STOPS(slotIdx%, 1).position THEN
            DRAWER_resolve_gradient_color~& = PAINT_apply_opacity~&(GRAD_with_stop_alpha~&(GRAD_COLOR_STOPS(slotIdx%, 1).clr, gradAlpha%))
            EXIT FUNCTION
        END IF

        ' After last stop
        IF t! >= GRAD_COLOR_STOPS(slotIdx%, gdCount%).position THEN
            DRAWER_resolve_gradient_color~& = PAINT_apply_opacity~&(GRAD_with_stop_alpha~&(GRAD_COLOR_STOPS(slotIdx%, gdCount%).clr, gradAlpha%))
            EXIT FUNCTION
        END IF

        ' Find bracketing stops and apply dither threshold
        FOR gdI% = 1 TO gdCount% - 1
            IF t! >= GRAD_COLOR_STOPS(slotIdx%, gdI%).position AND t! <= GRAD_COLOR_STOPS(slotIdx%, gdI% + 1).position THEN
                gdSpan! = GRAD_COLOR_STOPS(slotIdx%, gdI% + 1).position - GRAD_COLOR_STOPS(slotIdx%, gdI%).position
                IF gdSpan! > 0 THEN
                    gdSegT! = (t! - GRAD_COLOR_STOPS(slotIdx%, gdI%).position) / gdSpan!
                ELSE
                    gdSegT! = 0
                END IF
                gdColorA~& = GRAD_COLOR_STOPS(slotIdx%, gdI%).clr
                gdColorB~& = GRAD_COLOR_STOPS(slotIdx%, gdI% + 1).clr
                gdThreshold! = DITHER_get_threshold!(GRAD_DEFS(slotIdx%).ditherMode%, x%, y%)
                ' Blend smooth lerp with binary dither by strength
                DIM gdSmooth AS _UNSIGNED LONG
                DIM gdDither AS _UNSIGNED LONG
                gdSmooth~& = DRAWER_gradient_lerp_color~&(gdColorA~&, gdColorB~&, gdSegT!)
                IF gdSegT! < gdThreshold! THEN gdDither~& = gdColorA~& ELSE gdDither~& = gdColorB~&
                IF gdStrength! >= 1 THEN
                    DRAWER_resolve_gradient_color~& = PAINT_apply_opacity~&(GRAD_with_stop_alpha~&(gdDither~&, gradAlpha%))
                ELSEIF gdStrength! <= 0 THEN
                    DRAWER_resolve_gradient_color~& = PAINT_apply_opacity~&(GRAD_with_stop_alpha~&(gdSmooth~&, gradAlpha%))
                ELSE
                    DIM gdFR AS INTEGER, gdFG AS INTEGER, gdFB AS INTEGER
                    gdFR% = _RED32(gdSmooth~&) + INT((_RED32(gdDither~&) - _RED32(gdSmooth~&)) * gdStrength! + .5)
                    gdFG% = _GREEN32(gdSmooth~&) + INT((_GREEN32(gdDither~&) - _GREEN32(gdSmooth~&)) * gdStrength! + .5)
                    gdFB% = _BLUE32(gdSmooth~&) + INT((_BLUE32(gdDither~&) - _BLUE32(gdSmooth~&)) * gdStrength! + .5)
                    DRAWER_resolve_gradient_color~& = PAINT_apply_opacity~&(GRAD_with_stop_alpha~&(_RGB32(gdFR%, gdFG%, gdFB%), gradAlpha%))
                END IF
                EXIT FUNCTION
            END IF
        NEXT gdI%

        ' Fallback
        DRAWER_resolve_gradient_color~& = PAINT_apply_opacity~&(GRAD_with_stop_alpha~&(GRAD_COLOR_STOPS(slotIdx%, gdCount%).clr, gradAlpha%))
    ELSE
        DRAWER_resolve_gradient_color~& = PAINT_apply_opacity~&(GRAD_with_stop_alpha~&(GRAD_DEF_eval_color~&(slotIdx%, t!), gradAlpha%))
    END IF
END FUNCTION

''
' Ensure all drawer sample images are loaded and up to date.
' Handles theme changes, FG/BG color changes, and initial loading.
' Loads default .dset files from config, falls back to built-in themes.
'
SUB DRAWER_ensure_samples ()
    DIM i AS INTEGER
    DIM imgH AS LONG
    DIM brushNames(1 TO DRAWER_SLOT_COUNT) AS STRING
    DIM themeChanged AS INTEGER
    DIM colorsChanged AS INTEGER

    themeChanged% = (RTRIM$(DRAWER.loadedTheme) <> RTRIM$(CFG.THEME$))
    colorsChanged% = (DRAWER_GRADIENT_LAST_FG~& <> PAINT_COLOR~&) OR (DRAWER_GRADIENT_LAST_BG~& <> PAINT_BG_COLOR~&)

    IF DRAWER.samplesLoaded% AND NOT themeChanged% AND NOT colorsChanged% THEN EXIT SUB

    IF DRAWER.samplesLoaded% AND NOT themeChanged% AND colorsChanged% THEN
        GRAD_DEF_update_fg_bg_stops
        FOR i% = 1 TO DRAWER_SLOT_COUNT
            IF GRAD_DEFS(i%).colorCount% >= 1 THEN
                GRAD_DEF_rebuild_preview i%
            END IF
        NEXT i%
        DRAWER_GRADIENT_LAST_FG~& = PAINT_COLOR~&
        DRAWER_GRADIENT_LAST_BG~& = PAINT_BG_COLOR~&
        EXIT SUB
    END IF

    DRAWER_free_samples

    ' Load default .dset files from config if specified
    DIM loadedBrushes AS INTEGER
    DIM loadedPatterns AS INTEGER
    DIM loadedGradients AS INTEGER
    loadedBrushes% = FALSE
    loadedPatterns% = FALSE
    loadedGradients% = FALSE
    IF CFG.DEFAULT_DSET_BRUSHES_FILE$ <> "" THEN
        loadedBrushes% = DRAWER_load_dset_file%(CFG.DEFAULT_DSET_BRUSHES_FILE$, DRAWER_MODE_BRUSH)
    END IF
    IF CFG.DEFAULT_DSET_PATTERNS_FILE$ <> "" THEN
        loadedPatterns% = DRAWER_load_dset_file%(CFG.DEFAULT_DSET_PATTERNS_FILE$, DRAWER_MODE_PATTERN)
    END IF
    IF CFG.DEFAULT_DSET_GRADIENTS_FILE$ <> "" THEN
        loadedGradients% = DRAWER_load_dset_file%(CFG.DEFAULT_DSET_GRADIENTS_FILE$, DRAWER_MODE_GRADIENT)
    END IF

    ' Fall back to built-in theme samples for any mode not loaded from .dset
    brushNames(1) = "cursor-brush.png"
    brushNames(2) = "cursor-spray.png"
    brushNames(3) = "cursor-fill.png"
    brushNames(4) = "cursor-dropper.png"
    brushNames(5) = "brush.png"
    brushNames(6) = "fill.png"
    brushNames(7) = "line.png"
    brushNames(8) = "rect.png"
    brushNames(9) = "circle.png"
    brushNames(10) = "polygon.png"
    brushNames(11) = "text.png"
    brushNames(12) = "eraser.png"
    brushNames(13) = "move.png"
    brushNames(14) = "zoom.png"
    brushNames(15) = "cursor-crosshair-rect.png"
    brushNames(16) = "cursor-crosshair-ellipse.png"

    FOR i% = 1 TO DRAWER_SLOT_COUNT
        IF NOT loadedPatterns% THEN
            imgH& = DRAWER_load_theme_image&("IMAGES/PATTERNS", "pattern-" + _TRIM$(STR$(i% - 1)) + ".png")
            IF imgH& < -1 THEN
                DRAWER_PATTERN_SLOTS(i%) = imgH&
                DRAWER_PATTERN_HAS(i%) = TRUE
            END IF
        END IF

        IF NOT loadedBrushes% THEN
            IF i% <= 4 THEN
                imgH& = DRAWER_load_theme_image&("CURSORS", brushNames(i%))
            ELSEIF i% <= 14 THEN
                imgH& = DRAWER_load_theme_image&("IMAGES/TOOLBOX", brushNames(i%))
            ELSE
                imgH& = DRAWER_load_theme_image&("CURSORS", brushNames(i%))
            END IF
            IF imgH& < -1 THEN
                DRAWER_BRUSH_SLOTS(i%).IMG = imgH&
                DRAWER_BRUSH_SLOTS(i%).W = _WIDTH(imgH&)
                DRAWER_BRUSH_SLOTS(i%).H = _HEIGHT(imgH&)
            END IF
        END IF

        IF NOT loadedGradients% THEN
            DRAWER_GRADIENT_SLOTS(i%) = DRAWER_create_gradient_sample&(i%)
            DRAWER_GRADIENT_HAS(i%) = (DRAWER_GRADIENT_SLOTS(i%) < -1)
            DRAWER_GRADIENT_CUSTOM(i%) = FALSE
        END IF
    NEXT i%

    DRAWER_PALETTE_IMG& = DRAWER_load_theme_image&("IMAGES/PALETTE", "palette-thin.png")
    DRAWER_PALETTE_LEFT_IMG& = DRAWER_load_theme_image&("IMAGES/PALETTE", "palette-left.png")
    DRAWER_PALETTE_RIGHT_IMG& = DRAWER_load_theme_image&("IMAGES/PALETTE", "palette-right.png")
    IF DRAWER_PALETTE_IMG& < -1 THEN
        DRAWER_sync_palette_marker PAINT_COLOR~&, FALSE
        DRAWER_sync_palette_marker PAINT_BG_COLOR~&, TRUE
    END IF

    ' Ensure all parametric gradient slots reflect current FG/BG colors
    GRAD_DEF_update_fg_bg_stops
    FOR i% = 1 TO DRAWER_SLOT_COUNT
        IF GRAD_DEFS(i%).colorCount% >= 1 AND NOT DRAWER_GRADIENT_CUSTOM(i%) THEN
            GRAD_DEF_rebuild_preview i%
        END IF
    NEXT i%

    DRAWER_analyze_all_1bit

    DRAWER.samplesLoaded% = TRUE
    DRAWER.loadedTheme = _TRIM$(CFG.THEME$)
    DRAWER_GRADIENT_LAST_FG~& = PAINT_COLOR~&
    DRAWER_GRADIENT_LAST_BG~& = PAINT_BG_COLOR~&
END SUB

''
' Switch the drawer panel to the specified mode.
' Closes context menu if open and updates the paint mode accordingly.
' @param mode INTEGER Target drawer mode (DRAWER_MODE_NONE/BRUSH/PATTERN/GRADIENT)
'
SUB DRAWER_set_mode (mode AS INTEGER)
    IF mode% < DRAWER_MODE_NONE OR mode% > DRAWER_MODE_GRADIENT THEN EXIT SUB

    IF DRAWER.contextMenuOpen% THEN DRAWER_context_menu_close

    DIM targetPaintMode AS INTEGER
    IF mode% = DRAWER_MODE_NONE THEN
        DRAWER.visible% = TRUE
        DRAWER.mode% = DRAWER_MODE_BRUSH
        targetPaintMode% = 1
    ELSE
        DRAWER.visible% = TRUE
        DRAWER.mode% = mode%
        targetPaintMode% = DRAWER_paint_mode_from_panel%(mode%)
    END IF

    ' Stash/unstash custom brush when switching between brush and non-brush modes
    IF targetPaintMode% = 1 THEN
        ' Entering brush/color mode — restore stashed custom brush if available
        IF CUSTOM_BRUSH_has_stash% THEN CUSTOM_BRUSH_unstash
    ELSE
        ' Entering pattern/gradient mode — stash active custom brush
        IF CUSTOM_BRUSH_is_active% THEN CUSTOM_BRUSH_stash
    END IF

    DRAWER.paintMode% = targetPaintMode%

    GUI_NEEDS_REDRAW% = TRUE
    FRAME_IDLE% = FALSE
END SUB

''
' Apply configuration defaults for drawer visibility and paint mode.
' Reads DEFAULT_BIN_MODE and DEFAULT_DRAW_MODE from CFG.
'
SUB DRAWER_apply_config_defaults ()
    DRAWER.visible% = TRUE
    DRAWER.mode% = DRAWER_panel_mode_from_config%(CFG.DEFAULT_BIN_MODE%)

    SELECT CASE CFG.DEFAULT_DRAW_MODE%
        CASE 2
            DRAWER.paintMode% = 2
        CASE 3
            DRAWER.paintMode% = 3
        CASE ELSE
            DRAWER.paintMode% = 1
    END SELECT
END SUB

''
' Clear the deferred import action state variables.
'
SUB DRAWER_clear_deferred_action ()
    DRAWER_DEFERRED_IMPORT_SLOT% = 0
    DRAWER_DEFERRED_IMPORT_MODE% = DRAWER_MODE_NONE
END SUB

''
' Queue a deferred slot import dialog for the given slot index.
' Sets MOUSE.DEFERRED_ACTION to 5 so the dialog opens after mouse processing.
' @param slotIndex INTEGER Slot to import into (1..DRAWER_SLOT_COUNT)
'
SUB DRAWER_queue_slot_import (slotIndex AS INTEGER)
    IF slotIndex% < 1 OR slotIndex% > DRAWER_SLOT_COUNT THEN EXIT SUB
    IF DRAWER.mode% < DRAWER_MODE_BRUSH OR DRAWER.mode% > DRAWER_MODE_GRADIENT THEN EXIT SUB

    DRAWER_DEFERRED_IMPORT_SLOT% = slotIndex%
    DRAWER_DEFERRED_IMPORT_MODE% = DRAWER.mode%
    MOUSE.DEFERRED_ACTION% = 5
END SUB

''
' Execute the deferred slot import action.
' Opens a file dialog to load an image into the previously queued slot,
' handling brush, pattern, or gradient mode appropriately.
'
SUB DRAWER_run_deferred_action ()
    DIM defaultPath AS STRING
    DIM dialogTitle AS STRING
    DIM filename AS STRING
    DIM loadedImg AS LONG

    IF DRAWER_DEFERRED_IMPORT_SLOT% < 1 OR DRAWER_DEFERRED_IMPORT_SLOT% > DRAWER_SLOT_COUNT THEN
        DRAWER_clear_deferred_action
        EXIT SUB
    END IF

    IF CFG.LAST_DIR_IMPORT$ <> "" THEN
        defaultPath$ = CFG.LAST_DIR_IMPORT$ + "/"
    ELSEIF LAST_DIRECTORY$ <> "" THEN
        defaultPath$ = LAST_DIRECTORY$ + "/"
    ELSEIF CFG.DEFAULT_OPEN_DIR$ <> "" THEN
        defaultPath$ = CFG.DEFAULT_OPEN_DIR$ + "/"
    ELSE
        defaultPath$ = ""
    END IF

    SELECT CASE DRAWER_DEFERRED_IMPORT_MODE%
        CASE DRAWER_MODE_BRUSH
            dialogTitle$ = "Load Brush Slot"
        CASE DRAWER_MODE_PATTERN
            dialogTitle$ = "Load Pattern Slot"
        CASE DRAWER_MODE_GRADIENT
            dialogTitle$ = "Load Gradient Slot"
        CASE ELSE
            DRAWER_clear_deferred_action
            EXIT SUB
    END SELECT

    POINTER_hide_for_dialog
    filename$ = DRAW_open_file$(dialogTitle$, defaultPath$, "Image files|*.png|*.bmp|*.jpg|*.jpeg|*.gif", 0)
    POINTER_show_after_dialog
    MOUSE_cleanup_after_dialog TRUE

    IF filename$ = "" THEN
        DRAWER_clear_deferred_action
        EXIT SUB
    END IF

    CFG.LAST_DIR_IMPORT$ = CONFIG_extract_dir$(filename$)
    LAST_DIRECTORY$ = CFG.LAST_DIR_IMPORT$
    CONFIG_save

    loadedImg& = _LOADIMAGE(filename$, 32)
    IF loadedImg& < -1 THEN
        SELECT CASE DRAWER_DEFERRED_IMPORT_MODE%
            CASE DRAWER_MODE_BRUSH
                IF DRAWER_BRUSH_SLOTS(DRAWER_DEFERRED_IMPORT_SLOT%).IMG < -1 THEN _FREEIMAGE DRAWER_BRUSH_SLOTS(DRAWER_DEFERRED_IMPORT_SLOT%).IMG
                DRAWER_BRUSH_SLOTS(DRAWER_DEFERRED_IMPORT_SLOT%).IMG = loadedImg&
                DRAWER_BRUSH_SLOTS(DRAWER_DEFERRED_IMPORT_SLOT%).W = _WIDTH(loadedImg&)
                DRAWER_BRUSH_SLOTS(DRAWER_DEFERRED_IMPORT_SLOT%).H = _HEIGHT(loadedImg&)
                DRAWER.brushSelected% = DRAWER_DEFERRED_IMPORT_SLOT%
                DRAWER_load_brush_slot_to_custom DRAWER_DEFERRED_IMPORT_SLOT%
            CASE DRAWER_MODE_PATTERN
                IF DRAWER_PATTERN_SLOTS(DRAWER_DEFERRED_IMPORT_SLOT%) < -1 THEN _FREEIMAGE DRAWER_PATTERN_SLOTS(DRAWER_DEFERRED_IMPORT_SLOT%)
                DRAWER_PATTERN_SLOTS(DRAWER_DEFERRED_IMPORT_SLOT%) = loadedImg&
                DRAWER_PATTERN_HAS(DRAWER_DEFERRED_IMPORT_SLOT%) = TRUE
                DRAWER_analyze_1bit DRAWER_DEFERRED_IMPORT_SLOT%
                DRAWER.patternSelected% = DRAWER_DEFERRED_IMPORT_SLOT%
            CASE DRAWER_MODE_GRADIENT
                IF DRAWER_GRADIENT_SLOTS(DRAWER_DEFERRED_IMPORT_SLOT%) < -1 THEN _FREEIMAGE DRAWER_GRADIENT_SLOTS(DRAWER_DEFERRED_IMPORT_SLOT%)
                DRAWER_GRADIENT_SLOTS(DRAWER_DEFERRED_IMPORT_SLOT%) = loadedImg&
                DRAWER_GRADIENT_HAS(DRAWER_DEFERRED_IMPORT_SLOT%) = TRUE
                DRAWER_GRADIENT_CUSTOM(DRAWER_DEFERRED_IMPORT_SLOT%) = TRUE
                GRAD_DEFS(DRAWER_DEFERRED_IMPORT_SLOT%).colorCount% = 0
                GRAD_DEFS(DRAWER_DEFERRED_IMPORT_SLOT%).opacityCount% = 0
                GRAD_DEFS(DRAWER_DEFERRED_IMPORT_SLOT%).usesFG% = FALSE
                GRAD_DEFS(DRAWER_DEFERRED_IMPORT_SLOT%).usesBG% = FALSE
                DIM cst AS INTEGER
                FOR cst% = 1 TO GRADIENT_MAX_STOPS
                    GRAD_STOP_TYPES(DRAWER_DEFERRED_IMPORT_SLOT%, cst%) = GRAD_STOP_USER
                NEXT cst%
                DRAWER.gradientSelected% = DRAWER_DEFERRED_IMPORT_SLOT%
        END SELECT
        GUI_NEEDS_REDRAW% = TRUE
        FRAME_IDLE% = FALSE
    ELSE
        POINTER_hide_for_dialog
        DRAW_error "Load Error", "Failed to load image: " + filename$
        POINTER_show_after_dialog
        MOUSE_cleanup_after_dialog TRUE
    END IF

    DRAWER_clear_deferred_action
END SUB

''
' Check whether a specific drawer mode is currently active and visible.
' @param mode INTEGER Drawer mode to check (DRAWER_MODE_BRUSH/PATTERN/GRADIENT)
' @return INTEGER - TRUE if the drawer is visible and set to the given mode
'
FUNCTION DRAWER_mode_is_active% (mode AS INTEGER)
    DRAWER_mode_is_active% = (DRAWER.visible% AND DRAWER.mode% = mode%)
END FUNCTION

''
' Check whether the drawer has an active paint mode with a valid source.
' Returns TRUE when pattern or gradient mode is active and the selected
' slot has a loaded image.
' @return INTEGER - TRUE if a non-brush paint mode has a valid source
'
FUNCTION DRAWER_has_paint_mode% ()
    DRAWER_has_paint_mode% = FALSE

    IF DRAWER.paintMode% = 3 THEN
        IF DRAWER.patternSelected% >= 1 AND DRAWER.patternSelected% <= DRAWER_SLOT_COUNT THEN
            DRAWER_has_paint_mode% = (DRAWER_PATTERN_SLOTS(DRAWER.patternSelected%) < -1)
        END IF
    ELSEIF DRAWER.paintMode% = 2 THEN
        IF DRAWER.gradientSelected% >= 1 AND DRAWER.gradientSelected% <= DRAWER_SLOT_COUNT THEN
            DRAWER_has_paint_mode% = (DRAWER_GRADIENT_SLOTS(DRAWER.gradientSelected%) < -1)
        END IF
    END IF
END FUNCTION

''
' Resolve the paint color at a canvas position using the active paint mode.
' In pattern mode, tiles the pattern image across the canvas.
' In gradient mode, maps position to the gradient with optional context bounds.
' @param x INTEGER Canvas X coordinate being painted
' @param y INTEGER Canvas Y coordinate being painted
' @param baseColor _UNSIGNED LONG Base foreground color (used as fallback or for recolor)
' @return _UNSIGNED LONG - resolved color with opacity applied
'
FUNCTION DRAWER_resolve_paint_color~& (x AS INTEGER, y AS INTEGER, baseColor AS _UNSIGNED LONG)
    DIM sampleImg AS LONG
    DIM srcX AS INTEGER
    DIM srcY AS INTEGER
    DIM imgW AS INTEGER
    DIM imgH AS INTEGER
    DIM oldSource AS LONG
    DIM sampleColor AS _UNSIGNED LONG
    DIM clampedX AS INTEGER
    DIM clampedY AS INTEGER

    IF _ALPHA32(baseColor~&) = 0 THEN
        DRAWER_resolve_paint_color~& = baseColor~&
        EXIT FUNCTION
    END IF

    ' When gradient mode has an active context, use operation-bounded resolver
    IF DRAWER.paintMode% = 2 AND GRAD_CTX.active% THEN
        DRAWER_resolve_paint_color~& = DRAWER_resolve_gradient_color~&(x%, y%, baseColor~&, GRAD_CTX)
        EXIT FUNCTION
    END IF

    sampleImg& = 0
    IF DRAWER.paintMode% = 3 THEN
        IF DRAWER.patternSelected% >= 1 AND DRAWER.patternSelected% <= DRAWER_SLOT_COUNT THEN
            sampleImg& = DRAWER_PATTERN_SLOTS(DRAWER.patternSelected%)
        END IF
    ELSEIF DRAWER.paintMode% = 2 THEN
        IF DRAWER.gradientSelected% >= 1 AND DRAWER.gradientSelected% <= DRAWER_SLOT_COUNT THEN
            sampleImg& = DRAWER_GRADIENT_SLOTS(DRAWER.gradientSelected%)
        END IF
    END IF

    IF sampleImg& >= -1 THEN
        DRAWER_resolve_paint_color~& = PAINT_apply_opacity~&(baseColor~&)
        EXIT FUNCTION
    END IF

    imgW% = _WIDTH(sampleImg&)
    imgH% = _HEIGHT(sampleImg&)
    IF imgW% < 1 OR imgH% < 1 THEN
        DRAWER_resolve_paint_color~& = PAINT_apply_opacity~&(baseColor~&)
        EXIT FUNCTION
    END IF

    clampedX% = x%
    clampedY% = y%
    IF clampedX% < 0 THEN clampedX% = 0
    IF clampedY% < 0 THEN clampedY% = 0
    IF clampedX% >= SCRN.canvasW& THEN clampedX% = SCRN.canvasW& - 1
    IF clampedY% >= SCRN.canvasH& THEN clampedY% = SCRN.canvasH& - 1

    IF DRAWER.paintMode% = 3 THEN
        srcX% = clampedX% MOD imgW%
        srcY% = clampedY% MOD imgH%
    ELSE
        IF SCRN.canvasW& > 1 THEN
            srcX% = INT((clampedX% / (SCRN.canvasW& - 1)) * (imgW% - 1))
        ELSE
            srcX% = 0
        END IF
        IF SCRN.canvasH& > 1 THEN
            srcY% = INT((clampedY% / (SCRN.canvasH& - 1)) * (imgH% - 1))
        ELSE
            srcY% = 0
        END IF
    END IF

    oldSource& = _SOURCE
    _SOURCE sampleImg&
    sampleColor~& = POINT(srcX%, srcY%)
    _SOURCE oldSource&

    ' 1-bit pattern auto-remap: FG pixels → baseColor, BG/transparent → PAINT_BG_COLOR
    ' Always takes priority (even over RECOLOR_MODE) since 1-bit patterns need
    ' both FG and BG mapped — RECOLOR_MODE would collapse them to one color.
    IF DRAWER.paintMode% = 3 THEN
        IF DRAWER.patternSelected% >= 1 AND DRAWER.patternSelected% <= DRAWER_SLOT_COUNT THEN
            IF DRAWER_PATTERN_1BIT(DRAWER.patternSelected%) THEN
                DIM sampleRGB AS _UNSIGNED LONG
                sampleRGB~& = _RGB32(_RED32(sampleColor~&), _GREEN32(sampleColor~&), _BLUE32(sampleColor~&))
                IF _ALPHA32(sampleColor~&) > 0 AND sampleRGB~& = DRAWER_PATTERN_1BIT_FG(DRAWER.patternSelected%) THEN
                    ' FG pixel → draw with current paint color
                    DRAWER_resolve_paint_color~& = PAINT_apply_opacity~&(baseColor~&)
                ELSEIF _ALPHA32(sampleColor~&) = 0 THEN
                    ' Truly transparent pixel → always transparent
                    ' (pattern is FG-on-transparent; no opaque BG exists)
                    DRAWER_resolve_paint_color~& = _RGBA32(0, 0, 0, 0)
                ELSE
                    ' Opaque BG pixel (2-color 1-bit pattern) → use BG color or transparent
                    IF PAL_BG_IS_TRANSPARENT% THEN
                        DRAWER_resolve_paint_color~& = _RGBA32(0, 0, 0, 0)
                    ELSE
                        DRAWER_resolve_paint_color~& = PAINT_apply_opacity~&(PAINT_BG_COLOR~&)
                    END IF
                END IF
                EXIT FUNCTION
            END IF
        END IF
    END IF

    ' Recolor mode: use base (FG) color where pattern has non-transparent pixels
    IF DRAWER.paintMode% = 3 AND CUSTOM_BRUSH.RECOLOR_MODE% THEN
        IF _ALPHA32(sampleColor~&) > 0 THEN
            DRAWER_resolve_paint_color~& = PAINT_apply_opacity~&(baseColor~&)
        ELSE
            DRAWER_resolve_paint_color~& = sampleColor~&
        END IF
        EXIT FUNCTION
    END IF

    DRAWER_resolve_paint_color~& = PAINT_apply_opacity~&(sampleColor~&)
END FUNCTION

''
' Convert a drawer panel mode constant to the internal paint mode number.
' @param panelMode INTEGER Drawer panel mode (DRAWER_MODE_BRUSH/PATTERN/GRADIENT)
' @return INTEGER - paint mode: 1=brush, 2=gradient, 3=pattern
'
FUNCTION DRAWER_paint_mode_from_panel% (panelMode AS INTEGER)
    SELECT CASE panelMode%
        CASE DRAWER_MODE_GRADIENT
            DRAWER_paint_mode_from_panel% = 2
        CASE DRAWER_MODE_PATTERN
            DRAWER_paint_mode_from_panel% = 3
        CASE ELSE
            DRAWER_paint_mode_from_panel% = 1
    END SELECT
END FUNCTION

''
' Convert a config bin mode number to a drawer panel mode constant.
' @param binMode INTEGER Config bin mode value (1=brush, 2=pattern, 3=gradient)
' @return INTEGER - DRAWER_MODE_BRUSH, DRAWER_MODE_PATTERN, or DRAWER_MODE_GRADIENT
'
FUNCTION DRAWER_panel_mode_from_config% (binMode AS INTEGER)
    SELECT CASE binMode%
        CASE 2
            DRAWER_panel_mode_from_config% = DRAWER_MODE_PATTERN
        CASE 3
            DRAWER_panel_mode_from_config% = DRAWER_MODE_GRADIENT
        CASE ELSE
            DRAWER_panel_mode_from_config% = DRAWER_MODE_BRUSH
    END SELECT
END FUNCTION

''
' Compute the drawer panel layout geometry including bin grid positions,
' mini palette area, and page button locations. All output parameters are
' set by this sub to reflect the current panel bounds and toolbar scale.
' @param contentX INTEGER [out] X origin of the bin grid content area
' @param contentY INTEGER [out] Y origin of the bin grid content area
' @param binW INTEGER [out] Width of each bin cell in pixels
' @param binH INTEGER [out] Height of each bin cell in pixels
' @param binGapX INTEGER [out] Horizontal gap between bins
' @param binGapY INTEGER [out] Vertical gap between bins
' @param miniX INTEGER [out] X origin of the mini palette area
' @param miniY INTEGER [out] Y origin of the mini palette area
' @param miniCellW INTEGER [out] Width of the mini palette display area
' @param miniCellH INTEGER [out] Height of the mini palette display area
' @param miniGapX INTEGER [out] Horizontal gap in mini palette (unused)
' @param miniGapY INTEGER [out] Vertical gap in mini palette (unused)
' @param pageBtnY INTEGER [out] Y position of the page navigation buttons
' @param scrollX INTEGER [out] Reserved scrollbar X (currently unused)
' @param scrollY INTEGER [out] Reserved scrollbar Y (currently unused)
' @param scrollH INTEGER [out] Reserved scrollbar height (currently unused)
'
SUB DRAWER_layout (contentX AS INTEGER, contentY AS INTEGER, binW AS INTEGER, binH AS INTEGER, binGapX AS INTEGER, binGapY AS INTEGER, miniX AS INTEGER, miniY AS INTEGER, miniCellW AS INTEGER, miniCellH AS INTEGER, miniGapX AS INTEGER, miniGapY AS INTEGER, pageBtnY AS INTEGER, scrollX AS INTEGER, scrollY AS INTEGER, scrollH AS INTEGER)
    DIM padX AS INTEGER
    DIM padY AS INTEGER
    DIM uiScale AS INTEGER
    DIM minRailW AS INTEGER
    DIM maxRailW AS INTEGER
    DIM requiredLeftW AS INTEGER
    DIM leftAreaW AS INTEGER
    DIM railW AS INTEGER
    DIM separatorGap AS INTEGER
    DIM toolbarBottomBars AS INTEGER
    DIM availableBottom AS INTEGER
    DIM pageBtnH AS INTEGER
    DIM pageBtnW AS INTEGER
    DIM panelW AS INTEGER
    DIM paletteMaxH AS INTEGER
    DIM srcW AS INTEGER
    DIM srcH AS INTEGER
    DIM railX AS INTEGER

    uiScale% = CFG.TOOLBAR_SCALE%
    IF uiScale% < 1 THEN uiScale% = 1
    IF uiScale% > 4 THEN uiScale% = 4

    padX% = THEME.DRAWER_PANEL_PAD_X% * uiScale%
    padY% = THEME.DRAWER_PANEL_PAD_Y% * uiScale%
    binW% = THEME.DRAWER_BIN_WIDTH% * uiScale%
    binH% = THEME.DRAWER_BIN_HEIGHT% * uiScale%
    binGapX% = THEME.DRAWER_BIN_GAP_X% * uiScale%
    binGapY% = THEME.DRAWER_BIN_GAP_Y% * uiScale%
    miniCellW% = THEME.DRAWER_MINI_PALETTE_CELL_W% * uiScale%
    miniCellH% = THEME.DRAWER_MINI_PALETTE_CELL_H% * uiScale%
    miniGapX% = THEME.DRAWER_MINI_PALETTE_GAP_X% * uiScale%
    miniGapY% = THEME.DRAWER_MINI_PALETTE_GAP_Y% * uiScale%

    IF padX% < 1 THEN padX% = 1
    IF padY% < 1 THEN padY% = 1
    IF binW% < 6 THEN binW% = 6
    IF binH% < 6 THEN binH% = 6
    separatorGap% = THEME.DRAWER_PANEL_GAP_Y% * uiScale%
    IF separatorGap% < uiScale% THEN separatorGap% = uiScale%

    pageBtnW% = 0
    pageBtnH% = 0

    panelW% = ORGANIZER.panelX2% - ORGANIZER.panelX1% + 1
    IF SCRN.showStatus% THEN
        toolbarBottomBars% = THEME.STATUS_height% + PALETTE_STRIP_get_height%
    ELSE
        toolbarBottomBars% = 0
    END IF
    availableBottom% = SCRN.h& - toolbarBottomBars% - 1
    IF availableBottom% < ORGANIZER.panelY2% + (32 * uiScale%) THEN
        availableBottom% = ORGANIZER.panelY2% + (32 * uiScale%)
    END IF
    railW% = (panelW% * 34) \ 100
    minRailW% = 8 * uiScale%
    IF minRailW% < 12 THEN minRailW% = 12

    DRAWER.panelX1% = ORGANIZER.panelX1%
    DRAWER.panelX2% = DRAWER.panelX1% + panelW% - 1
    DRAWER.panelY1% = ORGANIZER.panelY2% + 1
    DRAWER.panelY2% = availableBottom%

    binGapX% = THEME.DRAWER_BIN_GAP_X% * uiScale%
    binGapY% = THEME.DRAWER_BIN_GAP_Y% * uiScale%
    IF binGapX% < 1 THEN binGapX% = 1
    IF binGapY% < 1 THEN binGapY% = 1
    binW% = THEME.BINS_BRUSH_WIDTH% * uiScale%
    binH% = THEME.BINS_BRUSH_HEIGHT% * uiScale%
    IF binW% < 9 * uiScale% THEN binW% = 9 * uiScale%
    IF binH% < 9 * uiScale% THEN binH% = 9 * uiScale%
    requiredLeftW% = (3 * binW%) + (2 * binGapX%)

    maxRailW% = panelW% - (padX% * 2) - separatorGap% - requiredLeftW%
    IF maxRailW% < minRailW% THEN
        binW% = (panelW% - (padX% * 2) - separatorGap% - minRailW% - (2 * binGapX%)) \ 3
        IF binW% < 4 * uiScale% THEN binW% = 4 * uiScale%
        binH% = binW%
        requiredLeftW% = (3 * binW%) + (2 * binGapX%)
        maxRailW% = panelW% - (padX% * 2) - separatorGap% - requiredLeftW%
    END IF

    IF railW% < minRailW% THEN railW% = minRailW%
    IF railW% > maxRailW% THEN railW% = maxRailW%

    leftAreaW% = panelW% - (padX% * 2) - railW% - separatorGap%
    IF leftAreaW% < requiredLeftW% THEN leftAreaW% = requiredLeftW%

    contentX% = DRAWER.panelX1% + padX%
    contentY% = DRAWER.panelY1% + padY%
    railX% = DRAWER.panelX2% - padX% - railW% + 1

    miniGapX% = 0
    miniGapY% = 0
    paletteMaxH% = DRAWER.panelY2% - contentY% - padY% + 1
    IF paletteMaxH% < 8 * uiScale% THEN paletteMaxH% = 8 * uiScale%

    miniCellW% = railW%
    miniCellH% = paletteMaxH%
    IF DRAWER_PALETTE_IMG& < -1 THEN
        srcW% = _WIDTH(DRAWER_PALETTE_IMG&)
        srcH% = _HEIGHT(DRAWER_PALETTE_IMG&)
        IF srcW% > 0 AND srcH% > 0 THEN
            miniCellH% = (srcH% * miniCellW%) \ srcW%
            IF miniCellH% > paletteMaxH% THEN
                miniCellH% = paletteMaxH%
                miniCellW% = (srcW% * miniCellH%) \ srcH%
            END IF
        END IF
    END IF
    IF miniCellW% < 4 * uiScale% THEN miniCellW% = 4 * uiScale%
    IF miniCellH% < 4 * uiScale% THEN miniCellH% = 4 * uiScale%

    miniX% = railX% + ((railW% - miniCellW%) \ 2)
    miniY% = contentY%
    pageBtnY% = miniY% + miniCellH%
    scrollX% = 0
    scrollY% = 0
    scrollH% = 0
END SUB

''
' Determine which bin slot the mouse is hovering over.
' @param mouseX INTEGER Raw screen X coordinate
' @param mouseY INTEGER Raw screen Y coordinate
' @return INTEGER - slot index (1..DRAWER_SLOT_COUNT) or 0 if not over a slot
'
FUNCTION DRAWER_slot_at% (mouseX AS INTEGER, mouseY AS INTEGER)
    DIM contentX AS INTEGER, contentY AS INTEGER
    DIM binW AS INTEGER, binH AS INTEGER, binGapX AS INTEGER, binGapY AS INTEGER
    DIM miniX AS INTEGER, miniY AS INTEGER, miniCellW AS INTEGER, miniCellH AS INTEGER
    DIM miniGapX AS INTEGER, miniGapY AS INTEGER, pageBtnY AS INTEGER, scrollX AS INTEGER, scrollY AS INTEGER, scrollH AS INTEGER
    DIM row AS INTEGER, col AS INTEGER
    DIM slotX AS INTEGER, slotY AS INTEGER
    DIM slotCols AS INTEGER
    DIM slotRows AS INTEGER
    DIM slotIndex AS INTEGER

    DRAWER_slot_at% = 0
    IF NOT DRAWER.visible% THEN EXIT FUNCTION

    DRAWER_layout contentX%, contentY%, binW%, binH%, binGapX%, binGapY%, miniX%, miniY%, miniCellW%, miniCellH%, miniGapX%, miniGapY%, pageBtnY%, scrollX%, scrollY%, scrollH%

    slotCols% = DRAWER_GRID_COLS
    slotRows% = DRAWER_GRID_ROWS

    FOR row% = 0 TO slotRows% - 1
        FOR col% = 0 TO slotCols% - 1
            slotIndex% = (row% * slotCols%) + col% + 1
            slotX% = contentX% + col% * (binW% + binGapX%)
            slotY% = contentY% + row% * (binH% + binGapY%)
            IF mouseX% >= slotX% AND mouseX% <= slotX% + binW% - 1 AND mouseY% >= slotY% AND mouseY% <= slotY% + binH% - 1 THEN
                IF slotIndex% > DRAWER_SLOT_COUNT THEN EXIT FUNCTION
                DRAWER_slot_at% = slotIndex%
                EXIT FUNCTION
            END IF
        NEXT col%
    NEXT row%
END FUNCTION

''
' Check whether the mouse is over the mini palette display area.
' @param mouseX INTEGER Raw screen X coordinate
' @param mouseY INTEGER Raw screen Y coordinate
' @return INTEGER - 1 if over the palette, 0 otherwise
'
FUNCTION DRAWER_palette_cell_at% (mouseX AS INTEGER, mouseY AS INTEGER)
    DIM contentX AS INTEGER, contentY AS INTEGER
    DIM binW AS INTEGER, binH AS INTEGER, binGapX AS INTEGER, binGapY AS INTEGER
    DIM miniX AS INTEGER, miniY AS INTEGER, miniCellW AS INTEGER, miniCellH AS INTEGER
    DIM miniGapX AS INTEGER, miniGapY AS INTEGER, pageBtnY AS INTEGER, scrollX AS INTEGER, scrollY AS INTEGER, scrollH AS INTEGER
    DRAWER_palette_cell_at% = 0
    IF NOT DRAWER.visible% THEN EXIT FUNCTION

    DRAWER_layout contentX%, contentY%, binW%, binH%, binGapX%, binGapY%, miniX%, miniY%, miniCellW%, miniCellH%, miniGapX%, miniGapY%, pageBtnY%, scrollX%, scrollY%, scrollH%

    IF mouseX% >= miniX% AND mouseX% <= miniX% + miniCellW% - 1 AND mouseY% >= miniY% AND mouseY% <= miniY% + miniCellH% - 1 THEN
        DRAWER_palette_cell_at% = 1
    END IF
END FUNCTION

''
' Check whether the mouse is over a palette page navigation button.
' Currently a stub that always returns 0.
' @param mouseX INTEGER Raw screen X coordinate
' @param mouseY INTEGER Raw screen Y coordinate
' @return INTEGER - page direction or 0 if not over a button
'
FUNCTION DRAWER_palette_page_button_at% (mouseX AS INTEGER, mouseY AS INTEGER)
    IF mouseX% < -1 AND mouseY% < -1 THEN DRAWER_palette_page_button_at% = 0
    DRAWER_palette_page_button_at% = 0
END FUNCTION

''
' Draw a checkerboard transparency pattern within a rectangle.
' Uses theme-defined dark/light checker colors.
' @param x1 INTEGER Left edge of the fill area
' @param y1 INTEGER Top edge of the fill area
' @param x2 INTEGER Right edge of the fill area
' @param y2 INTEGER Bottom edge of the fill area
' @param cellSize INTEGER Size of each checker cell in pixels
'
SUB DRAWER_draw_checker_fill (x1 AS INTEGER, y1 AS INTEGER, x2 AS INTEGER, y2 AS INTEGER, cellSize AS INTEGER)
    DIM px AS INTEGER
    DIM py AS INTEGER
    DIM fillColor AS _UNSIGNED LONG

    IF cellSize% < 1 THEN cellSize% = 1

    FOR py% = y1% TO y2% STEP cellSize%
        FOR px% = x1% TO x2% STEP cellSize%
            IF (((px% - x1%) \ cellSize%) + ((py% - y1%) \ cellSize%)) MOD 2 = 0 THEN
                fillColor~& = THEME.DRAWER_BRUSH_CHECKER_DARK~&
            ELSE
                fillColor~& = THEME.DRAWER_BRUSH_CHECKER_LIGHT~&
            END IF
            LINE (px%, py%)-(px% + cellSize% - 1, py% + cellSize% - 1), fillColor~&, BF
        NEXT px%
    NEXT py%
END SUB

''
' Draw a transparency indicator chip: white fill with a red diagonal line
' and a colored border.
' @param x1 INTEGER Left edge of the chip
' @param y1 INTEGER Top edge of the chip
' @param x2 INTEGER Right edge of the chip
' @param y2 INTEGER Bottom edge of the chip
' @param borderColor _UNSIGNED LONG Color for the chip border
'
SUB DRAWER_draw_transparent_chip (x1 AS INTEGER, y1 AS INTEGER, x2 AS INTEGER, y2 AS INTEGER, borderColor AS _UNSIGNED LONG)
    DIM diagLen AS INTEGER
    DIM diagX0 AS INTEGER
    DIM dp AS INTEGER

    LINE (x1%, y1%)-(x2%, y2%), _RGB32(255, 255, 255), BF
    diagLen% = y2% - y1%
    diagX0% = x1% + ((x2% - x1%) - diagLen%) \ 2
    FOR dp% = 0 TO diagLen%
        PSET (diagX0% + dp%, y1% + dp%), _RGB32(255, 0, 0)
    NEXT dp%
    LINE (x1%, y1%)-(x2%, y2%), borderColor~&, B
END SUB

''
' Render the full drawer panel: bin grid, slot previews, mini palette,
' selection highlights, hover effects, and drag overlay.
'
SUB DRAWER_render ()
    DIM contentX AS INTEGER, contentY AS INTEGER
    DIM binW AS INTEGER, binH AS INTEGER, binGapX AS INTEGER, binGapY AS INTEGER
    DIM miniX AS INTEGER, miniY AS INTEGER, miniCellW AS INTEGER, miniCellH AS INTEGER
    DIM miniGapX AS INTEGER, miniGapY AS INTEGER, pageBtnY AS INTEGER, scrollX AS INTEGER, scrollY AS INTEGER, scrollH AS INTEGER
    DIM row AS INTEGER, col AS INTEGER, slotIndex AS INTEGER
    DIM slotX AS INTEGER, slotY AS INTEGER
    DIM selectedSlot AS INTEGER
    DIM slotImg AS LONG
    DIM cellIndex AS INTEGER
    DIM borderColor AS _UNSIGNED LONG
    DIM bgColor AS _UNSIGNED LONG
    DIM uiScale AS INTEGER
    DIM panelBg AS _UNSIGNED LONG
    DIM railBg AS _UNSIGNED LONG
    DIM slotPad AS INTEGER
    DIM slotInnerX1 AS INTEGER, slotInnerY1 AS INTEGER, slotInnerX2 AS INTEGER, slotInnerY2 AS INTEGER
    DIM slotCols AS INTEGER
    DIM slotRows AS INTEGER
    DIM separatorGap AS INTEGER
    DIM drawX AS INTEGER, drawY AS INTEGER, drawW AS INTEGER, drawH AS INTEGER
    DIM tileX AS INTEGER, tileY AS INTEGER
    DIM tileW AS INTEGER, tileH AS INTEGER
    DIM tileStartX AS INTEGER, tileStartY AS INTEGER
    DIM destX1 AS INTEGER, destY1 AS INTEGER, destX2 AS INTEGER, destY2 AS INTEGER
    DIM srcX1 AS INTEGER, srcY1 AS INTEGER, srcX2 AS INTEGER, srcY2 AS INTEGER
    DIM totalCells AS INTEGER
    DIM padX AS INTEGER
    DIM markerX AS INTEGER
    DIM markerY AS INTEGER
    DIM sourceW AS INTEGER
    DIM sourceH AS INTEGER
    DIM checkerSize AS INTEGER
    DIM remapImg AS LONG
    DIM remapOldDest AS LONG
    DIM remapOldSrc AS LONG
    DIM remapX AS INTEGER
    DIM remapY AS INTEGER
    DIM remapC AS _UNSIGNED LONG
    DIM remapA AS _UNSIGNED LONG
    DIM remapOrigFG AS _UNSIGNED LONG
    DIM sigilS AS INTEGER
    DIM sigilGW AS INTEGER
    DIM sigilGH AS INTEGER
    DIM sigilPad AS INTEGER
    DIM sigilBX AS INTEGER
    DIM sigilBY AS INTEGER
    DIM sigilBW AS INTEGER
    DIM sigilBH AS INTEGER
    DIM sigilOX AS INTEGER
    DIM sigilOY AS INTEGER
    IF NOT DRAWER.visible% OR DRAWER.mode% = DRAWER_MODE_NONE THEN EXIT SUB

    uiScale% = CFG.TOOLBAR_SCALE%
    IF uiScale% < 1 THEN uiScale% = 1
    IF uiScale% > 4 THEN uiScale% = 4
    padX% = THEME.DRAWER_PANEL_PAD_X% * uiScale%
    IF padX% < 1 THEN padX% = 1

    DRAWER_ensure_samples
    DRAWER_layout contentX%, contentY%, binW%, binH%, binGapX%, binGapY%, miniX%, miniY%, miniCellW%, miniCellH%, miniGapX%, miniGapY%, pageBtnY%, scrollX%, scrollY%, scrollH%
    separatorGap% = THEME.DRAWER_PANEL_GAP_Y% * uiScale%
    IF separatorGap% < uiScale% THEN separatorGap% = uiScale%
    checkerSize% = uiScale%
    IF checkerSize% < 1 THEN checkerSize% = 1

    IF DRAWER_PALETTE_IMG& < -1 THEN
        DRAWER_sync_palette_marker PAINT_COLOR~&, FALSE
        DRAWER_sync_palette_marker PAINT_BG_COLOR~&, TRUE
    END IF

    slotCols% = DRAWER_GRID_COLS
    slotRows% = DRAWER_GRID_ROWS
    totalCells% = slotCols% * slotRows%

    panelBg~& = THEME.BINS_BG_COLOR~&
    railBg~& = THEME.BINS_BG_COLOR~&

    LINE (DRAWER.panelX1%, DRAWER.panelY1%)-(DRAWER.panelX2%, DRAWER.panelY2%), panelBg~&, BF
    LINE (miniX% - separatorGap%, contentY% - uiScale%)-(DRAWER.panelX2% - padX%, DRAWER.panelY2% - uiScale%), railBg~&, BF

    SELECT CASE DRAWER.mode%
        CASE DRAWER_MODE_BRUSH
            selectedSlot% = DRAWER.brushSelected%
        CASE DRAWER_MODE_PATTERN
            selectedSlot% = DRAWER.patternSelected%
        CASE ELSE
            selectedSlot% = DRAWER.gradientSelected%
    END SELECT

    STATIC drawerLastHoverSlot AS INTEGER
    DIM drawerHoverHit AS INTEGER
    drawerHoverHit% = FALSE
    cellIndex% = 0
    FOR row% = 0 TO slotRows% - 1
        FOR col% = 0 TO slotCols% - 1
            cellIndex% = cellIndex% + 1
            slotIndex% = cellIndex%
            IF cellIndex% > totalCells% THEN EXIT FOR
            slotX% = contentX% + col% * (binW% + binGapX%)
            slotY% = contentY% + row% * (binH% + binGapY%)

            SELECT CASE DRAWER.mode%
                CASE DRAWER_MODE_BRUSH
                    IF slotIndex% <= DRAWER_SLOT_COUNT THEN slotImg& = DRAWER_BRUSH_SLOTS(slotIndex%).IMG ELSE slotImg& = 0
                    IF slotIndex% <= DRAWER_SLOT_COUNT AND slotImg& < -1 THEN
                        bgColor~& = THEME.DRAWER_BIN_BG~&
                        borderColor~& = THEME.DRAWER_BIN_BORDER~&
                    ELSE
                        bgColor~& = THEME.DRAWER_BIN_EMPTY_BG~&
                        borderColor~& = THEME.DRAWER_BIN_EMPTY_BORDER~&
                    END IF
                CASE DRAWER_MODE_PATTERN
                    IF slotIndex% <= DRAWER_SLOT_COUNT THEN slotImg& = DRAWER_PATTERN_SLOTS(slotIndex%) ELSE slotImg& = 0
                    IF slotIndex% <= DRAWER_SLOT_COUNT AND slotImg& < -1 THEN
                        bgColor~& = THEME.DRAWER_BIN_BG~&
                        borderColor~& = THEME.DRAWER_BIN_BORDER~&
                    ELSE
                        bgColor~& = THEME.DRAWER_BIN_EMPTY_BG~&
                        borderColor~& = THEME.DRAWER_BIN_EMPTY_BORDER~&
                    END IF
                CASE ELSE
                    IF slotIndex% <= DRAWER_SLOT_COUNT THEN slotImg& = DRAWER_GRADIENT_SLOTS(slotIndex%) ELSE slotImg& = 0
                    IF slotIndex% <= DRAWER_SLOT_COUNT AND slotImg& < -1 THEN
                        bgColor~& = THEME.DRAWER_BIN_BG~&
                        borderColor~& = THEME.DRAWER_BIN_BORDER~&
                    ELSE
                        bgColor~& = THEME.DRAWER_BIN_EMPTY_BG~&
                        borderColor~& = THEME.DRAWER_BIN_EMPTY_BORDER~&
                    END IF
            END SELECT

            IF slotIndex% <= DRAWER_SLOT_COUNT AND slotIndex% = selectedSlot% THEN
                bgColor~& = THEME.DRAWER_BIN_BG~&
                SELECT CASE DRAWER.mode%
                    CASE DRAWER_MODE_BRUSH
                        borderColor~& = THEME.DRAWER_BIN_SELECTED_BORDER_BRUSH~&
                    CASE DRAWER_MODE_PATTERN
                        borderColor~& = THEME.DRAWER_BIN_SELECTED_BORDER_PATTERN~&
                    CASE ELSE
                        borderColor~& = THEME.DRAWER_BIN_SELECTED_BORDER_GRADIENT~&
                END SELECT
            ELSEIF MOUSE.RAW_X% >= slotX% AND MOUSE.RAW_X% <= slotX% + binW% - 1 AND MOUSE.RAW_Y% >= slotY% AND MOUSE.RAW_Y% <= slotY% + binH% - 1 THEN
                bgColor~& = THEME.DRAWER_BIN_HOVER_BG~&
                borderColor~& = THEME.DRAWER_BIN_HOVER_BORDER~&
                IF slotIndex% <> drawerLastHoverSlot% THEN
                    drawerLastHoverSlot% = slotIndex%
                    SOUND_play SND_MENU_HOVER
                END IF
            END IF

            LINE (slotX%, slotY%)-(slotX% + binW% - 1, slotY% + binH% - 1), bgColor~&, BF

            slotPad% = THEME.DRAWER_BIN_PREVIEW_PAD% * uiScale%
            IF slotPad% < 1 THEN slotPad% = 1
            slotInnerX1% = slotX% + slotPad%
            slotInnerY1% = slotY% + slotPad%
            slotInnerX2% = slotX% + binW% - slotPad% - 1
            slotInnerY2% = slotY% + binH% - slotPad% - 1
            IF slotInnerX2% <= slotInnerX1% THEN slotInnerX2% = slotX% + binW% - 2
            IF slotInnerY2% <= slotInnerY1% THEN slotInnerY2% = slotY% + binH% - 2

            DRAWER_draw_checker_fill slotInnerX1%, slotInnerY1%, slotInnerX2%, slotInnerY2%, checkerSize%

            IF slotImg& < -1 THEN
                SELECT CASE DRAWER.mode%
                    CASE DRAWER_MODE_PATTERN
                        ' For 1-bit patterns, create a remapped temp image
                        remapImg& = 0
                        IF slotIndex% >= 1 AND slotIndex% <= DRAWER_SLOT_COUNT THEN
                            IF DRAWER_PATTERN_1BIT(slotIndex%) THEN
                                remapOrigFG~& = DRAWER_PATTERN_1BIT_FG(slotIndex%)
                                remapImg& = _COPYIMAGE(slotImg&, 32)
                                IF remapImg& < -1 THEN
                                    remapOldDest& = _DEST
                                    remapOldSrc& = _SOURCE
                                    _SOURCE remapImg&
                                    _DEST remapImg&
                                    FOR remapY% = 0 TO _HEIGHT(remapImg&) - 1
                                        FOR remapX% = 0 TO _WIDTH(remapImg&) - 1
                                            remapC~& = POINT(remapX%, remapY%)
                                            remapA~& = _ALPHA32(remapC~&)
                                            IF remapA~& > 0 THEN
                                                ' Strip alpha for comparison
                                                IF _RGB32(_RED32(remapC~&), _GREEN32(remapC~&), _BLUE32(remapC~&)) = remapOrigFG~& THEN
                                                    PSET (remapX%, remapY%), PAINT_COLOR~&
                                                ELSE
                                                    ' Opaque BG pixel (2-color pattern)
                                                    IF PAL_BG_IS_TRANSPARENT% THEN
                                                        PSET (remapX%, remapY%), _RGBA32(0, 0, 0, 0)
                                                    ELSE
                                                        PSET (remapX%, remapY%), PAINT_BG_COLOR~&
                                                    END IF
                                                END IF
                                            ELSE
                                                ' Transparent pixel → stays transparent
                                                PSET (remapX%, remapY%), _RGBA32(0, 0, 0, 0)
                                            END IF
                                        NEXT remapX%
                                    NEXT remapY%
                                    _DEST remapOldDest&
                                    _SOURCE remapOldSrc&
                                END IF
                            END IF
                        END IF

                        DIM tileImg AS LONG
                        IF remapImg& < -1 THEN tileImg& = remapImg& ELSE tileImg& = slotImg&
                        tileW% = _WIDTH(tileImg&)
                        tileH% = _HEIGHT(tileImg&)
                        IF tileW% > 0 AND tileH% > 0 THEN
                            drawW% = slotInnerX2% - slotInnerX1% + 1
                            drawH% = slotInnerY2% - slotInnerY1% + 1
                            tileStartX% = slotInnerX1% - ((tileW% - (drawW% MOD tileW%)) MOD tileW%) \ 2
                            tileStartY% = slotInnerY1% - ((tileH% - (drawH% MOD tileH%)) MOD tileH%) \ 2
                            FOR tileY% = tileStartY% TO slotInnerY2% STEP tileH%
                                FOR tileX% = tileStartX% TO slotInnerX2% STEP tileW%
                                    destX1% = tileX%
                                    destY1% = tileY%
                                    destX2% = tileX% + tileW% - 1
                                    destY2% = tileY% + tileH% - 1
                                    IF destX1% < slotInnerX1% THEN destX1% = slotInnerX1%
                                    IF destY1% < slotInnerY1% THEN destY1% = slotInnerY1%
                                    IF destX2% > slotInnerX2% THEN destX2% = slotInnerX2%
                                    IF destY2% > slotInnerY2% THEN destY2% = slotInnerY2%
                                    IF destX1% <= destX2% AND destY1% <= destY2% THEN
                                        srcX1% = destX1% - tileX%
                                        srcY1% = destY1% - tileY%
                                        srcX2% = srcX1% + (destX2% - destX1%)
                                        srcY2% = srcY1% + (destY2% - destY1%)
                                        _PUTIMAGE (destX1%, destY1%)-(destX2%, destY2%), tileImg&, SCRN.GUI&, (srcX1%, srcY1%)-(srcX2%, srcY2%)
                                    END IF
                                NEXT tileX%
                            NEXT tileY%
                        END IF

                        IF remapImg& < -1 THEN _FREEIMAGE remapImg&

                        ' Draw tiny "1" sigil badge on 1-bit pattern bins
                        IF slotIndex% >= 1 AND slotIndex% <= DRAWER_SLOT_COUNT THEN
                            IF DRAWER_PATTERN_1BIT(slotIndex%) THEN
                                ' Each glyph "pixel" is 1x1 (no scaling)
                                sigilS% = 1
                                ' 3x3 pixel art "1":
                                '  .#.
                                '  ##.
                                '  .#.
                                sigilGW% = 3 * sigilS%
                                sigilGH% = 3 * sigilS%
                                sigilPad% = THEME.DRAWER_BIN_1BIT_SIGIL_PAD% * sigilS%
                                IF sigilPad% < sigilS% THEN sigilPad% = sigilS%
                                sigilBW% = sigilGW% + sigilPad% * 2
                                sigilBH% = sigilGH% + sigilPad% * 2
                                sigilBX% = slotInnerX2% - sigilBW% + 1
                                sigilBY% = slotInnerY2% - sigilBH% + 1
                                IF sigilBX% < slotInnerX1% THEN sigilBX% = slotInnerX1%
                                IF sigilBY% < slotInnerY1% THEN sigilBY% = slotInnerY1%
                                ' Background
                                LINE (sigilBX%, sigilBY%)-(sigilBX% + sigilBW% - 1, sigilBY% + sigilBH% - 1), THEME.DRAWER_BIN_1BIT_SIGIL_BG~&, BF
                                ' Border
                                LINE (sigilBX%, sigilBY%)-(sigilBX% + sigilBW% - 1, sigilBY% + sigilBH% - 1), THEME.DRAWER_BIN_1BIT_SIGIL_BORDER~&, B
                                ' Draw 3x3 "1" glyph
                                sigilOX% = sigilBX% + sigilPad%
                                sigilOY% = sigilBY% + sigilPad%
                                ' Row 0: .#.
                                LINE (sigilOX% + sigilS%, sigilOY%)-(sigilOX% + sigilS% * 2 - 1, sigilOY% + sigilS% - 1), THEME.DRAWER_BIN_1BIT_SIGIL_FG~&, BF
                                ' Row 1: ##.
                                LINE (sigilOX%, sigilOY% + sigilS%)-(sigilOX% + sigilS% * 2 - 1, sigilOY% + sigilS% * 2 - 1), THEME.DRAWER_BIN_1BIT_SIGIL_FG~&, BF
                                ' Row 2: .#.
                                LINE (sigilOX% + sigilS%, sigilOY% + sigilS% * 2)-(sigilOX% + sigilS% * 2 - 1, sigilOY% + sigilS% * 3 - 1), THEME.DRAWER_BIN_1BIT_SIGIL_FG~&, BF
                            END IF
                        END IF
                    CASE DRAWER_MODE_BRUSH
                        drawW% = slotInnerX2% - slotInnerX1% + 1 - uiScale%
                        drawH% = slotInnerY2% - slotInnerY1% + 1 - uiScale%
                        IF drawW% < 1 THEN drawW% = slotInnerX2% - slotInnerX1% + 1
                        IF drawH% < 1 THEN drawH% = slotInnerY2% - slotInnerY1% + 1
                        IF drawW% > drawH% THEN drawW% = drawH%
                        IF drawH% > drawW% THEN drawH% = drawW%
                        drawX% = slotInnerX1%
                        drawY% = slotInnerY1% + uiScale%
                        IF drawY% + drawH% - 1 > slotInnerY2% THEN drawY% = slotInnerY1%
                        _PUTIMAGE (drawX%, drawY%)-(drawX% + drawW% - 1, drawY% + drawH% - 1), slotImg&, SCRN.GUI&
                    CASE ELSE
                        _PUTIMAGE (slotInnerX1%, slotInnerY1%)-(slotInnerX2%, slotInnerY2%), slotImg&, SCRN.GUI&
                END SELECT
            ELSEIF DRAWER.mode% = DRAWER_MODE_GRADIENT THEN
                LINE (slotInnerX1%, slotInnerY1%)-(slotInnerX2%, slotInnerY2%), railBg~&, BF
                LINE (slotInnerX1%, slotInnerY1%)-(slotInnerX2%, slotInnerY2%), THEME.DRAWER_BIN_DISABLED_FG~&, B
                LINE (slotInnerX1%, slotInnerY1%)-(slotInnerX2%, slotInnerY2%), THEME.DRAWER_BIN_DISABLED_FG~&
                LINE (slotInnerX2%, slotInnerY1%)-(slotInnerX1%, slotInnerY2%), THEME.DRAWER_BIN_DISABLED_FG~&
            END IF

            ' Draw border on top of content (selected / hover / normal)
            LINE (slotX%, slotY%)-(slotX% + binW% - 1, slotY% + binH% - 1), borderColor~&, B
            IF MOUSE.RAW_X% >= slotX% AND MOUSE.RAW_X% <= slotX% + binW% - 1 AND MOUSE.RAW_Y% >= slotY% AND MOUSE.RAW_Y% <= slotY% + binH% - 1 THEN
                drawerHoverHit% = TRUE
            END IF
        NEXT col%
    NEXT row%
    IF NOT drawerHoverHit% THEN drawerLastHoverSlot% = 0

    ' --- Drag overlay: highlight drop target and draw ghost of dragged bin ---
    IF DRAWER.isDragging% THEN
        DIM dragRow AS INTEGER, dragCol AS INTEGER
        DIM dragSlotX AS INTEGER, dragSlotY AS INTEGER
        ' Draw highlight on drop target slot
        IF DRAWER.dragTargetSlot% > 0 THEN
            dragRow% = (DRAWER.dragTargetSlot% - 1) \ slotCols%
            dragCol% = (DRAWER.dragTargetSlot% - 1) MOD slotCols%
            dragSlotX% = contentX% + dragCol% * (binW% + binGapX%)
            dragSlotY% = contentY% + dragRow% * (binH% + binGapY%)
            IF MODIFIERS.shift% THEN
                ' Insert mode indicator: thick colored line on the edge closest to source
                DIM edgeX AS INTEGER, edgeY AS INTEGER
                DIM lineThick AS INTEGER
                lineThick% = uiScale%
                IF lineThick% < 1 THEN lineThick% = 1
                IF DRAWER.dragSourceSlot% < DRAWER.dragTargetSlot% THEN
                    ' Source is above/left - draw line on left/top edge
                    edgeX% = dragSlotX%
                    edgeY% = dragSlotY%
                    LINE (edgeX%, edgeY%)-(edgeX%, edgeY% + binH% - 1), THEME.DRAWER_BIN_DRAG_INSERT_LINE~&, BF
                    IF lineThick% > 1 THEN LINE (edgeX% + 1, edgeY%)-(edgeX% + lineThick% - 1, edgeY% + binH% - 1), THEME.DRAWER_BIN_DRAG_INSERT_LINE~&, BF
                ELSE
                    ' Source is below/right - draw line on right/bottom edge
                    edgeX% = dragSlotX% + binW% - 1
                    edgeY% = dragSlotY%
                    LINE (edgeX%, edgeY%)-(edgeX%, edgeY% + binH% - 1), THEME.DRAWER_BIN_DRAG_INSERT_LINE~&, BF
                    IF lineThick% > 1 THEN LINE (edgeX% - lineThick% + 1, edgeY%)-(edgeX%, edgeY% + binH% - 1), THEME.DRAWER_BIN_DRAG_INSERT_LINE~&, BF
                END IF
            ELSE
                ' Swap mode indicator: highlighted border on drop target
                LINE (dragSlotX%, dragSlotY%)-(dragSlotX% + binW% - 1, dragSlotY% + binH% - 1), THEME.DRAWER_BIN_DRAG_SWAP_BORDER~&, B
                IF uiScale% > 1 THEN LINE (dragSlotX% + 1, dragSlotY% + 1)-(dragSlotX% + binW% - 2, dragSlotY% + binH% - 2), THEME.DRAWER_BIN_DRAG_SWAP_BORDER~&, B
            END IF
        END IF
        ' Dim the source slot to show it's being dragged
        dragRow% = (DRAWER.dragSourceSlot% - 1) \ slotCols%
        dragCol% = (DRAWER.dragSourceSlot% - 1) MOD slotCols%
        dragSlotX% = contentX% + dragCol% * (binW% + binGapX%)
        dragSlotY% = contentY% + dragRow% * (binH% + binGapY%)
        LINE (dragSlotX%, dragSlotY%)-(dragSlotX% + binW% - 1, dragSlotY% + binH% - 1), THEME.DRAWER_BIN_DRAG_SOURCE_FILL~&, BF
    END IF

    LINE (miniX%, miniY%)-(miniX% + miniCellW% - 1, miniY% + miniCellH% - 1), THEME.DRAWER_BIN_EMPTY_BG~&, BF
    IF DRAWER_PALETTE_IMG& < -1 THEN
        _PUTIMAGE (miniX%, miniY%)-(miniX% + miniCellW% - 1, miniY% + miniCellH% - 1), DRAWER_PALETTE_IMG&, SCRN.GUI&
    END IF

    IF DRAWER_PALETTE_IMG& < -1 THEN
        sourceW% = _WIDTH(DRAWER_PALETTE_IMG&)
        sourceH% = _HEIGHT(DRAWER_PALETTE_IMG&)
        IF sourceW% > 1 AND sourceH% > 1 THEN
            IF DRAWER.paletteFGX% >= 0 AND DRAWER.paletteFGY% >= 0 THEN
                markerX% = miniX% + (DRAWER.paletteFGX% * (miniCellW% - 1)) \ (sourceW% - 1)
                markerY% = miniY% + (DRAWER.paletteFGY% * (miniCellH% - 1)) \ (sourceH% - 1)
                LINE (markerX%, markerY%)-(markerX% + 1, markerY% + 1), _RGB32(255, 255, 255), BF
            END IF
            IF DRAWER.paletteBGX% >= 0 AND DRAWER.paletteBGY% >= 0 THEN
                markerX% = miniX% + (DRAWER.paletteBGX% * (miniCellW% - 1)) \ (sourceW% - 1)
                markerY% = miniY% + (DRAWER.paletteBGY% * (miniCellH% - 1)) \ (sourceH% - 1)
                markerY% = markerY% + uiScale%
                IF markerY% > miniY% + miniCellH% - 2 THEN markerY% = miniY% + miniCellH% - 2
                LINE (markerX%, markerY%)-(markerX% + 1, markerY% + 1), _RGB32(255, 255, 255), BF
            END IF
        END IF
    END IF

END SUB

''
' Check whether the mouse is anywhere within the drawer panel bounds.
' @param mouseX INTEGER Raw screen X coordinate
' @param mouseY INTEGER Raw screen Y coordinate
' @return INTEGER - TRUE if the mouse is within the panel area
'
FUNCTION DRAWER_is_over_area% (mouseX AS INTEGER, mouseY AS INTEGER)
    DIM contentX AS INTEGER, contentY AS INTEGER
    DIM binW AS INTEGER, binH AS INTEGER, binGapX AS INTEGER, binGapY AS INTEGER
    DIM miniX AS INTEGER, miniY AS INTEGER, miniCellW AS INTEGER, miniCellH AS INTEGER
    DIM miniGapX AS INTEGER, miniGapY AS INTEGER, pageBtnY AS INTEGER, scrollX AS INTEGER, scrollY AS INTEGER, scrollH AS INTEGER

    DRAWER_is_over_area% = FALSE
    IF NOT DRAWER.visible% THEN EXIT FUNCTION
    DRAWER_layout contentX%, contentY%, binW%, binH%, binGapX%, binGapY%, miniX%, miniY%, miniCellW%, miniCellH%, miniGapX%, miniGapY%, pageBtnY%, scrollX%, scrollY%, scrollH%
    IF mouseX% >= DRAWER.panelX1% AND mouseX% <= DRAWER.panelX2% AND mouseY% >= DRAWER.panelY1% AND mouseY% <= DRAWER.panelY2% THEN
        DRAWER_is_over_area% = TRUE
    END IF
END FUNCTION

''
' Check whether the mouse is over a specific drawer bin slot.
' @param mouseX INTEGER Raw screen X coordinate
' @param mouseY INTEGER Raw screen Y coordinate
' @return INTEGER - TRUE if the mouse is over any bin slot
'
FUNCTION DRAWER_is_over_slot% (mouseX AS INTEGER, mouseY AS INTEGER)
    DRAWER_is_over_slot% = (DRAWER_slot_at%(mouseX%, mouseY%) > 0)
END FUNCTION

''
' Check whether the mouse is over the drawer's mini palette area.
' @param mouseX INTEGER Raw screen X coordinate
' @param mouseY INTEGER Raw screen Y coordinate
' @return INTEGER - TRUE if the mouse is over the mini palette
'
FUNCTION DRAWER_is_over_palette% (mouseX AS INTEGER, mouseY AS INTEGER)
    DRAWER_is_over_palette% = (DRAWER_palette_cell_at%(mouseX%, mouseY%) > 0)
END FUNCTION

''
' Load a brush slot's image into the custom brush pipeline.
' Copies the slot image and activates the custom brush.
' @param slotIndex INTEGER Brush slot index (1..DRAWER_SLOT_COUNT)
'
SUB DRAWER_load_brush_slot_to_custom (slotIndex AS INTEGER)
    IF slotIndex% < 1 OR slotIndex% > DRAWER_SLOT_COUNT THEN EXIT SUB
    IF DRAWER_BRUSH_SLOTS(slotIndex%).IMG >= -1 THEN EXIT SUB

    CUSTOM_BRUSH_reset
    CUSTOM_BRUSH.IMAGE& = _COPYIMAGE(DRAWER_BRUSH_SLOTS(slotIndex%).IMG, 32)
    CUSTOM_BRUSH.WIDTH% = _WIDTH(CUSTOM_BRUSH.IMAGE&)
    CUSTOM_BRUSH.HEIGHT% = _HEIGHT(CUSTOM_BRUSH.IMAGE&)
    CUSTOM_BRUSH.ORIG_WIDTH% = CUSTOM_BRUSH.WIDTH%
    CUSTOM_BRUSH.ORIG_HEIGHT% = CUSTOM_BRUSH.HEIGHT%
    CUSTOM_BRUSH.SCALE! = 1.0
    CUSTOM_BRUSH.ACTIVE% = TRUE
END SUB

''
' Store current content into a drawer slot based on the active mode.
' Brush mode: stores custom brush or clipboard image.
' Pattern mode: stores clipboard or custom brush image.
' Gradient mode: creates a 2-stop FG-to-BG gradient.
' @param slotIndex INTEGER Target slot index (1..DRAWER_SLOT_COUNT)
'
SUB DRAWER_store_to_slot (slotIndex AS INTEGER)
    DIM srcImg AS LONG

    IF slotIndex% < 1 OR slotIndex% > DRAWER_SLOT_COUNT THEN EXIT SUB

    SELECT CASE DRAWER.mode%
        CASE DRAWER_MODE_BRUSH
            ' Store custom brush or clipboard image into brush slot
            srcImg& = 0
            IF CUSTOM_BRUSH.ACTIVE% AND CUSTOM_BRUSH.IMAGE& < -1 THEN
                srcImg& = CUSTOM_BRUSH.IMAGE&
            ELSEIF CLIPBOARD.VALID% AND CLIPBOARD.IMAGE& < -1 THEN
                srcImg& = CLIPBOARD.IMAGE&
            END IF
            IF srcImg& < -1 THEN
                IF DRAWER_BRUSH_SLOTS(slotIndex%).IMG < -1 THEN _FREEIMAGE DRAWER_BRUSH_SLOTS(slotIndex%).IMG
                DRAWER_BRUSH_SLOTS(slotIndex%).IMG = _COPYIMAGE(srcImg&, 32)
                DRAWER_BRUSH_SLOTS(slotIndex%).W = _WIDTH(DRAWER_BRUSH_SLOTS(slotIndex%).IMG)
                DRAWER_BRUSH_SLOTS(slotIndex%).H = _HEIGHT(DRAWER_BRUSH_SLOTS(slotIndex%).IMG)
                DRAWER.brushSelected% = slotIndex%
            END IF

        CASE DRAWER_MODE_PATTERN
            ' Store clipboard image into pattern slot
            srcImg& = 0
            IF CLIPBOARD.VALID% AND CLIPBOARD.IMAGE& < -1 THEN
                srcImg& = CLIPBOARD.IMAGE&
            ELSEIF CUSTOM_BRUSH.ACTIVE% AND CUSTOM_BRUSH.IMAGE& < -1 THEN
                srcImg& = CUSTOM_BRUSH.IMAGE&
            END IF
            IF srcImg& < -1 THEN
                IF DRAWER_PATTERN_SLOTS(slotIndex%) < -1 THEN _FREEIMAGE DRAWER_PATTERN_SLOTS(slotIndex%)
                DRAWER_PATTERN_SLOTS(slotIndex%) = _COPYIMAGE(srcImg&, 32)
                DRAWER_PATTERN_HAS(slotIndex%) = TRUE
                DRAWER_analyze_1bit slotIndex%
                DRAWER.patternSelected% = slotIndex%
            END IF

        CASE DRAWER_MODE_GRADIENT
            ' Store current FG->BG as a 2-stop gradient
            GRAD_DEFS(slotIndex%).colorCount% = 2
            IF GRAD_DEFS(slotIndex%).family% < 1 OR GRAD_DEFS(slotIndex%).family% > 8 THEN
                GRAD_DEFS(slotIndex%).family% = 1
            END IF
            GRAD_DEFS(slotIndex%).usesFG% = FALSE
            GRAD_DEFS(slotIndex%).usesBG% = FALSE
            GRAD_COLOR_STOPS(slotIndex%, 1).position = 0
            GRAD_COLOR_STOPS(slotIndex%, 1).clr = PAINT_COLOR~&
            GRAD_COLOR_STOPS(slotIndex%, 2).position = 1
            GRAD_COLOR_STOPS(slotIndex%, 2).clr = PAINT_BG_COLOR~&
            GRAD_DEF_rebuild_preview slotIndex%
            DRAWER.gradientSelected% = slotIndex%
    END SELECT

    SOUND_play SND_FILL
    GUI_NEEDS_REDRAW% = TRUE
    FRAME_IDLE% = FALSE

    ' Easter egg: all brush bins filled with the same brush
    IF DRAWER.mode% = DRAWER_MODE_BRUSH THEN
        DRAWER_check_brush_easter_egg
    END IF
END SUB


''
' Easter egg: check if all brush bins contain identical brushes.
' If so, show a congratulatory message and play the startup sound.
'
SUB DRAWER_check_brush_easter_egg ()
    DIM i AS INTEGER
    DIM refW AS INTEGER, refH AS INTEGER
    DIM refMem AS _MEM, cmpMem AS _MEM
    DIM refCRC AS _UNSIGNED LONG, cmpCRC AS _UNSIGNED LONG
    DIM allMatch AS INTEGER

    ' All slots must have a valid image
    FOR i% = 1 TO DRAWER_SLOT_COUNT
        IF DRAWER_BRUSH_SLOTS(i%).IMG >= -1 THEN EXIT SUB
    NEXT i%

    ' All must have the same dimensions as slot 1
    refW% = DRAWER_BRUSH_SLOTS(1).W
    refH% = DRAWER_BRUSH_SLOTS(1).H
    IF refW% < 1 OR refH% < 1 THEN EXIT SUB
    FOR i% = 2 TO DRAWER_SLOT_COUNT
        IF DRAWER_BRUSH_SLOTS(i%).W <> refW% OR DRAWER_BRUSH_SLOTS(i%).H <> refH% THEN EXIT SUB
    NEXT i%

    ' Compare pixel data via CRC32
    DIM refData AS STRING, cmpData AS STRING
    refMem = _MEMIMAGE(DRAWER_BRUSH_SLOTS(1).IMG)
    refData$ = SPACE$(refMem.SIZE)
    _MEMGET refMem, refMem.OFFSET, refData$
    refCRC~& = _CRC32(refData$)
    _MEMFREE refMem
    allMatch% = TRUE
    FOR i% = 2 TO DRAWER_SLOT_COUNT
        cmpMem = _MEMIMAGE(DRAWER_BRUSH_SLOTS(i%).IMG)
        cmpData$ = SPACE$(cmpMem.SIZE)
        _MEMGET cmpMem, cmpMem.OFFSET, cmpData$
        cmpCRC~& = _CRC32(cmpData$)
        _MEMFREE cmpMem
        IF cmpCRC~& <> refCRC~& THEN
            allMatch% = FALSE
            EXIT FOR
        END IF
    NEXT i%

    IF allMatch% THEN
        SOUND_play SND_NEW_FILE
        POINTER_hide_for_dialog
        DRAW_alert "GREAT JOB!", "GREAT JOB!" + CHR$(10) + "~Tim and Eric"
        POINTER_show_after_dialog
        MOUSE_cleanup_after_dialog FALSE
    END IF
END SUB

''
' Clear a single drawer slot in the current mode, freeing its image.
' @param slotIndex INTEGER Slot index to clear (1..DRAWER_SLOT_COUNT)
'
SUB DRAWER_clear_slot (slotIndex AS INTEGER)
    IF slotIndex% < 1 OR slotIndex% > DRAWER_SLOT_COUNT THEN EXIT SUB

    SELECT CASE DRAWER.mode%
        CASE DRAWER_MODE_BRUSH
            IF DRAWER_BRUSH_SLOTS(slotIndex%).IMG < -1 THEN _FREEIMAGE DRAWER_BRUSH_SLOTS(slotIndex%).IMG
            DRAWER_BRUSH_SLOTS(slotIndex%).IMG = 0
            DRAWER_BRUSH_SLOTS(slotIndex%).W = 0
            DRAWER_BRUSH_SLOTS(slotIndex%).H = 0
        CASE DRAWER_MODE_PATTERN
            IF DRAWER_PATTERN_SLOTS(slotIndex%) < -1 THEN _FREEIMAGE DRAWER_PATTERN_SLOTS(slotIndex%)
            DRAWER_PATTERN_SLOTS(slotIndex%) = 0
            DRAWER_PATTERN_HAS(slotIndex%) = FALSE
            DRAWER_PATTERN_1BIT(slotIndex%) = FALSE
            DRAWER_PATTERN_1BIT_FG(slotIndex%) = 0
            DRAWER_PATTERN_1BIT_HAS_BG(slotIndex%) = FALSE
        CASE DRAWER_MODE_GRADIENT
            IF DRAWER_GRADIENT_SLOTS(slotIndex%) < -1 THEN _FREEIMAGE DRAWER_GRADIENT_SLOTS(slotIndex%)
            DRAWER_GRADIENT_SLOTS(slotIndex%) = 0
            DRAWER_GRADIENT_HAS(slotIndex%) = FALSE
            GRAD_DEFS(slotIndex%).colorCount% = 0
    END SELECT

    SOUND_play SND_LAYER_OP
    GUI_NEEDS_REDRAW% = TRUE
    FRAME_IDLE% = FALSE
END SUB


''
' Returns TRUE if a drawer bin drag is in progress or pending
' @return INTEGER - TRUE if dragging or drag pending, FALSE otherwise
'
FUNCTION DRAWER_is_dragging% ()
    DRAWER_is_dragging% = DRAWER.isDragging% OR DRAWER.dragPending%
END FUNCTION


''
' Cancel any in-progress or pending drawer bin drag
'
SUB DRAWER_drag_cancel ()
    DRAWER.dragPending% = FALSE
    DRAWER.isDragging% = FALSE
    DRAWER.dragSourceSlot% = 0
    DRAWER.dragTargetSlot% = 0
    DRAWER.dragStartX% = 0
    DRAWER.dragStartY% = 0
    GUI_NEEDS_REDRAW% = TRUE
END SUB


''
' Handle mouse movement during a drawer bin drag operation.
' Promotes pending to active after threshold, then updates drop target.
' @param rawX INTEGER Raw screen X coordinate of the mouse cursor
' @param rawY INTEGER Raw screen Y coordinate of the mouse cursor
'
SUB DRAWER_handle_drag (rawX AS INTEGER, rawY AS INTEGER)
    CONST DRAG_THRESHOLD = 5
    DIM dx AS INTEGER, dy AS INTEGER
    DIM target AS INTEGER

    ' Check if pending drag should promote to active
    IF DRAWER.dragPending% THEN
        dx% = ABS(rawX% - DRAWER.dragStartX%)
        dy% = ABS(rawY% - DRAWER.dragStartY%)
        IF dx% >= DRAG_THRESHOLD OR dy% >= DRAG_THRESHOLD THEN
            DRAWER.dragPending% = FALSE
            DRAWER.isDragging% = TRUE
        ELSE
            EXIT SUB
        END IF
    END IF

    IF NOT DRAWER.isDragging% THEN EXIT SUB

    ' Find what slot the mouse is currently over
    target% = DRAWER_slot_at%(rawX%, rawY%)
    IF target% > 0 AND target% <> DRAWER.dragSourceSlot% THEN
        DRAWER.dragTargetSlot% = target%
    ELSE
        DRAWER.dragTargetSlot% = 0
    END IF
    GUI_NEEDS_REDRAW% = TRUE
    FRAME_IDLE% = FALSE
END SUB


''
' Select a slot (the same logic that was in handle_click before drag was added)
' @param slotIndex INTEGER Slot index to select (1..DRAWER_SLOT_COUNT)
'
SUB DRAWER_select_slot (slotIndex AS INTEGER)
    IF slotIndex% < 1 OR slotIndex% > DRAWER_SLOT_COUNT THEN EXIT SUB
    SELECT CASE DRAWER.mode%
        CASE DRAWER_MODE_BRUSH
            DRAWER.brushSelected% = slotIndex%
            DRAWER_load_brush_slot_to_custom slotIndex%
            DRAWER.paintMode% = 1
        CASE DRAWER_MODE_PATTERN
            DRAWER.patternSelected% = slotIndex%
            DRAWER.paintMode% = 3
            CUSTOM_BRUSH.RECOLOR_MODE% = FALSE
        CASE DRAWER_MODE_GRADIENT
            DRAWER.gradientSelected% = slotIndex%
            DRAWER.paintMode% = 2
    END SELECT
END SUB


''
' Swap all parallel array data between two bin slots for the current mode.
' @param slotA INTEGER First slot index to swap
' @param slotB INTEGER Second slot index to swap
'
SUB DRAWER_swap_slots (slotA AS INTEGER, slotB AS INTEGER)
    DIM tmpBrush AS DRAW_BRUSH
    DIM tmpImg AS LONG
    DIM tmpHas AS INTEGER
    DIM tmpCustom AS INTEGER
    DIM tmpDef AS GRADIENT_DEF
    DIM tmpColorStop AS GRADIENT_COLOR_STOP
    DIM tmpOpacityStop AS GRADIENT_OPACITY_STOP
    DIM tmpStopType AS INTEGER
    DIM s AS INTEGER

    IF slotA% < 1 OR slotA% > DRAWER_SLOT_COUNT THEN EXIT SUB
    IF slotB% < 1 OR slotB% > DRAWER_SLOT_COUNT THEN EXIT SUB
    IF slotA% = slotB% THEN EXIT SUB

    SELECT CASE DRAWER.mode%
        CASE DRAWER_MODE_BRUSH
            tmpBrush = DRAWER_BRUSH_SLOTS(slotA%)
            DRAWER_BRUSH_SLOTS(slotA%) = DRAWER_BRUSH_SLOTS(slotB%)
            DRAWER_BRUSH_SLOTS(slotB%) = tmpBrush
        CASE DRAWER_MODE_PATTERN
            tmpImg& = DRAWER_PATTERN_SLOTS(slotA%)
            DRAWER_PATTERN_SLOTS(slotA%) = DRAWER_PATTERN_SLOTS(slotB%)
            DRAWER_PATTERN_SLOTS(slotB%) = tmpImg&
            tmpHas% = DRAWER_PATTERN_HAS(slotA%)
            DRAWER_PATTERN_HAS(slotA%) = DRAWER_PATTERN_HAS(slotB%)
            DRAWER_PATTERN_HAS(slotB%) = tmpHas%
            DIM tmp1bit AS INTEGER
            DIM tmp1bitFG AS _UNSIGNED LONG
            tmp1bit% = DRAWER_PATTERN_1BIT(slotA%)
            DRAWER_PATTERN_1BIT(slotA%) = DRAWER_PATTERN_1BIT(slotB%)
            DRAWER_PATTERN_1BIT(slotB%) = tmp1bit%
            tmp1bitFG~& = DRAWER_PATTERN_1BIT_FG(slotA%)
            DRAWER_PATTERN_1BIT_FG(slotA%) = DRAWER_PATTERN_1BIT_FG(slotB%)
            DRAWER_PATTERN_1BIT_FG(slotB%) = tmp1bitFG~&
        CASE DRAWER_MODE_GRADIENT
            tmpImg& = DRAWER_GRADIENT_SLOTS(slotA%)
            DRAWER_GRADIENT_SLOTS(slotA%) = DRAWER_GRADIENT_SLOTS(slotB%)
            DRAWER_GRADIENT_SLOTS(slotB%) = tmpImg&
            tmpHas% = DRAWER_GRADIENT_HAS(slotA%)
            DRAWER_GRADIENT_HAS(slotA%) = DRAWER_GRADIENT_HAS(slotB%)
            DRAWER_GRADIENT_HAS(slotB%) = tmpHas%
            tmpCustom% = DRAWER_GRADIENT_CUSTOM(slotA%)
            DRAWER_GRADIENT_CUSTOM(slotA%) = DRAWER_GRADIENT_CUSTOM(slotB%)
            DRAWER_GRADIENT_CUSTOM(slotB%) = tmpCustom%
            tmpDef = GRAD_DEFS(slotA%)
            GRAD_DEFS(slotA%) = GRAD_DEFS(slotB%)
            GRAD_DEFS(slotB%) = tmpDef
            FOR s% = 1 TO GRADIENT_MAX_STOPS
                tmpColorStop = GRAD_COLOR_STOPS(slotA%, s%)
                GRAD_COLOR_STOPS(slotA%, s%) = GRAD_COLOR_STOPS(slotB%, s%)
                GRAD_COLOR_STOPS(slotB%, s%) = tmpColorStop
                tmpOpacityStop = GRAD_OPACITY_STOPS(slotA%, s%)
                GRAD_OPACITY_STOPS(slotA%, s%) = GRAD_OPACITY_STOPS(slotB%, s%)
                GRAD_OPACITY_STOPS(slotB%, s%) = tmpOpacityStop
                tmpStopType% = GRAD_STOP_TYPES(slotA%, s%)
                GRAD_STOP_TYPES(slotA%, s%) = GRAD_STOP_TYPES(slotB%, s%)
                GRAD_STOP_TYPES(slotB%, s%) = tmpStopType%
            NEXT s%
    END SELECT
END SUB


''
' Insert slot at target position, shifting others to make room.
' Moves source slot data to target position, shifting intervening slots
' toward the vacated source position.
' @param srcSlot INTEGER Source slot index to move
' @param dstSlot INTEGER Destination slot index to insert at
'
SUB DRAWER_insert_slot (srcSlot AS INTEGER, dstSlot AS INTEGER)
    DIM i AS INTEGER

    IF srcSlot% < 1 OR srcSlot% > DRAWER_SLOT_COUNT THEN EXIT SUB
    IF dstSlot% < 1 OR dstSlot% > DRAWER_SLOT_COUNT THEN EXIT SUB
    IF srcSlot% = dstSlot% THEN EXIT SUB

    ' Shift slots between source and destination by swapping adjacent pairs
    ' This moves the source toward the destination one position at a time
    IF srcSlot% < dstSlot% THEN
        FOR i% = srcSlot% TO dstSlot% - 1
            DRAWER_swap_slots i%, i% + 1
        NEXT i%
    ELSE
        FOR i% = srcSlot% TO dstSlot% + 1 STEP -1
            DRAWER_swap_slots i%, i% - 1
        NEXT i%
    END IF
END SUB


''
' Handle mouse release during a drawer bin drag.
' If drag never activated (below threshold), treat as a normal click/select.
' If drag is active: Shift held = insert, otherwise = swap.
'
SUB DRAWER_handle_drop ()
    DIM src AS INTEGER, dst AS INTEGER

    ' If drag never activated, treat as a simple click/select
    IF DRAWER.dragPending% AND NOT DRAWER.isDragging% THEN
        DRAWER_select_slot DRAWER.dragSourceSlot%
        SOUND_play SND_MENU_OPEN
        GUI_NEEDS_REDRAW% = TRUE
        FRAME_IDLE% = FALSE
        DRAWER_drag_cancel
        EXIT SUB
    END IF

    IF NOT DRAWER.isDragging% THEN
        DRAWER_drag_cancel
        EXIT SUB
    END IF

    src% = DRAWER.dragSourceSlot%
    dst% = DRAWER.dragTargetSlot%

    IF dst% > 0 AND dst% <> src% THEN
        IF MODIFIERS.shift% THEN
            ' INSERT: shift+drag - push other bins aside
            DRAWER_insert_slot src%, dst%
        ELSE
            ' SWAP: normal drag - exchange the two bins
            DRAWER_swap_slots src%, dst%
        END IF
        ' Update selected slot to follow the dragged content
        SELECT CASE DRAWER.mode%
            CASE DRAWER_MODE_BRUSH
                IF DRAWER.brushSelected% = src% THEN DRAWER.brushSelected% = dst%
            CASE DRAWER_MODE_PATTERN
                IF DRAWER.patternSelected% = src% THEN DRAWER.patternSelected% = dst%
            CASE DRAWER_MODE_GRADIENT
                IF DRAWER.gradientSelected% = src% THEN DRAWER.gradientSelected% = dst%
        END SELECT
        SOUND_play SND_DRAG_DROP
    END IF

    DRAWER_drag_cancel
    GUI_NEEDS_REDRAW% = TRUE
    FRAME_IDLE% = FALSE
END SUB

''
' Find the closest matching pixel in the mini palette image to a target color
' and update the FG or BG marker position accordingly.
' @param targetColor _UNSIGNED LONG Color to match against the palette image pixels
' @param setBackground INTEGER TRUE to update the BG marker, FALSE for FG marker
'
SUB DRAWER_sync_palette_marker (targetColor AS _UNSIGNED LONG, setBackground AS INTEGER)
    DIM srcW AS INTEGER
    DIM srcH AS INTEGER
    DIM oldSource AS LONG
    DIM px AS INTEGER
    DIM py AS INTEGER
    DIM sampleColor AS _UNSIGNED LONG
    DIM dr AS INTEGER
    DIM dg AS INTEGER
    DIM db AS INTEGER
    DIM dist AS LONG
    DIM bestDist AS LONG
    DIM bestX AS INTEGER
    DIM bestY AS INTEGER

    IF DRAWER_PALETTE_IMG& >= -1 THEN EXIT SUB

    srcW% = _WIDTH(DRAWER_PALETTE_IMG&)
    srcH% = _HEIGHT(DRAWER_PALETTE_IMG&)
    IF srcW% < 1 OR srcH% < 1 THEN EXIT SUB

    bestDist& = -1
    oldSource& = _SOURCE
    _SOURCE DRAWER_PALETTE_IMG&
    FOR py% = 0 TO srcH% - 1
        FOR px% = 0 TO srcW% - 1
            sampleColor~& = POINT(px%, py%)
            dr% = _RED32(targetColor~&) - _RED32(sampleColor~&)
            dg% = _GREEN32(targetColor~&) - _GREEN32(sampleColor~&)
            db% = _BLUE32(targetColor~&) - _BLUE32(sampleColor~&)
            dist& = dr% * dr% + dg% * dg% + db% * db%
            IF bestDist& = -1 OR dist& < bestDist& THEN
                bestDist& = dist&
                bestX% = px%
                bestY% = py%
            END IF
        NEXT px%
    NEXT py%
    _SOURCE oldSource&

    IF setBackground% THEN
        DRAWER.paletteBGX% = bestX%
        DRAWER.paletteBGY% = bestY%
    ELSE
        DRAWER.paletteFGX% = bestX%
        DRAWER.paletteFGY% = bestY%
    END IF
END SUB

''
' Pick a color from the mini palette at the given mouse position.
' Sets either the FG or BG color and auto-enables recolor mode
' when a brush or pattern slot is active.
' @param mouseX INTEGER Raw screen X coordinate within the palette area
' @param mouseY INTEGER Raw screen Y coordinate within the palette area
' @param setBackground INTEGER TRUE to set background color, FALSE for foreground
'
SUB DRAWER_select_palette_color (mouseX AS INTEGER, mouseY AS INTEGER, setBackground AS INTEGER)
    DIM contentX AS INTEGER, contentY AS INTEGER
    DIM binW AS INTEGER, binH AS INTEGER, binGapX AS INTEGER, binGapY AS INTEGER
    DIM miniX AS INTEGER, miniY AS INTEGER, miniCellW AS INTEGER, miniCellH AS INTEGER
    DIM miniGapX AS INTEGER, miniGapY AS INTEGER, pageBtnY AS INTEGER, scrollX AS INTEGER, scrollY AS INTEGER, scrollH AS INTEGER
    DIM srcW AS INTEGER
    DIM srcH AS INTEGER
    DIM srcX AS INTEGER
    DIM srcY AS INTEGER
    DIM pickedColor AS _UNSIGNED LONG
    DIM oldSource AS LONG
    DIM palIndex AS INTEGER

    IF DRAWER_PALETTE_IMG& >= -1 THEN EXIT SUB

    DRAWER_layout contentX%, contentY%, binW%, binH%, binGapX%, binGapY%, miniX%, miniY%, miniCellW%, miniCellH%, miniGapX%, miniGapY%, pageBtnY%, scrollX%, scrollY%, scrollH%
    IF mouseX% < miniX% OR mouseX% > miniX% + miniCellW% - 1 OR mouseY% < miniY% OR mouseY% > miniY% + miniCellH% - 1 THEN EXIT SUB

    srcW% = _WIDTH(DRAWER_PALETTE_IMG&)
    srcH% = _HEIGHT(DRAWER_PALETTE_IMG&)
    IF srcW% < 1 OR srcH% < 1 THEN EXIT SUB

    IF miniCellW% > 1 THEN
        srcX% = ((mouseX% - miniX%) * (srcW% - 1)) \ (miniCellW% - 1)
    ELSE
        srcX% = 0
    END IF
    IF miniCellH% > 1 THEN
        srcY% = ((mouseY% - miniY%) * (srcH% - 1)) \ (miniCellH% - 1)
    ELSE
        srcY% = 0
    END IF

    oldSource& = _SOURCE
    _SOURCE DRAWER_PALETTE_IMG&
    pickedColor~& = POINT(srcX%, srcY%)
    _SOURCE oldSource&
    pickedColor~& = _RGB32(_RED32(pickedColor~&), _GREEN32(pickedColor~&), _BLUE32(pickedColor~&))
    palIndex% = PAL_find_index%(pickedColor~&)
    IF palIndex% < 0 THEN palIndex% = PAL_find_closest%(pickedColor~&)

    IF setBackground% THEN
        PAL_BG_IS_TRANSPARENT% = FALSE
        PAINT_BG_COLOR~& = pickedColor~&
        PAL_BG_IDX% = palIndex%
        DRAWER.paletteBGX% = srcX%
        DRAWER.paletteBGY% = srcY%
    ELSE
        PAL_FG_IS_TRANSPARENT% = FALSE
        PAINT_COLOR~& = pickedColor~&
        PAL_FG_IDX% = palIndex%
        POINTER.C~& = pickedColor~&
        DRAWER.paletteFGX% = srcX%
        DRAWER.paletteFGY% = srcY%
        ' Auto-enable recolor when brush/pattern is active from drawer bin
        IF CUSTOM_BRUSH.ACTIVE% AND DRAWER.mode% = DRAWER_MODE_BRUSH AND DRAWER.brushSelected% > 0 THEN
            CUSTOM_BRUSH.RECOLOR_MODE% = TRUE
        ELSEIF DRAWER.mode% = DRAWER_MODE_PATTERN AND DRAWER.patternSelected% > 0 THEN
            CUSTOM_BRUSH.RECOLOR_MODE% = TRUE
        END IF
    END IF
END SUB

''
' Handle a left-click on the drawer panel.
' Dispatches to palette color picking, slot store (Shift+click),
' or initiates a pending drag for bin reordering.
' @param mouseX INTEGER Raw screen X coordinate of the click
' @param mouseY INTEGER Raw screen Y coordinate of the click
' @return INTEGER - TRUE if the click was consumed by the drawer
'
FUNCTION DRAWER_handle_click% (mouseX AS INTEGER, mouseY AS INTEGER)
    DIM slotIndex AS INTEGER
    DIM cellIndex AS INTEGER
    DIM pageDir AS INTEGER

    DRAWER_handle_click% = FALSE
    IF NOT DRAWER_is_over_area%(mouseX%, mouseY%) THEN EXIT FUNCTION
    TOOLTIP_reset

    pageDir% = DRAWER_palette_page_button_at%(mouseX%, mouseY%)
    IF pageDir% <> 0 THEN
        DRAWER_handle_click% = TRUE
        EXIT FUNCTION
    END IF

    cellIndex% = DRAWER_palette_cell_at%(mouseX%, mouseY%)
    IF cellIndex% > 0 THEN
        DRAWER_select_palette_color mouseX%, mouseY%, FALSE
        GUI_NEEDS_REDRAW% = TRUE
        FRAME_IDLE% = FALSE
        DRAWER_handle_click% = TRUE
        EXIT FUNCTION
    END IF

    slotIndex% = DRAWER_slot_at%(mouseX%, mouseY%)
    IF slotIndex% > 0 THEN
        IF MODIFIERS.shift% THEN
            ' STORE: Shift+Left Click - store current content into slot
            DRAWER_store_to_slot slotIndex%
        ELSE
            ' Start pending drag - will become a drag if mouse moves, otherwise
            ' acts as a normal select on release
            DRAWER.dragPending% = TRUE
            DRAWER.isDragging% = FALSE
            DRAWER.dragSourceSlot% = slotIndex%
            DRAWER.dragTargetSlot% = 0
            DRAWER.dragStartX% = mouseX%
            DRAWER.dragStartY% = mouseY%
        END IF
        SOUND_play SND_MENU_OPEN
        GUI_NEEDS_REDRAW% = TRUE
        FRAME_IDLE% = FALSE
        DRAWER_handle_click% = TRUE
    END IF
END FUNCTION

''
' Handle a right-click on the drawer panel.
' Right-click on palette picks BG color; on a slot opens context menu
' (or queues a deferred import if Shift is held).
' @param mouseX INTEGER Raw screen X coordinate of the click
' @param mouseY INTEGER Raw screen Y coordinate of the click
' @return INTEGER - TRUE if the click was consumed by the drawer
'
FUNCTION DRAWER_handle_right_click% (mouseX AS INTEGER, mouseY AS INTEGER)
    DIM cellIndex AS INTEGER
    DIM slotIndex AS INTEGER

    DRAWER_handle_right_click% = FALSE
    IF NOT DRAWER_is_over_area%(mouseX%, mouseY%) THEN
            EXIT FUNCTION
    END IF

    cellIndex% = DRAWER_palette_cell_at%(mouseX%, mouseY%)
    IF cellIndex% > 0 THEN
        DRAWER_select_palette_color mouseX%, mouseY%, TRUE
        GUI_NEEDS_REDRAW% = TRUE
        FRAME_IDLE% = FALSE
        DRAWER_handle_right_click% = TRUE
        EXIT FUNCTION
    END IF

    slotIndex% = DRAWER_slot_at%(mouseX%, mouseY%)
    IF slotIndex% > 0 THEN
        IF MODIFIERS.shift% THEN
            DRAWER_queue_slot_import slotIndex%
        ELSE
            ' Select the slot so the context menu acts on it
            SELECT CASE DRAWER.mode%
                CASE DRAWER_MODE_BRUSH
                    DRAWER.brushSelected% = slotIndex%
                CASE DRAWER_MODE_PATTERN
                    DRAWER.patternSelected% = slotIndex%
                CASE DRAWER_MODE_GRADIENT
                    DRAWER.gradientSelected% = slotIndex%
            END SELECT
            DRAWER_context_menu_show slotIndex%, mouseX%, mouseY%
        END IF
        DRAWER_handle_right_click% = TRUE
    END IF
END FUNCTION

''
' Cycle the drawer mode: Brush -> Pattern -> Gradient -> Brush.
'
SUB DRAWER_cycle_mode ()
    SELECT CASE DRAWER.mode%
        CASE DRAWER_MODE_BRUSH
            DRAWER_set_mode DRAWER_MODE_PATTERN
        CASE DRAWER_MODE_PATTERN
            DRAWER_set_mode DRAWER_MODE_GRADIENT
        CASE ELSE
            DRAWER_set_mode DRAWER_MODE_BRUSH
    END SELECT
END SUB

''
' Handle a middle-click on the drawer panel.
' Shift+middle-click clears a single slot; plain middle-click cycles mode.
' @param mouseX INTEGER Raw screen X coordinate of the click
' @param mouseY INTEGER Raw screen Y coordinate of the click
' @return INTEGER - TRUE if the click was consumed by the drawer
'
FUNCTION DRAWER_handle_middle_click% (mouseX AS INTEGER, mouseY AS INTEGER)
    DIM mcSlot AS INTEGER
    DRAWER_handle_middle_click% = FALSE
    IF NOT DRAWER_is_over_area%(mouseX%, mouseY%) THEN EXIT FUNCTION

    mcSlot% = DRAWER_slot_at%(mouseX%, mouseY%)
    IF mcSlot% > 0 THEN
        IF MODIFIERS.shift% THEN
            ' CLEAR: Shift+Middle Click - clear the single slot
            DRAWER_clear_slot mcSlot%
        ELSE
            DRAWER_cycle_mode
        END IF
        GUI_NEEDS_REDRAW% = TRUE
        FRAME_IDLE% = FALSE
        DRAWER_handle_middle_click% = TRUE
    END IF
END FUNCTION

''
' Handle mouse wheel events over the drawer panel.
' Currently a no-op placeholder for future scrolling support.
' @param mouseX INTEGER Raw screen X coordinate
' @param mouseY INTEGER Raw screen Y coordinate
' @param wheelDelta INTEGER Scroll wheel delta (positive=up, negative=down)
'
SUB DRAWER_handle_wheel (mouseX AS INTEGER, mouseY AS INTEGER, wheelDelta AS INTEGER)
    IF NOT DRAWER_is_over_area%(mouseX%, mouseY%) THEN EXIT SUB
    IF wheelDelta% = 0 THEN EXIT SUB
END SUB

''
' Open the drawer context menu at the given position for a specific slot.
' Builds menu items, measures width, and places the popup on screen.
' @param slotIndex INTEGER Slot index the menu will act upon (1..DRAWER_SLOT_COUNT)
' @param mouseX INTEGER Raw screen X coordinate for menu placement
' @param mouseY INTEGER Raw screen Y coordinate for menu placement
'
SUB DRAWER_context_menu_show (slotIndex AS INTEGER, mouseX AS INTEGER, mouseY AS INTEGER)
    DIM itemCount AS INTEGER
    DIM popupH AS INTEGER
    DIM popupFont AS LONG

    IF slotIndex% < 1 OR slotIndex% > DRAWER_SLOT_COUNT THEN EXIT SUB

    DRAWER_context_menu_build itemCount%
    DRAWER.contextMenuItems% = itemCount%
    popupFont& = DRAWER_popup_font_handle&
    DRAWER.contextMenuW% = POPUP_MENU_measure_width%(itemCount%, popupFont&)
    POPUP_MENU_place mouseX%, mouseY%, DRAWER.contextMenuW%, itemCount%, DRAWER_CONTEXT_ITEM_H, DRAWER.contextMenuX%, DRAWER.contextMenuY%, popupH%
    DRAWER.contextMenuOpen% = TRUE
    DRAWER.contextMenuSlot% = slotIndex%
    DRAWER.contextMenuHover% = -1
    GUI_NEEDS_REDRAW% = TRUE
    FRAME_IDLE% = FALSE
END SUB

''
' Close the drawer context menu and reset its state.
'
SUB DRAWER_context_menu_close ()
    DRAWER.contextMenuOpen% = FALSE
    DRAWER.contextMenuSlot% = 0
    DRAWER.contextMenuHover% = -1
    GUI_NEEDS_REDRAW% = TRUE
    FRAME_IDLE% = FALSE
END SUB

''
' Update the hover highlight within the open context menu.
' Plays a hover sound when the highlighted item changes.
' @param mouseX INTEGER Raw screen X coordinate
' @param mouseY INTEGER Raw screen Y coordinate
'
SUB DRAWER_context_menu_hover (mouseX AS INTEGER, mouseY AS INTEGER)
    DIM prevHover AS INTEGER

    IF NOT DRAWER.contextMenuOpen% THEN EXIT SUB

    prevHover% = DRAWER.contextMenuHover%
    ' Items built once in _show; reused here (only one popup open at a time)
    DRAWER.contextMenuHover% = POPUP_MENU_hover_row%(DRAWER.contextMenuX%, DRAWER.contextMenuY%, DRAWER.contextMenuW%, DRAWER.contextMenuItems%, DRAWER_CONTEXT_ITEM_H, mouseX%, mouseY%)
    IF DRAWER.contextMenuHover% <> prevHover% AND DRAWER.contextMenuHover% > 0 THEN
        SOUND_play SND_MENU_HOVER
        GUI_NEEDS_REDRAW% = TRUE
        FRAME_IDLE% = FALSE
    ELSEIF DRAWER.contextMenuHover% <> prevHover% THEN
        GUI_NEEDS_REDRAW% = TRUE
        FRAME_IDLE% = FALSE
    END IF
END SUB

''
' Hit-test the drawer context menu and return the action value under the mouse.
' @param mouseX INTEGER Raw screen X coordinate
' @param mouseY INTEGER Raw screen Y coordinate
' @return INTEGER - action value of the hovered item, -2 if no menu open
'
FUNCTION DRAWER_context_menu_hit% (mouseX AS INTEGER, mouseY AS INTEGER)
    IF NOT DRAWER.contextMenuOpen% THEN
        DRAWER_context_menu_hit% = -2
        EXIT FUNCTION
    END IF

    ' Items built once in _show; reused here (only one popup open at a time)
    DRAWER_context_menu_hit% = POPUP_MENU_hit_value%(DRAWER.contextMenuX%, DRAWER.contextMenuY%, DRAWER.contextMenuW%, DRAWER.contextMenuItems%, DRAWER_CONTEXT_ITEM_H, mouseX%, mouseY%)
END FUNCTION

''
' Execute a drawer context menu action by its value constant.
' Dispatches to load/save/clear set, explore folder, or gradient editor.
' @param actionValue INTEGER DRAWER_CONTEXT_* action constant to execute
'
SUB DRAWER_context_menu_activate (actionValue AS INTEGER)
    DRAWER_context_menu_close
    SELECT CASE actionValue%
        CASE DRAWER_CONTEXT_LOAD_SET
            DRAWER_import_set_dialog
        CASE DRAWER_CONTEXT_SAVE_SET
            DRAWER_export_set_dialog
        CASE DRAWER_CONTEXT_CLEAR_SET
            DRAWER_clear_active_set
        CASE DRAWER_CONTEXT_EXPLORE_FOLDER
            DRAWER_explore_context_folder
        CASE DRAWER_CONTEXT_EDIT_GRADIENT
            GRADIENT_editor_dialog
    END SELECT
END SUB

''
' Render the drawer context menu popup onto the canvas.
' Only draws if the menu is currently open.
'
SUB DRAWER_context_menu_render ()
    DIM popupFont AS LONG

    IF NOT DRAWER.contextMenuOpen% THEN EXIT SUB

    DRAWER_context_menu_build DRAWER.contextMenuItems%
    popupFont& = DRAWER_popup_font_handle&
    POPUP_MENU_render SCRN.CANVAS&, DRAWER.contextMenuX%, DRAWER.contextMenuY%, DRAWER.contextMenuW%, DRAWER.contextMenuItems%, DRAWER_CONTEXT_ITEM_H, DRAWER.contextMenuHover%, popupFont&
END SUB

''
' Get the font handle to use for drawer popup menu rendering.
' Prefers the menubar font, falls back to the layer panel font.
' @return LONG - font handle, or 0 if no UI font is loaded
'
FUNCTION DRAWER_popup_font_handle& ()
    IF MENU_BAR.fontHandle& > 0 THEN
        DRAWER_popup_font_handle& = MENU_BAR.fontHandle&
    ELSEIF LAYER_PANEL.fontHandle& > 0 THEN
        DRAWER_popup_font_handle& = LAYER_PANEL.fontHandle&
    ELSE
        DRAWER_popup_font_handle& = 0
    END IF
END FUNCTION

''
' Build the context menu items list for the current drawer mode.
' Adds mode-specific header items plus standard set management actions.
' @param itemCount INTEGER [out] Total number of menu items built
'
SUB DRAWER_context_menu_build (itemCount AS INTEGER)
    POPUP_MENU_clear_items
    itemCount% = 0

    SELECT CASE DRAWER.mode%
        CASE DRAWER_MODE_PATTERN
            POPUP_MENU_set_item itemCount%, "SOURCE = CLIPBOARD", "", -1, POPUP_MENU_FLAG_DISABLED
            itemCount% = itemCount% + 1
            POPUP_MENU_set_item itemCount%, "", "", -1, POPUP_MENU_FLAG_DIVIDER
            itemCount% = itemCount% + 1
        CASE DRAWER_MODE_GRADIENT
            POPUP_MENU_set_item itemCount%, "EDIT GRADIENT...", "", DRAWER_CONTEXT_EDIT_GRADIENT, 0
            itemCount% = itemCount% + 1
            POPUP_MENU_set_item itemCount%, "", "", -1, POPUP_MENU_FLAG_DIVIDER
            itemCount% = itemCount% + 1
        CASE DRAWER_MODE_BRUSH
            POPUP_MENU_set_item itemCount%, "SOURCE = CLIPBRD / BRUSH", "", -1, POPUP_MENU_FLAG_DISABLED
            itemCount% = itemCount% + 1
            POPUP_MENU_set_item itemCount%, "", "", -1, POPUP_MENU_FLAG_DIVIDER
            itemCount% = itemCount% + 1
    END SELECT

    POPUP_MENU_set_item itemCount%, "SELECT", "LMB", -1, POPUP_MENU_FLAG_DISABLED
    itemCount% = itemCount% + 1

    POPUP_MENU_set_item itemCount%, "STORE", "SHIFT+LMB", -1, POPUP_MENU_FLAG_DISABLED
    itemCount% = itemCount% + 1

    POPUP_MENU_set_item itemCount%, "CLEAR", "SHIFT+MMB", -1, POPUP_MENU_FLAG_DISABLED
    itemCount% = itemCount% + 1

    POPUP_MENU_set_item itemCount%, "LOAD", "SHIFT+RMB", -1, POPUP_MENU_FLAG_DISABLED
    itemCount% = itemCount% + 1

    POPUP_MENU_set_item itemCount%, "", "", -1, POPUP_MENU_FLAG_DIVIDER
    itemCount% = itemCount% + 1

    POPUP_MENU_set_item itemCount%, "LOAD DRAWER SET (.dset)", "", DRAWER_CONTEXT_LOAD_SET, 0
    itemCount% = itemCount% + 1

    POPUP_MENU_set_item itemCount%, "SAVE DRAWER SET (.dset)", "", DRAWER_CONTEXT_SAVE_SET, 0
    itemCount% = itemCount% + 1

    POPUP_MENU_set_item itemCount%, "CLEAR DRAWER SET", "", DRAWER_CONTEXT_CLEAR_SET, 0
    itemCount% = itemCount% + 1

    POPUP_MENU_set_item itemCount%, "", "", -1, POPUP_MENU_FLAG_DIVIDER
    itemCount% = itemCount% + 1

    POPUP_MENU_set_item itemCount%, "EXPLORE FOLDER", "", DRAWER_CONTEXT_EXPLORE_FOLDER, 0
    itemCount% = itemCount% + 1
END SUB

''
' Return the filesystem path to the USER/DRAWER-SETS directory.
' @return STRING - absolute path to the drawer sets folder
'
FUNCTION DRAWER_sets_dir$ ()
    DRAWER_sets_dir$ = PATHS_data$("DRAWER-SETS")
END FUNCTION

''
' Ensure the USER/DRAWER-SETS directory exists, creating it if needed.
'
SUB DRAWER_ensure_sets_dir ()
    PATHS_ensure_dir DRAWER_sets_dir$ + "/"
END SUB

''
' Open the drawer sets folder in the system file explorer.
'
SUB DRAWER_explore_sets_folder ()
    DIM setsDir AS STRING

    setsDir$ = DRAWER_sets_dir$
    DRAWER_ensure_sets_dir

    $IF WIN THEN
        SHELL _DONTWAIT "explorer /e " + CHR$(34) + setsDir$ + CHR$(34)
    $ELSEIF MAC THEN
        SHELL _DONTWAIT "open " + CHR$(34) + setsDir$ + CHR$(34)
    $ELSE
        SHELL _DONTWAIT "open " + CHR$(34) + setsDir$ + CHR$(34)
    $END IF
END SUB

''
' Open the relevant folder for the current drawer mode in the file explorer.
' For pattern mode, opens the theme IMAGES/PATTERNS directory.
' For other modes, opens the drawer sets folder.
'
SUB DRAWER_explore_context_folder ()
    DIM targetPath AS STRING

    IF DRAWER.mode% = DRAWER_MODE_PATTERN THEN
        targetPath$ = _CWD$ + "/ASSETS/THEMES/" + _TRIM$(CFG.THEME$) + "/IMAGES/PATTERNS"
        IF NOT _DIREXISTS(targetPath$) THEN targetPath$ = _CWD$ + "/ASSETS/THEMES/DEFAULT/IMAGES/PATTERNS"

        $IF WIN THEN
            SHELL _DONTWAIT "explorer /e " + CHR$(34) + targetPath$ + CHR$(34)
        $ELSEIF MAC THEN
            SHELL _DONTWAIT "open " + CHR$(34) + targetPath$ + CHR$(34)
        $ELSE
            SHELL _DONTWAIT "open " + CHR$(34) + targetPath$ + CHR$(34)
        $END IF
    ELSE
        DRAWER_explore_sets_folder
    END IF
END SUB

''
' Write a slot's image data to a binary file.
' Writes a hasImage flag, then width, height, and raw RGBA pixel data.
' @param fh INTEGER File handle open for binary writing
' @param imgHandle LONG Image handle to save, or 0/invalid to write empty marker
'
SUB DRAWER_save_slot_image (fh AS INTEGER, imgHandle AS LONG)
    DIM hasImage AS INTEGER
    DIM imgW AS INTEGER
    DIM imgH AS INTEGER
    DIM x AS INTEGER
    DIM y AS INTEGER
    DIM c AS _UNSIGNED LONG
    DIM oldSource AS LONG

    hasImage% = (imgHandle& < -1)
    PUT #fh%, , hasImage%
    IF NOT hasImage% THEN EXIT SUB

    imgW% = _WIDTH(imgHandle&)
    imgH% = _HEIGHT(imgHandle&)
    PUT #fh%, , imgW%
    PUT #fh%, , imgH%

    oldSource& = _SOURCE
    _SOURCE imgHandle&
    FOR y% = 0 TO imgH% - 1
        FOR x% = 0 TO imgW% - 1
            c~& = POINT(x%, y%)
            PUT #fh%, , c~&
        NEXT x%
    NEXT y%
    _SOURCE oldSource&
END SUB

''
' Read a slot's image data from a binary file.
' Reads the hasImage flag, dimensions, and raw RGBA pixel data.
' @param fh INTEGER File handle open for binary reading
' @return LONG - loaded image handle, or 0 if no image was stored
'
FUNCTION DRAWER_load_slot_image& (fh AS INTEGER)
    DIM hasImage AS INTEGER
    DIM imgW AS INTEGER
    DIM imgH AS INTEGER
    DIM x AS INTEGER
    DIM y AS INTEGER
    DIM c AS _UNSIGNED LONG
    DIM imgHandle AS LONG
    DIM oldDest AS LONG

    DRAWER_load_slot_image& = 0

    GET #fh%, , hasImage%
    IF NOT hasImage% THEN EXIT FUNCTION

    GET #fh%, , imgW%
    GET #fh%, , imgH%
    IF imgW% < 1 OR imgH% < 1 THEN EXIT FUNCTION

    imgHandle& = _NEWIMAGE(imgW%, imgH%, 32)
    oldDest& = _DEST
    _DEST imgHandle&
    _DONTBLEND imgHandle&
    FOR y% = 0 TO imgH% - 1
        FOR x% = 0 TO imgW% - 1
            GET #fh%, , c~&
            PSET (x%, y%), c~&
        NEXT x%
    NEXT y%
    _BLEND imgHandle&
    _DEST oldDest&

    DRAWER_load_slot_image& = imgHandle&
END FUNCTION

''
' Load a .dset file into the specified mode's slots.
' Returns TRUE on success, FALSE on failure.
' targetMode: DRAWER_MODE_BRUSH, DRAWER_MODE_PATTERN, or DRAWER_MODE_GRADIENT
' If targetMode = 0, uses the mode stored in the file.
' @param filename STRING Path to the .dset file to load
' @param targetMode INTEGER Target drawer mode (0 = auto-detect from file)
' @return INTEGER - TRUE on success, FALSE on failure
'
FUNCTION DRAWER_load_dset_file% (filename AS STRING, targetMode AS INTEGER)
    DIM fh AS INTEGER
    DIM magic AS STRING * 4
    DIM version AS INTEGER
    DIM fileMode AS INTEGER
    DIM selectedSlot AS INTEGER
    DIM i AS INTEGER
    DIM loadedImg AS LONG
    DIM resolvedPath AS STRING

    DRAWER_load_dset_file% = FALSE

    ' Resolve path: try as-is, then relative to _STARTDIR$
    IF _FILEEXISTS(filename$) THEN
        resolvedPath$ = filename$
    ELSEIF _FILEEXISTS(_STARTDIR$ + "/" + filename$) THEN
        resolvedPath$ = _STARTDIR$ + "/" + filename$
    ELSE
        ERR_warn "Drawer: DEFAULT_DSET file not found: " + filename$
        EXIT FUNCTION
    END IF

    fh% = FREEFILE
    OPEN resolvedPath$ FOR BINARY AS #fh%
    GET #fh%, , magic$
    IF magic$ <> "DST1" THEN
        CLOSE #fh%
        ERR_warn "Drawer: Invalid .dset file: " + resolvedPath$
        EXIT FUNCTION
    END IF

    GET #fh%, , version%
    GET #fh%, , fileMode%
    GET #fh%, , selectedSlot%
    IF (version% < 1 OR version% > 2) OR fileMode% < DRAWER_MODE_BRUSH OR fileMode% > DRAWER_MODE_GRADIENT THEN
        CLOSE #fh%
        ERR_warn "Drawer: Unsupported .dset version in: " + resolvedPath$
        EXIT FUNCTION
    END IF

    ' Use file mode if targetMode is 0, otherwise override
    IF targetMode% > 0 THEN fileMode% = targetMode%

    SELECT CASE fileMode%
        CASE DRAWER_MODE_BRUSH
            FOR i% = 1 TO DRAWER_SLOT_COUNT
                IF DRAWER_BRUSH_SLOTS(i%).IMG < -1 THEN _FREEIMAGE DRAWER_BRUSH_SLOTS(i%).IMG
                loadedImg& = DRAWER_load_slot_image&(fh%)
                DRAWER_BRUSH_SLOTS(i%).IMG = loadedImg&
                IF loadedImg& < -1 THEN
                    DRAWER_BRUSH_SLOTS(i%).W = _WIDTH(loadedImg&)
                    DRAWER_BRUSH_SLOTS(i%).H = _HEIGHT(loadedImg&)
                ELSE
                    DRAWER_BRUSH_SLOTS(i%).W = 0
                    DRAWER_BRUSH_SLOTS(i%).H = 0
                END IF
            NEXT i%
            DRAWER.brushSelected% = selectedSlot%
            IF DRAWER.brushSelected% < 1 OR DRAWER.brushSelected% > DRAWER_SLOT_COUNT THEN DRAWER.brushSelected% = 1
        CASE DRAWER_MODE_PATTERN
            FOR i% = 1 TO DRAWER_SLOT_COUNT
                IF DRAWER_PATTERN_SLOTS(i%) < -1 THEN _FREEIMAGE DRAWER_PATTERN_SLOTS(i%)
                loadedImg& = DRAWER_load_slot_image&(fh%)
                DRAWER_PATTERN_SLOTS(i%) = loadedImg&
                DRAWER_PATTERN_HAS(i%) = (loadedImg& < -1)
            NEXT i%
            DRAWER_analyze_all_1bit
            DRAWER.patternSelected% = selectedSlot%
            IF DRAWER.patternSelected% < 1 OR DRAWER.patternSelected% > DRAWER_SLOT_COUNT THEN DRAWER.patternSelected% = 1
        CASE DRAWER_MODE_GRADIENT
            FOR i% = 1 TO DRAWER_SLOT_COUNT
                IF DRAWER_GRADIENT_SLOTS(i%) < -1 THEN _FREEIMAGE DRAWER_GRADIENT_SLOTS(i%)
                loadedImg& = DRAWER_load_slot_image&(fh%)
                DRAWER_GRADIENT_SLOTS(i%) = loadedImg&
                DRAWER_GRADIENT_HAS(i%) = (loadedImg& < -1)
                DRAWER_GRADIENT_CUSTOM(i%) = (loadedImg& < -1)
                IF DRAWER_GRADIENT_CUSTOM(i%) THEN
                    GRAD_DEFS(i%).colorCount% = 0
                    GRAD_DEFS(i%).opacityCount% = 0
                END IF
            NEXT i%
            ' Version 2: read per-slot grad_defs, color/opacity stops, and stop types
            IF version% >= 2 THEN
                DIM gs AS INTEGER
                FOR i% = 1 TO DRAWER_SLOT_COUNT
                    GET #fh%, , GRAD_DEFS(i%).family%
                    GET #fh%, , GRAD_DEFS(i%).colorCount%
                    GET #fh%, , GRAD_DEFS(i%).opacityCount%
                    GET #fh%, , GRAD_DEFS(i%).usesFG%
                    GET #fh%, , GRAD_DEFS(i%).usesBG%
                    GET #fh%, , GRAD_DEFS(i%).gName
                    GET #fh%, , GRAD_DEFS(i%).ditherMode%
                    GET #fh%, , GRAD_DEFS(i%).ditherStrength!
                    FOR gs% = 1 TO GRADIENT_MAX_STOPS
                        GET #fh%, , GRAD_COLOR_STOPS(i%, gs%).position
                        GET #fh%, , GRAD_COLOR_STOPS(i%, gs%).clr
                    NEXT gs%
                    FOR gs% = 1 TO GRADIENT_MAX_STOPS
                        GET #fh%, , GRAD_OPACITY_STOPS(i%, gs%).position
                        GET #fh%, , GRAD_OPACITY_STOPS(i%, gs%).opacity%
                    NEXT gs%
                    FOR gs% = 1 TO GRADIENT_MAX_STOPS
                        GET #fh%, , GRAD_STOP_TYPES(i%, gs%)
                    NEXT gs%
                    IF GRAD_DEFS(i%).colorCount% >= 1 THEN DRAWER_GRADIENT_CUSTOM(i%) = FALSE
                    GRAD_DEFS(i%).previewDirty% = TRUE
                NEXT i%
                ' Rebuild previews from loaded definitions
                FOR i% = 1 TO DRAWER_SLOT_COUNT
                    IF GRAD_DEFS(i%).colorCount% >= 1 THEN
                        GRAD_DEF_rebuild_preview i%
                    END IF
                NEXT i%
            END IF
            DRAWER.gradientSelected% = selectedSlot%
            IF DRAWER.gradientSelected% < 1 OR DRAWER.gradientSelected% > DRAWER_SLOT_COUNT THEN DRAWER.gradientSelected% = 1
    END SELECT
    CLOSE #fh%

    DRAWER_load_dset_file% = TRUE
END FUNCTION

''
' Save the complete drawer state to a binary file (DRW project format).
' Writes visibility, mode, selected slots, custom brush state, and all
' 30 brush, pattern, and gradient slot images.
' @param fh INTEGER File handle open for binary writing
'
SUB DRAWER_save_state_binary (fh AS INTEGER)
    DIM i AS INTEGER
    DIM customBrushActive AS INTEGER

    PUT #fh%, , DRAWER.visible%
    PUT #fh%, , DRAWER.mode%
    PUT #fh%, , DRAWER.miniPaletteOffset%
    PUT #fh%, , DRAWER.brushSelected%
    PUT #fh%, , DRAWER.patternSelected%
    PUT #fh%, , DRAWER.gradientSelected%

    customBrushActive% = CUSTOM_BRUSH_is_active%
    PUT #fh%, , customBrushActive%

    FOR i% = 1 TO DRAWER_SLOT_COUNT
        DRAWER_save_slot_image fh%, DRAWER_BRUSH_SLOTS(i%).IMG
    NEXT i%
    FOR i% = 1 TO DRAWER_SLOT_COUNT
        DRAWER_save_slot_image fh%, DRAWER_PATTERN_SLOTS(i%)
    NEXT i%
    FOR i% = 1 TO DRAWER_SLOT_COUNT
        DRAWER_save_slot_image fh%, DRAWER_GRADIENT_SLOTS(i%)
    NEXT i%
END SUB

''
' Load the complete drawer state from a binary file (DRW project format).
' Resets drawer state, reads slot images, reloads palette images, and
' restores custom brush if it was active when saved.
' @param fh INTEGER File handle open for binary reading
'
SUB DRAWER_load_state_binary (fh AS INTEGER)
    DIM i AS INTEGER
    DIM loadedImg AS LONG
    DIM customBrushActive AS INTEGER

    DRAWER_reset

    GET #fh%, , DRAWER.visible%
    GET #fh%, , DRAWER.mode%
    GET #fh%, , DRAWER.miniPaletteOffset%
    GET #fh%, , DRAWER.brushSelected%
    GET #fh%, , DRAWER.patternSelected%
    GET #fh%, , DRAWER.gradientSelected%
    GET #fh%, , customBrushActive%

    IF DRAWER.mode% < DRAWER_MODE_NONE OR DRAWER.mode% > DRAWER_MODE_GRADIENT THEN DRAWER.mode% = DRAWER_MODE_NONE
    DRAWER.paintMode% = DRAWER_paint_mode_from_panel%(DRAWER.mode%)
    IF DRAWER.brushSelected% < 1 OR DRAWER.brushSelected% > DRAWER_SLOT_COUNT THEN DRAWER.brushSelected% = 1
    IF DRAWER.patternSelected% < 1 OR DRAWER.patternSelected% > DRAWER_SLOT_COUNT THEN DRAWER.patternSelected% = 1
    IF DRAWER.gradientSelected% < 1 OR DRAWER.gradientSelected% > DRAWER_SLOT_COUNT THEN DRAWER.gradientSelected% = 1
    IF DRAWER.miniPaletteOffset% < 0 THEN DRAWER.miniPaletteOffset% = 0

    FOR i% = 1 TO DRAWER_SLOT_COUNT
        loadedImg& = DRAWER_load_slot_image&(fh%)
        DRAWER_BRUSH_SLOTS(i%).IMG = loadedImg&
        IF loadedImg& < -1 THEN
            DRAWER_BRUSH_SLOTS(i%).W = _WIDTH(loadedImg&)
            DRAWER_BRUSH_SLOTS(i%).H = _HEIGHT(loadedImg&)
        ELSE
            DRAWER_BRUSH_SLOTS(i%).W = 0
            DRAWER_BRUSH_SLOTS(i%).H = 0
        END IF
    NEXT i%

    FOR i% = 1 TO DRAWER_SLOT_COUNT
        loadedImg& = DRAWER_load_slot_image&(fh%)
        DRAWER_PATTERN_SLOTS(i%) = loadedImg&
        DRAWER_PATTERN_HAS(i%) = (loadedImg& < -1)
    NEXT i%

    DRAWER_analyze_all_1bit

    FOR i% = 1 TO DRAWER_SLOT_COUNT
        loadedImg& = DRAWER_load_slot_image&(fh%)
        DRAWER_GRADIENT_SLOTS(i%) = loadedImg&
        DRAWER_GRADIENT_HAS(i%) = (loadedImg& < -1)
        DRAWER_GRADIENT_CUSTOM(i%) = (loadedImg& < -1)
    NEXT i%

    ' Recreate palette strip images (DRAWER_reset freed them)
    DRAWER_PALETTE_IMG& = DRAWER_load_theme_image&("IMAGES/PALETTE", "palette-thin.png")
    DRAWER_PALETTE_LEFT_IMG& = DRAWER_load_theme_image&("IMAGES/PALETTE", "palette-left.png")
    DRAWER_PALETTE_RIGHT_IMG& = DRAWER_load_theme_image&("IMAGES/PALETTE", "palette-right.png")
    IF DRAWER_PALETTE_IMG& < -1 THEN
        DRAWER_sync_palette_marker PAINT_COLOR~&, FALSE
        DRAWER_sync_palette_marker PAINT_BG_COLOR~&, TRUE
    END IF

    DRAWER.samplesLoaded% = TRUE
    DRAWER.loadedTheme = _TRIM$(CFG.THEME$)
    DRAWER_GRADIENT_LAST_FG~& = PAINT_COLOR~&
    DRAWER_GRADIENT_LAST_BG~& = PAINT_BG_COLOR~&
    DRAWER.visible% = TRUE

    IF customBrushActive% AND DRAWER_BRUSH_SLOTS(DRAWER.brushSelected%).IMG < -1 THEN
        DRAWER_load_brush_slot_to_custom DRAWER.brushSelected%
    ELSEIF CUSTOM_BRUSH_is_active% THEN
        CUSTOM_BRUSH_reset
    END IF
END SUB

''
' Save gradient definitions and color/opacity stops to a binary file (v12+).
' Writes family, stop counts, FG/BG flags, name, dither settings, and all
' color and opacity stop arrays for each slot.
' @param fh INTEGER File handle open for binary writing
'
SUB DRAWER_save_grad_defs (fh AS INTEGER)
    ' Save gradient definitions and color/opacity stops (v12+)
    DIM i AS INTEGER, j AS INTEGER
    FOR i% = 1 TO DRAWER_SLOT_COUNT
        PUT #fh%, , GRAD_DEFS(i%).family%
        PUT #fh%, , GRAD_DEFS(i%).colorCount%
        PUT #fh%, , GRAD_DEFS(i%).opacityCount%
        PUT #fh%, , GRAD_DEFS(i%).usesFG%
        PUT #fh%, , GRAD_DEFS(i%).usesBG%
        PUT #fh%, , GRAD_DEFS(i%).gName
        PUT #fh%, , GRAD_DEFS(i%).ditherMode%
        PUT #fh%, , GRAD_DEFS(i%).ditherStrength!
        FOR j% = 1 TO GRADIENT_MAX_STOPS
            PUT #fh%, , GRAD_COLOR_STOPS(i%, j%).position
            PUT #fh%, , GRAD_COLOR_STOPS(i%, j%).clr
        NEXT j%
        FOR j% = 1 TO GRADIENT_MAX_STOPS
            PUT #fh%, , GRAD_OPACITY_STOPS(i%, j%).position
            PUT #fh%, , GRAD_OPACITY_STOPS(i%, j%).opacity%
        NEXT j%
    NEXT i%
END SUB

''
' Load gradient definitions and color/opacity stops from a binary file (v12+).
' Reads all slot definitions and rebuilds preview images for slots that
' have parametric color stop data.
' @param fh INTEGER File handle open for binary reading
'
SUB DRAWER_load_grad_defs (fh AS INTEGER)
    ' Load gradient definitions and color/opacity stops (v12+)
    DIM i AS INTEGER, j AS INTEGER
    FOR i% = 1 TO DRAWER_SLOT_COUNT
        GET #fh%, , GRAD_DEFS(i%).family%
        GET #fh%, , GRAD_DEFS(i%).colorCount%
        GET #fh%, , GRAD_DEFS(i%).opacityCount%
        GET #fh%, , GRAD_DEFS(i%).usesFG%
        GET #fh%, , GRAD_DEFS(i%).usesBG%
        GET #fh%, , GRAD_DEFS(i%).gName
        GET #fh%, , GRAD_DEFS(i%).ditherMode%
        GET #fh%, , GRAD_DEFS(i%).ditherStrength!
        FOR j% = 1 TO GRADIENT_MAX_STOPS
            GET #fh%, , GRAD_COLOR_STOPS(i%, j%).position
            GET #fh%, , GRAD_COLOR_STOPS(i%, j%).clr
        NEXT j%
        FOR j% = 1 TO GRADIENT_MAX_STOPS
            GET #fh%, , GRAD_OPACITY_STOPS(i%, j%).position
            GET #fh%, , GRAD_OPACITY_STOPS(i%, j%).opacity%
        NEXT j%
        GRAD_DEFS(i%).previewDirty% = TRUE
    NEXT i%
    ' Rebuild previews for any slots that have definitions
    FOR i% = 1 TO DRAWER_SLOT_COUNT
        IF GRAD_DEFS(i%).colorCount% >= 1 THEN
            DRAWER_GRADIENT_CUSTOM(i%) = FALSE
            GRAD_DEF_rebuild_preview i%
        END IF
    NEXT i%
END SUB

''
' Get the human-readable display name for a drawer mode.
' @param mode INTEGER Drawer mode constant (DRAWER_MODE_BRUSH/PATTERN/GRADIENT)
' @return STRING - "Brush", "Pattern", "Gradient", or "Drawer"
'
FUNCTION DRAWER_set_mode_name$ (mode AS INTEGER)
    SELECT CASE mode%
        CASE DRAWER_MODE_BRUSH
            DRAWER_set_mode_name$ = "Brush"
        CASE DRAWER_MODE_PATTERN
            DRAWER_set_mode_name$ = "Pattern"
        CASE DRAWER_MODE_GRADIENT
            DRAWER_set_mode_name$ = "Gradient"
        CASE ELSE
            DRAWER_set_mode_name$ = "Drawer"
    END SELECT
END FUNCTION

''
' Clear all slots in the currently active drawer mode.
' Frees all images and resets selected slot to 1.
'
SUB DRAWER_clear_active_set ()
    DIM i AS INTEGER

    SELECT CASE DRAWER.mode%
        CASE DRAWER_MODE_BRUSH
            FOR i% = 1 TO DRAWER_SLOT_COUNT
                IF DRAWER_BRUSH_SLOTS(i%).IMG < -1 THEN _FREEIMAGE DRAWER_BRUSH_SLOTS(i%).IMG
                DRAWER_BRUSH_SLOTS(i%).IMG = 0
                DRAWER_BRUSH_SLOTS(i%).W = 0
                DRAWER_BRUSH_SLOTS(i%).H = 0
            NEXT i%
            DRAWER.brushSelected% = 1
            CUSTOM_BRUSH_reset
        CASE DRAWER_MODE_PATTERN
            FOR i% = 1 TO DRAWER_SLOT_COUNT
                IF DRAWER_PATTERN_SLOTS(i%) < -1 THEN _FREEIMAGE DRAWER_PATTERN_SLOTS(i%)
                DRAWER_PATTERN_SLOTS(i%) = 0
                DRAWER_PATTERN_HAS(i%) = FALSE
            NEXT i%
            DRAWER.patternSelected% = 1
        CASE DRAWER_MODE_GRADIENT
            FOR i% = 1 TO DRAWER_SLOT_COUNT
                IF DRAWER_GRADIENT_SLOTS(i%) < -1 THEN _FREEIMAGE DRAWER_GRADIENT_SLOTS(i%)
                DRAWER_GRADIENT_SLOTS(i%) = 0
                DRAWER_GRADIENT_HAS(i%) = FALSE
                DRAWER_GRADIENT_CUSTOM(i%) = TRUE
            NEXT i%
            DRAWER.gradientSelected% = 1
    END SELECT

    SOUND_play SND_LAYER_OP
    GUI_NEEDS_REDRAW% = TRUE
    FRAME_IDLE% = FALSE
END SUB

''
' Show a save dialog and export the current mode's slots as a .dset file.
' Gradient mode uses version 2 format with gradient definitions.
'
SUB DRAWER_export_set_dialog ()
    DIM fh AS INTEGER
    DIM modeName AS STRING
    DIM defaultPath AS STRING
    DIM filename AS STRING
    DIM magic AS STRING * 4
    DIM version AS INTEGER
    DIM selectedSlot AS INTEGER
    DIM i AS INTEGER

    IF DRAWER.mode% < DRAWER_MODE_BRUSH OR DRAWER.mode% > DRAWER_MODE_GRADIENT THEN
        POINTER_hide_for_dialog
        DRAW_alert "Drawer Set", "Open a brush, pattern, or gradient drawer mode before exporting a set."
        POINTER_show_after_dialog
        MOUSE_cleanup_after_dialog TRUE
        EXIT SUB
    END IF

    DRAWER_ensure_samples
    modeName$ = DRAWER_set_mode_name$(DRAWER.mode%)
    DIM dsetDir AS STRING, dsetFile AS STRING
    IF CFG.LAST_DIR_EXPORT_BRUSH$ <> "" THEN
        dsetDir$ = CFG.LAST_DIR_EXPORT_BRUSH$
        dsetFile$ = LCASE$(modeName$) + "-set.dset"
    ELSEIF LAST_DIRECTORY$ <> "" THEN
        dsetDir$ = LAST_DIRECTORY$
        dsetFile$ = LCASE$(modeName$) + "-set.dset"
    ELSE
        DRAWER_ensure_sets_dir
        dsetDir$ = DRAWER_sets_dir$
        dsetFile$ = LCASE$(modeName$) + "-set.dset"
    END IF

    POINTER_hide_for_dialog
    filename$ = DRAW_save_file$("Export " + modeName$ + " Set", dsetDir$, "DRAW Drawer Set|*.dset", 0, dsetFile$, ".dset")
    POINTER_show_after_dialog
    MOUSE_cleanup_after_dialog TRUE
    IF filename$ = "" THEN EXIT SUB

    CFG.LAST_DIR_EXPORT_BRUSH$ = CONFIG_extract_dir$(filename$)
    LAST_DIRECTORY$ = CFG.LAST_DIR_EXPORT_BRUSH$
    CONFIG_save

    fh% = FREEFILE
    OPEN filename$ FOR BINARY AS #fh%
    magic$ = "DST1"
    IF DRAWER.mode% = DRAWER_MODE_GRADIENT THEN version% = 2 ELSE version% = 1
    PUT #fh%, , magic$
    PUT #fh%, , version%
    PUT #fh%, , DRAWER.mode%
    SELECT CASE DRAWER.mode%
        CASE DRAWER_MODE_BRUSH
            selectedSlot% = DRAWER.brushSelected%
        CASE DRAWER_MODE_PATTERN
            selectedSlot% = DRAWER.patternSelected%
        CASE ELSE
            selectedSlot% = DRAWER.gradientSelected%
    END SELECT
    PUT #fh%, , selectedSlot%

    FOR i% = 1 TO DRAWER_SLOT_COUNT
        SELECT CASE DRAWER.mode%
            CASE DRAWER_MODE_BRUSH
                DRAWER_save_slot_image fh%, DRAWER_BRUSH_SLOTS(i%).IMG
            CASE DRAWER_MODE_PATTERN
                DRAWER_save_slot_image fh%, DRAWER_PATTERN_SLOTS(i%)
            CASE ELSE
                DRAWER_save_slot_image fh%, DRAWER_GRADIENT_SLOTS(i%)
        END SELECT
    NEXT i%

    ' Version 2: write per-slot grad_defs, color/opacity stops, and stop types
    IF version% = 2 THEN
        DIM gs AS INTEGER
        FOR i% = 1 TO DRAWER_SLOT_COUNT
            PUT #fh%, , GRAD_DEFS(i%).family%
            PUT #fh%, , GRAD_DEFS(i%).colorCount%
            PUT #fh%, , GRAD_DEFS(i%).opacityCount%
            PUT #fh%, , GRAD_DEFS(i%).usesFG%
            PUT #fh%, , GRAD_DEFS(i%).usesBG%
            PUT #fh%, , GRAD_DEFS(i%).gName
            PUT #fh%, , GRAD_DEFS(i%).ditherMode%
            PUT #fh%, , GRAD_DEFS(i%).ditherStrength!
            FOR gs% = 1 TO GRADIENT_MAX_STOPS
                PUT #fh%, , GRAD_COLOR_STOPS(i%, gs%).position
                PUT #fh%, , GRAD_COLOR_STOPS(i%, gs%).clr
            NEXT gs%
            FOR gs% = 1 TO GRADIENT_MAX_STOPS
                PUT #fh%, , GRAD_OPACITY_STOPS(i%, gs%).position
                PUT #fh%, , GRAD_OPACITY_STOPS(i%, gs%).opacity%
            NEXT gs%
            FOR gs% = 1 TO GRADIENT_MAX_STOPS
                PUT #fh%, , GRAD_STOP_TYPES(i%, gs%)
            NEXT gs%
        NEXT i%
    END IF
    CLOSE #fh%
END SUB

''
' Show an open dialog and import a .dset file into the drawer.
' Replaces all slots in the mode stored within the file.
'
SUB DRAWER_import_set_dialog ()
    DIM fh AS INTEGER
    DIM defaultPath AS STRING
    DIM filename AS STRING
    DIM magic AS STRING * 4
    DIM version AS INTEGER
    DIM fileMode AS INTEGER
    DIM selectedSlot AS INTEGER
    DIM i AS INTEGER
    DIM loadedImg AS LONG

    IF CFG.LAST_DIR_IMPORT$ <> "" THEN
        defaultPath$ = CFG.LAST_DIR_IMPORT$ + "/"
    ELSEIF LAST_DIRECTORY$ <> "" THEN
        defaultPath$ = LAST_DIRECTORY$ + "/"
    ELSE
        DRAWER_ensure_sets_dir
        defaultPath$ = DRAWER_sets_dir$ + "/"
    END IF

    POINTER_hide_for_dialog
    filename$ = DRAW_open_file$("Import Drawer Set", defaultPath$, "DRAW Drawer Set|*.dset", 0)
    POINTER_show_after_dialog
    MOUSE_cleanup_after_dialog TRUE
    IF filename$ = "" THEN EXIT SUB

    CFG.LAST_DIR_IMPORT$ = CONFIG_extract_dir$(filename$)
    LAST_DIRECTORY$ = CFG.LAST_DIR_IMPORT$
    CONFIG_save

    fh% = FREEFILE
    OPEN filename$ FOR BINARY AS #fh%
    GET #fh%, , magic$
    IF magic$ <> "DST1" THEN
        CLOSE #fh%
        POINTER_hide_for_dialog
        DRAW_error "Drawer Set", "Unsupported drawer set file."
        POINTER_show_after_dialog
        MOUSE_cleanup_after_dialog TRUE
        EXIT SUB
    END IF

    GET #fh%, , version%
    GET #fh%, , fileMode%
    GET #fh%, , selectedSlot%
    IF (version% < 1 OR version% > 2) OR fileMode% < DRAWER_MODE_BRUSH OR fileMode% > DRAWER_MODE_GRADIENT THEN
        CLOSE #fh%
        POINTER_hide_for_dialog
        DRAW_error "Drawer Set", "Unsupported drawer set version."
        POINTER_show_after_dialog
        MOUSE_cleanup_after_dialog TRUE
        EXIT SUB
    END IF

    DRAWER_ensure_samples

    SELECT CASE fileMode%
        CASE DRAWER_MODE_BRUSH
            FOR i% = 1 TO DRAWER_SLOT_COUNT
                IF DRAWER_BRUSH_SLOTS(i%).IMG < -1 THEN _FREEIMAGE DRAWER_BRUSH_SLOTS(i%).IMG
                loadedImg& = DRAWER_load_slot_image&(fh%)
                DRAWER_BRUSH_SLOTS(i%).IMG = loadedImg&
                IF loadedImg& < -1 THEN
                    DRAWER_BRUSH_SLOTS(i%).W = _WIDTH(loadedImg&)
                    DRAWER_BRUSH_SLOTS(i%).H = _HEIGHT(loadedImg&)
                ELSE
                    DRAWER_BRUSH_SLOTS(i%).W = 0
                    DRAWER_BRUSH_SLOTS(i%).H = 0
                END IF
            NEXT i%
            DRAWER.brushSelected% = selectedSlot%
            IF DRAWER.brushSelected% < 1 OR DRAWER.brushSelected% > DRAWER_SLOT_COUNT THEN DRAWER.brushSelected% = 1
            IF DRAWER_BRUSH_SLOTS(DRAWER.brushSelected%).IMG < -1 THEN DRAWER_load_brush_slot_to_custom DRAWER.brushSelected%
        CASE DRAWER_MODE_PATTERN
            FOR i% = 1 TO DRAWER_SLOT_COUNT
                IF DRAWER_PATTERN_SLOTS(i%) < -1 THEN _FREEIMAGE DRAWER_PATTERN_SLOTS(i%)
                loadedImg& = DRAWER_load_slot_image&(fh%)
                DRAWER_PATTERN_SLOTS(i%) = loadedImg&
                DRAWER_PATTERN_HAS(i%) = (loadedImg& < -1)
            NEXT i%
            DRAWER_analyze_all_1bit
            DRAWER.patternSelected% = selectedSlot%
            IF DRAWER.patternSelected% < 1 OR DRAWER.patternSelected% > DRAWER_SLOT_COUNT THEN DRAWER.patternSelected% = 1
        CASE ELSE
            FOR i% = 1 TO DRAWER_SLOT_COUNT
                IF DRAWER_GRADIENT_SLOTS(i%) < -1 THEN _FREEIMAGE DRAWER_GRADIENT_SLOTS(i%)
                loadedImg& = DRAWER_load_slot_image&(fh%)
                DRAWER_GRADIENT_SLOTS(i%) = loadedImg&
                DRAWER_GRADIENT_HAS(i%) = (loadedImg& < -1)
                DRAWER_GRADIENT_CUSTOM(i%) = (loadedImg& < -1)
                IF DRAWER_GRADIENT_CUSTOM(i%) THEN
                    GRAD_DEFS(i%).colorCount% = 0
                    GRAD_DEFS(i%).opacityCount% = 0
                END IF
            NEXT i%
            ' Version 2: read per-slot grad_defs, color/opacity stops, and stop types
            IF version% >= 2 THEN
                DIM gs AS INTEGER
                FOR i% = 1 TO DRAWER_SLOT_COUNT
                    GET #fh%, , GRAD_DEFS(i%).family%
                    GET #fh%, , GRAD_DEFS(i%).colorCount%
                    GET #fh%, , GRAD_DEFS(i%).opacityCount%
                    GET #fh%, , GRAD_DEFS(i%).usesFG%
                    GET #fh%, , GRAD_DEFS(i%).usesBG%
                    GET #fh%, , GRAD_DEFS(i%).gName
                    GET #fh%, , GRAD_DEFS(i%).ditherMode%
                    GET #fh%, , GRAD_DEFS(i%).ditherStrength!
                    FOR gs% = 1 TO GRADIENT_MAX_STOPS
                        GET #fh%, , GRAD_COLOR_STOPS(i%, gs%).position
                        GET #fh%, , GRAD_COLOR_STOPS(i%, gs%).clr
                    NEXT gs%
                    FOR gs% = 1 TO GRADIENT_MAX_STOPS
                        GET #fh%, , GRAD_OPACITY_STOPS(i%, gs%).position
                        GET #fh%, , GRAD_OPACITY_STOPS(i%, gs%).opacity%
                    NEXT gs%
                    FOR gs% = 1 TO GRADIENT_MAX_STOPS
                        GET #fh%, , GRAD_STOP_TYPES(i%, gs%)
                    NEXT gs%
                    IF GRAD_DEFS(i%).colorCount% >= 1 THEN DRAWER_GRADIENT_CUSTOM(i%) = FALSE
                    GRAD_DEFS(i%).previewDirty% = TRUE
                NEXT i%
                ' Rebuild previews from loaded definitions
                FOR i% = 1 TO DRAWER_SLOT_COUNT
                    IF GRAD_DEFS(i%).colorCount% >= 1 THEN
                        GRAD_DEF_rebuild_preview i%
                    END IF
                NEXT i%
            END IF
            DRAWER.gradientSelected% = selectedSlot%
            IF DRAWER.gradientSelected% < 1 OR DRAWER.gradientSelected% > DRAWER_SLOT_COUNT THEN DRAWER.gradientSelected% = 1
    END SELECT
    CLOSE #fh%

    DRAWER.visible% = TRUE
    DRAWER.mode% = fileMode%
    DRAWER.samplesLoaded% = TRUE
    DRAWER.loadedTheme = _TRIM$(CFG.THEME$)
    DRAWER_GRADIENT_LAST_FG~& = PAINT_COLOR~&
    DRAWER_GRADIENT_LAST_BG~& = PAINT_BG_COLOR~&
    GUI_NEEDS_REDRAW% = TRUE
    FRAME_IDLE% = FALSE
END SUB


''
' Modal gradient editor dialog.
' Edits the currently selected gradient slot's color stops and family.
'
SUB GRADIENT_editor_dialog ()
    DIM slotIdx AS INTEGER
    slotIdx% = DRAWER.gradientSelected%
    IF slotIdx% < 1 OR slotIdx% > DRAWER_SLOT_COUNT THEN EXIT SUB

    ' ---- Layout constants ----
    CONST GED_W = 256
    CONST GED_BAR_X = 8
    CONST GED_BAR_W = 240
    CONST GED_BAR_H = 20
    CONST GED_STOP_H = 8
    CONST GED_BTN_H = 20
    CONST GED_OK_X = 10
    CONST GED_OK_W = 108
    CONST GED_CX_X = 138
    CONST GED_CX_W = 108
    CONST GED_OKCX_H = 22

    ' Compute dynamic heights
    DIM gedBarY AS INTEGER
    DIM gedStopY AS INTEGER
    DIM gedFamilyY AS INTEGER
    DIM gedInfoY AS INTEGER
    DIM gedActY AS INTEGER
    DIM gedAlphaY AS INTEGER
    DIM gedDivY AS INTEGER
    DIM gedOkY AS INTEGER
    DIM gedH AS INTEGER

    gedBarY% = 22
    gedStopY% = gedBarY% + GED_BAR_H + 2
    gedFamilyY% = gedStopY% + GED_STOP_H + 6
    gedInfoY% = gedFamilyY% + 20
    gedAlphaY% = gedInfoY% + 20
    gedActY% = gedAlphaY% + 40

    ' FG/BG type buttons row
    DIM gedTypeY AS INTEGER
    gedTypeY% = gedActY% + GED_BTN_H + 18

    ' Dither controls between actions and divider
    DIM gedDitherY AS INTEGER
    DIM gedStrengthY AS INTEGER
    gedDitherY% = gedTypeY% + GED_BTN_H + 8
    gedStrengthY% = gedDitherY% + 22

    gedDivY% = gedStrengthY% + 38
    gedOkY% = gedDivY% + 6
    gedH% = gedOkY% + GED_OKCX_H + 8

    ' ---- Init dialog context ----
    DIM ctx AS DIALOG_CTX
    ' Force a render so any previously-visible popup menu is cleared from the screen
    ' before DIALOG_init captures its background screenshot
    SCENE_DIRTY% = TRUE
    SCREEN_render
    DIALOG_init ctx, GED_W, gedH%

    ' ---- Initialize empty slots with black-to-white default ----
    ' If slot has a custom image but no GRAD_DEFS (imported PNG), extract stops
    IF GRAD_DEFS(slotIdx%).colorCount% < 2 THEN
        IF DRAWER_GRADIENT_SLOTS(slotIdx%) < -1 THEN
            ' Extract color stops from existing gradient image
            DIM gedExtImg AS LONG : gedExtImg& = DRAWER_GRADIENT_SLOTS(slotIdx%)
            DIM gedExtW AS INTEGER : gedExtW% = _WIDTH(gedExtImg&)
            DIM gedExtH AS INTEGER : gedExtH% = _HEIGHT(gedExtImg&)
            DIM gedExtOldSrc AS LONG : gedExtOldSrc& = _SOURCE
            _SOURCE gedExtImg&
            ' Sample up to 8 evenly-spaced stops along horizontal center line
            DIM gedExtCount AS INTEGER
            IF gedExtW% <= 8 THEN gedExtCount% = gedExtW% ELSE gedExtCount% = 8
            IF gedExtCount% < 2 THEN gedExtCount% = 2
            DIM gedExtMidY AS INTEGER : gedExtMidY% = gedExtH% \ 2
            DIM gedExtI AS INTEGER
            FOR gedExtI% = 1 TO gedExtCount%
                DIM gedExtSX AS INTEGER
                IF gedExtCount% > 1 THEN
                    gedExtSX% = INT((gedExtI% - 1) * (gedExtW% - 1) / (gedExtCount% - 1))
                ELSE
                    gedExtSX% = 0
                END IF
                GRAD_COLOR_STOPS(slotIdx%, gedExtI%).position = (gedExtI% - 1) / (gedExtCount% - 1)
                GRAD_COLOR_STOPS(slotIdx%, gedExtI%).clr = POINT(gedExtSX%, gedExtMidY%)
                GRAD_STOP_TYPES(slotIdx%, gedExtI%) = GRAD_STOP_USER
            NEXT gedExtI%
            _SOURCE gedExtOldSrc&
            GRAD_DEFS(slotIdx%).colorCount% = gedExtCount%
            IF GRAD_DEFS(slotIdx%).family% < 1 OR GRAD_DEFS(slotIdx%).family% > 8 THEN
                GRAD_DEFS(slotIdx%).family% = 1
            END IF
        ELSE
            ' Truly empty slot - use black-to-white default
            GRAD_DEFS(slotIdx%).colorCount% = 2
            IF GRAD_DEFS(slotIdx%).family% < 1 OR GRAD_DEFS(slotIdx%).family% > 8 THEN
                GRAD_DEFS(slotIdx%).family% = 1
            END IF
            GRAD_COLOR_STOPS(slotIdx%, 1).position = 0
            GRAD_COLOR_STOPS(slotIdx%, 1).clr = _RGB32(0, 0, 0)
            GRAD_COLOR_STOPS(slotIdx%, 2).position = 1
            GRAD_COLOR_STOPS(slotIdx%, 2).clr = _RGB32(255, 255, 255)
        END IF
    END IF

    ' ---- Snapshot for cancel ----
    DIM savedDef AS GRADIENT_DEF
    DIM savedStops(1 TO GRADIENT_MAX_STOPS) AS GRADIENT_COLOR_STOP
    DIM savedStopTypes(1 TO GRADIENT_MAX_STOPS) AS INTEGER
    savedDef = GRAD_DEFS(slotIdx%)
    DIM gedSi AS INTEGER
    FOR gedSi% = 1 TO GRADIENT_MAX_STOPS
        savedStops(gedSi%) = GRAD_COLOR_STOPS(slotIdx%, gedSi%)
        savedStopTypes(gedSi%) = GRAD_STOP_TYPES(slotIdx%, gedSi%)
    NEXT gedSi%

    DIM selStop AS INTEGER
    DIM dragStop AS INTEGER
    DIM stopCnt AS INTEGER
    DIM tmpStopType AS INTEGER

    selStop% = 1
    dragStop% = 0

    ' ---- Family name lookup ----
    DIM famNames(1 TO 8) AS STRING
    famNames(1) = "HORIZONTAL"
    famNames(2) = "VERTICAL"
    famNames(3) = "DIAGONAL"
    famNames(4) = "ANTI-DIAG"
    famNames(5) = "RADIAL"
    famNames(6) = "REFLECT-H"
    famNames(7) = "REFLECT-V"
    famNames(8) = "DIAMOND"

    ' ---- Modal loop ----
    DIM gedK AS LONG
    DIM gedGx AS INTEGER
    DIM gedGt AS SINGLE
    DIM gedGc AS _UNSIGNED LONG
    DIM gedSx AS INTEGER
    DIM hitIdx AS INTEGER
    DIM newFam AS INTEGER
    DIM gedI AS INTEGER
    DIM gedJ AS INTEGER
    DIM tmpStop AS GRADIENT_COLOR_STOP
    DIM stopAlpha AS INTEGER

    DO
        DIALOG_poll_mouse ctx

        ' Keyboard
        gedK& = _KEYHIT
        IF gedK& = 13 THEN ctx.done% = TRUE : ctx.result% = TRUE
        IF gedK& = 27 THEN ctx.done% = TRUE : ctx.result% = FALSE
        ' Delete key removes selected stop
        IF gedK& = 21248 THEN
            stopCnt% = GRAD_DEFS(slotIdx%).colorCount%
            IF stopCnt% > 2 AND selStop% >= 1 AND selStop% <= stopCnt% THEN
                FOR gedI% = selStop% TO stopCnt% - 1
                    GRAD_COLOR_STOPS(slotIdx%, gedI%) = GRAD_COLOR_STOPS(slotIdx%, gedI% + 1)
                    GRAD_STOP_TYPES(slotIdx%, gedI%) = GRAD_STOP_TYPES(slotIdx%, gedI% + 1)
                NEXT gedI%
                GRAD_STOP_TYPES(slotIdx%, stopCnt%) = GRAD_STOP_USER
                GRAD_DEFS(slotIdx%).colorCount% = stopCnt% - 1
                IF selStop% > GRAD_DEFS(slotIdx%).colorCount% THEN selStop% = GRAD_DEFS(slotIdx%).colorCount%
            END IF
        END IF

        stopCnt% = GRAD_DEFS(slotIdx%).colorCount%

        ' ---- Stop interaction (click on stop markers) ----
        IF ctx.justClicked% THEN
            hitIdx% = 0

            ' Check stop markers
            FOR gedI% = 1 TO stopCnt%
                gedSx% = GED_BAR_X + INT(GRAD_COLOR_STOPS(slotIdx%, gedI%).position * (GED_BAR_W - 1))
                IF ctx.mx% >= gedSx% - 4 AND ctx.mx% <= gedSx% + 4 THEN
                    IF ctx.my% >= gedStopY% AND ctx.my% <= gedStopY% + GED_STOP_H THEN
                        hitIdx% = gedI%
                        EXIT FOR
                    END IF
                END IF
            NEXT gedI%

            IF hitIdx% > 0 THEN
                selStop% = hitIdx%
                dragStop% = hitIdx%
            ELSEIF ctx.my% >= gedBarY% AND ctx.my% <= gedBarY% + GED_BAR_H AND ctx.mx% >= GED_BAR_X AND ctx.mx% <= GED_BAR_X + GED_BAR_W THEN
                ' Click on gradient bar = add new stop
                IF stopCnt% < GRADIENT_MAX_STOPS THEN
                    DIM newStopPos AS SINGLE
                    newStopPos! = (ctx.mx% - GED_BAR_X) / (GED_BAR_W - 1)
                    IF newStopPos! < 0 THEN newStopPos! = 0
                    IF newStopPos! > 1 THEN newStopPos! = 1
                    stopCnt% = stopCnt% + 1
                    GRAD_DEFS(slotIdx%).colorCount% = stopCnt%
                    GRAD_COLOR_STOPS(slotIdx%, stopCnt%).position = newStopPos!
                    GRAD_COLOR_STOPS(slotIdx%, stopCnt%).clr = PAINT_COLOR~&
                    GRAD_STOP_TYPES(slotIdx%, stopCnt%) = GRAD_STOP_USER
                    selStop% = stopCnt%
                    ' Sort stops by position
                    FOR gedI% = 1 TO stopCnt% - 1
                        FOR gedJ% = 1 TO stopCnt% - gedI%
                            IF GRAD_COLOR_STOPS(slotIdx%, gedJ%).position > GRAD_COLOR_STOPS(slotIdx%, gedJ% + 1).position THEN
                                tmpStop = GRAD_COLOR_STOPS(slotIdx%, gedJ%)
                                GRAD_COLOR_STOPS(slotIdx%, gedJ%) = GRAD_COLOR_STOPS(slotIdx%, gedJ% + 1)
                                GRAD_COLOR_STOPS(slotIdx%, gedJ% + 1) = tmpStop
                                tmpStopType% = GRAD_STOP_TYPES(slotIdx%, gedJ%)
                                GRAD_STOP_TYPES(slotIdx%, gedJ%) = GRAD_STOP_TYPES(slotIdx%, gedJ% + 1)
                                GRAD_STOP_TYPES(slotIdx%, gedJ% + 1) = tmpStopType%
                                IF selStop% = gedJ% THEN
                                    selStop% = gedJ% + 1
                                ELSEIF selStop% = gedJ% + 1 THEN
                                    selStop% = gedJ%
                                END IF
                            END IF
                        NEXT gedJ%
                    NEXT gedI%
                END IF
            END IF
        END IF

        ' ---- Drag selected stop ----
        IF dragStop% > 0 AND ctx.mb1% THEN
            DIM dragPos AS SINGLE
            dragPos! = (ctx.mx% - GED_BAR_X) / (GED_BAR_W - 1)
            IF dragPos! < 0 THEN dragPos! = 0
            IF dragPos! > 1 THEN dragPos! = 1
            GRAD_COLOR_STOPS(slotIdx%, dragStop%).position = dragPos!
        ELSEIF dragStop% > 0 AND NOT ctx.mb1% THEN
            dragStop% = 0
            ' Re-sort after drag
            FOR gedI% = 1 TO stopCnt% - 1
                FOR gedJ% = 1 TO stopCnt% - gedI%
                    IF GRAD_COLOR_STOPS(slotIdx%, gedJ%).position > GRAD_COLOR_STOPS(slotIdx%, gedJ% + 1).position THEN
                        tmpStop = GRAD_COLOR_STOPS(slotIdx%, gedJ%)
                        GRAD_COLOR_STOPS(slotIdx%, gedJ%) = GRAD_COLOR_STOPS(slotIdx%, gedJ% + 1)
                        GRAD_COLOR_STOPS(slotIdx%, gedJ% + 1) = tmpStop
                        tmpStopType% = GRAD_STOP_TYPES(slotIdx%, gedJ%)
                        GRAD_STOP_TYPES(slotIdx%, gedJ%) = GRAD_STOP_TYPES(slotIdx%, gedJ% + 1)
                        GRAD_STOP_TYPES(slotIdx%, gedJ% + 1) = tmpStopType%
                        IF selStop% = gedJ% THEN
                            selStop% = gedJ% + 1
                        ELSEIF selStop% = gedJ% + 1 THEN
                            selStop% = gedJ%
                        END IF
                    END IF
                NEXT gedJ%
            NEXT gedI%
        END IF

        ' ---- Family cycle buttons ----
        IF DIALOG_hit%(ctx, GED_BAR_X, gedFamilyY%, 20, 16) THEN
            newFam% = GRAD_DEFS(slotIdx%).family% - 1
            IF newFam% < 1 THEN newFam% = 8
            GRAD_DEFS(slotIdx%).family% = newFam%
        END IF
        IF DIALOG_hit%(ctx, GED_BAR_X + GED_BAR_W - 20, gedFamilyY%, 20, 16) THEN
            newFam% = GRAD_DEFS(slotIdx%).family% + 1
            IF newFam% > 8 THEN newFam% = 1
            GRAD_DEFS(slotIdx%).family% = newFam%
        END IF

        ' ---- Alpha slider for selected stop ----
        IF selStop% >= 1 AND selStop% <= stopCnt% THEN
            stopAlpha% = _ALPHA32(GRAD_COLOR_STOPS(slotIdx%, selStop%).clr)
            stopAlpha% = DIALOG_slider_drag%(ctx, GED_BAR_X, gedAlphaY% + 14, GED_BAR_W, 14, stopAlpha%, 0, 255)
            stopAlpha% = DIALOG_slider_wheel%(ctx, GED_BAR_X, gedAlphaY% + 14, GED_BAR_W, 14, stopAlpha%, 0, 255)
            GRAD_COLOR_STOPS(slotIdx%, selStop%).clr = _RGBA32(_RED32(GRAD_COLOR_STOPS(slotIdx%, selStop%).clr), _GREEN32(GRAD_COLOR_STOPS(slotIdx%, selStop%).clr), _BLUE32(GRAD_COLOR_STOPS(slotIdx%, selStop%).clr), stopAlpha%)
        END IF

        ' ---- Pick Color button ----
        ' Normal click = app palette picker, Shift+click = system color chooser
        IF DIALOG_hit%(ctx, GED_BAR_X, gedActY%, 80, GED_BTN_H) THEN
            IF selStop% >= 1 AND selStop% <= stopCnt% THEN
                DIM pickedColor AS _UNSIGNED LONG
                IF _KEYDOWN(KEY_LSHIFT&) OR _KEYDOWN(KEY_RSHIFT&) THEN
                    POINTER_hide_for_dialog
                    pickedColor~& = DRAW_pick_color&("Choose Stop Color", GRAD_COLOR_STOPS(slotIdx%, selStop%).clr)
                    POINTER_show_after_dialog
                    MOUSE_cleanup_after_dialog FALSE
                ELSE
                    pickedColor~& = PALETTE_PICKER_show~&("Choose Stop Color", GRAD_COLOR_STOPS(slotIdx%, selStop%).clr)
                    _MOUSESHOW
                END IF
                stopAlpha% = _ALPHA32(GRAD_COLOR_STOPS(slotIdx%, selStop%).clr)
                GRAD_COLOR_STOPS(slotIdx%, selStop%).clr = _RGBA32(_RED32(pickedColor~&), _GREEN32(pickedColor~&), _BLUE32(pickedColor~&), stopAlpha%)
                GRAD_STOP_TYPES(slotIdx%, selStop%) = GRAD_STOP_USER
                GRAD_DEFS(slotIdx%).usesFG% = FALSE
                GRAD_DEFS(slotIdx%).usesBG% = FALSE
            END IF
        END IF

        ' ---- Delete Stop button ----
        IF DIALOG_hit%(ctx, GED_BAR_X + 90, gedActY%, 80, GED_BTN_H) THEN
            IF stopCnt% > 2 AND selStop% >= 1 AND selStop% <= stopCnt% THEN
                FOR gedI% = selStop% TO stopCnt% - 1
                    GRAD_COLOR_STOPS(slotIdx%, gedI%) = GRAD_COLOR_STOPS(slotIdx%, gedI% + 1)
                    GRAD_STOP_TYPES(slotIdx%, gedI%) = GRAD_STOP_TYPES(slotIdx%, gedI% + 1)
                NEXT gedI%
                GRAD_STOP_TYPES(slotIdx%, stopCnt%) = GRAD_STOP_USER
                GRAD_DEFS(slotIdx%).colorCount% = stopCnt% - 1
                stopCnt% = stopCnt% - 1
                IF selStop% > stopCnt% THEN selStop% = stopCnt%
            END IF
        END IF

        ' ---- SET FG / SET BG / USER type buttons ----
        IF selStop% >= 1 AND selStop% <= stopCnt% THEN
            IF DIALOG_hit%(ctx, GED_BAR_X, gedTypeY%, 75, GED_BTN_H) THEN
                ' SET FG
                GRAD_STOP_TYPES(slotIdx%, selStop%) = GRAD_STOP_FG
                GRAD_COLOR_STOPS(slotIdx%, selStop%).clr = _RGBA32(_RED32(PAINT_COLOR~&), _GREEN32(PAINT_COLOR~&), _BLUE32(PAINT_COLOR~&), _ALPHA32(GRAD_COLOR_STOPS(slotIdx%, selStop%).clr))
                GRAD_DEFS(slotIdx%).usesFG% = TRUE
            END IF
            IF DIALOG_hit%(ctx, GED_BAR_X + 83, gedTypeY%, 75, GED_BTN_H) THEN
                ' SET BG
                GRAD_STOP_TYPES(slotIdx%, selStop%) = GRAD_STOP_BG
                GRAD_COLOR_STOPS(slotIdx%, selStop%).clr = _RGBA32(_RED32(PAINT_BG_COLOR~&), _GREEN32(PAINT_BG_COLOR~&), _BLUE32(PAINT_BG_COLOR~&), _ALPHA32(GRAD_COLOR_STOPS(slotIdx%, selStop%).clr))
                GRAD_DEFS(slotIdx%).usesBG% = TRUE
            END IF
            IF DIALOG_hit%(ctx, GED_BAR_X + 166, gedTypeY%, 75, GED_BTN_H) THEN
                ' USER (clear FG/BG type)
                GRAD_STOP_TYPES(slotIdx%, selStop%) = GRAD_STOP_USER
                ' Recalculate usesFG/usesBG flags
                GRAD_DEFS(slotIdx%).usesFG% = FALSE
                GRAD_DEFS(slotIdx%).usesBG% = FALSE
                DIM chkJ AS INTEGER
                FOR chkJ% = 1 TO stopCnt%
                    IF GRAD_STOP_TYPES(slotIdx%, chkJ%) = GRAD_STOP_FG THEN GRAD_DEFS(slotIdx%).usesFG% = TRUE
                    IF GRAD_STOP_TYPES(slotIdx%, chkJ%) = GRAD_STOP_BG THEN GRAD_DEFS(slotIdx%).usesBG% = TRUE
                NEXT chkJ%
            END IF
        END IF

        ' ---- OK / Cancel ----
        IF DIALOG_hit%(ctx, GED_OK_X, gedOkY%, GED_OK_W, GED_OKCX_H) THEN
            ctx.done% = TRUE : ctx.result% = TRUE
        END IF
        IF DIALOG_hit%(ctx, GED_CX_X, gedOkY%, GED_CX_W, GED_OKCX_H) THEN
            ctx.done% = TRUE : ctx.result% = FALSE
        END IF

        ' ---- Dither mode cycle button ----
        IF DIALOG_hit%(ctx, GED_BAR_X, gedDitherY%, GED_BAR_W, 18) THEN
            DIM curPpIdx AS INTEGER
            curPpIdx% = DITHER_imgadj_to_perpixel%(GRAD_DEFS(slotIdx%).ditherMode%)
            IF GRAD_DEFS(slotIdx%).ditherMode% = DITHER_NONE THEN
                ' First per-pixel algorithm
                GRAD_DEFS(slotIdx%).ditherMode% = DITHER_PERPIXEL_MAP(0)
            ELSEIF curPpIdx% >= 0 AND curPpIdx% < DITHER_COUNT_PERPIXEL - 1 THEN
                GRAD_DEFS(slotIdx%).ditherMode% = DITHER_PERPIXEL_MAP(curPpIdx% + 1)
            ELSE
                GRAD_DEFS(slotIdx%).ditherMode% = DITHER_NONE
            END IF
        END IF

        ' ---- Dither strength slider ----
        IF GRAD_DEFS(slotIdx%).ditherMode% <> DITHER_NONE THEN
            DIM gedDitherPct AS INTEGER
            gedDitherPct% = INT(GRAD_DEFS(slotIdx%).ditherStrength! * 100! + 0.5)
            gedDitherPct% = DIALOG_slider_drag%(ctx, GED_BAR_X, gedStrengthY% + 14, GED_BAR_W, 14, gedDitherPct%, 0, 100)
            gedDitherPct% = DIALOG_slider_wheel%(ctx, GED_BAR_X, gedStrengthY% + 14, GED_BAR_W, 14, gedDitherPct%, 0, 100)
            GRAD_DEFS(slotIdx%).ditherStrength! = gedDitherPct% / 100!
        END IF

        ' ========== RENDER ==========
        _DEST ctx.imgHandle
        DIALOG_draw_frame ctx, "GRADIENT EDITOR"

        ' Checker background behind gradient bar (for transparency)
        DIM cbx AS INTEGER, cby AS INTEGER
        FOR cby% = gedBarY% TO gedBarY% + GED_BAR_H - 1
            FOR cbx% = GED_BAR_X TO GED_BAR_X + GED_BAR_W - 1
                IF ((cbx% \ 4) + (cby% \ 4)) MOD 2 = 0 THEN
                    PSET (cbx%, cby%), _RGB32(192, 192, 192)
                ELSE
                    PSET (cbx%, cby%), _RGB32(128, 128, 128)
                END IF
            NEXT cbx%
        NEXT cby%

        ' Draw gradient bar
        IF GRAD_DEFS(slotIdx%).ditherMode% <> DITHER_NONE AND GRAD_DEFS(slotIdx%).colorCount% >= 2 THEN
            ' Per-pixel dithered rendering
            DIM gedDy AS INTEGER
            DIM gedDt AS SINGLE, gedDu AS SINGLE
            DIM gedDsegT AS SINGLE, gedDspan AS SINGLE, gedDthr AS SINGLE
            DIM gedDstr AS SINGLE, gedDi AS INTEGER
            DIM gedDcolA AS _UNSIGNED LONG, gedDcolB AS _UNSIGNED LONG
            DIM gedDcnt AS INTEGER
            gedDcnt% = GRAD_DEFS(slotIdx%).colorCount%
            gedDstr! = GRAD_DEFS(slotIdx%).ditherStrength!
            FOR gedDy% = 0 TO GED_BAR_H - 1
                FOR gedGx% = 0 TO GED_BAR_W - 1
                    gedDt! = gedGx% / (GED_BAR_W - 1)
                    ' Find bracketing stops
                    gedDu! = gedDt!
                    IF gedDu! < 0 THEN gedDu! = 0
                    IF gedDu! > 1 THEN gedDu! = 1
                    gedDcolA~& = GRAD_COLOR_STOPS(slotIdx%, 1).clr
                    gedDcolB~& = gedDcolA~&
                    gedDsegT! = 0.5
                    FOR gedDi% = 1 TO gedDcnt% - 1
                        IF gedDu! >= GRAD_COLOR_STOPS(slotIdx%, gedDi%).position AND gedDu! <= GRAD_COLOR_STOPS(slotIdx%, gedDi% + 1).position THEN
                            gedDcolA~& = GRAD_COLOR_STOPS(slotIdx%, gedDi%).clr
                            gedDcolB~& = GRAD_COLOR_STOPS(slotIdx%, gedDi% + 1).clr
                            gedDspan! = GRAD_COLOR_STOPS(slotIdx%, gedDi% + 1).position - GRAD_COLOR_STOPS(slotIdx%, gedDi%).position
                            IF gedDspan! > 0 THEN
                                gedDsegT! = (gedDu! - GRAD_COLOR_STOPS(slotIdx%, gedDi%).position) / gedDspan!
                            ELSE
                                gedDsegT! = 0
                            END IF
                            EXIT FOR
                        END IF
                    NEXT gedDi%
                    gedDthr! = DITHER_get_threshold!(GRAD_DEFS(slotIdx%).ditherMode%, GED_BAR_X + gedGx%, gedBarY% + gedDy%)
                    ' Blend smooth lerp with binary dither by strength
                    DIM gedSmooth AS _UNSIGNED LONG
                    DIM gedDither AS _UNSIGNED LONG
                    gedSmooth~& = DRAWER_gradient_lerp_color~&(gedDcolA~&, gedDcolB~&, gedDsegT!)
                    IF gedDsegT! < gedDthr! THEN gedDither~& = gedDcolA~& ELSE gedDither~& = gedDcolB~&
                    IF gedDstr! >= 1 THEN
                        PSET (GED_BAR_X + gedGx%, gedBarY% + gedDy%), gedDither~&
                    ELSEIF gedDstr! <= 0 THEN
                        PSET (GED_BAR_X + gedGx%, gedBarY% + gedDy%), gedSmooth~&
                    ELSE
                        DIM gedFR AS INTEGER, gedFG AS INTEGER, gedFB AS INTEGER
                        gedFR% = _RED32(gedSmooth~&) + INT((_RED32(gedDither~&) - _RED32(gedSmooth~&)) * gedDstr! + .5)
                        gedFG% = _GREEN32(gedSmooth~&) + INT((_GREEN32(gedDither~&) - _GREEN32(gedSmooth~&)) * gedDstr! + .5)
                        gedFB% = _BLUE32(gedSmooth~&) + INT((_BLUE32(gedDither~&) - _BLUE32(gedSmooth~&)) * gedDstr! + .5)
                        PSET (GED_BAR_X + gedGx%, gedBarY% + gedDy%), _RGB32(gedFR%, gedFG%, gedFB%)
                    END IF
                NEXT gedGx%
            NEXT gedDy%
        ELSE
            FOR gedGx% = 0 TO GED_BAR_W - 1
                gedGt! = gedGx% / (GED_BAR_W - 1)
                gedGc~& = GRAD_DEF_eval_color~&(slotIdx%, gedGt!)
                LINE (GED_BAR_X + gedGx%, gedBarY%)-(GED_BAR_X + gedGx%, gedBarY% + GED_BAR_H - 1), gedGc~&
            NEXT gedGx%
        END IF
        ' Border
        LINE (GED_BAR_X - 1, gedBarY% - 1)-(GED_BAR_X + GED_BAR_W, gedBarY% + GED_BAR_H), _RGB32(100, 100, 100), B

        ' Draw stop markers
        FOR gedI% = 1 TO stopCnt%
            gedSx% = GED_BAR_X + INT(GRAD_COLOR_STOPS(slotIdx%, gedI%).position * (GED_BAR_W - 1))
            ' Filled rect with stop color
            LINE (gedSx% - 3, gedStopY%)-(gedSx% + 3, gedStopY% + GED_STOP_H - 1), GRAD_COLOR_STOPS(slotIdx%, gedI%).clr, BF
            ' Selection highlight
            IF gedI% = selStop% THEN
                LINE (gedSx% - 4, gedStopY% - 1)-(gedSx% + 4, gedStopY% + GED_STOP_H), _RGB32(255, 255, 255), B
            ELSE
                LINE (gedSx% - 3, gedStopY%)-(gedSx% + 3, gedStopY% + GED_STOP_H - 1), _RGB32(64, 64, 64), B
            END IF
        NEXT gedI%

        ' Family selector row
        DIM famStr AS STRING
        DIM famIdx AS INTEGER
        famIdx% = GRAD_DEFS(slotIdx%).family%
        IF famIdx% < 1 OR famIdx% > 8 THEN famIdx% = 1
        famStr$ = famNames(famIdx%)
        DIALOG_draw_button ctx, GED_BAR_X, gedFamilyY%, 20, 16, CHR$(17), _RGB32(60, 60, 80), _RGB32(80, 80, 120), _RGB32(120, 120, 160)
        DIALOG_draw_button ctx, GED_BAR_X + GED_BAR_W - 20, gedFamilyY%, 20, 16, CHR$(16), _RGB32(60, 60, 80), _RGB32(80, 80, 120), _RGB32(120, 120, 160)
        DIALOG_draw_label ctx, GED_BAR_X + 28, gedFamilyY% + 2, "FAMILY: " + famStr$

        ' Selected stop info
        IF selStop% >= 1 AND selStop% <= stopCnt% THEN
            DIM posStr AS STRING
            DIM typeStr AS STRING
            posStr$ = LTRIM$(STR$(INT(GRAD_COLOR_STOPS(slotIdx%, selStop%).position * 100 + 0.5)))
            SELECT CASE GRAD_STOP_TYPES(slotIdx%, selStop%)
                CASE GRAD_STOP_FG: typeStr$ = " [FG]"
                CASE GRAD_STOP_BG: typeStr$ = " [BG]"
                CASE ELSE: typeStr$ = ""
            END SELECT
            DIALOG_draw_label ctx, GED_BAR_X, gedInfoY% + 2, "STOP #" + LTRIM$(STR$(selStop%)) + " AT " + posStr$ + "%" + typeStr$
            ' Show stop color swatch
            LINE (GED_BAR_X + GED_BAR_W - 20, gedInfoY%)-(GED_BAR_X + GED_BAR_W - 1, gedInfoY% + 15), GRAD_COLOR_STOPS(slotIdx%, selStop%).clr, BF
            LINE (GED_BAR_X + GED_BAR_W - 20, gedInfoY%)-(GED_BAR_X + GED_BAR_W - 1, gedInfoY% + 15), _RGB32(100, 100, 100), B
        ELSE
            DIALOG_draw_label ctx, GED_BAR_X, gedInfoY% + 2, "NO STOP SELECTED"
        END IF

        ' Alpha slider
        IF selStop% >= 1 AND selStop% <= stopCnt% THEN
            DIALOG_draw_slider ctx, GED_BAR_X, gedAlphaY% + 14, GED_BAR_W, _ALPHA32(GRAD_COLOR_STOPS(slotIdx%, selStop%).clr), 0, 255, "ALPHA", ""
        ELSE
            DIALOG_draw_slider ctx, GED_BAR_X, gedAlphaY% + 14, GED_BAR_W, 255, 0, 255, "ALPHA", ""
        END IF

        ' Action buttons
        DIALOG_draw_button ctx, GED_BAR_X, gedActY%, 80, GED_BTN_H, "PICK COLOR", _RGB32(40, 80, 100), _RGB32(60, 120, 150), _RGB32(80, 160, 200)
        DIALOG_draw_label ctx, GED_BAR_X, gedActY% + GED_BTN_H + 2, "SHIFT=SYS"
        DIALOG_draw_button ctx, GED_BAR_X + 90, gedActY%, 80, GED_BTN_H, "DEL STOP", _RGB32(100, 40, 40), _RGB32(150, 60, 60), _RGB32(200, 80, 80)

        ' Stop type buttons (SET FG / SET BG / USER)
        DIM gedFgBtnC AS _UNSIGNED LONG, gedBgBtnC AS _UNSIGNED LONG, gedUsrBtnC AS _UNSIGNED LONG
        IF selStop% >= 1 AND selStop% <= stopCnt% THEN
            IF GRAD_STOP_TYPES(slotIdx%, selStop%) = GRAD_STOP_FG THEN
                gedFgBtnC~& = _RGB32(80, 160, 80)
            ELSE
                gedFgBtnC~& = _RGB32(60, 80, 60)
            END IF
            IF GRAD_STOP_TYPES(slotIdx%, selStop%) = GRAD_STOP_BG THEN
                gedBgBtnC~& = _RGB32(80, 80, 160)
            ELSE
                gedBgBtnC~& = _RGB32(60, 60, 80)
            END IF
            IF GRAD_STOP_TYPES(slotIdx%, selStop%) = GRAD_STOP_USER THEN
                gedUsrBtnC~& = _RGB32(120, 120, 120)
            ELSE
                gedUsrBtnC~& = _RGB32(70, 70, 70)
            END IF
        ELSE
            gedFgBtnC~& = _RGB32(50, 50, 50)
            gedBgBtnC~& = _RGB32(50, 50, 50)
            gedUsrBtnC~& = _RGB32(50, 50, 50)
        END IF
        DIALOG_draw_button ctx, GED_BAR_X, gedTypeY%, 75, GED_BTN_H, "SET FG", gedFgBtnC~&, _RGB32(100, 200, 100), _RGB32(120, 255, 120)
        DIALOG_draw_button ctx, GED_BAR_X + 83, gedTypeY%, 75, GED_BTN_H, "SET BG", gedBgBtnC~&, _RGB32(100, 100, 200), _RGB32(120, 120, 255)
        DIALOG_draw_button ctx, GED_BAR_X + 166, gedTypeY%, 75, GED_BTN_H, "USER", gedUsrBtnC~&, _RGB32(150, 150, 150), _RGB32(200, 200, 200)

        ' Dither mode button
        DIM gedDithName AS STRING
        IF GRAD_DEFS(slotIdx%).ditherMode% = DITHER_NONE THEN
            gedDithName$ = "DITHER: OFF"
        ELSE
            gedDithName$ = "D: " + DITHER_algorithm_name$(GRAD_DEFS(slotIdx%).ditherMode%)
        END IF
        DIALOG_draw_button ctx, GED_BAR_X, gedDitherY%, GED_BAR_W, 18, gedDithName$, _RGB32(60, 60, 80), _RGB32(80, 80, 110), _RGB32(110, 110, 150)

        ' Dither strength slider
        IF GRAD_DEFS(slotIdx%).ditherMode% <> DITHER_NONE THEN
            DIM gedStrPct AS INTEGER
            gedStrPct% = INT(GRAD_DEFS(slotIdx%).ditherStrength! * 100! + 0.5)
            DIALOG_draw_slider ctx, GED_BAR_X, gedStrengthY% + 14, GED_BAR_W, gedStrPct%, 0, 100, "STRENGTH", "%"
        END IF

        ' Divider + OK/Cancel
        DIALOG_draw_divider ctx, gedDivY%
        DIALOG_draw_button ctx, GED_OK_X, gedOkY%, GED_OK_W, GED_OKCX_H, "OK", _RGB32(40, 100, 40), _RGB32(60, 150, 60), _RGB32(80, 200, 80)
        DIALOG_draw_button ctx, GED_CX_X, gedOkY%, GED_CX_W, GED_OKCX_H, "CANCEL", _RGB32(100, 40, 40), _RGB32(150, 60, 60), _RGB32(200, 80, 80)

        DIALOG_blit ctx
    LOOP UNTIL ctx.done%

    ' ---- Commit or cancel ----
    IF ctx.result% THEN
        ' Keep changes, rebuild the slot preview
        GRAD_DEF_rebuild_preview slotIdx%
    ELSE
        ' Restore snapshot
        GRAD_DEFS(slotIdx%) = savedDef
        FOR gedSi% = 1 TO GRADIENT_MAX_STOPS
            GRAD_COLOR_STOPS(slotIdx%, gedSi%) = savedStops(gedSi%)
            GRAD_STOP_TYPES(slotIdx%, gedSi%) = savedStopTypes(gedSi%)
        NEXT gedSi%
    END IF

    DIALOG_cleanup ctx
    MOUSE_cleanup_after_dialog FALSE
    GUI_NEEDS_REDRAW% = TRUE
    FRAME_IDLE% = FALSE
END SUB


''
' Check whether a pattern slot is flagged as 1-bit.
' @param slotIndex INTEGER Slot index (1..DRAWER_SLOT_COUNT)
' @return INTEGER - TRUE if the slot contains a 1-bit pattern
'
FUNCTION DRAWER_pattern_is_1bit% (slotIndex AS INTEGER)
    IF slotIndex% < 1 OR slotIndex% > DRAWER_SLOT_COUNT THEN
        DRAWER_pattern_is_1bit% = FALSE
        EXIT FUNCTION
    END IF
    DRAWER_pattern_is_1bit% = DRAWER_PATTERN_1BIT(slotIndex%)
END FUNCTION


''
' Analyze a pattern slot to determine if it is a 1-bit pattern.
' A 1-bit pattern has at most 1 opaque color (on transparent), or exactly
' 2 opaque colors where the majority-pixel color is treated as BG and the
' minority-pixel color as FG.
' Sets DRAWER_PATTERN_1BIT(slot) and DRAWER_PATTERN_1BIT_FG(slot).
' @param slotIndex INTEGER Slot index (1..DRAWER_SLOT_COUNT)
'
SUB DRAWER_analyze_1bit (slotIndex AS INTEGER)
    DIM img AS LONG
    DIM imgW AS INTEGER
    DIM imgH AS INTEGER
    DIM oldSource AS LONG
    DIM px AS INTEGER
    DIM py AS INTEGER
    DIM c AS _UNSIGNED LONG
    DIM a AS _UNSIGNED LONG
    DIM color1 AS _UNSIGNED LONG
    DIM color2 AS _UNSIGNED LONG
    DIM count1 AS LONG
    DIM count2 AS LONG
    DIM numColors AS INTEGER

    IF slotIndex% < 1 OR slotIndex% > DRAWER_SLOT_COUNT THEN EXIT SUB

    DRAWER_PATTERN_1BIT(slotIndex%) = FALSE
    DRAWER_PATTERN_1BIT_FG(slotIndex%) = 0

    img& = DRAWER_PATTERN_SLOTS(slotIndex%)
    IF img& >= -1 THEN EXIT SUB

    imgW% = _WIDTH(img&)
    imgH% = _HEIGHT(img&)
    IF imgW% < 1 OR imgH% < 1 THEN EXIT SUB

    oldSource& = _SOURCE
    _SOURCE img&

    numColors% = 0
    color1~& = 0
    color2~& = 0
    count1& = 0
    count2& = 0

    FOR py% = 0 TO imgH% - 1
        FOR px% = 0 TO imgW% - 1
            c~& = POINT(px%, py%)
            a~& = _ALPHA32(c~&)
            IF a~& = 0 THEN _CONTINUE ' skip fully transparent pixels

            ' Strip alpha channel for comparison (treat any opaque/semi-opaque as same color)
            c~& = _RGB32(_RED32(c~&), _GREEN32(c~&), _BLUE32(c~&))

            IF numColors% = 0 THEN
                color1~& = c~&
                count1& = 1
                numColors% = 1
            ELSEIF c~& = color1~& THEN
                count1& = count1& + 1
            ELSEIF numColors% = 1 THEN
                color2~& = c~&
                count2& = 1
                numColors% = 2
            ELSEIF c~& = color2~& THEN
                count2& = count2& + 1
            ELSE
                ' More than 2 opaque colors — not 1-bit
                _SOURCE oldSource&
                EXIT SUB
            END IF
        NEXT px%
    NEXT py%

    _SOURCE oldSource&

    IF numColors% = 0 THEN
        ' All transparent — not useful as 1-bit
        EXIT SUB
    ELSEIF numColors% = 1 THEN
        ' Single opaque color on transparent — 1-bit (no opaque BG)
        DRAWER_PATTERN_1BIT(slotIndex%) = TRUE
        DRAWER_PATTERN_1BIT_FG(slotIndex%) = color1~&
        DRAWER_PATTERN_1BIT_HAS_BG(slotIndex%) = FALSE
    ELSEIF numColors% = 2 THEN
        ' Two opaque colors — majority is BG, minority is FG
        DRAWER_PATTERN_1BIT(slotIndex%) = TRUE
        DRAWER_PATTERN_1BIT_HAS_BG(slotIndex%) = TRUE
        IF count1& <= count2& THEN
            DRAWER_PATTERN_1BIT_FG(slotIndex%) = color1~&
        ELSE
            DRAWER_PATTERN_1BIT_FG(slotIndex%) = color2~&
        END IF
    END IF
END SUB


''
' Analyze all populated pattern slots for 1-bit status.
'
SUB DRAWER_analyze_all_1bit ()
    DIM i AS INTEGER
    FOR i% = 1 TO DRAWER_SLOT_COUNT
        IF DRAWER_PATTERN_HAS(i%) THEN
            DRAWER_analyze_1bit i%
        ELSE
            DRAWER_PATTERN_1BIT(i%) = FALSE
            DRAWER_PATTERN_1BIT_FG(i%) = 0
            DRAWER_PATTERN_1BIT_HAS_BG(i%) = FALSE
        END IF
    NEXT i%
END SUB