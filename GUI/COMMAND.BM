''
' Register a command
' @param cmd_name STRING - Display name shown in the command palette
' @param cmd_hotkey STRING - Keyboard shortcut hint displayed beside the command
' @param cmd_category INTEGER - Category constant (CMD_CAT_*) for grouping
' @param cmd_action_id INTEGER - Action ID dispatched by CMD_execute_action
'
SUB CMD_register (cmd_name AS STRING, cmd_hotkey AS STRING, cmd_category AS INTEGER, cmd_action_id AS INTEGER)
    IF CMD_COUNT >= CMD_MAX_COMMANDS THEN EXIT SUB
    
    CMD_LIST(CMD_COUNT).name = cmd_name$
    CMD_LIST(CMD_COUNT).hotkey = cmd_hotkey$
    CMD_LIST(CMD_COUNT).category = cmd_category%
    CMD_LIST(CMD_COUNT).action_id = cmd_action_id%
    CMD_LIST(CMD_COUNT).enabled = TRUE
    CMD_COUNT = CMD_COUNT + 1
END SUB


''
' Show command palette (with search)
'
SUB CMD_show_palette ()
    CMD_PALETTE.visible = TRUE
    CMD_PALETTE.mode = 0  ' Command palette mode with search
    CMD_PALETTE.search = ""
    CMD_PALETTE.search_len = 0
    CMD_PALETTE.hover = 0
    CMD_PALETTE.scroll = 0
    CMD_update_search
    GUI_NEEDS_REDRAW% = TRUE
END SUB


''
' Show quick reference (no search, just list all)
'
SUB CMD_show_quick_ref ()
    CMD_PALETTE.visible = TRUE
    CMD_PALETTE.mode = 1  ' Quick reference mode
    CMD_PALETTE.search = ""
    CMD_PALETTE.search_len = 0
    CMD_PALETTE.hover = 0
    CMD_PALETTE.scroll = 0
    CMD_update_search
    GUI_NEEDS_REDRAW% = TRUE
END SUB


''
' Hide command palette
'
SUB CMD_hide ()
    CMD_PALETTE.visible = FALSE
    GUI_NEEDS_REDRAW% = TRUE
END SUB


''
' Render command palette
' @param dest LONG - Image handle to draw the palette UI onto
'
SUB CMD_render (dest AS LONG)
    IF NOT CMD_PALETTE.visible THEN EXIT SUB
    
    DIM oldDest AS LONG
    DIM oldFont AS LONG
    DIM i AS INTEGER, idx AS INTEGER
    DIM item_y AS INTEGER
    DIM display_count AS INTEGER
    DIM cat_name AS STRING
    DIM name_str AS STRING, hotkey_str AS STRING
    DIM row_height AS INTEGER
    DIM char_width AS INTEGER
    DIM font_height AS INTEGER
    
    oldDest& = _DEST
    _DEST dest&
    
    ' Set font
    oldFont& = _FONT(dest&)
    IF CMD_FONT_HANDLE > 0 THEN
        _FONT CMD_FONT_HANDLE, dest&
        font_height% = _UFONTHEIGHT(CMD_FONT_HANDLE)
        char_width% = _PRINTWIDTH("M", dest&)  ' Use M width for proportional
    ELSE
        font_height% = THEME.GLOBAL_FONT_SIZE%
        IF font_height% < 1 THEN font_height% = 8
        char_width% = font_height%
    END IF
    row_height% = font_height% + 4
    
    ' Recalculate dimensions based on font â€” width scales with canvas
    CMD_PALETTE_W = INT(SCRN.w& * THEME.CMD_PALETTE_width_ratio!)
    IF CMD_PALETTE_W < THEME.CMD_PALETTE_min_width% THEN CMD_PALETTE_W = THEME.CMD_PALETTE_min_width%
    IF CMD_PALETTE_W > THEME.CMD_PALETTE_max_width% THEN CMD_PALETTE_W = THEME.CMD_PALETTE_max_width%
    CMD_PALETTE_H = (CMD_MAX_VISIBLE + 2) * row_height% + 30
    CMD_PALETTE_X = (SCRN.w& - CMD_PALETTE_W) \ 2
    CMD_PALETTE_Y = THEME.CMD_PALETTE_top%
    
    ' Draw background with border
    LINE (CMD_PALETTE_X - 2, CMD_PALETTE_Y - 2)-(CMD_PALETTE_X + CMD_PALETTE_W + 2, CMD_PALETTE_Y + CMD_PALETTE_H + 2), THEME.CMD_PALETTE_frame_outer~&, BF
    LINE (CMD_PALETTE_X - 1, CMD_PALETTE_Y - 1)-(CMD_PALETTE_X + CMD_PALETTE_W + 1, CMD_PALETTE_Y + CMD_PALETTE_H + 1), THEME.CMD_PALETTE_frame_mid~&, BF
    LINE (CMD_PALETTE_X, CMD_PALETTE_Y)-(CMD_PALETTE_X + CMD_PALETTE_W, CMD_PALETTE_Y + CMD_PALETTE_H), THEME.CMD_PALETTE_bg~&, BF
    
    ' Draw header
    DIM header_text AS STRING
    IF CMD_PALETTE.mode = 0 THEN
        header_text$ = "Command Palette"
    ELSE
        header_text$ = "Hotkey Quick Reference"
    END IF
    COLOR THEME.CMD_PALETTE_header_fg~&, _RGBA32(0, 0, 0, 0)
    _UPRINTSTRING (CMD_PALETTE_X + 10, CMD_PALETTE_Y + 6), header_text$
    
    ' Draw close hint
    DIM hint_text AS STRING
    hint_text$ = "ESC close"
    COLOR THEME.CMD_PALETTE_hint_fg~&, _RGBA32(0, 0, 0, 0)
    _UPRINTSTRING (CMD_PALETTE_X + CMD_PALETTE_W - _PRINTWIDTH(hint_text$, dest&) - 10, CMD_PALETTE_Y + 6), hint_text$
    
    ' Draw search box
    DIM search_y AS INTEGER
    search_y% = CMD_PALETTE_Y + row_height% + 6
    
    IF TRUE THEN
        LINE (CMD_PALETTE_X + 6, search_y%)-(CMD_PALETTE_X + CMD_PALETTE_W - 6, search_y% + row_height%), THEME.CMD_PALETTE_search_bg~&, BF
        LINE (CMD_PALETTE_X + 6, search_y%)-(CMD_PALETTE_X + CMD_PALETTE_W - 6, search_y% + row_height%), THEME.CMD_PALETTE_search_border~&, B
        
        COLOR THEME.CMD_PALETTE_search_fg~&, _RGBA32(0, 0, 0, 0)
        IF CMD_PALETTE.search_len > 0 THEN
            _UPRINTSTRING (CMD_PALETTE_X + 10, search_y% + 3), LEFT$(CMD_PALETTE.search, CMD_PALETTE.search_len)
        ELSE
            COLOR THEME.CMD_PALETTE_search_placeholder_fg~&, _RGBA32(0, 0, 0, 0)
            _UPRINTSTRING (CMD_PALETTE_X + 10, search_y% + 3), "Type to search..."
        END IF
        
        ' Draw cursor
        DIM cursor_x AS INTEGER
        DIM search_text AS STRING
        search_text$ = LEFT$(CMD_PALETTE.search, CMD_PALETTE.search_len)
        cursor_x% = CMD_PALETTE_X + 10 + _PRINTWIDTH(search_text$, dest&)
        LINE (cursor_x%, search_y% + 2)-(cursor_x%, search_y% + row_height% - 2), THEME.CMD_PALETTE_cursor_fg~&
    END IF
    
    ' Draw results
    DIM list_y AS INTEGER
    list_y% = search_y% + row_height% + 4
    
    display_count% = CMD_PALETTE.result_count - CMD_PALETTE.scroll
    IF display_count% > CMD_MAX_VISIBLE THEN display_count% = CMD_MAX_VISIBLE
    
    ' Column positions
    DIM cat_col AS INTEGER, name_col AS INTEGER, hotkey_col AS INTEGER
    cat_col% = CMD_PALETTE_X + 10
    name_col% = CMD_PALETTE_X + 80
    hotkey_col% = CMD_PALETTE_X + CMD_PALETTE_W - 10  ' Right edge for right-aligned hotkeys
    
    FOR i% = 0 TO display_count% - 1
        idx% = CMD_RESULTS(CMD_PALETTE.scroll + i%)
        item_y% = list_y% + (i% * row_height%)
        
        ' Highlight hovered item
        IF i% + CMD_PALETTE.scroll = CMD_PALETTE.hover THEN
            LINE (CMD_PALETTE_X + 6, item_y%)-(CMD_PALETTE_X + CMD_PALETTE_W - 6, item_y% + row_height% - 1), THEME.CMD_PALETTE_hover_bg~&, BF
        END IF
        
        ' Get category name
        cat_name$ = CMD_category_name$(CMD_LIST(idx%).category)
        
        ' Draw category in dim color
        COLOR THEME.CMD_PALETTE_category_fg~&, _RGBA32(0, 0, 0, 0)
        _UPRINTSTRING (cat_col%, item_y% + 2), LEFT$(cat_name$, 8)
        
        ' Draw command name
        name_str$ = RTRIM$(CMD_LIST(idx%).name)
        COLOR THEME.CMD_PALETTE_name_fg~&, _RGBA32(0, 0, 0, 0)
        _UPRINTSTRING (name_col%, item_y% + 2), name_str$
        
        ' Draw hotkey on right side (right-aligned)
        hotkey_str$ = RTRIM$(CMD_LIST(idx%).hotkey)
        IF LEN(hotkey_str$) > 0 THEN
            COLOR THEME.CMD_PALETTE_hotkey_fg~&, _RGBA32(0, 0, 0, 0)
            _UPRINTSTRING (hotkey_col% - _PRINTWIDTH(hotkey_str$, dest&), item_y% + 2), hotkey_str$
        END IF
    NEXT i%
    
    ' Draw scroll indicator if needed
    IF CMD_PALETTE.result_count > CMD_MAX_VISIBLE THEN
        DIM scroll_info AS STRING
        scroll_info$ = _TRIM$(STR$(CMD_PALETTE.scroll + 1)) + "-" + _TRIM$(STR$(CMD_PALETTE.scroll + display_count%)) + " of " + _TRIM$(STR$(CMD_PALETTE.result_count))
        COLOR THEME.CMD_PALETTE_scroll_fg~&, _RGBA32(0, 0, 0, 0)
        _UPRINTSTRING (CMD_PALETTE_X + 10, CMD_PALETTE_Y + CMD_PALETTE_H - row_height%), scroll_info$
    END IF
    
    ' Restore font
    IF oldFont& > 0 THEN _FONT oldFont&, dest&
    
    _DEST oldDest&
END SUB


''
' Handle key input for command palette
' @param keypress STRING - Single character from _KEYHIT (ESC, Enter, Backspace, or printable)
'
SUB CMD_handle_key (keypress AS STRING)
    IF NOT CMD_PALETTE.visible THEN EXIT SUB
    
    DIM key_code AS INTEGER
    
    IF LEN(keypress$) = 0 THEN EXIT SUB
    
    key_code% = ASC(keypress$)
    
    SELECT CASE key_code%
        CASE 27  ' ESC - close
            CMD_hide
            
        CASE 13  ' Enter - execute selected
            CMD_execute_selected
            CMD_hide
            
        CASE 8   ' Backspace - delete character
            IF CMD_PALETTE.search_len > 0 THEN
                CMD_PALETTE.search_len = CMD_PALETTE.search_len - 1
                CMD_update_search
            END IF
            
        CASE 32 TO 126  ' Printable characters
            IF CMD_PALETTE.search_len < CMD_MAX_SEARCH THEN
                MID$(CMD_PALETTE.search, CMD_PALETTE.search_len + 1, 1) = keypress$
                CMD_PALETTE.search_len = CMD_PALETTE.search_len + 1
                CMD_update_search
            END IF
    END SELECT
    
    GUI_NEEDS_REDRAW% = TRUE
END SUB


''
' Handle mouse click on command palette
' @param x INTEGER - Screen X coordinate of the click
' @param y INTEGER - Screen Y coordinate of the click
'
SUB CMD_handle_click (x AS INTEGER, y AS INTEGER)
    IF NOT CMD_PALETTE.visible THEN EXIT SUB
    IF NOT CMD_in_bounds%(x%, y%) THEN
        CMD_hide
        EXIT SUB
    END IF
    
    ' Calculate row height based on font
    DIM row_height AS INTEGER
    IF CMD_FONT_HANDLE > 0 THEN
        row_height% = _UFONTHEIGHT(CMD_FONT_HANDLE) + 4
    ELSE
        row_height% = THEME.GLOBAL_FONT_SIZE%
        IF row_height% < 1 THEN row_height% = 10
        row_height% = row_height% + 4
    END IF
    
    ' Calculate which item was clicked
    DIM list_y AS INTEGER
    DIM item_idx AS INTEGER
    
    IF CMD_PALETTE.mode = 0 THEN
        list_y% = CMD_PALETTE_Y + row_height% + 6 + row_height% + 4  ' After header and search box
    ELSE
        list_y% = CMD_PALETTE_Y + row_height% + 6  ' After header
    END IF
    
    IF y% >= list_y% THEN
        item_idx% = (y% - list_y%) \ row_height% + CMD_PALETTE.scroll
        IF item_idx% >= 0 AND item_idx% < CMD_PALETTE.result_count THEN
            CMD_PALETTE.hover = item_idx%
            CMD_execute_selected
            CMD_hide
        END IF
    END IF
END SUB


''
' Navigate up in list
'
SUB CMD_navigate_up ()
    IF NOT CMD_PALETTE.visible THEN EXIT SUB
    
    IF CMD_PALETTE.hover > 0 THEN
        CMD_PALETTE.hover = CMD_PALETTE.hover - 1
        IF CMD_PALETTE.hover < CMD_PALETTE.scroll THEN
            CMD_PALETTE.scroll = CMD_PALETTE.hover
        END IF
    END IF
    GUI_NEEDS_REDRAW% = TRUE
END SUB


''
' Navigate down in list
'
SUB CMD_navigate_down ()
    IF NOT CMD_PALETTE.visible THEN EXIT SUB
    
    IF CMD_PALETTE.hover < CMD_PALETTE.result_count - 1 THEN
        CMD_PALETTE.hover = CMD_PALETTE.hover + 1
        IF CMD_PALETTE.hover >= CMD_PALETTE.scroll + CMD_MAX_VISIBLE THEN
            CMD_PALETTE.scroll = CMD_PALETTE.hover - CMD_MAX_VISIBLE + 1
        END IF
    END IF
    GUI_NEEDS_REDRAW% = TRUE
END SUB


''
' Navigate page up in list
'
SUB CMD_navigate_page_up ()
    IF NOT CMD_PALETTE.visible THEN EXIT SUB
    
    CMD_PALETTE.hover = CMD_PALETTE.hover - CMD_MAX_VISIBLE
    IF CMD_PALETTE.hover < 0 THEN CMD_PALETTE.hover = 0
    
    CMD_PALETTE.scroll = CMD_PALETTE.scroll - CMD_MAX_VISIBLE
    IF CMD_PALETTE.scroll < 0 THEN CMD_PALETTE.scroll = 0
    
    GUI_NEEDS_REDRAW% = TRUE
END SUB


''
' Navigate page down in list
'
SUB CMD_navigate_page_down ()
    IF NOT CMD_PALETTE.visible THEN EXIT SUB
    
    CMD_PALETTE.hover = CMD_PALETTE.hover + CMD_MAX_VISIBLE
    IF CMD_PALETTE.hover >= CMD_PALETTE.result_count THEN
        CMD_PALETTE.hover = CMD_PALETTE.result_count - 1
    END IF
    
    CMD_PALETTE.scroll = CMD_PALETTE.scroll + CMD_MAX_VISIBLE
    DIM max_scroll AS INTEGER
    max_scroll% = CMD_PALETTE.result_count - CMD_MAX_VISIBLE
    IF max_scroll% < 0 THEN max_scroll% = 0
    IF CMD_PALETTE.scroll > max_scroll% THEN CMD_PALETTE.scroll = max_scroll%
    
    GUI_NEEDS_REDRAW% = TRUE
END SUB


''
' Execute the currently selected command
'
SUB CMD_execute_selected ()
    IF CMD_PALETTE.hover < 0 OR CMD_PALETTE.hover >= CMD_PALETTE.result_count THEN EXIT SUB
    
    DIM idx AS INTEGER
    idx% = CMD_RESULTS(CMD_PALETTE.hover)
    CMD_execute_action CMD_LIST(idx%).action_id
END SUB


''
' Execute a command by action ID
' @param action_id INTEGER - Action ID to execute (see Action ID Ranges in COMMAND.BM)
'
SUB CMD_execute_action (action_id AS INTEGER)
    ' Auto-deactivate Palette Ops mode on any command dispatch
    IF PALETTE_OPS.ACTIVE% THEN
        PALETTE_OPS_deactivate
    END IF

    SELECT CASE action_id%
        ' ========== TOOLS ==========
        CASE 101: KEYBOARD_tools "b"  ' Brush
        CASE 102: KEYBOARD_tools "d"  ' Dot
        CASE 103: KEYBOARD_tools "f"  ' Fill
        CASE 104: KEYBOARD_tools "i"  ' Picker
        CASE 105: KEYBOARD_tools "l"  ' Line
        CASE 106: KEYBOARD_tools "p"  ' Polygon
        CASE 107  ' Polygon Filled (simulate Shift+P)
            PREVIOUS_TOOL% = CURRENT_TOOL%
            CURRENT_TOOL% = TOOL_POLYGON_FILLED
            POLY_LINE.FILLED = TRUE
            GUI_NEEDS_REDRAW% = TRUE
        CASE 108: KEYBOARD_tools "r"  ' Rectangle
        CASE 109  ' Rectangle Filled
            PREVIOUS_TOOL% = CURRENT_TOOL%
            CURRENT_TOOL% = TOOL_RECT_FILLED
            GUI_NEEDS_REDRAW% = TRUE
        CASE 110: KEYBOARD_tools "c"  ' Ellipse
        CASE 111  ' Ellipse Filled
            PREVIOUS_TOOL% = CURRENT_TOOL%
            CURRENT_TOOL% = TOOL_ELLIPSE_FILLED
            GUI_NEEDS_REDRAW% = TRUE
        CASE 112  ' Marquee
            SOUND_play SND_SELECTION
            KEYBOARD_tools "m"
        CASE 117  ' Magic Wand
            SOUND_play SND_SELECTION
            KEYBOARD_tools "w"
        CASE 113: KEYBOARD_tools "v"  ' Move
        CASE 114: KEYBOARD_tools "t"  ' Text
        CASE 115  ' Text Tiny5
            PREVIOUS_TOOL% = CURRENT_TOOL%
            CURRENT_TOOL% = TOOL_TEXT
            TEXT.USE_CUSTOM = FALSE
            TEXT.USE_TINY5 = TRUE
            TEXT.CHAR_WIDTH = 5
            TEXT.LINE_HEIGHT = 6
            TEXT_reset
            GUI_NEEDS_REDRAW% = TRUE
        CASE 116  ' Text Custom
            PREVIOUS_TOOL% = CURRENT_TOOL%
            CURRENT_TOOL% = TOOL_TEXT
            IF TEXT.CUSTOM_FONT_HANDLE > 0 THEN TEXT.USE_CUSTOM = TRUE
            TEXT.USE_TINY5 = FALSE
            TEXT_reset
            GUI_NEEDS_REDRAW% = TRUE
        CASE 118  ' Eraser Tool
            PREVIOUS_TOOL% = CURRENT_TOOL%
            CURRENT_TOOL% = TOOL_ERASER
            TOOLS_reset_all FALSE
            ERASER_activate
            GUI_NEEDS_REDRAW% = TRUE
        CASE 119  ' Freehand Select
            PREVIOUS_TOOL% = CURRENT_TOOL%
            IF CURRENT_TOOL% = TOOL_ERASER THEN ERASER_deactivate
            CURRENT_TOOL% = TOOL_MARQUEE
            TOOLS_reset_all FALSE
            MARQUEE.MAGIC_WAND_MODE = FALSE
            MARQUEE.VARIANT = TOOL_SELECT_FREE
            FREEHAND_SEL_reset
            POLY_SEL_reset
            ELLIPSE_SEL_reset
            SOUND_play SND_SELECTION
            GUI_NEEDS_REDRAW% = TRUE
        CASE 120  ' Polygon Select
            PREVIOUS_TOOL% = CURRENT_TOOL%
            IF CURRENT_TOOL% = TOOL_ERASER THEN ERASER_deactivate
            CURRENT_TOOL% = TOOL_MARQUEE
            TOOLS_reset_all FALSE
            MARQUEE.MAGIC_WAND_MODE = FALSE
            MARQUEE.VARIANT = TOOL_SELECT_POLY
            FREEHAND_SEL_reset
            POLY_SEL_reset
            ELLIPSE_SEL_reset
            SOUND_play SND_SELECTION
            GUI_NEEDS_REDRAW% = TRUE
        CASE 121  ' Ellipse Select
            PREVIOUS_TOOL% = CURRENT_TOOL%
            IF CURRENT_TOOL% = TOOL_ERASER THEN ERASER_deactivate
            CURRENT_TOOL% = TOOL_MARQUEE
            TOOLS_reset_all FALSE
            MARQUEE.MAGIC_WAND_MODE = FALSE
            MARQUEE.VARIANT = TOOL_SELECT_ELLIPSE
            FREEHAND_SEL_reset
            POLY_SEL_reset
            ELLIPSE_SEL_reset
            SOUND_play SND_SELECTION
            GUI_NEEDS_REDRAW% = TRUE
        
        ' ========== EDIT ==========
        CASE 301  ' Undo
            IF CURRENT_TOOL% = TOOL_MOVE AND MOVE.ACTIVE THEN
                ' Abort the active move instead of undoing â€” same as ESC
                ' Suppress undo save in MOVE_apply_transform (called by MOVE_reset)
                ' since the cancel just restores original pixels â€” saving would create
                ' a phantom undo state identical to pre-capture.
                HISTORY_saved_this_frame% = TRUE
                MOVE_cancel_transform
                MOVE_reset
                ' Keep TOOL_MOVE selected (MOVE_reset already cleans up auto-created marquee)
            ELSEIF (CURRENT_TOOL% = TOOL_POLYGON OR CURRENT_TOOL% = TOOL_POLYGON_FILLED) AND POLY_LINE.HAS_LAST AND POLY_LINE.HISTORY_BEFORE_IMG < -1 THEN
                POLY_LINE_cancel_restore
            ELSE
                IF HISTORY_can_undo% THEN
                    HISTORY_undo
                END IF
            END IF
            GUI_NEEDS_REDRAW% = TRUE
            FRAME_IDLE% = FALSE
        CASE 302  ' Redo
            IF HISTORY_can_redo% THEN
                HISTORY_redo
            END IF
            GUI_NEEDS_REDRAW% = TRUE
            FRAME_IDLE% = FALSE
        CASE 303: SOUND_play SND_CLIPBOARD: CLIPBOARD_copy  ' Copy
        CASE 304: SOUND_play SND_CLIPBOARD: CLIPBOARD_cut   ' Cut
        CASE 305: SOUND_play SND_CLIPBOARD: CLIPBOARD_paste MOUSE.X%, MOUSE.Y%  ' Paste
        CASE 330: SOUND_play SND_CLIPBOARD: CLIPBOARD_paste_from_os MOUSE.X%, MOUSE.Y%  ' Paste from OS Clipboard
        CASE 322: SOUND_play SND_CLIPBOARD: CLIPBOARD_copy_merged  ' Copy Merged
        CASE 323  ' Cut to New Layer
            SOUND_play SND_CLIPBOARD
            IF CURRENT_LAYER% > 0 THEN
                ' Save workspace undo for the compound operation
                CLIPBOARD_cut
                DIM ctnl_idx AS INTEGER
                ctnl_idx% = LAYERS_new%
                IF ctnl_idx% > 0 AND CLIPBOARD.VALID AND CLIPBOARD.IMAGE < -1 THEN
                    ' Directly paint clipboard onto new layer (no floating selection)
                    DIM ctnl_dest AS LONG
                    ctnl_dest& = LAYERS(ctnl_idx%).imgHandle&
                    IF ctnl_dest& < -1 THEN
                        _PUTIMAGE (CLIPBOARD.SOURCE_X, CLIPBOARD.SOURCE_Y), CLIPBOARD.IMAGE, ctnl_dest&
                        LAYERS(ctnl_idx%).contentDirty% = TRUE
                        HISTORY_refresh_layer_add_snapshot LAYERS(ctnl_idx%).historyId&
                        HISTORY_saved_this_frame% = TRUE
                        INVALIDATE_layers
                    END IF
                END IF
            END IF
        CASE 321  ' Copy to New Layer
            SOUND_play SND_CLIPBOARD
            IF CURRENT_LAYER% > 0 THEN
                DIM cpnl_srcLyr AS INTEGER
                cpnl_srcLyr% = CURRENT_LAYER%  ' Save before LAYERS_new% changes it
                CLIPBOARD_copy
                DIM cpnl_idx AS INTEGER
                cpnl_idx% = LAYERS_new%
                IF cpnl_idx% > 0 THEN
                    ' Directly paint onto new layer (no floating selection)
                    DIM cpnl_dest AS LONG
                    cpnl_dest& = LAYERS(cpnl_idx%).imgHandle&
                    IF cpnl_dest& < -1 THEN
                        ' Opacity lock: copy only non-transparent pixels from source layer
                        IF LAYERS(cpnl_srcLyr%).opacityLock% AND LAYERS(cpnl_srcLyr%).imgHandle& < -1 THEN
                            DIM cpnlSrcMem AS _MEM, cpnlDstMem AS _MEM
                            cpnlSrcMem = _MEMIMAGE(LAYERS(cpnl_srcLyr%).imgHandle&)
                            cpnlDstMem = _MEMIMAGE(cpnl_dest&)
                            DIM cpnlMaxOff AS _OFFSET
                            cpnlMaxOff = cpnlSrcMem.SIZE
                            IF cpnlDstMem.SIZE < cpnlMaxOff THEN cpnlMaxOff = cpnlDstMem.SIZE
                            DIM cpnlOff AS _OFFSET
                            DIM cpnlAlpha AS _UNSIGNED _BYTE
                            DIM cpnlPx AS _UNSIGNED LONG
                            FOR cpnlOff = 0 TO cpnlMaxOff - 4 STEP 4
                                _MEMGET cpnlSrcMem, cpnlSrcMem.OFFSET + cpnlOff + 3, cpnlAlpha~%%
                                IF cpnlAlpha~%% > 0 THEN
                                    _MEMGET cpnlSrcMem, cpnlSrcMem.OFFSET + cpnlOff, cpnlPx~&
                                    _MEMPUT cpnlDstMem, cpnlDstMem.OFFSET + cpnlOff, cpnlPx~&
                                END IF
                            NEXT cpnlOff
                            _MEMFREE cpnlSrcMem
                            _MEMFREE cpnlDstMem
                        ELSEIF CLIPBOARD.VALID AND CLIPBOARD.IMAGE < -1 THEN
                            _PUTIMAGE (CLIPBOARD.SOURCE_X, CLIPBOARD.SOURCE_Y), CLIPBOARD.IMAGE, cpnl_dest&
                        END IF
                        LAYERS(cpnl_idx%).contentDirty% = TRUE
                        HISTORY_refresh_layer_add_snapshot LAYERS(cpnl_idx%).historyId&
                        HISTORY_saved_this_frame% = TRUE
                        INVALIDATE_layers
                    END IF
                END IF
            END IF
        CASE 306, 308  ' Clear selection / Edit > Clear
            DIM clearUsedHistoryGroup AS INTEGER
            clearUsedHistoryGroup% = FALSE
            IF MULTI_SELECT_has_any% AND NOT HISTORY_IN_PROGRESS% THEN
                HISTORY_begin_group
                clearUsedHistoryGroup% = HISTORY_GROUP_ACTIVE%
            END IF
            CLIPBOARD_clear_selection
            ' Apply clear to all other multi-selected layers
            IF MULTI_SELECT_has_any% THEN
                DIM mlClrI AS INTEGER
                FOR mlClrI% = 1 TO MAX_LAYERS
                    IF MULTI_SELECT_LAYERS(mlClrI%) AND mlClrI% <> CURRENT_LAYER% THEN
                        CMD_ml_clear mlClrI%
                    END IF
                NEXT mlClrI%
                INVALIDATE_layers
            END IF
            IF clearUsedHistoryGroup% THEN HISTORY_end_group
        CASE 307  ' Deselect
            IF MARQUEE.WAND_HAS_SELECTION AND MARQUEE.SELECTION_MASK < -1 THEN
                HISTORY_selection_stage
                MAGIC_WAND_reset
                MARQUEE.ACTIVE% = FALSE
                HISTORY_selection_commit
                GUI_NEEDS_REDRAW% = TRUE
                FRAME_IDLE% = FALSE
            ELSEIF MARQUEE.ACTIVE% THEN
                HISTORY_selection_stage
                MARQUEE_clear
                HISTORY_selection_commit
                GUI_NEEDS_REDRAW% = TRUE
                FRAME_IDLE% = FALSE
            END IF
        CASE 310  ' Select All
            SOUND_play SND_SELECTION
            HISTORY_selection_stage
            SELECTION_select_all
            HISTORY_selection_commit
        CASE 311  ' Invert Selection
            SOUND_play SND_SELECTION
            HISTORY_selection_stage
            SELECTION_invert
            HISTORY_selection_commit
        
        ' ========== VIEW ==========
        CASE 401  ' Toggle Toolbar
            SCRN.showToolbar% = NOT SCRN.showToolbar%
            SCRN.toolbarManuallyHidden% = NOT SCRN.showToolbar%
            GUI_NEEDS_REDRAW% = TRUE
            SCENE_DIRTY% = TRUE
        CASE 402  ' Toggle Status Bar
            SCRN.showStatus% = NOT SCRN.showStatus%
            SCRN.statusManuallyHidden% = NOT SCRN.showStatus%
            GUI_NEEDS_REDRAW% = TRUE
            SCENE_DIRTY% = TRUE
        CASE 403  ' Toggle All UI
            IF SCRN.showToolbar% OR SCRN.showStatus% OR LAYER_PANEL.visible% OR (SCRN.showMenubar% AND MENU_BAR.visible%) OR PREVIEW.visible% OR SCRN.showEditBar% OR SCRN.showAdvBar% OR TEXT_BAR.visible% OR SCRN.showCharMap% THEN
                SCRN.showToolbar% = FALSE
                SCRN.showStatus% = FALSE
                LAYER_PANEL.visible% = FALSE
                MENU_BAR.visible% = FALSE
                MENUBAR_close_all
                SCRN.toolbarManuallyHidden% = TRUE
                SCRN.statusManuallyHidden% = TRUE
                SCRN.menubarManuallyHidden% = TRUE
                SCRN.layerPanelManuallyHidden% = TRUE
                ' Only hide preview if it was actually visible;
                ' set a dedicated flag so "show all" knows to restore it
                IF PREVIEW.visible% THEN
                    PREVIEW.visible% = FALSE
                    SCRN.showPreviewWindow% = FALSE
                    SCRN.previewHiddenByToggleAll% = TRUE
                ELSE
                    SCRN.previewHiddenByToggleAll% = FALSE
                END IF
                ' Only hide edit bar if it was actually visible
                IF SCRN.showEditBar% THEN
                    SCRN.showEditBar% = FALSE
                    EDIT_BAR.visible% = FALSE
                    SCRN.editBarHiddenByToggleAll% = TRUE
                ELSE
                    SCRN.editBarHiddenByToggleAll% = FALSE
                END IF
                SCRN.editBarManuallyHidden% = TRUE
                ' Only hide advanced bar if it was actually visible
                IF SCRN.showAdvBar% THEN
                    SCRN.showAdvBar% = FALSE
                    ADV_BAR.visible% = FALSE
                    SCRN.advBarHiddenByToggleAll% = TRUE
                ELSE
                    SCRN.advBarHiddenByToggleAll% = FALSE
                END IF
                SCRN.advBarManuallyHidden% = TRUE
                ' Only hide text bar if it was actually visible
                IF TEXT_BAR.visible% THEN
                    TEXT_BAR.visible% = FALSE
                    SCRN.textBarHiddenByToggleAll% = TRUE
                ELSE
                    SCRN.textBarHiddenByToggleAll% = FALSE
                END IF
                ' Only hide character map if it was actually visible
                IF SCRN.showCharMap% THEN
                    SCRN.showCharMap% = FALSE
                    CHARMAP.visible% = FALSE
                    SCRN.charMapHiddenByToggleAll% = TRUE
                ELSE
                    SCRN.charMapHiddenByToggleAll% = FALSE
                END IF
                SCRN.charMapManuallyHidden% = TRUE
                ' Only hide color mixer if it was actually visible
                IF SCRN.showColorMixer% THEN
                    SCRN.showColorMixer% = FALSE
                    COLORMIXER.visible% = FALSE
                    SCRN.colorMixerHiddenByToggleAll% = TRUE
                ELSE
                    SCRN.colorMixerHiddenByToggleAll% = FALSE
                END IF
                SCRN.colorMixerManuallyHidden% = TRUE
            ELSE
                SCRN.showToolbar% = TRUE
                SCRN.showStatus% = TRUE
                LAYER_PANEL.visible% = TRUE
                MENU_BAR.visible% = TRUE
                SCRN.toolbarManuallyHidden% = FALSE
                SCRN.statusManuallyHidden% = FALSE
                SCRN.menubarManuallyHidden% = FALSE
                SCRN.layerPanelManuallyHidden% = FALSE
                ' Only restore preview if toggle-all hid it (not if user
                ' had it off before)
                IF SCRN.previewHiddenByToggleAll% THEN
                    PREVIEW.visible% = TRUE
                    SCRN.showPreviewWindow% = TRUE
                    SCRN.previewManuallyHidden% = FALSE
                    IF NOT PREVIEW.positioned% THEN PREVIEW_auto_position
                    SCRN.previewHiddenByToggleAll% = FALSE
                END IF
                ' Only restore edit bar if toggle-all hid it
                IF SCRN.editBarHiddenByToggleAll% THEN
                    SCRN.showEditBar% = TRUE
                    EDIT_BAR.visible% = TRUE
                    SCRN.editBarManuallyHidden% = FALSE
                    SCRN.editBarHiddenByToggleAll% = FALSE
                END IF
                ' Only restore advanced bar if toggle-all hid it
                IF SCRN.advBarHiddenByToggleAll% THEN
                    SCRN.showAdvBar% = TRUE
                    ADV_BAR.visible% = TRUE
                    SCRN.advBarManuallyHidden% = FALSE
                    SCRN.advBarHiddenByToggleAll% = FALSE
                END IF
                ' Only restore text bar if toggle-all hid it
                IF SCRN.textBarHiddenByToggleAll% THEN
                    SCRN.textBarHiddenByToggleAll% = FALSE
                END IF
                ' Only restore character map if toggle-all hid it
                IF SCRN.charMapHiddenByToggleAll% THEN
                    SCRN.showCharMap% = TRUE
                    CHARMAP.visible% = TRUE
                    SCRN.charMapManuallyHidden% = FALSE
                    SCRN.charMapHiddenByToggleAll% = FALSE
                END IF
                ' Only restore color mixer if toggle-all hid it
                IF SCRN.colorMixerHiddenByToggleAll% THEN
                    SCRN.showColorMixer% = TRUE
                    COLORMIXER.visible% = TRUE
                    SCRN.colorMixerManuallyHidden% = FALSE
                    SCRN.colorMixerHiddenByToggleAll% = FALSE
                END IF
            END IF
            GUI_NEEDS_REDRAW% = TRUE
            SCENE_DIRTY% = TRUE
        CASE 434  ' Toggle Preview Window
            PREVIEW_toggle
            CFG.PREVIEW_VISIBLE% = PREVIEW.visible%
            CONFIG_save
            GUI_NEEDS_REDRAW% = TRUE
            FRAME_IDLE% = FALSE
        CASE 2021  ' Toggle Color Mixer
            COLORMIXER_toggle
            CFG.COLOR_MIXER_VISIBLE% = COLORMIXER.visible%
            CONFIG_save
            GUI_NEEDS_REDRAW% = TRUE
            FRAME_IDLE% = FALSE
        CASE 435  ' Toggle Edit Bar
            EDITBAR_toggle
            FRAME_IDLE% = FALSE
        CASE 449  ' Toggle Advanced Bar
            ADVBAR_toggle
            FRAME_IDLE% = FALSE
        CASE 450  ' Advanced Bar Dock Left
            ADV_BAR.dockSide% = ADVBAR_DOCK_LEFT
            CFG.ADV_BAR_DOCK_POSITION$ = "LEFT"
            CONFIG_save
            GUI_NEEDS_REDRAW% = TRUE
            SCENE_DIRTY% = TRUE
            FRAME_IDLE% = FALSE
        CASE 451  ' Advanced Bar Dock Right
            ADV_BAR.dockSide% = ADVBAR_DOCK_RIGHT
            CFG.ADV_BAR_DOCK_POSITION$ = "RIGHT"
            CONFIG_save
            GUI_NEEDS_REDRAW% = TRUE
            SCENE_DIRTY% = TRUE
            FRAME_IDLE% = FALSE
        CASE 2050  ' Toggle Character Map
            CHARMAP_toggle
            FRAME_IDLE% = FALSE
        CASE 2051  ' Character Map Dock Left
            CHARMAP.dockSide% = CHARMAP_DOCK_LEFT
            CFG.CHARMAP_PANEL_DOCK_EDGE$ = "LEFT"
            CONFIG_save
            SCENE_DIRTY% = TRUE
            GUI_NEEDS_REDRAW% = TRUE
            FRAME_IDLE% = FALSE
        CASE 2052  ' Character Map Dock Right
            CHARMAP.dockSide% = CHARMAP_DOCK_RIGHT
            CFG.CHARMAP_PANEL_DOCK_EDGE$ = "RIGHT"
            CONFIG_save
            SCENE_DIRTY% = TRUE
            GUI_NEEDS_REDRAW% = TRUE
            FRAME_IDLE% = FALSE
        CASE 2053  ' Toggle Char Grid
            CHARMAP_char_grid_toggle
            GUI_NEEDS_REDRAW% = TRUE
        CASE 2054  ' Toggle Snap to Char Grid
            CHARMAP_char_grid_snap_toggle
            GUI_NEEDS_REDRAW% = TRUE
        CASE 2055  ' Toggle Unicode/CP437 mode
            CHARMAP_toggle_unicode_mode
        CASE 2056  ' Unicode charmap next page
            CHARMAP_next_page
        CASE 2057  ' Unicode charmap prev page
            CHARMAP_prev_page
        CASE 436  ' Hide/Show Left Side UI (layers panel + toolbar + edit bar + adv bar if LEFT-docked)
            IF SCRN.layerPanelHiddenByToggleLeft% OR SCRN.editBarHiddenByToggleLeft% OR SCRN.advBarHiddenByToggleLeft% OR SCRN.toolbarHiddenByToggleLeft% THEN
                ' Restore what this command previously hid
                IF SCRN.layerPanelHiddenByToggleLeft% THEN
                    LAYER_PANEL.visible% = TRUE
                    SCRN.layerPanelManuallyHidden% = FALSE
                    SCRN.layerPanelHiddenByToggleLeft% = FALSE
                END IF
                IF SCRN.editBarHiddenByToggleLeft% THEN
                    SCRN.showEditBar% = TRUE
                    SCRN.editBarManuallyHidden% = FALSE
                    SCRN.editBarHiddenByToggleLeft% = FALSE
                END IF
                IF SCRN.advBarHiddenByToggleLeft% THEN
                    SCRN.showAdvBar% = TRUE
                    SCRN.advBarManuallyHidden% = FALSE
                    SCRN.advBarHiddenByToggleLeft% = FALSE
                END IF
                IF SCRN.toolbarHiddenByToggleLeft% THEN
                    SCRN.showToolbar% = TRUE
                    SCRN.toolbarManuallyHidden% = FALSE
                    SCRN.toolbarHiddenByToggleLeft% = FALSE
                END IF
            ELSE
                ' Hide everything on the left side
                IF UCASE$(_TRIM$(CFG.LAYERS_PANEL_DOCK_EDGE)) = "LEFT" AND LAYER_PANEL.visible% THEN
                    LAYER_PANEL.visible% = FALSE
                    SCRN.layerPanelManuallyHidden% = TRUE
                    SCRN.layerPanelHiddenByToggleLeft% = TRUE
                END IF
                IF SCRN.showEditBar% AND EDIT_BAR.dockSide% = EDITBAR_DOCK_LEFT THEN
                    SCRN.showEditBar% = FALSE
                    SCRN.editBarManuallyHidden% = TRUE
                    SCRN.editBarHiddenByToggleLeft% = TRUE
                END IF
                IF SCRN.showAdvBar% AND ADV_BAR.dockSide% = ADVBAR_DOCK_LEFT THEN
                    SCRN.showAdvBar% = FALSE
                    SCRN.advBarManuallyHidden% = TRUE
                    SCRN.advBarHiddenByToggleLeft% = TRUE
                END IF
                IF UCASE$(_TRIM$(CFG.TOOLBOX_DOCK_EDGE)) = "LEFT" AND SCRN.showToolbar% THEN
                    SCRN.showToolbar% = FALSE
                    SCRN.toolbarManuallyHidden% = TRUE
                    SCRN.toolbarHiddenByToggleLeft% = TRUE
                END IF
            END IF
            GUI_NEEDS_REDRAW% = TRUE
            SCENE_DIRTY% = TRUE
            FRAME_IDLE% = FALSE
        CASE 437  ' Hide/Show Right Side UI (toolbar + edit bar + adv bar + layers if RIGHT-docked)
            IF SCRN.toolbarHiddenByToggleRight% OR SCRN.editBarHiddenByToggleRight% OR SCRN.advBarHiddenByToggleRight% OR SCRN.layerPanelHiddenByToggleRight% THEN
                ' Restore
                IF SCRN.toolbarHiddenByToggleRight% THEN
                    SCRN.showToolbar% = TRUE
                    SCRN.toolbarManuallyHidden% = FALSE
                    SCRN.toolbarHiddenByToggleRight% = FALSE
                END IF
                IF SCRN.editBarHiddenByToggleRight% THEN
                    SCRN.showEditBar% = TRUE
                    SCRN.editBarManuallyHidden% = FALSE
                    SCRN.editBarHiddenByToggleRight% = FALSE
                END IF
                IF SCRN.advBarHiddenByToggleRight% THEN
                    SCRN.showAdvBar% = TRUE
                    SCRN.advBarManuallyHidden% = FALSE
                    SCRN.advBarHiddenByToggleRight% = FALSE
                END IF
                IF SCRN.layerPanelHiddenByToggleRight% THEN
                    LAYER_PANEL.visible% = TRUE
                    SCRN.layerPanelManuallyHidden% = FALSE
                    SCRN.layerPanelHiddenByToggleRight% = FALSE
                END IF
            ELSE
                ' Hide everything on the right side
                IF UCASE$(_TRIM$(CFG.TOOLBOX_DOCK_EDGE)) = "RIGHT" AND SCRN.showToolbar% THEN
                    SCRN.showToolbar% = FALSE
                    SCRN.toolbarManuallyHidden% = TRUE
                    SCRN.toolbarHiddenByToggleRight% = TRUE
                END IF
                IF SCRN.showEditBar% AND EDIT_BAR.dockSide% = EDITBAR_DOCK_RIGHT THEN
                    SCRN.showEditBar% = FALSE
                    SCRN.editBarManuallyHidden% = TRUE
                    SCRN.editBarHiddenByToggleRight% = TRUE
                END IF
                IF SCRN.showAdvBar% AND ADV_BAR.dockSide% = ADVBAR_DOCK_RIGHT THEN
                    SCRN.showAdvBar% = FALSE
                    SCRN.advBarManuallyHidden% = TRUE
                    SCRN.advBarHiddenByToggleRight% = TRUE
                END IF
                IF UCASE$(_TRIM$(CFG.LAYERS_PANEL_DOCK_EDGE)) = "RIGHT" AND LAYER_PANEL.visible% THEN
                    LAYER_PANEL.visible% = FALSE
                    SCRN.layerPanelManuallyHidden% = TRUE
                    SCRN.layerPanelHiddenByToggleRight% = TRUE
                END IF
            END IF
            GUI_NEEDS_REDRAW% = TRUE
            SCENE_DIRTY% = TRUE
            FRAME_IDLE% = FALSE
        CASE 438  ' Hide/Show Menu Bar (top)
            IF SCRN.menubarHiddenByToggleTop% THEN
                MENU_BAR.visible% = TRUE
                SCRN.showMenubar% = TRUE
                SCRN.menubarManuallyHidden% = FALSE
                SCRN.menubarHiddenByToggleTop% = FALSE
            ELSE
                IF SCRN.showMenubar% THEN
                    MENU_BAR.visible% = FALSE
                    SCRN.showMenubar% = FALSE
                    SCRN.menubarManuallyHidden% = TRUE
                    SCRN.menubarHiddenByToggleTop% = TRUE
                    MENUBAR_close_all
                END IF
            END IF
            INVALIDATE_scene
            FRAME_IDLE% = FALSE
        CASE 439  ' Hide/Show Status Bar + Palette Strip (bottom)
            IF SCRN.statusHiddenByToggleBottom% THEN
                SCRN.showStatus% = TRUE
                SCRN.statusManuallyHidden% = FALSE
                SCRN.statusHiddenByToggleBottom% = FALSE
            ELSE
                IF SCRN.showStatus% THEN
                    SCRN.showStatus% = FALSE
                    SCRN.statusManuallyHidden% = TRUE
                    SCRN.statusHiddenByToggleBottom% = TRUE
                END IF
            END IF
            INVALIDATE_scene
            FRAME_IDLE% = FALSE
        CASE 440  ' Toggle Pattern Tile Mode (3x3 tiled canvas view)
            IF SCREEN_pattern_tile_allowed% THEN
                SCRN.patternTileMode% = NOT SCRN.patternTileMode%
                INVALIDATE_scene
            END IF
        CASE 441  ' Toggle Canvas Border visibility
            SCRN.showCanvasBorder% = NOT SCRN.showCanvasBorder%
            SCENE_DIRTY% = TRUE
            FRAME_IDLE% = FALSE
        CASE 442  ' Layout submenu parent (no-op, handled by menu toggle)
            ' Intentionally empty â€” submenu opens via MENUBAR click intercept
        CASE 443  ' Toolbox Dock Left
            IF UCASE$(_TRIM$(CFG.TOOLBOX_DOCK_EDGE)) <> "LEFT" THEN
                CFG.TOOLBOX_DOCK_EDGE = "LEFT"
                SOUND_play SND_DRAG_DROP
                CONFIG_save
                GUI_NEEDS_REDRAW% = TRUE
                SCENE_DIRTY% = TRUE
                FRAME_IDLE% = FALSE
            END IF
        CASE 444  ' Toolbox Dock Right
            IF UCASE$(_TRIM$(CFG.TOOLBOX_DOCK_EDGE)) <> "RIGHT" THEN
                CFG.TOOLBOX_DOCK_EDGE = "RIGHT"
                SOUND_play SND_DRAG_DROP
                CONFIG_save
                GUI_NEEDS_REDRAW% = TRUE
                SCENE_DIRTY% = TRUE
                FRAME_IDLE% = FALSE
            END IF
        CASE 445  ' Layer Panel Dock Left
            IF UCASE$(_TRIM$(CFG.LAYERS_PANEL_DOCK_EDGE)) <> "LEFT" THEN
                CFG.LAYERS_PANEL_DOCK_EDGE = "LEFT"
                SOUND_play SND_DRAG_DROP
                CONFIG_save
                GUI_NEEDS_REDRAW% = TRUE
                SCENE_DIRTY% = TRUE
                FRAME_IDLE% = FALSE
            END IF
        CASE 446  ' Layer Panel Dock Right
            IF UCASE$(_TRIM$(CFG.LAYERS_PANEL_DOCK_EDGE)) <> "RIGHT" THEN
                CFG.LAYERS_PANEL_DOCK_EDGE = "RIGHT"
                SOUND_play SND_DRAG_DROP
                CONFIG_save
                GUI_NEEDS_REDRAW% = TRUE
                SCENE_DIRTY% = TRUE
                FRAME_IDLE% = FALSE
            END IF
        CASE 447  ' Edit Bar Dock Left
            IF EDIT_BAR.dockSide% <> EDITBAR_DOCK_LEFT THEN
                EDIT_BAR.dockSide% = EDITBAR_DOCK_LEFT
                CFG.EDIT_BAR_DOCK_POSITION$ = "LEFT"
                SOUND_play SND_DRAG_DROP
                CONFIG_save
                GUI_NEEDS_REDRAW% = TRUE
                SCENE_DIRTY% = TRUE
                FRAME_IDLE% = FALSE
            END IF
        CASE 448  ' Edit Bar Dock Right
            IF EDIT_BAR.dockSide% <> EDITBAR_DOCK_RIGHT THEN
                EDIT_BAR.dockSide% = EDITBAR_DOCK_RIGHT
                CFG.EDIT_BAR_DOCK_POSITION$ = "RIGHT"
                SOUND_play SND_DRAG_DROP
                CONFIG_save
                GUI_NEEDS_REDRAW% = TRUE
                SCENE_DIRTY% = TRUE
                FRAME_IDLE% = FALSE
            END IF
        CASE 404  ' Toggle Layer Panel
            LAYER_PANEL.visible% = NOT LAYER_PANEL.visible%
            SCRN.layerPanelManuallyHidden% = NOT LAYER_PANEL.visible%
            GUI_NEEDS_REDRAW% = TRUE
            SCENE_DIRTY% = TRUE
        CASE 405  ' Reset Zoom
            SCRN.zoom! = 1.0
            SCRN.offsetX% = 0
            SCRN.offsetY% = 0
            GUI_NEEDS_REDRAW% = TRUE
            SCENE_DIRTY% = TRUE
        CASE 406  ' Zoom In
            IF SCRN.zoom! < SCRN.zoomMax! THEN
                IF SCRN.zoom! < 0.5 THEN
                    SCRN.zoom! = 0.5
                ELSEIF SCRN.zoom! < 1.0 THEN
                    SCRN.zoom! = 1.0
                ELSE
                    SCRN.zoom! = INT(SCRN.zoom!) + 1.0
                    IF SCRN.zoom! > SCRN.zoomMax! THEN SCRN.zoom! = SCRN.zoomMax!
                END IF
                GUI_NEEDS_REDRAW% = TRUE
                SCENE_DIRTY% = TRUE
            END IF
        CASE 407  ' Zoom Out
            IF SCRN.zoom! > 0.25 THEN
                IF SCRN.zoom! > 1.0 THEN
                    SCRN.zoom! = INT(SCRN.zoom!) - 1.0
                    IF SCRN.zoom! < 1.0 THEN SCRN.zoom! = 1.0
                ELSEIF SCRN.zoom! > 0.5 THEN
                    SCRN.zoom! = 0.5
                ELSE
                    SCRN.zoom! = 0.25
                END IF
                GUI_NEEDS_REDRAW% = TRUE
                SCENE_DIRTY% = TRUE
            END IF
        CASE 408  ' Display Scale Up
            SCREEN_set_display_scale SCRN.displayScale% + 1
        CASE 409  ' Display Scale Down
            SCREEN_set_display_scale SCRN.displayScale% - 1
        CASE 416  ' Display Scale Reset
            DIM resetToScale AS INTEGER
            resetToScale% = CFG.DISPLAY_SCALE%
            IF resetToScale% < 1 THEN resetToScale% = 1
            SCREEN_set_display_scale resetToScale%

        CASE 417  ' Toggle Sounds
            CFG.SOUNDS_ENABLED% = NOT CFG.SOUNDS_ENABLED%
            CONFIG_save
            GUI_NEEDS_REDRAW% = TRUE

        CASE 420  ' Toggle Music
            CFG.MUSIC_ENABLED% = NOT CFG.MUSIC_ENABLED%
            IF CFG.MUSIC_ENABLED% THEN MUSIC_play_random ELSE MUSIC_stop
            CONFIG_save
            GUI_NEEDS_REDRAW% = TRUE

        CASE 421  ' Toggle Sound FX Mute
            CFG.SOUNDS_MUTED% = NOT CFG.SOUNDS_MUTED%
            SOUND_apply_volume
            CONFIG_save
            GUI_NEEDS_REDRAW% = TRUE

        CASE 422  ' Music Volume Up
            CFG.MUSIC_VOLUME% = CFG.MUSIC_VOLUME% + 10
            IF CFG.MUSIC_VOLUME% > 100 THEN CFG.MUSIC_VOLUME% = 100
            SOUND_apply_volume
            CONFIG_save
            GUI_NEEDS_REDRAW% = TRUE

        CASE 423  ' Music Volume Down
            CFG.MUSIC_VOLUME% = CFG.MUSIC_VOLUME% - 10
            IF CFG.MUSIC_VOLUME% < 0 THEN CFG.MUSIC_VOLUME% = 0
            SOUND_apply_volume
            CONFIG_save
            GUI_NEEDS_REDRAW% = TRUE

        CASE 424  ' Toggle Music Mute
            CFG.MUSIC_MUTED% = NOT CFG.MUSIC_MUTED%
            SOUND_apply_volume
            CONFIG_save
            GUI_NEEDS_REDRAW% = TRUE

        CASE 425  ' Explore Music Folder
            DIM musicExpPath AS STRING
            musicExpPath$ = _CWD$ + "/ASSETS/THEMES/" + CFG.THEME$ + "/MUSIC"
            $IF WIN THEN
                SHELL _DONTWAIT "explorer /e " + CHR$(34) + musicExpPath$ + CHR$(34)
            $ELSEIF MAC THEN
                SHELL _DONTWAIT "open " + CHR$(34) + musicExpPath$ + CHR$(34)
            $ELSE
                SHELL _DONTWAIT "open " + CHR$(34) + musicExpPath$ + CHR$(34)
            $END IF

        CASE 418  ' Sound FX Volume Up
            CFG.SOUNDS_VOLUME% = CFG.SOUNDS_VOLUME% + 10
            IF CFG.SOUNDS_VOLUME% > 100 THEN CFG.SOUNDS_VOLUME% = 100
            SOUND_apply_volume
            CONFIG_save
            GUI_NEEDS_REDRAW% = TRUE

        CASE 419  ' Sound FX Volume Down
            CFG.SOUNDS_VOLUME% = CFG.SOUNDS_VOLUME% - 10
            IF CFG.SOUNDS_VOLUME% < 0 THEN CFG.SOUNDS_VOLUME% = 0
            SOUND_apply_volume
            CONFIG_save
            GUI_NEEDS_REDRAW% = TRUE

        CASE 427  ' Next Track
            MUSIC_next_track
            SOUND_play SND_MENU_SELECT
            GUI_NEEDS_REDRAW% = TRUE

        CASE 428  ' Prev Track
            MUSIC_prev_track
            SOUND_play SND_MENU_SELECT
            GUI_NEEDS_REDRAW% = TRUE

        CASE 429  ' Random Track (.MOD)
            MUSIC_play_random_ext ".mod"
            GUI_NEEDS_REDRAW% = TRUE

        CASE 430  ' Random Track (.IT)
            MUSIC_play_random_ext ".it"
            GUI_NEEDS_REDRAW% = TRUE

        CASE 431  ' Random Track (.XM)
            MUSIC_play_random_ext ".xm"
            GUI_NEEDS_REDRAW% = TRUE

        CASE 432  ' Random Track (.RAD)
            MUSIC_play_random_ext ".rad"
            GUI_NEEDS_REDRAW% = TRUE

        CASE 433  ' Random Track (any format)
            MUSIC_play_random
            GUI_NEEDS_REDRAW% = TRUE

        ' ========== COLOR / OPACITY ==========
        CASE 501: PAINT_OPACITY% = 10:  GUI_NEEDS_REDRAW% = TRUE: SCENE_DIRTY% = TRUE
        CASE 502: PAINT_OPACITY% = 20:  GUI_NEEDS_REDRAW% = TRUE: SCENE_DIRTY% = TRUE
        CASE 503: PAINT_OPACITY% = 30:  GUI_NEEDS_REDRAW% = TRUE: SCENE_DIRTY% = TRUE
        CASE 504: PAINT_OPACITY% = 40:  GUI_NEEDS_REDRAW% = TRUE: SCENE_DIRTY% = TRUE
        CASE 505: PAINT_OPACITY% = 50:  GUI_NEEDS_REDRAW% = TRUE: SCENE_DIRTY% = TRUE
        CASE 506: PAINT_OPACITY% = 60:  GUI_NEEDS_REDRAW% = TRUE: SCENE_DIRTY% = TRUE
        CASE 507: PAINT_OPACITY% = 70:  GUI_NEEDS_REDRAW% = TRUE: SCENE_DIRTY% = TRUE
        CASE 508: PAINT_OPACITY% = 80:  GUI_NEEDS_REDRAW% = TRUE: SCENE_DIRTY% = TRUE
        CASE 509: PAINT_OPACITY% = 90:  GUI_NEEDS_REDRAW% = TRUE: SCENE_DIRTY% = TRUE
        CASE 510: PAINT_OPACITY% = 100: GUI_NEEDS_REDRAW% = TRUE: SCENE_DIRTY% = TRUE
        CASE 518  ' Default Colors (White/Black)
            PAL_FG_IS_TRANSPARENT% = FALSE
            PAINT_COLOR~& = _RGB32(255, 255, 255)
            PAL_FG_IDX% = PAL_find_index%(_RGB32(255, 255, 255))
            IF PAL_FG_IDX% < 0 THEN PAL_FG_IDX% = 0
            PAL_BG_IS_TRANSPARENT% = FALSE
            PAINT_BG_COLOR~& = _RGB32(0, 0, 0)
            PAL_BG_IDX% = PAL_find_index%(_RGB32(0, 0, 0))
            IF PAL_BG_IDX% < 0 THEN PAL_BG_IDX% = 0
            GUI_NEEDS_REDRAW% = TRUE
        CASE 519  ' Set BG Transparent
            PAL_BG_IS_TRANSPARENT% = TRUE
            PAINT_BG_COLOR~& = _RGBA32(0, 0, 0, 0)
            GUI_NEEDS_REDRAW% = TRUE

        ' ========== BRUSH ==========
        CASE 601: BRUSH_SIZE_decrease
        CASE 602: BRUSH_SIZE_increase
        CASE 603: DRAWER_set_mode DRAWER_MODE_BRUSH
        CASE 604: DRAWER_set_mode DRAWER_MODE_GRADIENT
        CASE 605: DRAWER_set_mode DRAWER_MODE_PATTERN
        CASE 606: BRUSH_SIZE_set_preset 4
        CASE 607: BRUSH_SIZE_toggle_preview: GUI_NEEDS_REDRAW% = TRUE: FRAME_IDLE% = FALSE
        CASE 608: BRUSH_SIZE_toggle_shape: GUI_NEEDS_REDRAW% = TRUE: FRAME_IDLE% = FALSE
        CASE 609: BRUSH_SIZE_toggle_pixel_perfect: GUI_NEEDS_REDRAW% = TRUE: FRAME_IDLE% = FALSE
        
        ' ========== LAYER ==========
        CASE 701  ' New Layer
            SOUND_play SND_NEW_LAYER
            DIM newLayerIdx AS INTEGER
            newLayerIdx% = LAYERS_new%
        CASE 702  ' Delete Layer â€” if multi-select, delete all selected (stop at 1 remaining)
            SOUND_play SND_LAYER_OP
            IF MULTI_SELECT_has_any% THEN
                DIM delLayers(1 TO MAX_LAYERS) AS INTEGER
                DIM delCount AS INTEGER
                DIM delZ AS INTEGER, delI AS INTEGER
                ' Collect selected layer indices sorted by zIndex descending (delete from top down)
                FOR delZ% = LAYER_COUNT% TO 1 STEP -1
                    FOR delI% = 1 TO MAX_LAYERS
                        IF LAYERS(delI%).imgHandle& <> 0 AND LAYERS(delI%).zIndex% = delZ% AND MULTI_SELECT_LAYERS(delI%) THEN
                            delCount% = delCount% + 1
                            delLayers(delCount%) = delI%
                        END IF
                    NEXT delI%
                NEXT delZ%
                FOR delI% = 1 TO delCount%
                    IF LAYER_COUNT% > 1 THEN LAYERS_delete delLayers(delI%)
                NEXT delI%
            ELSE
                ' If current layer is a group, use LAYERS_delete_group which shows
                ' a Yes/No/Cancel dialog (delete all / ungroup / cancel)
                IF CURRENT_LAYER% >= 1 AND CURRENT_LAYER% <= MAX_LAYERS THEN
                    IF LAYERS(CURRENT_LAYER%).layerType% = LAYER_TYPE_GROUP THEN
                        LAYERS_delete_group CURRENT_LAYER%
                    ELSE
                        LAYERS_delete CURRENT_LAYER%
                    END IF
                ELSE
                    LAYERS_delete CURRENT_LAYER%
                END IF
            END IF
        CASE 703: SOUND_play SND_LAYER_OP: LAYERS_move_up CURRENT_LAYER%
        CASE 704: SOUND_play SND_LAYER_OP: LAYERS_move_down CURRENT_LAYER%
        CASE 705: SOUND_play SND_LAYER_OP: LAYERS_merge_down CURRENT_LAYER%
        CASE 706: SOUND_play SND_LAYER_OP: LAYERS_merge_visible
        CASE 707  ' Duplicate Layer â€” if multi-select, duplicate all selected
            SOUND_play SND_LAYER_OP
            IF MULTI_SELECT_has_any% THEN
                DIM dupI AS INTEGER
                FOR dupI% = 1 TO MAX_LAYERS
                    IF MULTI_SELECT_LAYERS(dupI%) AND LAYERS(dupI%).imgHandle& <> 0 THEN
                        LAYERS_duplicate dupI%
                    END IF
                NEXT dupI%
            ELSE
                LAYERS_duplicate CURRENT_LAYER%
            END IF
        
        CASE 711  ' Merge Selected Layers
            SOUND_play SND_LAYER_OP
            IF MULTI_SELECT_COUNT% < 2 THEN EXIT SELECT
            ' Build sorted list of selected layers by zIndex (ascending = bottom first)
            DIM ms711_sortedSel(1 TO MAX_LAYERS) AS INTEGER
            DIM ms711_sortCount AS INTEGER
            DIM ms711_zi AS INTEGER, ms711_si AS INTEGER
            ms711_sortCount% = 0
            FOR ms711_zi% = 1 TO LAYER_COUNT%
                FOR ms711_si% = 1 TO MAX_LAYERS
                    IF MULTI_SELECT_LAYERS(ms711_si%) AND LAYERS(ms711_si%).imgHandle& <> 0 AND LAYERS(ms711_si%).zIndex% = ms711_zi% THEN
                        ms711_sortCount% = ms711_sortCount% + 1
                        ms711_sortedSel%(ms711_sortCount%) = ms711_si%
                        EXIT FOR
                    END IF
                NEXT ms711_si%
            NEXT ms711_zi%
            IF ms711_sortCount% < 2 THEN EXIT SELECT
            ' Record in unified history BEFORE structural changes
            HISTORY_record_layer_merge_visible ms711_sortedSel%(), ms711_sortCount%, 0
            HISTORY_IN_PROGRESS% = TRUE
            ' Create new blank layer for merged result
            DIM ms711_newIdx AS INTEGER
            ms711_newIdx% = LAYERS_new%
            IF ms711_newIdx% = 0 THEN
                HISTORY_IN_PROGRESS% = FALSE
                EXIT SELECT
            END IF
            ' Update history record with the actual slot now that we have it
            HISTORY_RECORDS(HISTORY.current%).slotIndex% = ms711_newIdx%
            HISTORY_merge_update_result_id LAYERS(ms711_newIdx%).historyId&
            LAYERS(ms711_newIdx%).name = "Merged"
            ' Composite selected layers bottom-to-top onto the new blank layer
            DIM ms711_oldDest AS LONG
            DIM ms711_tempImg AS LONG
            ms711_oldDest& = _DEST
            _DEST LAYERS(ms711_newIdx%).imgHandle&
            CLS , _RGBA32(0, 0, 0, 0)
            _BLEND LAYERS(ms711_newIdx%).imgHandle&
            FOR ms711_si% = 1 TO ms711_sortCount%
                DIM ms711_srcIdx AS INTEGER
                ms711_srcIdx% = ms711_sortedSel%(ms711_si%)
                IF LAYERS(ms711_srcIdx%).blendMode% <> BLEND_NORMAL THEN
                    _DEST ms711_oldDest&
                    LAYER_blend_composite LAYERS(ms711_newIdx%).imgHandle&, LAYERS(ms711_srcIdx%).imgHandle&, LAYERS(ms711_srcIdx%).blendMode%, LAYERS(ms711_srcIdx%).opacity%
                    _DEST LAYERS(ms711_newIdx%).imgHandle&
                ELSEIF LAYERS(ms711_srcIdx%).opacity% < 255 THEN
                    ms711_tempImg& = _COPYIMAGE(LAYERS(ms711_srcIdx%).imgHandle&, 32)
                    DIM ms711_mem AS _MEM
                    DIM ms711_off AS _OFFSET
                    DIM ms711_pix AS _UNSIGNED LONG
                    DIM ms711_a AS _UNSIGNED _BYTE
                    DIM ms711_na AS INTEGER
                    ms711_mem = _MEMIMAGE(ms711_tempImg&)
                    FOR ms711_off = ms711_mem.OFFSET TO ms711_mem.OFFSET + ms711_mem.SIZE - 4 STEP 4
                        _MEMGET ms711_mem, ms711_off, ms711_pix~&
                        ms711_a~%% = _ALPHA32(ms711_pix~&)
                        IF ms711_a~%% > 0 THEN
                            ms711_na% = (ms711_a~%% * LAYERS(ms711_srcIdx%).opacity%) \ 255
                            _MEMPUT ms711_mem, ms711_off + 3, ms711_na% AS _UNSIGNED _BYTE
                        END IF
                    NEXT ms711_off
                    _MEMFREE ms711_mem
                    _PUTIMAGE , ms711_tempImg&
                    IF ms711_tempImg& < -1 THEN _FREEIMAGE ms711_tempImg&
                ELSE
                    _PUTIMAGE , LAYERS(ms711_srcIdx%).imgHandle&
                END IF
            NEXT ms711_si%
            _DEST ms711_oldDest&
            LAYERS(ms711_newIdx%).contentDirty% = TRUE
            ' Delete the source selected layers
            FOR ms711_si% = 1 TO ms711_sortCount%
                IF ms711_sortedSel%(ms711_si%) <> ms711_newIdx% THEN
                    LAYERS_delete ms711_sortedSel%(ms711_si%)
                END IF
            NEXT ms711_si%
            HISTORY_IN_PROGRESS% = FALSE
            MULTI_SELECT_clear
            LAYERS_select ms711_newIdx%
            BLEND_invalidate_cache
            INVALIDATE_scene

        ' ========== TEXT LAYERS ==========
        CASE 712  ' New Text Layer
            SOUND_play SND_LAYER_OP
            DIM ntlX AS INTEGER, ntlY AS INTEGER
            ntlX% = SCRN.canvasW& \ 2
            ntlY% = SCRN.canvasH& \ 2
            CURRENT_TOOL% = TOOL_TEXT
            TEXT_start ntlX%, ntlY%
            GUI_NEEDS_REDRAW% = TRUE
            FRAME_IDLE% = FALSE

        CASE 713  ' Rasterize Text Layer
            IF CURRENT_LAYER% >= 1 AND LAYERS(CURRENT_LAYER%).layerType% = LAYER_TYPE_TEXT THEN
                DIM rast713 AS INTEGER
                POINTER_hide_for_dialog
                rast713% = DRAW_message_box%("Rasterize", "Convert text layer to pixels?", MB_BTN_YES_NO, MB_ICON_QUESTION)
                POINTER_show_after_dialog
                MOUSE_cleanup_after_dialog FALSE
                IF rast713% = MB_RESULT_1 THEN
                    ' Commit any active editing first
                    IF TEXT.ACTIVE AND TEXT.editingTextLayer% = CURRENT_LAYER% THEN TEXT_commit
                    DIM rTdIdx AS INTEGER
                    rTdIdx% = LAYERS(CURRENT_LAYER%).textDataIdx%
                    IF rTdIdx% >= 1 THEN
                        ' Save before-image and text data BEFORE rasterize
                        DIM r713BeforeImg AS LONG
                        r713BeforeImg& = _COPYIMAGE(LAYERS(CURRENT_LAYER%).imgHandle&, 32)
                        DIM r713TextData AS STRING
                        r713TextData$ = TEXT_LAYER_serialize$(rTdIdx%)
                        ' Rasterize the text layer
                        TEXT_LAYER_rasterize CURRENT_LAYER%
                        ' Record history (after rasterize so after-image captures rasterized pixels)
                        HISTORY_record_rasterize LAYERS(CURRENT_LAYER%).historyId&, CURRENT_LAYER%, r713BeforeImg&, r713TextData$, "Rasterize Text"
                    END IF
                    SOUND_play SND_LAYER_OP
                    LAYERS(CURRENT_LAYER%).contentDirty% = TRUE
                    INVALIDATE_scene
                END IF
            END IF

        CASE 714  ' Rasterize All Text Layers
            DIM rast714 AS INTEGER
            POINTER_hide_for_dialog
            rast714% = DRAW_message_box%("Rasterize All", "Convert all text layers to pixels?", MB_BTN_YES_NO, MB_ICON_QUESTION)
            POINTER_show_after_dialog
            MOUSE_cleanup_after_dialog FALSE
            IF rast714% = MB_RESULT_1 THEN
                ' Commit active text editing
                IF TEXT.ACTIVE THEN TEXT_commit
                HISTORY_begin_group
                DIM rl714 AS INTEGER
                FOR rl714% = 1 TO LAYER_COUNT%
                    IF LAYERS(rl714%).layerType% = LAYER_TYPE_TEXT AND LAYERS(rl714%).textDataIdx% >= 1 THEN
                        ' Save before-image and text data BEFORE rasterize
                        DIM r714BeforeImg AS LONG
                        r714BeforeImg& = _COPYIMAGE(LAYERS(rl714%).imgHandle&, 32)
                        DIM r714TextData AS STRING
                        r714TextData$ = TEXT_LAYER_serialize$(LAYERS(rl714%).textDataIdx%)
                        TEXT_LAYER_rasterize rl714%
                        HISTORY_record_rasterize LAYERS(rl714%).historyId&, rl714%, r714BeforeImg&, r714TextData$, "Rasterize All"
                        LAYERS(rl714%).contentDirty% = TRUE
                    END IF
                NEXT rl714%
                HISTORY_end_group
                SOUND_play SND_LAYER_OP
                INVALIDATE_scene
            END IF
        
        ' ========== LAYER GROUPS ==========
        CASE 720  ' New Group
            SOUND_play SND_LAYER_OP
            DIM ng720 AS INTEGER
            ng720% = LAYERS_new_group%
            IF ng720% > 0 THEN
                GUI_NEEDS_REDRAW% = TRUE
                FRAME_IDLE% = FALSE
            END IF

        CASE 721  ' Group from Selection
            IF MULTI_SELECT_COUNT% >= 1 THEN
                SOUND_play SND_LAYER_OP
                DIM gfs721 AS INTEGER
                gfs721% = LAYERS_group_from_selection%
                IF gfs721% > 0 THEN
                    GUI_NEEDS_REDRAW% = TRUE
                    FRAME_IDLE% = FALSE
                END IF
            END IF

        CASE 722  ' Ungroup
            IF CURRENT_LAYER% >= 1 AND CURRENT_LAYER% <= MAX_LAYERS THEN
                IF LAYERS(CURRENT_LAYER%).layerType% = LAYER_TYPE_GROUP THEN
                    SOUND_play SND_LAYER_OP
                    LAYERS_ungroup CURRENT_LAYER%
                    GUI_NEEDS_REDRAW% = TRUE
                    FRAME_IDLE% = FALSE
                END IF
            END IF

        CASE 723  ' Merge Group
            IF CURRENT_LAYER% >= 1 AND CURRENT_LAYER% <= MAX_LAYERS THEN
                IF LAYERS(CURRENT_LAYER%).layerType% = LAYER_TYPE_GROUP THEN
                    SOUND_play SND_LAYER_OP
                    LAYERS_merge_group CURRENT_LAYER%
                    GUI_NEEDS_REDRAW% = TRUE
                    FRAME_IDLE% = FALSE
                END IF
            END IF

        CASE 724  ' Toggle Group Collapse
            IF CURRENT_LAYER% >= 1 AND CURRENT_LAYER% <= MAX_LAYERS THEN
                IF LAYERS(CURRENT_LAYER%).layerType% = LAYER_TYPE_GROUP THEN
                    LAYERS(CURRENT_LAYER%).collapsed% = NOT LAYERS(CURRENT_LAYER%).collapsed%
                    GUI_NEEDS_REDRAW% = TRUE
                    FRAME_IDLE% = FALSE
                END IF
            END IF

        CASE 725  ' Select All in Group
            IF CURRENT_LAYER% >= 1 AND CURRENT_LAYER% <= MAX_LAYERS THEN
                IF LAYERS(CURRENT_LAYER%).layerType% = LAYER_TYPE_GROUP THEN
                    LAYERS_select_group CURRENT_LAYER%
                ELSEIF LAYERS(CURRENT_LAYER%).parentGroupIdx% > 0 THEN
                    ' If current layer is a group child, select whole group
                    LAYERS_select_group LAYERS(CURRENT_LAYER%).parentGroupIdx%
                END IF
            END IF

        CASE 726  ' Rename Layer
            IF CURRENT_LAYER% >= 1 AND CURRENT_LAYER% <= MAX_LAYERS THEN
                IF LAYERS(CURRENT_LAYER%).imgHandle& <> 0 THEN
                    LAYERS_rename CURRENT_LAYER%
                END IF
            END IF

        CASE 727  ' Selection from Group
            IF CURRENT_LAYER% >= 1 AND CURRENT_LAYER% <= MAX_LAYERS THEN
                DIM sel727_grp AS INTEGER
                sel727_grp% = 0
                IF LAYERS(CURRENT_LAYER%).layerType% = LAYER_TYPE_GROUP THEN
                    sel727_grp% = CURRENT_LAYER%
                ELSEIF LAYERS(CURRENT_LAYER%).parentGroupIdx% > 0 THEN
                    sel727_grp% = LAYERS(CURRENT_LAYER%).parentGroupIdx%
                END IF
                IF sel727_grp% > 0 THEN
                    ' Select all in group then do union select
                    LAYERS_select_group sel727_grp%
                    ' Remove all group headers from MULTI_SELECT â€” their 1x1 sentinel
                    ' images corrupt the pixel-based bounding box in union select (1414).
                    DIM sel727_i AS INTEGER
                    DIM sel727_topChild AS INTEGER, sel727_topZ AS INTEGER
                    sel727_topChild% = 0
                    sel727_topZ% = 0
                    FOR sel727_i% = 1 TO MAX_LAYERS
                        IF MULTI_SELECT_LAYERS(sel727_i%) THEN
                            IF LAYERS(sel727_i%).layerType% = LAYER_TYPE_GROUP THEN
                                MULTI_SELECT_LAYERS(sel727_i%) = FALSE
                                MULTI_SELECT_COUNT% = MULTI_SELECT_COUNT% - 1
                            ELSEIF NOT LAYERS(sel727_i%).visible% THEN
                                ' Exclude directly hidden layers
                                MULTI_SELECT_LAYERS(sel727_i%) = FALSE
                                MULTI_SELECT_COUNT% = MULTI_SELECT_COUNT% - 1
                            ELSE
                                ' Also exclude if any ancestor group is hidden
                                DIM sel727_anc AS INTEGER
                                DIM sel727_hidden AS INTEGER
                                sel727_hidden% = FALSE
                                sel727_anc% = LAYERS(sel727_i%).parentGroupIdx%
                                DO WHILE sel727_anc% > 0 AND sel727_anc% <= MAX_LAYERS
                                    IF LAYERS(sel727_anc%).imgHandle& = 0 THEN EXIT DO
                                    IF NOT LAYERS(sel727_anc%).visible% THEN
                                        sel727_hidden% = TRUE
                                        EXIT DO
                                    END IF
                                    sel727_anc% = LAYERS(sel727_anc%).parentGroupIdx%
                                LOOP
                                IF sel727_hidden% THEN
                                    MULTI_SELECT_LAYERS(sel727_i%) = FALSE
                                    MULTI_SELECT_COUNT% = MULTI_SELECT_COUNT% - 1
                                ELSE
                                    IF LAYERS(sel727_i%).zIndex% > sel727_topZ% THEN
                                        sel727_topZ% = LAYERS(sel727_i%).zIndex%
                                        sel727_topChild% = sel727_i%
                                    END IF
                                END IF
                            END IF
                        END IF
                    NEXT sel727_i%
                    ' Switch CURRENT_LAYER from group header to a real image layer
                    IF sel727_topChild% > 0 THEN
                        CURRENT_LAYER% = sel727_topChild%
                    END IF
                    IF MULTI_SELECT_COUNT% >= 2 THEN
                        CMD_execute_action 1414
                    ELSEIF MULTI_SELECT_COUNT% = 1 THEN
                        LAYER_select_non_transparent CURRENT_LAYER%
                    END IF
                END IF
            END IF

        CASE 728  ' Selection from Layer
            IF CURRENT_LAYER% >= 1 AND CURRENT_LAYER% <= MAX_LAYERS THEN
                IF LAYERS(CURRENT_LAYER%).imgHandle& <> 0 THEN
                    SOUND_play SND_SELECTION
                    LAYER_select_non_transparent CURRENT_LAYER%
                END IF
            END IF

        ' ========== SYMBOL LAYERS ==========
        CASE 730  ' Convert to Symbol Parent
            IF CURRENT_LAYER% >= 1 THEN
                IF CURRENT_LAYER% <= MAX_LAYERS THEN
                    IF LAYERS(CURRENT_LAYER%).layerType% = LAYER_TYPE_IMAGE THEN
                        SYMBOL_create_parent CURRENT_LAYER%
                        FRAME_IDLE% = FALSE
                    END IF
                END IF
            END IF
        CASE 731  ' New Symbol Layer (empty)
            DIM newSymIdx AS INTEGER
            newSymIdx% = SYMBOL_create_parent_empty%
            IF newSymIdx% > 0 THEN FRAME_IDLE% = FALSE
        CASE 732  ' Create Symbol Instance
            IF CURRENT_LAYER% >= 1 THEN
                IF CURRENT_LAYER% <= MAX_LAYERS THEN
                    IF LAYERS(CURRENT_LAYER%).layerType% = LAYER_TYPE_SYMBOL_PARENT THEN
                        SYMBOL_create_child CURRENT_LAYER%
                        FRAME_IDLE% = FALSE
                    END IF
                END IF
            END IF
        CASE 733  ' Sync Symbols
            SYMBOL_sync_all
            FRAME_IDLE% = FALSE
        CASE 734  ' Rasterize Symbol
            IF CURRENT_LAYER% >= 1 THEN
                IF CURRENT_LAYER% <= MAX_LAYERS THEN
                    IF LAYERS(CURRENT_LAYER%).layerType% = LAYER_TYPE_SYMBOL_PARENT THEN
                        SYMBOL_rasterize_parent CURRENT_LAYER%
                        FRAME_IDLE% = FALSE
                    END IF
                END IF
            END IF
        CASE 735  ' Detach Instance
            IF CURRENT_LAYER% >= 1 THEN
                IF CURRENT_LAYER% <= MAX_LAYERS THEN
                    IF LAYERS(CURRENT_LAYER%).layerType% = LAYER_TYPE_SYMBOL_CHILD THEN
                        SYMBOL_detach_child CURRENT_LAYER%
                        FRAME_IDLE% = FALSE
                    END IF
                END IF
            END IF
        CASE 736  ' Select Parent (from child)
            IF CURRENT_LAYER% >= 1 THEN
                IF CURRENT_LAYER% <= MAX_LAYERS THEN
                    IF LAYERS(CURRENT_LAYER%).layerType% = LAYER_TYPE_SYMBOL_CHILD THEN
                        SYMBOL_select_parent CURRENT_LAYER%
                        FRAME_IDLE% = FALSE
                    END IF
                END IF
            END IF

        ' ========== GRID ==========
        CASE 901: GRID.SHOW% = NOT GRID.SHOW%: GUI_NEEDS_REDRAW% = TRUE: SCENE_DIRTY% = TRUE
        CASE 902: PIXEL_GRID.SHOW% = NOT PIXEL_GRID.SHOW%: GUI_NEEDS_REDRAW% = TRUE: SCENE_DIRTY% = TRUE
        CASE 903: GRID.SNAP% = NOT GRID.SNAP%: GUI_NEEDS_REDRAW% = TRUE
        CASE 904  ' Increase grid size
            IF GRID.gridWidth% < 50 THEN GRID.gridWidth% = GRID.gridWidth% + 1: GRID.gridHeight% = GRID.gridWidth%: GRID_draw: GUI_NEEDS_REDRAW% = TRUE: SCENE_DIRTY% = TRUE: FRAME_IDLE% = FALSE
        CASE 905  ' Decrease grid size
            IF GRID.gridWidth% > 2 THEN GRID.gridWidth% = GRID.gridWidth% - 1: GRID.gridHeight% = GRID.gridWidth%: GRID_draw: GUI_NEEDS_REDRAW% = TRUE: SCENE_DIRTY% = TRUE: FRAME_IDLE% = FALSE
        CASE 906  ' Toggle grid tile mode (ON = center/tiling, OFF = corner/lines)
            IF GRID.ALIGN_MODE% = GRID_ALIGN_CORNER THEN GRID.ALIGN_MODE% = GRID_ALIGN_CENTER ELSE GRID.ALIGN_MODE% = GRID_ALIGN_CORNER
            GUI_NEEDS_REDRAW% = TRUE
        CASE 908  ' Toggle grid cell fill mode
            GRID.CELL_FILL% = NOT GRID.CELL_FILL%: GUI_NEEDS_REDRAW% = TRUE
        CASE 909  ' Toggle fill adjustment mode
            FILL_ADJ_toggle_enabled: GUI_NEEDS_REDRAW% = TRUE
        CASE 907  ' Make grid match brush size
            IF CUSTOM_BRUSH_is_active% THEN
                ' Use custom brush dimensions
                GRID.gridWidth% = CUSTOM_BRUSH.WIDTH%
                GRID.gridHeight% = CUSTOM_BRUSH.HEIGHT%
            ELSE
                ' Use regular brush size
                GRID.gridWidth% = BRUSH_PIXEL_SIZES(BRUSH_SIZE.CURRENT)
                GRID.gridHeight% = BRUSH_PIXEL_SIZES(BRUSH_SIZE.CURRENT)
            END IF
            GRID.ALIGN_MODE% = GRID_ALIGN_CENTER  ' Center/tile mode for filling gaps
            GRID.SNAP% = TRUE  ' Enable snap to grid
            GRID_draw
        CASE 910  ' Toggle Smart Guides
            SMART_GUIDES.ENABLED% = NOT SMART_GUIDES.ENABLED%
            CFG.SMART_GUIDES_ENABLED% = SMART_GUIDES.ENABLED%
            IF NOT SMART_GUIDES.ENABLED% THEN SMART_GUIDES_clear
            GUI_NEEDS_REDRAW% = TRUE: FRAME_IDLE% = FALSE
        CASE 911  ' Toggle Snap Smart Guides
            SMART_GUIDES.SNAP% = NOT SMART_GUIDES.SNAP%
            CFG.SMART_GUIDES_SNAP% = SMART_GUIDES.SNAP%
            GUI_NEEDS_REDRAW% = TRUE
            GUI_NEEDS_REDRAW% = TRUE
            SCENE_DIRTY% = TRUE
        
        ' ========== SYMMETRY ==========
        CASE 1001: SYMMETRY_cycle_mode
        CASE 1002: SYMMETRY_clear
        
        ' ========== CUSTOM BRUSH ==========
        CASE 1103  ' Toggle recolor (brush + pattern)
            IF CUSTOM_BRUSH_is_active% OR (DRAWER.mode% = DRAWER_MODE_PATTERN AND DRAWER.patternSelected% > 0) THEN
                CUSTOM_BRUSH.RECOLOR_MODE% = NOT CUSTOM_BRUSH.RECOLOR_MODE%
            END IF
        CASE 1104  ' Outline with BG color
            IF CUSTOM_BRUSH_is_active% THEN CUSTOM_BRUSH_apply_outline
        CASE 1105  ' Flip H
            IF CUSTOM_BRUSH_is_active% THEN CUSTOM_BRUSH_toggle_flip_h
        CASE 1106  ' Flip V
            IF CUSTOM_BRUSH_is_active% THEN CUSTOM_BRUSH_toggle_flip_v
        CASE 1107  ' Scale up
            IF CUSTOM_BRUSH_is_active% THEN CUSTOM_BRUSH_scale_up
        CASE 1108  ' Scale down
            IF CUSTOM_BRUSH_is_active% THEN CUSTOM_BRUSH_scale_down
        CASE 1109  ' Reset scale
            IF CUSTOM_BRUSH_is_active% THEN CUSTOM_BRUSH_scale_reset
        CASE 1111  ' Rotate 90 CW
            IF CUSTOM_BRUSH_is_active% THEN
                CUSTOM_BRUSH_rotate_cw
            ELSE
                CMD_execute_action 319
            END IF
        CASE 1112  ' Rotate 90 CCW
            IF CUSTOM_BRUSH_is_active% THEN
                CUSTOM_BRUSH_rotate_ccw
            ELSE
                CMD_execute_action 320
            END IF
        
        ' ========== FILE (menu-only) ==========
        CASE 202  ' Save (Ctrl+S)
            SAVE_image
        CASE 204  ' Save As (Ctrl+Shift+S)
            SAVE_as
        CASE 205  ' Export Selection
            SAVE_selection
        CASE 206  ' Open DRAW file
            DRW_open_dialog
        CASE 215  ' Open Aseprite file
            FILE_ASE_open_dialog
        CASE 216  ' Open PSD file
            FILE_PSD_open_dialog
        CASE 208  ' Import Image
            IMPORT_image
        CASE 1911  ' Load Drawer Set
            DRAWER_import_set_dialog
        CASE 207  ' Revert
            ' Only revert if we have a saved file to revert to
            IF CURRENT_DRW_FILENAME$ <> "" OR CURRENT_FILENAME$ <> "" THEN
                DIM doRevert AS INTEGER
                doRevert% = TRUE
                IF CANVAS_DIRTY% THEN
                    POINTER_hide_for_dialog
                    DIM revertResult AS LONG
                    revertResult& = DRAW_message_box%("Revert", "Discard unsaved changes and revert to last saved version?", MB_BTN_YES_NO, MB_ICON_WARNING)
                    POINTER_show_after_dialog
                    MOUSE_cleanup_after_dialog FALSE
                    IF revertResult& <> MB_RESULT_1 THEN doRevert% = FALSE
                END IF
                IF doRevert% THEN
                    DIM revertFile AS STRING
                    IF CURRENT_DRW_FILENAME$ <> "" THEN
                        revertFile$ = CURRENT_DRW_FILENAME$
                    ELSE
                        revertFile$ = CURRENT_FILENAME$
                    END IF
                    DRW_load revertFile$
                    CANVAS_DIRTY% = FALSE
                    MOUSE_cleanup_after_dialog TRUE
                END IF
            END IF
        CASE 209  ' New
            SOUND_play SND_NEW_FILE
            DRW_new_canvas
        CASE 210  ' New from Template
            ' Prompt to save if dirty
            IF CANVAS_DIRTY% THEN
                POINTER_hide_for_dialog
                DIM tmplSave AS LONG
                tmplSave& = DRAW_message_box%("New from Template", "You have unsaved changes. Continue without saving?", MB_BTN_YES_NO, MB_ICON_WARNING)
                POINTER_show_after_dialog
                MOUSE_cleanup_after_dialog FALSE
                IF tmplSave& <> MB_RESULT_1 THEN EXIT SUB
            END IF

            ' Open file dialog for template
            DIM tmplDefault AS STRING
            IF CFG.TEMPLATE_DIR$ <> "" THEN
                tmplDefault$ = CFG.TEMPLATE_DIR$ + "/"
            ELSEIF CFG.LAST_DIR_OPEN$ <> "" THEN
                tmplDefault$ = CFG.LAST_DIR_OPEN$ + "/"
            ELSEIF LAST_DIRECTORY$ <> "" THEN
                tmplDefault$ = LAST_DIRECTORY$ + "/"
            ELSE
                tmplDefault$ = ""
            END IF

            POINTER_hide_for_dialog
            DIM tmplFile AS STRING
            tmplFile$ = DRAW_open_file$("New from Template", tmplDefault$, "Template Files|*.draw|*.png|*.bmp|*.jpg|*.jpeg|*.gif|*.psd|*.tga|*.qoi|*.hdr", 0)
            POINTER_show_after_dialog
            MOUSE_cleanup_after_dialog TRUE

            IF LEN(tmplFile$) > 0 THEN
                ' Update template directory
                CFG.TEMPLATE_DIR$ = CONFIG_extract_dir$(tmplFile$)
                CONFIG_save

                ' Load the file
                DRW_load tmplFile$

                ' Do NOT set CURRENT_DRW_FILENAME$ or CURRENT_FILENAME$
                ' This makes the file treated as a new untitled document
                ' First Save/CTRL-S will trigger Save As dialog
                CURRENT_DRW_FILENAME$ = ""
                CURRENT_FILENAME$ = ""

                ' Mark clean â€” template opens fresh
                CANVAS_DIRTY% = FALSE

                MOUSE_cleanup_after_dialog TRUE
            END IF
        CASE 1912  ' Save Drawer Set
            DRAWER_export_set_dialog
        CASE 1913  ' Clear Drawer Set
            DRAWER_clear_active_set
        CASE 1914  ' Explore Drawer Sets
            DRAWER_explore_sets_folder
        CASE 211  ' Export Layer
            DIM layerExportPath AS STRING
            POINTER_hide_for_dialog
            DIM layerExportDefault AS STRING
            IF CFG.LAST_DIR_EXPORT_LAYER$ <> "" THEN
                layerExportDefault$ = CFG.LAST_DIR_EXPORT_LAYER$ + "/"
            ELSE
                layerExportDefault$ = ""
            END IF
            layerExportPath$ = DRAW_save_file$("Export Layer", layerExportDefault$, "Image files|*.png|*.bmp|*.jpg|*.gif|*.tga|*.hdr|*.ico|*.qoi", 0, "", ".png")
            POINTER_show_after_dialog
            IF layerExportPath$ <> "" THEN
                ' Update per-operation last directory
                CFG.LAST_DIR_EXPORT_LAYER$ = CONFIG_extract_dir$(layerExportPath$)
                LAST_DIRECTORY$ = CFG.LAST_DIR_EXPORT_LAYER$
                CONFIG_save
                ' Save the current layer's image handle as PNG
                ' Crop to the bounding box of opaque pixels
                IF CURRENT_LAYER% > 0 AND CURRENT_LAYER% <= LAYER_COUNT% THEN
                    IF LAYERS(CURRENT_LAYER%).imgHandle& < -1 THEN
                        DIM eleSrcW AS INTEGER, eleSrcH AS INTEGER
                        eleSrcW% = _WIDTH(LAYERS(CURRENT_LAYER%).imgHandle&)
                        eleSrcH% = _HEIGHT(LAYERS(CURRENT_LAYER%).imgHandle&)
                        DIM eleMinX AS INTEGER, eleMinY AS INTEGER
                        DIM eleMaxX AS INTEGER, eleMaxY AS INTEGER
                        eleMinX% = eleSrcW% : eleMinY% = eleSrcH%
                        eleMaxX% = -1 : eleMaxY% = -1
                        DIM eleMem AS _MEM
                        eleMem = _MEMIMAGE(LAYERS(CURRENT_LAYER%).imgHandle&)
                        DIM eleA AS _UNSIGNED _BYTE
                        DIM elePX AS INTEGER, elePY AS INTEGER
                        FOR elePY% = 0 TO eleSrcH% - 1
                            FOR elePX% = 0 TO eleSrcW% - 1
                                _MEMGET eleMem, eleMem.OFFSET + (elePY% * eleSrcW% + elePX%) * 4 + 3, eleA~%%
                                IF eleA~%% > 0 THEN
                                    IF elePX% < eleMinX% THEN eleMinX% = elePX%
                                    IF elePX% > eleMaxX% THEN eleMaxX% = elePX%
                                    IF elePY% < eleMinY% THEN eleMinY% = elePY%
                                    IF elePY% > eleMaxY% THEN eleMaxY% = elePY%
                                END IF
                            NEXT elePX%
                        NEXT elePY%
                        _MEMFREE eleMem
                        IF eleMaxX% < 0 THEN
                            ' Layer is entirely transparent â€” save full image
                            _SAVEIMAGE layerExportPath$, LAYERS(CURRENT_LAYER%).imgHandle&
                        ELSE
                            DIM eleCropW AS INTEGER: eleCropW% = eleMaxX% - eleMinX% + 1
                            DIM eleCropH AS INTEGER: eleCropH% = eleMaxY% - eleMinY% + 1
                            DIM eleCropImg AS LONG
                            eleCropImg& = _NEWIMAGE(eleCropW%, eleCropH%, 32)
                            IF eleCropImg& < -1 THEN
                                DIM eleOldDest AS LONG: eleOldDest& = _DEST
                                _DEST eleCropImg&
                                _DONTBLEND eleCropImg&
                                CLS , _RGBA32(0, 0, 0, 0)
                                _PUTIMAGE (0, 0)-(eleCropW% - 1, eleCropH% - 1), LAYERS(CURRENT_LAYER%).imgHandle&, eleCropImg&, (eleMinX%, eleMinY%)-(eleMaxX%, eleMaxY%)
                                _BLEND eleCropImg&
                                _DEST eleOldDest&
                                _SAVEIMAGE layerExportPath$, eleCropImg&
                                _FREEIMAGE eleCropImg&
                            ELSE
                                ' _NEWIMAGE failed â€” save full image as fallback
                                _SAVEIMAGE layerExportPath$, LAYERS(CURRENT_LAYER%).imgHandle&
                            END IF
                        END IF
                        _LOGINFO "Layer exported to: " + layerExportPath$
                    ELSE
                        ERR_info "Invalid layer image"
                    END IF
                ELSE
                    ERR_info "No valid layer selected"
                END IF
            END IF
        CASE 214  ' Extract Images
            EXTRACT_IMAGES_dialog
            FRAME_IDLE% = FALSE
        CASE 218  ' Extract From Grid
            EXTRACT_GRID_run
            FRAME_IDLE% = FALSE
        CASE 219  ' Extract To Layers From Grid
            EXTRACT_LAYERS_GRID_run
            FRAME_IDLE% = FALSE
        ' ========== EXPORT AS (format-specific flattened exports) ==========
        CASE EXPORT_ACT_PNG_NATIVE
            EXPORT_flattened_as ".png", "PNG", TRUE
        CASE EXPORT_ACT_PNG
            EXPORT_flattened_as ".png", "PNG", FALSE
        CASE EXPORT_ACT_GIF
            EXPORT_flattened_as ".gif", "GIF", FALSE
        CASE EXPORT_ACT_JPG
            EXPORT_flattened_as ".jpg", "JPEG", FALSE
        CASE EXPORT_ACT_TGA
            EXPORT_flattened_as ".tga", "TGA", FALSE
        CASE EXPORT_ACT_BMP
            EXPORT_flattened_as ".bmp", "BMP", FALSE
        CASE EXPORT_ACT_HDR
            EXPORT_flattened_as ".hdr", "HDR", FALSE
        CASE EXPORT_ACT_ICO
            EXPORT_flattened_as ".ico", "ICO", FALSE
        CASE EXPORT_ACT_QOI
            EXPORT_flattened_as ".qoi", "QOI", FALSE

        CASE 212  ' Exit
            DIM shouldExit AS INTEGER
            shouldExit% = TRUE
            IF CANVAS_DIRTY% THEN
                POINTER_hide_for_dialog
                DIM exitResult AS LONG
                exitResult& = DRAW_message_box%("DRAW", "Canvas has unsaved changes. Exit anyway?", MB_BTN_YES_NO, MB_ICON_QUESTION)
                POINTER_show_after_dialog
                IF exitResult& <> MB_RESULT_1 THEN shouldExit% = FALSE
            END IF
            IF shouldExit% THEN MAIN_shutdown
        
        ' ========== EDIT (menu-only) ==========
        CASE 312  ' Paste in Place
            SOUND_play SND_CLIPBOARD
            CLIPBOARD_paste CLIPBOARD.SOURCE_X + CLIPBOARD.WIDTH \ 2, CLIPBOARD.SOURCE_Y + CLIPBOARD.HEIGHT \ 2
        CASE 313  ' Fill with FG
            SOUND_play SND_FILL
            IF CURRENT_LAYER% > 0 THEN
                DIM oldFillDest AS LONG
                DIM fillHistoryBefore AS LONG
                DIM fillHistoryFlags AS LONG
                DIM fillUsedHistoryGroup AS INTEGER
                oldFillDest& = _DEST
                fillHistoryBefore& = 0
                fillHistoryFlags& = 0
                fillUsedHistoryGroup% = FALSE
                IF SELECTION_has_active% OR LAYERS(CURRENT_LAYER%).opacityLock% THEN fillHistoryFlags& = fillHistoryFlags& OR HISTORY_FLAG_CLIPPED
                IF NOT HISTORY_IN_PROGRESS% AND LAYERS(CURRENT_LAYER%).historyId& > 0 AND LAYERS(CURRENT_LAYER%).imgHandle& < -1 THEN
                    fillHistoryBefore& = _COPYIMAGE(LAYERS(CURRENT_LAYER%).imgHandle&, 32)
                END IF
                IF MULTI_SELECT_has_any% AND NOT HISTORY_IN_PROGRESS% THEN
                    HISTORY_begin_group
                    fillUsedHistoryGroup% = HISTORY_GROUP_ACTIVE%
                END IF
                STROKE_begin
                _DEST LAYERS(CURRENT_LAYER%).imgHandle&
                IF MARQUEE.WAND_HAS_SELECTION AND MARQUEE.SELECTION_MASK < -1 AND MARQUEE.ACTIVE AND MARQUEE.USER_CREATED THEN
                    ' Mask-based selection: fill only selected pixels
                    DIM fgFillX AS INTEGER, fgFillY AS INTEGER
                    DIM fgFillOldSrc AS LONG, fgFillMaskColor AS _UNSIGNED LONG
                    fgFillOldSrc& = _SOURCE
                    fgFillMaskColor~& = _RGB32(255, 255, 255)
                    FOR fgFillY% = MARQUEE.WAND_MIN_Y TO MARQUEE.WAND_MAX_Y
                        FOR fgFillX% = MARQUEE.WAND_MIN_X TO MARQUEE.WAND_MAX_X
                            _SOURCE MARQUEE.SELECTION_MASK
                            IF POINT(fgFillX%, fgFillY%) = fgFillMaskColor~& THEN
                                _DEST LAYERS(CURRENT_LAYER%).imgHandle&
                                PSET (fgFillX%, fgFillY%), PAINT_COLOR~&
                            END IF
                        NEXT fgFillX%
                    NEXT fgFillY%
                    _SOURCE fgFillOldSrc&
                ELSEIF MARQUEE.ACTIVE AND MARQUEE.USER_CREATED AND MARQUEE.INITIALIZED THEN
                    LINE (MARQUEE.BOX.x, MARQUEE.BOX.y)-(MARQUEE.BOX.x + MARQUEE.BOX.w - 1, MARQUEE.BOX.y + MARQUEE.BOX.h - 1), PAINT_COLOR~&, BF
                ELSE
                    ' Multi-select or opacity lock: fill only opaque pixels.
                    ' Single-layer with no lock: full CLS to fill entire layer.
                    IF MULTI_SELECT_has_any% OR LAYERS(CURRENT_LAYER%).opacityLock% THEN
                        CMD_ml_fill CURRENT_LAYER%, PAINT_COLOR~&, fillHistoryFlags&, "Fill FG"
                    ELSE
                        CLS , PAINT_COLOR~&
                    END IF
                END IF
                _DEST oldFillDest&
                STROKE_commit
                IF fillHistoryBefore& < -1 THEN
                    HISTORY_record_fill LAYERS(CURRENT_LAYER%).historyId&, CURRENT_LAYER%, PAINT_COLOR~&, fillHistoryFlags&, fillHistoryBefore&, -32768, -32768, "Fill FG"
                    HISTORY_saved_this_frame% = TRUE
                END IF
                LAYERS(CURRENT_LAYER%).contentDirty% = TRUE
                ' Apply fill to all other multi-selected layers (opaque pixels only)
                IF MULTI_SELECT_has_any% THEN
                    DIM mlFgI AS INTEGER
                    FOR mlFgI% = 1 TO MAX_LAYERS
                        IF MULTI_SELECT_LAYERS(mlFgI%) AND mlFgI% <> CURRENT_LAYER% THEN
                            CMD_ml_fill mlFgI%, PAINT_COLOR~&, HISTORY_FLAG_CLIPPED, "Fill FG"
                        END IF
                    NEXT mlFgI%
                END IF
                IF fillUsedHistoryGroup% THEN HISTORY_end_group
                INVALIDATE_layers
            END IF
        CASE 314  ' Fill with BG
            SOUND_play SND_FILL
            IF CURRENT_LAYER% > 0 THEN
                DIM oldBgDest AS LONG
                DIM bgHistoryBefore AS LONG
                DIM bgHistoryFlags AS LONG
                DIM bgUsedHistoryGroup AS INTEGER
                oldBgDest& = _DEST
                bgHistoryBefore& = 0
                bgHistoryFlags& = 0
                bgUsedHistoryGroup% = FALSE
                IF SELECTION_has_active% OR LAYERS(CURRENT_LAYER%).opacityLock% THEN bgHistoryFlags& = bgHistoryFlags& OR HISTORY_FLAG_CLIPPED
                IF NOT HISTORY_IN_PROGRESS% AND LAYERS(CURRENT_LAYER%).historyId& > 0 AND LAYERS(CURRENT_LAYER%).imgHandle& < -1 THEN
                    bgHistoryBefore& = _COPYIMAGE(LAYERS(CURRENT_LAYER%).imgHandle&, 32)
                END IF
                IF MULTI_SELECT_has_any% AND NOT HISTORY_IN_PROGRESS% THEN
                    HISTORY_begin_group
                    bgUsedHistoryGroup% = HISTORY_GROUP_ACTIVE%
                END IF
                _DEST LAYERS(CURRENT_LAYER%).imgHandle&
                IF MARQUEE.WAND_HAS_SELECTION AND MARQUEE.SELECTION_MASK < -1 AND MARQUEE.ACTIVE AND MARQUEE.USER_CREATED THEN
                    ' Mask-based selection: fill only selected pixels
                    DIM bgFillX AS INTEGER, bgFillY AS INTEGER
                    DIM bgFillOldSrc AS LONG, bgFillMaskColor AS _UNSIGNED LONG
                    bgFillOldSrc& = _SOURCE
                    bgFillMaskColor~& = _RGB32(255, 255, 255)
                    FOR bgFillY% = MARQUEE.WAND_MIN_Y TO MARQUEE.WAND_MAX_Y
                        FOR bgFillX% = MARQUEE.WAND_MIN_X TO MARQUEE.WAND_MAX_X
                            _SOURCE MARQUEE.SELECTION_MASK
                            IF POINT(bgFillX%, bgFillY%) = bgFillMaskColor~& THEN
                                _DEST LAYERS(CURRENT_LAYER%).imgHandle&
                                PSET (bgFillX%, bgFillY%), PAINT_BG_COLOR~&
                            END IF
                        NEXT bgFillX%
                    NEXT bgFillY%
                    _SOURCE bgFillOldSrc&
                ELSEIF MARQUEE.ACTIVE AND MARQUEE.USER_CREATED AND MARQUEE.INITIALIZED THEN
                    LINE (MARQUEE.BOX.x, MARQUEE.BOX.y)-(MARQUEE.BOX.x + MARQUEE.BOX.w - 1, MARQUEE.BOX.y + MARQUEE.BOX.h - 1), PAINT_BG_COLOR~&, BF
                ELSE
                    ' Multi-select or opacity lock: fill only opaque pixels.
                    ' Single-layer with no lock: full CLS to fill entire layer.
                    IF MULTI_SELECT_has_any% OR LAYERS(CURRENT_LAYER%).opacityLock% THEN
                        CMD_ml_fill CURRENT_LAYER%, PAINT_BG_COLOR~&, bgHistoryFlags&, "Fill BG"
                    ELSE
                        CLS , PAINT_BG_COLOR~&
                    END IF
                END IF
                _DEST oldBgDest&
                IF bgHistoryBefore& < -1 THEN
                    HISTORY_record_fill LAYERS(CURRENT_LAYER%).historyId&, CURRENT_LAYER%, PAINT_BG_COLOR~&, bgHistoryFlags&, bgHistoryBefore&, -32768, -32768, "Fill BG"
                    HISTORY_saved_this_frame% = TRUE
                END IF
                LAYERS(CURRENT_LAYER%).contentDirty% = TRUE
                ' Apply fill to all other multi-selected layers (opaque pixels only)
                IF MULTI_SELECT_has_any% THEN
                    DIM mlBgI AS INTEGER
                    FOR mlBgI% = 1 TO MAX_LAYERS
                        IF MULTI_SELECT_LAYERS(mlBgI%) AND mlBgI% <> CURRENT_LAYER% THEN
                            CMD_ml_fill mlBgI%, PAINT_BG_COLOR~&, HISTORY_FLAG_CLIPPED, "Fill BG"
                        END IF
                    NEXT mlBgI%
                END IF
                IF bgUsedHistoryGroup% THEN HISTORY_end_group
                INVALIDATE_layers
            END IF
        CASE 324  ' Stroke Selection
            IF SELECTION_has_active% THEN
                SOUND_play SND_SELECTION
                MENUBAR_close_all
                GUI_NEEDS_REDRAW% = TRUE
                SCENE_DIRTY% = TRUE
                SCREEN_render
                _DISPLAY
                STROKE_SEL_show_dialog
                FRAME_IDLE% = FALSE
            END IF
        CASE 325, 326, 327, 328, 329  ' On-canvas transform modes
            IF CURRENT_LAYER% >= 1 THEN
                MENUBAR_close_all
                SELECT CASE action_id%
                    CASE 325: TRANSFORM_activate TRANSFORM_MODE_SCALE
                    CASE 326: TRANSFORM_activate TRANSFORM_MODE_DISTORT
                    CASE 327: TRANSFORM_activate TRANSFORM_MODE_PERSPECTIVE
                    CASE 328: TRANSFORM_activate TRANSFORM_MODE_ROTATE
                    CASE 329: TRANSFORM_activate TRANSFORM_MODE_SHEAR
                END SELECT
                FRAME_IDLE% = FALSE
            END IF
        CASE 315  ' Flip Horizontal
            ' Symbol child: toggle flip via negative scale instead of destructive pixel flip
            IF CURRENT_LAYER% >= 1 THEN
                IF CURRENT_LAYER% <= MAX_LAYERS THEN
                    IF LAYERS(CURRENT_LAYER%).layerType% = LAYER_TYPE_SYMBOL_CHILD THEN
                        LAYERS(CURRENT_LAYER%).symbolScaleX! = -LAYERS(CURRENT_LAYER%).symbolScaleX!
                        SYMBOL_render_child CURRENT_LAYER%
                        BLEND_invalidate_cache
                        FRAME_IDLE% = FALSE
                        INVALIDATE_scene
                        GOTO SkipFlipH315
                    END IF
                END IF
            END IF
            DIM grpExp315 AS INTEGER
            grpExp315% = CMD_group_expand_for_op%
            SOUND_play SND_TRANSFORM
            IF CUSTOM_BRUSH_is_active% THEN
                CUSTOM_BRUSH_toggle_flip_h
            ELSEIF MOVE.ACTIVE AND MOVE.SELECTION_IMAGE < -1 THEN
                ' Flip the floating move selection horizontally
                DIM fhMoveW AS INTEGER, fhMoveH AS INTEGER
                fhMoveW% = _WIDTH(MOVE.SELECTION_IMAGE)
                fhMoveH% = _HEIGHT(MOVE.SELECTION_IMAGE)
                DIM fhMoveTmp AS LONG
                fhMoveTmp& = _NEWIMAGE(fhMoveW%, fhMoveH%, 32)
                _PUTIMAGE (fhMoveW% - 1, 0)-(0, fhMoveH% - 1), MOVE.SELECTION_IMAGE, fhMoveTmp&
                _DEST MOVE.SELECTION_IMAGE
                _DONTBLEND MOVE.SELECTION_IMAGE
                _PUTIMAGE , fhMoveTmp&, MOVE.SELECTION_IMAGE
                _BLEND MOVE.SELECTION_IMAGE
                _DEST SCRN.CANVAS&
                IF fhMoveTmp& < -1 THEN _FREEIMAGE fhMoveTmp&
                MOVE_update_preview_buffer
                INVALIDATE_scene
            ELSEIF CURRENT_LAYER% > 0 THEN
                DIM flipH_src AS LONG, flipH_w AS LONG, flipH_h AS LONG
                DIM flipH_history_before AS LONG
                DIM flipH_history_flags AS LONG
                DIM flipH_used_history_group AS INTEGER
                flipH_src& = LAYERS(CURRENT_LAYER%).imgHandle&
                flipH_history_before& = 0
                flipH_history_flags& = 0
                flipH_used_history_group% = FALSE
                IF SELECTION_has_active% OR LAYERS(CURRENT_LAYER%).opacityLock% THEN flipH_history_flags& = flipH_history_flags& OR HISTORY_FLAG_CLIPPED
                IF NOT HISTORY_IN_PROGRESS% AND LAYERS(CURRENT_LAYER%).historyId& > 0 AND flipH_src& < -1 THEN
                    flipH_history_before& = _COPYIMAGE(flipH_src&, 32)
                END IF
                IF MULTI_SELECT_has_any% AND NOT HISTORY_IN_PROGRESS% THEN
                    HISTORY_begin_group
                    flipH_used_history_group% = HISTORY_GROUP_ACTIVE%
                END IF
                IF SELECTION_has_active% THEN
                    ' Flip only within selection bounds
                    DIM fhSelW AS INTEGER, fhSelH AS INTEGER
                    fhSelW% = MARQUEE.BOX.w : fhSelH% = MARQUEE.BOX.h
                    DIM fhRegion AS LONG
                    fhRegion& = _NEWIMAGE(fhSelW%, fhSelH%, 32)
                    _PUTIMAGE (0, 0), flipH_src&, fhRegion&, (MARQUEE.BOX.x, MARQUEE.BOX.y)-(MARQUEE.BOX.x + fhSelW% - 1, MARQUEE.BOX.y + fhSelH% - 1)
                    DIM oldFHSelDest AS LONG : oldFHSelDest& = _DEST
                    _DEST flipH_src&
                    _DONTBLEND flipH_src&
                    _PUTIMAGE (MARQUEE.BOX.x + fhSelW% - 1, MARQUEE.BOX.y)-(MARQUEE.BOX.x, MARQUEE.BOX.y + fhSelH% - 1), fhRegion&, flipH_src&
                    _BLEND flipH_src&
                    _DEST oldFHSelDest&
                    IF fhRegion& < -1 THEN _FREEIMAGE fhRegion&
                ELSE
                    ' Flip entire layer
                    flipH_w& = _WIDTH(flipH_src&)
                    flipH_h& = _HEIGHT(flipH_src&)
                    DIM flipH_tmp AS LONG
                    flipH_tmp& = _NEWIMAGE(flipH_w&, flipH_h&, 32)
                    _PUTIMAGE (flipH_w& - 1, 0)-(0, flipH_h& - 1), flipH_src&, flipH_tmp&
                    DIM oldFlipDest AS LONG : oldFlipDest& = _DEST
                    _DEST flipH_src&
                    _DONTBLEND flipH_src&
                    _PUTIMAGE , flipH_tmp&, flipH_src&
                    _BLEND flipH_src&
                    _DEST oldFlipDest&
                    IF flipH_tmp& < -1 THEN _FREEIMAGE flipH_tmp&
                END IF
                IF flipH_history_before& < -1 THEN
                    HISTORY_record_transform LAYERS(CURRENT_LAYER%).historyId&, CURRENT_LAYER%, flipH_history_flags&, flipH_history_before&, "Flip Horizontal"
                    HISTORY_saved_this_frame% = TRUE
                END IF
                LAYERS(CURRENT_LAYER%).contentDirty% = TRUE
                ' Apply flip H to all other multi-selected layers
                IF MULTI_SELECT_has_any% THEN
                    DIM mlFhI AS INTEGER
                    FOR mlFhI% = 1 TO MAX_LAYERS
                        IF MULTI_SELECT_LAYERS(mlFhI%) AND mlFhI% <> CURRENT_LAYER% THEN
                            CMD_ml_flip_h mlFhI%, flipH_history_flags&, "Flip Horizontal"
                        END IF
                    NEXT mlFhI%
                END IF
                IF flipH_used_history_group% THEN HISTORY_end_group
                INVALIDATE_layers
            END IF
            IF grpExp315% > 0 THEN CMD_group_restore_after_op grpExp315%
            SkipFlipH315:
        CASE 316  ' Flip Vertical
            ' Symbol child: toggle flip via negative scale instead of destructive pixel flip
            IF CURRENT_LAYER% >= 1 THEN
                IF CURRENT_LAYER% <= MAX_LAYERS THEN
                    IF LAYERS(CURRENT_LAYER%).layerType% = LAYER_TYPE_SYMBOL_CHILD THEN
                        LAYERS(CURRENT_LAYER%).symbolScaleY! = -LAYERS(CURRENT_LAYER%).symbolScaleY!
                        SYMBOL_render_child CURRENT_LAYER%
                        BLEND_invalidate_cache
                        FRAME_IDLE% = FALSE
                        INVALIDATE_scene
                        GOTO SkipFlipV316
                    END IF
                END IF
            END IF
            DIM grpExp316 AS INTEGER
            grpExp316% = CMD_group_expand_for_op%
            SOUND_play SND_TRANSFORM
            IF CUSTOM_BRUSH_is_active% THEN
                CUSTOM_BRUSH_toggle_flip_v
            ELSEIF MOVE.ACTIVE AND MOVE.SELECTION_IMAGE < -1 THEN
                ' Flip the floating move selection vertically
                DIM fvMoveW AS INTEGER, fvMoveH AS INTEGER
                fvMoveW% = _WIDTH(MOVE.SELECTION_IMAGE)
                fvMoveH% = _HEIGHT(MOVE.SELECTION_IMAGE)
                DIM fvMoveTmp AS LONG
                fvMoveTmp& = _NEWIMAGE(fvMoveW%, fvMoveH%, 32)
                _PUTIMAGE (0, fvMoveH% - 1)-(fvMoveW% - 1, 0), MOVE.SELECTION_IMAGE, fvMoveTmp&
                _DEST MOVE.SELECTION_IMAGE
                _DONTBLEND MOVE.SELECTION_IMAGE
                _PUTIMAGE , fvMoveTmp&, MOVE.SELECTION_IMAGE
                _BLEND MOVE.SELECTION_IMAGE
                _DEST SCRN.CANVAS&
                IF fvMoveTmp& < -1 THEN _FREEIMAGE fvMoveTmp&
                MOVE_update_preview_buffer
                INVALIDATE_scene
            ELSEIF CURRENT_LAYER% > 0 THEN
                DIM flipV_src AS LONG, flipV_w AS LONG, flipV_h AS LONG
                DIM flipV_history_before AS LONG
                DIM flipV_history_flags AS LONG
                DIM flipV_used_history_group AS INTEGER
                flipV_src& = LAYERS(CURRENT_LAYER%).imgHandle&
                flipV_history_before& = 0
                flipV_history_flags& = 0
                flipV_used_history_group% = FALSE
                IF SELECTION_has_active% OR LAYERS(CURRENT_LAYER%).opacityLock% THEN flipV_history_flags& = flipV_history_flags& OR HISTORY_FLAG_CLIPPED
                IF NOT HISTORY_IN_PROGRESS% AND LAYERS(CURRENT_LAYER%).historyId& > 0 AND flipV_src& < -1 THEN
                    flipV_history_before& = _COPYIMAGE(flipV_src&, 32)
                END IF
                IF MULTI_SELECT_has_any% AND NOT HISTORY_IN_PROGRESS% THEN
                    HISTORY_begin_group
                    flipV_used_history_group% = HISTORY_GROUP_ACTIVE%
                END IF
                IF SELECTION_has_active% THEN
                    ' Flip only within selection bounds
                    DIM fvSelW AS INTEGER, fvSelH AS INTEGER
                    fvSelW% = MARQUEE.BOX.w : fvSelH% = MARQUEE.BOX.h
                    DIM fvRegion AS LONG
                    fvRegion& = _NEWIMAGE(fvSelW%, fvSelH%, 32)
                    _PUTIMAGE (0, 0), flipV_src&, fvRegion&, (MARQUEE.BOX.x, MARQUEE.BOX.y)-(MARQUEE.BOX.x + fvSelW% - 1, MARQUEE.BOX.y + fvSelH% - 1)
                    DIM oldFVSelDest AS LONG : oldFVSelDest& = _DEST
                    _DEST flipV_src&
                    _DONTBLEND flipV_src&
                    _PUTIMAGE (MARQUEE.BOX.x, MARQUEE.BOX.y + fvSelH% - 1)-(MARQUEE.BOX.x + fvSelW% - 1, MARQUEE.BOX.y), fvRegion&, flipV_src&
                    _BLEND flipV_src&
                    _DEST oldFVSelDest&
                    IF fvRegion& < -1 THEN _FREEIMAGE fvRegion&
                ELSE
                    ' Flip entire layer
                    flipV_w& = _WIDTH(flipV_src&)
                    flipV_h& = _HEIGHT(flipV_src&)
                    DIM flipV_tmp AS LONG
                    flipV_tmp& = _NEWIMAGE(flipV_w&, flipV_h&, 32)
                    _PUTIMAGE (0, flipV_h& - 1)-(flipV_w& - 1, 0), flipV_src&, flipV_tmp&
                    DIM oldFlipVDest AS LONG : oldFlipVDest& = _DEST
                    _DEST flipV_src&
                    _DONTBLEND flipV_src&
                    _PUTIMAGE , flipV_tmp&, flipV_src&
                    _BLEND flipV_src&
                    _DEST oldFlipVDest&
                    IF flipV_tmp& < -1 THEN _FREEIMAGE flipV_tmp&
                END IF
                IF flipV_history_before& < -1 THEN
                    HISTORY_record_transform LAYERS(CURRENT_LAYER%).historyId&, CURRENT_LAYER%, flipV_history_flags&, flipV_history_before&, "Flip Vertical"
                    HISTORY_saved_this_frame% = TRUE
                END IF
                LAYERS(CURRENT_LAYER%).contentDirty% = TRUE
                ' Apply flip V to all other multi-selected layers
                IF MULTI_SELECT_has_any% THEN
                    DIM mlFvI AS INTEGER
                    FOR mlFvI% = 1 TO MAX_LAYERS
                        IF MULTI_SELECT_LAYERS(mlFvI%) AND mlFvI% <> CURRENT_LAYER% THEN
                            CMD_ml_flip_v mlFvI%, flipV_history_flags&, "Flip Vertical"
                        END IF
                    NEXT mlFvI%
                END IF
                IF flipV_used_history_group% THEN HISTORY_end_group
                INVALIDATE_layers
            END IF
            IF grpExp316% > 0 THEN CMD_group_restore_after_op grpExp316%
            SkipFlipV316:
        CASE 317  ' Scale -50%
            ' Symbol child: adjust scale factor non-destructively (integer steps)
            IF CURRENT_LAYER% >= 1 THEN
                IF CURRENT_LAYER% <= MAX_LAYERS THEN
                    IF LAYERS(CURRENT_LAYER%).layerType% = LAYER_TYPE_SYMBOL_CHILD THEN
                        DIM sc317x AS SINGLE, sc317y AS SINGLE
                        sc317x! = LAYERS(CURRENT_LAYER%).symbolScaleX!
                        sc317y! = LAYERS(CURRENT_LAYER%).symbolScaleY!
                        ' Decrease absolute value by 1, minimum 1.0
                        IF sc317x! > 0 THEN
                            sc317x! = sc317x! - 1.0!
                            IF sc317x! < 1.0! THEN sc317x! = 1.0!
                        ELSE
                            sc317x! = sc317x! + 1.0!
                            IF sc317x! > -1.0! THEN sc317x! = -1.0!
                        END IF
                        IF sc317y! > 0 THEN
                            sc317y! = sc317y! - 1.0!
                            IF sc317y! < 1.0! THEN sc317y! = 1.0!
                        ELSE
                            sc317y! = sc317y! + 1.0!
                            IF sc317y! > -1.0! THEN sc317y! = -1.0!
                        END IF
                        LAYERS(CURRENT_LAYER%).symbolScaleX! = sc317x!
                        LAYERS(CURRENT_LAYER%).symbolScaleY! = sc317y!
                        SYMBOL_render_child CURRENT_LAYER%
                        BLEND_invalidate_cache
                        FRAME_IDLE% = FALSE
                        INVALIDATE_scene
                        SOUND_play SND_TRANSFORM
                        GOTO SkipScale317
                    END IF
                END IF
            END IF
            DIM grpExp317 AS INTEGER
            grpExp317% = CMD_group_expand_for_op%
            SOUND_play SND_TRANSFORM
            IF CUSTOM_BRUSH_is_active% THEN
                CUSTOM_BRUSH_scale_down
            ELSEIF MOVE.ACTIVE AND MOVE.SELECTION_IMAGE < -1 THEN
                ' Scale the floating move selection down by 50% (from original to prevent generation loss)
                MOVE.SCALE_FACTOR = MOVE.SCALE_FACTOR * 0.5
                DIM sdNewW AS INTEGER, sdNewH AS INTEGER
                sdNewW% = INT(MOVE.ORIGINAL_IMG_W * MOVE.SCALE_FACTOR)
                sdNewH% = INT(MOVE.ORIGINAL_IMG_H * MOVE.SCALE_FACTOR)
                IF sdNewW% < 1 THEN sdNewW% = 1
                IF sdNewH% < 1 THEN sdNewH% = 1
                DIM sdMoveTmp AS LONG
                sdMoveTmp& = _NEWIMAGE(sdNewW%, sdNewH%, 32)
                _DONTBLEND sdMoveTmp&
                _PUTIMAGE (0, 0)-(sdNewW% - 1, sdNewH% - 1), MOVE.ORIGINAL_IMAGE, sdMoveTmp&
                _BLEND sdMoveTmp&
                IF MOVE.SELECTION_IMAGE < -1 THEN _FREEIMAGE MOVE.SELECTION_IMAGE
                MOVE.SELECTION_IMAGE = sdMoveTmp&
                MOVE.CURRENT_W = sdNewW%
                MOVE.CURRENT_H = sdNewH%
                MOVE.SELECTION_W = sdNewW%
                MOVE.SELECTION_H = sdNewH%
                MARQUEE.BOX.w = sdNewW%
                MARQUEE.BOX.h = sdNewH%
                MOVE_update_preview_buffer
                INVALIDATE_scene
            ELSEIF CURRENT_LAYER% > 0 THEN
                DIM sdSrc AS LONG
                DIM sd_history_before AS LONG
                DIM sd_history_flags AS LONG
                DIM sd_used_history_group AS INTEGER
                sdSrc& = LAYERS(CURRENT_LAYER%).imgHandle&
                sd_history_before& = 0
                sd_history_flags& = 0
                sd_used_history_group% = FALSE
                IF SELECTION_has_active% OR LAYERS(CURRENT_LAYER%).opacityLock% THEN sd_history_flags& = sd_history_flags& OR HISTORY_FLAG_CLIPPED
                IF NOT HISTORY_IN_PROGRESS% AND LAYERS(CURRENT_LAYER%).historyId& > 0 AND sdSrc& < -1 THEN
                    sd_history_before& = _COPYIMAGE(sdSrc&, 32)
                END IF
                IF MULTI_SELECT_has_any% AND NOT HISTORY_IN_PROGRESS% THEN
                    HISTORY_begin_group
                    sd_used_history_group% = HISTORY_GROUP_ACTIVE%
                END IF
                IF SELECTION_has_active% THEN
                    ' Scale only within selection bounds
                    DIM sdSelW AS INTEGER, sdSelH AS INTEGER
                    sdSelW% = MARQUEE.BOX.w : sdSelH% = MARQUEE.BOX.h
                    DIM sdSelNW AS INTEGER, sdSelNH AS INTEGER
                    sdSelNW% = INT(sdSelW% * 0.5)
                    sdSelNH% = INT(sdSelH% * 0.5)
                    IF sdSelNW% < 1 THEN sdSelNW% = 1
                    IF sdSelNH% < 1 THEN sdSelNH% = 1
                    ' Extract selection region
                    DIM sdReg AS LONG
                    sdReg& = _NEWIMAGE(sdSelW%, sdSelH%, 32)
                    _DONTBLEND sdReg&
                    _PUTIMAGE (0, 0), sdSrc&, sdReg&, (MARQUEE.BOX.x, MARQUEE.BOX.y)-(MARQUEE.BOX.x + sdSelW% - 1, MARQUEE.BOX.y + sdSelH% - 1)
                    ' Scale to smaller size
                    DIM sdScl AS LONG
                    sdScl& = _NEWIMAGE(sdSelNW%, sdSelNH%, 32)
                    _DONTBLEND sdScl&
                    _PUTIMAGE (0, 0)-(sdSelNW% - 1, sdSelNH% - 1), sdReg&, sdScl&
                    ' Clear selection area on layer
                    DIM oldSdDest AS LONG : oldSdDest& = _DEST
                    _DEST sdSrc&
                    _DONTBLEND sdSrc&
                    LINE (MARQUEE.BOX.x, MARQUEE.BOX.y)-(MARQUEE.BOX.x + sdSelW% - 1, MARQUEE.BOX.y + sdSelH% - 1), _RGBA32(0, 0, 0, 0), BF
                    ' Center scaled content in selection bounds
                    DIM sdCx AS INTEGER, sdCy AS INTEGER
                    sdCx% = MARQUEE.BOX.x + (sdSelW% - sdSelNW%) \ 2
                    sdCy% = MARQUEE.BOX.y + (sdSelH% - sdSelNH%) \ 2
                    _PUTIMAGE (sdCx%, sdCy%)-(sdCx% + sdSelNW% - 1, sdCy% + sdSelNH% - 1), sdScl&, sdSrc&
                    _BLEND sdSrc&
                    _DEST oldSdDest&
                    IF sdReg& < -1 THEN _FREEIMAGE sdReg&
                    IF sdScl& < -1 THEN _FREEIMAGE sdScl&
                    ' Update marquee box to the scaled content position
                    MARQUEE.BOX.x = sdCx% : MARQUEE.BOX.y = sdCy%
                    MARQUEE.BOX.w = sdSelNW% : MARQUEE.BOX.h = sdSelNH%
                ELSE
                    ' Scale entire layer content down by 50% (from original to prevent generation loss)
                    DIM sdLW AS LONG, sdLH AS LONG
                    sdLW& = _WIDTH(sdSrc&)
                    sdLH& = _HEIGHT(sdSrc&)
                    ' Save original on first scale operation for this layer
                    IF SCALE_ORIGINAL_IMAGE = 0 OR SCALE_ORIGINAL_LAYER <> CURRENT_LAYER% THEN
                        IF SCALE_ORIGINAL_IMAGE < -1 THEN _FREEIMAGE SCALE_ORIGINAL_IMAGE
                        SCALE_ORIGINAL_IMAGE = _COPYIMAGE(sdSrc&)
                        SCALE_ORIGINAL_LAYER = CURRENT_LAYER%
                        SCALE_FACTOR_LAYER = 1.0
                    END IF
                    SCALE_FACTOR_LAYER = SCALE_FACTOR_LAYER * 0.5
                    DIM sdLNW AS INTEGER, sdLNH AS INTEGER
                    sdLNW% = INT(sdLW& * SCALE_FACTOR_LAYER)
                    sdLNH% = INT(sdLH& * SCALE_FACTOR_LAYER)
                    IF sdLNW% < 1 THEN sdLNW% = 1
                    IF sdLNH% < 1 THEN sdLNH% = 1
                    ' Resample from original and center on layer
                    DIM sdLTmp AS LONG
                    sdLTmp& = _NEWIMAGE(sdLNW%, sdLNH%, 32)
                    _DONTBLEND sdLTmp&
                    _PUTIMAGE (0, 0)-(sdLNW% - 1, sdLNH% - 1), SCALE_ORIGINAL_IMAGE, sdLTmp&
                    ' Clear layer and center scaled content
                    DIM oldSdLDest AS LONG : oldSdLDest& = _DEST
                    _DEST sdSrc&
                    _DONTBLEND sdSrc&
                    CLS , _RGBA32(0, 0, 0, 0)
                    DIM sdLCx AS INTEGER, sdLCy AS INTEGER
                    sdLCx% = (sdLW& - sdLNW%) \ 2
                    sdLCy% = (sdLH& - sdLNH%) \ 2
                    _PUTIMAGE (sdLCx%, sdLCy%)-(sdLCx% + sdLNW% - 1, sdLCy% + sdLNH% - 1), sdLTmp&, sdSrc&
                    _BLEND sdSrc&
                    _DEST oldSdLDest&
                    IF sdLTmp& < -1 THEN _FREEIMAGE sdLTmp&
                END IF
                IF sd_history_before& < -1 THEN
                    HISTORY_record_transform LAYERS(CURRENT_LAYER%).historyId&, CURRENT_LAYER%, sd_history_flags&, sd_history_before&, "Scale -50%"
                    HISTORY_saved_this_frame% = TRUE
                END IF
                LAYERS(CURRENT_LAYER%).contentDirty% = TRUE
                ' Apply scale -50% to all other multi-selected layers
                IF MULTI_SELECT_has_any% THEN
                    DIM mlSdI AS INTEGER
                    FOR mlSdI% = 1 TO MAX_LAYERS
                        IF MULTI_SELECT_LAYERS(mlSdI%) AND mlSdI% <> CURRENT_LAYER% THEN
                            CMD_ml_scale mlSdI%, 0.5!, sd_history_flags&, "Scale -50%"
                        END IF
                    NEXT mlSdI%
                END IF
                IF sd_used_history_group% THEN HISTORY_end_group
                INVALIDATE_layers
            END IF
            IF grpExp317% > 0 THEN CMD_group_restore_after_op grpExp317%
            SkipScale317:
        CASE 318  ' Scale +50%
            ' Symbol child: adjust scale factor non-destructively (integer steps)
            IF CURRENT_LAYER% >= 1 THEN
                IF CURRENT_LAYER% <= MAX_LAYERS THEN
                    IF LAYERS(CURRENT_LAYER%).layerType% = LAYER_TYPE_SYMBOL_CHILD THEN
                        DIM sc318x AS SINGLE, sc318y AS SINGLE
                        sc318x! = LAYERS(CURRENT_LAYER%).symbolScaleX!
                        sc318y! = LAYERS(CURRENT_LAYER%).symbolScaleY!
                        ' Increase absolute value by 1, maximum 10.0
                        IF sc318x! > 0 THEN
                            sc318x! = sc318x! + 1.0!
                            IF sc318x! > 10.0! THEN sc318x! = 10.0!
                        ELSE
                            sc318x! = sc318x! - 1.0!
                            IF sc318x! < -10.0! THEN sc318x! = -10.0!
                        END IF
                        IF sc318y! > 0 THEN
                            sc318y! = sc318y! + 1.0!
                            IF sc318y! > 10.0! THEN sc318y! = 10.0!
                        ELSE
                            sc318y! = sc318y! - 1.0!
                            IF sc318y! < -10.0! THEN sc318y! = -10.0!
                        END IF
                        LAYERS(CURRENT_LAYER%).symbolScaleX! = sc318x!
                        LAYERS(CURRENT_LAYER%).symbolScaleY! = sc318y!
                        SYMBOL_render_child CURRENT_LAYER%
                        BLEND_invalidate_cache
                        FRAME_IDLE% = FALSE
                        INVALIDATE_scene
                        SOUND_play SND_TRANSFORM
                        GOTO SkipScale318
                    END IF
                END IF
            END IF
            DIM grpExp318 AS INTEGER
            grpExp318% = CMD_group_expand_for_op%
            SOUND_play SND_TRANSFORM
            IF CUSTOM_BRUSH_is_active% THEN
                CUSTOM_BRUSH_scale_up
            ELSEIF MOVE.ACTIVE AND MOVE.SELECTION_IMAGE < -1 THEN
                ' Scale the floating move selection up by 50% (from original to prevent generation loss)
                MOVE.SCALE_FACTOR = MOVE.SCALE_FACTOR * 1.5
                DIM suNewW AS INTEGER, suNewH AS INTEGER
                suNewW% = INT(MOVE.ORIGINAL_IMG_W * MOVE.SCALE_FACTOR)
                suNewH% = INT(MOVE.ORIGINAL_IMG_H * MOVE.SCALE_FACTOR)
                IF suNewW% < 1 THEN suNewW% = 1
                IF suNewH% < 1 THEN suNewH% = 1
                DIM suMoveTmp AS LONG
                suMoveTmp& = _NEWIMAGE(suNewW%, suNewH%, 32)
                _DONTBLEND suMoveTmp&
                _PUTIMAGE (0, 0)-(suNewW% - 1, suNewH% - 1), MOVE.ORIGINAL_IMAGE, suMoveTmp&
                _BLEND suMoveTmp&
                IF MOVE.SELECTION_IMAGE < -1 THEN _FREEIMAGE MOVE.SELECTION_IMAGE
                MOVE.SELECTION_IMAGE = suMoveTmp&
                MOVE.CURRENT_W = suNewW%
                MOVE.CURRENT_H = suNewH%
                MOVE.SELECTION_W = suNewW%
                MOVE.SELECTION_H = suNewH%
                MARQUEE.BOX.w = suNewW%
                MARQUEE.BOX.h = suNewH%
                MOVE_update_preview_buffer
                INVALIDATE_scene
            ELSEIF CURRENT_LAYER% > 0 THEN
                DIM suSrc AS LONG
                DIM su_history_before AS LONG
                DIM su_history_flags AS LONG
                DIM su_used_history_group AS INTEGER
                suSrc& = LAYERS(CURRENT_LAYER%).imgHandle&
                su_history_before& = 0
                su_history_flags& = 0
                su_used_history_group% = FALSE
                IF SELECTION_has_active% OR LAYERS(CURRENT_LAYER%).opacityLock% THEN su_history_flags& = su_history_flags& OR HISTORY_FLAG_CLIPPED
                IF NOT HISTORY_IN_PROGRESS% AND LAYERS(CURRENT_LAYER%).historyId& > 0 AND suSrc& < -1 THEN
                    su_history_before& = _COPYIMAGE(suSrc&, 32)
                END IF
                IF MULTI_SELECT_has_any% AND NOT HISTORY_IN_PROGRESS% THEN
                    HISTORY_begin_group
                    su_used_history_group% = HISTORY_GROUP_ACTIVE%
                END IF
                IF SELECTION_has_active% THEN
                    ' Scale only within selection bounds (150%)
                    DIM suSelW AS INTEGER, suSelH AS INTEGER
                    suSelW% = MARQUEE.BOX.w : suSelH% = MARQUEE.BOX.h
                    DIM suSelNW AS INTEGER, suSelNH AS INTEGER
                    suSelNW% = INT(suSelW% * 1.5)
                    suSelNH% = INT(suSelH% * 1.5)
                    IF suSelNW% < 1 THEN suSelNW% = 1
                    IF suSelNH% < 1 THEN suSelNH% = 1
                    ' Extract selection region
                    DIM suReg AS LONG
                    suReg& = _NEWIMAGE(suSelW%, suSelH%, 32)
                    _DONTBLEND suReg&
                    _PUTIMAGE (0, 0), suSrc&, suReg&, (MARQUEE.BOX.x, MARQUEE.BOX.y)-(MARQUEE.BOX.x + suSelW% - 1, MARQUEE.BOX.y + suSelH% - 1)
                    ' Scale up
                    DIM suScl AS LONG
                    suScl& = _NEWIMAGE(suSelNW%, suSelNH%, 32)
                    _DONTBLEND suScl&
                    _PUTIMAGE (0, 0)-(suSelNW% - 1, suSelNH% - 1), suReg&, suScl&
                    ' Clear selection area on layer
                    DIM oldSuDest AS LONG : oldSuDest& = _DEST
                    _DEST suSrc&
                    _DONTBLEND suSrc&
                    LINE (MARQUEE.BOX.x, MARQUEE.BOX.y)-(MARQUEE.BOX.x + suSelW% - 1, MARQUEE.BOX.y + suSelH% - 1), _RGBA32(0, 0, 0, 0), BF
                    ' Center scaled content on selection centre; overflow clips to canvas only
                    DIM suSrcX AS INTEGER, suSrcY AS INTEGER
                    DIM suDstX AS INTEGER, suDstY AS INTEGER
                    DIM suCpW AS INTEGER, suCpH AS INTEGER
                    DIM suCanvW AS INTEGER, suCanvH AS INTEGER
                    suCanvW% = _WIDTH(suSrc&) : suCanvH% = _HEIGHT(suSrc&)
                    ' Top-left when scaled image is centered on the selection centre
                    suDstX% = MARQUEE.BOX.x + (suSelW% - suSelNW%) \ 2
                    suDstY% = MARQUEE.BOX.y + (suSelH% - suSelNH%) \ 2
                    suSrcX% = 0 : suSrcY% = 0
                    suCpW% = suSelNW% : suCpH% = suSelNH%
                    ' Clip to canvas left / top
                    IF suDstX% < 0 THEN suSrcX% = -suDstX% : suCpW% = suCpW% - suSrcX% : suDstX% = 0
                    IF suDstY% < 0 THEN suSrcY% = -suDstY% : suCpH% = suCpH% - suSrcY% : suDstY% = 0
                    ' Clip to canvas right / bottom
                    IF suDstX% + suCpW% > suCanvW% THEN suCpW% = suCanvW% - suDstX%
                    IF suDstY% + suCpH% > suCanvH% THEN suCpH% = suCanvH% - suDstY%
                    IF suCpW% > 0 AND suCpH% > 0 THEN
                        _PUTIMAGE (suDstX%, suDstY%)-(suDstX% + suCpW% - 1, suDstY% + suCpH% - 1), suScl&, suSrc&, (suSrcX%, suSrcY%)-(suSrcX% + suCpW% - 1, suSrcY% + suCpH% - 1)
                    END IF
                    _BLEND suSrc&
                    _DEST oldSuDest&
                    IF suReg& < -1 THEN _FREEIMAGE suReg&
                    IF suScl& < -1 THEN _FREEIMAGE suScl&
                    ' Update marquee box to the actual drawn region (already canvas-clamped)
                    MARQUEE.BOX.x = suDstX% : MARQUEE.BOX.y = suDstY%
                    MARQUEE.BOX.w = suCpW% : MARQUEE.BOX.h = suCpH%
                ELSE
                    ' Scale entire layer content up by 50% (from original to prevent generation loss)
                    DIM suLW AS LONG, suLH AS LONG
                    suLW& = _WIDTH(suSrc&)
                    suLH& = _HEIGHT(suSrc&)
                    ' Save original on first scale operation for this layer
                    IF SCALE_ORIGINAL_IMAGE = 0 OR SCALE_ORIGINAL_LAYER <> CURRENT_LAYER% THEN
                        IF SCALE_ORIGINAL_IMAGE < -1 THEN _FREEIMAGE SCALE_ORIGINAL_IMAGE
                        SCALE_ORIGINAL_IMAGE = _COPYIMAGE(suSrc&)
                        SCALE_ORIGINAL_LAYER = CURRENT_LAYER%
                        SCALE_FACTOR_LAYER = 1.0
                    END IF
                    SCALE_FACTOR_LAYER = SCALE_FACTOR_LAYER * 1.5
                    DIM suLNW AS INTEGER, suLNH AS INTEGER
                    suLNW% = INT(suLW& * SCALE_FACTOR_LAYER)
                    suLNH% = INT(suLH& * SCALE_FACTOR_LAYER)
                    IF suLNW% < 1 THEN suLNW% = 1
                    IF suLNH% < 1 THEN suLNH% = 1
                    ' Resample from original and center on layer
                    DIM suLTmp AS LONG
                    suLTmp& = _NEWIMAGE(suLNW%, suLNH%, 32)
                    _DONTBLEND suLTmp&
                    _PUTIMAGE (0, 0)-(suLNW% - 1, suLNH% - 1), SCALE_ORIGINAL_IMAGE, suLTmp&
                    ' Clear layer and center scaled content (overflow clips to layer edges)
                    DIM oldSuLDest AS LONG : oldSuLDest& = _DEST
                    _DEST suSrc&
                    _DONTBLEND suSrc&
                    CLS , _RGBA32(0, 0, 0, 0)
                    DIM suOverX AS INTEGER, suOverY AS INTEGER
                    suOverX% = (suLNW% - suLW&) \ 2
                    suOverY% = (suLNH% - suLH&) \ 2
                    _PUTIMAGE (0, 0)-(suLW& - 1, suLH& - 1), suLTmp&, suSrc&, (suOverX%, suOverY%)-(suOverX% + suLW& - 1, suOverY% + suLH& - 1)
                    _BLEND suSrc&
                    _DEST oldSuLDest&
                    IF suLTmp& < -1 THEN _FREEIMAGE suLTmp&
                END IF
                IF su_history_before& < -1 THEN
                    HISTORY_record_transform LAYERS(CURRENT_LAYER%).historyId&, CURRENT_LAYER%, su_history_flags&, su_history_before&, "Scale +50%"
                    HISTORY_saved_this_frame% = TRUE
                END IF
                LAYERS(CURRENT_LAYER%).contentDirty% = TRUE
                ' Apply scale +50% to all other multi-selected layers
                IF MULTI_SELECT_has_any% THEN
                    DIM mlSuI AS INTEGER
                    FOR mlSuI% = 1 TO MAX_LAYERS
                        IF MULTI_SELECT_LAYERS(mlSuI%) AND mlSuI% <> CURRENT_LAYER% THEN
                            CMD_ml_scale mlSuI%, 1.5!, su_history_flags&, "Scale +50%"
                        END IF
                    NEXT mlSuI%
                END IF
                IF su_used_history_group% THEN HISTORY_end_group
                INVALIDATE_layers
            END IF
            IF grpExp318% > 0 THEN CMD_group_restore_after_op grpExp318%
            SkipScale318:
        CASE 319  ' Rotate 90 CW
            DIM grpExp319 AS INTEGER
            grpExp319% = CMD_group_expand_for_op%
            SOUND_play SND_TRANSFORM
            IF CUSTOM_BRUSH_is_active% THEN
                CUSTOM_BRUSH_rotate_cw
            ELSEIF MOVE.ACTIVE AND MOVE.SELECTION_IMAGE < -1 THEN
                ' Rotate the floating move selection 90 CW
                DIM rcMoveW AS INTEGER, rcMoveH AS INTEGER
                rcMoveW% = _WIDTH(MOVE.SELECTION_IMAGE)
                rcMoveH% = _HEIGHT(MOVE.SELECTION_IMAGE)
                DIM rcNew AS LONG
                rcNew& = _NEWIMAGE(rcMoveH%, rcMoveW%, 32)
                DIM rcOldSrc AS LONG, rcOldDst AS LONG
                rcOldSrc& = _SOURCE : rcOldDst& = _DEST
                _SOURCE MOVE.SELECTION_IMAGE
                _DEST rcNew&
                _DONTBLEND rcNew&
                CLS , _RGBA32(0, 0, 0, 0)
                DIM rcPx AS INTEGER, rcPy AS INTEGER
                DIM rcPixel AS _UNSIGNED LONG
                FOR rcPy% = 0 TO rcMoveH% - 1
                    FOR rcPx% = 0 TO rcMoveW% - 1
                        rcPixel~& = POINT(rcPx%, rcPy%)
                        PSET (rcMoveH% - 1 - rcPy%, rcPx%), rcPixel~&
                    NEXT rcPx%
                NEXT rcPy%
                _BLEND rcNew&
                _SOURCE rcOldSrc& : _DEST rcOldDst&
                IF MOVE.SELECTION_IMAGE < -1 THEN _FREEIMAGE MOVE.SELECTION_IMAGE
                MOVE.SELECTION_IMAGE = rcNew&
                ' Swap dimensions
                MOVE.CURRENT_W = rcMoveH%
                MOVE.CURRENT_H = rcMoveW%
                MOVE.SELECTION_W = rcMoveH%
                MOVE.SELECTION_H = rcMoveW%
                MARQUEE.BOX.w = rcMoveH%
                MARQUEE.BOX.h = rcMoveW%
                MOVE_update_preview_buffer
                INVALIDATE_scene
            ELSEIF CURRENT_LAYER% > 0 THEN
                DIM rcSrc AS LONG
                DIM rc_history_before AS LONG
                DIM rc_history_flags AS LONG
                DIM rc_used_history_group AS INTEGER
                rcSrc& = LAYERS(CURRENT_LAYER%).imgHandle&
                rc_history_before& = 0
                rc_history_flags& = 0
                rc_used_history_group% = FALSE
                IF SELECTION_has_active% OR LAYERS(CURRENT_LAYER%).opacityLock% THEN rc_history_flags& = rc_history_flags& OR HISTORY_FLAG_CLIPPED
                IF NOT HISTORY_IN_PROGRESS% AND LAYERS(CURRENT_LAYER%).historyId& > 0 AND rcSrc& < -1 THEN
                    rc_history_before& = _COPYIMAGE(rcSrc&, 32)
                END IF
                IF MULTI_SELECT_has_any% AND NOT HISTORY_IN_PROGRESS% THEN
                    HISTORY_begin_group
                    rc_used_history_group% = HISTORY_GROUP_ACTIVE%
                END IF
                IF SELECTION_has_active% THEN
                    ' Rotate only within selection bounds
                    DIM rcSelW AS INTEGER, rcSelH AS INTEGER
                    rcSelW% = MARQUEE.BOX.w : rcSelH% = MARQUEE.BOX.h
                    ' Extract selection region
                    DIM rcReg AS LONG
                    rcReg& = _NEWIMAGE(rcSelW%, rcSelH%, 32)
                    _DONTBLEND rcReg&
                    _PUTIMAGE (0, 0), rcSrc&, rcReg&, (MARQUEE.BOX.x, MARQUEE.BOX.y)-(MARQUEE.BOX.x + rcSelW% - 1, MARQUEE.BOX.y + rcSelH% - 1)
                    ' Create rotated image (swapped dimensions)
                    DIM rcRot AS LONG
                    rcRot& = _NEWIMAGE(rcSelH%, rcSelW%, 32)
                    DIM rcRotOS AS LONG, rcRotOD AS LONG
                    rcRotOS& = _SOURCE : rcRotOD& = _DEST
                    _SOURCE rcReg& : _DEST rcRot&
                    _DONTBLEND rcRot&
                    CLS , _RGBA32(0, 0, 0, 0)
                    DIM rcSPx AS INTEGER, rcSPy AS INTEGER
                    DIM rcSPixel AS _UNSIGNED LONG
                    FOR rcSPy% = 0 TO rcSelH% - 1
                        FOR rcSPx% = 0 TO rcSelW% - 1
                            rcSPixel~& = POINT(rcSPx%, rcSPy%)
                            PSET (rcSelH% - 1 - rcSPy%, rcSPx%), rcSPixel~&
                        NEXT rcSPx%
                    NEXT rcSPy%
                    _BLEND rcRot&
                    _SOURCE rcRotOS& : _DEST rcRotOD&
                    ' Clear selection area; paste rotated content centred on selection centre,
                    ' clipping only to canvas bounds (not selection bounds)
                    DIM rcD AS LONG : rcD& = _DEST
                    _DEST rcSrc&
                    _DONTBLEND rcSrc&
                    LINE (MARQUEE.BOX.x, MARQUEE.BOX.y)-(MARQUEE.BOX.x + rcSelW% - 1, MARQUEE.BOX.y + rcSelH% - 1), _RGBA32(0, 0, 0, 0), BF
                    DIM rcCanvW AS INTEGER, rcCanvH AS INTEGER
                    rcCanvW% = _WIDTH(rcSrc&) : rcCanvH% = _HEIGHT(rcSrc&)
                    ' Rotated image is rcSelH% x rcSelW%; centre it on the selection centre
                    DIM rcSrcX1 AS INTEGER, rcSrcY1 AS INTEGER
                    DIM rcDstX1 AS INTEGER, rcDstY1 AS INTEGER
                    DIM rcDrawW AS INTEGER, rcDrawH AS INTEGER
                    rcDstX1% = MARQUEE.BOX.x + (rcSelW% - rcSelH%) \ 2
                    rcDstY1% = MARQUEE.BOX.y + (rcSelH% - rcSelW%) \ 2
                    rcSrcX1% = 0 : rcSrcY1% = 0
                    rcDrawW% = rcSelH% : rcDrawH% = rcSelW%
                    ' Clip to canvas left / top
                    IF rcDstX1% < 0 THEN rcSrcX1% = -rcDstX1% : rcDrawW% = rcDrawW% - rcSrcX1% : rcDstX1% = 0
                    IF rcDstY1% < 0 THEN rcSrcY1% = -rcDstY1% : rcDrawH% = rcDrawH% - rcSrcY1% : rcDstY1% = 0
                    ' Clip to canvas right / bottom
                    IF rcDstX1% + rcDrawW% > rcCanvW% THEN rcDrawW% = rcCanvW% - rcDstX1%
                    IF rcDstY1% + rcDrawH% > rcCanvH% THEN rcDrawH% = rcCanvH% - rcDstY1%
                    IF rcDrawW% > 0 AND rcDrawH% > 0 THEN
                        _PUTIMAGE (rcDstX1%, rcDstY1%)-(rcDstX1% + rcDrawW% - 1, rcDstY1% + rcDrawH% - 1), rcRot&, rcSrc&, (rcSrcX1%, rcSrcY1%)-(rcSrcX1% + rcDrawW% - 1, rcSrcY1% + rcDrawH% - 1)
                    END IF
                    _BLEND rcSrc&
                    _DEST rcD&
                    IF rcReg& < -1 THEN _FREEIMAGE rcReg&
                    IF rcRot& < -1 THEN _FREEIMAGE rcRot&
                    ' Update marquee box: swap w/h and recentre on original selection centre,
                    ' clamped to canvas so the box always matches the rotated pixel content
                    DIM rcNewBx AS INTEGER, rcNewBy AS INTEGER
                    DIM rcNewBw AS INTEGER, rcNewBh AS INTEGER
                    rcNewBx% = MARQUEE.BOX.x + (rcSelW% - rcSelH%) \ 2
                    rcNewBy% = MARQUEE.BOX.y + (rcSelH% - rcSelW%) \ 2
                    rcNewBw% = rcSelH% : rcNewBh% = rcSelW%
                    IF rcNewBx% < 0 THEN rcNewBx% = 0
                    IF rcNewBy% < 0 THEN rcNewBy% = 0
                    IF rcNewBx% + rcNewBw% > rcCanvW% THEN rcNewBw% = rcCanvW% - rcNewBx%
                    IF rcNewBy% + rcNewBh% > rcCanvH% THEN rcNewBh% = rcCanvH% - rcNewBy%
                    MARQUEE.BOX.x = rcNewBx% : MARQUEE.BOX.y = rcNewBy%
                    MARQUEE.BOX.w = rcNewBw% : MARQUEE.BOX.h = rcNewBh%
                ELSE
                    ' Rotate entire layer 90 CW
                    DIM rcLW AS LONG, rcLH AS LONG
                    rcLW& = _WIDTH(rcSrc&) : rcLH& = _HEIGHT(rcSrc&)
                    DIM rcLRot AS LONG
                    rcLRot& = _NEWIMAGE(rcLH&, rcLW&, 32)
                    DIM rcLOS AS LONG, rcLOD AS LONG
                    rcLOS& = _SOURCE : rcLOD& = _DEST
                    _SOURCE rcSrc& : _DEST rcLRot&
                    _DONTBLEND rcLRot&
                    CLS , _RGBA32(0, 0, 0, 0)
                    DIM rcLPx AS INTEGER, rcLPy AS INTEGER
                    DIM rcLPixel AS _UNSIGNED LONG
                    FOR rcLPy% = 0 TO rcLH& - 1
                        FOR rcLPx% = 0 TO rcLW& - 1
                            rcLPixel~& = POINT(rcLPx%, rcLPy%)
                            PSET (rcLH& - 1 - rcLPy%, rcLPx%), rcLPixel~&
                        NEXT rcLPx%
                    NEXT rcLPy%
                    _BLEND rcLRot&
                    _SOURCE rcLOS&
                    ' Copy rotated content back, centered (clips to layer size)
                    _DEST rcSrc&
                    _DONTBLEND rcSrc&
                    CLS , _RGBA32(0, 0, 0, 0)
                    DIM rcLCx AS INTEGER, rcLCy AS INTEGER
                    rcLCx% = (rcLW& - rcLH&) \ 2
                    rcLCy% = (rcLH& - rcLW&) \ 2
                    DIM rcLSx AS INTEGER, rcLSy AS INTEGER
                    DIM rcLDw AS INTEGER, rcLDh AS INTEGER
                    rcLSx% = 0 : rcLSy% = 0
                    DIM rcLDx AS INTEGER, rcLDy AS INTEGER
                    rcLDx% = rcLCx% : rcLDy% = rcLCy%
                    rcLDw% = rcLH& : rcLDh% = rcLW&
                    IF rcLDx% < 0 THEN
                        rcLSx% = -rcLDx%
                        rcLDw% = rcLDw% - rcLSx%
                        rcLDx% = 0
                    END IF
                    IF rcLDy% < 0 THEN
                        rcLSy% = -rcLDy%
                        rcLDh% = rcLDh% - rcLSy%
                        rcLDy% = 0
                    END IF
                    IF rcLDx% + rcLDw% > rcLW& THEN rcLDw% = rcLW& - rcLDx%
                    IF rcLDy% + rcLDh% > rcLH& THEN rcLDh% = rcLH& - rcLDy%
                    IF rcLDw% > 0 AND rcLDh% > 0 THEN
                        _PUTIMAGE (rcLDx%, rcLDy%)-(rcLDx% + rcLDw% - 1, rcLDy% + rcLDh% - 1), rcLRot&, rcSrc&, (rcLSx%, rcLSy%)-(rcLSx% + rcLDw% - 1, rcLSy% + rcLDh% - 1)
                    END IF
                    _BLEND rcSrc&
                    _DEST rcLOD&
                    IF rcLRot& < -1 THEN _FREEIMAGE rcLRot&
                END IF
                IF rc_history_before& < -1 THEN
                    HISTORY_record_transform LAYERS(CURRENT_LAYER%).historyId&, CURRENT_LAYER%, rc_history_flags&, rc_history_before&, "Rotate 90 CW"
                    HISTORY_saved_this_frame% = TRUE
                END IF
                LAYERS(CURRENT_LAYER%).contentDirty% = TRUE
                ' Apply rotate CW to all other multi-selected layers
                IF MULTI_SELECT_has_any% THEN
                    DIM mlRcI AS INTEGER
                    FOR mlRcI% = 1 TO MAX_LAYERS
                        IF MULTI_SELECT_LAYERS(mlRcI%) AND mlRcI% <> CURRENT_LAYER% THEN
                            CMD_ml_rotate_cw mlRcI%, rc_history_flags&, "Rotate 90 CW"
                        END IF
                    NEXT mlRcI%
                END IF
                IF rc_used_history_group% THEN HISTORY_end_group
                INVALIDATE_layers
            END IF
            IF grpExp319% > 0 THEN CMD_group_restore_after_op grpExp319%
        CASE 320  ' Rotate 90 CCW
            DIM grpExp320 AS INTEGER
            grpExp320% = CMD_group_expand_for_op%
            SOUND_play SND_TRANSFORM
            IF CUSTOM_BRUSH_is_active% THEN
                CUSTOM_BRUSH_rotate_ccw
            ELSEIF MOVE.ACTIVE AND MOVE.SELECTION_IMAGE < -1 THEN
                ' Rotate the floating move selection 90 CCW
                DIM rccMoveW AS INTEGER, rccMoveH AS INTEGER
                rccMoveW% = _WIDTH(MOVE.SELECTION_IMAGE)
                rccMoveH% = _HEIGHT(MOVE.SELECTION_IMAGE)
                DIM rccNew AS LONG
                rccNew& = _NEWIMAGE(rccMoveH%, rccMoveW%, 32)
                DIM rccOldSrc AS LONG, rccOldDst AS LONG
                rccOldSrc& = _SOURCE : rccOldDst& = _DEST
                _SOURCE MOVE.SELECTION_IMAGE
                _DEST rccNew&
                _DONTBLEND rccNew&
                CLS , _RGBA32(0, 0, 0, 0)
                DIM rccPx AS INTEGER, rccPy AS INTEGER
                DIM rccPixel AS _UNSIGNED LONG
                FOR rccPy% = 0 TO rccMoveH% - 1
                    FOR rccPx% = 0 TO rccMoveW% - 1
                        rccPixel~& = POINT(rccPx%, rccPy%)
                        PSET (rccPy%, rccMoveW% - 1 - rccPx%), rccPixel~&
                    NEXT rccPx%
                NEXT rccPy%
                _BLEND rccNew&
                _SOURCE rccOldSrc& : _DEST rccOldDst&
                IF MOVE.SELECTION_IMAGE < -1 THEN _FREEIMAGE MOVE.SELECTION_IMAGE
                MOVE.SELECTION_IMAGE = rccNew&
                ' Swap dimensions
                MOVE.CURRENT_W = rccMoveH%
                MOVE.CURRENT_H = rccMoveW%
                MOVE.SELECTION_W = rccMoveH%
                MOVE.SELECTION_H = rccMoveW%
                MARQUEE.BOX.w = rccMoveH%
                MARQUEE.BOX.h = rccMoveW%
                MOVE_update_preview_buffer
                INVALIDATE_scene
            ELSEIF CURRENT_LAYER% > 0 THEN
                DIM rccSrc AS LONG
                DIM rcc_history_before AS LONG
                DIM rcc_history_flags AS LONG
                DIM rcc_used_history_group AS INTEGER
                rccSrc& = LAYERS(CURRENT_LAYER%).imgHandle&
                rcc_history_before& = 0
                rcc_history_flags& = 0
                rcc_used_history_group% = FALSE
                IF SELECTION_has_active% OR LAYERS(CURRENT_LAYER%).opacityLock% THEN rcc_history_flags& = rcc_history_flags& OR HISTORY_FLAG_CLIPPED
                IF NOT HISTORY_IN_PROGRESS% AND LAYERS(CURRENT_LAYER%).historyId& > 0 AND rccSrc& < -1 THEN
                    rcc_history_before& = _COPYIMAGE(rccSrc&, 32)
                END IF
                IF MULTI_SELECT_has_any% AND NOT HISTORY_IN_PROGRESS% THEN
                    HISTORY_begin_group
                    rcc_used_history_group% = HISTORY_GROUP_ACTIVE%
                END IF
                IF SELECTION_has_active% THEN
                    ' Rotate only within selection bounds
                    DIM rccSelW AS INTEGER, rccSelH AS INTEGER
                    rccSelW% = MARQUEE.BOX.w : rccSelH% = MARQUEE.BOX.h
                    DIM rccReg AS LONG
                    rccReg& = _NEWIMAGE(rccSelW%, rccSelH%, 32)
                    _DONTBLEND rccReg&
                    _PUTIMAGE (0, 0), rccSrc&, rccReg&, (MARQUEE.BOX.x, MARQUEE.BOX.y)-(MARQUEE.BOX.x + rccSelW% - 1, MARQUEE.BOX.y + rccSelH% - 1)
                    DIM rccRot AS LONG
                    rccRot& = _NEWIMAGE(rccSelH%, rccSelW%, 32)
                    DIM rccRotOS AS LONG, rccRotOD AS LONG
                    rccRotOS& = _SOURCE : rccRotOD& = _DEST
                    _SOURCE rccReg& : _DEST rccRot&
                    _DONTBLEND rccRot&
                    CLS , _RGBA32(0, 0, 0, 0)
                    DIM rccSPx AS INTEGER, rccSPy AS INTEGER
                    DIM rccSPixel AS _UNSIGNED LONG
                    FOR rccSPy% = 0 TO rccSelH% - 1
                        FOR rccSPx% = 0 TO rccSelW% - 1
                            rccSPixel~& = POINT(rccSPx%, rccSPy%)
                            PSET (rccSPy%, rccSelW% - 1 - rccSPx%), rccSPixel~&
                        NEXT rccSPx%
                    NEXT rccSPy%
                    _BLEND rccRot&
                    _SOURCE rccRotOS& : _DEST rccRotOD&
                    ' Clear selection area; paste rotated content centred on selection centre,
                    ' clipping only to canvas bounds (not selection bounds)
                    DIM rccD AS LONG : rccD& = _DEST
                    _DEST rccSrc&
                    _DONTBLEND rccSrc&
                    LINE (MARQUEE.BOX.x, MARQUEE.BOX.y)-(MARQUEE.BOX.x + rccSelW% - 1, MARQUEE.BOX.y + rccSelH% - 1), _RGBA32(0, 0, 0, 0), BF
                    DIM rccCanvW AS INTEGER, rccCanvH AS INTEGER
                    rccCanvW% = _WIDTH(rccSrc&) : rccCanvH% = _HEIGHT(rccSrc&)
                    ' Rotated image is rccSelH% x rccSelW%; centre it on the selection centre
                    DIM rccSrcX1 AS INTEGER, rccSrcY1 AS INTEGER
                    DIM rccDstX1 AS INTEGER, rccDstY1 AS INTEGER
                    DIM rccDrawW AS INTEGER, rccDrawH AS INTEGER
                    rccDstX1% = MARQUEE.BOX.x + (rccSelW% - rccSelH%) \ 2
                    rccDstY1% = MARQUEE.BOX.y + (rccSelH% - rccSelW%) \ 2
                    rccSrcX1% = 0 : rccSrcY1% = 0
                    rccDrawW% = rccSelH% : rccDrawH% = rccSelW%
                    ' Clip to canvas left / top
                    IF rccDstX1% < 0 THEN rccSrcX1% = -rccDstX1% : rccDrawW% = rccDrawW% - rccSrcX1% : rccDstX1% = 0
                    IF rccDstY1% < 0 THEN rccSrcY1% = -rccDstY1% : rccDrawH% = rccDrawH% - rccSrcY1% : rccDstY1% = 0
                    ' Clip to canvas right / bottom
                    IF rccDstX1% + rccDrawW% > rccCanvW% THEN rccDrawW% = rccCanvW% - rccDstX1%
                    IF rccDstY1% + rccDrawH% > rccCanvH% THEN rccDrawH% = rccCanvH% - rccDstY1%
                    IF rccDrawW% > 0 AND rccDrawH% > 0 THEN
                        _PUTIMAGE (rccDstX1%, rccDstY1%)-(rccDstX1% + rccDrawW% - 1, rccDstY1% + rccDrawH% - 1), rccRot&, rccSrc&, (rccSrcX1%, rccSrcY1%)-(rccSrcX1% + rccDrawW% - 1, rccSrcY1% + rccDrawH% - 1)
                    END IF
                    _BLEND rccSrc&
                    _DEST rccD&
                    IF rccReg& < -1 THEN _FREEIMAGE rccReg&
                    IF rccRot& < -1 THEN _FREEIMAGE rccRot&
                    ' Update marquee box: swap w/h and recentre on original selection centre,
                    ' clamped to canvas so the box always matches the rotated pixel content
                    DIM rccNewBx AS INTEGER, rccNewBy AS INTEGER
                    DIM rccNewBw AS INTEGER, rccNewBh AS INTEGER
                    rccNewBx% = MARQUEE.BOX.x + (rccSelW% - rccSelH%) \ 2
                    rccNewBy% = MARQUEE.BOX.y + (rccSelH% - rccSelW%) \ 2
                    rccNewBw% = rccSelH% : rccNewBh% = rccSelW%
                    IF rccNewBx% < 0 THEN rccNewBx% = 0
                    IF rccNewBy% < 0 THEN rccNewBy% = 0
                    IF rccNewBx% + rccNewBw% > rccCanvW% THEN rccNewBw% = rccCanvW% - rccNewBx%
                    IF rccNewBy% + rccNewBh% > rccCanvH% THEN rccNewBh% = rccCanvH% - rccNewBy%
                    MARQUEE.BOX.x = rccNewBx% : MARQUEE.BOX.y = rccNewBy%
                    MARQUEE.BOX.w = rccNewBw% : MARQUEE.BOX.h = rccNewBh%
                ELSE
                    ' Rotate entire layer 90 CCW
                    DIM rccLW AS LONG, rccLH AS LONG
                    rccLW& = _WIDTH(rccSrc&) : rccLH& = _HEIGHT(rccSrc&)
                    DIM rccLRot AS LONG
                    rccLRot& = _NEWIMAGE(rccLH&, rccLW&, 32)
                    DIM rccLOS AS LONG, rccLOD AS LONG
                    rccLOS& = _SOURCE : rccLOD& = _DEST
                    _SOURCE rccSrc& : _DEST rccLRot&
                    _DONTBLEND rccLRot&
                    CLS , _RGBA32(0, 0, 0, 0)
                    DIM rccLPx AS INTEGER, rccLPy AS INTEGER
                    DIM rccLPixel AS _UNSIGNED LONG
                    FOR rccLPy% = 0 TO rccLH& - 1
                        FOR rccLPx% = 0 TO rccLW& - 1
                            rccLPixel~& = POINT(rccLPx%, rccLPy%)
                            PSET (rccLPy%, rccLW& - 1 - rccLPx%), rccLPixel~&
                        NEXT rccLPx%
                    NEXT rccLPy%
                    _BLEND rccLRot&
                    _SOURCE rccLOS&
                    _DEST rccSrc&
                    _DONTBLEND rccSrc&
                    CLS , _RGBA32(0, 0, 0, 0)
                    DIM rccLCx AS INTEGER, rccLCy AS INTEGER
                    rccLCx% = (rccLW& - rccLH&) \ 2
                    rccLCy% = (rccLH& - rccLW&) \ 2
                    DIM rccLSx AS INTEGER, rccLSy AS INTEGER
                    DIM rccLDw AS INTEGER, rccLDh AS INTEGER
                    rccLSx% = 0 : rccLSy% = 0
                    DIM rccLDx AS INTEGER, rccLDy AS INTEGER
                    rccLDx% = rccLCx% : rccLDy% = rccLCy%
                    rccLDw% = rccLH& : rccLDh% = rccLW&
                    IF rccLDx% < 0 THEN
                        rccLSx% = -rccLDx%
                        rccLDw% = rccLDw% - rccLSx%
                        rccLDx% = 0
                    END IF
                    IF rccLDy% < 0 THEN
                        rccLSy% = -rccLDy%
                        rccLDh% = rccLDh% - rccLSy%
                        rccLDy% = 0
                    END IF
                    IF rccLDx% + rccLDw% > rccLW& THEN rccLDw% = rccLW& - rccLDx%
                    IF rccLDy% + rccLDh% > rccLH& THEN rccLDh% = rccLH& - rccLDy%
                    IF rccLDw% > 0 AND rccLDh% > 0 THEN
                        _PUTIMAGE (rccLDx%, rccLDy%)-(rccLDx% + rccLDw% - 1, rccLDy% + rccLDh% - 1), rccLRot&, rccSrc&, (rccLSx%, rccLSy%)-(rccLSx% + rccLDw% - 1, rccLSy% + rccLDh% - 1)
                    END IF
                    _BLEND rccSrc&
                    _DEST rccLOD&
                    IF rccLRot& < -1 THEN _FREEIMAGE rccLRot&
                END IF
                IF rcc_history_before& < -1 THEN
                    HISTORY_record_transform LAYERS(CURRENT_LAYER%).historyId&, CURRENT_LAYER%, rcc_history_flags&, rcc_history_before&, "Rotate 90 CCW"
                    HISTORY_saved_this_frame% = TRUE
                END IF
                LAYERS(CURRENT_LAYER%).contentDirty% = TRUE
                ' Apply rotate CCW to all other multi-selected layers
                IF MULTI_SELECT_has_any% THEN
                    DIM mlRccI AS INTEGER
                    FOR mlRccI% = 1 TO MAX_LAYERS
                        IF MULTI_SELECT_LAYERS(mlRccI%) AND mlRccI% <> CURRENT_LAYER% THEN
                            CMD_ml_rotate_ccw mlRccI%, rcc_history_flags&, "Rotate 90 CCW"
                        END IF
                    NEXT mlRccI%
                END IF
                IF rcc_used_history_group% THEN HISTORY_end_group
                INVALIDATE_layers
            END IF
            IF grpExp320% > 0 THEN CMD_group_restore_after_op grpExp320%
        CASE 411  ' Toggle Menu Bar
            SCRN.showMenubar% = NOT SCRN.showMenubar%
            MENU_BAR.visible% = SCRN.showMenubar%
            IF NOT SCRN.showMenubar% THEN
                SCRN.menubarManuallyHidden% = TRUE
                MENUBAR_close_all
            ELSE
                SCRN.menubarManuallyHidden% = FALSE
            END IF
            GUI_NEEDS_REDRAW% = TRUE
            SCENE_DIRTY% = TRUE
        CASE 412  ' Toggle Brush Cursors
            POINTER.HIDDEN = NOT POINTER.HIDDEN
            ' Sync brush edge preview: visible when cursors are on
            BRUSH_SIZE.PREVIEW = NOT POINTER.HIDDEN
            GUI_NEEDS_REDRAW% = TRUE
            FRAME_IDLE% = FALSE
        CASE 413  ' Reset Canvas Position
            SCRN.zoom! = 1.0
            SCRN.offsetX% = 0
            SCRN.offsetY% = 0
            SCENE_DIRTY% = TRUE
            GUI_NEEDS_REDRAW% = TRUE
        CASE 414  ' Toggle Angle Snap: Degrees mode
            CFG.ANGLE_SNAP_PIXEL_ART% = FALSE
            GUI_NEEDS_REDRAW% = TRUE
        CASE 415  ' Toggle Angle Snap: Pixel Art mode
            CFG.ANGLE_SNAP_PIXEL_ART% = TRUE
            GUI_NEEDS_REDRAW% = TRUE
        
        ' ========== REFERENCE IMAGE ==========
        CASE 1501  ' Toggle Reference Image
            REFIMG_toggle
        CASE 1502  ' Load Reference Image
            REFIMG_load
        CASE 1503  ' Clear Reference Image
            REFIMG_clear
        CASE 1504  ' Reposition Reference Image
            REFIMG_reposition_start
        
        ' ========== LAYER (menu-only) ==========
        CASE 708  ' Arrange to Top
            SOUND_play SND_LAYER_OP
            DIM arrI AS INTEGER
            FOR arrI% = 1 TO LAYER_COUNT%
                IF CURRENT_LAYER% > 0 THEN LAYERS_move_up CURRENT_LAYER%
            NEXT arrI%
        CASE 709  ' Arrange to Bottom
            SOUND_play SND_LAYER_OP
            DIM arrJ AS INTEGER
            FOR arrJ% = 1 TO LAYER_COUNT%
                IF CURRENT_LAYER% > 0 THEN LAYERS_move_down CURRENT_LAYER%
            NEXT arrJ%
        CASE 710  ' Export Layer as PNG
            ERR_info "Export layer as PNG: not yet implemented"
        
        ' ========== ALIGN/DISTRIBUTE ==========
        ' Multi-select: align relative to CURRENT_LAYER% (reference); single: align to canvas.
        ' Distribute (1907/1908) spaces layers evenly between extremes.
        CASE 1901, 1902, 1903, 1904, 1905, 1906, 1907, 1908
            DIM grpExp1901 AS INTEGER
            grpExp1901% = CMD_group_expand_for_op%
            DIM algnI AS INTEGER
            DIM algnLayers(1 TO MAX_LAYERS) AS INTEGER
            DIM algnBefore(1 TO MAX_LAYERS) AS LONG
            DIM algnCount AS INTEGER
            DIM algnMulti AS INTEGER
            DIM algnUsedHistoryGroup AS INTEGER
            DIM algnRecorded AS INTEGER
            DIM algnHistoryLabel AS STRING
            algnMulti% = MULTI_SELECT_has_any%
            algnUsedHistoryGroup% = FALSE
            algnRecorded% = FALSE
            SELECT CASE action_id%
                CASE 1901: algnHistoryLabel$ = "Align Left"
                CASE 1902: algnHistoryLabel$ = "Align Center H"
                CASE 1903: algnHistoryLabel$ = "Align Right"
                CASE 1904: algnHistoryLabel$ = "Align Top"
                CASE 1905: algnHistoryLabel$ = "Align Middle V"
                CASE 1906: algnHistoryLabel$ = "Align Bottom"
                CASE 1907: algnHistoryLabel$ = "Distribute H"
                CASE 1908: algnHistoryLabel$ = "Distribute V"
            END SELECT
            ' Collect selected layers
            FOR algnI% = 1 TO MAX_LAYERS
                algnBefore(algnI%) = 0
                IF LAYERS(algnI%).imgHandle& <> 0 THEN
                    IF algnMulti% THEN
                        IF MULTI_SELECT_LAYERS(algnI%) THEN
                            algnCount% = algnCount% + 1
                            algnLayers(algnCount%) = algnI%
                        END IF
                    ELSE
                        IF algnI% = CURRENT_LAYER% THEN
                            algnCount% = algnCount% + 1
                            algnLayers(1) = algnI%
                        END IF
                    END IF
                END IF
            NEXT algnI%

            ' Determine alignment reference
            DIM algRefX AS INTEGER, algRefY AS INTEGER, algRefW AS INTEGER, algRefH AS INTEGER
            DIM algCanvasW AS INTEGER, algCanvasH AS INTEGER
            DIM algnAnchor AS INTEGER
            DIM algScanX AS INTEGER, algScanY AS INTEGER, algScanW AS INTEGER, algScanH AS INTEGER
            DIM algExtreme AS INTEGER, algTestVal AS INTEGER
            DIM algBBx1 AS INTEGER, algBBy1 AS INTEGER, algBBx2 AS INTEGER, algBBy2 AS INTEGER
            algCanvasW% = _WIDTH(LAYER_current_image&)
            algCanvasH% = _HEIGHT(LAYER_current_image&)
            algnAnchor% = 0
            IF algnMulti% THEN
                ' Find direction-appropriate anchor for edge alignments
                IF action_id% = 1901 OR action_id% = 1904 THEN
                    ' Left / Top â€” find minimum X or Y
                    algExtreme% = 32767
                    FOR algnI% = 1 TO algnCount%
                        LAYER_get_content_bounds algnLayers(algnI%), algScanX%, algScanY%, algScanW%, algScanH%
                        IF algScanW% > 0 AND algScanH% > 0 THEN
                            IF action_id% = 1901 THEN algTestVal% = algScanX% ELSE algTestVal% = algScanY%
                            IF algTestVal% < algExtreme% THEN
                                algExtreme% = algTestVal%
                                algnAnchor% = algnLayers(algnI%)
                            END IF
                        END IF
                    NEXT algnI%
                ELSEIF action_id% = 1903 OR action_id% = 1906 THEN
                    ' Right / Bottom â€” find maximum X+W or Y+H
                    algExtreme% = -32768
                    FOR algnI% = 1 TO algnCount%
                        LAYER_get_content_bounds algnLayers(algnI%), algScanX%, algScanY%, algScanW%, algScanH%
                        IF algScanW% > 0 AND algScanH% > 0 THEN
                            IF action_id% = 1903 THEN algTestVal% = algScanX% + algScanW% ELSE algTestVal% = algScanY% + algScanH%
                            IF algTestVal% > algExtreme% THEN
                                algExtreme% = algTestVal%
                                algnAnchor% = algnLayers(algnI%)
                            END IF
                        END IF
                    NEXT algnI%
                END IF
                IF algnAnchor% > 0 THEN
                    ' Use anchor layer content bounds as reference
                    LAYER_get_content_bounds algnAnchor%, algRefX%, algRefY%, algRefW%, algRefH%
                ELSE
                    ' Center / Middle / Distribute â€” use bounding box of all selected
                    algBBx1% = 32767: algBBy1% = 32767
                    algBBx2% = -32768: algBBy2% = -32768
                    FOR algnI% = 1 TO algnCount%
                        LAYER_get_content_bounds algnLayers(algnI%), algScanX%, algScanY%, algScanW%, algScanH%
                        IF algScanW% > 0 AND algScanH% > 0 THEN
                            IF algScanX% < algBBx1% THEN algBBx1% = algScanX%
                            IF algScanY% < algBBy1% THEN algBBy1% = algScanY%
                            IF algScanX% + algScanW% > algBBx2% THEN algBBx2% = algScanX% + algScanW%
                            IF algScanY% + algScanH% > algBBy2% THEN algBBy2% = algScanY% + algScanH%
                        END IF
                    NEXT algnI%
                    algRefX% = algBBx1%: algRefY% = algBBy1%
                    algRefW% = algBBx2% - algBBx1%: algRefH% = algBBy2% - algBBy1%
                END IF
                IF algRefW% <= 0 OR algRefH% <= 0 THEN
                    algRefX% = 0: algRefY% = 0: algRefW% = algCanvasW%: algRefH% = algCanvasH%
                END IF
            ELSE
                ' Single layer: align to canvas bounds
                algRefX% = 0: algRefY% = 0: algRefW% = algCanvasW%: algRefH% = algCanvasH%
            END IF

            IF NOT HISTORY_IN_PROGRESS% THEN
                HISTORY_begin_group
                algnUsedHistoryGroup% = HISTORY_GROUP_ACTIVE%
            END IF

            ' Capture before-images for each affected layer before making changes
            FOR algnI% = 1 TO algnCount%
                DIM algnSnapLayer AS INTEGER
                algnSnapLayer% = algnLayers(algnI%)
                IF LAYERS(algnSnapLayer%).imgHandle& < -1 AND LAYERS(algnSnapLayer%).historyId& > 0 THEN
                    algnBefore(algnSnapLayer%) = _COPYIMAGE(LAYERS(algnSnapLayer%).imgHandle&, 32)
                END IF
            NEXT algnI%

            DIM algBx AS INTEGER, algBy AS INTEGER, algBw AS INTEGER, algBh AS INTEGER
            DIM algDx AS INTEGER, algDy AS INTEGER

            ' ---- Distribute requires sorting by position; handled separately ----
            IF action_id% = 1907 OR action_id% = 1908 THEN
                ' Distribute H (1907) or V (1908)
                ' Gather bounds per selected layer
                DIM distBx(1 TO MAX_LAYERS) AS INTEGER, distBy(1 TO MAX_LAYERS) AS INTEGER
                DIM distBw(1 TO MAX_LAYERS) AS INTEGER, distBh(1 TO MAX_LAYERS) AS INTEGER
                DIM distOrder(1 TO MAX_LAYERS) AS INTEGER  ' indices into algnLayers, sorted
                DIM distValid AS INTEGER
                distValid% = 0
                FOR algnI% = 1 TO algnCount%
                    LAYER_get_content_bounds algnLayers(algnI%), distBx(algnI%), distBy(algnI%), distBw(algnI%), distBh(algnI%)
                    IF distBw(algnI%) > 0 AND distBh(algnI%) > 0 THEN
                        distValid% = distValid% + 1
                        distOrder(distValid%) = algnI%
                    END IF
                NEXT algnI%
                IF distValid% >= 2 THEN
                    ' Simple insertion sort by position (X for H, Y for V)
                    DIM distJ AS INTEGER, distTmp AS INTEGER, distKey AS INTEGER
                    FOR algnI% = 2 TO distValid%
                        distTmp% = distOrder(algnI%)
                        IF action_id% = 1907 THEN
                            distKey% = distBx(distTmp%)
                        ELSE
                            distKey% = distBy(distTmp%)
                        END IF
                        distJ% = algnI% - 1
                        DO WHILE distJ% >= 1
                            DIM distCmp AS INTEGER
                            IF action_id% = 1907 THEN
                                distCmp% = distBx(distOrder(distJ%))
                            ELSE
                                distCmp% = distBy(distOrder(distJ%))
                            END IF
                            IF distCmp% <= distKey% THEN EXIT DO
                            distOrder(distJ% + 1) = distOrder(distJ%)
                            distJ% = distJ% - 1
                        LOOP
                        distOrder(distJ% + 1) = distTmp%
                    NEXT algnI%
                    ' Compute total span and content size sum
                    DIM distFirst AS INTEGER, distLast AS INTEGER
                    distFirst% = distOrder(1): distLast% = distOrder(distValid%)
                    DIM distSpanStart AS INTEGER, distSpanEnd AS INTEGER
                    DIM distContentSum AS INTEGER
                    distContentSum% = 0
                    FOR algnI% = 1 TO distValid%
                        DIM distIdx2 AS INTEGER
                        distIdx2% = distOrder(algnI%)
                        IF action_id% = 1907 THEN
                            distContentSum% = distContentSum% + distBw(distIdx2%)
                        ELSE
                            distContentSum% = distContentSum% + distBh(distIdx2%)
                        END IF
                    NEXT algnI%
                    IF action_id% = 1907 THEN
                        distSpanStart% = distBx(distFirst%)
                        distSpanEnd% = distBx(distLast%) + distBw(distLast%)
                    ELSE
                        distSpanStart% = distBy(distFirst%)
                        distSpanEnd% = distBy(distLast%) + distBh(distLast%)
                    END IF
                    DIM distTotalGap AS INTEGER, distGap AS SINGLE
                    distTotalGap% = (distSpanEnd% - distSpanStart%) - distContentSum%
                    IF distValid% > 1 THEN
                        distGap! = distTotalGap% / (distValid% - 1)
                    ELSE
                        distGap! = 0
                    END IF
                    ' Place each layer at evenly spaced positions
                    DIM distPos AS SINGLE
                    distPos! = distSpanStart%
                    FOR algnI% = 1 TO distValid%
                        DIM distIdx3 AS INTEGER
                        distIdx3% = distOrder(algnI%)
                        DIM distTarget AS INTEGER
                        distTarget% = INT(distPos! + 0.5)
                        IF action_id% = 1907 THEN
                            algDx% = distTarget% - distBx(distIdx3%)
                            algDy% = 0
                            distPos! = distPos! + distBw(distIdx3%) + distGap!
                        ELSE
                            algDx% = 0
                            algDy% = distTarget% - distBy(distIdx3%)
                            distPos! = distPos! + distBh(distIdx3%) + distGap!
                        END IF
                        IF algDx% <> 0 OR algDy% <> 0 THEN
                            DIM distLayerIdx AS INTEGER
                            distLayerIdx% = algnLayers(distIdx3%)
                            LAYER_translate_content distLayerIdx%, algDx%, algDy%
                            LAYERS(distLayerIdx%).contentDirty% = TRUE
                            IF algnBefore(distLayerIdx%) < -1 THEN
                                HISTORY_record_transform LAYERS(distLayerIdx%).historyId&, distLayerIdx%, 0, algnBefore(distLayerIdx%), algnHistoryLabel$
                                algnBefore(distLayerIdx%) = 0
                                algnRecorded% = TRUE
                            END IF
                        END IF
                    NEXT algnI%
                END IF
            ELSE
                ' ---- Align operations (1901-1906) ----
                FOR algnI% = 1 TO algnCount%
                    DIM algnIdx AS INTEGER
                    algnIdx% = algnLayers(algnI%)
                    ' Skip the anchor layer in multi-select â€” it stays put
                    IF algnMulti% AND algnIdx% = algnAnchor% THEN GOTO algNextLayer
                    LAYER_get_content_bounds algnIdx%, algBx%, algBy%, algBw%, algBh%
                    IF algBw% <= 0 OR algBh% <= 0 THEN GOTO algNextLayer
                    algDx% = 0: algDy% = 0
                    SELECT CASE action_id%
                        CASE 1901  ' Align Left
                            algDx% = algRefX% - algBx%
                        CASE 1902  ' Align Center H
                            algDx% = (algRefX% + algRefW% \ 2) - (algBx% + algBw% \ 2)
                        CASE 1903  ' Align Right
                            algDx% = (algRefX% + algRefW% - 1) - (algBx% + algBw% - 1)
                        CASE 1904  ' Align Top
                            algDy% = algRefY% - algBy%
                        CASE 1905  ' Align Middle V
                            algDy% = (algRefY% + algRefH% \ 2) - (algBy% + algBh% \ 2)
                        CASE 1906  ' Align Bottom
                            algDy% = (algRefY% + algRefH% - 1) - (algBy% + algBh% - 1)
                    END SELECT
                    IF algDx% <> 0 OR algDy% <> 0 THEN
                        LAYER_translate_content algnIdx%, algDx%, algDy%
                        LAYERS(algnIdx%).contentDirty% = TRUE
                        IF algnBefore(algnIdx%) < -1 THEN
                            HISTORY_record_transform LAYERS(algnIdx%).historyId&, algnIdx%, 0, algnBefore(algnIdx%), algnHistoryLabel$
                            algnBefore(algnIdx%) = 0
                            algnRecorded% = TRUE
                        END IF
                    END IF
                    algNextLayer:
                NEXT algnI%
            END IF
            FOR algnI% = 1 TO algnCount%
                IF algnBefore(algnLayers(algnI%)) < -1 THEN
                    _FREEIMAGE algnBefore(algnLayers(algnI%))
                    algnBefore(algnLayers(algnI%)) = 0
                END IF
            NEXT algnI%
            IF algnUsedHistoryGroup% THEN HISTORY_end_group
            IF algnRecorded% THEN HISTORY_saved_this_frame% = TRUE
            BLEND_invalidate_cache
            GUI_NEEDS_REDRAW% = TRUE
            SCENE_DIRTY% = TRUE
            IF grpExp1901% > 0 THEN CMD_group_restore_after_op grpExp1901%
        
        ' ========== SELECT (menu-only) ==========
        CASE 801  ' Pan tool (space emulation)
            ERR_info "Pan mode: hold Space and drag on canvas"
        CASE 1401  ' Select from current layer
            SOUND_play SND_SELECTION
            IF CURRENT_LAYER% >= 1 THEN
                IF CURRENT_LAYER% <= MAX_LAYERS THEN
                    IF LAYERS(CURRENT_LAYER%).layerType% = LAYER_TYPE_GROUP THEN
                        ' For groups: select union of all children's non-transparent pixels
                        DIM sel1401_grp AS INTEGER
                        sel1401_grp% = CMD_group_expand_for_op%
                        IF MULTI_SELECT_COUNT% >= 2 THEN
                            CMD_execute_action 1414
                        ELSEIF CURRENT_LAYER% >= 1 THEN
                            ' Single child â€” select from that child
                            LAYER_select_non_transparent CURRENT_LAYER%
                        END IF
                        IF sel1401_grp% > 0 THEN CMD_group_restore_after_op sel1401_grp%
                    ELSE
                        LAYER_select_non_transparent CURRENT_LAYER%
                    END IF
                END IF
            END IF
        CASE 1414  ' Select from selected layers (union of non-transparent pixels)
            SOUND_play SND_SELECTION
            IF MULTI_SELECT_COUNT% < 2 THEN EXIT SELECT
            DIM sel14_i AS INTEGER, sel14_px AS INTEGER, sel14_py AS INTEGER
            DIM sel14_w AS INTEGER, sel14_h AS INTEGER
            DIM sel14_imgH AS LONG, sel14_pix AS _UNSIGNED LONG
            DIM sel14_minX AS INTEGER, sel14_minY AS INTEGER
            DIM sel14_maxX AS INTEGER, sel14_maxY AS INTEGER
            DIM sel14_found AS INTEGER
            DIM sel14_oldDest AS LONG, sel14_oldSrc AS LONG
            DIM sel14_maskClr AS _UNSIGNED LONG
            ' Find first valid selected layer for canvas dimensions
            sel14_imgH& = 0
            FOR sel14_i% = 1 TO MAX_LAYERS
                IF MULTI_SELECT_LAYERS(sel14_i%) AND LAYERS(sel14_i%).imgHandle& <> 0 THEN
                    sel14_imgH& = LAYERS(sel14_i%).imgHandle&
                    EXIT FOR
                END IF
            NEXT sel14_i%
            IF sel14_imgH& = 0 THEN EXIT SELECT
            sel14_w% = _WIDTH(sel14_imgH&)
            sel14_h% = _HEIGHT(sel14_imgH&)
            sel14_oldDest& = _DEST
            sel14_oldSrc& = _SOURCE
            sel14_maskClr~& = _RGB32(255, 255, 255)
            ' Reset any existing selection
            MARQUEE_reset
            MAGIC_WAND_reset
            IF MARQUEE.SELECTION_MASK < -1 THEN
                _FREEIMAGE MARQUEE.SELECTION_MASK
                MARQUEE.SELECTION_MASK = 0
            END IF
            ' Create new selection mask
            MARQUEE.SELECTION_MASK = _NEWIMAGE(sel14_w%, sel14_h%, 32)
            IF MARQUEE.SELECTION_MASK >= -1 THEN
                _DEST sel14_oldDest&: _SOURCE sel14_oldSrc&: EXIT SELECT
            END IF
            _DEST MARQUEE.SELECTION_MASK
            CLS , _RGBA32(0, 0, 0, 0)
            _DONTBLEND MARQUEE.SELECTION_MASK
            ' Union non-transparent pixels across all selected layers
            sel14_minX% = sel14_w%: sel14_minY% = sel14_h%: sel14_maxX% = 0: sel14_maxY% = 0
            sel14_found% = FALSE
            FOR sel14_i% = 1 TO MAX_LAYERS
                IF MULTI_SELECT_LAYERS(sel14_i%) AND LAYERS(sel14_i%).imgHandle& <> 0 THEN
                    sel14_imgH& = LAYERS(sel14_i%).imgHandle&
                    _SOURCE sel14_imgH&
                    FOR sel14_py% = 0 TO sel14_h% - 1
                        FOR sel14_px% = 0 TO sel14_w% - 1
                            sel14_pix~& = POINT(sel14_px%, sel14_py%)
                            IF _ALPHA32(sel14_pix~&) > 0 THEN
                                _DEST MARQUEE.SELECTION_MASK
                                PSET (sel14_px%, sel14_py%), sel14_maskClr~&
                                IF sel14_px% < sel14_minX% THEN sel14_minX% = sel14_px%
                                IF sel14_px% > sel14_maxX% THEN sel14_maxX% = sel14_px%
                                IF sel14_py% < sel14_minY% THEN sel14_minY% = sel14_py%
                                IF sel14_py% > sel14_maxY% THEN sel14_maxY% = sel14_py%
                                sel14_found% = TRUE
                                _SOURCE sel14_imgH&
                            END IF
                        NEXT sel14_px%
                    NEXT sel14_py%
                END IF
            NEXT sel14_i%
            _BLEND MARQUEE.SELECTION_MASK
            _DEST sel14_oldDest&
            _SOURCE sel14_oldSrc&
            IF sel14_found% THEN
                MARQUEE.WAND_MIN_X = sel14_minX%
                MARQUEE.WAND_MIN_Y = sel14_minY%
                MARQUEE.WAND_MAX_X = sel14_maxX%
                MARQUEE.WAND_MAX_Y = sel14_maxY%
                MARQUEE.BOX.x = sel14_minX%
                MARQUEE.BOX.y = sel14_minY%
                MARQUEE.BOX.w = sel14_maxX% - sel14_minX% + 1
                MARQUEE.BOX.h = sel14_maxY% - sel14_minY% + 1
                MARQUEE.ACTIVE% = TRUE
                MARQUEE.INITIALIZED% = TRUE
                MARQUEE.USER_CREATED = TRUE
                MARQUEE.WAND_HAS_SELECTION = TRUE
                MARQUEE.CFG.initX = sel14_minX%
                MARQUEE.CFG.initY = sel14_minY%
                MARQUEE.CFG.initW = sel14_maxX% - sel14_minX% + 1
                MARQUEE.CFG.initH = sel14_maxY% - sel14_minY% + 1
                MARQUEE.BOX.x = MARQUEE.CFG.initX
                MARQUEE.BOX.y = MARQUEE.CFG.initY
                MARQUEE.BOX.w = MARQUEE.CFG.initW
                MARQUEE.BOX.h = MARQUEE.CFG.initH
                MARQUEE.BOX.state = MARQUEE_STATE_IDLE
            END IF
            INVALIDATE_scene
        CASE 1402  ' Nudge 1px left
            SOUND_play SND_SELECTION
            IF MARQUEE.ACTIVE% THEN MARQUEE.BOX.x = MARQUEE.BOX.x - 1
            INVALIDATE_scene
        CASE 1403  ' Nudge 1px right
            SOUND_play SND_SELECTION
            IF MARQUEE.ACTIVE% THEN MARQUEE.BOX.x = MARQUEE.BOX.x + 1
            INVALIDATE_scene
        CASE 1404  ' Nudge 1px down
            SOUND_play SND_SELECTION
            IF MARQUEE.ACTIVE% THEN MARQUEE.BOX.y = MARQUEE.BOX.y + 1
            INVALIDATE_scene
        CASE 1405  ' Nudge 1px up
            SOUND_play SND_SELECTION
            IF MARQUEE.ACTIVE% THEN MARQUEE.BOX.y = MARQUEE.BOX.y - 1
            INVALIDATE_scene
        CASE 1406  ' Nudge 10px left
            SOUND_play SND_SELECTION
            IF MARQUEE.ACTIVE% THEN MARQUEE.BOX.x = MARQUEE.BOX.x - 10
            INVALIDATE_scene
        CASE 1407  ' Nudge 10px right
            SOUND_play SND_SELECTION
            IF MARQUEE.ACTIVE% THEN MARQUEE.BOX.x = MARQUEE.BOX.x + 10
            INVALIDATE_scene
        CASE 1408  ' Nudge 10px down
            SOUND_play SND_SELECTION
            IF MARQUEE.ACTIVE% THEN MARQUEE.BOX.y = MARQUEE.BOX.y + 10
            INVALIDATE_scene
        CASE 1409  ' Nudge 10px up
            SOUND_play SND_SELECTION
            IF MARQUEE.ACTIVE% THEN MARQUEE.BOX.y = MARQUEE.BOX.y - 10
            INVALIDATE_scene
        CASE 1410  ' Expand Selection 1px
            SOUND_play SND_SELECTION
            SELECTION_expand 1
            INVALIDATE_scene
        CASE 1411  ' Contract Selection 1px
            SOUND_play SND_SELECTION
            SELECTION_contract 1
            INVALIDATE_scene
        CASE 1412  ' Expand Selection by NUDGE_N px
            SOUND_play SND_SELECTION
            SELECTION_expand CFG.NUDGE_N%
            INVALIDATE_scene
        CASE 1413  ' Contract Selection by NUDGE_N px
            SOUND_play SND_SELECTION
            SELECTION_contract CFG.NUDGE_N%
            INVALIDATE_scene

        ' ========== PALETTE (menu-only) ==========
        CASE 1510  ' Import palette (GPL)
            PALETTE_LOADER_ensure_user_dirs
            DIM impPalPath AS STRING
            impPalPath$ = DRAW_open_file$("Import Palette", PATHS_data$("PALETTES/"), "GIMP Palette|*.gpl|All Files|*.*", 0)
            MOUSE_cleanup_after_dialog FALSE
            IF LEN(impPalPath$) > 0 THEN
                DIM impResult AS INTEGER
                impResult% = PALETTE_LOADER_load_gpl%(impPalPath$)
                IF impResult% > 0 THEN
                    PAL_set_defaults_by_size
                    PALETTE_EMBEDDED_ACTIVE% = TRUE
                    PALETTE_EMBEDDED_NAME$ = "[IMPORTED]"
                    GUI_NEEDS_REDRAW% = TRUE
                    SCENE_DIRTY% = TRUE
                    FRAME_IDLE% = FALSE
                    BLEND_invalidate_cache
                    _LOGINFO "CMD: Imported palette from " + impPalPath$
                ELSE
                    ERR_info "Failed to load palette file"
                END IF
            END IF
        CASE 1511  ' Export palette (GPL)
            PALETTE_LOADER_ensure_user_dirs
            DIM expPalName AS STRING
            expPalName$ = PALETTE_LOADER_get_name$
            ' Sanitize name for filename: replace problematic chars
            DIM expSan AS INTEGER
            FOR expSan% = 1 TO LEN(expPalName$)
                DIM expCh AS STRING
                expCh$ = MID$(expPalName$, expSan%, 1)
                IF expCh$ = "/" OR expCh$ = "\" OR expCh$ = ":" OR expCh$ = "*" OR _
                   expCh$ = "?" OR expCh$ = CHR$(34) OR expCh$ = "<" OR expCh$ = ">" OR expCh$ = "|" THEN
                    MID$(expPalName$, expSan%, 1) = "_"
                END IF
            NEXT expSan%
            ' Remove brackets from [DOCUMENT] etc.
            DIM expClean AS STRING
            expClean$ = ""
            FOR expSan% = 1 TO LEN(expPalName$)
                expCh$ = MID$(expPalName$, expSan%, 1)
                IF expCh$ <> "[" AND expCh$ <> "]" THEN expClean$ = expClean$ + expCh$
            NEXT expSan%
            IF LEN(expClean$) = 0 THEN expClean$ = "palette"
            DIM expPalPath AS STRING
            expPalPath$ = DRAW_save_file$("Export Palette", PATHS_data$("PALETTES/"), "GIMP Palette|*.gpl", 0, expClean$, ".gpl")
            MOUSE_cleanup_after_dialog FALSE
            IF LEN(expPalPath$) > 0 THEN
                PALETTE_LOADER_export_gpl expPalPath$
                _LOGINFO "CMD: Exported palette to " + expPalPath$
            END IF
        CASE 1512  ' Random palette
            IF PALETTE_LOADER_COUNT% > 1 THEN
                DIM rndPalIdx AS INTEGER
                DO
                    rndPalIdx% = INT(RND * PALETTE_LOADER_COUNT%)
                LOOP WHILE rndPalIdx% = PALETTE_LOADER_CURRENT_IDX% AND PALETTE_LOADER_COUNT% > 1
                DIM rndResult AS INTEGER
                rndResult% = PALETTE_LOADER_load_by_index%(rndPalIdx%)
                IF rndResult% > 0 THEN
                    GUI_NEEDS_REDRAW% = TRUE
                    SCENE_DIRTY% = TRUE
                END IF
            END IF
        CASE 1513  ' Swap FG/BG Colors
            DIM swap_tmp_color AS _UNSIGNED LONG
            DIM swap_tmp_idx AS INTEGER
            DIM swap_tmp_trans AS INTEGER
            swap_tmp_color~& = PAINT_COLOR~&
            swap_tmp_idx% = PAL_FG_IDX%
            swap_tmp_trans% = PAL_FG_IS_TRANSPARENT%
            PAINT_COLOR~& = PAINT_BG_COLOR~&
            PAL_FG_IDX% = PAL_BG_IDX%
            PAL_FG_IS_TRANSPARENT% = PAL_BG_IS_TRANSPARENT%
            PAINT_BG_COLOR~& = swap_tmp_color~&
            PAL_BG_IDX% = swap_tmp_idx%
            PAL_BG_IS_TRANSPARENT% = swap_tmp_trans%
            GUI_NEEDS_REDRAW% = TRUE
        CASE 1505  ' Color Picker dialog for FG
            ' Force a render cycle so the menu visually closes before the picker appears
            GUI_NEEDS_REDRAW% = TRUE
            SCENE_DIRTY% = TRUE
            SCREEN_render
            _DISPLAY
            DIM picker_color AS _UNSIGNED LONG
            picker_color~& = PALETTE_PICKER_show~&("Choose Foreground Color", PAINT_COLOR~&)
            IF PALETTE_PICKER_CHOSE_TRANSPARENT% THEN
                PAL_FG_IS_TRANSPARENT% = TRUE
                PAINT_COLOR~& = _RGBA32(0, 0, 0, 0)
                POINTER.C~& = _RGBA32(0, 0, 0, 0)
                GUI_NEEDS_REDRAW% = TRUE
            ELSEIF picker_color~& <> PAINT_COLOR~& THEN
                PAL_FG_IS_TRANSPARENT% = FALSE
                PAINT_COLOR~& = picker_color~&
                POINTER.C~& = picker_color~&
                DIM picker_pal_idx AS INTEGER
                picker_pal_idx% = PAL_find_index%(picker_color~&)
                IF picker_pal_idx% >= 0 THEN PAL_FG_IDX% = picker_pal_idx%
                GUI_NEEDS_REDRAW% = TRUE
            END IF
            MOUSE_reset_buttons

        CASE 1506  ' Color Picker dialog for BG
            ' Force a render cycle so the menu visually closes before the picker appears
            GUI_NEEDS_REDRAW% = TRUE
            SCENE_DIRTY% = TRUE
            SCREEN_render
            _DISPLAY
            DIM bg_picker_color AS _UNSIGNED LONG
            bg_picker_color~& = PALETTE_PICKER_show~&("Choose Background Color", PAINT_BG_COLOR~&)
            IF PALETTE_PICKER_CHOSE_TRANSPARENT% THEN
                PAL_BG_IS_TRANSPARENT% = TRUE
                PAINT_BG_COLOR~& = _RGBA32(0, 0, 0, 0)
                ' Explicit transparent pick should apply to selected text even when
                ' PAINT_BG_COLOR~& was already transparent before opening the picker.
                IF TEXT.ACTIVE AND TEXT_has_selection% THEN
                    IF TEXT_BAR.editingLayerIdx% >= 1 THEN
                        DIM bgSelTd AS INTEGER
                        bgSelTd% = LAYERS(TEXT_BAR.editingLayerIdx%).textDataIdx%
                        IF bgSelTd% >= 1 THEN
                            DIM bgSelMin AS INTEGER, bgSelMax AS INTEGER
                            bgSelMin% = TEXT.selStart%: bgSelMax% = TEXT.selEnd%
                            IF bgSelMin% > bgSelMax% THEN SWAP bgSelMin%, bgSelMax%
                            TEXT_LAYER_set_selection_attr bgSelTd%, bgSelMin%, bgSelMax% - 1, "BG", PAINT_BG_COLOR~&
                            TEXT_LAYER_DATA(bgSelTd%).dirty = TRUE
                            SCENE_DIRTY% = TRUE
                            FRAME_IDLE% = FALSE
                        END IF
                    END IF
                END IF
                GUI_NEEDS_REDRAW% = TRUE
            ELSEIF bg_picker_color~& <> PAINT_BG_COLOR~& THEN
                PAL_BG_IS_TRANSPARENT% = FALSE
                PAINT_BG_COLOR~& = bg_picker_color~&
                DIM bg_picker_pal_idx AS INTEGER
                bg_picker_pal_idx% = PAL_find_index%(bg_picker_color~&)
                IF bg_picker_pal_idx% >= 0 THEN PAL_BG_IDX% = bg_picker_pal_idx%
                GUI_NEEDS_REDRAW% = TRUE
            END IF
            MOUSE_reset_buttons

        CASE 1507  ' Outline color picker (text bar)
            GUI_NEEDS_REDRAW% = TRUE
            SCENE_DIRTY% = TRUE
            SCREEN_render
            _DISPLAY
            DIM out_picker_color AS _UNSIGNED LONG
            out_picker_color~& = PALETTE_PICKER_show~&("Choose Outline Color", TEXT_BAR.outlineColor~&)
            IF NOT PALETTE_PICKER_CHOSE_TRANSPARENT% THEN
                IF out_picker_color~& <> TEXT_BAR.outlineColor~& THEN
                    TEXT_BAR.outlineColor~& = out_picker_color~&
                    TEXT_BAR.needsRedraw% = TRUE
                    TEXT_BAR_apply_outline_to_selection
                END IF
            END IF
            MOUSE_reset_buttons

        CASE 1508  ' Shadow color picker (text bar)
            GUI_NEEDS_REDRAW% = TRUE
            SCENE_DIRTY% = TRUE
            SCREEN_render
            _DISPLAY
            DIM shd_picker_color AS _UNSIGNED LONG
            shd_picker_color~& = PALETTE_PICKER_show~&("Choose Shadow Color", TEXT_BAR.shadowColor~&)
            IF NOT PALETTE_PICKER_CHOSE_TRANSPARENT% THEN
                IF shd_picker_color~& <> TEXT_BAR.shadowColor~& THEN
                    TEXT_BAR.shadowColor~& = shd_picker_color~&
                    TEXT_BAR.needsRedraw% = TRUE
                    TEXT_BAR_apply_shadow_to_selection
                END IF
            END IF
            MOUSE_reset_buttons

        CASE 1509  ' Toggle AA (text bar)
            TEXT_BAR.aaActive% = NOT TEXT_BAR.aaActive%
            TEXT_BAR_apply_aa
            TEXT_BAR.needsRedraw% = TRUE
            FRAME_IDLE% = FALSE

        CASE 1510  ' Import text styles
            GUI_NEEDS_REDRAW% = TRUE
            SCENE_DIRTY% = TRUE
            SCREEN_render
            _DISPLAY
            DIM importStylePath AS STRING
            importStylePath$ = DRAW_open_file$("Import Text Style", "", "DRAW Text Style|*.dstyle|*.DSTYLE", 0)
            IF LEN(importStylePath$) > 0 THEN
                TEXT_STYLE_import importStylePath$
                TEXT_BAR.needsRedraw% = TRUE
            END IF
            MOUSE_cleanup_after_dialog FALSE
            MOUSE_reset_buttons

        CASE 1511  ' Export selected text style
            GUI_NEEDS_REDRAW% = TRUE
            SCENE_DIRTY% = TRUE
            SCREEN_render
            _DISPLAY
            IF TEXT_STYLE_SELECTED% >= 1 AND TEXT_STYLE_SELECTED% <= TEXT_STYLE_MAX THEN
                IF TEXT_STYLES(TEXT_STYLE_SELECTED%).used THEN
                    DIM exportStylePath AS STRING
                    exportStylePath$ = DRAW_save_file$("Export Text Style", "", "DRAW Text Style|*.dstyle", 0, "", ".dstyle")
                    IF LEN(exportStylePath$) > 0 THEN
                        TEXT_STYLE_export TEXT_STYLE_SELECTED%, exportStylePath$
                    END IF
                END IF
            END IF
            MOUSE_cleanup_after_dialog FALSE
            MOUSE_reset_buttons

        CASE 1512  ' Export all text styles
            GUI_NEEDS_REDRAW% = TRUE
            SCENE_DIRTY% = TRUE
            SCREEN_render
            _DISPLAY
            DIM exportAllPath AS STRING
            exportAllPath$ = DRAW_save_file$("Export All Text Styles", "", "DRAW Text Style|*.dstyle", 0, "", ".dstyle")
            IF LEN(exportAllPath$) > 0 THEN
                TEXT_STYLE_export_all exportAllPath$
            END IF
            MOUSE_cleanup_after_dialog FALSE
            MOUSE_reset_buttons

        CASE 1514  ' Load from Lospec...
            GUI_NEEDS_REDRAW% = TRUE
            SCENE_DIRTY% = TRUE
            SCREEN_render
            _DISPLAY
            LOSPEC_show_dialog
            MOUSE_reset_buttons

        CASE 1515  ' Create palette from image...
            GUI_NEEDS_REDRAW% = TRUE
            SCENE_DIRTY% = TRUE
            SCREEN_render
            _DISPLAY
            PALETTE_LOADER_create_from_image_dialog
            MOUSE_reset_buttons

        CASE 1516  ' Remap to palette with dither dialog
            IF PAL_COLOR_COUNT% > 0 AND LAYER_COUNT% > 0 THEN
                PALETTE_LOADER_remap_dialog
            ELSE
                ERR_info "Remap to Palette: no palette or no layers loaded"
            END IF

        CASE 1517  ' Toggle: Show Lospec palettes in picker
            CFG.PALETTE_SHOW_LOSPEC% = NOT CFG.PALETTE_SHOW_LOSPEC%
            CONFIG_save
            ' Reload palette list
            PALETTE_LOADER_COUNT% = 0
            PALETTE_LOADER_scan_folder "./ASSETS/PALETTES"
            PALETTE_LOADER_scan_user_folders
            GUI_NEEDS_REDRAW% = TRUE

        CASE 1518  ' Toggle: Show Created palettes in picker
            CFG.PALETTE_SHOW_CREATED% = NOT CFG.PALETTE_SHOW_CREATED%
            CONFIG_save
            ' Reload palette list
            PALETTE_LOADER_COUNT% = 0
            PALETTE_LOADER_scan_folder "./ASSETS/PALETTES"
            PALETTE_LOADER_scan_user_folders
            GUI_NEEDS_REDRAW% = TRUE
        
        ' ========== TOOLS (menu-only) ==========
        CASE 1102  ' Clear custom brush
            IF CUSTOM_BRUSH_is_active% THEN
                CUSTOM_BRUSH_reset
                GUI_NEEDS_REDRAW% = TRUE
            END IF
        CASE 1110  ' Export brush as PNG
            IF CUSTOM_BRUSH_is_active% THEN
                DIM brushExportPath AS STRING
                POINTER_hide_for_dialog
                DIM brushExportDefault AS STRING
                IF CFG.LAST_DIR_EXPORT_BRUSH$ <> "" THEN
                    brushExportDefault$ = CFG.LAST_DIR_EXPORT_BRUSH$ + "/"
                ELSE
                    brushExportDefault$ = ""
                END IF
                brushExportPath$ = DRAW_save_file$("Export Brush as PNG", brushExportDefault$, "PNG Image|*.png", 0, "", ".png")
                POINTER_show_after_dialog
                IF brushExportPath$ <> "" THEN
                    ' Update per-operation last directory
                    CFG.LAST_DIR_EXPORT_BRUSH$ = CONFIG_extract_dir$(brushExportPath$)
                    LAST_DIRECTORY$ = CFG.LAST_DIR_EXPORT_BRUSH$
                    CONFIG_save
                    CUSTOM_BRUSH_export_png brushExportPath$
                END IF
            ELSE
                ERR_info "No custom brush active. Create one with Ctrl+B first."
            END IF
        CASE 1701  ' Zoom tool
            ERR_info "Zoom: use Ctrl+= / Ctrl+- or scroll wheel"
        CASE 1702  ' Spray tool
            PREVIOUS_TOOL% = CURRENT_TOOL%
            CURRENT_TOOL% = TOOL_SPRAY
            GUI_NEEDS_REDRAW% = TRUE
        CASE 1703  ' Command palette / cheat sheet
            CMD_show_palette
        CASE 1704  ' Code / BAS export
            FILE_BAS_export_dialog
        
        ' ========== HELP ==========
        CASE 1601  ' About
            SOUND_play SND_TRANSFORM
            MENUBAR_close_all
            ABOUT_show
        CASE 1602  ' Cheat sheet (same as command palette quick ref)
            CMD_show_quick_ref
        CASE 1603  ' Manual
            ERR_info "Manual: not yet available"
        CASE 1609  ' Pixel Art Analyzer
            MENUBAR_close_all
            SCENE_DIRTY% = TRUE
            SCREEN_render
            _DISPLAY
            PIXEL_ANALYZER_show
        CASE 1604  ' GitHub
            SHELL "xdg-open https://github.com/grymmjack/DRAW &"
        CASE 1605  ' Issue tracker
            SHELL "xdg-open https://github.com/grymmjack/DRAW/issues &"
        CASE 1606  ' Credits
            POINTER_hide_for_dialog
            DIM creditsMsg AS STRING
            creditsMsg$ = "DRAW " + APP_VERSION$ + CHR$(10) + CHR$(10) + _
                          "Created by grymmjack (Rick Christy)" + CHR$(10) + _
                          "github.com/grymmjack" + CHR$(10) + CHR$(10) + _
                          "Built with QB64-PE" + CHR$(10) + _
                          "github.com/QB64-Phoenix-Edition" + CHR$(10) + CHR$(10) + _
                          "--- Special Thanks to: ---" + CHR$(10) + CHR$(10) + _
                          "Samuel Gomez (a740g) : my QB64 Super Hero" + CHR$(10) + _
                          "dbox (boxgaming) (qbjs dev) : brilliant nice guy" + CHR$(10) + _
                          "Alex (beatslaughter) : friend and early tester" + CHR$(10) + CHR$(10) + _
                          "The entire QB64 Phoenix Edition team!" + CHR$(10) + CHR$(10) + _
                          "Thank you all"
            DRAW_alert "Credits", creditsMsg$
            POINTER_show_after_dialog
        CASE 1607  ' Examples
            ERR_info "Examples: not yet available"
        CASE 1608  ' Show Tooltips toggle
            CFG.TOOLTIPS_DISABLED% = NOT CFG.TOOLTIPS_DISABLED%
            CONFIG_save
            FRAME_IDLE% = FALSE

        ' ========== CANVAS ==========
        CASE 1801  ' Canvas Resize
            CANVAS_resize_dialog
        CASE 1802  ' Canvas Crop
            CROP_begin
        CASE 1803  ' Flip Canvas Horizontal (all layers)
            SOUND_play SND_TRANSFORM
            HISTORY_begin_group
            DIM fcHI AS INTEGER
            FOR fcHI% = 1 TO MAX_LAYERS
                IF LAYERS(fcHI%).imgHandle& < -1 THEN
                    CMD_ml_flip_h fcHI%, 0, "Flip Canvas H"
                END IF
            NEXT fcHI%
            HISTORY_end_group
            INVALIDATE_layers
            FRAME_IDLE% = FALSE
        CASE 1804  ' Flip Canvas Vertical (all layers)
            SOUND_play SND_TRANSFORM
            HISTORY_begin_group
            DIM fcVI AS INTEGER
            FOR fcVI% = 1 TO MAX_LAYERS
                IF LAYERS(fcVI%).imgHandle& < -1 THEN
                    CMD_ml_flip_v fcVI%, 0, "Flip Canvas V"
                END IF
            NEXT fcVI%
            HISTORY_end_group
            INVALIDATE_layers
            FRAME_IDLE% = FALSE

        ' ========== IMAGE ==========
        CASE 2001, 2002, 2003, 2004, 2005, 2006, 2009, 2010, 2011
            DIM grpExpImgAdj AS INTEGER
            grpExpImgAdj% = CMD_group_expand_for_op%
            ' Close menu first so the dialog screenshot captures a clean canvas
            MENUBAR_close_all
            SCENE_DIRTY% = TRUE
            SCREEN_render
            _PUTIMAGE (0, 0)-(_WIDTH(0) - 1, _HEIGHT(0) - 1), SCRN.CANVAS&, 0
            _DISPLAY
            SELECT CASE action_id%
                CASE 2001 : IMAGE_ADJ_brightness_contrast_dialog
                CASE 2002 : IMAGE_ADJ_hue_saturation_dialog
                CASE 2003 : IMAGE_ADJ_levels_dialog
                CASE 2004 : IMAGE_ADJ_color_balance_dialog
                CASE 2005 : IMAGE_ADJ_blur_dialog
                CASE 2006 : IMAGE_ADJ_sharpen_dialog
                CASE 2009 : IMAGE_ADJ_posterize_dialog
                CASE 2010 : IMAGE_ADJ_pixelate_dialog
                CASE 2011 : IMAGE_ADJ_remove_background_dialog
            END SELECT
            ' Force full redraw to clear dialog artifacts from screen
            SCENE_DIRTY% = TRUE
            FRAME_IDLE% = FALSE
            IF grpExpImgAdj% > 0 THEN CMD_group_restore_after_op grpExpImgAdj%
        CASE 2007
            DIM grpExp2007 AS INTEGER
            grpExp2007% = CMD_group_expand_for_op%
            IMAGE_ADJ_invert
            IF grpExp2007% > 0 THEN CMD_group_restore_after_op grpExp2007%
        CASE 2008
            DIM grpExp2008 AS INTEGER
            grpExp2008% = CMD_group_expand_for_op%
            IMAGE_ADJ_desaturate
            IF grpExp2008% > 0 THEN CMD_group_restore_after_op grpExp2008%

        ' --- Preview Window actions ---
        CASE 2013 ' Follow Mode
            CFG.PREVIEW_MODE% = PREVIEW_MODE_FOLLOW
            PREVIEW_set_follow_mode
            CONFIG_save
        CASE 2014 ' Floating Image Mode
            CFG.PREVIEW_MODE% = PREVIEW_MODE_FLOAT
            PREVIEW_set_floating_mode
            CONFIG_save
        CASE 2015 ' Bin Quick Look toggle
            CFG.PREVIEW_BIN_QUICK_LOOK% = NOT CFG.PREVIEW_BIN_QUICK_LOOK%
            PREVIEW.binQuickLookEnabled% = CFG.PREVIEW_BIN_QUICK_LOOK%
            CONFIG_save
        CASE 2016 ' Allow Color Picking toggle
            CFG.PREVIEW_COLOR_PICK% = NOT CFG.PREVIEW_COLOR_PICK%
            PREVIEW.colorPickEnabled% = CFG.PREVIEW_COLOR_PICK%
            CONFIG_save
        CASE 2017 ' Load Image...
            PREVIEW_load_floating_image ""
        CASE 2019 ' Clear Recent Preview Images
            RECENT_PREVIEW_clear
            CONFIG_save
        CASE 2020 ' Grayscale Preview toggle
            GRAYSCALE_PREVIEW_ACTIVE% = NOT GRAYSCALE_PREVIEW_ACTIVE%
            SCENE_DIRTY% = TRUE
            STATUS_NEEDS_REDRAW% = TRUE
            FRAME_IDLE% = FALSE
        CASE ACTION_SETTINGS ' Settings dialog
            MENUBAR_close_all
            SETTINGS_show_dialog
    END SELECT
END SUB


''
' Update search results based on current search string
'
SUB CMD_update_search ()
    DIM i AS INTEGER
    DIM search_str AS STRING
    DIM name_str AS STRING
    
    CMD_PALETTE.result_count = 0
    search_str$ = UCASE$(LEFT$(CMD_PALETTE.search, CMD_PALETTE.search_len))
    
    FOR i% = 0 TO CMD_COUNT - 1
        ' If no search, show all
        IF CMD_PALETTE.search_len = 0 THEN
            CMD_RESULTS(CMD_PALETTE.result_count) = i%
            CMD_PALETTE.result_count = CMD_PALETTE.result_count + 1
        ELSE
            ' Check for fuzzy match in name or hotkey
            name_str$ = UCASE$(RTRIM$(CMD_LIST(i%).name))
            IF CMD_fuzzy_match%(search_str$, name_str$) THEN
                CMD_RESULTS(CMD_PALETTE.result_count) = i%
                CMD_PALETTE.result_count = CMD_PALETTE.result_count + 1
            ELSEIF INSTR(UCASE$(RTRIM$(CMD_LIST(i%).hotkey)), search_str$) > 0 THEN
                CMD_RESULTS(CMD_PALETTE.result_count) = i%
                CMD_PALETTE.result_count = CMD_PALETTE.result_count + 1
            END IF
        END IF
    NEXT i%
    
    ' Reset hover and scroll
    CMD_PALETTE.hover = 0
    CMD_PALETTE.scroll = 0
END SUB


''
' Fuzzy match - check if search characters appear in order in target
' @param searchStr STRING - Search query characters to match in order
' @param targetStr STRING - Target string to search within
' @return INTEGER - TRUE if all characters of searchStr appear in order in targetStr
'
FUNCTION CMD_fuzzy_match% (searchStr AS STRING, targetStr AS STRING)
    DIM si AS INTEGER, ti AS INTEGER
    DIM sc AS STRING, tc AS STRING
    
    IF LEN(searchStr$) = 0 THEN
        CMD_fuzzy_match% = TRUE
        EXIT FUNCTION
    END IF
    
    si% = 1
    ti% = 1
    
    DO WHILE si% <= LEN(searchStr$) AND ti% <= LEN(targetStr$)
        sc$ = MID$(searchStr$, si%, 1)
        tc$ = MID$(targetStr$, ti%, 1)
        
        IF sc$ = tc$ THEN
            si% = si% + 1
        END IF
        ti% = ti% + 1
    LOOP
    
    CMD_fuzzy_match% = (si% > LEN(searchStr$))
END FUNCTION


''
' ============================================================
' Multi-layer edit helpers
' Each sub operates on a single extra-selected layer:
'   - saves undo state before modifying
'   - marks contentDirty%
'   - does NOT call BLEND_invalidate_cache (caller does it once after the loop)
' ============================================================

''
' Fill every opaque pixel on layerIdx with fillColor.
' Used so transparent areas on co-selected layers are not flooded solid.
' @param layerIdx INTEGER - Index (1-64) of the layer to fill
' @param fillColor _UNSIGNED LONG - RGBA color to write into every opaque pixel
' @param historyFlags LONG - Flags passed to HISTORY_record_fill (e.g. HISTORY_FLAG_CLIPPED)
' @param historyLabel STRING - Label for the history record (e.g. "Fill FG")
'
SUB CMD_ml_fill (layerIdx AS INTEGER, fillColor AS _UNSIGNED LONG, historyFlags AS LONG, historyLabel AS STRING)
    IF layerIdx% < 1 OR layerIdx% > MAX_LAYERS THEN EXIT SUB
    IF LAYERS(layerIdx%).imgHandle& >= -1 THEN EXIT SUB
    DIM mlFBefore AS LONG
    mlFBefore& = 0
    IF NOT HISTORY_IN_PROGRESS% AND LAYERS(layerIdx%).historyId& > 0 THEN
        mlFBefore& = _COPYIMAGE(LAYERS(layerIdx%).imgHandle&, 32)
    END IF
    DIM mlFMem AS _MEM
    mlFMem = _MEMIMAGE(LAYERS(layerIdx%).imgHandle&)
    DIM mlFOff AS _OFFSET
    DIM mlFAlpha AS _UNSIGNED _BYTE
    FOR mlFOff = mlFMem.OFFSET TO mlFMem.OFFSET + mlFMem.SIZE - 4 STEP 4
        _MEMGET mlFMem, mlFOff + 3, mlFAlpha~%%
        IF mlFAlpha~%% > 0 THEN
            _MEMPUT mlFMem, mlFOff, fillColor~& AS _UNSIGNED LONG
        END IF
    NEXT mlFOff
    _MEMFREE mlFMem
    IF mlFBefore& < -1 THEN
        HISTORY_record_fill LAYERS(layerIdx%).historyId&, layerIdx%, fillColor~&, historyFlags&, mlFBefore&, -32768, -32768, historyLabel$
    END IF
    LAYERS(layerIdx%).contentDirty% = TRUE
END SUB

''
' Clear layerIdx (marquee region if user-created, otherwise whole layer).
' @param layerIdx INTEGER - Index (1-64) of the layer to clear
'
SUB CMD_ml_clear (layerIdx AS INTEGER)
    IF layerIdx% < 1 OR layerIdx% > MAX_LAYERS THEN EXIT SUB
    IF LAYERS(layerIdx%).imgHandle& >= -1 THEN EXIT SUB
    DIM mlCBefore AS LONG
    DIM mlCHistoryFlags AS LONG
    mlCBefore& = 0
    mlCHistoryFlags& = 0
    IF MARQUEE.ACTIVE AND MARQUEE.USER_CREATED AND MARQUEE.INITIALIZED THEN mlCHistoryFlags& = HISTORY_FLAG_CLIPPED
    IF NOT HISTORY_IN_PROGRESS% AND LAYERS(layerIdx%).historyId& > 0 THEN
        mlCBefore& = _COPYIMAGE(LAYERS(layerIdx%).imgHandle&, 32)
    END IF
    DIM mlCImg AS LONG : mlCImg& = LAYERS(layerIdx%).imgHandle&
    DIM mlCOD AS LONG : mlCOD& = _DEST
    _DEST mlCImg&
    _DONTBLEND mlCImg&
    IF MARQUEE.ACTIVE AND MARQUEE.USER_CREATED AND MARQUEE.INITIALIZED THEN
        LINE (MARQUEE.BOX.x, MARQUEE.BOX.y)-(MARQUEE.BOX.x + MARQUEE.BOX.w - 1, MARQUEE.BOX.y + MARQUEE.BOX.h - 1), _RGBA32(0, 0, 0, 0), BF
    ELSE
        CLS , _RGBA32(0, 0, 0, 0)
    END IF
    _BLEND mlCImg&
    _DEST mlCOD&
    IF mlCBefore& < -1 THEN
        HISTORY_record_brush LAYERS(layerIdx%).historyId&, layerIdx%, _RGBA32(0, 0, 0, 0), mlCHistoryFlags&, mlCBefore&, "Clear"
    END IF
    LAYERS(layerIdx%).contentDirty% = TRUE
END SUB

''
' Auto-select group children into MULTI_SELECT when CURRENT_LAYER is a group.
' Switches CURRENT_LAYER to the topmost child so operations apply to real layers.
' Returns the original group index (>0 if expansion happened, 0 if not a group).
'
FUNCTION CMD_group_expand_for_op% ()
    DIM cge_i AS INTEGER
    CMD_group_expand_for_op% = 0
    IF CURRENT_LAYER% < 1 THEN EXIT FUNCTION
    IF CURRENT_LAYER% > MAX_LAYERS THEN EXIT FUNCTION
    IF LAYERS(CURRENT_LAYER%).layerType% <> LAYER_TYPE_GROUP THEN EXIT FUNCTION
    DIM cge_grpIdx AS INTEGER
    cge_grpIdx% = CURRENT_LAYER%
    ' Select all descendants (recursive) into MULTI_SELECT and switch to topmost child
    DIM cge_topChild AS INTEGER, cge_topZ AS INTEGER
    DIM cge_walk AS INTEGER, cge_found AS INTEGER, cge_safe AS INTEGER
    cge_topChild% = 0
    cge_topZ% = 0
    MULTI_SELECT_clear
    FOR cge_i% = 1 TO MAX_LAYERS
        IF LAYERS(cge_i%).imgHandle& <> 0 AND cge_i% <> cge_grpIdx% THEN
            ' Walk parent chain to find ALL descendants (not just direct children)
            cge_walk% = LAYERS(cge_i%).parentGroupIdx%
            cge_found% = FALSE
            cge_safe% = 0
            DO WHILE cge_walk% > 0 AND cge_safe% < MAX_GROUP_NESTING
                IF cge_walk% = cge_grpIdx% THEN
                    cge_found% = TRUE
                    EXIT DO
                END IF
                IF cge_walk% < 1 OR cge_walk% > MAX_LAYERS THEN EXIT DO
                IF LAYERS(cge_walk%).imgHandle& = 0 THEN EXIT DO
                cge_walk% = LAYERS(cge_walk%).parentGroupIdx%
                cge_safe% = cge_safe% + 1
            LOOP
            IF cge_found% THEN
                ' Skip ALL group headers â€” their 1x1 sentinel images corrupt
                ' dimension calculations in transforms and Select From Layer (1414).
                IF LAYERS(cge_i%).layerType% <> LAYER_TYPE_GROUP THEN
                    MULTI_SELECT_LAYERS(cge_i%) = TRUE
                    MULTI_SELECT_COUNT% = MULTI_SELECT_COUNT% + 1
                    IF LAYERS(cge_i%).zIndex% > cge_topZ% THEN
                        cge_topZ% = LAYERS(cge_i%).zIndex%
                        cge_topChild% = cge_i%
                    END IF
                END IF
            END IF
        END IF
    NEXT cge_i%
    IF cge_topChild% > 0 THEN
        CURRENT_LAYER% = cge_topChild%
        CMD_group_expand_for_op% = cge_grpIdx%
    END IF
END FUNCTION

''
' Restore CURRENT_LAYER to the group header after an expanded group operation.
'
SUB CMD_group_restore_after_op (groupIdx AS INTEGER)
    IF groupIdx% < 1 THEN EXIT SUB
    IF groupIdx% > MAX_LAYERS THEN EXIT SUB
    CURRENT_LAYER% = groupIdx%
    MULTI_SELECT_clear
END SUB

''
' Flip layerIdx horizontally.
' @param layerIdx INTEGER - Index (1-64) of the layer to flip
' @param historyFlags LONG - Flags passed to HISTORY_record_transform
' @param historyLabel STRING - Label for the history record (e.g. "Flip H")
'
SUB CMD_ml_flip_h (layerIdx AS INTEGER, historyFlags AS LONG, historyLabel AS STRING)
    IF layerIdx% < 1 OR layerIdx% > MAX_LAYERS THEN EXIT SUB
    IF LAYERS(layerIdx%).imgHandle& >= -1 THEN EXIT SUB
    DIM mlFHBefore AS LONG
    mlFHBefore& = 0
    IF NOT HISTORY_IN_PROGRESS% AND LAYERS(layerIdx%).historyId& > 0 THEN
        mlFHBefore& = _COPYIMAGE(LAYERS(layerIdx%).imgHandle&, 32)
    END IF
    DIM mlFHSrc AS LONG : mlFHSrc& = LAYERS(layerIdx%).imgHandle&
    DIM mlFHW AS LONG : mlFHW& = _WIDTH(mlFHSrc&)
    DIM mlFHH AS LONG : mlFHH& = _HEIGHT(mlFHSrc&)
    DIM mlFHTmp AS LONG : mlFHTmp& = _NEWIMAGE(mlFHW&, mlFHH&, 32)
    _PUTIMAGE (mlFHW& - 1, 0)-(0, mlFHH& - 1), mlFHSrc&, mlFHTmp&
    DIM mlFHOD AS LONG : mlFHOD& = _DEST
    _DEST mlFHSrc&
    _DONTBLEND mlFHSrc&
    _PUTIMAGE , mlFHTmp&, mlFHSrc&
    _BLEND mlFHSrc&
    _DEST mlFHOD&
    IF mlFHTmp& < -1 THEN _FREEIMAGE mlFHTmp&
    IF mlFHBefore& < -1 THEN
        HISTORY_record_transform LAYERS(layerIdx%).historyId&, layerIdx%, historyFlags&, mlFHBefore&, historyLabel$
    END IF
    LAYERS(layerIdx%).contentDirty% = TRUE
END SUB

''
' Flip layerIdx vertically.
' @param layerIdx INTEGER - Index (1-64) of the layer to flip
' @param historyFlags LONG - Flags passed to HISTORY_record_transform
' @param historyLabel STRING - Label for the history record (e.g. "Flip V")
'
SUB CMD_ml_flip_v (layerIdx AS INTEGER, historyFlags AS LONG, historyLabel AS STRING)
    IF layerIdx% < 1 OR layerIdx% > MAX_LAYERS THEN EXIT SUB
    IF LAYERS(layerIdx%).imgHandle& >= -1 THEN EXIT SUB
    DIM mlFVBefore AS LONG
    mlFVBefore& = 0
    IF NOT HISTORY_IN_PROGRESS% AND LAYERS(layerIdx%).historyId& > 0 THEN
        mlFVBefore& = _COPYIMAGE(LAYERS(layerIdx%).imgHandle&, 32)
    END IF
    DIM mlFVSrc AS LONG : mlFVSrc& = LAYERS(layerIdx%).imgHandle&
    DIM mlFVW AS LONG : mlFVW& = _WIDTH(mlFVSrc&)
    DIM mlFVH AS LONG : mlFVH& = _HEIGHT(mlFVSrc&)
    DIM mlFVTmp AS LONG : mlFVTmp& = _NEWIMAGE(mlFVW&, mlFVH&, 32)
    _PUTIMAGE (0, mlFVH& - 1)-(mlFVW& - 1, 0), mlFVSrc&, mlFVTmp&
    DIM mlFVOD AS LONG : mlFVOD& = _DEST
    _DEST mlFVSrc&
    _DONTBLEND mlFVSrc&
    _PUTIMAGE , mlFVTmp&, mlFVSrc&
    _BLEND mlFVSrc&
    _DEST mlFVOD&
    IF mlFVTmp& < -1 THEN _FREEIMAGE mlFVTmp&
    IF mlFVBefore& < -1 THEN
        HISTORY_record_transform LAYERS(layerIdx%).historyId&, layerIdx%, historyFlags&, mlFVBefore&, historyLabel$
    END IF
    LAYERS(layerIdx%).contentDirty% = TRUE
END SUB

''
' Scale layerIdx content by factor, centered on the canvas (clips to canvas edges).
' Mirrors the whole-layer logic in CASE 317/318 without lossless accumulation.
' @param layerIdx INTEGER - Index (1-64) of the layer to scale
' @param factor SINGLE - Scale multiplier (e.g. 0.5 for half size, 2.0 for double)
' @param historyFlags LONG - Flags passed to HISTORY_record_transform
' @param historyLabel STRING - Label for the history record (e.g. "Scale+")
'
SUB CMD_ml_scale (layerIdx AS INTEGER, factor AS SINGLE, historyFlags AS LONG, historyLabel AS STRING)
    IF layerIdx% < 1 OR layerIdx% > MAX_LAYERS THEN EXIT SUB
    IF LAYERS(layerIdx%).imgHandle& >= -1 THEN EXIT SUB
    DIM mlSBefore AS LONG
    mlSBefore& = 0
    IF NOT HISTORY_IN_PROGRESS% AND LAYERS(layerIdx%).historyId& > 0 THEN
        mlSBefore& = _COPYIMAGE(LAYERS(layerIdx%).imgHandle&, 32)
    END IF
    DIM mlSSrc AS LONG : mlSSrc& = LAYERS(layerIdx%).imgHandle&
    DIM mlSW AS LONG : mlSW& = _WIDTH(mlSSrc&)
    DIM mlSH AS LONG : mlSH& = _HEIGHT(mlSSrc&)
    DIM mlSNW AS INTEGER : mlSNW% = INT(mlSW& * factor!)
    DIM mlSNH AS INTEGER : mlSNH% = INT(mlSH& * factor!)
    IF mlSNW% < 1 THEN mlSNW% = 1
    IF mlSNH% < 1 THEN mlSNH% = 1
    DIM mlSTmp AS LONG : mlSTmp& = _NEWIMAGE(mlSNW%, mlSNH%, 32)
    _DONTBLEND mlSTmp&
    _PUTIMAGE (0, 0)-(mlSNW% - 1, mlSNH% - 1), mlSSrc&, mlSTmp&
    DIM mlSOD AS LONG : mlSOD& = _DEST
    _DEST mlSSrc&
    _DONTBLEND mlSSrc&
    CLS , _RGBA32(0, 0, 0, 0)
    ' Centre scaled content; use source offset when scaled > canvas, dest offset when scaled < canvas
    DIM mlSDX AS INTEGER : mlSDX% = (mlSW& - mlSNW%) \ 2
    DIM mlSDY AS INTEGER : mlSDY% = (mlSH& - mlSNH%) \ 2
    DIM mlSSX AS INTEGER : mlSSX% = 0
    DIM mlSSY AS INTEGER : mlSSY% = 0
    DIM mlSCW AS INTEGER : mlSCW% = mlSNW%
    DIM mlSCH AS INTEGER : mlSCH% = mlSNH%
    IF mlSDX% < 0 THEN mlSSX% = -mlSDX% : mlSCW% = mlSCW% + mlSDX% : mlSDX% = 0
    IF mlSDY% < 0 THEN mlSSY% = -mlSDY% : mlSCH% = mlSCH% + mlSDY% : mlSDY% = 0
    IF mlSDX% + mlSCW% > mlSW& THEN mlSCW% = mlSW& - mlSDX%
    IF mlSDY% + mlSCH% > mlSH& THEN mlSCH% = mlSH& - mlSDY%
    IF mlSCW% > 0 AND mlSCH% > 0 THEN
        _PUTIMAGE (mlSDX%, mlSDY%)-(mlSDX% + mlSCW% - 1, mlSDY% + mlSCH% - 1), mlSTmp&, mlSSrc&, (mlSSX%, mlSSY%)-(mlSSX% + mlSCW% - 1, mlSSY% + mlSCH% - 1)
    END IF
    _BLEND mlSSrc&
    _DEST mlSOD&
    IF mlSTmp& < -1 THEN _FREEIMAGE mlSTmp&
    IF mlSBefore& < -1 THEN
        HISTORY_record_transform LAYERS(layerIdx%).historyId&, layerIdx%, historyFlags&, mlSBefore&, historyLabel$
    END IF
    LAYERS(layerIdx%).contentDirty% = TRUE
END SUB

''
' Rotate layerIdx 90 degrees clockwise, centered on the canvas.
' @param layerIdx INTEGER - Index (1-64) of the layer to rotate
' @param historyFlags LONG - Flags passed to HISTORY_record_transform
' @param historyLabel STRING - Label for the history record (e.g. "Rotate CW")
'
SUB CMD_ml_rotate_cw (layerIdx AS INTEGER, historyFlags AS LONG, historyLabel AS STRING)
    IF layerIdx% < 1 OR layerIdx% > MAX_LAYERS THEN EXIT SUB
    IF LAYERS(layerIdx%).imgHandle& >= -1 THEN EXIT SUB
    DIM mlRcBefore AS LONG
    mlRcBefore& = 0
    IF NOT HISTORY_IN_PROGRESS% AND LAYERS(layerIdx%).historyId& > 0 THEN
        mlRcBefore& = _COPYIMAGE(LAYERS(layerIdx%).imgHandle&, 32)
    END IF
    DIM mlRcSrc AS LONG : mlRcSrc& = LAYERS(layerIdx%).imgHandle&
    DIM mlRcW AS LONG : mlRcW& = _WIDTH(mlRcSrc&)
    DIM mlRcH AS LONG : mlRcH& = _HEIGHT(mlRcSrc&)
    DIM mlRcRot AS LONG : mlRcRot& = _NEWIMAGE(mlRcH&, mlRcW&, 32)
    DIM mlRcOS AS LONG : mlRcOS& = _SOURCE
    DIM mlRcOD AS LONG : mlRcOD& = _DEST
    _SOURCE mlRcSrc& : _DEST mlRcRot&
    _DONTBLEND mlRcRot&
    CLS , _RGBA32(0, 0, 0, 0)
    DIM mlRcPx AS INTEGER, mlRcPy AS INTEGER
    FOR mlRcPy% = 0 TO mlRcH& - 1
        FOR mlRcPx% = 0 TO mlRcW& - 1
            PSET (mlRcH& - 1 - mlRcPy%, mlRcPx%), POINT(mlRcPx%, mlRcPy%)
        NEXT mlRcPx%
    NEXT mlRcPy%
    _BLEND mlRcRot&
    _SOURCE mlRcOS& : _DEST mlRcOD&
    ' Copy rotated content back centred / clipped to original layer dimensions
    DIM mlRcOD2 AS LONG : mlRcOD2& = _DEST
    _DEST mlRcSrc&
    _DONTBLEND mlRcSrc&
    CLS , _RGBA32(0, 0, 0, 0)
    DIM mlRcDx AS INTEGER : mlRcDx% = (mlRcW& - mlRcH&) \ 2
    DIM mlRcDy AS INTEGER : mlRcDy% = (mlRcH& - mlRcW&) \ 2
    DIM mlRcSx AS INTEGER : mlRcSx% = 0
    DIM mlRcSy AS INTEGER : mlRcSy% = 0
    DIM mlRcDw AS INTEGER : mlRcDw% = mlRcH&
    DIM mlRcDh AS INTEGER : mlRcDh% = mlRcW&
    IF mlRcDx% < 0 THEN mlRcSx% = -mlRcDx% : mlRcDw% = mlRcDw% - mlRcSx% : mlRcDx% = 0
    IF mlRcDy% < 0 THEN mlRcSy% = -mlRcDy% : mlRcDh% = mlRcDh% - mlRcSy% : mlRcDy% = 0
    IF mlRcDx% + mlRcDw% > mlRcW& THEN mlRcDw% = mlRcW& - mlRcDx%
    IF mlRcDy% + mlRcDh% > mlRcH& THEN mlRcDh% = mlRcH& - mlRcDy%
    IF mlRcDw% > 0 AND mlRcDh% > 0 THEN
        _PUTIMAGE (mlRcDx%, mlRcDy%)-(mlRcDx% + mlRcDw% - 1, mlRcDy% + mlRcDh% - 1), mlRcRot&, mlRcSrc&, (mlRcSx%, mlRcSy%)-(mlRcSx% + mlRcDw% - 1, mlRcSy% + mlRcDh% - 1)
    END IF
    _BLEND mlRcSrc&
    _DEST mlRcOD2&
    IF mlRcRot& < -1 THEN _FREEIMAGE mlRcRot&
    IF mlRcBefore& < -1 THEN
        HISTORY_record_transform LAYERS(layerIdx%).historyId&, layerIdx%, historyFlags&, mlRcBefore&, historyLabel$
    END IF
    LAYERS(layerIdx%).contentDirty% = TRUE
END SUB

''
' Rotate layerIdx 90 degrees counter-clockwise, centered on the canvas.
' @param layerIdx INTEGER - Index (1-64) of the layer to rotate
' @param historyFlags LONG - Flags passed to HISTORY_record_transform
' @param historyLabel STRING - Label for the history record (e.g. "Rotate CCW")
'
SUB CMD_ml_rotate_ccw (layerIdx AS INTEGER, historyFlags AS LONG, historyLabel AS STRING)
    IF layerIdx% < 1 OR layerIdx% > MAX_LAYERS THEN EXIT SUB
    IF LAYERS(layerIdx%).imgHandle& >= -1 THEN EXIT SUB
    DIM mlRccBefore AS LONG
    mlRccBefore& = 0
    IF NOT HISTORY_IN_PROGRESS% AND LAYERS(layerIdx%).historyId& > 0 THEN
        mlRccBefore& = _COPYIMAGE(LAYERS(layerIdx%).imgHandle&, 32)
    END IF
    DIM mlRccSrc AS LONG : mlRccSrc& = LAYERS(layerIdx%).imgHandle&
    DIM mlRccW AS LONG : mlRccW& = _WIDTH(mlRccSrc&)
    DIM mlRccH AS LONG : mlRccH& = _HEIGHT(mlRccSrc&)
    DIM mlRccRot AS LONG : mlRccRot& = _NEWIMAGE(mlRccH&, mlRccW&, 32)
    DIM mlRccOS AS LONG : mlRccOS& = _SOURCE
    DIM mlRccOD AS LONG : mlRccOD& = _DEST
    _SOURCE mlRccSrc& : _DEST mlRccRot&
    _DONTBLEND mlRccRot&
    CLS , _RGBA32(0, 0, 0, 0)
    DIM mlRccPx AS INTEGER, mlRccPy AS INTEGER
    FOR mlRccPy% = 0 TO mlRccH& - 1
        FOR mlRccPx% = 0 TO mlRccW& - 1
            PSET (mlRccPy%, mlRccW& - 1 - mlRccPx%), POINT(mlRccPx%, mlRccPy%)
        NEXT mlRccPx%
    NEXT mlRccPy%
    _BLEND mlRccRot&
    _SOURCE mlRccOS& : _DEST mlRccOD&
    DIM mlRccOD2 AS LONG : mlRccOD2& = _DEST
    _DEST mlRccSrc&
    _DONTBLEND mlRccSrc&
    CLS , _RGBA32(0, 0, 0, 0)
    DIM mlRccDx AS INTEGER : mlRccDx% = (mlRccW& - mlRccH&) \ 2
    DIM mlRccDy AS INTEGER : mlRccDy% = (mlRccH& - mlRccW&) \ 2
    DIM mlRccSx AS INTEGER : mlRccSx% = 0
    DIM mlRccSy AS INTEGER : mlRccSy% = 0
    DIM mlRccDw AS INTEGER : mlRccDw% = mlRccH&
    DIM mlRccDh AS INTEGER : mlRccDh% = mlRccW&
    IF mlRccDx% < 0 THEN mlRccSx% = -mlRccDx% : mlRccDw% = mlRccDw% - mlRccSx% : mlRccDx% = 0
    IF mlRccDy% < 0 THEN mlRccSy% = -mlRccDy% : mlRccDh% = mlRccDh% - mlRccSy% : mlRccDy% = 0
    IF mlRccDx% + mlRccDw% > mlRccW& THEN mlRccDw% = mlRccW& - mlRccDx%
    IF mlRccDy% + mlRccDh% > mlRccH& THEN mlRccDh% = mlRccH& - mlRccDy%
    IF mlRccDw% > 0 AND mlRccDh% > 0 THEN
        _PUTIMAGE (mlRccDx%, mlRccDy%)-(mlRccDx% + mlRccDw% - 1, mlRccDy% + mlRccDh% - 1), mlRccRot&, mlRccSrc&, (mlRccSx%, mlRccSy%)-(mlRccSx% + mlRccDw% - 1, mlRccSy% + mlRccDh% - 1)
    END IF
    _BLEND mlRccSrc&
    _DEST mlRccOD2&
    IF mlRccRot& < -1 THEN _FREEIMAGE mlRccRot&
    IF mlRccBefore& < -1 THEN
        HISTORY_record_transform LAYERS(layerIdx%).historyId&, layerIdx%, historyFlags&, mlRccBefore&, historyLabel$
    END IF
    LAYERS(layerIdx%).contentDirty% = TRUE
END SUB


''
' Check if screen coordinates are within the command palette bounds.
' @param x INTEGER Screen X coordinate to test
' @param y INTEGER Screen Y coordinate to test
' @return INTEGER - TRUE if the point is inside the palette area
'
FUNCTION CMD_in_bounds% (x AS INTEGER, y AS INTEGER)
    CMD_in_bounds% = (x% >= CMD_PALETTE_X AND x% <= CMD_PALETTE_X + CMD_PALETTE_W AND _
                      y% >= CMD_PALETTE_Y AND y% <= CMD_PALETTE_Y + CMD_PALETTE_H)
END FUNCTION


''
' Get category name from category constant
' @param cat INTEGER - Category constant (CMD_CAT_*) to look up
' @return STRING - Human-readable category label (e.g. "Tool", "File", "Edit")
'
FUNCTION CMD_category_name$ (cat AS INTEGER)
    SELECT CASE cat%
        CASE CMD_CAT_TOOL: CMD_category_name$ = "Tool"
        CASE CMD_CAT_FILE: CMD_category_name$ = "File"
        CASE CMD_CAT_EDIT: CMD_category_name$ = "Edit"
        CASE CMD_CAT_VIEW: CMD_category_name$ = "View"
        CASE CMD_CAT_COLOR: CMD_category_name$ = "Color"
        CASE CMD_CAT_BRUSH: CMD_category_name$ = "Brush"
        CASE CMD_CAT_LAYER: CMD_category_name$ = "Layer"
        CASE CMD_CAT_CANVAS: CMD_category_name$ = "Canvas"
        CASE CMD_CAT_ASSIST: CMD_category_name$ = "Assist"
        CASE CMD_CAT_CUSTOM: CMD_category_name$ = "Custom"
        CASE CMD_CAT_GRID: CMD_category_name$ = "Grid"
        CASE CMD_CAT_SYMM: CMD_category_name$ = "Symmetry"
        CASE CMD_CAT_SELECT: CMD_category_name$ = "Select"
        CASE CMD_CAT_HELP: CMD_category_name$ = "Help"
        CASE ELSE: CMD_category_name$ = "Other"
    END SELECT
END FUNCTION
