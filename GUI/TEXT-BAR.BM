''
' DRAW - GUI/TEXT-BAR.BM
' =============================================================================
' Text formatting bar — renders below menu bar when text tool is active.
' Provides font picker, size, style toggles [B][I][U][S], color swatches,
' [LOAD] button for custom fonts, and [DONE] to commit text editing.
'
' @author Rick Christy <grymmjack@gmail.com>
'
$INCLUDEONCE
OPTION _EXPLICIT
OPTION _EXPLICITARRAY
'$DYNAMIC


''
' Initialize text bar with default values.
'
SUB TEXT_BAR_init ()
    TEXT_BAR.visible% = FALSE
    TEXT_BAR.fontDropdownOpen% = FALSE
    TEXT_BAR.sizeDropdownOpen% = FALSE
    TEXT_BAR.fontDropdownScroll% = 0
    TEXT_BAR.selectedFontIdx% = 0
    TEXT_BAR.selectedSize% = 8
    TEXT_BAR.boldActive% = FALSE
    TEXT_BAR.italicActive% = FALSE
    TEXT_BAR.underlineActive% = FALSE
    TEXT_BAR.strikeActive% = FALSE
    TEXT_BAR.barH% = THEME.TEXT_BAR_ROW_HEIGHT% * 2
    TEXT_BAR.hoverBtn% = TEXT_BTN_NONE
    TEXT_BAR.lastPaintColor~& = 0
    TEXT_BAR.lastPaintBgColor~& = 0
    TEXT_BAR.editingLayerIdx% = 0
    TEXT_BAR.autoLineHeight% = TRUE
    TEXT_BAR.needsRedraw% = TRUE
    TEXT_BAR.outlineActive% = FALSE
    TEXT_BAR.outlineColor~& = _RGB32(0, 0, 0)
    TEXT_BAR.outlineSize% = 1
    TEXT_BAR.shadowActive% = FALSE
    TEXT_BAR.shadowColor~& = _RGB32(0, 0, 0)
    TEXT_BAR.shadowOffsetX% = 2
    TEXT_BAR.shadowOffsetY% = 2
    TEXT_BAR.alignMode% = TEXT_ALIGN_LEFT
    TEXT_BAR.aaActive% = TRUE
    TEXT_BAR.styleDropdownOpen% = FALSE
    TEXT_BAR.styleDropdownScroll% = 0
    TEXT_BAR.fontDropdownHoverRow% = -1
    TEXT_BAR.sizeDropdownHoverRow% = -1
    TEXT_BAR.styleDropdownHoverRow% = -1

    ' Populate preset sizes (4-17 individually, then larger steps)
    TEXT_BAR_SIZES(0) = 4
    TEXT_BAR_SIZES(1) = 5
    TEXT_BAR_SIZES(2) = 6
    TEXT_BAR_SIZES(3) = 7
    TEXT_BAR_SIZES(4) = 8
    TEXT_BAR_SIZES(5) = 9
    TEXT_BAR_SIZES(6) = 10
    TEXT_BAR_SIZES(7) = 11
    TEXT_BAR_SIZES(8) = 12
    TEXT_BAR_SIZES(9) = 13
    TEXT_BAR_SIZES(10) = 14
    TEXT_BAR_SIZES(11) = 15
    TEXT_BAR_SIZES(12) = 16
    TEXT_BAR_SIZES(13) = 17
    TEXT_BAR_SIZES(14) = 18
    TEXT_BAR_SIZES(15) = 20
    TEXT_BAR_SIZES(16) = 24
    TEXT_BAR_SIZES(17) = 28
    TEXT_BAR_SIZES(18) = 32
    TEXT_BAR_SIZES(19) = 48
    TEXT_BAR_SIZES(20) = 64
    TEXT_BAR_SIZES(21) = 72
    TEXT_BAR_SIZES(22) = 96
    TEXT_BAR_SIZES(23) = 112
    TEXT_BAR_SIZES(24) = 128

    ' Resolve default font immediately so the bar
    ' shows the correct name before the user clicks on canvas
    FONT_LIST_scan
    IF FONT_LIST_COUNT% > 0 THEN
        DIM initTiny5 AS INTEGER
        initTiny5% = -1
        ' Check for user-configured default font first
        IF LEN(CFG.FONT_DEFAULT_FONT$) > 0 THEN
            initTiny5% = FONT_LIST_find_by_name%(CFG.FONT_DEFAULT_FONT$)
        END IF
        ' Fall back to Tiny5 Regular if no config or not found
        IF initTiny5% < 0 THEN initTiny5% = FONT_LIST_find_by_name%("Tiny5 Regular")
        IF initTiny5% < 0 THEN initTiny5% = FONT_LIST_find_by_name%("Tiny5")
        IF initTiny5% >= 0 THEN TEXT_BAR.selectedFontIdx% = initTiny5%
    END IF
    ' Apply configured default font size (4-128), or keep program default (8)
    IF CFG.FONT_DEFAULT_SIZE% >= 4 AND CFG.FONT_DEFAULT_SIZE% <= 128 THEN
        TEXT_BAR.selectedSize% = CFG.FONT_DEFAULT_SIZE%
    END IF

    ' Load saved text style presets
    TEXT_STYLE_load
END SUB


''
' TRUE when the given font index is safe for Character Mode / CP437 glyph use.
'
FUNCTION TEXT_BAR_char_mode_font_is_safe% (fontIdx AS INTEGER)
    TEXT_BAR_char_mode_font_is_safe% = FALSE
    IF fontIdx% < 0 OR fontIdx% >= FONT_LIST_COUNT% THEN EXIT FUNCTION
    IF FONT_LIST(fontIdx%).isBuiltIn OR FONT_LIST(fontIdx%).isBitmapFont THEN
        TEXT_BAR_char_mode_font_is_safe% = TRUE
    END IF
END FUNCTION


''
' Character Mode relies on a full CP437-safe glyph set.
' Force a built-in or bitmap font when the current text font is scalable.
'
SUB TEXT_BAR_ensure_char_mode_safe_font ()
    DIM safeIdx AS INTEGER
    DIM i AS INTEGER

    IF NOT CHARMAP.useChars% THEN EXIT SUB
    FONT_LIST_scan
    IF FONT_LIST_COUNT% < 1 THEN EXIT SUB
    IF TEXT_BAR_char_mode_font_is_safe%(TEXT_BAR.selectedFontIdx%) THEN EXIT SUB

    safeIdx% = FONT_LIST_find_by_name%("QB64 8x16")
    IF safeIdx% < 0 THEN safeIdx% = FONT_LIST_find_by_name%("QB64 8x8")

    IF safeIdx% < 0 THEN
        FOR i% = 0 TO FONT_LIST_COUNT% - 1
            IF TEXT_BAR_char_mode_font_is_safe%(i%) THEN
                safeIdx% = i%
                EXIT FOR
            END IF
        NEXT i%
    END IF

    IF safeIdx% < 0 THEN EXIT SUB

    TEXT_BAR.selectedFontIdx% = safeIdx%
    IF FONT_LIST(safeIdx%).isBuiltIn THEN
        TEXT_BAR.selectedSize% = FONT_LIST(safeIdx%).builtInHandle
    ELSEIF FONT_LIST(safeIdx%).isBitmapFont THEN
        TEXT_BAR.selectedSize% = FONT_LIST(safeIdx%).bitmapGlyphH
    END IF

    TEXT_BAR.monoActive% = TRUE
    TEXT_BAR.autoLineHeight% = TRUE
    CHARMAP.cacheValid% = FALSE

    IF TEXT_BAR.editingLayerIdx% >= 1 THEN
        DIM safeTd AS INTEGER
        safeTd% = LAYERS(TEXT_BAR.editingLayerIdx%).textDataIdx%
        IF safeTd% >= 1 THEN
            TEXT_LAYER_DATA(safeTd%).fontIdx = TEXT_BAR.selectedFontIdx%
            TEXT_LAYER_DATA(safeTd%).fontSize = TEXT_BAR.selectedSize%
            TEXT_LAYER_DATA(safeTd%).monospace = TRUE
            IF FONT_LIST(safeIdx%).isBuiltIn THEN
                TEXT_LAYER_DATA(safeTd%).defaultLeading = FONT_LIST(safeIdx%).builtInHandle
            ELSE
                TEXT_LAYER_DATA(safeTd%).defaultLeading = FONT_LIST(safeIdx%).bitmapGlyphH
            END IF
            TEXT_LAYER_DATA(safeTd%).dirty = TRUE
        END IF
    END IF
END SUB


''
' Load text bar button icons from the theme directory.
' Called lazily on first render (THEME fields are empty at init time).
'
SUB TEXT_BAR_load_icons ()
    DIM themeDir AS STRING
    themeDir$ = "ASSETS/THEMES/" + _TRIM$(CFG.THEME$) + "/"

    DIM iconFile AS STRING

    iconFile$ = _TRIM$(THEME.TEXT_BAR_ICON_BOLD$)
    IF LEN(iconFile$) > 0 THEN TEXT_BAR.iconBold& = _LOADIMAGE(themeDir$ + iconFile$, 32)

    iconFile$ = _TRIM$(THEME.TEXT_BAR_ICON_ITALIC$)
    IF LEN(iconFile$) > 0 THEN TEXT_BAR.iconItalic& = _LOADIMAGE(themeDir$ + iconFile$, 32)

    iconFile$ = _TRIM$(THEME.TEXT_BAR_ICON_UNDERLINE$)
    IF LEN(iconFile$) > 0 THEN TEXT_BAR.iconUnderline& = _LOADIMAGE(themeDir$ + iconFile$, 32)

    iconFile$ = _TRIM$(THEME.TEXT_BAR_ICON_STRIKE$)
    IF LEN(iconFile$) > 0 THEN TEXT_BAR.iconStrike& = _LOADIMAGE(themeDir$ + iconFile$, 32)

    iconFile$ = _TRIM$(THEME.TEXT_BAR_ICON_MONO$)
    IF LEN(iconFile$) > 0 THEN TEXT_BAR.iconMono& = _LOADIMAGE(themeDir$ + iconFile$, 32)

    iconFile$ = _TRIM$(THEME.TEXT_BAR_ICON_LINE_HEIGHT$)
    IF LEN(iconFile$) > 0 THEN TEXT_BAR.iconLineHeight& = _LOADIMAGE(themeDir$ + iconFile$, 32)

    ' Build deselected (dimmed) copies with per-pixel alpha scaling
    DIM dimScale AS SINGLE
    dimScale! = THEME.TEXT_BAR_ICON_DESELECTED_OPACITY% / 255!
    IF dimScale! < 0 THEN dimScale! = 0
    IF dimScale! > 1 THEN dimScale! = 1

    IF TEXT_BAR.iconBold& < -1 THEN
        TEXT_BAR.iconBoldOff& = _COPYIMAGE(TEXT_BAR.iconBold&)
        TEXT_BAR_dim_icon TEXT_BAR.iconBoldOff&, dimScale!
    END IF
    IF TEXT_BAR.iconItalic& < -1 THEN
        TEXT_BAR.iconItalicOff& = _COPYIMAGE(TEXT_BAR.iconItalic&)
        TEXT_BAR_dim_icon TEXT_BAR.iconItalicOff&, dimScale!
    END IF
    IF TEXT_BAR.iconUnderline& < -1 THEN
        TEXT_BAR.iconUnderlineOff& = _COPYIMAGE(TEXT_BAR.iconUnderline&)
        TEXT_BAR_dim_icon TEXT_BAR.iconUnderlineOff&, dimScale!
    END IF
    IF TEXT_BAR.iconStrike& < -1 THEN
        TEXT_BAR.iconStrikeOff& = _COPYIMAGE(TEXT_BAR.iconStrike&)
        TEXT_BAR_dim_icon TEXT_BAR.iconStrikeOff&, dimScale!
    END IF
    IF TEXT_BAR.iconMono& < -1 THEN
        TEXT_BAR.iconMonoOff& = _COPYIMAGE(TEXT_BAR.iconMono&)
        TEXT_BAR_dim_icon TEXT_BAR.iconMonoOff&, dimScale!
    END IF
    IF TEXT_BAR.iconLineHeight& < -1 THEN
        TEXT_BAR.iconLineHeightOff& = _COPYIMAGE(TEXT_BAR.iconLineHeight&)
        TEXT_BAR_dim_icon TEXT_BAR.iconLineHeightOff&, dimScale!
    END IF

    ' --- Row 2 icons ---
    iconFile$ = _TRIM$(THEME.TEXT_BAR_ICON_OUTLINE$)
    IF LEN(iconFile$) > 0 THEN TEXT_BAR.iconOutline& = _LOADIMAGE(themeDir$ + iconFile$, 32)
    iconFile$ = _TRIM$(THEME.TEXT_BAR_ICON_SHADOW$)
    IF LEN(iconFile$) > 0 THEN TEXT_BAR.iconShadow& = _LOADIMAGE(themeDir$ + iconFile$, 32)
    iconFile$ = _TRIM$(THEME.TEXT_BAR_ICON_ALIGN_LEFT$)
    IF LEN(iconFile$) > 0 THEN TEXT_BAR.iconAlignL& = _LOADIMAGE(themeDir$ + iconFile$, 32)
    iconFile$ = _TRIM$(THEME.TEXT_BAR_ICON_ALIGN_CENTER$)
    IF LEN(iconFile$) > 0 THEN TEXT_BAR.iconAlignC& = _LOADIMAGE(themeDir$ + iconFile$, 32)
    iconFile$ = _TRIM$(THEME.TEXT_BAR_ICON_ALIGN_RIGHT$)
    IF LEN(iconFile$) > 0 THEN TEXT_BAR.iconAlignR& = _LOADIMAGE(themeDir$ + iconFile$, 32)
    iconFile$ = _TRIM$(THEME.TEXT_BAR_ICON_STYLE_UPDATE$)
    IF LEN(iconFile$) > 0 THEN TEXT_BAR.iconStyleU& = _LOADIMAGE(themeDir$ + iconFile$, 32)
    iconFile$ = _TRIM$(THEME.TEXT_BAR_ICON_STYLE_SAVE$)
    IF LEN(iconFile$) > 0 THEN TEXT_BAR.iconStyleS& = _LOADIMAGE(themeDir$ + iconFile$, 32)
    iconFile$ = _TRIM$(THEME.TEXT_BAR_ICON_STYLE_DELETE$)
    IF LEN(iconFile$) > 0 THEN TEXT_BAR.iconStyleX& = _LOADIMAGE(themeDir$ + iconFile$, 32)
    iconFile$ = _TRIM$(THEME.TEXT_BAR_ICON_AUTO$)
    IF LEN(iconFile$) > 0 THEN TEXT_BAR.iconAuto& = _LOADIMAGE(themeDir$ + iconFile$, 32)
    iconFile$ = _TRIM$(THEME.TEXT_BAR_ICON_CHAR$)
    IF LEN(iconFile$) > 0 THEN TEXT_BAR.iconChar& = _LOADIMAGE(themeDir$ + iconFile$, 32)
    iconFile$ = _TRIM$(THEME.TEXT_BAR_ICON_AA$)
    IF LEN(iconFile$) > 0 THEN TEXT_BAR.iconAA& = _LOADIMAGE(themeDir$ + iconFile$, 32)

    ' Build dimmed copies for row 2 toggle icons
    IF TEXT_BAR.iconOutline& < -1 THEN
        TEXT_BAR.iconOutlineOff& = _COPYIMAGE(TEXT_BAR.iconOutline&)
        TEXT_BAR_dim_icon TEXT_BAR.iconOutlineOff&, dimScale!
    END IF
    IF TEXT_BAR.iconShadow& < -1 THEN
        TEXT_BAR.iconShadowOff& = _COPYIMAGE(TEXT_BAR.iconShadow&)
        TEXT_BAR_dim_icon TEXT_BAR.iconShadowOff&, dimScale!
    END IF
    IF TEXT_BAR.iconAlignL& < -1 THEN
        TEXT_BAR.iconAlignLOff& = _COPYIMAGE(TEXT_BAR.iconAlignL&)
        TEXT_BAR_dim_icon TEXT_BAR.iconAlignLOff&, dimScale!
    END IF
    IF TEXT_BAR.iconAlignC& < -1 THEN
        TEXT_BAR.iconAlignCOff& = _COPYIMAGE(TEXT_BAR.iconAlignC&)
        TEXT_BAR_dim_icon TEXT_BAR.iconAlignCOff&, dimScale!
    END IF
    IF TEXT_BAR.iconAlignR& < -1 THEN
        TEXT_BAR.iconAlignROff& = _COPYIMAGE(TEXT_BAR.iconAlignR&)
        TEXT_BAR_dim_icon TEXT_BAR.iconAlignROff&, dimScale!
    END IF
    IF TEXT_BAR.iconAuto& < -1 THEN
        TEXT_BAR.iconAutoOff& = _COPYIMAGE(TEXT_BAR.iconAuto&)
        TEXT_BAR_dim_icon TEXT_BAR.iconAutoOff&, dimScale!
    END IF
    IF TEXT_BAR.iconChar& < -1 THEN
        TEXT_BAR.iconCharOff& = _COPYIMAGE(TEXT_BAR.iconChar&)
        TEXT_BAR_dim_icon TEXT_BAR.iconCharOff&, dimScale!
    END IF
    IF TEXT_BAR.iconAA& < -1 THEN
        TEXT_BAR.iconAAOff& = _COPYIMAGE(TEXT_BAR.iconAA&)
        TEXT_BAR_dim_icon TEXT_BAR.iconAAOff&, dimScale!
    END IF

    TEXT_BAR.iconsLoaded% = TRUE
END SUB


''
' Scale per-pixel alpha on an icon handle for dimmed rendering.
'
SUB TEXT_BAR_dim_icon (handle AS LONG, dimScale AS SINGLE)
    DIM m AS _MEM
    DIM px AS _UNSIGNED LONG
    DIM a AS INTEGER, newA AS INTEGER
    DIM offs AS _OFFSET

    m = _MEMIMAGE(handle&)
    offs = m.OFFSET
    DO WHILE offs < m.OFFSET + m.SIZE
        px~& = _MEMGET(m, offs, _UNSIGNED LONG)
        a% = _ALPHA32(px~&)
        IF a% > 0 THEN
            newA% = INT(a% * dimScale!)
            IF newA% < 0 THEN newA% = 0
            px~& = _RGBA32(_RED32(px~&), _GREEN32(px~&), _BLUE32(px~&), newA%)
            _MEMPUT m, offs, px~& AS _UNSIGNED LONG
        END IF
        offs = offs + 4
    LOOP
    _MEMFREE m
END SUB


''
' Render the text formatting bar on the GUI overlay.
' Call from RENDER_gui_elements when TEXT_BAR.visible is TRUE.
'
SUB TEXT_BAR_render ()
    IF NOT TEXT_BAR.visible% THEN EXIT SUB

    ' CPU frugality: skip full render when nothing changed (unless dropdown open)
    IF NOT TEXT_BAR.needsRedraw% THEN
        IF TEXT_BAR.fontDropdownOpen% OR TEXT_BAR.sizeDropdownOpen% OR TEXT_BAR.styleDropdownOpen% THEN
            ' Dropdowns need per-frame hover update — fall through
        ELSE
            EXIT SUB
        END IF
    END IF

    DIM oldDest AS LONG
    oldDest& = _DEST
    _DEST SCRN.GUI&

    ' Lazy-load icons on first render
    IF NOT TEXT_BAR.iconsLoaded% THEN TEXT_BAR_load_icons

    DIM bx AS INTEGER, by AS INTEGER, bw AS INTEGER, bh AS INTEGER
    DIM rowH AS INTEGER
    bx% = TEXT_BAR.barX%
    by% = TEXT_BAR.barY%
    bw% = TEXT_BAR.barW%
    bh% = TEXT_BAR.barH%
    rowH% = THEME.TEXT_BAR_ROW_HEIGHT%

    ' Background (both rows)
    LINE (bx%, by%)-(bx% + bw% - 1, by% + bh% - 1), THEME.TEXT_BAR_BG~&, BF
    ' Row separator
    LINE (bx%, by% + rowH% - 1)-(bx% + bw% - 1, by% + rowH% - 1), THEME.TEXT_BAR_BORDER~&
    ' Bottom border
    LINE (bx%, by% + bh% - 1)-(bx% + bw% - 1, by% + bh% - 1), THEME.TEXT_BAR_BORDER~&

    ' For row 1 button math, bh% = single row height
    bh% = rowH%

    ' Use the menu bar font for consistency
    DIM oldFont AS LONG
    oldFont& = _FONT
    IF MENU_BAR.fontHandle& > 0 THEN _FONT MENU_BAR.fontHandle&, SCRN.GUI&

    DIM cx AS INTEGER
    cx% = bx% + 4

    ' --- FONT label + name button ---
    COLOR THEME.TEXT_BAR_FG~&, _RGBA32(0, 0, 0, 0)
    _UPRINTSTRING (cx%, by% + 3), "FONT:"
    cx% = cx% + _PRINTWIDTH("FONT:") + 3

    ' Font name button
    DIM fontName AS STRING
    IF FONT_LIST_COUNT% > 0 AND TEXT_BAR.selectedFontIdx% >= 0 AND TEXT_BAR.selectedFontIdx% < FONT_LIST_COUNT% THEN
        fontName$ = RTRIM$(FONT_LIST(TEXT_BAR.selectedFontIdx%).displayName)
    ELSE
        fontName$ = "(none)"
    END IF
    IF LEN(fontName$) > 16 THEN fontName$ = LEFT$(fontName$, 15) + "~"

    DIM fontBtnW AS INTEGER
    fontBtnW% = _PRINTWIDTH(fontName$) + 12
    TEXT_BAR.fontBtnX% = cx%
    TEXT_BAR.fontBtnW% = fontBtnW% + 6  ' include down arrow area
    IF TEXT_BAR.hoverBtn% = TEXT_BTN_FONT OR TEXT_BAR.fontDropdownOpen% THEN
        LINE (cx%, by% + 1)-(cx% + fontBtnW% - 1, by% + bh% - 3), THEME.TEXT_BAR_BTN_HOVER~&, BF
    END IF
    _UPRINTSTRING (cx% + 4, by% + 3), fontName$
    cx% = cx% + fontBtnW% + 2

    ' Down arrow
    _UPRINTSTRING (cx% - 8, by% + 3), CHR$(25)
    cx% = cx% + 4

    ' --- SIZE label + value ---
    _UPRINTSTRING (cx%, by% + 3), "SIZE:"
    cx% = cx% + _PRINTWIDTH("SIZE:") + 3

    DIM sizeStr AS STRING
    sizeStr$ = _TRIM$(STR$(TEXT_BAR.selectedSize%))
    DIM sizeBtnW AS INTEGER
    sizeBtnW% = _PRINTWIDTH(sizeStr$) + 12
    TEXT_BAR.sizeBtnX% = cx%
    TEXT_BAR.sizeBtnW% = sizeBtnW% + 6  ' include down arrow area
    IF TEXT_BAR.hoverBtn% = TEXT_BTN_SIZE OR TEXT_BAR.sizeDropdownOpen% THEN
        LINE (cx%, by% + 1)-(cx% + sizeBtnW% - 1, by% + bh% - 3), THEME.TEXT_BAR_BTN_HOVER~&, BF
    END IF
    _UPRINTSTRING (cx% + 4, by% + 3), sizeStr$
    cx% = cx% + sizeBtnW% + 2

    ' Down arrow
    _UPRINTSTRING (cx% - 8, by% + 3), CHR$(25)
    cx% = cx% + 6

    ' --- Style toggle buttons [B] [I] [U] [S] ---
    DIM btnW AS INTEGER
    btnW% = 12
    TEXT_BAR.styleBtnW% = btnW%
    DIM iconY AS INTEGER
    iconY% = by% + 2  ' vertically center 10px icon in 14px bar

    ' Bold
    TEXT_BAR.boldBtnX% = cx%
    IF TEXT_BAR.boldActive% THEN
        LINE (cx%, by% + 1)-(cx% + btnW% - 1, by% + bh% - 3), THEME.TEXT_BAR_BTN_ACTIVE~&, BF
    ELSEIF TEXT_BAR.hoverBtn% = TEXT_BTN_BOLD THEN
        LINE (cx%, by% + 1)-(cx% + btnW% - 1, by% + bh% - 3), THEME.TEXT_BAR_BTN_HOVER~&, BF
    ELSE
        LINE (cx%, by% + 1)-(cx% + btnW% - 1, by% + bh% - 3), THEME.TEXT_BAR_BTN_BG~&, BF
    END IF
    LINE (cx%, by% + 1)-(cx% + btnW% - 1, by% + bh% - 3), THEME.TEXT_BAR_BTN_BORDER~&, B
    IF TEXT_BAR.iconBold& < -1 THEN
        IF TEXT_BAR.boldActive% THEN
            _PUTIMAGE (cx% + 1, iconY%)-(cx% + 10, iconY% + 9), TEXT_BAR.iconBold&
        ELSE
            _PUTIMAGE (cx% + 1, iconY%)-(cx% + 10, iconY% + 9), TEXT_BAR.iconBoldOff&
        END IF
    ELSE
        IF TEXT_BAR.boldActive% THEN
            COLOR THEME.TEXT_BAR_FG~&, _RGBA32(0, 0, 0, 0)
        ELSE
            COLOR THEME.TEXT_BAR_BTN_FG~&, _RGBA32(0, 0, 0, 0)
        END IF
        _UPRINTSTRING (cx% + 3, by% + 3), "B"
    END IF
    cx% = cx% + btnW% + 2

    ' Italic
    TEXT_BAR.italicBtnX% = cx%
    IF TEXT_BAR.italicActive% THEN
        LINE (cx%, by% + 1)-(cx% + btnW% - 1, by% + bh% - 3), THEME.TEXT_BAR_BTN_ACTIVE~&, BF
    ELSEIF TEXT_BAR.hoverBtn% = TEXT_BTN_ITALIC THEN
        LINE (cx%, by% + 1)-(cx% + btnW% - 1, by% + bh% - 3), THEME.TEXT_BAR_BTN_HOVER~&, BF
    ELSE
        LINE (cx%, by% + 1)-(cx% + btnW% - 1, by% + bh% - 3), THEME.TEXT_BAR_BTN_BG~&, BF
    END IF
    LINE (cx%, by% + 1)-(cx% + btnW% - 1, by% + bh% - 3), THEME.TEXT_BAR_BTN_BORDER~&, B
    IF TEXT_BAR.iconItalic& < -1 THEN
        IF TEXT_BAR.italicActive% THEN
            _PUTIMAGE (cx% + 1, iconY%)-(cx% + 10, iconY% + 9), TEXT_BAR.iconItalic&
        ELSE
            _PUTIMAGE (cx% + 1, iconY%)-(cx% + 10, iconY% + 9), TEXT_BAR.iconItalicOff&
        END IF
    ELSE
        IF TEXT_BAR.italicActive% THEN
            COLOR THEME.TEXT_BAR_FG~&, _RGBA32(0, 0, 0, 0)
        ELSE
            COLOR THEME.TEXT_BAR_BTN_FG~&, _RGBA32(0, 0, 0, 0)
        END IF
        _UPRINTSTRING (cx% + 3, by% + 3), "I"
    END IF
    cx% = cx% + btnW% + 2

    ' Underline
    TEXT_BAR.underlineBtnX% = cx%
    IF TEXT_BAR.underlineActive% THEN
        LINE (cx%, by% + 1)-(cx% + btnW% - 1, by% + bh% - 3), THEME.TEXT_BAR_BTN_ACTIVE~&, BF
    ELSEIF TEXT_BAR.hoverBtn% = TEXT_BTN_UNDERLINE THEN
        LINE (cx%, by% + 1)-(cx% + btnW% - 1, by% + bh% - 3), THEME.TEXT_BAR_BTN_HOVER~&, BF
    ELSE
        LINE (cx%, by% + 1)-(cx% + btnW% - 1, by% + bh% - 3), THEME.TEXT_BAR_BTN_BG~&, BF
    END IF
    LINE (cx%, by% + 1)-(cx% + btnW% - 1, by% + bh% - 3), THEME.TEXT_BAR_BTN_BORDER~&, B
    IF TEXT_BAR.iconUnderline& < -1 THEN
        IF TEXT_BAR.underlineActive% THEN
            _PUTIMAGE (cx% + 1, iconY%)-(cx% + 10, iconY% + 9), TEXT_BAR.iconUnderline&
        ELSE
            _PUTIMAGE (cx% + 1, iconY%)-(cx% + 10, iconY% + 9), TEXT_BAR.iconUnderlineOff&
        END IF
    ELSE
        IF TEXT_BAR.underlineActive% THEN
            COLOR THEME.TEXT_BAR_FG~&, _RGBA32(0, 0, 0, 0)
        ELSE
            COLOR THEME.TEXT_BAR_BTN_FG~&, _RGBA32(0, 0, 0, 0)
        END IF
        _UPRINTSTRING (cx% + 3, by% + 3), "U"
    END IF
    cx% = cx% + btnW% + 2

    ' Strikethrough
    TEXT_BAR.strikeBtnX% = cx%
    IF TEXT_BAR.strikeActive% THEN
        LINE (cx%, by% + 1)-(cx% + btnW% - 1, by% + bh% - 3), THEME.TEXT_BAR_BTN_ACTIVE~&, BF
    ELSEIF TEXT_BAR.hoverBtn% = TEXT_BTN_STRIKE THEN
        LINE (cx%, by% + 1)-(cx% + btnW% - 1, by% + bh% - 3), THEME.TEXT_BAR_BTN_HOVER~&, BF
    ELSE
        LINE (cx%, by% + 1)-(cx% + btnW% - 1, by% + bh% - 3), THEME.TEXT_BAR_BTN_BG~&, BF
    END IF
    LINE (cx%, by% + 1)-(cx% + btnW% - 1, by% + bh% - 3), THEME.TEXT_BAR_BTN_BORDER~&, B
    IF TEXT_BAR.iconStrike& < -1 THEN
        IF TEXT_BAR.strikeActive% THEN
            _PUTIMAGE (cx% + 1, iconY%)-(cx% + 10, iconY% + 9), TEXT_BAR.iconStrike&
        ELSE
            _PUTIMAGE (cx% + 1, iconY%)-(cx% + 10, iconY% + 9), TEXT_BAR.iconStrikeOff&
        END IF
    ELSE
        IF TEXT_BAR.strikeActive% THEN
            COLOR THEME.TEXT_BAR_FG~&, _RGBA32(0, 0, 0, 0)
        ELSE
            COLOR THEME.TEXT_BAR_BTN_FG~&, _RGBA32(0, 0, 0, 0)
        END IF
        _UPRINTSTRING (cx% + 3, by% + 3), "S"
    END IF
    cx% = cx% + btnW% + 4

    ' --- FG color swatch ---
    TEXT_BAR.fgSwatchX% = cx%
    IF PAL_FG_IS_TRANSPARENT% THEN
        ' Draw checkerboard to indicate transparency
        DIM cfby AS INTEGER, cfbx AS INTEGER
        FOR cfby% = by% + 2 TO by% + bh% - 4
            FOR cfbx% = cx% TO cx% + 9
                IF ((cfbx% + cfby%) AND 1) = 0 THEN
                    PSET (cfbx%, cfby%), _RGB32(192, 192, 192)
                ELSE
                    PSET (cfbx%, cfby%), _RGB32(255, 255, 255)
                END IF
            NEXT cfbx%
        NEXT cfby%
    ELSE
        LINE (cx%, by% + 2)-(cx% + 9, by% + bh% - 4), PAINT_COLOR~&, BF
    END IF
    LINE (cx%, by% + 2)-(cx% + 9, by% + bh% - 4), THEME.TEXT_BAR_FG~&, B
    cx% = cx% + 14

    ' --- BG color swatch ---
    TEXT_BAR.bgSwatchX% = cx%
    IF PAL_BG_IS_TRANSPARENT% THEN
        ' Draw checkerboard to indicate transparency
        DIM cby AS INTEGER, cbx AS INTEGER
        FOR cby% = by% + 2 TO by% + bh% - 4
            FOR cbx% = cx% TO cx% + 9
                IF ((cbx% + cby%) AND 1) = 0 THEN
                    PSET (cbx%, cby%), _RGB32(192, 192, 192)
                ELSE
                    PSET (cbx%, cby%), _RGB32(255, 255, 255)
                END IF
            NEXT cbx%
        NEXT cby%
    ELSE
        LINE (cx%, by% + 2)-(cx% + 9, by% + bh% - 4), PAINT_BG_COLOR~&, BF
    END IF
    LINE (cx%, by% + 2)-(cx% + 9, by% + bh% - 4), THEME.TEXT_BAR_FG~&, B
    cx% = cx% + 16

    ' --- Monospace toggle [MONO] ---
    TEXT_BAR.monoBtnX% = cx%
    DIM monoBtnW AS INTEGER
    IF TEXT_BAR.iconMono& < -1 THEN
        monoBtnW% = btnW%  ' icon: same width as style buttons
    ELSE
        monoBtnW% = _PRINTWIDTH("MONO") + 4  ' text: dynamic width
    END IF
    TEXT_BAR.monoBtnW% = monoBtnW%
    IF TEXT_BAR.monoActive% THEN
        LINE (cx%, by% + 1)-(cx% + monoBtnW% - 1, by% + bh% - 3), THEME.TEXT_BAR_BTN_ACTIVE~&, BF
    ELSEIF TEXT_BAR.hoverBtn% = TEXT_BTN_MONO THEN
        LINE (cx%, by% + 1)-(cx% + monoBtnW% - 1, by% + bh% - 3), THEME.TEXT_BAR_BTN_HOVER~&, BF
    ELSE
        LINE (cx%, by% + 1)-(cx% + monoBtnW% - 1, by% + bh% - 3), THEME.TEXT_BAR_BTN_BG~&, BF
    END IF
    LINE (cx%, by% + 1)-(cx% + monoBtnW% - 1, by% + bh% - 3), THEME.TEXT_BAR_BTN_BORDER~&, B
    IF TEXT_BAR.iconMono& < -1 THEN
        IF TEXT_BAR.monoActive% THEN
            _PUTIMAGE (cx% + 1, iconY%)-(cx% + 10, iconY% + 9), TEXT_BAR.iconMono&
        ELSE
            _PUTIMAGE (cx% + 1, iconY%)-(cx% + 10, iconY% + 9), TEXT_BAR.iconMonoOff&
        END IF
    ELSE
        IF TEXT_BAR.monoActive% THEN
            COLOR THEME.TEXT_BAR_FG~&, _RGBA32(0, 0, 0, 0)
        ELSE
            COLOR THEME.TEXT_BAR_BTN_FG~&, _RGBA32(0, 0, 0, 0)
        END IF
        _UPRINTSTRING (cx% + 2, by% + 3), "MONO"
    END IF
    cx% = cx% + monoBtnW% + 4

    ' --- Line Height ---
    TEXT_BAR.lineHeightLabelX% = cx%
    COLOR THEME.TEXT_BAR_FG~&, _RGBA32(0, 0, 0, 0)
    IF TEXT_BAR.iconLineHeight& < -1 THEN
        _PUTIMAGE (cx%, iconY%)-(cx% + 9, iconY% + 9), TEXT_BAR.iconLineHeight&
        cx% = cx% + 12
    ELSE
        _UPRINTSTRING (cx%, by% + 3), "LH:"
        cx% = cx% + _PRINTWIDTH("LH:") + 3
    END IF

    DIM lhStr AS STRING
    lhStr$ = LTRIM$(STR$(TEXT_BAR_get_line_height%))
    TEXT_BAR.lineHeightBtnX% = cx%
    TEXT_BAR.lineHeightBtnW% = _PRINTWIDTH(lhStr$) + 8
    LINE (cx%, by% + 1)-(cx% + TEXT_BAR.lineHeightBtnW% - 1, by% + bh% - 3), THEME.TEXT_BAR_BTN_HOVER~&, B
    _UPRINTSTRING (cx% + 4, by% + 3), lhStr$
    cx% = cx% + TEXT_BAR.lineHeightBtnW% + 2

    ' --- Auto Line Height checkbox [x] AUTO ---
    TEXT_BAR.autoLHBtnX% = cx%
    DIM autoLbl AS STRING
    autoLbl$ = "AUTO"
    TEXT_BAR.autoLHBtnW% = _PRINTWIDTH(autoLbl$) + 4
    IF TEXT_BAR.autoLineHeight% THEN
        LINE (cx%, by% + 1)-(cx% + TEXT_BAR.autoLHBtnW% - 1, by% + bh% - 3), THEME.TEXT_BAR_BTN_ACTIVE~&, BF
    ELSEIF TEXT_BAR.hoverBtn% = TEXT_BTN_AUTO_LH THEN
        LINE (cx%, by% + 1)-(cx% + TEXT_BAR.autoLHBtnW% - 1, by% + bh% - 3), THEME.TEXT_BAR_BTN_HOVER~&, BF
    ELSE
        LINE (cx%, by% + 1)-(cx% + TEXT_BAR.autoLHBtnW% - 1, by% + bh% - 3), THEME.TEXT_BAR_BTN_BG~&, BF
    END IF
    LINE (cx%, by% + 1)-(cx% + TEXT_BAR.autoLHBtnW% - 1, by% + bh% - 3), THEME.TEXT_BAR_BTN_BORDER~&, B
    IF TEXT_BAR.autoLineHeight% THEN
        COLOR THEME.TEXT_BAR_FG~&, _RGBA32(0, 0, 0, 0)
    ELSE
        COLOR THEME.TEXT_BAR_BTN_FG~&, _RGBA32(0, 0, 0, 0)
    END IF
    _UPRINTSTRING (cx% + 2, by% + 3), autoLbl$
    cx% = cx% + TEXT_BAR.autoLHBtnW% + 4

    ' --- CHAR (Character Mode) toggle ---
    TEXT_BAR.charBtnX% = cx%
    DIM charLbl AS STRING
    charLbl$ = "CHAR"
    TEXT_BAR.charBtnW% = _PRINTWIDTH(charLbl$) + 4
    IF CHARMAP.useChars% THEN
        LINE (cx%, by% + 1)-(cx% + TEXT_BAR.charBtnW% - 1, by% + bh% - 3), THEME.TEXT_BAR_BTN_ACTIVE~&, BF
    ELSEIF TEXT_BAR.hoverBtn% = TEXT_BTN_CHAR THEN
        LINE (cx%, by% + 1)-(cx% + TEXT_BAR.charBtnW% - 1, by% + bh% - 3), THEME.TEXT_BAR_BTN_HOVER~&, BF
    ELSE
        LINE (cx%, by% + 1)-(cx% + TEXT_BAR.charBtnW% - 1, by% + bh% - 3), THEME.TEXT_BAR_BTN_BG~&, BF
    END IF
    LINE (cx%, by% + 1)-(cx% + TEXT_BAR.charBtnW% - 1, by% + bh% - 3), THEME.TEXT_BAR_BTN_BORDER~&, B
    IF CHARMAP.useChars% THEN
        COLOR THEME.TEXT_BAR_FG~&, _RGBA32(0, 0, 0, 0)
    ELSE
        COLOR THEME.TEXT_BAR_BTN_FG~&, _RGBA32(0, 0, 0, 0)
    END IF
    _UPRINTSTRING (cx% + 2, by% + 3), charLbl$
    cx% = cx% + TEXT_BAR.charBtnW% + 4

    ' =========================================================================
    ' ROW 2: Style, Alignment, Shadow, Outline, AA
    ' =========================================================================
    DIM r2y AS INTEGER
    r2y% = by% + rowH%  ' Row 2 Y offset
    cx% = bx% + THEME.TEXT_BAR_PADDING_H%

    ' --- STYLE preset dropdown ---
    COLOR THEME.TEXT_BAR_FG~&, _RGBA32(0, 0, 0, 0)
    _UPRINTSTRING (cx%, r2y% + THEME.TEXT_BAR_LABEL_OFFSET_Y%), "STYLE:"
    cx% = cx% + _PRINTWIDTH("STYLE:") + 3

    DIM styleName AS STRING
    IF TEXT_STYLE_SELECTED% >= 1 AND TEXT_STYLE_SELECTED% <= TEXT_STYLE_COUNT% THEN
        styleName$ = RTRIM$(TEXT_STYLES(TEXT_STYLE_SELECTED%).name)
        IF LEN(styleName$) = 0 THEN styleName$ = "Default"
    ELSE
        styleName$ = "Default"
    END IF
    IF LEN(styleName$) > 12 THEN styleName$ = LEFT$(styleName$, 11) + "~"

    DIM styleBtnW AS INTEGER
    styleBtnW% = _PRINTWIDTH(styleName$) + 12
    TEXT_BAR.styleDDBtnX% = cx%
    TEXT_BAR.styleDDBtnW% = styleBtnW% + 6
    IF TEXT_BAR.hoverBtn% = TEXT_BTN_STYLE_DD OR TEXT_BAR.styleDropdownOpen% THEN
        LINE (cx%, r2y% + 1)-(cx% + styleBtnW% - 1, r2y% + rowH% - 3), THEME.TEXT_BAR_BTN_HOVER~&, BF
    END IF
    _UPRINTSTRING (cx% + 4, r2y% + THEME.TEXT_BAR_LABEL_OFFSET_Y%), styleName$
    cx% = cx% + styleBtnW% + 2
    _UPRINTSTRING (cx% - 8, r2y% + THEME.TEXT_BAR_LABEL_OFFSET_Y%), CHR$(25)
    cx% = cx% + 2

    ' Style [U]pdate button
    TEXT_BAR.styleUpdateBtnX% = cx%
    IF TEXT_BAR.hoverBtn% = TEXT_BTN_STYLE_UPDATE THEN
        LINE (cx%, r2y% + 1)-(cx% + btnW% - 1, r2y% + rowH% - 3), THEME.TEXT_BAR_BTN_HOVER~&, BF
    ELSE
        LINE (cx%, r2y% + 1)-(cx% + btnW% - 1, r2y% + rowH% - 3), THEME.TEXT_BAR_BTN_BG~&, BF
    END IF
    LINE (cx%, r2y% + 1)-(cx% + btnW% - 1, r2y% + rowH% - 3), THEME.TEXT_BAR_BTN_BORDER~&, B
    IF TEXT_BAR.iconStyleU& < -1 THEN
        _PUTIMAGE (cx% + THEME.TEXT_BAR_ICON_OFFSET_X%, r2y% + THEME.TEXT_BAR_ICON_OFFSET_Y%)-(cx% + THEME.TEXT_BAR_ICON_OFFSET_X% + THEME.TEXT_BAR_ICON_WIDTH% - 1, r2y% + THEME.TEXT_BAR_ICON_OFFSET_Y% + THEME.TEXT_BAR_ICON_HEIGHT% - 1), TEXT_BAR.iconStyleU&
    ELSE
        COLOR THEME.TEXT_BAR_BTN_FG~&, _RGBA32(0, 0, 0, 0)
        _UPRINTSTRING (cx% + 3, r2y% + THEME.TEXT_BAR_LABEL_OFFSET_Y%), "U"
    END IF
    cx% = cx% + btnW% + THEME.TEXT_BAR_BTN_GAP%

    ' Style [S]ave/export button
    TEXT_BAR.styleSaveBtnX% = cx%
    IF TEXT_BAR.hoverBtn% = TEXT_BTN_STYLE_SAVE THEN
        LINE (cx%, r2y% + 1)-(cx% + btnW% - 1, r2y% + rowH% - 3), THEME.TEXT_BAR_BTN_HOVER~&, BF
    ELSE
        LINE (cx%, r2y% + 1)-(cx% + btnW% - 1, r2y% + rowH% - 3), THEME.TEXT_BAR_BTN_BG~&, BF
    END IF
    LINE (cx%, r2y% + 1)-(cx% + btnW% - 1, r2y% + rowH% - 3), THEME.TEXT_BAR_BTN_BORDER~&, B
    IF TEXT_BAR.iconStyleS& < -1 THEN
        _PUTIMAGE (cx% + THEME.TEXT_BAR_ICON_OFFSET_X%, r2y% + THEME.TEXT_BAR_ICON_OFFSET_Y%)-(cx% + THEME.TEXT_BAR_ICON_OFFSET_X% + THEME.TEXT_BAR_ICON_WIDTH% - 1, r2y% + THEME.TEXT_BAR_ICON_OFFSET_Y% + THEME.TEXT_BAR_ICON_HEIGHT% - 1), TEXT_BAR.iconStyleS&
    ELSE
        COLOR THEME.TEXT_BAR_BTN_FG~&, _RGBA32(0, 0, 0, 0)
        _UPRINTSTRING (cx% + 3, r2y% + THEME.TEXT_BAR_LABEL_OFFSET_Y%), "S"
    END IF
    cx% = cx% + btnW% + THEME.TEXT_BAR_BTN_GAP%

    ' Style [X] delete button
    TEXT_BAR.styleDeleteBtnX% = cx%
    IF TEXT_BAR.hoverBtn% = TEXT_BTN_STYLE_DELETE THEN
        LINE (cx%, r2y% + 1)-(cx% + btnW% - 1, r2y% + rowH% - 3), THEME.TEXT_BAR_BTN_HOVER~&, BF
    ELSE
        LINE (cx%, r2y% + 1)-(cx% + btnW% - 1, r2y% + rowH% - 3), THEME.TEXT_BAR_BTN_BG~&, BF
    END IF
    LINE (cx%, r2y% + 1)-(cx% + btnW% - 1, r2y% + rowH% - 3), THEME.TEXT_BAR_BTN_BORDER~&, B
    IF TEXT_BAR.iconStyleX& < -1 THEN
        _PUTIMAGE (cx% + THEME.TEXT_BAR_ICON_OFFSET_X%, r2y% + THEME.TEXT_BAR_ICON_OFFSET_Y%)-(cx% + THEME.TEXT_BAR_ICON_OFFSET_X% + THEME.TEXT_BAR_ICON_WIDTH% - 1, r2y% + THEME.TEXT_BAR_ICON_OFFSET_Y% + THEME.TEXT_BAR_ICON_HEIGHT% - 1), TEXT_BAR.iconStyleX&
    ELSE
        COLOR THEME.TEXT_BAR_BTN_FG~&, _RGBA32(0, 0, 0, 0)
        _UPRINTSTRING (cx% + 3, r2y% + THEME.TEXT_BAR_LABEL_OFFSET_Y%), "X"
    END IF
    cx% = cx% + btnW% + THEME.TEXT_BAR_GROUP_GAP%

    TEXT_BAR.styleBtnRowW% = btnW%

    ' --- ALIGN buttons [L] [C] [R] ---
    DIM r2iconY AS INTEGER
    r2iconY% = r2y% + THEME.TEXT_BAR_ICON_OFFSET_Y%

    TEXT_BAR.alignLBtnX% = cx%
    IF TEXT_BAR.alignMode% = TEXT_ALIGN_LEFT THEN
        LINE (cx%, r2y% + 1)-(cx% + btnW% - 1, r2y% + rowH% - 3), THEME.TEXT_BAR_BTN_ACTIVE~&, BF
    ELSEIF TEXT_BAR.hoverBtn% = TEXT_BTN_ALIGN_L THEN
        LINE (cx%, r2y% + 1)-(cx% + btnW% - 1, r2y% + rowH% - 3), THEME.TEXT_BAR_BTN_HOVER~&, BF
    ELSE
        LINE (cx%, r2y% + 1)-(cx% + btnW% - 1, r2y% + rowH% - 3), THEME.TEXT_BAR_BTN_BG~&, BF
    END IF
    LINE (cx%, r2y% + 1)-(cx% + btnW% - 1, r2y% + rowH% - 3), THEME.TEXT_BAR_BTN_BORDER~&, B
    IF TEXT_BAR.iconAlignL& < -1 THEN
        IF TEXT_BAR.alignMode% = TEXT_ALIGN_LEFT THEN
            _PUTIMAGE (cx% + THEME.TEXT_BAR_ICON_OFFSET_X%, r2iconY%)-(cx% + THEME.TEXT_BAR_ICON_OFFSET_X% + THEME.TEXT_BAR_ICON_WIDTH% - 1, r2iconY% + THEME.TEXT_BAR_ICON_HEIGHT% - 1), TEXT_BAR.iconAlignL&
        ELSE
            _PUTIMAGE (cx% + THEME.TEXT_BAR_ICON_OFFSET_X%, r2iconY%)-(cx% + THEME.TEXT_BAR_ICON_OFFSET_X% + THEME.TEXT_BAR_ICON_WIDTH% - 1, r2iconY% + THEME.TEXT_BAR_ICON_HEIGHT% - 1), TEXT_BAR.iconAlignLOff&
        END IF
    ELSE
        IF TEXT_BAR.alignMode% = TEXT_ALIGN_LEFT THEN COLOR THEME.TEXT_BAR_FG~&, _RGBA32(0, 0, 0, 0) ELSE COLOR THEME.TEXT_BAR_BTN_FG~&, _RGBA32(0, 0, 0, 0)
        _UPRINTSTRING (cx% + 3, r2y% + THEME.TEXT_BAR_LABEL_OFFSET_Y%), "L"
    END IF
    cx% = cx% + btnW% + THEME.TEXT_BAR_BTN_GAP%

    TEXT_BAR.alignCBtnX% = cx%
    IF TEXT_BAR.alignMode% = TEXT_ALIGN_CENTER THEN
        LINE (cx%, r2y% + 1)-(cx% + btnW% - 1, r2y% + rowH% - 3), THEME.TEXT_BAR_BTN_ACTIVE~&, BF
    ELSEIF TEXT_BAR.hoverBtn% = TEXT_BTN_ALIGN_C THEN
        LINE (cx%, r2y% + 1)-(cx% + btnW% - 1, r2y% + rowH% - 3), THEME.TEXT_BAR_BTN_HOVER~&, BF
    ELSE
        LINE (cx%, r2y% + 1)-(cx% + btnW% - 1, r2y% + rowH% - 3), THEME.TEXT_BAR_BTN_BG~&, BF
    END IF
    LINE (cx%, r2y% + 1)-(cx% + btnW% - 1, r2y% + rowH% - 3), THEME.TEXT_BAR_BTN_BORDER~&, B
    IF TEXT_BAR.iconAlignC& < -1 THEN
        IF TEXT_BAR.alignMode% = TEXT_ALIGN_CENTER THEN
            _PUTIMAGE (cx% + THEME.TEXT_BAR_ICON_OFFSET_X%, r2iconY%)-(cx% + THEME.TEXT_BAR_ICON_OFFSET_X% + THEME.TEXT_BAR_ICON_WIDTH% - 1, r2iconY% + THEME.TEXT_BAR_ICON_HEIGHT% - 1), TEXT_BAR.iconAlignC&
        ELSE
            _PUTIMAGE (cx% + THEME.TEXT_BAR_ICON_OFFSET_X%, r2iconY%)-(cx% + THEME.TEXT_BAR_ICON_OFFSET_X% + THEME.TEXT_BAR_ICON_WIDTH% - 1, r2iconY% + THEME.TEXT_BAR_ICON_HEIGHT% - 1), TEXT_BAR.iconAlignCOff&
        END IF
    ELSE
        IF TEXT_BAR.alignMode% = TEXT_ALIGN_CENTER THEN COLOR THEME.TEXT_BAR_FG~&, _RGBA32(0, 0, 0, 0) ELSE COLOR THEME.TEXT_BAR_BTN_FG~&, _RGBA32(0, 0, 0, 0)
        _UPRINTSTRING (cx% + 3, r2y% + THEME.TEXT_BAR_LABEL_OFFSET_Y%), "C"
    END IF
    cx% = cx% + btnW% + THEME.TEXT_BAR_BTN_GAP%

    TEXT_BAR.alignRBtnX% = cx%
    IF TEXT_BAR.alignMode% = TEXT_ALIGN_RIGHT THEN
        LINE (cx%, r2y% + 1)-(cx% + btnW% - 1, r2y% + rowH% - 3), THEME.TEXT_BAR_BTN_ACTIVE~&, BF
    ELSEIF TEXT_BAR.hoverBtn% = TEXT_BTN_ALIGN_R THEN
        LINE (cx%, r2y% + 1)-(cx% + btnW% - 1, r2y% + rowH% - 3), THEME.TEXT_BAR_BTN_HOVER~&, BF
    ELSE
        LINE (cx%, r2y% + 1)-(cx% + btnW% - 1, r2y% + rowH% - 3), THEME.TEXT_BAR_BTN_BG~&, BF
    END IF
    LINE (cx%, r2y% + 1)-(cx% + btnW% - 1, r2y% + rowH% - 3), THEME.TEXT_BAR_BTN_BORDER~&, B
    IF TEXT_BAR.iconAlignR& < -1 THEN
        IF TEXT_BAR.alignMode% = TEXT_ALIGN_RIGHT THEN
            _PUTIMAGE (cx% + THEME.TEXT_BAR_ICON_OFFSET_X%, r2iconY%)-(cx% + THEME.TEXT_BAR_ICON_OFFSET_X% + THEME.TEXT_BAR_ICON_WIDTH% - 1, r2iconY% + THEME.TEXT_BAR_ICON_HEIGHT% - 1), TEXT_BAR.iconAlignR&
        ELSE
            _PUTIMAGE (cx% + THEME.TEXT_BAR_ICON_OFFSET_X%, r2iconY%)-(cx% + THEME.TEXT_BAR_ICON_OFFSET_X% + THEME.TEXT_BAR_ICON_WIDTH% - 1, r2iconY% + THEME.TEXT_BAR_ICON_HEIGHT% - 1), TEXT_BAR.iconAlignROff&
        END IF
    ELSE
        IF TEXT_BAR.alignMode% = TEXT_ALIGN_RIGHT THEN COLOR THEME.TEXT_BAR_FG~&, _RGBA32(0, 0, 0, 0) ELSE COLOR THEME.TEXT_BAR_BTN_FG~&, _RGBA32(0, 0, 0, 0)
        _UPRINTSTRING (cx% + 3, r2y% + THEME.TEXT_BAR_LABEL_OFFSET_Y%), "R"
    END IF
    cx% = cx% + btnW% + THEME.TEXT_BAR_GROUP_GAP%

    ' --- SHADOW toggle + controls ---
    TEXT_BAR.shadowBtnX% = cx%
    IF TEXT_BAR.shadowActive% THEN
        LINE (cx%, r2y% + 1)-(cx% + btnW% - 1, r2y% + rowH% - 3), THEME.TEXT_BAR_BTN_ACTIVE~&, BF
    ELSEIF TEXT_BAR.hoverBtn% = TEXT_BTN_SHADOW THEN
        LINE (cx%, r2y% + 1)-(cx% + btnW% - 1, r2y% + rowH% - 3), THEME.TEXT_BAR_BTN_HOVER~&, BF
    ELSE
        LINE (cx%, r2y% + 1)-(cx% + btnW% - 1, r2y% + rowH% - 3), THEME.TEXT_BAR_BTN_BG~&, BF
    END IF
    LINE (cx%, r2y% + 1)-(cx% + btnW% - 1, r2y% + rowH% - 3), THEME.TEXT_BAR_BTN_BORDER~&, B
    IF TEXT_BAR.iconShadow& < -1 THEN
        IF TEXT_BAR.shadowActive% THEN
            _PUTIMAGE (cx% + THEME.TEXT_BAR_ICON_OFFSET_X%, r2iconY%)-(cx% + THEME.TEXT_BAR_ICON_OFFSET_X% + THEME.TEXT_BAR_ICON_WIDTH% - 1, r2iconY% + THEME.TEXT_BAR_ICON_HEIGHT% - 1), TEXT_BAR.iconShadow&
        ELSE
            _PUTIMAGE (cx% + THEME.TEXT_BAR_ICON_OFFSET_X%, r2iconY%)-(cx% + THEME.TEXT_BAR_ICON_OFFSET_X% + THEME.TEXT_BAR_ICON_WIDTH% - 1, r2iconY% + THEME.TEXT_BAR_ICON_HEIGHT% - 1), TEXT_BAR.iconShadowOff&
        END IF
    ELSE
        IF TEXT_BAR.shadowActive% THEN COLOR THEME.TEXT_BAR_FG~&, _RGBA32(0, 0, 0, 0) ELSE COLOR THEME.TEXT_BAR_BTN_FG~&, _RGBA32(0, 0, 0, 0)
        _UPRINTSTRING (cx% + 1, r2y% + THEME.TEXT_BAR_LABEL_OFFSET_Y%), "Sh"
    END IF
    cx% = cx% + btnW% + THEME.TEXT_BAR_BTN_GAP%

    IF TEXT_BAR.shadowActive% THEN
        ' Shadow color chip
        TEXT_BAR.shadowColorBtnX% = cx%
        LINE (cx%, r2y% + 2)-(cx% + THEME.TEXT_BAR_SWATCH_WIDTH% - 1, r2y% + rowH% - 4), TEXT_BAR.shadowColor~&, BF
        LINE (cx%, r2y% + 2)-(cx% + THEME.TEXT_BAR_SWATCH_WIDTH% - 1, r2y% + rowH% - 4), THEME.TEXT_BAR_FG~&, B
        cx% = cx% + THEME.TEXT_BAR_SWATCH_WIDTH% + THEME.TEXT_BAR_BTN_GAP%

        ' Shadow X offset
        COLOR THEME.TEXT_BAR_FG~&, _RGBA32(0, 0, 0, 0)
        _UPRINTSTRING (cx%, r2y% + THEME.TEXT_BAR_LABEL_OFFSET_Y%), "X:"
        cx% = cx% + _PRINTWIDTH("X:") + 1
        DIM shdXStr AS STRING
        shdXStr$ = _TRIM$(STR$(TEXT_BAR.shadowOffsetX%))
        TEXT_BAR.shadowXBtnX% = cx%
        TEXT_BAR.shadowXBtnW% = _PRINTWIDTH(shdXStr$) + 8
        LINE (cx%, r2y% + 1)-(cx% + TEXT_BAR.shadowXBtnW% - 1, r2y% + rowH% - 3), THEME.TEXT_BAR_BTN_HOVER~&, B
        _UPRINTSTRING (cx% + 4, r2y% + THEME.TEXT_BAR_LABEL_OFFSET_Y%), shdXStr$
        cx% = cx% + TEXT_BAR.shadowXBtnW% + THEME.TEXT_BAR_BTN_GAP%

        ' Shadow Y offset
        _UPRINTSTRING (cx%, r2y% + THEME.TEXT_BAR_LABEL_OFFSET_Y%), "Y:"
        cx% = cx% + _PRINTWIDTH("Y:") + 1
        DIM shdYStr AS STRING
        shdYStr$ = _TRIM$(STR$(TEXT_BAR.shadowOffsetY%))
        TEXT_BAR.shadowYBtnX% = cx%
        TEXT_BAR.shadowYBtnW% = _PRINTWIDTH(shdYStr$) + 8
        LINE (cx%, r2y% + 1)-(cx% + TEXT_BAR.shadowYBtnW% - 1, r2y% + rowH% - 3), THEME.TEXT_BAR_BTN_HOVER~&, B
        _UPRINTSTRING (cx% + 4, r2y% + THEME.TEXT_BAR_LABEL_OFFSET_Y%), shdYStr$
        cx% = cx% + TEXT_BAR.shadowYBtnW% + THEME.TEXT_BAR_BTN_GAP%
    END IF
    cx% = cx% + THEME.TEXT_BAR_GROUP_GAP% - THEME.TEXT_BAR_BTN_GAP%

    ' --- OUTLINE toggle + controls ---
    TEXT_BAR.outlineBtnX% = cx%
    IF TEXT_BAR.outlineActive% THEN
        LINE (cx%, r2y% + 1)-(cx% + btnW% - 1, r2y% + rowH% - 3), THEME.TEXT_BAR_BTN_ACTIVE~&, BF
    ELSEIF TEXT_BAR.hoverBtn% = TEXT_BTN_OUTLINE THEN
        LINE (cx%, r2y% + 1)-(cx% + btnW% - 1, r2y% + rowH% - 3), THEME.TEXT_BAR_BTN_HOVER~&, BF
    ELSE
        LINE (cx%, r2y% + 1)-(cx% + btnW% - 1, r2y% + rowH% - 3), THEME.TEXT_BAR_BTN_BG~&, BF
    END IF
    LINE (cx%, r2y% + 1)-(cx% + btnW% - 1, r2y% + rowH% - 3), THEME.TEXT_BAR_BTN_BORDER~&, B
    IF TEXT_BAR.iconOutline& < -1 THEN
        IF TEXT_BAR.outlineActive% THEN
            _PUTIMAGE (cx% + THEME.TEXT_BAR_ICON_OFFSET_X%, r2iconY%)-(cx% + THEME.TEXT_BAR_ICON_OFFSET_X% + THEME.TEXT_BAR_ICON_WIDTH% - 1, r2iconY% + THEME.TEXT_BAR_ICON_HEIGHT% - 1), TEXT_BAR.iconOutline&
        ELSE
            _PUTIMAGE (cx% + THEME.TEXT_BAR_ICON_OFFSET_X%, r2iconY%)-(cx% + THEME.TEXT_BAR_ICON_OFFSET_X% + THEME.TEXT_BAR_ICON_WIDTH% - 1, r2iconY% + THEME.TEXT_BAR_ICON_HEIGHT% - 1), TEXT_BAR.iconOutlineOff&
        END IF
    ELSE
        IF TEXT_BAR.outlineActive% THEN COLOR THEME.TEXT_BAR_FG~&, _RGBA32(0, 0, 0, 0) ELSE COLOR THEME.TEXT_BAR_BTN_FG~&, _RGBA32(0, 0, 0, 0)
        _UPRINTSTRING (cx% + 2, r2y% + THEME.TEXT_BAR_LABEL_OFFSET_Y%), "OL"
    END IF
    cx% = cx% + btnW% + THEME.TEXT_BAR_BTN_GAP%

    IF TEXT_BAR.outlineActive% THEN
        ' Outline color chip
        TEXT_BAR.outlineColorBtnX% = cx%
        LINE (cx%, r2y% + 2)-(cx% + THEME.TEXT_BAR_SWATCH_WIDTH% - 1, r2y% + rowH% - 4), TEXT_BAR.outlineColor~&, BF
        LINE (cx%, r2y% + 2)-(cx% + THEME.TEXT_BAR_SWATCH_WIDTH% - 1, r2y% + rowH% - 4), THEME.TEXT_BAR_FG~&, B
        cx% = cx% + THEME.TEXT_BAR_SWATCH_WIDTH% + THEME.TEXT_BAR_BTN_GAP%

        ' Outline size
        COLOR THEME.TEXT_BAR_FG~&, _RGBA32(0, 0, 0, 0)
        _UPRINTSTRING (cx%, r2y% + THEME.TEXT_BAR_LABEL_OFFSET_Y%), "Sz:"
        cx% = cx% + _PRINTWIDTH("Sz:") + 1
        DIM outSzStr AS STRING
        outSzStr$ = _TRIM$(STR$(TEXT_BAR.outlineSize%))
        TEXT_BAR.outlineSizeBtnX% = cx%
        TEXT_BAR.outlineSizeBtnW% = _PRINTWIDTH(outSzStr$) + 8
        LINE (cx%, r2y% + 1)-(cx% + TEXT_BAR.outlineSizeBtnW% - 1, r2y% + rowH% - 3), THEME.TEXT_BAR_BTN_HOVER~&, B
        _UPRINTSTRING (cx% + 4, r2y% + THEME.TEXT_BAR_LABEL_OFFSET_Y%), outSzStr$
        cx% = cx% + TEXT_BAR.outlineSizeBtnW% + THEME.TEXT_BAR_BTN_GAP%
    END IF
    cx% = cx% + THEME.TEXT_BAR_GROUP_GAP% - THEME.TEXT_BAR_BTN_GAP%

    ' --- AA (Antialias) toggle ---
    TEXT_BAR.aaBtnX% = cx%
    DIM aaLbl AS STRING
    aaLbl$ = "AA"
    TEXT_BAR.aaBtnW% = _PRINTWIDTH(aaLbl$) + 4
    IF TEXT_BAR.iconAA& < -1 THEN TEXT_BAR.aaBtnW% = btnW%
    IF TEXT_BAR.aaActive% THEN
        LINE (cx%, r2y% + 1)-(cx% + TEXT_BAR.aaBtnW% - 1, r2y% + rowH% - 3), THEME.TEXT_BAR_BTN_ACTIVE~&, BF
    ELSEIF TEXT_BAR.hoverBtn% = TEXT_BTN_AA THEN
        LINE (cx%, r2y% + 1)-(cx% + TEXT_BAR.aaBtnW% - 1, r2y% + rowH% - 3), THEME.TEXT_BAR_BTN_HOVER~&, BF
    ELSE
        LINE (cx%, r2y% + 1)-(cx% + TEXT_BAR.aaBtnW% - 1, r2y% + rowH% - 3), THEME.TEXT_BAR_BTN_BG~&, BF
    END IF
    LINE (cx%, r2y% + 1)-(cx% + TEXT_BAR.aaBtnW% - 1, r2y% + rowH% - 3), THEME.TEXT_BAR_BTN_BORDER~&, B
    IF TEXT_BAR.iconAA& < -1 THEN
        IF TEXT_BAR.aaActive% THEN
            _PUTIMAGE (cx% + THEME.TEXT_BAR_ICON_OFFSET_X%, r2iconY%)-(cx% + THEME.TEXT_BAR_ICON_OFFSET_X% + THEME.TEXT_BAR_ICON_WIDTH% - 1, r2iconY% + THEME.TEXT_BAR_ICON_HEIGHT% - 1), TEXT_BAR.iconAA&
        ELSE
            _PUTIMAGE (cx% + THEME.TEXT_BAR_ICON_OFFSET_X%, r2iconY%)-(cx% + THEME.TEXT_BAR_ICON_OFFSET_X% + THEME.TEXT_BAR_ICON_WIDTH% - 1, r2iconY% + THEME.TEXT_BAR_ICON_HEIGHT% - 1), TEXT_BAR.iconAAOff&
        END IF
    ELSE
        IF TEXT_BAR.aaActive% THEN COLOR THEME.TEXT_BAR_FG~&, _RGBA32(0, 0, 0, 0) ELSE COLOR THEME.TEXT_BAR_BTN_FG~&, _RGBA32(0, 0, 0, 0)
        _UPRINTSTRING (cx% + 2, r2y% + THEME.TEXT_BAR_LABEL_OFFSET_Y%), aaLbl$
    END IF

    _FONT oldFont&

    ' Render open dropdowns on top
    IF TEXT_BAR.fontDropdownOpen% THEN TEXT_BAR_render_font_dropdown
    IF TEXT_BAR.sizeDropdownOpen% THEN TEXT_BAR_render_size_dropdown
    IF TEXT_BAR.styleDropdownOpen% THEN TEXT_BAR_render_style_dropdown

    TEXT_BAR.needsRedraw% = FALSE

    _DEST oldDest&
END SUB


''
' Render the font dropdown (text-only list, scrollable).
'
SUB TEXT_BAR_render_font_dropdown ()
    IF FONT_LIST_COUNT% = 0 THEN EXIT SUB

    DIM ddOldFont AS LONG
    ddOldFont& = _FONT
    IF MENU_BAR.fontHandle& > 0 THEN _FONT MENU_BAR.fontHandle&

    DIM ddX AS INTEGER, ddY AS INTEGER, ddW AS INTEGER, ddH AS INTEGER
    DIM maxVisible AS INTEGER
    DIM itemH AS INTEGER
    DIM i AS INTEGER
    DIM dispName AS STRING

    itemH% = 12
    maxVisible% = TEXT_BAR_font_dropdown_max_visible%
    ddW% = 160
    ddH% = maxVisible% * itemH% + 2
    ddX% = TEXT_BAR.fontBtnX%
    ddY% = TEXT_BAR.barY% + THEME.TEXT_BAR_ROW_HEIGHT%

    ' Background
    LINE (ddX%, ddY%)-(ddX% + ddW% - 1, ddY% + ddH% - 1), THEME.TEXT_BAR_DROPDOWN_BG~&, BF
    LINE (ddX%, ddY%)-(ddX% + ddW% - 1, ddY% + ddH% - 1), THEME.TEXT_BAR_BORDER~&, B

    DIM drawY AS INTEGER
    drawY% = ddY% + 1

    DIM startIdx AS INTEGER
    startIdx% = TEXT_BAR.fontDropdownScroll%
    IF startIdx% < 0 THEN startIdx% = 0
    IF startIdx% > FONT_LIST_COUNT% - maxVisible% THEN startIdx% = FONT_LIST_COUNT% - maxVisible%
    IF startIdx% < 0 THEN startIdx% = 0

    FOR i% = startIdx% TO startIdx% + maxVisible% - 1
        IF i% >= FONT_LIST_COUNT% THEN EXIT FOR

        ' Highlight selected item
        IF i% = TEXT_BAR.selectedFontIdx% THEN
            LINE (ddX% + 1, drawY%)-(ddX% + ddW% - 2, drawY% + itemH% - 1), THEME.TEXT_BAR_DROPDOWN_HIGHLIGHT~&, BF
        ELSEIF i% = TEXT_BAR.fontDropdownHoverRow% THEN
            LINE (ddX% + 1, drawY%)-(ddX% + ddW% - 2, drawY% + itemH% - 1), THEME.TEXT_BAR_DROPDOWN_HOVER_BG~&, BF
        END IF

        DIM fontItemFG AS _UNSIGNED LONG
        IF i% = TEXT_BAR.fontDropdownHoverRow% AND i% <> TEXT_BAR.selectedFontIdx% THEN
            fontItemFG~& = THEME.TEXT_BAR_DROPDOWN_HOVER_FG~&
        ELSE
            fontItemFG~& = THEME.TEXT_BAR_DROPDOWN_FG~&
        END IF

        ' Add separator after last favorite font
        IF i% > 0 THEN
            IF NOT FONT_LIST(i%).isFavorite AND FONT_LIST(i% - 1).isFavorite THEN
                LINE (ddX% + 4, drawY%)-(ddX% + ddW% - 5, drawY%), THEME.TEXT_BAR_BORDER~&
            END IF
        END IF

        ' Add separator after last bundled font (when no favorites divider was drawn)
        IF i% > 0 THEN
            IF FONT_LIST(i%).isBundled = FALSE AND FONT_LIST(i% - 1).isBundled = TRUE THEN
                IF NOT FONT_LIST(i% - 1).isFavorite THEN
                    LINE (ddX% + 4, drawY%)-(ddX% + ddW% - 5, drawY%), THEME.TEXT_BAR_BORDER~&
                END IF
            END IF
        END IF

        ' Add separator when transitioning into bitmap fonts tier
        IF i% > 0 THEN
            IF FONT_LIST(i%).isBitmapFont AND NOT FONT_LIST(i% - 1).isBitmapFont THEN
                LINE (ddX% + 4, drawY%)-(ddX% + ddW% - 5, drawY%), THEME.TEXT_BAR_BORDER~&
            END IF
        END IF

        dispName$ = RTRIM$(FONT_LIST(i%).displayName)
        IF LEN(dispName$) > 24 THEN dispName$ = LEFT$(dispName$, 23) + "~"

        COLOR fontItemFG~&, _RGBA32(0, 0, 0, 0)
        _UPRINTSTRING (ddX% + 4, drawY% + 2), dispName$

        drawY% = drawY% + itemH%
    NEXT i%

    ' Scroll arrows — always show them when list overflows, indicate position
    DIM arrowFG AS _UNSIGNED LONG
    arrowFG~& = THEME.TEXT_BAR_DROPDOWN_FG~&
    IF startIdx% > 0 THEN
        ' Up arrow at top-right corner
        COLOR arrowFG~&, _RGBA32(0, 0, 0, 0)
        _UPRINTSTRING (ddX% + ddW% - 10, ddY% + 2), CHR$(30)
    END IF
    IF startIdx% + maxVisible% < FONT_LIST_COUNT% THEN
        ' Down arrow at bottom-right corner
        COLOR arrowFG~&, _RGBA32(0, 0, 0, 0)
        _UPRINTSTRING (ddX% + ddW% - 10, ddY% + ddH% - 10), CHR$(31)
    END IF

    _FONT ddOldFont&
END SUB


''
' Render the size dropdown (preset sizes list).
'
SUB TEXT_BAR_render_style_dropdown ()
    ' Always show (at minimum the Default entry)
    DIM ddX AS INTEGER, ddY AS INTEGER, ddW AS INTEGER, ddH AS INTEGER
    DIM itemH AS INTEGER
    DIM si AS INTEGER
    DIM hasDivider AS INTEGER

    DIM ddOldFont3 AS LONG
    ddOldFont3& = _FONT
    IF MENU_BAR.fontHandle& > 0 THEN _FONT MENU_BAR.fontHandle&

    itemH% = 12
    ddW% = 120
    hasDivider% = (TEXT_STYLE_COUNT% > 0)
    ' 1 (Default) + 1 (divider if user styles exist) + user styles
    ddH% = itemH% + 2
    IF hasDivider% THEN ddH% = ddH% + itemH%  ' divider row
    ddH% = ddH% + TEXT_STYLE_COUNT% * itemH%
    ddX% = TEXT_BAR.styleDDBtnX%
    ddY% = TEXT_BAR.barY% + THEME.TEXT_BAR_ROW_HEIGHT% * 2

    ' Background + border
    LINE (ddX%, ddY%)-(ddX% + ddW% - 1, ddY% + ddH% - 1), THEME.TEXT_BAR_DROPDOWN_BG~&, BF
    LINE (ddX%, ddY%)-(ddX% + ddW% - 1, ddY% + ddH% - 1), THEME.TEXT_BAR_BORDER~&, B

    DIM drawY AS INTEGER
    drawY% = ddY% + 1
    DIM styleVisualRow AS INTEGER
    styleVisualRow% = 0

    ' --- Default row (SELECTED=0) ---
    IF TEXT_STYLE_SELECTED% = 0 THEN
        LINE (ddX% + 1, drawY%)-(ddX% + ddW% - 2, drawY% + itemH% - 1), THEME.TEXT_BAR_DROPDOWN_HIGHLIGHT~&, BF
    ELSEIF TEXT_BAR.styleDropdownHoverRow% = styleVisualRow% THEN
        LINE (ddX% + 1, drawY%)-(ddX% + ddW% - 2, drawY% + itemH% - 1), THEME.TEXT_BAR_DROPDOWN_HOVER_BG~&, BF
    END IF
    IF TEXT_BAR.styleDropdownHoverRow% = styleVisualRow% AND TEXT_STYLE_SELECTED% <> 0 THEN
        COLOR THEME.TEXT_BAR_DROPDOWN_HOVER_FG~&, _RGBA32(0, 0, 0, 0)
    ELSE
        COLOR THEME.TEXT_BAR_DROPDOWN_FG~&, _RGBA32(0, 0, 0, 0)
    END IF
    _UPRINTSTRING (ddX% + 4, drawY% + 2), "Default"
    drawY% = drawY% + itemH%
    styleVisualRow% = styleVisualRow% + 1

    ' --- Divider ---
    IF hasDivider% THEN
        DIM divMidY AS INTEGER
        divMidY% = drawY% + itemH% \ 2
        LINE (ddX% + 4, divMidY%)-(ddX% + ddW% - 5, divMidY%), THEME.TEXT_BAR_BORDER~&
        drawY% = drawY% + itemH%
        styleVisualRow% = styleVisualRow% + 1
    END IF

    ' --- User styles ---
    FOR si% = 1 TO TEXT_STYLE_COUNT%
        IF NOT TEXT_STYLES(si%).used THEN
            drawY% = drawY% + itemH%
            styleVisualRow% = styleVisualRow% + 1
            _CONTINUE
        END IF
        IF si% = TEXT_STYLE_SELECTED% THEN
            LINE (ddX% + 1, drawY%)-(ddX% + ddW% - 2, drawY% + itemH% - 1), THEME.TEXT_BAR_DROPDOWN_HIGHLIGHT~&, BF
        ELSEIF TEXT_BAR.styleDropdownHoverRow% = styleVisualRow% THEN
            LINE (ddX% + 1, drawY%)-(ddX% + ddW% - 2, drawY% + itemH% - 1), THEME.TEXT_BAR_DROPDOWN_HOVER_BG~&, BF
        END IF
        IF TEXT_BAR.styleDropdownHoverRow% = styleVisualRow% AND si% <> TEXT_STYLE_SELECTED% THEN
            COLOR THEME.TEXT_BAR_DROPDOWN_HOVER_FG~&, _RGBA32(0, 0, 0, 0)
        ELSE
            COLOR THEME.TEXT_BAR_DROPDOWN_FG~&, _RGBA32(0, 0, 0, 0)
        END IF
        DIM sn AS STRING
        sn$ = RTRIM$(TEXT_STYLES(si%).name)
        IF LEN(sn$) = 0 THEN sn$ = "Style " + _TRIM$(STR$(si%))
        _UPRINTSTRING (ddX% + 4, drawY% + 2), sn$
        drawY% = drawY% + itemH%
        styleVisualRow% = styleVisualRow% + 1
    NEXT si%

    _FONT ddOldFont3&
END SUB


SUB TEXT_BAR_render_size_dropdown ()
    DIM ddX AS INTEGER, ddY AS INTEGER, ddW AS INTEGER, ddH AS INTEGER
    DIM itemH AS INTEGER
    DIM i AS INTEGER
    DIM sizeStr AS STRING

    DIM ddOldFont2 AS LONG
    ddOldFont2& = _FONT
    IF MENU_BAR.fontHandle& > 0 THEN _FONT MENU_BAR.fontHandle&

    itemH% = 12
    ddW% = 40
    ddH% = TEXT_BAR_SIZE_COUNT * itemH% + 2
    ' Position directly under the row-1 size button area
    ddX% = TEXT_BAR.sizeBtnX%
    ddY% = TEXT_BAR.barY% + THEME.TEXT_BAR_ROW_HEIGHT%

    ' Background
    LINE (ddX%, ddY%)-(ddX% + ddW% - 1, ddY% + ddH% - 1), THEME.TEXT_BAR_DROPDOWN_BG~&, BF
    LINE (ddX%, ddY%)-(ddX% + ddW% - 1, ddY% + ddH% - 1), THEME.TEXT_BAR_BORDER~&, B

    DIM drawY AS INTEGER
    drawY% = ddY% + 1

    FOR i% = 0 TO TEXT_BAR_SIZE_COUNT - 1
        IF TEXT_BAR_SIZES(i%) = TEXT_BAR.selectedSize% THEN
            LINE (ddX% + 1, drawY%)-(ddX% + ddW% - 2, drawY% + itemH% - 1), THEME.TEXT_BAR_DROPDOWN_HIGHLIGHT~&, BF
        ELSEIF i% = TEXT_BAR.sizeDropdownHoverRow% THEN
            LINE (ddX% + 1, drawY%)-(ddX% + ddW% - 2, drawY% + itemH% - 1), THEME.TEXT_BAR_DROPDOWN_HOVER_BG~&, BF
        END IF

        sizeStr$ = _TRIM$(STR$(TEXT_BAR_SIZES(i%)))
        DIM sizeItemFG AS _UNSIGNED LONG
        IF i% = TEXT_BAR.sizeDropdownHoverRow% AND TEXT_BAR_SIZES(i%) <> TEXT_BAR.selectedSize% THEN
            sizeItemFG~& = THEME.TEXT_BAR_DROPDOWN_HOVER_FG~&
        ELSE
            sizeItemFG~& = THEME.TEXT_BAR_DROPDOWN_FG~&
        END IF
        COLOR sizeItemFG~&, _RGBA32(0, 0, 0, 0)
        _UPRINTSTRING (ddX% + 4, drawY% + 2), sizeStr$

        drawY% = drawY% + itemH%
    NEXT i%

    _FONT ddOldFont2&
END SUB


''
' Handle a mouse click within the text bar bounds.
' Returns TRUE if the click was consumed (prevents pass-through to canvas).
'
' @param rawX% Screen X coordinate
' @param rawY% Screen Y coordinate
' @return INTEGER TRUE if click was consumed
'
FUNCTION TEXT_BAR_handle_click% (rawX%, rawY%)
    TEXT_BAR_handle_click% = FALSE
    IF NOT TEXT_BAR.visible% THEN EXIT FUNCTION

    ' This handler is only called for text-bar interactions; force repaint so
    ' GUI clear + render pass cannot skip drawing when dropdown state changes.
    TEXT_BAR.needsRedraw% = TRUE

    ' Close any open dropdown if clicking outside it
    IF TEXT_BAR.fontDropdownOpen% OR TEXT_BAR.sizeDropdownOpen% OR TEXT_BAR.styleDropdownOpen% THEN
        ' Check if click is inside a dropdown
        DIM inDropdown AS INTEGER
        inDropdown% = FALSE

        ' Font dropdown bounds
        IF TEXT_BAR.fontDropdownOpen% THEN
            DIM fddX AS INTEGER, fddY AS INTEGER, fddW AS INTEGER, fddH AS INTEGER
            DIM fMaxVis AS INTEGER
            fMaxVis% = TEXT_BAR_font_dropdown_max_visible%
            fddX% = TEXT_BAR.fontBtnX%
            fddY% = TEXT_BAR.barY% + THEME.TEXT_BAR_ROW_HEIGHT%
            fddW% = 160
            fddH% = fMaxVis% * 12 + 2
            IF rawX% >= fddX% AND rawX% < fddX% + fddW% THEN
                IF rawY% >= fddY% AND rawY% < fddY% + fddH% THEN
                    inDropdown% = TRUE
                    ' Select a font
                    DIM fontClicked AS INTEGER
                    fontClicked% = TEXT_BAR.fontDropdownScroll% + (rawY% - fddY% - 1) \ 12
                    IF fontClicked% >= 0 AND fontClicked% < FONT_LIST_COUNT% THEN
                        TEXT_BAR.selectedFontIdx% = fontClicked%
                        ' Auto-set size to native height for fixed-size bitmap fonts
                        IF FONT_LIST(fontClicked%).isBuiltIn THEN
                            TEXT_BAR.selectedSize% = FONT_LIST(fontClicked%).builtInHandle
                        ELSEIF FONT_LIST(fontClicked%).isBitmapFont THEN
                            TEXT_BAR.selectedSize% = FONT_LIST(fontClicked%).bitmapGlyphH
                        END IF
                        ' Auto-enable monospace + auto line height for bitmap fonts
                        IF FONT_LIST(fontClicked%).isBitmapFont THEN
                            TEXT_BAR.monoActive% = TRUE
                            TEXT_BAR.autoLineHeight% = TRUE
                        END IF
                        TEXT_BAR_ensure_char_mode_safe_font
                        ' Apply font to selection if active
                        IF TEXT_has_selection% THEN
                            IF TEXT_BAR.editingLayerIdx% >= 1 THEN
                                DIM fsTd AS INTEGER
                                fsTd% = LAYERS(TEXT_BAR.editingLayerIdx%).textDataIdx%
                                IF fsTd% >= 1 THEN
                                    DIM fsMin AS INTEGER, fsMax AS INTEGER
                                    fsMin% = TEXT.selStart%: fsMax% = TEXT.selEnd%
                                    IF fsMin% > fsMax% THEN SWAP fsMin%, fsMax%
                                    TEXT_LAYER_set_selection_attr fsTd%, fsMin%, fsMax% - 1, "FONT_IDX", fontClicked%
                                    SCENE_DIRTY% = TRUE
                                END IF
                            END IF
                        END IF
                        TEXT_BAR.fontDropdownOpen% = FALSE
                        FRAME_IDLE% = FALSE
                        TEXT_BAR_auto_update_line_height
                        CHARMAP.cacheValid% = FALSE
                        GUI_NEEDS_REDRAW% = TRUE
                        SCENE_DIRTY% = TRUE
                        ' Refresh character grid when font changes
                        IF CHARMAP.charGridShow% THEN
                            CHARMAP_char_grid_update_size
                            CHARMAP_char_grid_draw
                            SCENE_DIRTY% = TRUE
                        END IF
                    END IF
                END IF
            END IF
            IF NOT inDropdown% THEN TEXT_BAR.fontDropdownOpen% = FALSE
        END IF

        IF TEXT_BAR.sizeDropdownOpen% THEN
            DIM sddX AS INTEGER, sddY AS INTEGER, sddW AS INTEGER, sddH AS INTEGER
            sddX% = TEXT_BAR.sizeBtnX%
            sddY% = TEXT_BAR.barY% + THEME.TEXT_BAR_ROW_HEIGHT%
            sddW% = 40
            sddH% = TEXT_BAR_SIZE_COUNT * 12 + 2
            IF rawX% >= sddX% AND rawX% < sddX% + sddW% THEN
                IF rawY% >= sddY% AND rawY% < sddY% + sddH% THEN
                    inDropdown% = TRUE
                    DIM sizeClicked AS INTEGER
                    sizeClicked% = (rawY% - sddY% - 1) \ 12
                    IF sizeClicked% >= 0 AND sizeClicked% < TEXT_BAR_SIZE_COUNT THEN
                        TEXT_BAR.selectedSize% = TEXT_BAR_SIZES(sizeClicked%)
                        ' Apply size to selection if active
                        IF TEXT_has_selection% THEN
                            IF TEXT_BAR.editingLayerIdx% >= 1 THEN
                                DIM szTd AS INTEGER
                                szTd% = LAYERS(TEXT_BAR.editingLayerIdx%).textDataIdx%
                                IF szTd% >= 1 THEN
                                    DIM szMin AS INTEGER, szMax AS INTEGER
                                    szMin% = TEXT.selStart%: szMax% = TEXT.selEnd%
                                    IF szMin% > szMax% THEN SWAP szMin%, szMax%
                                    TEXT_LAYER_set_selection_attr szTd%, szMin%, szMax% - 1, "FONT_SIZE", TEXT_BAR_SIZES(sizeClicked%)
                                    SCENE_DIRTY% = TRUE
                                END IF
                            END IF
                        END IF
                        TEXT_BAR.sizeDropdownOpen% = FALSE
                        FRAME_IDLE% = FALSE
                        TEXT_BAR_auto_update_line_height
                        ' Refresh character grid when font size changes
                        IF CHARMAP.charGridShow% THEN
                            CHARMAP_char_grid_update_size
                            CHARMAP_char_grid_draw
                            SCENE_DIRTY% = TRUE
                        END IF
                    END IF
                END IF
            END IF
            IF NOT inDropdown% THEN TEXT_BAR.sizeDropdownOpen% = FALSE
        END IF

        IF TEXT_BAR.styleDropdownOpen% THEN
            DIM sdDdX AS INTEGER, sdDdY AS INTEGER, sdDdW AS INTEGER, sdDdH AS INTEGER
            sdDdX% = TEXT_BAR.styleDDBtnX%
            sdDdY% = TEXT_BAR.barY% + THEME.TEXT_BAR_ROW_HEIGHT% * 2
            sdDdW% = 120
            DIM sdHasDividerH AS INTEGER
            IF TEXT_STYLE_COUNT% > 0 THEN sdHasDividerH% = 1 ELSE sdHasDividerH% = 0
            sdDdH% = 12 + 2 + (sdHasDividerH% * 12) + TEXT_STYLE_COUNT% * 12
            ' Clicking the button again while open closes the dropdown
            IF rawX% >= TEXT_BAR.styleDDBtnX% AND rawX% < TEXT_BAR.styleDDBtnX% + TEXT_BAR.styleDDBtnW% THEN
                IF rawY% >= TEXT_BAR.barY% + THEME.TEXT_BAR_ROW_HEIGHT% AND rawY% < TEXT_BAR.barY% + THEME.TEXT_BAR_ROW_HEIGHT% * 2 THEN
                    TEXT_BAR.styleDropdownOpen% = FALSE
                    inDropdown% = TRUE
                END IF
            END IF
            ' Click inside the dropdown list
            IF rawX% >= sdDdX% AND rawX% < sdDdX% + sdDdW% THEN
                IF rawY% >= sdDdY% AND rawY% < sdDdY% + sdDdH% THEN
                    inDropdown% = TRUE
                    DIM sdClicked AS INTEGER
                    ' Row 0 = Default, row 1 = divider (if user styles exist), rows 2..N = user styles
                    sdClicked% = (rawY% - sdDdY% - 1) \ 12  ' 0-based
                    DIM sdHasDivider AS INTEGER
                    IF TEXT_STYLE_COUNT% > 0 THEN sdHasDivider% = 1 ELSE sdHasDivider% = 0
                    IF sdClicked% = 0 THEN
                        ' Default selected
                        TEXT_STYLE_apply_default
                        TEXT_BAR.styleDropdownOpen% = FALSE
                    ELSEIF sdHasDivider% AND sdClicked% = 1 THEN
                        ' Divider row — ignore click
                    ELSE
                        ' User style: subtract 1 for Default row + 1 for divider if present
                        DIM sdOffset AS INTEGER
                        sdOffset% = 1 + sdHasDivider%  ' rows consumed before user styles
                        DIM sdUserIdx AS INTEGER
                        sdUserIdx% = sdClicked% - sdOffset% + 1  ' 1-based
                        IF sdUserIdx% >= 1 AND sdUserIdx% <= TEXT_STYLE_COUNT% THEN
                            IF TEXT_STYLES(sdUserIdx%).used THEN
                                TEXT_STYLE_apply sdUserIdx%
                            END IF
                        END IF
                        TEXT_BAR.styleDropdownOpen% = FALSE
                    END IF
                END IF
            END IF
            IF NOT inDropdown% THEN TEXT_BAR.styleDropdownOpen% = FALSE
        END IF

        ' Consume only when click is inside text-bar UI/dropdown geometry.
        ' Outside clicks close dropdowns but should pass through to other panels.
        TEXT_BAR_handle_click% = inDropdown% OR TEXT_BAR_in_bounds%(rawX%, rawY%)
        EXIT FUNCTION
    END IF

    ' Check if click is in the bar itself
    IF NOT TEXT_BAR_in_bounds%(rawX%, rawY%) THEN EXIT FUNCTION

    TEXT_BAR_handle_click% = TRUE

    ' Use stored hit zone positions from last render
    DIM bw AS INTEGER
    DIM inRow1 AS INTEGER, inRow2 AS INTEGER
    bw% = TEXT_BAR.styleBtnW%
    inRow1% = (rawY% >= TEXT_BAR.barY% AND rawY% < TEXT_BAR.barY% + THEME.TEXT_BAR_ROW_HEIGHT%)
    inRow2% = (rawY% >= TEXT_BAR.barY% + THEME.TEXT_BAR_ROW_HEIGHT% AND rawY% < TEXT_BAR.barY% + THEME.TEXT_BAR_ROW_HEIGHT% * 2)

    IF inRow1% AND rawX% >= TEXT_BAR.fontBtnX% AND rawX% < TEXT_BAR.fontBtnX% + TEXT_BAR.fontBtnW% THEN
        ' Font dropdown area
        TEXT_BAR.fontDropdownOpen% = NOT TEXT_BAR.fontDropdownOpen%
        TEXT_BAR.sizeDropdownOpen% = FALSE
        TEXT_BAR.styleDropdownOpen% = FALSE
        FONT_LIST_scan  ' Ensure fonts are enumerated
        FRAME_IDLE% = FALSE
    ELSEIF inRow1% AND rawX% >= TEXT_BAR.sizeBtnX% AND rawX% < TEXT_BAR.sizeBtnX% + TEXT_BAR.sizeBtnW% THEN
        ' Size dropdown area
        TEXT_BAR.sizeDropdownOpen% = NOT TEXT_BAR.sizeDropdownOpen%
        TEXT_BAR.fontDropdownOpen% = FALSE
        TEXT_BAR.styleDropdownOpen% = FALSE
        FRAME_IDLE% = FALSE
    ELSEIF inRow1% AND rawX% >= TEXT_BAR.boldBtnX% AND rawX% < TEXT_BAR.boldBtnX% + bw% THEN
        ' Bold toggle
        TEXT_BAR.boldActive% = NOT TEXT_BAR.boldActive%
        TEXT_BAR_apply_style_to_selection "BOLD"
        FRAME_IDLE% = FALSE
    ELSEIF inRow1% AND rawX% >= TEXT_BAR.italicBtnX% AND rawX% < TEXT_BAR.italicBtnX% + bw% THEN
        ' Italic toggle
        TEXT_BAR.italicActive% = NOT TEXT_BAR.italicActive%
        TEXT_BAR_apply_style_to_selection "ITALIC"
        FRAME_IDLE% = FALSE
    ELSEIF inRow1% AND rawX% >= TEXT_BAR.underlineBtnX% AND rawX% < TEXT_BAR.underlineBtnX% + bw% THEN
        ' Underline toggle
        TEXT_BAR.underlineActive% = NOT TEXT_BAR.underlineActive%
        TEXT_BAR_apply_style_to_selection "UNDERLINE"
        FRAME_IDLE% = FALSE
    ELSEIF inRow1% AND rawX% >= TEXT_BAR.strikeBtnX% AND rawX% < TEXT_BAR.strikeBtnX% + bw% THEN
        ' Strikethrough toggle
        TEXT_BAR.strikeActive% = NOT TEXT_BAR.strikeActive%
        TEXT_BAR_apply_style_to_selection "STRIKE"
        FRAME_IDLE% = FALSE
    ELSEIF inRow1% AND rawX% >= TEXT_BAR.fgSwatchX% AND rawX% < TEXT_BAR.fgSwatchX% + 10 THEN
        ' FG color swatch — open palette picker for foreground
        TEXT_BAR_close_dropdowns
        CMD_execute_action 1505
        FRAME_IDLE% = FALSE
    ELSEIF inRow1% AND rawX% >= TEXT_BAR.bgSwatchX% AND rawX% < TEXT_BAR.bgSwatchX% + 10 THEN
        ' BG color swatch — open palette picker for background
        TEXT_BAR_close_dropdowns
        CMD_execute_action 1506
        FRAME_IDLE% = FALSE
    ELSEIF inRow1% AND rawX% >= TEXT_BAR.monoBtnX% AND rawX% < TEXT_BAR.monoBtnX% + TEXT_BAR.monoBtnW% THEN
        ' Monospace toggle
        TEXT_BAR.monoActive% = NOT TEXT_BAR.monoActive%
        ' Apply to current text layer
        IF TEXT_BAR.editingLayerIdx% >= 1 THEN
            DIM monoTd AS INTEGER
            monoTd% = LAYERS(TEXT_BAR.editingLayerIdx%).textDataIdx%
            IF monoTd% >= 1 THEN
                TEXT_LAYER_DATA(monoTd%).monospace = TEXT_BAR.monoActive%
                TEXT_LAYER_DATA(monoTd%).dirty = TRUE
                SCENE_DIRTY% = TRUE
                TEXT.CURSOR_X = TEXT_LAYER_get_char_x%(monoTd%, TEXT_LAYER_DATA(monoTd%).cursorPos)
            END IF
        END IF
        FRAME_IDLE% = FALSE
    ELSEIF inRow1% AND rawX% >= TEXT_BAR.lineHeightBtnX% AND rawX% < TEXT_BAR.lineHeightBtnX% + TEXT_BAR.lineHeightBtnW% THEN
        ' Line height — prompt for manual value (disables auto)
        TEXT_BAR_close_dropdowns
        TEXT_BAR_adjust_line_height
        FRAME_IDLE% = FALSE
    ELSEIF inRow1% AND rawX% >= TEXT_BAR.autoLHBtnX% AND rawX% < TEXT_BAR.autoLHBtnX% + TEXT_BAR.autoLHBtnW% THEN
        ' Toggle auto line height
        TEXT_BAR.autoLineHeight% = NOT TEXT_BAR.autoLineHeight%
        IF TEXT_BAR.autoLineHeight% THEN
            ' Immediately recalculate line height
            TEXT_BAR_auto_update_line_height
        END IF
        FRAME_IDLE% = FALSE
    ELSEIF inRow1% AND rawX% >= TEXT_BAR.charBtnX% AND rawX% < TEXT_BAR.charBtnX% + TEXT_BAR.charBtnW% THEN
        ' Toggle Character Mode (Use Chars)
        CHARMAP.useChars% = NOT CHARMAP.useChars%
        ' Note: useChars% is saved per-document in .draw files, not in global config
        IF CHARMAP.useChars% THEN TEXT_BAR_ensure_char_mode_safe_font
        ' Auto-show Character Map panel when enabling Character Mode
        IF CHARMAP.useChars% AND NOT SCRN.showCharMap% THEN
            CHARMAP_toggle
        END IF
        ' Auto-enable char grid + snap + recolor when entering Character Mode
        IF CHARMAP.useChars% THEN
            IF NOT CHARMAP.charGridShow% THEN
                CHARMAP.charGridShow% = TRUE
                CHARMAP_char_grid_update_size
                CHARMAP_char_grid_draw
                SCENE_DIRTY% = TRUE
            END IF
            IF NOT CHARMAP.charGridSnap% THEN
                CHARMAP.charGridSnap% = TRUE
            END IF
            TEXT_BAR.monoActive% = TRUE
            TEXT_BAR.autoLineHeight% = TRUE
            IF TEXT_BAR.editingLayerIdx% >= 1 THEN
                DIM charTd AS INTEGER
                charTd% = LAYERS(TEXT_BAR.editingLayerIdx%).textDataIdx%
                IF charTd% >= 1 THEN
                    TEXT_LAYER_DATA(charTd%).monospace = TRUE
                    TEXT_LAYER_DATA(charTd%).defaultLeading = CHARMAP.charGridH%
                    TEXT_LAYER_DATA(charTd%).dirty = TRUE
                    SCENE_DIRTY% = TRUE
                END IF
            END IF
            CUSTOM_BRUSH.RECOLOR_MODE% = TRUE
        END IF
        ' Select a default non-whitespace glyph if none is selected
        IF CHARMAP.useChars% AND CHARMAP.selectedIdx% <= 32 THEN
            CHARMAP_select_glyph 65  ' Default to 'A'
        END IF
        ' Force title bar update for CHAR MODE hint
        TITLE_PREV_DIRTY% = -99
        CONFIG_save
        FRAME_IDLE% = FALSE

    ' --- Row 2 hit tests ---
    ELSEIF inRow2% AND rawX% >= TEXT_BAR.alignLBtnX% AND rawX% < TEXT_BAR.alignLBtnX% + THEME.TEXT_BAR_BTN_WIDTH% THEN
        TEXT_BAR.alignMode% = TEXT_ALIGN_LEFT
        TEXT_BAR_apply_alignment
        TEXT_BAR.needsRedraw% = TRUE
        FRAME_IDLE% = FALSE
    ELSEIF inRow2% AND rawX% >= TEXT_BAR.alignCBtnX% AND rawX% < TEXT_BAR.alignCBtnX% + THEME.TEXT_BAR_BTN_WIDTH% THEN
        TEXT_BAR.alignMode% = TEXT_ALIGN_CENTER
        TEXT_BAR_apply_alignment
        TEXT_BAR.needsRedraw% = TRUE
        FRAME_IDLE% = FALSE
    ELSEIF inRow2% AND rawX% >= TEXT_BAR.alignRBtnX% AND rawX% < TEXT_BAR.alignRBtnX% + THEME.TEXT_BAR_BTN_WIDTH% THEN
        TEXT_BAR.alignMode% = TEXT_ALIGN_RIGHT
        TEXT_BAR_apply_alignment
        TEXT_BAR.needsRedraw% = TRUE
        FRAME_IDLE% = FALSE
    ELSEIF inRow2% AND rawX% >= TEXT_BAR.outlineBtnX% AND rawX% < TEXT_BAR.outlineBtnX% + THEME.TEXT_BAR_BTN_WIDTH% THEN
        TEXT_BAR.outlineActive% = NOT TEXT_BAR.outlineActive%
        TEXT_BAR_apply_outline_to_selection
        TEXT_BAR.needsRedraw% = TRUE
        FRAME_IDLE% = FALSE
    ELSEIF inRow2% AND TEXT_BAR.outlineActive% AND rawX% >= TEXT_BAR.outlineColorBtnX% AND rawX% < TEXT_BAR.outlineColorBtnX% + THEME.TEXT_BAR_SWATCH_WIDTH% THEN
        TEXT_BAR_close_dropdowns
        CMD_execute_action 1507
        FRAME_IDLE% = FALSE
    ELSEIF inRow2% AND TEXT_BAR.outlineActive% AND rawX% >= TEXT_BAR.outlineSizeBtnX% AND rawX% < TEXT_BAR.outlineSizeBtnX% + TEXT_BAR.outlineSizeBtnW% THEN
        ' Cycle outline size 1-10
        TEXT_BAR.outlineSize% = TEXT_BAR.outlineSize% + 1
        IF TEXT_BAR.outlineSize% > 10 THEN TEXT_BAR.outlineSize% = 1
        TEXT_BAR_apply_outline_to_selection
        TEXT_BAR.needsRedraw% = TRUE
        FRAME_IDLE% = FALSE
    ELSEIF inRow2% AND rawX% >= TEXT_BAR.shadowBtnX% AND rawX% < TEXT_BAR.shadowBtnX% + THEME.TEXT_BAR_BTN_WIDTH% THEN
        TEXT_BAR.shadowActive% = NOT TEXT_BAR.shadowActive%
        TEXT_BAR_apply_shadow_to_selection
        TEXT_BAR.needsRedraw% = TRUE
        FRAME_IDLE% = FALSE
    ELSEIF inRow2% AND TEXT_BAR.shadowActive% AND rawX% >= TEXT_BAR.shadowColorBtnX% AND rawX% < TEXT_BAR.shadowColorBtnX% + THEME.TEXT_BAR_SWATCH_WIDTH% THEN
        TEXT_BAR_close_dropdowns
        CMD_execute_action 1508
        FRAME_IDLE% = FALSE
    ELSEIF inRow2% AND TEXT_BAR.shadowActive% AND rawX% >= TEXT_BAR.shadowXBtnX% AND rawX% < TEXT_BAR.shadowXBtnX% + TEXT_BAR.shadowXBtnW% THEN
        ' Cycle shadow X offset 1-10
        TEXT_BAR.shadowOffsetX% = TEXT_BAR.shadowOffsetX% + 1
        IF TEXT_BAR.shadowOffsetX% > 10 THEN TEXT_BAR.shadowOffsetX% = 1
        TEXT_BAR_apply_shadow_to_selection
        TEXT_BAR.needsRedraw% = TRUE
        FRAME_IDLE% = FALSE
    ELSEIF inRow2% AND TEXT_BAR.shadowActive% AND rawX% >= TEXT_BAR.shadowYBtnX% AND rawX% < TEXT_BAR.shadowYBtnX% + TEXT_BAR.shadowYBtnW% THEN
        ' Cycle shadow Y offset 1-10
        TEXT_BAR.shadowOffsetY% = TEXT_BAR.shadowOffsetY% + 1
        IF TEXT_BAR.shadowOffsetY% > 10 THEN TEXT_BAR.shadowOffsetY% = 1
        TEXT_BAR_apply_shadow_to_selection
        TEXT_BAR.needsRedraw% = TRUE
        FRAME_IDLE% = FALSE
    ELSEIF inRow2% AND rawX% >= TEXT_BAR.aaBtnX% AND rawX% < TEXT_BAR.aaBtnX% + TEXT_BAR.aaBtnW% THEN
        TEXT_BAR.aaActive% = NOT TEXT_BAR.aaActive%
        TEXT_BAR_apply_aa
        TEXT_BAR.needsRedraw% = TRUE
        FRAME_IDLE% = FALSE
    ELSEIF inRow2% AND rawX% >= TEXT_BAR.styleDDBtnX% AND rawX% < TEXT_BAR.styleDDBtnX% + TEXT_BAR.styleDDBtnW% THEN
        TEXT_BAR.styleDropdownOpen% = NOT TEXT_BAR.styleDropdownOpen%
        TEXT_BAR.fontDropdownOpen% = FALSE
        TEXT_BAR.sizeDropdownOpen% = FALSE
        TEXT_BAR.needsRedraw% = TRUE
        FRAME_IDLE% = FALSE
    ELSEIF inRow2% AND rawX% >= TEXT_BAR.styleUpdateBtnX% AND rawX% < TEXT_BAR.styleUpdateBtnX% + THEME.TEXT_BAR_BTN_WIDTH% THEN
        ' Update selected style from current bar state
        IF TEXT_STYLE_SELECTED% >= 1 AND TEXT_STYLE_SELECTED% <= TEXT_STYLE_COUNT% THEN
            TEXT_STYLE_capture_current TEXT_STYLE_SELECTED%
            TEXT_STYLE_save_all
        END IF
        TEXT_BAR.needsRedraw% = TRUE
        FRAME_IDLE% = FALSE
    ELSEIF inRow2% AND rawX% >= TEXT_BAR.styleSaveBtnX% AND rawX% < TEXT_BAR.styleSaveBtnX% + THEME.TEXT_BAR_BTN_WIDTH% THEN
        ' Save current settings as a new named style preset
        DIM newStyleName AS STRING
        newStyleName$ = _INPUTBOX$("Save Text Style", "Enter a name for this style:", "Style " + _TRIM$(STR$(TEXT_STYLE_COUNT% + 1)))
        MOUSE_cleanup_after_dialog FALSE
        IF LEN(_TRIM$(newStyleName$)) > 0 THEN
            ' Find the next free slot
            DIM newSlot AS INTEGER
            newSlot% = 0
            DIM si2 AS INTEGER
            FOR si2% = 1 TO TEXT_STYLE_MAX
                IF NOT TEXT_STYLES(si2%).used THEN
                    newSlot% = si2%
                    EXIT FOR
                END IF
            NEXT si2%
            IF newSlot% > 0 THEN
                TEXT_STYLES(newSlot%).name = LEFT$(_TRIM$(newStyleName$), 32)
                TEXT_STYLE_capture_current newSlot%
                TEXT_STYLE_SELECTED% = newSlot%
                IF newSlot% > TEXT_STYLE_COUNT% THEN TEXT_STYLE_COUNT% = newSlot%
                TEXT_STYLE_save_all
            ELSE
                DIM maxStyleMsg AS STRING
                maxStyleMsg$ = "Maximum number of styles reached (" + _TRIM$(STR$(TEXT_STYLE_MAX)) + ")."
                _MESSAGEBOX "Save Text Style", maxStyleMsg$, "warning"
                MOUSE_cleanup_after_dialog FALSE
            END IF
        END IF
        TEXT_BAR.needsRedraw% = TRUE
        FRAME_IDLE% = FALSE
    ELSEIF inRow2% AND rawX% >= TEXT_BAR.styleDeleteBtnX% AND rawX% < TEXT_BAR.styleDeleteBtnX% + THEME.TEXT_BAR_BTN_WIDTH% THEN
        IF TEXT_STYLE_SELECTED% >= 1 AND TEXT_STYLE_SELECTED% <= TEXT_STYLE_COUNT% THEN
            DIM delConfirm AS INTEGER
            delConfirm% = _MESSAGEBOX("Delete Style", "Delete style '" + RTRIM$(TEXT_STYLES(TEXT_STYLE_SELECTED%).name) + "'?", "yesno", "question", 0)
            IF delConfirm% = 1 THEN
                TEXT_STYLES(TEXT_STYLE_SELECTED%).used = FALSE
                TEXT_STYLES(TEXT_STYLE_SELECTED%).name = ""
                TEXT_STYLE_save_all
                TEXT_STYLE_SELECTED% = 0
            END IF
            MOUSE_cleanup_after_dialog FALSE
        END IF
        TEXT_BAR.needsRedraw% = TRUE
        FRAME_IDLE% = FALSE
    ELSE
        TEXT_BAR_close_dropdowns
    END IF
END FUNCTION


''
' Handle mouse wheel interactions for text bar controls.
' Returns TRUE when the wheel event is consumed by text bar UI.
'
' @param rawX% Screen X coordinate
' @param rawY% Screen Y coordinate
' @param wheel_delta% Wheel delta for this frame
' @return INTEGER TRUE if wheel event was consumed
'
FUNCTION TEXT_BAR_handle_wheel% (rawX%, rawY%, wheel_delta%)
    TEXT_BAR_handle_wheel% = FALSE
    IF NOT TEXT_BAR.visible% THEN EXIT FUNCTION
    IF wheel_delta% = 0 THEN EXIT FUNCTION

    FONT_LIST_scan

    ' Font dropdown open: scroll the list.
    IF TEXT_BAR.fontDropdownOpen% THEN
        TEXT_BAR.fontDropdownScroll% = TEXT_BAR.fontDropdownScroll% + wheel_delta% * 3
        IF TEXT_BAR.fontDropdownScroll% < 0 THEN TEXT_BAR.fontDropdownScroll% = 0
        DIM tbFddMaxScroll AS INTEGER
        tbFddMaxScroll% = FONT_LIST_COUNT% - TEXT_BAR_font_dropdown_max_visible%
        IF tbFddMaxScroll% < 0 THEN tbFddMaxScroll% = 0
        IF TEXT_BAR.fontDropdownScroll% > tbFddMaxScroll% THEN TEXT_BAR.fontDropdownScroll% = tbFddMaxScroll%
        FRAME_IDLE% = FALSE
        TEXT_BAR_handle_wheel% = TRUE
        EXIT FUNCTION
    END IF

    IF NOT TEXT_BAR_in_bounds%(rawX%, rawY%) THEN EXIT FUNCTION

    ' Size dropdown open: step selection directly with wheel.
    IF TEXT_BAR.sizeDropdownOpen% THEN
        DIM tbCurSizeIdx AS INTEGER
        DIM tbI AS INTEGER
        tbCurSizeIdx% = -1
        FOR tbI% = 0 TO TEXT_BAR_SIZE_COUNT - 1
            IF TEXT_BAR_SIZES(tbI%) = TEXT_BAR.selectedSize% THEN
                tbCurSizeIdx% = tbI%
                EXIT FOR
            END IF
        NEXT tbI%
        IF tbCurSizeIdx% < 0 THEN
            IF wheel_delta% < 0 THEN
                tbCurSizeIdx% = 0
            ELSE
                tbCurSizeIdx% = TEXT_BAR_SIZE_COUNT - 1
            END IF
        ELSE
            IF wheel_delta% < 0 THEN
                tbCurSizeIdx% = tbCurSizeIdx% + 1
            ELSE
                tbCurSizeIdx% = tbCurSizeIdx% - 1
            END IF
            IF tbCurSizeIdx% < 0 THEN tbCurSizeIdx% = 0
            IF tbCurSizeIdx% > TEXT_BAR_SIZE_COUNT - 1 THEN tbCurSizeIdx% = TEXT_BAR_SIZE_COUNT - 1
        END IF

        IF TEXT_BAR.selectedSize% <> TEXT_BAR_SIZES(tbCurSizeIdx%) THEN
            TEXT_BAR.selectedSize% = TEXT_BAR_SIZES(tbCurSizeIdx%)
            IF TEXT_has_selection% THEN
                IF TEXT_BAR.editingLayerIdx% >= 1 THEN
                    DIM tbSzTd AS INTEGER
                    tbSzTd% = LAYERS(TEXT_BAR.editingLayerIdx%).textDataIdx%
                    IF tbSzTd% >= 1 THEN
                        DIM tbSzMin AS INTEGER, tbSzMax AS INTEGER
                        tbSzMin% = TEXT.selStart%: tbSzMax% = TEXT.selEnd%
                        IF tbSzMin% > tbSzMax% THEN SWAP tbSzMin%, tbSzMax%
                        TEXT_LAYER_set_selection_attr tbSzTd%, tbSzMin%, tbSzMax% - 1, "FONT_SIZE", TEXT_BAR.selectedSize%
                        SCENE_DIRTY% = TRUE
                    END IF
                END IF
            END IF
            TEXT_BAR_auto_update_line_height
            IF CHARMAP.charGridShow% THEN
                CHARMAP_char_grid_update_size
                CHARMAP_char_grid_draw
                SCENE_DIRTY% = TRUE
            END IF
            FRAME_IDLE% = FALSE
        END IF
        TEXT_BAR_handle_wheel% = TRUE
        EXIT FUNCTION
    END IF

    DIM tbBw AS INTEGER
    tbBw% = TEXT_BAR.styleBtnW%

    ' Wheel over font button: previous/next font.
    IF rawX% >= TEXT_BAR.fontBtnX% AND rawX% < TEXT_BAR.fontBtnX% + TEXT_BAR.fontBtnW% THEN
        IF FONT_LIST_COUNT% > 0 THEN
            DIM tbNextFontIdx AS INTEGER
            tbNextFontIdx% = TEXT_BAR.selectedFontIdx%
            IF wheel_delta% < 0 THEN
                IF tbNextFontIdx% < FONT_LIST_COUNT% - 1 THEN tbNextFontIdx% = tbNextFontIdx% + 1
            ELSE
                IF tbNextFontIdx% > 0 THEN tbNextFontIdx% = tbNextFontIdx% - 1
            END IF

            IF tbNextFontIdx% <> TEXT_BAR.selectedFontIdx% THEN
                TEXT_BAR.selectedFontIdx% = tbNextFontIdx%
                IF FONT_LIST(tbNextFontIdx%).isBuiltIn THEN
                    TEXT_BAR.selectedSize% = FONT_LIST(tbNextFontIdx%).builtInHandle
                ELSEIF FONT_LIST(tbNextFontIdx%).isBitmapFont THEN
                    TEXT_BAR.selectedSize% = FONT_LIST(tbNextFontIdx%).bitmapGlyphH
                    TEXT_BAR.monoActive% = TRUE
                    TEXT_BAR.autoLineHeight% = TRUE
                END IF
                TEXT_BAR_ensure_char_mode_safe_font
                IF TEXT_has_selection% THEN
                    IF TEXT_BAR.editingLayerIdx% >= 1 THEN
                        DIM tbFsTd AS INTEGER
                        tbFsTd% = LAYERS(TEXT_BAR.editingLayerIdx%).textDataIdx%
                        IF tbFsTd% >= 1 THEN
                            DIM tbFsMin AS INTEGER, tbFsMax AS INTEGER
                            tbFsMin% = TEXT.selStart%: tbFsMax% = TEXT.selEnd%
                            IF tbFsMin% > tbFsMax% THEN SWAP tbFsMin%, tbFsMax%
                            TEXT_LAYER_set_selection_attr tbFsTd%, tbFsMin%, tbFsMax% - 1, "FONT_IDX", tbNextFontIdx%
                            SCENE_DIRTY% = TRUE
                        END IF
                    END IF
                END IF
                TEXT_BAR_auto_update_line_height
                CHARMAP.cacheValid% = FALSE
                GUI_NEEDS_REDRAW% = TRUE
                SCENE_DIRTY% = TRUE
                IF CHARMAP.charGridShow% THEN
                    CHARMAP_char_grid_update_size
                    CHARMAP_char_grid_draw
                    SCENE_DIRTY% = TRUE
                END IF
                FRAME_IDLE% = FALSE
            END IF
        END IF
        TEXT_BAR_handle_wheel% = TRUE
        EXIT FUNCTION
    END IF

    ' Wheel over size button: step through size presets.
    IF rawX% >= TEXT_BAR.sizeBtnX% AND rawX% < TEXT_BAR.sizeBtnX% + TEXT_BAR.sizeBtnW% THEN
        DIM tbSizeIdx AS INTEGER
        tbSizeIdx% = -1
        FOR tbI% = 0 TO TEXT_BAR_SIZE_COUNT - 1
            IF TEXT_BAR_SIZES(tbI%) = TEXT_BAR.selectedSize% THEN
                tbSizeIdx% = tbI%
                EXIT FOR
            END IF
        NEXT tbI%

        IF tbSizeIdx% < 0 THEN
            IF wheel_delta% < 0 THEN
                tbSizeIdx% = 0
            ELSE
                tbSizeIdx% = TEXT_BAR_SIZE_COUNT - 1
            END IF
        ELSE
            IF wheel_delta% < 0 THEN
                tbSizeIdx% = tbSizeIdx% + 1
            ELSE
                tbSizeIdx% = tbSizeIdx% - 1
            END IF
            IF tbSizeIdx% < 0 THEN tbSizeIdx% = 0
            IF tbSizeIdx% > TEXT_BAR_SIZE_COUNT - 1 THEN tbSizeIdx% = TEXT_BAR_SIZE_COUNT - 1
        END IF

        IF TEXT_BAR.selectedSize% <> TEXT_BAR_SIZES(tbSizeIdx%) THEN
            TEXT_BAR.selectedSize% = TEXT_BAR_SIZES(tbSizeIdx%)
            IF TEXT_has_selection% THEN
                IF TEXT_BAR.editingLayerIdx% >= 1 THEN
                    DIM tbSelTd AS INTEGER
                    tbSelTd% = LAYERS(TEXT_BAR.editingLayerIdx%).textDataIdx%
                    IF tbSelTd% >= 1 THEN
                        DIM tbSelMin AS INTEGER, tbSelMax AS INTEGER
                        tbSelMin% = TEXT.selStart%: tbSelMax% = TEXT.selEnd%
                        IF tbSelMin% > tbSelMax% THEN SWAP tbSelMin%, tbSelMax%
                        TEXT_LAYER_set_selection_attr tbSelTd%, tbSelMin%, tbSelMax% - 1, "FONT_SIZE", TEXT_BAR.selectedSize%
                        SCENE_DIRTY% = TRUE
                    END IF
                END IF
            END IF
            TEXT_BAR_auto_update_line_height
            CHARMAP.cacheValid% = FALSE
            GUI_NEEDS_REDRAW% = TRUE
            SCENE_DIRTY% = TRUE
            IF CHARMAP.charGridShow% THEN
                CHARMAP_char_grid_update_size
                CHARMAP_char_grid_draw
            END IF
            FRAME_IDLE% = FALSE
        END IF
        TEXT_BAR_handle_wheel% = TRUE
        EXIT FUNCTION
    END IF

    ' Wheel over line-height button: adjust manual line-height by 1px.
    IF rawX% >= TEXT_BAR.lineHeightBtnX% AND rawX% < TEXT_BAR.lineHeightBtnX% + TEXT_BAR.lineHeightBtnW% THEN
        IF TEXT_BAR.editingLayerIdx% >= 1 THEN
            DIM tbLhTd AS INTEGER
            tbLhTd% = LAYERS(TEXT_BAR.editingLayerIdx%).textDataIdx%
            IF tbLhTd% >= 1 THEN
                DIM tbNewLh AS INTEGER
                tbNewLh% = TEXT_BAR_get_line_height%
                IF wheel_delta% < 0 THEN
                    tbNewLh% = tbNewLh% + 1
                ELSE
                    tbNewLh% = tbNewLh% - 1
                END IF
                IF tbNewLh% < 1 THEN tbNewLh% = 1
                IF tbNewLh% > 999 THEN tbNewLh% = 999
                IF tbNewLh% <> TEXT_LAYER_DATA(tbLhTd%).defaultLeading THEN
                    TEXT_LAYER_DATA(tbLhTd%).defaultLeading = tbNewLh%
                    TEXT_LAYER_DATA(tbLhTd%).dirty = TRUE
                    TEXT_BAR.autoLineHeight% = FALSE
                    SCENE_DIRTY% = TRUE
                    FRAME_IDLE% = FALSE
                END IF
            END IF
        END IF
        TEXT_BAR_handle_wheel% = TRUE
        EXIT FUNCTION
    END IF

    ' Consume wheel for style/char controls to prevent canvas zoom while over text bar chrome.
    IF rawX% >= TEXT_BAR.boldBtnX% AND rawX% < TEXT_BAR.boldBtnX% + tbBw% THEN TEXT_BAR_handle_wheel% = TRUE: EXIT FUNCTION
    IF rawX% >= TEXT_BAR.italicBtnX% AND rawX% < TEXT_BAR.italicBtnX% + tbBw% THEN TEXT_BAR_handle_wheel% = TRUE: EXIT FUNCTION
    IF rawX% >= TEXT_BAR.underlineBtnX% AND rawX% < TEXT_BAR.underlineBtnX% + tbBw% THEN TEXT_BAR_handle_wheel% = TRUE: EXIT FUNCTION
    IF rawX% >= TEXT_BAR.strikeBtnX% AND rawX% < TEXT_BAR.strikeBtnX% + tbBw% THEN TEXT_BAR_handle_wheel% = TRUE: EXIT FUNCTION
    IF rawX% >= TEXT_BAR.autoLHBtnX% AND rawX% < TEXT_BAR.autoLHBtnX% + TEXT_BAR.autoLHBtnW% THEN TEXT_BAR_handle_wheel% = TRUE: EXIT FUNCTION
    IF rawX% >= TEXT_BAR.charBtnX% AND rawX% < TEXT_BAR.charBtnX% + TEXT_BAR.charBtnW% THEN TEXT_BAR_handle_wheel% = TRUE: EXIT FUNCTION
    IF rawX% >= TEXT_BAR.fgSwatchX% AND rawX% < TEXT_BAR.fgSwatchX% + 10 THEN TEXT_BAR_handle_wheel% = TRUE: EXIT FUNCTION
    IF rawX% >= TEXT_BAR.bgSwatchX% AND rawX% < TEXT_BAR.bgSwatchX% + 10 THEN TEXT_BAR_handle_wheel% = TRUE: EXIT FUNCTION
    IF rawX% >= TEXT_BAR.monoBtnX% AND rawX% < TEXT_BAR.monoBtnX% + TEXT_BAR.monoBtnW% THEN TEXT_BAR_handle_wheel% = TRUE: EXIT FUNCTION

    TEXT_BAR_handle_wheel% = TRUE
END FUNCTION


''
' Handle keyboard shortcuts for text formatting.
' @param k& Key code from _KEYHIT
'
SUB TEXT_BAR_handle_key (k&)
    IF NOT TEXT_BAR.visible% THEN EXIT SUB
    ' Ctrl+B, Ctrl+I, Ctrl+U handled in KEYBOARD.BM Phase 4
END SUB


''
' Sync text formatting colors with PAINT_COLOR~& and PAINT_BG_COLOR~&.
' Called each frame when the text bar is visible.
' This is the mechanism for global color sync — any color pick in DRAW
' automatically updates text formatting.
'
SUB TEXT_BAR_sync_paint_color ()
    IF NOT TEXT_BAR.visible% THEN EXIT SUB
    IF TEXT_BAR.editingLayerIdx% <= 0 THEN EXIT SUB

    DIM tdIdx AS INTEGER
    tdIdx% = LAYERS(TEXT_BAR.editingLayerIdx%).textDataIdx%
    IF tdIdx% < 1 THEN EXIT SUB

    ' Check if FG color changed
    IF PAINT_COLOR~& <> TEXT_BAR.lastPaintColor~& THEN
        TEXT_BAR.lastPaintColor~& = PAINT_COLOR~&
        IF TEXT_has_selection% THEN
            ' Apply FG color only to selected characters
            DIM fgMin AS INTEGER, fgMax AS INTEGER
            fgMin% = TEXT.selStart%: fgMax% = TEXT.selEnd%
            IF fgMin% > fgMax% THEN SWAP fgMin%, fgMax%
            TEXT_LAYER_set_selection_attr tdIdx%, fgMin%, fgMax% - 1, "FG", PAINT_COLOR~&
            TEXT_LAYER_DATA(tdIdx%).dirty = TRUE
            SCENE_DIRTY% = TRUE
            FRAME_IDLE% = FALSE
        END IF
    END IF

    ' Check if BG color changed
    IF PAINT_BG_COLOR~& <> TEXT_BAR.lastPaintBgColor~& THEN
        TEXT_BAR.lastPaintBgColor~& = PAINT_BG_COLOR~&
        IF TEXT_has_selection% THEN
            ' Apply BG color only to selected characters
            DIM bgMin AS INTEGER, bgMax AS INTEGER
            bgMin% = TEXT.selStart%: bgMax% = TEXT.selEnd%
            IF bgMin% > bgMax% THEN SWAP bgMin%, bgMax%
            TEXT_LAYER_set_selection_attr tdIdx%, bgMin%, bgMax% - 1, "BG", PAINT_BG_COLOR~&
            TEXT_LAYER_DATA(tdIdx%).dirty = TRUE
            SCENE_DIRTY% = TRUE
            FRAME_IDLE% = FALSE
        END IF
    END IF
END SUB


''
' Check if a screen coordinate falls within text bar interactive UI bounds.
' Includes main bar and currently open dropdown bounds.
' @param rawX% Screen X
' @param rawY% Screen Y
' @return INTEGER TRUE if within text bar interactive region
'
FUNCTION TEXT_BAR_ui_in_bounds% (rawX%, rawY%)
    TEXT_BAR_ui_in_bounds% = FALSE
    IF NOT TEXT_BAR.visible% THEN EXIT FUNCTION

    IF TEXT_BAR_in_bounds%(rawX%, rawY%) THEN
        TEXT_BAR_ui_in_bounds% = TRUE
        EXIT FUNCTION
    END IF

    IF TEXT_BAR.fontDropdownOpen% THEN
        DIM fddX AS INTEGER, fddY AS INTEGER, fddW AS INTEGER, fddH AS INTEGER
        fddX% = TEXT_BAR.fontBtnX%
        fddY% = TEXT_BAR.barY% + THEME.TEXT_BAR_ROW_HEIGHT%
        fddW% = 160
        fddH% = TEXT_BAR_font_dropdown_max_visible% * 12 + 2
        IF rawX% >= fddX% AND rawX% < fddX% + fddW% THEN
            IF rawY% >= fddY% AND rawY% < fddY% + fddH% THEN
                TEXT_BAR_ui_in_bounds% = TRUE
                EXIT FUNCTION
            END IF
        END IF
    END IF

    IF TEXT_BAR.sizeDropdownOpen% THEN
        DIM sddX AS INTEGER, sddY AS INTEGER, sddW AS INTEGER, sddH AS INTEGER
        sddX% = TEXT_BAR.sizeBtnX%
        sddY% = TEXT_BAR.barY% + THEME.TEXT_BAR_ROW_HEIGHT%
        sddW% = 40
        sddH% = TEXT_BAR_SIZE_COUNT * 12 + 2
        IF rawX% >= sddX% AND rawX% < sddX% + sddW% THEN
            IF rawY% >= sddY% AND rawY% < sddY% + sddH% THEN
                TEXT_BAR_ui_in_bounds% = TRUE
                EXIT FUNCTION
            END IF
        END IF
    END IF

    IF TEXT_BAR.styleDropdownOpen% THEN
        DIM stUibHasDivider AS INTEGER
        DIM stUibDdH AS INTEGER
        IF TEXT_STYLE_COUNT% > 0 THEN stUibHasDivider% = 1 ELSE stUibHasDivider% = 0
        stUibDdH% = 12 + 2 + (stUibHasDivider% * 12) + TEXT_STYLE_COUNT% * 12
        IF rawX% >= TEXT_BAR.styleDDBtnX% AND rawX% < TEXT_BAR.styleDDBtnX% + 120 THEN
            ' Cover both the button row and the full dropdown content below it
            IF rawY% >= TEXT_BAR.barY% + THEME.TEXT_BAR_ROW_HEIGHT% AND rawY% < TEXT_BAR.barY% + THEME.TEXT_BAR_ROW_HEIGHT% * 2 + stUibDdH% THEN
                TEXT_BAR_ui_in_bounds% = TRUE
                EXIT FUNCTION
            END IF
        END IF
    END IF
END FUNCTION


''
' Check if a screen coordinate falls within the text bar bounds.
' @param rawX% Screen X
' @param rawY% Screen Y
' @return INTEGER TRUE if within bounds
'
FUNCTION TEXT_BAR_in_bounds% (rawX%, rawY%)
    TEXT_BAR_in_bounds% = FALSE
    IF NOT TEXT_BAR.visible% THEN EXIT FUNCTION
    IF rawX% >= TEXT_BAR.barX% AND rawX% < TEXT_BAR.barX% + TEXT_BAR.barW% THEN
        IF rawY% >= TEXT_BAR.barY% AND rawY% < TEXT_BAR.barY% + TEXT_BAR.barH% THEN
            TEXT_BAR_in_bounds% = TRUE
        END IF
    END IF
END FUNCTION


''
' Close any open dropdowns.
'
SUB TEXT_BAR_close_dropdowns ()
    TEXT_BAR.fontDropdownOpen% = FALSE
    TEXT_BAR.sizeDropdownOpen% = FALSE
    TEXT_BAR.styleDropdownOpen% = FALSE
END SUB


''
' Apply alignment setting to the current text layer.
'
SUB TEXT_BAR_apply_alignment ()
    IF TEXT_BAR.editingLayerIdx% < 1 THEN EXIT SUB
    DIM alTd AS INTEGER
    alTd% = LAYERS(TEXT_BAR.editingLayerIdx%).textDataIdx%
    IF alTd% < 1 THEN EXIT SUB
    TEXT_LAYER_DATA(alTd%).alignment = TEXT_BAR.alignMode%
    TEXT_LAYER_DATA(alTd%).dirty = TRUE
    SCENE_DIRTY% = TRUE
END SUB


''
' Apply outline state to selection or store as default for new chars.
'
SUB TEXT_BAR_apply_outline_to_selection ()
    IF TEXT_BAR.editingLayerIdx% < 1 THEN EXIT SUB
    DIM olTd AS INTEGER
    olTd% = LAYERS(TEXT_BAR.editingLayerIdx%).textDataIdx%
    IF olTd% < 1 THEN EXIT SUB

    IF TEXT_has_selection% THEN
        DIM olMin AS INTEGER, olMax AS INTEGER
        olMin% = TEXT.selStart%: olMax% = TEXT.selEnd%
        IF olMin% > olMax% THEN SWAP olMin%, olMax%
        TEXT_LAYER_set_selection_attr olTd%, olMin%, olMax% - 1, "OUTLINE", TEXT_BAR.outlineActive%
        TEXT_LAYER_set_selection_attr olTd%, olMin%, olMax% - 1, "OUTLINE_COLOR", TEXT_BAR.outlineColor~&
        TEXT_LAYER_set_selection_attr olTd%, olMin%, olMax% - 1, "OUTLINE_SIZE", TEXT_BAR.outlineSize%
    END IF
    TEXT_LAYER_DATA(olTd%).dirty = TRUE
    SCENE_DIRTY% = TRUE
END SUB


''
' Apply shadow state to selection or store as default for new chars.
'
SUB TEXT_BAR_apply_shadow_to_selection ()
    IF TEXT_BAR.editingLayerIdx% < 1 THEN EXIT SUB
    DIM shTd AS INTEGER
    shTd% = LAYERS(TEXT_BAR.editingLayerIdx%).textDataIdx%
    IF shTd% < 1 THEN EXIT SUB

    IF TEXT_has_selection% THEN
        DIM shMin AS INTEGER, shMax AS INTEGER
        shMin% = TEXT.selStart%: shMax% = TEXT.selEnd%
        IF shMin% > shMax% THEN SWAP shMin%, shMax%
        TEXT_LAYER_set_selection_attr shTd%, shMin%, shMax% - 1, "SHADOW", TEXT_BAR.shadowActive%
        TEXT_LAYER_set_selection_attr shTd%, shMin%, shMax% - 1, "SHADOW_COLOR", TEXT_BAR.shadowColor~&
        TEXT_LAYER_set_selection_attr shTd%, shMin%, shMax% - 1, "SHADOW_X", TEXT_BAR.shadowOffsetX%
        TEXT_LAYER_set_selection_attr shTd%, shMin%, shMax% - 1, "SHADOW_Y", TEXT_BAR.shadowOffsetY%
    END IF
    TEXT_LAYER_DATA(shTd%).dirty = TRUE
    SCENE_DIRTY% = TRUE
END SUB


''
' Apply AA toggle to the current text layer.
'
SUB TEXT_BAR_apply_aa ()
    DIM aaTd AS INTEGER
    DIM aaLayerIdx AS INTEGER
    ' Use editing layer if active; fall back to current text layer.
    aaLayerIdx% = TEXT_BAR.editingLayerIdx%
    IF aaLayerIdx% < 1 THEN
        IF CURRENT_LAYER% >= 1 THEN
            IF LAYERS(CURRENT_LAYER%).layerType% = LAYER_TYPE_TEXT THEN
                aaLayerIdx% = CURRENT_LAYER%
            END IF
        END IF
    END IF
    IF aaLayerIdx% < 1 THEN EXIT SUB
    aaTd% = LAYERS(aaLayerIdx%).textDataIdx%
    IF aaTd% < 1 THEN EXIT SUB
    TEXT_LAYER_DATA(aaTd%).antialias = TEXT_BAR.aaActive%
    TEXT_LAYER_DATA(aaTd%).dirty = TRUE
    SCENE_DIRTY% = TRUE
END SUB


''
' Apply a style toggle to the current text selection (if any).
' If no selection, the toggle state is just stored as default for new chars.
' Full selection logic will be wired in Phase 4.
'
' @param attrName$ Attribute name: "BOLD", "ITALIC", "UNDERLINE", "STRIKE"
'
SUB TEXT_BAR_apply_style_to_selection (attrName$)
    IF TEXT_BAR.editingLayerIdx% <= 0 THEN EXIT SUB

    DIM tdIdx AS INTEGER
    tdIdx% = LAYERS(TEXT_BAR.editingLayerIdx%).textDataIdx%
    IF tdIdx% < 1 THEN EXIT SUB

    ' If there's an active selection, apply the style to selected chars
    IF TEXT_has_selection% THEN
        DIM asMin AS INTEGER, asMax AS INTEGER
        asMin% = TEXT.selStart%: asMax% = TEXT.selEnd%
        IF asMin% > asMax% THEN SWAP asMin%, asMax%
        DIM asAttr AS STRING
        asAttr$ = UCASE$(attrName$)
        DIM asVal AS LONG
        SELECT CASE asAttr$
            CASE "BOLD": asVal& = TEXT_BAR.boldActive%
            CASE "ITALIC": asVal& = TEXT_BAR.italicActive%
            CASE "UNDERLINE": asVal& = TEXT_BAR.underlineActive%
            CASE "STRIKE": asVal& = TEXT_BAR.strikeActive%
        END SELECT
        TEXT_LAYER_set_selection_attr tdIdx%, asMin%, asMax% - 1, asAttr$, asVal&
        ' Recompute cursor X — character widths may have changed (e.g. faux bold on/off)
        TEXT.CURSOR_X = TEXT_LAYER_get_char_x%(tdIdx%, TEXT_LAYER_DATA(tdIdx%).cursorPos)
        SCENE_DIRTY% = TRUE
        FRAME_IDLE% = FALSE
    END IF

    TEXT_LAYER_DATA(tdIdx%).dirty = TRUE
END SUB


''
' Get current line height (defaultLeading) for the active text layer.
' Returns selectedSize + 1 if no active layer.
'
FUNCTION TEXT_BAR_get_line_height% ()
    IF TEXT_BAR.editingLayerIdx% >= 1 THEN
        DIM lhTd AS INTEGER
        lhTd% = LAYERS(TEXT_BAR.editingLayerIdx%).textDataIdx%
        IF lhTd% >= 1 THEN
            IF TEXT_LAYER_DATA(lhTd%).defaultLeading > 0 THEN
                TEXT_BAR_get_line_height% = TEXT_LAYER_DATA(lhTd%).defaultLeading
            ELSE
                IF CHARMAP.useChars% THEN
                    CHARMAP_char_grid_update_size
                    TEXT_BAR_get_line_height% = CHARMAP.charGridH%
                    EXIT FUNCTION
                END IF
                IF FONT_LIST(TEXT_BAR.selectedFontIdx%).isBuiltIn THEN
                    TEXT_BAR_get_line_height% = FONT_LIST(TEXT_BAR.selectedFontIdx%).builtInHandle
                ELSEIF FONT_LIST(TEXT_BAR.selectedFontIdx%).isBitmapFont THEN
                    TEXT_BAR_get_line_height% = FONT_LIST(TEXT_BAR.selectedFontIdx%).bitmapGlyphH
                ELSE
                    TEXT_BAR_get_line_height% = TEXT_BAR.selectedSize% + 1
                END IF
            END IF
            EXIT FUNCTION
        END IF
    END IF
    IF FONT_LIST(TEXT_BAR.selectedFontIdx%).isBuiltIn THEN
        TEXT_BAR_get_line_height% = FONT_LIST(TEXT_BAR.selectedFontIdx%).builtInHandle
    ELSEIF FONT_LIST(TEXT_BAR.selectedFontIdx%).isBitmapFont THEN
        TEXT_BAR_get_line_height% = FONT_LIST(TEXT_BAR.selectedFontIdx%).bitmapGlyphH
    ELSE
        TEXT_BAR_get_line_height% = TEXT_BAR.selectedSize% + 1
    END IF
END FUNCTION


''
' Adjust line height for the active text layer via input box.
'
SUB TEXT_BAR_adjust_line_height ()
    IF TEXT_BAR.editingLayerIdx% < 1 THEN EXIT SUB
    DIM alhTd AS INTEGER
    alhTd% = LAYERS(TEXT_BAR.editingLayerIdx%).textDataIdx%
    IF alhTd% < 1 THEN EXIT SUB

    DIM curLH AS INTEGER
    curLH% = TEXT_BAR_get_line_height%
    DIM result AS STRING
    result$ = _INPUTBOX$("Line Height", "Enter line height in pixels:", LTRIM$(STR$(curLH%)))
    IF LEN(result$) > 0 THEN
        DIM newLH AS INTEGER
        newLH% = VAL(result$)
        IF newLH% >= 1 AND newLH% <= 999 THEN
            TEXT_LAYER_DATA(alhTd%).defaultLeading = newLH%
            TEXT_LAYER_DATA(alhTd%).dirty = TRUE
            SCENE_DIRTY% = TRUE
            FRAME_IDLE% = FALSE
            ' Manual line height change disables auto
            TEXT_BAR.autoLineHeight% = FALSE
        END IF
    END IF
    MOUSE_cleanup_after_dialog FALSE
END SUB


''
' Auto-update line height based on the largest font size in the active text layer.
' If no text exists yet, uses the current TEXT_BAR.selectedSize%.
' Called when AUTO is on and font/size changes.
'
SUB TEXT_BAR_auto_update_line_height ()
    IF NOT TEXT_BAR.autoLineHeight% THEN EXIT SUB

    DIM newLH AS INTEGER
    newLH% = TEXT_BAR.selectedSize%

    ' For fixed-size bitmap fonts, use native height
    IF TEXT_BAR.selectedFontIdx% >= 0 AND TEXT_BAR.selectedFontIdx% < FONT_LIST_COUNT% THEN
        IF FONT_LIST(TEXT_BAR.selectedFontIdx%).isBuiltIn THEN
            newLH% = FONT_LIST(TEXT_BAR.selectedFontIdx%).builtInHandle
        ELSEIF FONT_LIST(TEXT_BAR.selectedFontIdx%).isBitmapFont THEN
            newLH% = FONT_LIST(TEXT_BAR.selectedFontIdx%).bitmapGlyphH
        END IF
    END IF

    IF CHARMAP.useChars% THEN
        CHARMAP_char_grid_update_size
        newLH% = CHARMAP.charGridH%
    END IF

    ' Scan existing characters to find the largest font size in use
    IF TEXT_BAR.editingLayerIdx% >= 1 THEN
        DIM auTd AS INTEGER
        auTd% = LAYERS(TEXT_BAR.editingLayerIdx%).textDataIdx%
        IF auTd% >= 1 AND TEXT_LAYER_DATA(auTd%).used THEN
            DIM auI AS INTEGER
            DIM auMax AS INTEGER
            auMax% = newLH%
            FOR auI% = 0 TO TEXT_LAYER_DATA(auTd%).charCount - 1
                DIM auCharSize AS INTEGER
                DIM auCharFontIdx AS INTEGER
                auCharFontIdx% = TL_FONT_IDX(auTd%, auI%)
                IF auCharFontIdx% >= 0 AND auCharFontIdx% < FONT_LIST_COUNT% THEN
                    IF FONT_LIST(auCharFontIdx%).isBuiltIn THEN
                        auCharSize% = FONT_LIST(auCharFontIdx%).builtInHandle
                    ELSEIF FONT_LIST(auCharFontIdx%).isBitmapFont THEN
                        auCharSize% = FONT_LIST(auCharFontIdx%).bitmapGlyphH
                    ELSE
                        auCharSize% = TL_FONT_SIZE(auTd%, auI%)
                    END IF
                ELSE
                    auCharSize% = TL_FONT_SIZE(auTd%, auI%)
                END IF
                IF auCharSize% > auMax% THEN auMax% = auCharSize%
            NEXT auI%

            ' For scalable fonts add +1 for spacing; fixed bitmap fonts use exact height
            IF CHARMAP.useChars% THEN
                newLH% = CHARMAP.charGridH%
            ELSEIF FONT_LIST(TEXT_BAR.selectedFontIdx%).isBuiltIn OR FONT_LIST(TEXT_BAR.selectedFontIdx%).isBitmapFont THEN
                newLH% = auMax%
            ELSE
                newLH% = auMax% + 1
            END IF

            ' Apply to text layer
            IF newLH% <> TEXT_LAYER_DATA(auTd%).defaultLeading THEN
                TEXT_LAYER_DATA(auTd%).defaultLeading = newLH%
                TEXT_LAYER_DATA(auTd%).dirty = TRUE
                SCENE_DIRTY% = TRUE
                FRAME_IDLE% = FALSE
            END IF
            EXIT SUB
        END IF
    END IF

    ' No active layer — nothing more to do (selectedSize reflects in get_line_height)
END SUB


''
' Compute the max visible items for the font dropdown.
' Uses ~75% of screen height if there are enough fonts, otherwise fits to count.
' @return INTEGER number of visible rows
'
FUNCTION TEXT_BAR_font_dropdown_max_visible% ()
    DIM itemH AS INTEGER
    DIM available AS INTEGER
    DIM maxItems AS INTEGER
    itemH% = 12
    ' Available vertical space: from dropdown top to 75% of viewport height
    available% = INT(SCRN.h& * 0.75) - (TEXT_BAR.barY% + TEXT_BAR.barH%)
    IF available% < itemH% THEN available% = itemH%
    maxItems% = available% \ itemH%
    IF maxItems% < 5 THEN maxItems% = 5
    IF FONT_LIST_COUNT% < maxItems% THEN maxItems% = FONT_LIST_COUNT%
    TEXT_BAR_font_dropdown_max_visible% = maxItems%
END FUNCTION


''
' Load text styles from USER/DRAW_TEXT_STYLES.dstyle at startup.
'
SUB TEXT_STYLE_load ()
    DIM stylePath AS STRING
    stylePath$ = "USER/DRAW_TEXT_STYLES.dstyle"
    IF NOT _FILEEXISTS(stylePath$) THEN EXIT SUB

    DIM fh AS INTEGER
    fh% = FREEFILE
    OPEN stylePath$ FOR INPUT AS #fh%
    TEXT_STYLE_COUNT% = 0
    TEXT_STYLE_SELECTED% = 0

    DIM curSlot AS INTEGER
    curSlot% = 0
    DIM ln AS STRING, k AS STRING, v AS STRING
    DIM eqPos AS INTEGER

    DO WHILE NOT EOF(fh%)
        LINE INPUT #fh%, ln$
        ln$ = _TRIM$(ln$)
        IF LEN(ln$) = 0 OR LEFT$(ln$, 1) = "#" THEN _CONTINUE

        eqPos% = INSTR(ln$, "=")
        IF eqPos% < 2 THEN _CONTINUE
        k$ = UCASE$(_TRIM$(LEFT$(ln$, eqPos% - 1)))
        v$ = _TRIM$(MID$(ln$, eqPos% + 1))

        IF k$ = "NAME" THEN
            ' Start a new style block
            IF curSlot% < TEXT_STYLE_MAX THEN
                curSlot% = curSlot% + 1
                TEXT_STYLES(curSlot%).used = TRUE
                TEXT_STYLES(curSlot%).name = v$
                ' Set defaults for this slot
                TEXT_STYLES(curSlot%).fontSize = 8
                TEXT_STYLES(curSlot%).antialias = TRUE
                TEXT_STYLES(curSlot%).fgColor = _RGB32(255, 255, 255)
                TEXT_STYLES(curSlot%).bgColor = _RGBA32(0, 0, 0, 0)
                TEXT_STYLES(curSlot%).outColor = _RGB32(0, 0, 0)
                TEXT_STYLES(curSlot%).shdColor = _RGB32(0, 0, 0)
                TEXT_STYLES(curSlot%).outSize = 1
                TEXT_STYLES(curSlot%).shdX = 2
                TEXT_STYLES(curSlot%).shdY = 2
                TEXT_STYLE_COUNT% = curSlot%
            END IF
        ELSEIF curSlot% >= 1 AND curSlot% <= TEXT_STYLE_MAX THEN
            SELECT CASE k$
                CASE "FONT":      TEXT_STYLES(curSlot%).fontName = v$
                CASE "SIZE":      TEXT_STYLES(curSlot%).fontSize = VAL(v$)
                CASE "BOLD":      TEXT_STYLES(curSlot%).bold = VAL(v$)
                CASE "ITALIC":    TEXT_STYLES(curSlot%).italic = VAL(v$)
                CASE "UNDERLINE": TEXT_STYLES(curSlot%).underline = VAL(v$)
                CASE "STRIKE":    TEXT_STYLES(curSlot%).strike = VAL(v$)
                CASE "MONO":      TEXT_STYLES(curSlot%).mono = VAL(v$)
                CASE "LINE_HEIGHT": TEXT_STYLES(curSlot%).lineHeight = VAL(v$)
                CASE "AUTO_LH":   TEXT_STYLES(curSlot%).autoLH = VAL(v$)
                CASE "CHAR_MODE": TEXT_STYLES(curSlot%).charMode = VAL(v$)
                CASE "FG_COLOR":  TEXT_STYLES(curSlot%).fgColor = THEME_parse_rgba~&(v$)
                CASE "BG_COLOR":  TEXT_STYLES(curSlot%).bgColor = THEME_parse_rgba~&(v$)
                CASE "OUTLINE":   TEXT_STYLES(curSlot%).outline = VAL(v$)
                CASE "OUTLINE_COLOR": TEXT_STYLES(curSlot%).outColor = THEME_parse_rgba~&(v$)
                CASE "OUTLINE_SIZE": TEXT_STYLES(curSlot%).outSize = VAL(v$)
                CASE "SHADOW":    TEXT_STYLES(curSlot%).shadow = VAL(v$)
                CASE "SHADOW_COLOR": TEXT_STYLES(curSlot%).shdColor = THEME_parse_rgba~&(v$)
                CASE "SHADOW_X":  TEXT_STYLES(curSlot%).shdX = VAL(v$)
                CASE "SHADOW_Y":  TEXT_STYLES(curSlot%).shdY = VAL(v$)
                CASE "AA":        TEXT_STYLES(curSlot%).antialias = VAL(v$)
            END SELECT
        END IF
    LOOP

    CLOSE #fh%
    TEXT_STYLE_SELECTED% = 0  ' Always default to "Default" on load
END SUB


''
' Write a single style to a file handle in .dstyle format.
'
SUB TEXT_STYLE_write_one (fh AS INTEGER, idx AS INTEGER)
    IF idx% < 1 OR idx% > TEXT_STYLE_MAX THEN EXIT SUB
    IF NOT TEXT_STYLES(idx%).used THEN EXIT SUB
    DIM c AS _UNSIGNED LONG
    PRINT #fh%, "# DRAW Text Style"
    PRINT #fh%, "NAME=" + RTRIM$(TEXT_STYLES(idx%).name)
    PRINT #fh%, "FONT=" + RTRIM$(TEXT_STYLES(idx%).fontName)
    PRINT #fh%, "SIZE=" + _TRIM$(STR$(TEXT_STYLES(idx%).fontSize))
    PRINT #fh%, "BOLD=" + _TRIM$(STR$(TEXT_STYLES(idx%).bold))
    PRINT #fh%, "ITALIC=" + _TRIM$(STR$(TEXT_STYLES(idx%).italic))
    PRINT #fh%, "UNDERLINE=" + _TRIM$(STR$(TEXT_STYLES(idx%).underline))
    PRINT #fh%, "STRIKE=" + _TRIM$(STR$(TEXT_STYLES(idx%).strike))
    PRINT #fh%, "MONO=" + _TRIM$(STR$(TEXT_STYLES(idx%).mono))
    PRINT #fh%, "LINE_HEIGHT=" + _TRIM$(STR$(TEXT_STYLES(idx%).lineHeight))
    PRINT #fh%, "AUTO_LH=" + _TRIM$(STR$(TEXT_STYLES(idx%).autoLH))
    PRINT #fh%, "CHAR_MODE=" + _TRIM$(STR$(TEXT_STYLES(idx%).charMode))
    c~& = TEXT_STYLES(idx%).fgColor
    PRINT #fh%, "FG_COLOR=" + _TRIM$(STR$(_RED32(c~&))) + "," + _TRIM$(STR$(_GREEN32(c~&))) + "," + _TRIM$(STR$(_BLUE32(c~&))) + "," + _TRIM$(STR$(_ALPHA32(c~&)))
    c~& = TEXT_STYLES(idx%).bgColor
    PRINT #fh%, "BG_COLOR=" + _TRIM$(STR$(_RED32(c~&))) + "," + _TRIM$(STR$(_GREEN32(c~&))) + "," + _TRIM$(STR$(_BLUE32(c~&))) + "," + _TRIM$(STR$(_ALPHA32(c~&)))
    PRINT #fh%, "OUTLINE=" + _TRIM$(STR$(TEXT_STYLES(idx%).outline))
    c~& = TEXT_STYLES(idx%).outColor
    PRINT #fh%, "OUTLINE_COLOR=" + _TRIM$(STR$(_RED32(c~&))) + "," + _TRIM$(STR$(_GREEN32(c~&))) + "," + _TRIM$(STR$(_BLUE32(c~&))) + "," + _TRIM$(STR$(_ALPHA32(c~&)))
    PRINT #fh%, "OUTLINE_SIZE=" + _TRIM$(STR$(TEXT_STYLES(idx%).outSize))
    PRINT #fh%, "SHADOW=" + _TRIM$(STR$(TEXT_STYLES(idx%).shadow))
    c~& = TEXT_STYLES(idx%).shdColor
    PRINT #fh%, "SHADOW_COLOR=" + _TRIM$(STR$(_RED32(c~&))) + "," + _TRIM$(STR$(_GREEN32(c~&))) + "," + _TRIM$(STR$(_BLUE32(c~&))) + "," + _TRIM$(STR$(_ALPHA32(c~&)))
    PRINT #fh%, "SHADOW_X=" + _TRIM$(STR$(TEXT_STYLES(idx%).shdX))
    PRINT #fh%, "SHADOW_Y=" + _TRIM$(STR$(TEXT_STYLES(idx%).shdY))
    PRINT #fh%, "AA=" + _TRIM$(STR$(TEXT_STYLES(idx%).antialias))
    PRINT #fh%, ""
END SUB


''
' Save all text styles to USER/DRAW_TEXT_STYLES.dstyle.
'
SUB TEXT_STYLE_save_all ()
    DIM stylePath AS STRING
    stylePath$ = "USER/DRAW_TEXT_STYLES.dstyle"
    DIM fh AS INTEGER
    fh% = FREEFILE
    OPEN stylePath$ FOR OUTPUT AS #fh%
    DIM si AS INTEGER
    FOR si% = 1 TO TEXT_STYLE_MAX
        IF TEXT_STYLES(si%).used THEN TEXT_STYLE_write_one fh%, si%
    NEXT si%
    CLOSE #fh%
END SUB


''
' Apply the built-in Default style from CFG settings.
' Resets bar to configured defaults and applies to selection if active.
'
SUB TEXT_STYLE_apply_default ()
    ' Resolve font
    DIM defFontIdx AS INTEGER
    defFontIdx% = -1
    IF LEN(CFG.FONT_DEFAULT_FONT$) > 0 THEN
        defFontIdx% = FONT_LIST_find_by_name%(CFG.FONT_DEFAULT_FONT$)
    END IF
    IF defFontIdx% < 0 THEN defFontIdx% = FONT_LIST_find_by_name%("Tiny5 Regular")
    IF defFontIdx% < 0 THEN defFontIdx% = 0
    TEXT_BAR.selectedFontIdx% = defFontIdx%

    ' Font size
    IF CFG.FONT_DEFAULT_SIZE% >= 4 AND CFG.FONT_DEFAULT_SIZE% <= 128 THEN
        TEXT_BAR.selectedSize% = CFG.FONT_DEFAULT_SIZE%
    ELSE
        TEXT_BAR.selectedSize% = 8
    END IF

    ' Reset style toggles to clean defaults
    TEXT_BAR.boldActive% = FALSE
    TEXT_BAR.italicActive% = FALSE
    TEXT_BAR.underlineActive% = FALSE
    TEXT_BAR.strikeActive% = FALSE
    TEXT_BAR.monoActive% = FALSE
    TEXT_BAR.autoLineHeight% = TRUE
    TEXT_BAR.outlineActive% = FALSE
    TEXT_BAR.outlineSize% = 1
    TEXT_BAR.shadowActive% = FALSE
    TEXT_BAR.shadowOffsetX% = 2
    TEXT_BAR.shadowOffsetY% = 2
    TEXT_BAR.aaActive% = TRUE
    TEXT_BAR.alignMode% = TEXT_ALIGN_LEFT

    ' Restore default FG/BG colours
    PAINT_COLOR~& = _RGB32(255, 255, 255)
    PAINT_BG_COLOR~& = _RGB32(0, 0, 0)

    TEXT_STYLE_SELECTED% = 0
    TEXT_BAR.needsRedraw% = TRUE

    IF TEXT_BAR.editingLayerIdx% >= 1 THEN
        TEXT_BAR_apply_alignment
        TEXT_BAR_apply_aa
        TEXT_BAR_auto_update_line_height

        ' Push to selection if active
        IF TEXT_has_selection% THEN
            DIM defTd AS INTEGER
            defTd% = LAYERS(TEXT_BAR.editingLayerIdx%).textDataIdx%
            IF defTd% >= 1 THEN
                DIM defMin AS INTEGER, defMax AS INTEGER
                defMin% = TEXT.selStart%: defMax% = TEXT.selEnd%
                IF defMin% > defMax% THEN SWAP defMin%, defMax%
                DIM defLast AS INTEGER
                defLast% = defMax% - 1
                TEXT_LAYER_set_selection_attr defTd%, defMin%, defLast%, "FONT_IDX", defFontIdx%
                TEXT_LAYER_set_selection_attr defTd%, defMin%, defLast%, "FONT_SIZE", TEXT_BAR.selectedSize%
                TEXT_LAYER_set_selection_attr defTd%, defMin%, defLast%, "BOLD", 0
                TEXT_LAYER_set_selection_attr defTd%, defMin%, defLast%, "ITALIC", 0
                TEXT_LAYER_set_selection_attr defTd%, defMin%, defLast%, "UNDERLINE", 0
                TEXT_LAYER_set_selection_attr defTd%, defMin%, defLast%, "STRIKE", 0
                TEXT_LAYER_set_selection_attr defTd%, defMin%, defLast%, "OUTLINE", 0
                TEXT_LAYER_set_selection_attr defTd%, defMin%, defLast%, "SHADOW", 0
                TEXT_LAYER_set_selection_attr defTd%, defMin%, defLast%, "FG", PAINT_COLOR~&
                TEXT.CURSOR_X = TEXT_LAYER_get_char_x%(defTd%, TEXT_LAYER_DATA(defTd%).cursorPos)
                TEXT_LAYER_DATA(defTd%).dirty = TRUE
                SCENE_DIRTY% = TRUE
                FRAME_IDLE% = FALSE
            END IF
        END IF
    END IF
END SUB


''
' Apply a style preset to the current text bar state.
'
SUB TEXT_STYLE_apply (idx AS INTEGER)
    IF idx% < 1 OR idx% > TEXT_STYLE_MAX THEN EXIT SUB
    IF NOT TEXT_STYLES(idx%).used THEN EXIT SUB

    ' Resolve font name to index
    DIM fontIdx AS INTEGER
    fontIdx% = FONT_LIST_find_by_name%(RTRIM$(TEXT_STYLES(idx%).fontName))
    IF fontIdx% < 0 THEN
        _LOGWARN "TEXT_STYLE_apply: Font '" + RTRIM$(TEXT_STYLES(idx%).fontName) + "' not found, using current"
        fontIdx% = TEXT_BAR.selectedFontIdx%
    END IF

    TEXT_BAR.selectedFontIdx% = fontIdx%
    TEXT_BAR.selectedSize% = TEXT_STYLES(idx%).fontSize
    TEXT_BAR.boldActive% = TEXT_STYLES(idx%).bold
    TEXT_BAR.italicActive% = TEXT_STYLES(idx%).italic
    TEXT_BAR.underlineActive% = TEXT_STYLES(idx%).underline
    TEXT_BAR.strikeActive% = TEXT_STYLES(idx%).strike
    TEXT_BAR.monoActive% = TEXT_STYLES(idx%).mono
    TEXT_BAR.autoLineHeight% = TEXT_STYLES(idx%).autoLH
    TEXT_BAR.outlineActive% = TEXT_STYLES(idx%).outline
    TEXT_BAR.outlineColor~& = TEXT_STYLES(idx%).outColor
    TEXT_BAR.outlineSize% = TEXT_STYLES(idx%).outSize
    TEXT_BAR.shadowActive% = TEXT_STYLES(idx%).shadow
    TEXT_BAR.shadowColor~& = TEXT_STYLES(idx%).shdColor
    TEXT_BAR.shadowOffsetX% = TEXT_STYLES(idx%).shdX
    TEXT_BAR.shadowOffsetY% = TEXT_STYLES(idx%).shdY
    TEXT_BAR.aaActive% = TEXT_STYLES(idx%).antialias

    ' Always restore FG/BG colours — even before drawing starts
    PAINT_COLOR~& = TEXT_STYLES(idx%).fgColor
    PAINT_BG_COLOR~& = TEXT_STYLES(idx%).bgColor

    TEXT_STYLE_SELECTED% = idx%
    TEXT_BAR.needsRedraw% = TRUE
    CHARMAP.cacheValid% = FALSE
    GUI_NEEDS_REDRAW% = TRUE
    SCENE_DIRTY% = TRUE

    ' Apply to current layer if editing
    IF TEXT_BAR.editingLayerIdx% >= 1 THEN
        TEXT_BAR_apply_alignment
        TEXT_BAR_apply_aa
        TEXT_BAR_auto_update_line_height

        ' If there is an active selection, push all style attributes to it
        IF TEXT_has_selection% THEN
            DIM stTd AS INTEGER
            stTd% = LAYERS(TEXT_BAR.editingLayerIdx%).textDataIdx%
            IF stTd% >= 1 THEN
                DIM stMin AS INTEGER, stMax AS INTEGER
                stMin% = TEXT.selStart%: stMax% = TEXT.selEnd%
                IF stMin% > stMax% THEN SWAP stMin%, stMax%
                DIM stLast AS INTEGER
                stLast% = stMax% - 1

                TEXT_LAYER_set_selection_attr stTd%, stMin%, stLast%, "FONT_IDX", fontIdx%
                TEXT_LAYER_set_selection_attr stTd%, stMin%, stLast%, "FONT_SIZE", TEXT_STYLES(idx%).fontSize
                TEXT_LAYER_set_selection_attr stTd%, stMin%, stLast%, "BOLD", TEXT_STYLES(idx%).bold
                TEXT_LAYER_set_selection_attr stTd%, stMin%, stLast%, "ITALIC", TEXT_STYLES(idx%).italic
                TEXT_LAYER_set_selection_attr stTd%, stMin%, stLast%, "UNDERLINE", TEXT_STYLES(idx%).underline
                TEXT_LAYER_set_selection_attr stTd%, stMin%, stLast%, "STRIKE", TEXT_STYLES(idx%).strike
                TEXT_LAYER_set_selection_attr stTd%, stMin%, stLast%, "OUTLINE", TEXT_STYLES(idx%).outline
                TEXT_LAYER_set_selection_attr stTd%, stMin%, stLast%, "OUTLINE_COLOR", TEXT_STYLES(idx%).outColor
                TEXT_LAYER_set_selection_attr stTd%, stMin%, stLast%, "OUTLINE_SIZE", TEXT_STYLES(idx%).outSize
                TEXT_LAYER_set_selection_attr stTd%, stMin%, stLast%, "SHADOW", TEXT_STYLES(idx%).shadow
                TEXT_LAYER_set_selection_attr stTd%, stMin%, stLast%, "SHADOW_COLOR", TEXT_STYLES(idx%).shdColor
                TEXT_LAYER_set_selection_attr stTd%, stMin%, stLast%, "SHADOW_X", TEXT_STYLES(idx%).shdX
                TEXT_LAYER_set_selection_attr stTd%, stMin%, stLast%, "SHADOW_Y", TEXT_STYLES(idx%).shdY
                TEXT_LAYER_set_selection_attr stTd%, stMin%, stLast%, "FG", TEXT_STYLES(idx%).fgColor

                TEXT.CURSOR_X = TEXT_LAYER_get_char_x%(stTd%, TEXT_LAYER_DATA(stTd%).cursorPos)
                TEXT_LAYER_DATA(stTd%).dirty = TRUE
                SCENE_DIRTY% = TRUE
                FRAME_IDLE% = FALSE
            END IF
        END IF
    END IF
END SUB


''
' Capture current text bar state into a style preset slot.
'
SUB TEXT_STYLE_capture_current (idx AS INTEGER)
    IF idx% < 1 OR idx% > TEXT_STYLE_MAX THEN EXIT SUB
    TEXT_STYLES(idx%).used = TRUE
    IF LEN(RTRIM$(TEXT_STYLES(idx%).name)) = 0 THEN
        TEXT_STYLES(idx%).name = "Style " + _TRIM$(STR$(idx%))
    END IF
    IF TEXT_BAR.selectedFontIdx% >= 0 AND TEXT_BAR.selectedFontIdx% < FONT_LIST_COUNT% THEN
        TEXT_STYLES(idx%).fontName = RTRIM$(FONT_LIST(TEXT_BAR.selectedFontIdx%).displayName)
    END IF
    TEXT_STYLES(idx%).fontSize = TEXT_BAR.selectedSize%
    TEXT_STYLES(idx%).bold = TEXT_BAR.boldActive%
    TEXT_STYLES(idx%).italic = TEXT_BAR.italicActive%
    TEXT_STYLES(idx%).underline = TEXT_BAR.underlineActive%
    TEXT_STYLES(idx%).strike = TEXT_BAR.strikeActive%
    TEXT_STYLES(idx%).mono = TEXT_BAR.monoActive%
    TEXT_STYLES(idx%).lineHeight = TEXT_BAR_get_line_height%
    TEXT_STYLES(idx%).autoLH = TEXT_BAR.autoLineHeight%
    TEXT_STYLES(idx%).charMode = CHARMAP.useChars%
    TEXT_STYLES(idx%).fgColor = PAINT_COLOR~&
    TEXT_STYLES(idx%).bgColor = PAINT_BG_COLOR~&
    TEXT_STYLES(idx%).outline = TEXT_BAR.outlineActive%
    TEXT_STYLES(idx%).outColor = TEXT_BAR.outlineColor~&
    TEXT_STYLES(idx%).outSize = TEXT_BAR.outlineSize%
    TEXT_STYLES(idx%).shadow = TEXT_BAR.shadowActive%
    TEXT_STYLES(idx%).shdColor = TEXT_BAR.shadowColor~&
    TEXT_STYLES(idx%).shdX = TEXT_BAR.shadowOffsetX%
    TEXT_STYLES(idx%).shdY = TEXT_BAR.shadowOffsetY%
    TEXT_STYLES(idx%).antialias = TEXT_BAR.aaActive%
END SUB


''
' Export a single style preset to a .dstyle file.
'
SUB TEXT_STYLE_export (idx AS INTEGER, path AS STRING)
    IF idx% < 1 OR idx% > TEXT_STYLE_MAX THEN EXIT SUB
    IF NOT TEXT_STYLES(idx%).used THEN EXIT SUB
    IF LEN(path$) = 0 THEN EXIT SUB
    DIM fh AS INTEGER
    fh% = FREEFILE
    OPEN path$ FOR OUTPUT AS #fh%
    TEXT_STYLE_write_one fh%, idx%
    CLOSE #fh%
END SUB


''
' Export all style presets to a .dstyle file.
'
SUB TEXT_STYLE_export_all (path AS STRING)
    IF LEN(path$) = 0 THEN EXIT SUB
    DIM fh AS INTEGER
    fh% = FREEFILE
    OPEN path$ FOR OUTPUT AS #fh%
    DIM ei AS INTEGER
    FOR ei% = 1 TO TEXT_STYLE_MAX
        IF TEXT_STYLES(ei%).used THEN TEXT_STYLE_write_one fh%, ei%
    NEXT ei%
    CLOSE #fh%
END SUB


''
' Import styles from a .dstyle file, appending non-duplicate entries.
'
SUB TEXT_STYLE_import (path AS STRING)
    IF LEN(path$) = 0 THEN EXIT SUB
    IF NOT _FILEEXISTS(path$) THEN EXIT SUB

    ' Temporarily load into a scratch array, then merge
    DIM tmpStyles(1 TO TEXT_STYLE_MAX) AS TEXT_STYLE_OBJ
    DIM tmpCount AS INTEGER
    tmpCount% = 0

    DIM fh AS INTEGER
    fh% = FREEFILE
    OPEN path$ FOR INPUT AS #fh%
    DIM curSlot AS INTEGER
    curSlot% = 0
    DIM ln AS STRING, k AS STRING, v AS STRING
    DIM eqPos AS INTEGER

    DO WHILE NOT EOF(fh%)
        LINE INPUT #fh%, ln$
        ln$ = _TRIM$(ln$)
        IF LEN(ln$) = 0 OR LEFT$(ln$, 1) = "#" THEN _CONTINUE

        eqPos% = INSTR(ln$, "=")
        IF eqPos% < 2 THEN _CONTINUE
        k$ = UCASE$(_TRIM$(LEFT$(ln$, eqPos% - 1)))
        v$ = _TRIM$(MID$(ln$, eqPos% + 1))

        IF k$ = "NAME" THEN
            IF curSlot% < TEXT_STYLE_MAX THEN
                curSlot% = curSlot% + 1
                tmpStyles(curSlot%).used = TRUE
                tmpStyles(curSlot%).name = v$
                tmpStyles(curSlot%).fontSize = 8
                tmpStyles(curSlot%).antialias = TRUE
                tmpStyles(curSlot%).fgColor = _RGB32(255, 255, 255)
                tmpStyles(curSlot%).outSize = 1
                tmpStyles(curSlot%).shdX = 2: tmpStyles(curSlot%).shdY = 2
                tmpCount% = curSlot%
            END IF
        ELSEIF curSlot% >= 1 AND curSlot% <= TEXT_STYLE_MAX THEN
            SELECT CASE k$
                CASE "FONT":      tmpStyles(curSlot%).fontName = v$
                CASE "SIZE":      tmpStyles(curSlot%).fontSize = VAL(v$)
                CASE "BOLD":      tmpStyles(curSlot%).bold = VAL(v$)
                CASE "ITALIC":    tmpStyles(curSlot%).italic = VAL(v$)
                CASE "UNDERLINE": tmpStyles(curSlot%).underline = VAL(v$)
                CASE "STRIKE":    tmpStyles(curSlot%).strike = VAL(v$)
                CASE "MONO":      tmpStyles(curSlot%).mono = VAL(v$)
                CASE "LINE_HEIGHT": tmpStyles(curSlot%).lineHeight = VAL(v$)
                CASE "AUTO_LH":   tmpStyles(curSlot%).autoLH = VAL(v$)
                CASE "CHAR_MODE": tmpStyles(curSlot%).charMode = VAL(v$)
                CASE "FG_COLOR":  tmpStyles(curSlot%).fgColor = THEME_parse_rgba~&(v$)
                CASE "BG_COLOR":  tmpStyles(curSlot%).bgColor = THEME_parse_rgba~&(v$)
                CASE "OUTLINE":   tmpStyles(curSlot%).outline = VAL(v$)
                CASE "OUTLINE_COLOR": tmpStyles(curSlot%).outColor = THEME_parse_rgba~&(v$)
                CASE "OUTLINE_SIZE": tmpStyles(curSlot%).outSize = VAL(v$)
                CASE "SHADOW":    tmpStyles(curSlot%).shadow = VAL(v$)
                CASE "SHADOW_COLOR": tmpStyles(curSlot%).shdColor = THEME_parse_rgba~&(v$)
                CASE "SHADOW_X":  tmpStyles(curSlot%).shdX = VAL(v$)
                CASE "SHADOW_Y":  tmpStyles(curSlot%).shdY = VAL(v$)
                CASE "AA":        tmpStyles(curSlot%).antialias = VAL(v$)
            END SELECT
        END IF
    LOOP
    CLOSE #fh%

    ' Merge: append non-duplicate styles
    DIM mi AS INTEGER, mj AS INTEGER
    DIM isDup AS INTEGER
    FOR mi% = 1 TO tmpCount%
        IF NOT tmpStyles(mi%).used THEN _CONTINUE
        isDup% = FALSE
        FOR mj% = 1 TO TEXT_STYLE_MAX
            IF TEXT_STYLES(mj%).used THEN
                IF UCASE$(RTRIM$(TEXT_STYLES(mj%).name)) = UCASE$(RTRIM$(tmpStyles(mi%).name)) THEN
                    isDup% = TRUE
                    EXIT FOR
                END IF
            END IF
        NEXT mj%
        IF NOT isDup% THEN
            ' Find first free slot
            DIM freeSlot AS INTEGER
            freeSlot% = 0
            FOR mj% = 1 TO TEXT_STYLE_MAX
                IF NOT TEXT_STYLES(mj%).used THEN
                    freeSlot% = mj%
                    EXIT FOR
                END IF
            NEXT mj%
            IF freeSlot% >= 1 THEN
                TEXT_STYLES(freeSlot%) = tmpStyles(mi%)
                IF freeSlot% > TEXT_STYLE_COUNT% THEN TEXT_STYLE_COUNT% = freeSlot%
            ELSE
                _LOGWARN "TEXT_STYLE_import: No free style slots, skipping '" + RTRIM$(tmpStyles(mi%).name) + "'"
            END IF
        END IF
    NEXT mi%

    TEXT_STYLE_save_all
    TEXT_BAR.needsRedraw% = TRUE
END SUB


''
' Update hovered row index for each open dropdown based on raw mouse coords.
' Plays SND_MENU_HOVER when the hovered row changes.
' Call from MOUSE_handle_gui_panels every frame while TEXT_BAR is visible.
'
SUB TEXT_BAR_update_dropdown_hover (rawX AS INTEGER, rawY AS INTEGER)
    DIM itemH AS INTEGER
    itemH% = 12

    ' --- Font dropdown ---
    IF TEXT_BAR.fontDropdownOpen% THEN
        DIM fdX AS INTEGER, fdY AS INTEGER, fdW AS INTEGER
        DIM fdMaxVisible AS INTEGER
        fdX% = TEXT_BAR.fontBtnX%
        fdY% = TEXT_BAR.barY% + THEME.TEXT_BAR_ROW_HEIGHT%
        fdW% = 160
        fdMaxVisible% = TEXT_BAR_font_dropdown_max_visible%
        IF rawX% >= fdX% AND rawX% < fdX% + fdW% AND rawY% >= fdY% THEN
            DIM fdRow AS INTEGER
            fdRow% = (rawY% - fdY% - 1) \ itemH%
            IF fdRow% >= 0 AND fdRow% < fdMaxVisible% THEN
                DIM fdActual AS INTEGER
                fdActual% = TEXT_BAR.fontDropdownScroll% + fdRow%
                IF fdActual% >= 0 AND fdActual% < FONT_LIST_COUNT% THEN
                    IF fdActual% <> TEXT_BAR.fontDropdownHoverRow% THEN
                        TEXT_BAR.fontDropdownHoverRow% = fdActual%
                        SOUND_play SND_MENU_HOVER
                        TEXT_BAR.needsRedraw% = TRUE
                        GUI_NEEDS_REDRAW% = TRUE
                        FRAME_IDLE% = FALSE
                    END IF
                ELSE
                    TEXT_BAR.fontDropdownHoverRow% = -1
                END IF
            ELSE
                TEXT_BAR.fontDropdownHoverRow% = -1
            END IF
        ELSE
            TEXT_BAR.fontDropdownHoverRow% = -1
        END IF
    ELSE
        TEXT_BAR.fontDropdownHoverRow% = -1
    END IF

    ' --- Size dropdown ---
    IF TEXT_BAR.sizeDropdownOpen% THEN
        DIM sdX AS INTEGER, sdY AS INTEGER, sdW2 AS INTEGER
        sdX% = TEXT_BAR.sizeBtnX%
        sdY% = TEXT_BAR.barY% + THEME.TEXT_BAR_ROW_HEIGHT%
        sdW2% = 40
        IF rawX% >= sdX% AND rawX% < sdX% + sdW2% AND rawY% >= sdY% THEN
            DIM sdRow AS INTEGER
            sdRow% = (rawY% - sdY% - 1) \ itemH%
            IF sdRow% >= 0 AND sdRow% < TEXT_BAR_SIZE_COUNT THEN
                IF sdRow% <> TEXT_BAR.sizeDropdownHoverRow% THEN
                    TEXT_BAR.sizeDropdownHoverRow% = sdRow%
                    SOUND_play SND_MENU_HOVER
                    TEXT_BAR.needsRedraw% = TRUE
                    GUI_NEEDS_REDRAW% = TRUE
                    FRAME_IDLE% = FALSE
                END IF
            ELSE
                TEXT_BAR.sizeDropdownHoverRow% = -1
            END IF
        ELSE
            TEXT_BAR.sizeDropdownHoverRow% = -1
        END IF
    ELSE
        TEXT_BAR.sizeDropdownHoverRow% = -1
    END IF

    ' --- Style dropdown ---
    IF TEXT_BAR.styleDropdownOpen% THEN
        DIM stX AS INTEGER, stY AS INTEGER, stW AS INTEGER
        DIM stHasDivider AS INTEGER
        stX% = TEXT_BAR.styleDDBtnX%
        stY% = TEXT_BAR.barY% + THEME.TEXT_BAR_ROW_HEIGHT% * 2
        stW% = 120
        IF TEXT_STYLE_COUNT% > 0 THEN stHasDivider% = 1 ELSE stHasDivider% = 0
        DIM stTotalRows AS INTEGER
        stTotalRows% = 1 + stHasDivider% + TEXT_STYLE_COUNT%  ' Default + optional divider + user styles
        DIM stTotalH AS INTEGER
        stTotalH% = stTotalRows% * itemH% + 2
        IF rawX% >= stX% AND rawX% < stX% + stW% AND rawY% >= stY% AND rawY% < stY% + stTotalH% THEN
            DIM stRow AS INTEGER
            stRow% = (rawY% - stY% - 1) \ itemH%
            ' Skip divider row
            DIM stIsDivider AS INTEGER
            stIsDivider% = stHasDivider% AND stRow% = 1
            IF stRow% >= 0 AND stRow% < stTotalRows% AND NOT stIsDivider% THEN
                IF stRow% <> TEXT_BAR.styleDropdownHoverRow% THEN
                    TEXT_BAR.styleDropdownHoverRow% = stRow%
                    SOUND_play SND_MENU_HOVER
                    TEXT_BAR.needsRedraw% = TRUE
                    GUI_NEEDS_REDRAW% = TRUE
                    FRAME_IDLE% = FALSE
                END IF
            ELSE
                TEXT_BAR.styleDropdownHoverRow% = -1
            END IF
        ELSE
            TEXT_BAR.styleDropdownHoverRow% = -1
        END IF
    ELSE
        TEXT_BAR.styleDropdownHoverRow% = -1
    END IF
END SUB
