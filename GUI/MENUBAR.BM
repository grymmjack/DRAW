    MENUBAR_register_item "MUSIC VOL UP",     "", 10, 422, FALSE, FALSE
    MENUBAR_register_item "MUSIC VOL DOWN",   "", 10, 423, FALSE, FALSE
    MENUBAR_register_item "MUSIC MUTE",       "", 10, 424, TRUE,  FALSE
    MENUBAR_register_item "---", "", 10, 0, FALSE, TRUE
    MENUBAR_register_item "RANDOM TRACK",     CHR$(16), 10, 433, FALSE, FALSE
    MENUBAR_register_item "NEXT TRACK",       "}", 10, 427, FALSE, FALSE
    MENUBAR_register_item "PREV TRACK",       "{", 10, 428, FALSE, FALSE
    MENUBAR_register_item "---", "", 10, 0, FALSE, TRUE
    MENUBAR_register_item "EXPLORE MUSIC...", "", 10, 425, FALSE, FALSE
    MENUBAR_register_item "---", "", 10, 0, FALSE, TRUE
    MENUBAR_register_item "NOT PLAYING",      "", 10, 426, FALSE, FALSE
END SUB


''
' Update menu bar geometry based on visible panels and toolbar
'
SUB MENUBAR_update_bar_geometry ()
    MENU_BAR.barY% = 0
    MENU_BAR.barH% = MENU_BAR_HEIGHT

    ' Calculate X position and width — spans over editbar column
    ' SCRN.menuBarLeftEdge% = after layers+toolbox, before editbar
    ' SCRN.menuBarRightEdge% = before layers+toolbox, before editbar
    MENU_BAR.barX% = SCRN.menuBarLeftEdge%
    MENU_BAR.barW% = SCRN.menuBarRightEdge% - SCRN.menuBarLeftEdge% + 1

    IF MENU_BAR.barW% < 40 THEN MENU_BAR.barW% = 40 ' Minimum width

    ' Precompute root label X positions (first pass: all items, no overflow)
    DIM oldDest AS LONG, oldFont AS LONG
    DIM x       AS INTEGER, i AS INTEGER, lbl AS STRING, pw AS INTEGER

    oldDest& = _DEST
    oldFont& = _FONT
    IF MENU_BAR.fontHandle& > 0 THEN _FONT MENU_BAR.fontHandle&

    x% = MENU_BAR.barX% + MENU_PAD_LEFT

    ' Measure all non-HELP items first
    DIM helpIdx AS INTEGER
    helpIdx% = MENU_ROOT_COUNT% - 1                     ' HELP is always last

    FOR i% = 0 TO helpIdx% - 1
        lbl$            = RTRIM$(MENU_ROOT_LABEL(i%))
        pw%             = _PRINTWIDTH(lbl$)
        MENU_ROOT_X(i%) = x%
        MENU_ROOT_W(i%) = pw% + MENU_ROOT_GAP
        x% = x% + pw% + MENU_ROOT_GAP
    NEXT i%

    ' Measure HELP (right-justified)
    lbl$ = RTRIM$(MENU_ROOT_LABEL(helpIdx%))
    pw%  = _PRINTWIDTH(lbl$)
    DIM helpW AS INTEGER
    helpW%                = pw% + MENU_PAD_RIGHT
    MENU_ROOT_X(helpIdx%) = MENU_BAR.barX% + MENU_BAR.barW% - pw% - MENU_PAD_RIGHT
    MENU_ROOT_W(helpIdx%) = helpW%

    ' Check overflow: does the last non-HELP item's right edge exceed the
    ' right-justified HELP label's left edge (with a small gap)?
    DIM chevronLbl AS STRING, chevronW AS INTEGER
    DIM barRight   AS INTEGER
    chevronLbl$ = ">>"
    chevronW%   = _PRINTWIDTH(chevronLbl$) + MENU_ROOT_GAP + 2
    barRight%   = MENU_ROOT_X(helpIdx%) - MENU_ROOT_GAP ' Space before HELP

    ' Determine how many non-HELP items fit before the chevron
    DIM lastFitIdx AS INTEGER
    lastFitIdx% = helpIdx% - 1                          ' Assume all fit

    IF helpIdx% > 0 THEN
        ' Check if the rightmost non-HELP item overflows
        DIM rightEdge AS INTEGER
        rightEdge% = MENU_ROOT_X(lastFitIdx%) + MENU_ROOT_W(lastFitIdx%)
        IF rightEdge% > barRight% THEN
            ' Need overflow — find how many items fit  before chevron
            ' Reserve space for the chevron button
            DIM fitLimit AS INTEGER
            fitLimit%   = barRight% - chevronW%
            lastFitIdx% = -1
            FOR i% = 0 TO helpIdx% - 1
                IF (MENU_ROOT_X(i%) + MENU_ROOT_W(i%)) <= fitLimit% THEN
                    lastFitIdx% = i%
                ELSE
                    EXIT FOR
                END IF
            NEXT i%
            IF lastFitIdx% < 0 THEN lastFitIdx% = 0 ' At least 1 item visible
        END IF
    END IF

    ' Set overflow state
    MENU_VISIBLE_COUNT% = lastFitIdx% + 1               ' Number of non-HELP items visible
    IF MENU_VISIBLE_COUNT% < helpIdx% THEN
        ' Overflow exists
        MENU_CHEVRON_ACTIVE% = TRUE
        ' Position chevron right after the last visible item
        MENU_CHEVRON_X% = MENU_ROOT_X(lastFitIdx%) + MENU_ROOT_W(lastFitIdx%) + 2
        MENU_CHEVRON_W% = chevronW%
    ELSE
        MENU_CHEVRON_ACTIVE% = FALSE
        MENU_OVERFLOW_OPEN%  = FALSE
    END IF

    _FONT oldFont&
END SUB


''
' Sync checkbox states from live application state
'
SUB MENUBAR_update_checkboxes ()
    DIM i AS INTEGER

    ' Update root menu enabled states
    FOR i% = 0 TO MENU_ROOT_COUNT% - 1
        MENU_ROOT_ENABLED(i%) = TRUE ' Most roots are always enabled
    NEXT i%
    ' Brush root (index 5) always enabled so users can discover submenu
    MENU_ROOT_ENABLED(5) = TRUE

    FOR i% = 0 TO MENU_ITEM_COUNT% - 1
        ' Update checkbox states
        IF MENU_ITEMS(i%).hasCheckbox% THEN
            SELECT CASE MENU_ITEMS(i%).actionId%
                CASE 411  ' Menu Bar
                    MENU_ITEMS(i%).checked% = MENU_BAR.visible%
                CASE 404  ' Layer Panel
                    MENU_ITEMS(i%).checked% = LAYER_PANEL.visible%
                CASE 401  ' Toolbox
                    MENU_ITEMS(i%).checked% = SCRN.showToolbar%
                CASE 402  ' Color Strip/Status
                    MENU_ITEMS(i%).checked% = SCRN.showStatus%
                CASE 434  ' Preview Window
                    MENU_ITEMS(i%).checked% = PREVIEW.visible%
                CASE 435  ' Edit Bar
                    MENU_ITEMS(i%).checked% = SCRN.showEditBar%
                CASE 449  ' Advanced Bar
                    MENU_ITEMS(i%).checked% = SCRN.showAdvBar%
                CASE 2050 ' Character Map
                    MENU_ITEMS(i%).checked% = SCRN.showCharMap%
                CASE 2021 ' Color Mixer
                    MENU_ITEMS(i%).checked% = COLORMIXER.visible%
                CASE 2022 ' Browser
                    MENU_ITEMS(i%).checked% = BROWSER.visible%
                CASE 2053 ' Char Grid
                    MENU_ITEMS(i%).checked% = CHARMAP.charGridShow%
                CASE 2054 ' Snap to Char Grid
                    MENU_ITEMS(i%).checked% = CHARMAP.charGridSnap%
                CASE 440  ' Pattern Tile Mode
                    MENU_ITEMS(i%).checked% = SCRN.patternTileMode%
                CASE 901  ' Grid
                    MENU_ITEMS(i%).checked% = GRID.SHOW%
                CASE 903  ' Snap to Grid
                    MENU_ITEMS(i%).checked% = GRID.SNAP%
                CASE 906  ' Grid Tile Mode (ON = center/tiling, OFF = corner/lines)
                    MENU_ITEMS(i%).checked% = (GRID.ALIGN_MODE% = GRID_ALIGN_CENTER)
                CASE 908  ' Grid Cell Fill
                    MENU_ITEMS(i%).checked% = GRID.CELL_FILL%
                CASE 909  ' Fill Adjustment Mode
                    MENU_ITEMS(i%).checked% = FILL_ADJ.ENABLED%
                CASE 902  ' Pixel Grid
                    MENU_ITEMS(i%).checked% = PIXEL_GRID.SHOW%
                CASE 910  ' Smart Guides
                    MENU_ITEMS(i%).checked% = SMART_GUIDES.ENABLED%
                CASE 911  ' Snap Smart Guides
                    MENU_ITEMS(i%).checked% = SMART_GUIDES.SNAP%
                CASE 332  ' Hide Selection (checkmark = currently hidden)
                    MENU_ITEMS(i%).checked% = NOT MARQUEE.SHOW_OVERLAY%
                CASE 412  ' Cursors
                    MENU_ITEMS(i%).checked% = NOT POINTER.HIDDEN
                CASE 1103 ' Recolor Mode (Brush + Pattern)
                    DIM recolorEnabled AS INTEGER
                    recolorEnabled%                  = (CUSTOM_BRUSH_is_active% AND DRAWER.mode% = DRAWER_MODE_BRUSH) OR _
                                       (DRAWER.mode% = DRAWER_MODE_PATTERN AND DRAWER.patternSelected% > 0)
                    MENU_ITEMS(i%).checked%          = recolorEnabled% AND CUSTOM_BRUSH.RECOLOR_MODE
                CASE 609  ' Pixel Perfect Mode
                    MENU_ITEMS(i%).checked% = BRUSH_SIZE.PIXEL_PERFECT
                CASE 1501 ' Reference Image toggle
                    MENU_ITEMS(i%).checked% = REFIMG.VISIBLE AND (REFIMG.IMAGE < -1)
                CASE 414  ' Angle Snap: Degrees
                    MENU_ITEMS(i%).checked% = NOT CFG.ANGLE_SNAP_PIXEL_ART%
                    ' Update label dynamically to show current degree value
                    MENU_ITEMS(i%).label$ = "ANGLE SNAP: " + _TRIM$(STR$(CFG.ANGLE_SNAP_DEGREES%)) + CHR$(248)
                CASE 415  ' Angle Snap: Pixel Art
                    MENU_ITEMS(i%).checked% = CFG.ANGLE_SNAP_PIXEL_ART%
                CASE 417  ' Sound FX toggle
                    MENU_ITEMS(i%).checked% = CFG.SOUNDS_ENABLED%
                CASE 420  ' Music toggle
                    MENU_ITEMS(i%).checked% = CFG.MUSIC_ENABLED%
                CASE 421  ' SFX Mute
                    MENU_ITEMS(i%).checked% = CFG.SOUNDS_MUTED%
                CASE 424  ' Music Mute
                    MENU_ITEMS(i%).checked% = CFG.MUSIC_MUTED%
                CASE 1517 ' Show Lospec palettes in picker
                    MENU_ITEMS(i%).checked% = CFG.PALETTE_SHOW_LOSPEC%
                CASE 1518 ' Show Created palettes in picker
                    MENU_ITEMS(i%).checked% = CFG.PALETTE_SHOW_CREATED%
                CASE 603  ' Drawing Mode: Color
                    MENU_ITEMS(i%).checked% = (DRAWER.mode% = DRAWER_MODE_BRUSH)
                CASE 604  ' Drawing Mode: Gradients
                    MENU_ITEMS(i%).checked% = (DRAWER.mode% = DRAWER_MODE_GRADIENT)
                CASE 605  ' Drawing Mode: Patterns
                    MENU_ITEMS(i%).checked% = (DRAWER.mode% = DRAWER_MODE_PATTERN)
                CASE 1608 ' Show Tooltips
                    MENU_ITEMS(i%).checked% = NOT CFG.TOOLTIPS_DISABLED%
            END SELECT
        END IF

        ' Update enabled states for context-sensitive items
        ' Edit operations are always enabled — they operate on the active
        ' selection if one exists, or on the entire current layer otherwise.
        SELECT CASE MENU_ITEMS(i%).actionId%
            CASE 301                                                  ' Undo
                MENU_ITEMS(i%).enabled% = HISTORY_can_undo%
            CASE 302                                                  ' Redo
                MENU_ITEMS(i%).enabled% = HISTORY_can_redo%
            CASE 305, 312                                             ' Paste, Paste in Place
                MENU_ITEMS(i%).enabled% = CLIPBOARD.VALID
            CASE 2058                                                 ' New from Clipboard
                ' _CLIPBOARDIMAGE is expensive (decodes full image from OS clipboard every call).
                ' Cache the result; only re-check when the menu is open or every ~60 frames.
                STATIC ncbCacheValid  AS INTEGER
                STATIC ncbCacheResult AS INTEGER
                STATIC ncbFrameCount  AS INTEGER
                ncbFrameCount% = ncbFrameCount% + 1
                IF MENU_BAR.openMenu% >= 0 OR ncbFrameCount% >= 60 OR NOT ncbCacheValid% THEN
                    ncbFrameCount% = 0
                    ncbCacheValid% = TRUE
                    DIM ncbChk AS LONG
                    ncbChk&         = _CLIPBOARDIMAGE
                    ncbCacheResult% = (ncbChk& < -1)
                    IF ncbChk& < -1 THEN _FREEIMAGE ncbChk&
                END IF
                MENU_ITEMS(i%).enabled% = ncbCacheResult%
            CASE 207                                                  ' Revert
                MENU_ITEMS(i%).enabled% = (CURRENT_DRW_FILENAME$ <> "" OR CURRENT_FILENAME$ <> "")
            CASE 213                                                  ' Recent
                MENU_ITEMS(i%).enabled% = (RECENT_FILE_COUNT% > 0)
            CASE 1704                                                 ' Code (not yet implemented)
                MENU_ITEMS(i%).enabled% = FALSE
            CASE 1110                                                 ' Export Brush
                MENU_ITEMS(i%).enabled% = CUSTOM_BRUSH_is_active%
            CASE 1103                                                 ' Recolor — works for brush AND pattern
                MENU_ITEMS(i%).enabled% = CUSTOM_BRUSH_is_active% OR _
                    (DRAWER.mode%       = DRAWER_MODE_PATTERN AND DRAWER.patternSelected% > 0)
            CASE 1102, 1104, 1105, 1106, 1107, 1108, 1109, 1111, 1112 ' Brush operations
                MENU_ITEMS(i%).enabled% = CUSTOM_BRUSH_is_active%
            CASE 418                                                  ' SFX Vol Up
                MENU_ITEMS(i%).enabled% = CFG.SOUNDS_ENABLED% AND (NOT CFG.SOUNDS_MUTED%) AND (CFG.SOUNDS_VOLUME% < 100)
                MENU_ITEMS(i%).label$   = "SFX VOL UP (" + _TRIM$(STR$(CFG.SOUNDS_VOLUME%)) + "%)"
            CASE 419                                                  ' SFX Vol Down
                MENU_ITEMS(i%).enabled% = CFG.SOUNDS_ENABLED% AND (NOT CFG.SOUNDS_MUTED%) AND (CFG.SOUNDS_VOLUME% > 0)
                MENU_ITEMS(i%).label$   = "SFX VOL DOWN (" + _TRIM$(STR$(CFG.SOUNDS_VOLUME%)) + "%)"
            CASE 421                                                  ' SFX Mute
                MENU_ITEMS(i%).enabled% = CFG.SOUNDS_ENABLED%
            CASE 422                                                  ' Music Vol Up
                MENU_ITEMS(i%).enabled% = CFG.MUSIC_ENABLED% AND (NOT CFG.MUSIC_MUTED%) AND (CFG.MUSIC_VOLUME% < 100)
                MENU_ITEMS(i%).label$   = "MUSIC VOL UP (" + _TRIM$(STR$(CFG.MUSIC_VOLUME%)) + "%)"
            CASE 423                                                  ' Music Vol Down
                MENU_ITEMS(i%).enabled% = CFG.MUSIC_ENABLED% AND (NOT CFG.MUSIC_MUTED%) AND (CFG.MUSIC_VOLUME% > 0)
                MENU_ITEMS(i%).label$   = "MUSIC VOL DOWN (" + _TRIM$(STR$(CFG.MUSIC_VOLUME%)) + "%)"
            CASE 424                                                  ' Music Mute
                MENU_ITEMS(i%).enabled% = CFG.MUSIC_ENABLED%
            CASE 427, 428, 433                                        ' Next Track, Prev Track, Random Track
                MENU_ITEMS(i%).enabled% = CFG.MUSIC_ENABLED%
            CASE 425                                                  ' Explore Music Folder
                MENU_ITEMS(i%).enabled% = TRUE
            CASE 426                                                  ' Now Playing display
                MENU_ITEMS(i%).enabled% = FALSE
                DIM nowPlayName AS STRING
                DIM dotPosNP    AS INTEGER
                DIM npCharI     AS INTEGER
                DIM nowPlayExt  AS STRING
                IF MUSIC_CURRENT_FILE$ <> "" THEN
                    nowPlayName$ = MUSIC_CURRENT_FILE$
                    dotPosNP%    = 0
                    FOR npCharI% = LEN(nowPlayName$) TO 1 STEP -1
                        IF MID$(nowPlayName$, npCharI%, 1) = "." THEN dotPosNP% = npCharI%: EXIT FOR
                    NEXT npCharI%
                    IF dotPosNP% > 0 THEN
                        nowPlayExt$  = UCASE$(MID$(nowPlayName$, dotPosNP% + 1))
                        nowPlayName$ = LEFT$(nowPlayName$, dotPosNP% - 1)
                    ELSE
                        nowPlayExt$ = ""
                    END IF
                    IF LEN(nowPlayName$) > 32 THEN nowPlayName$ = LEFT$(nowPlayName$, 31) + "~"
                    IF nowPlayExt$ <> "" THEN
                        MENU_ITEMS(i%).label$ = "NOW: " + nowPlayName$ + " [" + nowPlayExt$ + "]"
                    ELSE
                        MENU_ITEMS(i%).label$ = "NOW: " + nowPlayName$
                    END IF
                ELSE
                    MENU_ITEMS(i%).label$ = "NOT PLAYING"
                END IF
            CASE 307                                                  ' Select None / Deselect
                MENU_ITEMS(i%).enabled% = SELECTION_has_active%
            CASE 311                                                  ' Invert Selection
                MENU_ITEMS(i%).enabled% = SELECTION_has_active%
            CASE 332                                                  ' Hide Selection
                MENU_ITEMS(i%).enabled% = SELECTION_has_active%
            CASE 1410, 1411, 1412, 1413                               ' Expand/Contract Selection
                MENU_ITEMS(i%).enabled% = SELECTION_has_active%
            CASE 324                                                  ' Stroke Selection
                MENU_ITEMS(i%).enabled% = SELECTION_has_active%
            CASE 1907, 1908                                           ' Distribute layers — require 2+ selected
                MENU_ITEMS(i%).enabled% = (MULTI_SELECT_COUNT% > 1)
            CASE 711, 1414                                            ' Merge Selected / From Selected Layers — require 2+ selected
                MENU_ITEMS(i%).enabled% = (MULTI_SELECT_COUNT% > 1)
            CASE 440                                                  ' Pattern Tile Mode — only when canvas <= 512x512
                MENU_ITEMS(i%).enabled% = SCREEN_pattern_tile_allowed%
        END SELECT
    NEXT i%
END SUB


''
' Render the menu bar to SCRN.GUI&
'
SUB MENUBAR_render ()
    IF NOT MENU_BAR.visible% THEN EXIT SUB

    DIM oldDest AS LONG, oldFont AS LONG
    DIM i       AS INTEGER, lbl AS STRING
    DIM bg      AS _UNSIGNED LONG, fg AS _UNSIGNED LONG
    DIM selBg   AS _UNSIGNED LONG, selFg AS _UNSIGNED LONG

    oldDest& = _DEST
    _DEST SCRN.GUI&
    oldFont& = _FONT
    IF MENU_BAR.fontHandle& > 0 THEN _FONT MENU_BAR.fontHandle&, SCRN.GUI&

    ' Recalculate positions
    MENUBAR_update_bar_geometry
    MENUBAR_update_checkboxes

    ' Get theme colors
    bg~&    = THEME.MENU_BAR_bg~&
    fg~&    = THEME.MENU_BAR_fg~&
    selBg~& = THEME.MENU_BAR_sel_bg~&
    selFg~& = THEME.MENU_BAR_sel_fg~&

    ' Draw menu bar background
    LINE (MENU_BAR.barX%, MENU_BAR.barY%)-(MENU_BAR.barX% + MENU_BAR.barW% - 1, MENU_BAR.barY% + MENU_BAR.barH% - 1), bg~&, BF

    ' Draw bottom border
    LINE (MENU_BAR.barX%, MENU_BAR.barY% + MENU_BAR.barH% - 1)-(MENU_BAR.barX% + MENU_BAR.barW% - 1, MENU_BAR.barY% + MENU_BAR.barH% - 1), THEME.MENU_BAR_border~&

    ' Draw root labels
    DIM helpIdx2 AS INTEGER
    helpIdx2% = MENU_ROOT_COUNT% - 1

    FOR i% = 0 TO MENU_ROOT_COUNT% - 1
        ' Skip overflow items (except HELP which is always visible)
        IF MENU_CHEVRON_ACTIVE% AND i% >= MENU_VISIBLE_COUNT% AND i% <> helpIdx2% THEN
            GOTO MENUBAR_render_skip_root
        END IF

        lbl$ = RTRIM$(MENU_ROOT_LABEL(i%))

        IF NOT MENU_ROOT_ENABLED(i%) THEN
            ' Disabled state - dimmed text
            COLOR THEME.MENU_BAR_disabled_fg~&, _RGBA32(0, 0, 0, 0)
        ELSEIF i% = MENU_BAR.openMenu% OR i% = MENU_BAR.hoverRoot% THEN
            ' Highlighted state
            LINE (MENU_ROOT_X(i%) - 2, MENU_BAR.barY%)-(MENU_ROOT_X(i%) + _PRINTWIDTH(lbl$) + 1, MENU_BAR.barY% + MENU_BAR.barH% - 2), selBg~&, BF
            COLOR selFg~&, _RGBA32(0, 0, 0, 0)
        ELSE
            ' Normal state
            COLOR fg~&, _RGBA32(0, 0, 0, 0)
        END IF

        _UPRINTSTRING (MENU_ROOT_X(i%), MENU_BAR.barY% + 2), lbl$
        MENUBAR_render_skip_root:
    NEXT i%

    ' Draw overflow chevron >> if active
    IF MENU_CHEVRON_ACTIVE% THEN
        DIM chevLbl AS STRING
        chevLbl$ = ">>"
        IF MENU_OVERFLOW_OPEN% OR MENU_OVERFLOW_HOVER% >= 0 THEN
            LINE (MENU_CHEVRON_X% - 2, MENU_BAR.barY%)-(MENU_CHEVRON_X% + _PRINTWIDTH(chevLbl$) + 1, MENU_BAR.barY% + MENU_BAR.barH% - 2), selBg~&, BF
            COLOR selFg~&, _RGBA32(0, 0, 0, 0)
        ELSE
            COLOR fg~&, _RGBA32(0, 0, 0, 0)
        END IF
        _UPRINTSTRING (MENU_CHEVRON_X%, MENU_BAR.barY% + 2), chevLbl$
    END IF

    ' Draw open submenu if any
    IF MENU_BAR.openMenu% >= 0 AND MENU_BAR.openMenu% < MENU_ROOT_COUNT% THEN
        MENUBAR_render_submenu MENU_BAR.openMenu%
    END IF

    ' Draw overflow popup if open
    IF MENU_OVERFLOW_OPEN% AND MENU_CHEVRON_ACTIVE% THEN
        MENUBAR_render_overflow_popup
    END IF

    _FONT oldFont&
    _DEST oldDest&
END SUB


''
' Render a dropdown submenu for a given root menu
' @param rootIdx INTEGER Index of the root menu whose submenu to render
'
SUB MENUBAR_render_submenu (rootIdx AS INTEGER)
    DIM i         AS INTEGER, childCount AS INTEGER
    DIM maxLabelW AS INTEGER, maxHotkeyW AS INTEGER
    DIM lbl       AS STRING, hk AS STRING
    DIM subBg     AS _UNSIGNED LONG, subFg AS _UNSIGNED LONG
    DIM subBorder AS _UNSIGNED LONG, subDivider AS _UNSIGNED LONG
    DIM subSelBg  AS _UNSIGNED LONG, subSelFg AS _UNSIGNED LONG
    DIM totalH    AS INTEGER, itemY AS INTEGER, childIdx AS INTEGER
    DIM checkStr  AS STRING

    ' Get theme colors
    subBg~&      = THEME.MENU_SUB_bg~&
    subFg~&      = THEME.MENU_SUB_fg~&
    subBorder~&  = THEME.MENU_SUB_border~&
    subDivider~& = THEME.MENU_SUB_divider~&
    subSelBg~&   = THEME.MENU_SUB_sel_bg~&
    subSelFg~&   = THEME.MENU_SUB_sel_fg~&

    ' Count children and measure max widths
    childCount% = 0
    maxLabelW%  = 0
    maxHotkeyW% = 0
    totalH%     = 4 ' Top/bottom padding

    FOR i% = 0 TO MENU_ITEM_COUNT% - 1
        IF MENU_ITEMS(i%).parentIdx% = rootIdx% THEN
            childCount% = childCount% + 1
            IF MENU_ITEMS(i%).isDivider% THEN
                totalH% = totalH% + MENU_DIVIDER_HEIGHT
            ELSE
                totalH% = totalH% + MENU_ITEM_HEIGHT
                lbl$ = RTRIM$(MENU_ITEMS(i%).label)
                hk$  = RTRIM$(MENU_ITEMS(i%).hotkey)
                DIM lw AS INTEGER, hw AS INTEGER
                lw% = _PRINTWIDTH(lbl$)
                hw% = _PRINTWIDTH(hk$)
                IF lw% > maxLabelW% THEN maxLabelW% = lw%
                IF hw% > maxHotkeyW% THEN maxHotkeyW% = hw%
            END IF
        END IF
    NEXT i%

    MENU_BAR.subItemCount% = childCount%

    ' Calculate submenu dimensions
    DIM subW AS INTEGER
    subW% = MENU_SUB_PAD_LEFT + maxLabelW% + MENU_SUB_HOTKEY_GAP + maxHotkeyW% + MENU_SUB_PAD_RIGHT
    IF subW% < 80 THEN subW% = 80 ' Minimum width

    ' Position submenu below the root label
    MENU_BAR.subX% = MENU_ROOT_X(rootIdx%) - 2
    MENU_BAR.subY% = MENU_BAR.barY% + MENU_BAR.barH%
    MENU_BAR.subW% = subW%

    ' Clamp: left edge must not go past menu bar left edge
    IF MENU_BAR.subX% < MENU_BAR.barX% THEN
        MENU_BAR.subX% = MENU_BAR.barX%
    END IF

    ' Clamp: right edge must not go past menu bar right edge (avoid toolbar overlap)
    DIM menuBarRight AS INTEGER
    menuBarRight% = MENU_BAR.barX% + MENU_BAR.barW%
    IF MENU_BAR.subX% + MENU_BAR.subW% > menuBarRight% THEN
        MENU_BAR.subX% = menuBarRight% - MENU_BAR.subW%
    END IF
    IF MENU_BAR.subX% < MENU_BAR.barX% THEN MENU_BAR.subX% = MENU_BAR.barX%

    ' Determine scrollable region
    DIM availH AS INTEGER, maxScroll AS INTEGER
    availH% = SCRN.h& - MENU_BAR.subY%
    IF availH% < MENU_ITEM_HEIGHT * 2 THEN availH% = MENU_ITEM_HEIGHT * 2
    IF totalH% > availH% THEN
        MENU_BAR.subH% = availH%
    ELSE
        MENU_BAR.subH% = totalH%
    END IF
    maxScroll% = totalH% - MENU_BAR.subH%
    IF maxScroll% < 0 THEN maxScroll% = 0
    MENU_BAR.subScrollMax% = maxScroll%
    IF MENU_BAR.subScroll% > maxScroll% THEN MENU_BAR.subScroll% = maxScroll%
    IF MENU_BAR.subScroll% < 0 THEN MENU_BAR.subScroll% = 0

    ' Scroll arrows take 1 row of space when active
    DIM scrollArrowH AS INTEGER
    scrollArrowH% = MENU_ITEM_HEIGHT
    DIM canScrollUp  AS INTEGER, canScrollDn AS INTEGER
    canScrollUp% = (MENU_BAR.subScroll% > 0)
    canScrollDn% = (MENU_BAR.subScroll% < maxScroll%)
    DIM viewportTop  AS INTEGER, viewportBot AS INTEGER
    viewportTop% = MENU_BAR.subY% + 2
    viewportBot% = MENU_BAR.subY% + MENU_BAR.subH% - 2
    IF canScrollUp% THEN viewportTop% = viewportTop% + scrollArrowH%
    IF canScrollDn% THEN viewportBot% = viewportBot% - scrollArrowH%

    ' Draw submenu border
    LINE (MENU_BAR.subX% - 1, MENU_BAR.subY% - 1)-(MENU_BAR.subX% + MENU_BAR.subW%, MENU_BAR.subY% + MENU_BAR.subH%), subBorder~&, BF

    ' Draw submenu background
    LINE (MENU_BAR.subX%, MENU_BAR.subY%)-(MENU_BAR.subX% + MENU_BAR.subW% - 1, MENU_BAR.subY% + MENU_BAR.subH% - 1), subBg~&, BF

    ' Draw up scroll arrow if needed
    IF canScrollUp% THEN
        LINE (MENU_BAR.subX% + 1, MENU_BAR.subY% + 1)-(MENU_BAR.subX% + MENU_BAR.subW% - 2, MENU_BAR.subY% + scrollArrowH%), subBg~&, BF
        COLOR subFg~&, _RGBA32(0, 0, 0, 0)
        DIM arrowUpX AS INTEGER
        arrowUpX% = MENU_BAR.subX% + (MENU_BAR.subW% \ 2) - (_PRINTWIDTH(CHR$(24)) \ 2)
        _UPRINTSTRING (arrowUpX%, MENU_BAR.subY% + 2), CHR$(24)
    END IF

    ' Draw menu items using virtual-Y scrolling
    DIM virtualY AS INTEGER
    virtualY% = 2   ' virtual offset from subY (content-space)
    childIdx% = 0

    FOR i% = 0 TO MENU_ITEM_COUNT% - 1
        IF MENU_ITEMS(i%).parentIdx% <> rootIdx% THEN GOTO MENUBAR_render_next_item

        DIM itemH AS INTEGER
        IF MENU_ITEMS(i%).isDivider% THEN
            itemH% = MENU_DIVIDER_HEIGHT
        ELSE
            itemH% = MENU_ITEM_HEIGHT
        END IF

        ' Compute screen Y from virtual Y and scroll offset
        itemY% = MENU_BAR.subY% + virtualY% - MENU_BAR.subScroll%

        ' Adjust for scroll arrow area at top
        IF canScrollUp% THEN itemY% = itemY% + scrollArrowH%

        ' Skip if out of visible viewport
        IF itemY% + itemH% <= viewportTop% OR itemY% >= viewportBot% THEN
            virtualY% = virtualY% + itemH%
            childIdx% = childIdx% + 1
            GOTO MENUBAR_render_next_item
        END IF

        IF MENU_ITEMS(i%).isDivider% THEN
            DIM divY AS INTEGER
            divY% = itemY% + MENU_DIVIDER_HEIGHT \ 2
            LINE (MENU_BAR.subX% + 4, divY%)-(MENU_BAR.subX% + MENU_BAR.subW% - 5, divY%), subDivider~&
            virtualY% = virtualY% + MENU_DIVIDER_HEIGHT
            childIdx% = childIdx% + 1
            GOTO MENUBAR_render_next_item
        END IF

        ' Draw highlight or normal background (skip highlight for disabled items)
        IF childIdx% = MENU_BAR.hoverSub% AND MENU_ITEMS(i%).enabled% THEN
            LINE (MENU_BAR.subX% + 1, itemY%)-(MENU_BAR.subX% + MENU_BAR.subW% - 2, itemY% + MENU_ITEM_HEIGHT - 1), subSelBg~&, BF
            COLOR subSelFg~&, _RGBA32(0, 0, 0, 0)
        ELSE
            IF MENU_ITEMS(i%).enabled% THEN
                COLOR subFg~&, _RGBA32(0, 0, 0, 0)
            ELSE
                COLOR THEME.MENU_SUB_disabled_fg~&, _RGBA32(0, 0, 0, 0)
            END IF
        END IF

        lbl$ = RTRIM$(MENU_ITEMS(i%).label)
        hk$  = RTRIM$(MENU_ITEMS(i%).hotkey)

        IF MENU_ITEMS(i%).hasCheckbox% THEN
            IF MENU_ITEMS(i%).checked% THEN
                checkStr$ = CHR$(251)
            ELSE
                checkStr$ = " "
            END IF
            _UPRINTSTRING (MENU_BAR.subX% + 4, itemY% + 2), checkStr$
        END IF

        _UPRINTSTRING (MENU_BAR.subX% + MENU_SUB_PAD_LEFT, itemY% + 2), lbl$

        IF LEN(hk$) > 0 THEN
            DIM hkX AS INTEGER
            hkX% = MENU_BAR.subX% + MENU_BAR.subW% - _PRINTWIDTH(hk$) - MENU_SUB_PAD_RIGHT
            _UPRINTSTRING (hkX%, itemY% + 2), hk$
        END IF

        ' Track RECENT item position for submenu
        IF MENU_ITEMS(i%).actionId% = 213 THEN
            MENU_BAR.recentItemIdx% = childIdx%
            MENU_BAR.recentY%       = itemY%
            IF childIdx% = MENU_BAR.hoverSub% AND MENU_ITEMS(i%).enabled% AND NOT MENU_BAR.kbActive% THEN
                MENU_BAR.recentOpen% = TRUE
            END IF
        END IF

        ' Track RANDOM TRACK item position for submenu
        IF MENU_ITEMS(i%).actionId% = 433 THEN
            MENU_BAR.randomItemIdx% = childIdx%
            MENU_BAR.randomY%       = itemY%
            IF childIdx% = MENU_BAR.hoverSub% AND MENU_ITEMS(i%).enabled% AND NOT MENU_BAR.kbActive% THEN
                MENU_BAR.randomOpen% = TRUE
            END IF
        END IF

        ' Track TRANSFORM item position for submenu
        IF MENU_ITEMS(i%).actionId% = 331 THEN
            MENU_BAR.transformItemIdx% = childIdx%
            MENU_BAR.transformY%       = itemY%
            IF childIdx% = MENU_BAR.hoverSub% AND MENU_ITEMS(i%).enabled% AND NOT MENU_BAR.kbActive% THEN
                MENU_BAR.transformOpen% = TRUE
            END IF
        END IF

        ' Track LAYOUT item position for submenu
        IF MENU_ITEMS(i%).actionId% = 442 THEN
            MENU_BAR.layoutItemIdx% = childIdx%
            MENU_BAR.layoutY%       = itemY%
            IF childIdx% = MENU_BAR.hoverSub% AND MENU_ITEMS(i%).enabled% AND NOT MENU_BAR.kbActive% THEN
                MENU_BAR.layoutOpen% = TRUE
            END IF
        END IF

        ' Track PREVIEW WINDOW item position for submenu
        IF MENU_ITEMS(i%).actionId% = 2012 THEN
            MENU_BAR.pvwItemIdx% = childIdx%
            MENU_BAR.pvwY%       = itemY%
            IF childIdx% = MENU_BAR.hoverSub% AND MENU_ITEMS(i%).enabled% AND NOT MENU_BAR.kbActive% THEN
                MENU_BAR.pvwOpen% = TRUE
            END IF
        END IF

        ' Track EXPORT AS item position for submenu
        IF MENU_ITEMS(i%).actionId% = EXPORT_ACT_FLYOUT THEN
            MENU_BAR.exportItemIdx% = childIdx%
            MENU_BAR.exportY%       = itemY%
            IF childIdx% = MENU_BAR.hoverSub% AND MENU_ITEMS(i%).enabled% AND NOT MENU_BAR.kbActive% THEN
                MENU_BAR.exportOpen% = TRUE
            END IF
        END IF

        virtualY% = virtualY% + MENU_ITEM_HEIGHT
        childIdx% = childIdx% + 1

        MENUBAR_render_next_item:
    NEXT i%

    ' Draw down scroll arrow if needed (on top of background, at bottom)
    IF canScrollDn% THEN
        LINE (MENU_BAR.subX% + 1, MENU_BAR.subY% + MENU_BAR.subH% - scrollArrowH%)-(MENU_BAR.subX% + MENU_BAR.subW% - 2, MENU_BAR.subY% + MENU_BAR.subH% - 1), subBg~&, BF
        COLOR subFg~&, _RGBA32(0, 0, 0, 0)
        DIM arrowDnX AS INTEGER
        arrowDnX% = MENU_BAR.subX% + (MENU_BAR.subW% \ 2) - (_PRINTWIDTH(CHR$(25)) \ 2)
        _UPRINTSTRING (arrowDnX%, MENU_BAR.subY% + MENU_BAR.subH% - scrollArrowH% + 2), CHR$(25)
    END IF

    ' Render recent files submenu if open
    IF MENU_BAR.recentOpen% AND RECENT_FILE_COUNT% > 0 THEN
        MENUBAR_render_recent_submenu
    END IF

    ' Render random track submenu if open
    IF MENU_BAR.randomOpen% THEN
        MENUBAR_render_random_submenu
    END IF

    ' Render transform submenu if open
    IF MENU_BAR.transformOpen% THEN
        MENUBAR_render_transform_submenu
    END IF

    ' Render layout submenu if open
    IF MENU_BAR.layoutOpen% THEN
        MENUBAR_render_layout_submenu
    END IF

    ' Render preview window submenu if open
    IF MENU_BAR.pvwOpen% THEN
        MENUBAR_render_pvw_submenu
    END IF

    ' Render preview window recent sub-submenu if open
    IF MENU_BAR.pvwRecentOpen% AND RECENT_PREVIEW_COUNT% > 0 THEN
        MENUBAR_render_pvw_recent_submenu
    END IF

    ' Render export-as submenu if open
    IF MENU_BAR.exportOpen% THEN
        MENUBAR_render_export_submenu
    END IF
END SUB


''
' Handle mouse click on menu bar or submenu
' @param rawX INTEGER Raw screen X coordinate of the click
' @param rawY INTEGER Raw screen Y coordinate of the click
'
SUB MENUBAR_handle_click (rawX AS INTEGER, rawY AS INTEGER)
    DIM i AS INTEGER

    ' Check if click is on the overflow popup first (it renders on top)
    IF MENU_OVERFLOW_OPEN% AND MENU_CHEVRON_ACTIVE% AND MENUBAR_overflow_in_bounds%(rawX%, rawY%) THEN
        MENUBAR_handle_overflow_click rawX%, rawY%
        EXIT SUB
    END IF

    ' Check if click is on the menu bar itself
    IF rawY% >= MENU_BAR.barY% AND rawY% < MENU_BAR.barY% + MENU_BAR.barH% _
        AND rawX% >= MENU_BAR.barX% AND rawX% < MENU_BAR.barX% + MENU_BAR.barW% THEN

        ' Check for chevron >> click first
        IF MENU_CHEVRON_ACTIVE% THEN
            IF rawX% >= MENU_CHEVRON_X% - 2 AND rawX% < MENU_CHEVRON_X% + MENU_CHEVRON_W% THEN
                ' Toggle overflow popup
                IF MENU_OVERFLOW_OPEN% THEN
                    MENU_OVERFLOW_OPEN%  = FALSE
                    MENU_OVERFLOW_HOVER% = -1
                ELSE
                    MENU_OVERFLOW_OPEN%  = TRUE
                    MENU_OVERFLOW_HOVER% = -1
                    ' Close any open root submenu
                    MENU_BAR.openMenu% = -1
                    MENU_BAR.hoverSub% = -1
                END IF
                GUI_NEEDS_REDRAW% = TRUE
                EXIT SUB
            END IF
        END IF

        ' Find which root item was clicked (only check visible items + HELP)
        FOR i% = 0 TO MENU_ROOT_COUNT% - 1
            ' Skip overflow items (not HELP, not visible)
            IF MENU_CHEVRON_ACTIVE% AND i% >= MENU_VISIBLE_COUNT% AND i% <> MENU_ROOT_COUNT% - 1 THEN
                GOTO MENUBAR_click_skip_root
            END IF
            IF rawX% >= MENU_ROOT_X(i%) - 2 AND rawX% < MENU_ROOT_X(i%) + MENU_ROOT_W(i%) THEN
                IF NOT MENU_ROOT_ENABLED(i%) THEN EXIT SUB ' Disabled root
                ' Close overflow popup if open
                MENU_OVERFLOW_OPEN%  = FALSE
                MENU_OVERFLOW_HOVER% = -1
                IF MENU_BAR.openMenu% = i% THEN
                    ' Clicked on same menu - close it
                    MENUBAR_close_all
                ELSE
                    ' Open this menu
                    MENU_BAR.openMenu%  = i%
                    MENU_BAR.hoverRoot% = i%
                    MENU_BAR.hoverSub%  = -1
                    MENU_BAR.subScroll% = 0
                    MENU_BAR.stayOpen%  = TRUE
                    ' Close palette menu to avoid overlap
                    IF PALETTE_MENU_VISIBLE% THEN PALETTE_MENU_hide
                    SOUND_play SND_MENU_OPEN
                    GUI_NEEDS_REDRAW% = TRUE
                END IF
                EXIT SUB
            END IF
            MENUBAR_click_skip_root:
        NEXT i%
        ' Clicked on menu bar but not on any root item - close menu if open
        IF MENU_BAR.openMenu% >= 0 THEN MENUBAR_close_all
        EXIT SUB
    END IF

    ' Check if click is on the recent files submenu
    IF MENU_BAR.recentOpen% AND MENUBAR_recent_in_bounds%(rawX%, rawY%) THEN
        MENUBAR_handle_recent_click rawX%, rawY%
        EXIT SUB
    END IF

    ' Check if click is on the random track submenu
    IF MENU_BAR.randomOpen% AND MENUBAR_random_in_bounds%(rawX%, rawY%) THEN
        MENUBAR_handle_random_click rawX%, rawY%
        EXIT SUB
    END IF

    ' Check if click is on the transform submenu
    IF MENU_BAR.transformOpen% AND MENUBAR_transform_in_bounds%(rawX%, rawY%) THEN
        MENUBAR_handle_transform_click rawX%, rawY%
        EXIT SUB
    END IF

    ' Check if click is on the layout submenu
    IF MENU_BAR.layoutOpen% AND MENUBAR_layout_in_bounds%(rawX%, rawY%) THEN
        MENUBAR_handle_layout_click rawX%, rawY%
        EXIT SUB
    END IF

    ' Check if click is on the preview window recent sub-submenu
    IF MENU_BAR.pvwRecentOpen% AND MENUBAR_pvw_recent_in_bounds%(rawX%, rawY%) THEN
        MENUBAR_handle_pvw_recent_click rawX%, rawY%
        EXIT SUB
    END IF

    ' Check if click is on the preview window submenu
    IF MENU_BAR.pvwOpen% AND MENUBAR_pvw_in_bounds%(rawX%, rawY%) THEN
        MENUBAR_handle_pvw_click rawX%, rawY%
        EXIT SUB
    END IF

    ' Check if click is on the export-as submenu
    IF MENU_BAR.exportOpen% AND MENUBAR_export_in_bounds%(rawX%, rawY%) THEN
        MENUBAR_handle_export_click rawX%, rawY%
        EXIT SUB
    END IF

    ' Check if click is on the open submenu
    IF MENU_BAR.openMenu% >= 0 AND MENUBAR_submenu_in_bounds%(rawX%, rawY%) THEN
        ' Handle scroll arrow clicks first
        IF MENU_BAR.subScroll% > 0 THEN
            ' Up arrow zone
            IF rawY% >= MENU_BAR.subY% AND rawY% < MENU_BAR.subY% + MENU_ITEM_HEIGHT + 2 THEN
                MENU_BAR.subScroll% = MENU_BAR.subScroll% - MENU_ITEM_HEIGHT
                IF MENU_BAR.subScroll% < 0 THEN MENU_BAR.subScroll% = 0
                GUI_NEEDS_REDRAW% = TRUE
                EXIT SUB
            END IF
        END IF
        IF MENU_BAR.subScroll% < MENU_BAR.subScrollMax% THEN
            ' Down arrow zone
            IF rawY% >= MENU_BAR.subY% + MENU_BAR.subH% - MENU_ITEM_HEIGHT - 2 AND rawY% < MENU_BAR.subY% + MENU_BAR.subH% THEN
                MENU_BAR.subScroll% = MENU_BAR.subScroll% + MENU_ITEM_HEIGHT
                IF MENU_BAR.subScroll% > MENU_BAR.subScrollMax% THEN MENU_BAR.subScroll% = MENU_BAR.subScrollMax%
                GUI_NEEDS_REDRAW% = TRUE
                EXIT SUB
            END IF
        END IF

        DIM clickedItem AS INTEGER
        clickedItem% = MENUBAR_get_submenu_item_at%(rawY%)

        IF clickedItem% >= 0 THEN
            ' Find the actual MENU_ITEMS index for this child
            DIM childIdx AS INTEGER, itemIdx AS INTEGER
            childIdx% = 0
            FOR itemIdx% = 0 TO MENU_ITEM_COUNT% - 1
                IF MENU_ITEMS(itemIdx%).parentIdx% = MENU_BAR.openMenu% THEN
                    IF MENU_ITEMS(itemIdx%).isDivider% THEN
                        childIdx% = childIdx% + 1
                        GOTO MENUBAR_click_next
                    END IF
                    IF childIdx% = clickedItem% THEN
                        ' Found the clicked item
                        IF MENU_ITEMS(itemIdx%).enabled% THEN
                            ' Intercept RECENT item: toggle submenu instead of dispatch
                            IF MENU_ITEMS(itemIdx%).actionId% = 213 THEN
                                MENU_BAR.recentOpen% = NOT MENU_BAR.recentOpen%
                                IF NOT MENU_BAR.recentOpen% THEN
                                    MENU_BAR.recentHover% = -1
                                END IF
                                GUI_NEEDS_REDRAW% = TRUE
                                EXIT SUB
                            END IF
                            IF MENU_ITEMS(itemIdx%).actionId% = 433 THEN
                                MENU_BAR.randomOpen% = NOT MENU_BAR.randomOpen%
                                IF NOT MENU_BAR.randomOpen% THEN
                                    MENU_BAR.randomHover% = -1
                                END IF
                                GUI_NEEDS_REDRAW% = TRUE
                                EXIT SUB
                            END IF
                            IF MENU_ITEMS(itemIdx%).actionId% = 331 THEN
                                MENU_BAR.transformOpen% = NOT MENU_BAR.transformOpen%
                                IF NOT MENU_BAR.transformOpen% THEN
                                    MENU_BAR.transformHover% = -1
                                END IF
                                GUI_NEEDS_REDRAW% = TRUE
                                EXIT SUB
                            END IF
                            IF MENU_ITEMS(itemIdx%).actionId% = 442 THEN
                                MENU_BAR.layoutOpen% = NOT MENU_BAR.layoutOpen%
                                IF NOT MENU_BAR.layoutOpen% THEN
                                    MENU_BAR.layoutHover% = -1
                                END IF
                                GUI_NEEDS_REDRAW% = TRUE
                                EXIT SUB
                            END IF
                            IF MENU_ITEMS(itemIdx%).actionId% = 2012 THEN
                                MENU_BAR.pvwOpen% = NOT MENU_BAR.pvwOpen%
                                IF NOT MENU_BAR.pvwOpen% THEN
                                    MENU_BAR.pvwHover%       = -1
                                    MENU_BAR.pvwRecentOpen%  = FALSE
                                    MENU_BAR.pvwRecentHover% = -1
                                END IF
                                GUI_NEEDS_REDRAW% = TRUE
                                EXIT SUB
                            END IF
                            IF MENU_ITEMS(itemIdx%).actionId% = EXPORT_ACT_FLYOUT THEN
                                MENU_BAR.exportOpen% = NOT MENU_BAR.exportOpen%
                                IF NOT MENU_BAR.exportOpen% THEN
                                    MENU_BAR.exportHover% = -1
                                END IF
                                GUI_NEEDS_REDRAW% = TRUE
                                EXIT SUB
                            END IF
                            ' Toggle checkbox if applicable
                            IF MENU_ITEMS(itemIdx%).hasCheckbox% THEN
                                MENU_ITEMS(itemIdx%).checked% = NOT MENU_ITEMS(itemIdx%).checked%
                            END IF
                            ' Execute action
                            DIM actId AS INTEGER
                            actId% = MENU_ITEMS(itemIdx%).actionId%
                            MENUBAR_close_all
                            IF actId% > 0 THEN SOUND_play SND_MENU_SELECT
                            IF actId% > 0 THEN CMD_execute_action actId%
                        END IF
                        EXIT SUB
                    END IF
                    childIdx% = childIdx% + 1
                END IF
                MENUBAR_click_next:
            NEXT itemIdx%
        END IF
        EXIT SUB
    END IF

    ' Click was outside all menu areas - close
    MENUBAR_close_all
END SUB


''
' Handle mouse movement for hover tracking
' @param rawX INTEGER Raw screen X coordinate of the mouse
' @param rawY INTEGER Raw screen Y coordinate of the mouse
'
SUB MENUBAR_handle_mouse_move (rawX AS INTEGER, rawY AS INTEGER)
    DIM i                AS INTEGER
    DIM oldHoverRoot     AS INTEGER, oldHoverSub AS INTEGER
    DIM oldOpenMenu      AS INTEGER
    DIM oldRecentOpen    AS INTEGER, oldRandomOpen AS INTEGER, oldTransformOpen AS INTEGER
    DIM oldLayoutOpen    AS INTEGER
    DIM oldPvwOpen       AS INTEGER
    DIM oldPvwRecentOpen AS INTEGER
    DIM oldExportOpen    AS INTEGER
    DIM oldOverflowOpen  AS INTEGER

    ' If keyboard navigation is active, ignore mouse until it actually moves
    IF MENU_BAR.kbActive% THEN
        IF rawX% = MENU_BAR.lastMouseX% AND rawY% = MENU_BAR.lastMouseY% THEN
            EXIT SUB
        END IF
        ' Mouse moved — keyboard nav yields to mouse
        MENU_BAR.kbActive% = FALSE
    END IF
    MENU_BAR.lastMouseX% = rawX%
    MENU_BAR.lastMouseY% = rawY%

    oldHoverRoot%     = MENU_BAR.hoverRoot%
    oldHoverSub%      = MENU_BAR.hoverSub%
    oldOpenMenu%      = MENU_BAR.openMenu%
    oldRecentOpen%    = MENU_BAR.recentOpen%
    oldRandomOpen%    = MENU_BAR.randomOpen%
    oldTransformOpen% = MENU_BAR.transformOpen%
    oldLayoutOpen%    = MENU_BAR.layoutOpen%
    oldPvwOpen%       = MENU_BAR.pvwOpen%
    oldPvwRecentOpen% = MENU_BAR.pvwRecentOpen%
    oldExportOpen%    = MENU_BAR.exportOpen%
    oldOverflowOpen%  = MENU_OVERFLOW_OPEN%
    DIM oldOverflowHover  AS INTEGER
    oldOverflowHover% = MENU_OVERFLOW_HOVER%
    DIM oldRecentHover    AS INTEGER
    oldRecentHover% = MENU_BAR.recentHover%
    DIM oldRandomHover    AS INTEGER
    oldRandomHover% = MENU_BAR.randomHover%
    DIM oldTransformHover AS INTEGER
    oldTransformHover% = MENU_BAR.transformHover%
    DIM oldLayoutHover    AS INTEGER
    oldLayoutHover% = MENU_BAR.layoutHover%
    DIM oldPvwHover       AS INTEGER
    oldPvwHover% = MENU_BAR.pvwHover%
    DIM oldPvwRecentHover AS INTEGER
    oldPvwRecentHover% = MENU_BAR.pvwRecentHover%
    DIM oldExportHover    AS INTEGER
    oldExportHover% = MENU_BAR.exportHover%

    ' Check if mouse is on the overflow popup
    IF MENU_OVERFLOW_OPEN% AND MENU_CHEVRON_ACTIVE% AND MENUBAR_overflow_in_bounds%(rawX%, rawY%) THEN
        ' Track hover within overflow popup
        DIM ovItemY   AS INTEGER, ovIdx AS INTEGER, ovI AS INTEGER
        DIM ovHelpIdx AS INTEGER
        ovHelpIdx%           = MENU_ROOT_COUNT% - 1
        ovItemY%             = MENU_OVERFLOW_Y% + 2
        MENU_OVERFLOW_HOVER% = -1
        ovIdx%               = 0
        FOR ovI% = MENU_VISIBLE_COUNT% TO ovHelpIdx% - 1
            IF rawY% >= ovItemY% AND rawY% < ovItemY% + MENU_ITEM_HEIGHT THEN
                MENU_OVERFLOW_HOVER% = ovIdx%
                EXIT FOR
            END IF
            ovItemY% = ovItemY% + MENU_ITEM_HEIGHT
            ovIdx% = ovIdx% + 1
        NEXT ovI%
        IF MENU_OVERFLOW_HOVER% <> oldOverflowHover% THEN GUI_NEEDS_REDRAW% = TRUE
        EXIT SUB

    ' Check if mouse is on the bar
    ELSEIF rawY% >= MENU_BAR.barY% AND rawY% < MENU_BAR.barY% + MENU_BAR.barH% _
        AND rawX% >= MENU_BAR.barX% AND rawX% < MENU_BAR.barX% + MENU_BAR.barW% THEN
        MENU_BAR.hoverRoot% = -1

        ' Check chevron hover
        IF MENU_CHEVRON_ACTIVE% THEN
            IF rawX% >= MENU_CHEVRON_X% - 2 AND rawX% < MENU_CHEVRON_X% + MENU_CHEVRON_W% THEN
                ' Hovering over chevron — if a menu is open, switch to showing overflow
                IF MENU_BAR.openMenu% >= 0 AND NOT MENU_OVERFLOW_OPEN% THEN
                    MENU_BAR.openMenu%   = -1
                    MENU_BAR.hoverSub%   = -1
                    MENU_OVERFLOW_OPEN%  = TRUE
                    MENU_OVERFLOW_HOVER% = -1
                    GUI_NEEDS_REDRAW%    = TRUE
                END IF
                GOTO MENUBAR_hover_done
            END IF
        END IF

        FOR i% = 0 TO MENU_ROOT_COUNT% - 1
            ' Skip overflow items (not HELP)
            IF MENU_CHEVRON_ACTIVE% AND i% >= MENU_VISIBLE_COUNT% AND i% <> MENU_ROOT_COUNT% - 1 THEN
                GOTO MENUBAR_hover_skip_root
            END IF
            IF rawX% >= MENU_ROOT_X(i%) - 2 AND rawX% < MENU_ROOT_X(i%) + MENU_ROOT_W(i%) THEN
                MENU_BAR.hoverRoot% = i%
                ' If a menu is open and we hover a different root, switch to it
                IF MENU_BAR.openMenu% >= 0 AND MENU_BAR.openMenu% <> i% AND MENU_ROOT_ENABLED(i%) THEN
                    MENU_BAR.openMenu%   = i%
                    MENU_BAR.hoverSub%   = -1
                    MENU_BAR.subScroll%  = 0
                    MENU_OVERFLOW_OPEN%  = FALSE
                    MENU_OVERFLOW_HOVER% = -1
                    ' Close all cascade submenus from the previous root menu
                    MENU_BAR.recentOpen%    = FALSE : MENU_BAR.recentHover% = -1
                    MENU_BAR.randomOpen%    = FALSE : MENU_BAR.randomHover% = -1
                    MENU_BAR.transformOpen% = FALSE : MENU_BAR.transformHover% = -1
                    MENU_BAR.layoutOpen%    = FALSE : MENU_BAR.layoutHover% = -1
                    MENU_BAR.pvwOpen%       = FALSE : MENU_BAR.pvwHover% = -1
                    MENU_BAR.pvwRecentOpen% = FALSE : MENU_BAR.pvwRecentHover% = -1
                    MENU_BAR.exportOpen%    = FALSE : MENU_BAR.exportHover% = -1
                    GUI_NEEDS_REDRAW%       = TRUE
                END IF
                EXIT FOR
            END IF
            MENUBAR_hover_skip_root:
        NEXT i%
        MENUBAR_hover_done:
    ELSEIF MENU_BAR.openMenu% >= 0 AND MENUBAR_random_in_bounds%(rawX%, rawY%) THEN
        ' Mouse is on the random track submenu - track hover there
        DIM randItemY           AS INTEGER
        randItemY%            = MENU_BAR.randomY% + 2
        MENU_BAR.randomHover% = -1
        DIM randIdx             AS INTEGER
        FOR randIdx% = 0 TO 5 ' 0=MOD, 1=IT, 2=XM, 3=RAD, 4=MID, 5=RMI
            IF rawY% >= randItemY% AND rawY% < randItemY% + MENU_ITEM_HEIGHT THEN
                MENU_BAR.randomHover% = randIdx%
                EXIT FOR
            END IF
            randItemY% = randItemY% + MENU_ITEM_HEIGHT
        NEXT randIdx%
        MENU_BAR.hoverSub%  = MENU_BAR.randomItemIdx%
        MENU_BAR.hoverRoot% = MENU_BAR.openMenu%
        IF MENU_BAR.randomHover% <> oldRandomHover% THEN
            SOUND_play SND_MENU_HOVER
            GUI_NEEDS_REDRAW% = TRUE
        END IF
    ELSEIF MENU_BAR.openMenu% >= 0 AND MENUBAR_transform_in_bounds%(rawX%, rawY%) THEN
        ' Mouse is on the transform submenu - track hover there
        DIM trItemY             AS INTEGER
        trItemY%                 = MENU_BAR.transformY% + 2
        MENU_BAR.transformHover% = -1
        DIM trIdx               AS INTEGER
        FOR trIdx% = 0 TO TRANSFORM_FLYOUT_ITEMS - 1
            IF rawY% >= trItemY% AND rawY% < trItemY% + MENU_ITEM_HEIGHT THEN
                MENU_BAR.transformHover% = trIdx%
                EXIT FOR
            END IF
            trItemY% = trItemY% + MENU_ITEM_HEIGHT
        NEXT trIdx%
        MENU_BAR.hoverSub%  = MENU_BAR.transformItemIdx%
        MENU_BAR.hoverRoot% = MENU_BAR.openMenu%
        IF MENU_BAR.transformHover% <> oldTransformHover% THEN
            SOUND_play SND_MENU_HOVER
            GUI_NEEDS_REDRAW% = TRUE
        END IF
    ELSEIF MENU_BAR.openMenu% >= 0 AND MENUBAR_layout_in_bounds%(rawX%, rawY%) THEN
        ' Mouse is on the layout submenu - track hover there
        DIM lyItemY             AS INTEGER
        lyItemY%              = MENU_BAR.layoutY% + 2
        MENU_BAR.layoutHover% = -1
        DIM lyIdx               AS INTEGER
        FOR lyIdx% = 0 TO 9   ' 10 items (5 panels x LEFT/RIGHT)
            IF rawY% >= lyItemY% AND rawY% < lyItemY% + MENU_ITEM_HEIGHT THEN
                MENU_BAR.layoutHover% = lyIdx%
                EXIT FOR
            END IF
            lyItemY% = lyItemY% + MENU_ITEM_HEIGHT
        NEXT lyIdx%
        MENU_BAR.hoverSub%  = MENU_BAR.layoutItemIdx%
        MENU_BAR.hoverRoot% = MENU_BAR.openMenu%
        IF MENU_BAR.layoutHover% <> oldLayoutHover% THEN
            SOUND_play SND_MENU_HOVER
            GUI_NEEDS_REDRAW% = TRUE
        END IF
    ELSEIF MENU_BAR.openMenu% >= 0 AND MENUBAR_pvw_recent_in_bounds%(rawX%, rawY%) THEN
        ' Mouse is on the preview window recent sub-submenu - track hover there
        DIM prItemY             AS INTEGER, prIdx AS INTEGER
        prItemY%                 = MENU_BAR.pvwRecentY% + 2
        MENU_BAR.pvwRecentHover% = -1
        ' Check file items (0-based: 0..count-1)
        FOR prIdx% = 0 TO RECENT_PREVIEW_COUNT% - 1
            IF rawY% >= prItemY% AND rawY% < prItemY% + MENU_ITEM_HEIGHT THEN
                MENU_BAR.pvwRecentHover% = prIdx%
                EXIT FOR
            END IF
            prItemY% = prItemY% + MENU_ITEM_HEIGHT
        NEXT prIdx%
        ' Skip divider, check CLEAR item
        IF MENU_BAR.pvwRecentHover% = -1 THEN
            prItemY% = MENU_BAR.pvwRecentY% + 2 + (RECENT_PREVIEW_COUNT% * MENU_ITEM_HEIGHT)
            prItemY% = prItemY% + MENU_DIVIDER_HEIGHT
            IF rawY% >= prItemY% AND rawY% < prItemY% + MENU_ITEM_HEIGHT THEN
                MENU_BAR.pvwRecentHover% = RECENT_PREVIEW_COUNT% ' CLEAR index
            END IF
        END IF
        ' Keep hoverSub on pvwItemIdx to keep parent highlighted
        MENU_BAR.hoverSub%  = MENU_BAR.pvwItemIdx%
        MENU_BAR.hoverRoot% = MENU_BAR.openMenu%
        IF MENU_BAR.pvwRecentHover% <> oldPvwRecentHover% THEN
            SOUND_play SND_MENU_HOVER
            GUI_NEEDS_REDRAW% = TRUE
        END IF
    ELSEIF MENU_BAR.openMenu% >= 0 AND MENUBAR_pvw_in_bounds%(rawX%, rawY%) THEN
        ' Mouse is on the preview window submenu - track hover there
        CONST PVW_ITEM_COUNT = 10
        DIM pvItemY             AS INTEGER
        pvItemY%           = MENU_BAR.pvwY% + 2
        MENU_BAR.pvwHover% = -1
        DIM pvIdx               AS INTEGER
        FOR pvIdx% = 0 TO PVW_ITEM_COUNT - 1
            ' Skip divider indices (1, 4, and 7 are dividers)
            IF pvIdx% = 1 OR pvIdx% = 4 OR pvIdx% = 7 THEN
                pvItemY% = pvItemY% + MENU_DIVIDER_HEIGHT
            ELSE
                IF rawY% >= pvItemY% AND rawY% < pvItemY% + MENU_ITEM_HEIGHT THEN
                    MENU_BAR.pvwHover% = pvIdx%
                    EXIT FOR
                END IF
                pvItemY% = pvItemY% + MENU_ITEM_HEIGHT
            END IF
        NEXT pvIdx%
        ' Track pvwRecent item for nested submenu auto-open
        IF MENU_BAR.pvwHover% = 9 AND RECENT_PREVIEW_COUNT% > 0 THEN
            MENU_BAR.pvwRecentOpen% = TRUE
        ELSEIF MENU_BAR.pvwHover% <> 9 THEN
            MENU_BAR.pvwRecentOpen%  = FALSE
            MENU_BAR.pvwRecentHover% = -1
        END IF
        MENU_BAR.hoverSub%  = MENU_BAR.pvwItemIdx%
        MENU_BAR.hoverRoot% = MENU_BAR.openMenu%
        IF MENU_BAR.pvwHover% <> oldPvwHover% THEN
            SOUND_play SND_MENU_HOVER
            GUI_NEEDS_REDRAW% = TRUE
        END IF
    ELSEIF MENU_BAR.openMenu% >= 0 AND MENUBAR_export_in_bounds%(rawX%, rawY%) THEN
        ' Mouse is on the export-as submenu - track hover there
        DIM exItemY             AS INTEGER
        exItemY%              = MENU_BAR.exportY% + 2
        MENU_BAR.exportHover% = -1
        DIM exIdx               AS INTEGER
        FOR exIdx% = 0 TO EXPORT_FLYOUT_ITEMS - 1
            IF rawY% >= exItemY% AND rawY% < exItemY% + MENU_ITEM_HEIGHT THEN
                MENU_BAR.exportHover% = exIdx%
                EXIT FOR
            END IF
            exItemY% = exItemY% + MENU_ITEM_HEIGHT
        NEXT exIdx%
        MENU_BAR.hoverSub%  = MENU_BAR.exportItemIdx%
        MENU_BAR.hoverRoot% = MENU_BAR.openMenu%
        IF MENU_BAR.exportHover% <> oldExportHover% THEN
            SOUND_play SND_MENU_HOVER
            GUI_NEEDS_REDRAW% = TRUE
        END IF
    ELSEIF MENU_BAR.openMenu% >= 0 AND MENUBAR_recent_in_bounds%(rawX%, rawY%) THEN
        ' Mouse is on the recent files submenu - track hover there
        DIM recItemY            AS INTEGER, recIdx AS INTEGER
        recItemY%             = MENU_BAR.recentY% + 2
        MENU_BAR.recentHover% = -1
        ' Check file items (0-based: 0..count-1)
        FOR recIdx% = 0 TO RECENT_FILE_COUNT% - 1
            IF rawY% >= recItemY% AND rawY% < recItemY% + MENU_ITEM_HEIGHT THEN
                MENU_BAR.recentHover% = recIdx%
                EXIT FOR
            END IF
            recItemY% = recItemY% + MENU_ITEM_HEIGHT
        NEXT recIdx%
        ' Skip divider
        IF MENU_BAR.recentHover% = -1 THEN
            recItemY% = MENU_BAR.recentY% + 2 + (RECENT_FILE_COUNT% * MENU_ITEM_HEIGHT)
            recItemY% = recItemY% + MENU_DIVIDER_HEIGHT
            ' Check CLEAR item
            IF rawY% >= recItemY% AND rawY% < recItemY% + MENU_ITEM_HEIGHT THEN
                MENU_BAR.recentHover% = RECENT_FILE_COUNT%       ' CLEAR index
            END IF
        END IF
        ' Keep hoverSub on the RECENT item to keep the parent highlighted
        MENU_BAR.hoverSub%  = MENU_BAR.recentItemIdx%
        MENU_BAR.hoverRoot% = MENU_BAR.openMenu%
        IF MENU_BAR.recentHover% <> oldRecentHover% THEN
            SOUND_play SND_MENU_HOVER
            GUI_NEEDS_REDRAW% = TRUE
        END IF
    ELSEIF MENU_BAR.openMenu% >= 0 AND MENUBAR_submenu_in_bounds%(rawX%, rawY%) THEN
        ' Mouse is on submenu - check scroll arrow hover first
        STATIC arrowScrollTimer AS DOUBLE
        DIM inUpArrow           AS INTEGER, inDnArrow AS INTEGER
        inUpArrow% = (MENU_BAR.subScroll% > 0 _
            AND rawY% >= MENU_BAR.subY% _
            AND rawY% < MENU_BAR.subY% + MENU_ITEM_HEIGHT + 2)
        inDnArrow% = (MENU_BAR.subScroll% < MENU_BAR.subScrollMax% _
            AND rawY% >= MENU_BAR.subY% + MENU_BAR.subH% - MENU_ITEM_HEIGHT - 2 _
            AND rawY% < MENU_BAR.subY% + MENU_BAR.subH%)
        IF inUpArrow% OR inDnArrow% THEN
            IF TIMER - arrowScrollTimer > 0.1 THEN
                arrowScrollTimer = TIMER
                IF inUpArrow% THEN
                    MENU_BAR.subScroll% = MENU_BAR.subScroll% - MENU_ITEM_HEIGHT
                    IF MENU_BAR.subScroll% < 0 THEN MENU_BAR.subScroll% = 0
                ELSE
                    MENU_BAR.subScroll% = MENU_BAR.subScroll% + MENU_ITEM_HEIGHT
                    IF MENU_BAR.subScroll% > MENU_BAR.subScrollMax% THEN MENU_BAR.subScroll% = MENU_BAR.subScrollMax%
                END IF
                GUI_NEEDS_REDRAW% = TRUE
            END IF
            MENU_BAR.hoverSub%  = -1
            MENU_BAR.hoverRoot% = MENU_BAR.openMenu%
        ELSE
            arrowScrollTimer = 0
            ' update submenu hover
            MENU_BAR.hoverSub%  = MENUBAR_get_submenu_item_at%(rawY%)
            MENU_BAR.hoverRoot% = MENU_BAR.openMenu%
            ' Close recent submenu if hover moved away from RECENT item
            IF MENU_BAR.recentOpen% AND MENU_BAR.hoverSub% <> MENU_BAR.recentItemIdx% THEN
                MENU_BAR.recentOpen%  = FALSE
                MENU_BAR.recentHover% = -1
            END IF
            ' Close random submenu if hover moved away from RANDOM TRACK item
            IF MENU_BAR.randomOpen% AND MENU_BAR.hoverSub% <> MENU_BAR.randomItemIdx% THEN
                MENU_BAR.randomOpen%  = FALSE
                MENU_BAR.randomHover% = -1
            END IF
            ' Close transform submenu if hover moved away from TRANSFORM... item
            IF MENU_BAR.transformOpen% AND MENU_BAR.hoverSub% <> MENU_BAR.transformItemIdx% THEN
                MENU_BAR.transformOpen%  = FALSE
                MENU_BAR.transformHover% = -1
            END IF
            ' Close layout submenu if hover moved away from LAYOUT item
            IF MENU_BAR.layoutOpen% AND MENU_BAR.hoverSub% <> MENU_BAR.layoutItemIdx% THEN
                MENU_BAR.layoutOpen%  = FALSE
                MENU_BAR.layoutHover% = -1
            END IF
            ' Close preview window submenu if hover moved away from PREVIEW WINDOW item
            IF MENU_BAR.pvwOpen% AND MENU_BAR.hoverSub% <> MENU_BAR.pvwItemIdx% THEN
                MENU_BAR.pvwOpen%        = FALSE
                MENU_BAR.pvwHover%       = -1
                MENU_BAR.pvwRecentOpen%  = FALSE
                MENU_BAR.pvwRecentHover% = -1
            END IF
            ' Close export submenu if hover moved away from EXPORT AS... item
            IF MENU_BAR.exportOpen% AND MENU_BAR.hoverSub% <> MENU_BAR.exportItemIdx% THEN
                MENU_BAR.exportOpen%  = FALSE
                MENU_BAR.exportHover% = -1
            END IF
        END IF
    ELSE
        ' Mouse is outside all menu areas
        IF MENU_BAR.openMenu% < 0 AND NOT MENU_OVERFLOW_OPEN% THEN
            MENU_BAR.hoverRoot% = -1
        END IF
        ' Always clear hoverSub when outside all areas — prevents render-loop
        ' auto-open from re-opening cascade submenus we just closed
        MENU_BAR.hoverSub% = -1
        ' Close recent submenu when mouse leaves all areas
        IF MENU_BAR.recentOpen% THEN
            MENU_BAR.recentOpen%  = FALSE
            MENU_BAR.recentHover% = -1
        END IF
        ' Close random submenu when mouse leaves all areas
        IF MENU_BAR.randomOpen% THEN
            MENU_BAR.randomOpen%  = FALSE
            MENU_BAR.randomHover% = -1
        END IF
        ' Close transform submenu when mouse leaves all areas
        IF MENU_BAR.transformOpen% THEN
            MENU_BAR.transformOpen%  = FALSE
            MENU_BAR.transformHover% = -1
        END IF
        ' Close layout submenu when mouse leaves all areas
        IF MENU_BAR.layoutOpen% THEN
            MENU_BAR.layoutOpen%  = FALSE
            MENU_BAR.layoutHover% = -1
        END IF
        ' Close preview window submenu when mouse leaves all areas
        IF MENU_BAR.pvwOpen% THEN
            MENU_BAR.pvwOpen%  = FALSE
            MENU_BAR.pvwHover% = -1
        END IF
        IF MENU_BAR.pvwRecentOpen% THEN
            MENU_BAR.pvwRecentOpen%  = FALSE
            MENU_BAR.pvwRecentHover% = -1
        END IF
        ' Close export submenu when mouse leaves all areas
        IF MENU_BAR.exportOpen% THEN
            MENU_BAR.exportOpen%  = FALSE
            MENU_BAR.exportHover% = -1
        END IF
        ' Clear overflow hover when mouse leaves popup
        IF MENU_OVERFLOW_HOVER% >= 0 THEN
            MENU_OVERFLOW_HOVER% = -1
            GUI_NEEDS_REDRAW%    = TRUE
        END IF
    END IF

    ' Root item hovered/switched -> MENU_OPEN; sub-item hovered -> MENU_HOVER
    ' Exception: sub-items that open a cascading menu also play MENU_OPEN
    ' Disabled items do not play any sound
    IF MENU_BAR.hoverRoot% <> oldHoverRoot% THEN
        SOUND_play SND_MENU_OPEN
    ELSEIF MENU_BAR.hoverSub% <> oldHoverSub% OR MENU_OVERFLOW_HOVER% <> oldOverflowHover% THEN
        IF MENUBAR_is_sub_item_enabled%(MENU_BAR.hoverSub%) THEN
            IF MENUBAR_is_cascading_item%(MENU_BAR.hoverSub%) THEN
                SOUND_play SND_MENU_OPEN
            ELSE
                SOUND_play SND_MENU_HOVER
            END IF
        END IF
    END IF
    IF MENU_BAR.hoverRoot% <> oldHoverRoot% OR MENU_BAR.hoverSub% <> oldHoverSub% _
        OR MENU_OVERFLOW_HOVER% <> oldOverflowHover% THEN
        GUI_NEEDS_REDRAW% = TRUE
    END IF

    IF MENU_BAR.openMenu% <> oldOpenMenu% _
        OR MENU_BAR.recentOpen% <> oldRecentOpen% _
        OR MENU_BAR.randomOpen% <> oldRandomOpen% _
        OR MENU_BAR.transformOpen% <> oldTransformOpen% _
        OR MENU_BAR.layoutOpen% <> oldLayoutOpen% _
        OR MENU_BAR.pvwOpen% <> oldPvwOpen% _
        OR MENU_BAR.pvwRecentOpen% <> oldPvwRecentOpen% _
        OR MENU_BAR.exportOpen% <> oldExportOpen% _
        OR MENU_OVERFLOW_OPEN% <> oldOverflowOpen% THEN
        SCENE_DIRTY% = TRUE
    END IF
END SUB


''
' Close all menus
'
SUB MENUBAR_close_all ()
    MENU_BAR.openMenu%       = -1
    MENU_BAR.hoverRoot%      = -1
    MENU_BAR.hoverSub%       = -1
    MENU_BAR.subScroll%      = 0
    MENU_BAR.stayOpen%       = FALSE
    MENU_BAR.recentOpen%     = FALSE
    MENU_BAR.recentHover%    = -1
    MENU_BAR.randomOpen%     = FALSE
    MENU_BAR.randomHover%    = -1
    MENU_BAR.transformOpen%  = FALSE
    MENU_BAR.transformHover% = -1
    MENU_BAR.layoutOpen%     = FALSE
    MENU_BAR.layoutHover%    = -1
    MENU_BAR.pvwOpen%        = FALSE
    MENU_BAR.pvwHover%       = -1
    MENU_BAR.pvwRecentOpen%  = FALSE
    MENU_BAR.pvwRecentHover% = -1
    MENU_BAR.exportOpen%     = FALSE
    MENU_BAR.exportHover%    = -1
    MENU_OVERFLOW_OPEN%      = FALSE
    MENU_OVERFLOW_HOVER%     = -1
    GUI_NEEDS_REDRAW%        = TRUE
    SCENE_DIRTY%             = TRUE
END SUB


''
' Handle keyboard navigation for open menus
' @param k LONG Key code from _KEYHIT to process
' @return INTEGER - TRUE if the key was consumed by menu navigation
'
FUNCTION MENUBAR_handle_key% (k AS LONG)
    MENUBAR_handle_key% = FALSE

    ' ALT tap to open/close menu — DISABLED (was interfering with Alt+click color picking)
    ' ALT state tracking is still maintained for other features (e.g. Alt-triggered picker)
    MENU_BAR.altWasDown% = FALSE
    MENU_BAR.altTapped%  = FALSE

    ' Only handle keys when menu or overflow is open
    IF MENU_BAR.openMenu% < 0 AND NOT MENU_OVERFLOW_OPEN% THEN EXIT FUNCTION

    ' --- Overflow popup keyboard navigation ---
    IF MENU_OVERFLOW_OPEN% AND MENU_CHEVRON_ACTIVE% THEN
        DIM ovHelpIdx2 AS INTEGER, ovCount2 AS INTEGER
        ovHelpIdx2% = MENU_ROOT_COUNT% - 1
        ovCount2%   = ovHelpIdx2% - MENU_VISIBLE_COUNT% ' Number of overflow items
        IF ovCount2% > 0 THEN
            SELECT CASE k&
                CASE 18432 ' Up arrow
                    IF MENU_OVERFLOW_HOVER% <= 0 THEN
                        MENU_OVERFLOW_HOVER% = ovCount2% - 1
                    ELSE
                        MENU_OVERFLOW_HOVER% = MENU_OVERFLOW_HOVER% - 1
                    END IF
                    MENU_BAR.kbActive%  = TRUE
                    GUI_NEEDS_REDRAW%   = TRUE
                    MENUBAR_handle_key% = TRUE
                    EXIT FUNCTION

                CASE 20480 ' Down arrow
                    IF MENU_OVERFLOW_HOVER% >= ovCount2% - 1 THEN
                        MENU_OVERFLOW_HOVER% = 0
                    ELSE
                        MENU_OVERFLOW_HOVER% = MENU_OVERFLOW_HOVER% + 1
                    END IF
                    MENU_BAR.kbActive%  = TRUE
                    GUI_NEEDS_REDRAW%   = TRUE
                    MENUBAR_handle_key% = TRUE
                    EXIT FUNCTION

                CASE 13    ' Enter — open the hovered overflow menu's submenu
                    IF MENU_OVERFLOW_HOVER% >= 0 AND MENU_OVERFLOW_HOVER% < ovCount2% THEN
                        DIM ovRootIdx AS INTEGER
                        ovRootIdx% = MENU_VISIBLE_COUNT% + MENU_OVERFLOW_HOVER%
                        IF MENU_ROOT_ENABLED(ovRootIdx%) THEN
                            MENU_OVERFLOW_OPEN%  = FALSE
                            MENU_OVERFLOW_HOVER% = -1
                            MENU_BAR.openMenu%   = ovRootIdx%
                            MENU_BAR.hoverRoot%  = ovRootIdx%
                            MENU_BAR.hoverSub%   = -1
                            MENU_BAR.subScroll%  = 0
                            MENU_BAR.kbActive%   = TRUE
                            GUI_NEEDS_REDRAW%    = TRUE
                        END IF
                    END IF
                    MENUBAR_handle_key% = TRUE
                    EXIT FUNCTION

                CASE 19200 ' Left arrow — close overflow, go to last visible root
                    MENU_OVERFLOW_OPEN%  = FALSE
                    MENU_OVERFLOW_HOVER% = -1
                    DIM ovPrev AS INTEGER
                    ovPrev% = MENU_VISIBLE_COUNT% - 1
                    IF ovPrev% < 0 THEN ovPrev% = 0
                    MENU_BAR.openMenu%  = ovPrev%
                    MENU_BAR.hoverRoot% = ovPrev%
                    MENU_BAR.hoverSub%  = -1
                    MENU_BAR.subScroll% = 0
                    MENU_BAR.kbActive%  = TRUE
                    GUI_NEEDS_REDRAW%   = TRUE
                    MENUBAR_handle_key% = TRUE
                    EXIT FUNCTION

                CASE 19712 ' Right arrow — close overflow, go to HELP
                    MENU_OVERFLOW_OPEN%  = FALSE
                    MENU_OVERFLOW_HOVER% = -1
                    MENU_BAR.openMenu%   = MENU_ROOT_COUNT% - 1
                    MENU_BAR.hoverRoot%  = MENU_ROOT_COUNT% - 1
                    MENU_BAR.hoverSub%   = -1
                    MENU_BAR.subScroll%  = 0
                    MENU_BAR.kbActive%   = TRUE
                    GUI_NEEDS_REDRAW%    = TRUE
                    MENUBAR_handle_key%  = TRUE
                    EXIT FUNCTION

                CASE 27    ' Escape
                    MENU_OVERFLOW_OPEN%  = FALSE
                    MENU_OVERFLOW_HOVER% = -1
                    GUI_NEEDS_REDRAW%    = TRUE
                    MENUBAR_handle_key%  = TRUE
                    EXIT FUNCTION
            END SELECT
        END IF
    END IF

    ' Only handle remaining keys when a submenu is open
    IF MENU_BAR.openMenu% < 0 THEN EXIT FUNCTION

    ' --- Preview Window Recent sub-submenu keyboard navigation ---
    IF MENU_BAR.pvwRecentOpen% AND RECENT_PREVIEW_COUNT% > 0 THEN
        DIM pvwRecMax AS INTEGER
        pvwRecMax% = RECENT_PREVIEW_COUNT% ' 0..count-1 = files, count = CLEAR
        SELECT CASE k&
            CASE 18432     ' Up arrow
                IF MENU_BAR.pvwRecentHover% <= 0 THEN
                    MENU_BAR.pvwRecentHover% = pvwRecMax%
                ELSE
                    MENU_BAR.pvwRecentHover% = MENU_BAR.pvwRecentHover% - 1
                END IF
                SOUND_play SND_MENU_HOVER
                MENU_BAR.kbActive%  = TRUE
                GUI_NEEDS_REDRAW%   = TRUE
                MENUBAR_handle_key% = TRUE
                EXIT FUNCTION

            CASE 20480     ' Down arrow
                IF MENU_BAR.pvwRecentHover% >= pvwRecMax% THEN
                    MENU_BAR.pvwRecentHover% = 0
                ELSE
                    MENU_BAR.pvwRecentHover% = MENU_BAR.pvwRecentHover% + 1
                END IF
                SOUND_play SND_MENU_HOVER
                MENU_BAR.kbActive%  = TRUE
                GUI_NEEDS_REDRAW%   = TRUE
                MENUBAR_handle_key% = TRUE
                EXIT FUNCTION

            CASE 13        ' Enter
                IF MENU_BAR.pvwRecentHover% >= 0 AND MENU_BAR.pvwRecentHover% < RECENT_PREVIEW_COUNT% THEN
                    ' Load recent preview image
                    DIM pvwRecPath AS STRING
                    pvwRecPath$ = RECENT_PREVIEW_FILES(MENU_BAR.pvwRecentHover% + 1)
                    MENUBAR_close_all
                    IF _FILEEXISTS(pvwRecPath$) THEN
                        CFG.PREVIEW_MODE% = PREVIEW_MODE_FLOAT
                        PREVIEW_set_floating_mode
                        PREVIEW_load_floating_image pvwRecPath$
                    ELSE
                        DIM pvwRmb1 AS INTEGER
                        POINTER_hide_for_dialog
                        pvwRmb1% = DRAW_message_box%("File Not Found", "File not found:" + CHR$(10) + pvwRecPath$ + CHR$(10) + CHR$(10) + "Remove from recent images?", MB_BTN_YES_NO, MB_ICON_WARNING)
                        POINTER_show_after_dialog
                        DO WHILE _MOUSEINPUT: LOOP
                        MOUSE_force_buttons_up
                        IF pvwRmb1% = MB_RESULT_1 THEN
                            DIM pvwRj AS INTEGER
                            FOR pvwRj% = (MENU_BAR.pvwRecentHover% + 1) TO RECENT_PREVIEW_COUNT% - 1
                                RECENT_PREVIEW_FILES(pvwRj%) = RECENT_PREVIEW_FILES(pvwRj% + 1)
                            NEXT pvwRj%
                            RECENT_PREVIEW_FILES(RECENT_PREVIEW_COUNT%) = ""
                            RECENT_PREVIEW_COUNT% = RECENT_PREVIEW_COUNT% - 1
                            CONFIG_save
                        END IF
                    END IF
                ELSEIF MENU_BAR.pvwRecentHover% = RECENT_PREVIEW_COUNT% THEN
                    ' CLEAR
                    DIM pvwRmb2 AS INTEGER
                    POINTER_hide_for_dialog
                    pvwRmb2% = DRAW_message_box%("Clear Recent Images", "Clear all recent preview images?", MB_BTN_YES_NO, MB_ICON_INFO)
                    POINTER_show_after_dialog
                    DO WHILE _MOUSEINPUT: LOOP
                    MOUSE_force_buttons_up
                    IF pvwRmb2% = MB_RESULT_1 THEN RECENT_PREVIEW_clear
                    MENUBAR_close_all
                END IF
                MENUBAR_handle_key% = TRUE
                EXIT FUNCTION

            CASE 19200, 27 ' Left arrow or Escape - close pvw recent sub-submenu
                MENU_BAR.pvwRecentOpen%  = FALSE
                MENU_BAR.pvwRecentHover% = -1
                MENU_BAR.kbActive%       = TRUE
                GUI_NEEDS_REDRAW%        = TRUE
                MENUBAR_handle_key%      = TRUE
                EXIT FUNCTION
        END SELECT
    END IF

    ' --- Preview Window submenu keyboard navigation ---
    IF MENU_BAR.pvwOpen% THEN
        ' Actionable items: 0=Show/Hide, (1=div), 2=Follow, 3=Float, (4=div),
        '                   5=BinQL, 6=ColorPick, (7=div), 8=LoadImg, 9=Recent
        SELECT CASE k&
            CASE 18432     ' Up arrow
                DIM pvwPrev AS INTEGER
                pvwPrev% = MENU_BAR.pvwHover%
                DO
                    pvwPrev% = pvwPrev% - 1
                    IF pvwPrev% < 0 THEN pvwPrev% = 9
                LOOP WHILE pvwPrev% = 1 OR pvwPrev% = 4 OR pvwPrev% = 7 ' skip dividers
                MENU_BAR.pvwHover% = pvwPrev%
                SOUND_play SND_MENU_HOVER
                MENU_BAR.kbActive%  = TRUE
                GUI_NEEDS_REDRAW%   = TRUE
                MENUBAR_handle_key% = TRUE
                EXIT FUNCTION

            CASE 20480 ' Down arrow
                DIM pvwNext AS INTEGER
                pvwNext% = MENU_BAR.pvwHover%
                DO
                    pvwNext% = pvwNext% + 1
                    IF pvwNext% > 9 THEN pvwNext% = 0
                LOOP WHILE pvwNext% = 1 OR pvwNext% = 4 OR pvwNext% = 7 ' skip dividers
                MENU_BAR.pvwHover% = pvwNext%
                SOUND_play SND_MENU_HOVER
                MENU_BAR.kbActive%  = TRUE
                GUI_NEEDS_REDRAW%   = TRUE
                MENUBAR_handle_key% = TRUE
                EXIT FUNCTION

            CASE 19712 ' Right arrow - open Recent sub-submenu if on RECENT item
                IF MENU_BAR.pvwHover% = 9 AND RECENT_PREVIEW_COUNT% > 0 THEN
                    MENU_BAR.pvwRecentOpen%  = TRUE
                    MENU_BAR.pvwRecentHover% = 0
                    MENU_BAR.kbActive%       = TRUE
                    GUI_NEEDS_REDRAW%        = TRUE
                    MENUBAR_handle_key%      = TRUE
                    EXIT FUNCTION
                END IF

            CASE 13    ' Enter
                IF MENU_BAR.pvwHover% >= 0 THEN
                    ' Open Recent sub-submenu on Enter too
                    IF MENU_BAR.pvwHover% = 9 AND RECENT_PREVIEW_COUNT% > 0 THEN
                        MENU_BAR.pvwRecentOpen%  = TRUE
                        MENU_BAR.pvwRecentHover% = 0
                        MENU_BAR.kbActive%       = TRUE
                        GUI_NEEDS_REDRAW%        = TRUE
                        MENUBAR_handle_key%      = TRUE
                        EXIT FUNCTION
                    END IF
                    MENUBAR_close_all
                    SELECT CASE MENU_BAR.pvwHover%
                        CASE 0 : CMD_execute_action 434  ' Show/Hide Preview Window
                        CASE 2 : CMD_execute_action 2013 ' Follow Mode
                        CASE 3 : CMD_execute_action 2014 ' Floating Image Mode
                        CASE 5 : CMD_execute_action 2015 ' Bin Quick Look
                        CASE 6 : CMD_execute_action 2016 ' Allow Color Picking
                        CASE 8 : CMD_execute_action 2017 ' Load Image...
                    END SELECT
                END IF
                MENUBAR_handle_key% = TRUE
                EXIT FUNCTION

            CASE 19200, 27 ' Left arrow or Escape - close pvw submenu
                MENU_BAR.pvwOpen%        = FALSE
                MENU_BAR.pvwHover%       = -1
                MENU_BAR.pvwRecentOpen%  = FALSE
                MENU_BAR.pvwRecentHover% = -1
                MENU_BAR.kbActive%       = TRUE
                GUI_NEEDS_REDRAW%        = TRUE
                MENUBAR_handle_key%      = TRUE
                EXIT FUNCTION
        END SELECT
    END IF

    ' --- Recent submenu keyboard navigation ---
    IF MENU_BAR.recentOpen% AND RECENT_FILE_COUNT% > 0 THEN
        DIM recMax AS INTEGER
        recMax% = RECENT_FILE_COUNT% ' 0..count-1 = files, count = CLEAR
        SELECT CASE k&
            CASE 18432 ' Up arrow
                IF MENU_BAR.recentHover% <= 0 THEN
                    MENU_BAR.recentHover% = recMax% ' Wrap to CLEAR
                ELSE
                    MENU_BAR.recentHover% = MENU_BAR.recentHover% - 1
                END IF
                SOUND_play SND_MENU_HOVER
                MENU_BAR.kbActive%  = TRUE
                GUI_NEEDS_REDRAW%   = TRUE
                MENUBAR_handle_key% = TRUE
                EXIT FUNCTION

            CASE 20480 ' Down arrow
                IF MENU_BAR.recentHover% >= recMax% THEN
                    MENU_BAR.recentHover% = 0 ' Wrap to first file
                ELSE
                    MENU_BAR.recentHover% = MENU_BAR.recentHover% + 1
                END IF
                SOUND_play SND_MENU_HOVER
                MENU_BAR.kbActive%  = TRUE
                GUI_NEEDS_REDRAW%   = TRUE
                MENUBAR_handle_key% = TRUE
                EXIT FUNCTION

            CASE 13        ' Enter
                IF MENU_BAR.recentHover% >= 0 AND MENU_BAR.recentHover% < RECENT_FILE_COUNT% THEN
                    ' Load recent file
                    DIM recPath AS STRING
                    recPath$ = RECENT_FILES(MENU_BAR.recentHover% + 1)
                    MENUBAR_close_all

                    IF NOT _FILEEXISTS(recPath$) THEN
                        DIM rmb1 AS INTEGER
                        POINTER_hide_for_dialog
                        rmb1% = DRAW_message_box%("File Not Found", "File not found:" + CHR$(10) + recPath$ + CHR$(10) + CHR$(10) + "Remove from recent files?", MB_BTN_YES_NO, MB_ICON_WARNING)
                        POINTER_show_after_dialog
                        DO WHILE _MOUSEINPUT: LOOP
                        MOUSE_force_buttons_up
                        IF rmb1% = MB_RESULT_1 THEN
                            DIM rj   AS INTEGER
                            FOR rj% = (MENU_BAR.recentHover% + 1) TO RECENT_FILE_COUNT% - 1
                                RECENT_FILES(rj%) = RECENT_FILES(rj% + 1)
                            NEXT rj%
                            RECENT_FILES(RECENT_FILE_COUNT%) = ""
                            RECENT_FILE_COUNT% = RECENT_FILE_COUNT% - 1
                            CONFIG_save
                        END IF
                    ELSE
                        IF CANVAS_DIRTY% THEN
                            DIM rmb2 AS INTEGER
                            POINTER_hide_for_dialog
                            rmb2% = DRAW_message_box%("Unsaved Changes", "Save changes before opening?", MB_BTN_YES_NO_CANCEL, MB_ICON_WARNING)
                            POINTER_show_after_dialog
                            DO WHILE _MOUSEINPUT: LOOP
                            MOUSE_force_buttons_up
                            IF rmb2% = MB_RESULT_NONE OR rmb2% = MB_RESULT_3 THEN
                                MENUBAR_handle_key% = TRUE
                                EXIT FUNCTION
                            END IF
                            IF rmb2% = MB_RESULT_1 THEN
                                IF LEN(CURRENT_DRW_FILENAME$) > 0 THEN
                                    DRW_save_binary CURRENT_DRW_FILENAME$
                                ELSE
                                    DRW_save_dialog
                                END IF
                            END IF
                        END IF
                        IF FILE_ASE_is_aseprite_file%(recPath$) THEN
                            FILE_ASE_load recPath$
                        ELSEIF FILE_PSD_is_psd_file%(recPath$) THEN
                            FILE_PSD_load recPath$
                        ELSE
                            DRW_load recPath$
                            CURRENT_DRW_FILENAME$ = recPath$
                        END IF
                        CURRENT_FILENAME$ = recPath$
                        RECENT_add_file recPath$
                        CFG.LAST_DIR_OPEN$ = CONFIG_extract_dir$(recPath$)
                        CANVAS_DIRTY%      = FALSE
                    END IF
                ELSEIF MENU_BAR.recentHover% = RECENT_FILE_COUNT% THEN
                    ' CLEAR
                    DIM rmb3 AS INTEGER
                    POINTER_hide_for_dialog
                    rmb3% = DRAW_message_box%("Clear Recent Files", "Clear all recent files?", MB_BTN_YES_NO, MB_ICON_INFO)
                    POINTER_show_after_dialog
                    DO WHILE _MOUSEINPUT: LOOP
                    MOUSE_force_buttons_up
                    IF rmb3% = MB_RESULT_1 THEN RECENT_clear
                    MENUBAR_close_all
                END IF
                MENUBAR_handle_key% = TRUE
                EXIT FUNCTION

            CASE 19200, 27 ' Left arrow or Escape - close recent submenu
                MENU_BAR.recentOpen%  = FALSE
                MENU_BAR.recentHover% = -1
                MENU_BAR.kbActive%    = TRUE
                GUI_NEEDS_REDRAW%     = TRUE
                MENUBAR_handle_key%   = TRUE
                EXIT FUNCTION
        END SELECT
    END IF

    ' --- Random Track submenu keyboard navigation ---
    IF MENU_BAR.randomOpen% THEN
        SELECT CASE k&
            CASE 18432     ' Up arrow
                IF MENU_BAR.randomHover% <= 0 THEN
                    MENU_BAR.randomHover% = 5
                ELSE
                    MENU_BAR.randomHover% = MENU_BAR.randomHover% - 1
                END IF
                SOUND_play SND_MENU_HOVER
                MENU_BAR.kbActive%  = TRUE
                GUI_NEEDS_REDRAW%   = TRUE
                MENUBAR_handle_key% = TRUE
                EXIT FUNCTION

            CASE 20480     ' Down arrow
                IF MENU_BAR.randomHover% >= 5 THEN
                    MENU_BAR.randomHover% = 0
                ELSE
                    MENU_BAR.randomHover% = MENU_BAR.randomHover% + 1
                END IF
                SOUND_play SND_MENU_HOVER
                MENU_BAR.kbActive%  = TRUE
                GUI_NEEDS_REDRAW%   = TRUE
                MENUBAR_handle_key% = TRUE
                EXIT FUNCTION

            CASE 13        ' Enter
                IF MENU_BAR.randomHover% >= 0 AND MENU_BAR.randomHover% <= 5 THEN
                    MENUBAR_close_all
                    SELECT CASE MENU_BAR.randomHover%
                        CASE 0 : CMD_execute_action 429 ' .MOD
                        CASE 1 : CMD_execute_action 430 ' .IT
                        CASE 2 : CMD_execute_action 431 ' .XM
                        CASE 3 : CMD_execute_action 432 ' .RAD
                        CASE 4 : CMD_execute_action 460 ' .MID
                        CASE 5 : CMD_execute_action 461 ' .RMI
                    END SELECT
                END IF
                MENUBAR_handle_key% = TRUE
                EXIT FUNCTION

            CASE 19200, 27 ' Left arrow or Escape - close random submenu
                MENU_BAR.randomOpen%  = FALSE
                MENU_BAR.randomHover% = -1
                MENU_BAR.kbActive%    = TRUE
                GUI_NEEDS_REDRAW%     = TRUE
                MENUBAR_handle_key%   = TRUE
                EXIT FUNCTION
        END SELECT
    END IF

    ' --- Main menu keyboard navigation ---
    SELECT CASE k&
        CASE 19200 ' Left arrow
            ' Move to previous visible root menu (wrap around, skip disabled, skip overflow)
            DIM prevMenu AS INTEGER, prevLoops AS INTEGER
            prevMenu%  = MENU_BAR.openMenu%
            prevLoops% = 0
            DO
                prevMenu% = prevMenu% - 1
                IF prevMenu% < 0 THEN prevMenu% = MENU_ROOT_COUNT% - 1
                ' Skip overflow items — jump from first visible to HELP
                IF MENU_CHEVRON_ACTIVE% AND prevMenu% >= MENU_VISIBLE_COUNT% AND prevMenu% <> MENU_ROOT_COUNT% - 1 THEN
                    ' If we're going left past overflow, open the overflow popup instead
                    IF MENU_BAR.openMenu% = MENU_ROOT_COUNT% - 1 THEN
                        ' Going left from HELP -> open overflow popup
                        MENU_BAR.openMenu%   = -1
                        MENU_BAR.hoverSub%   = -1
                        MENU_OVERFLOW_OPEN%  = TRUE
                        MENU_OVERFLOW_HOVER% = (MENU_ROOT_COUNT% - 2) - MENU_VISIBLE_COUNT% ' last overflow item
                        MENU_BAR.kbActive%   = TRUE
                        GUI_NEEDS_REDRAW%    = TRUE
                        MENUBAR_handle_key%  = TRUE
                        EXIT FUNCTION
                    END IF
                    prevMenu% = MENU_VISIBLE_COUNT% - 1 ' Jump to last visible
                    IF prevMenu% < 0 THEN prevMenu% = MENU_ROOT_COUNT% - 1
                END IF
                prevLoops% = prevLoops% + 1
                IF prevLoops% > MENU_ROOT_COUNT% THEN EXIT DO ' All disabled
            LOOP UNTIL MENU_ROOT_ENABLED(prevMenu%)
            MENU_BAR.openMenu%  = prevMenu%
            MENU_BAR.hoverRoot% = MENU_BAR.openMenu%
            MENU_BAR.hoverSub%  = -1
            MENU_BAR.subScroll% = 0
            SOUND_play SND_MENU_OPEN
            MENU_BAR.kbActive%  = TRUE
            GUI_NEEDS_REDRAW%   = TRUE
            MENUBAR_handle_key% = TRUE

        CASE 19712 ' Right arrow
            ' Check if hovered item is RECENT - if so, open recent submenu
            IF MENU_BAR.hoverSub% = MENU_BAR.recentItemIdx% AND RECENT_FILE_COUNT% > 0 THEN
                MENU_BAR.recentOpen%  = TRUE
                MENU_BAR.recentHover% = 0
                MENU_BAR.kbActive%    = TRUE
                GUI_NEEDS_REDRAW%     = TRUE
                MENUBAR_handle_key%   = TRUE
            ELSEIF MENU_BAR.hoverSub% = MENU_BAR.randomItemIdx% THEN
                MENU_BAR.randomOpen%  = TRUE
                MENU_BAR.randomHover% = 0
                MENU_BAR.kbActive%    = TRUE
                GUI_NEEDS_REDRAW%     = TRUE
                MENUBAR_handle_key%   = TRUE
            ELSEIF MENU_BAR.hoverSub% = MENU_BAR.pvwItemIdx% THEN
                MENU_BAR.pvwOpen%   = TRUE
                MENU_BAR.pvwHover%  = 0
                MENU_BAR.kbActive%  = TRUE
                GUI_NEEDS_REDRAW%   = TRUE
                MENUBAR_handle_key% = TRUE
            ELSE
                ' Move to next visible root menu (wrap around, skip disabled, skip overflow)
                DIM nextMenu AS INTEGER, nextLoops AS INTEGER
                nextMenu%  = MENU_BAR.openMenu%
                nextLoops% = 0
                DO
                    nextMenu% = nextMenu% + 1
                    IF nextMenu% >= MENU_ROOT_COUNT% THEN nextMenu% = 0
                    ' Skip overflow items — jump from last visible to overflow popup
                    IF MENU_CHEVRON_ACTIVE% AND nextMenu% >= MENU_VISIBLE_COUNT% AND nextMenu% <> MENU_ROOT_COUNT% - 1 THEN
                        ' Going right past last visible -> open overflow popup
                        MENU_BAR.openMenu%   = -1
                        MENU_BAR.hoverSub%   = -1
                        MENU_OVERFLOW_OPEN%  = TRUE
                        MENU_OVERFLOW_HOVER% = 0 ' first overflow item
                        MENU_BAR.kbActive%   = TRUE
                        GUI_NEEDS_REDRAW%    = TRUE
                        MENUBAR_handle_key%  = TRUE
                        EXIT FUNCTION
                    END IF
                    nextLoops% = nextLoops% + 1
                    IF nextLoops% > MENU_ROOT_COUNT% THEN EXIT DO ' All disabled
                LOOP UNTIL MENU_ROOT_ENABLED(nextMenu%)
                MENU_BAR.openMenu%  = nextMenu%
                MENU_BAR.hoverRoot% = MENU_BAR.openMenu%
                MENU_BAR.hoverSub%  = -1
                MENU_BAR.subScroll% = 0
                SOUND_play SND_MENU_OPEN
                MENU_BAR.kbActive%  = TRUE
                GUI_NEEDS_REDRAW%   = TRUE
                MENUBAR_handle_key% = TRUE
            END IF

        CASE 18432 ' Up arrow
            ' Move up in submenu (skip dividers)
            MENUBAR_navigate_submenu -1
            MENUBAR_handle_key% = TRUE

        CASE 20480 ' Down arrow
            ' Move down in submenu (skip dividers)
            MENUBAR_navigate_submenu 1
            MENUBAR_handle_key% = TRUE

        CASE 13    ' Enter
            ' Execute hovered submenu item
            IF MENU_BAR.hoverSub% >= 0 THEN
                DIM childIdx2 AS INTEGER, itemIdx2 AS INTEGER
                childIdx2% = 0
                FOR itemIdx2% = 0 TO MENU_ITEM_COUNT% - 1
                    IF MENU_ITEMS(itemIdx2%).parentIdx% = MENU_BAR.openMenu% THEN
                        IF childIdx2% = MENU_BAR.hoverSub% THEN
                            IF NOT MENU_ITEMS(itemIdx2%).isDivider% AND MENU_ITEMS(itemIdx2%).enabled% THEN
                                ' Intercept RECENT item: open submenu instead
                                IF MENU_ITEMS(itemIdx2%).actionId% = 213 AND RECENT_FILE_COUNT% > 0 THEN
                                    MENU_BAR.recentOpen%  = TRUE
                                    MENU_BAR.recentHover% = 0
                                    MENU_BAR.kbActive%    = TRUE
                                    GUI_NEEDS_REDRAW%     = TRUE
                                    MENUBAR_handle_key%   = TRUE
                                    EXIT FUNCTION
                                END IF
                                IF MENU_ITEMS(itemIdx2%).actionId% = 2012 THEN
                                    MENU_BAR.pvwOpen%   = TRUE
                                    MENU_BAR.pvwHover%  = 0
                                    MENU_BAR.kbActive%  = TRUE
                                    GUI_NEEDS_REDRAW%   = TRUE
                                    MENUBAR_handle_key% = TRUE
                                    EXIT FUNCTION
                                END IF
                                IF MENU_ITEMS(itemIdx2%).hasCheckbox% THEN
                                    MENU_ITEMS(itemIdx2%).checked% = NOT MENU_ITEMS(itemIdx2%).checked%
                                END IF
                                DIM actId2 AS INTEGER
                                actId2% = MENU_ITEMS(itemIdx2%).actionId%
                                MENUBAR_close_all
                                IF actId2% > 0 THEN CMD_execute_action actId2%
                            END IF
                            MENUBAR_handle_key% = TRUE
                            EXIT FUNCTION
                        END IF
                        childIdx2% = childIdx2% + 1
                    END IF
                NEXT itemIdx2%
            END IF
            MENUBAR_handle_key% = TRUE

        CASE 27    ' Escape
            MENUBAR_close_all
            MENUBAR_handle_key% = TRUE

    END SELECT
END FUNCTION


''
' Navigate submenu up (-1) or down (+1), skipping dividers
' @param direction INTEGER Movement direction: -1 for up, +1 for down
'
SUB MENUBAR_navigate_submenu (direction AS INTEGER)
    DIM childIdx      AS INTEGER
    DIM i             AS INTEGER
    DIM totalChildren AS INTEGER

    ' Count ALL children (including dividers) and build a divider map
    totalChildren% = 0
    FOR i% = 0 TO MENU_ITEM_COUNT% - 1
        IF MENU_ITEMS(i%).parentIdx% = MENU_BAR.openMenu% THEN
            totalChildren% = totalChildren% + 1
        END IF
    NEXT i%

    IF totalChildren% = 0 THEN EXIT SUB

    ' Start from current position or edge
    DIM newPos AS INTEGER
    IF MENU_BAR.hoverSub% < 0 THEN
        IF direction% > 0 THEN
            newPos% = -1             ' Will be incremented to 0
        ELSE
            newPos% = totalChildren% ' Will be decremented to last
        END IF
    ELSE
        newPos% = MENU_BAR.hoverSub%
    END IF

    ' Move in direction, skipping dividers, with wrapping
    DIM attempts AS INTEGER
    attempts% = 0
    DO
        newPos% = newPos% + direction%
        ' Wrap around
        IF newPos% < 0 THEN newPos% = totalChildren% - 1
        IF newPos% >= totalChildren% THEN newPos% = 0

        ' Check if this position is a divider or disabled item
        childIdx% = 0
        DIM isDivider  AS INTEGER
        DIM isDisabled AS INTEGER
        isDivider%  = FALSE
        isDisabled% = FALSE
        FOR i% = 0 TO MENU_ITEM_COUNT% - 1
            IF MENU_ITEMS(i%).parentIdx% = MENU_BAR.openMenu% THEN
                IF childIdx% = newPos% THEN
                    isDivider%  = MENU_ITEMS(i%).isDivider%
                    isDisabled% = NOT MENU_ITEMS(i%).enabled%
                    EXIT FOR
                END IF
                childIdx% = childIdx% + 1
            END IF
        NEXT i%

        IF NOT isDivider% AND NOT isDisabled% THEN EXIT DO

        attempts% = attempts% + 1
        IF attempts% >= totalChildren% THEN EXIT DO  ' Safety: all dividers
    LOOP

    MENU_BAR.hoverSub% = newPos%
    IF MENUBAR_is_cascading_item%(MENU_BAR.hoverSub%) THEN
        SOUND_play SND_MENU_OPEN
    ELSE
        SOUND_play SND_MENU_HOVER
    END IF
    MENU_BAR.kbActive% = TRUE

    ' Scroll so the newly hovered item is visible in the viewport
    ' Compute virtual Y (content-space, from top of submenu) of the selected item
    DIM virtY  AS INTEGER, ci2 AS INTEGER, ii2 AS INTEGER
    virtY% = 2
    ci2%   = 0
    FOR ii2% = 0 TO MENU_ITEM_COUNT% - 1
        IF MENU_ITEMS(ii2%).parentIdx% = MENU_BAR.openMenu% THEN
            IF ci2% = newPos% THEN EXIT FOR
            IF MENU_ITEMS(ii2%).isDivider% THEN
                virtY% = virtY% + MENU_DIVIDER_HEIGHT
            ELSE
                virtY% = virtY% + MENU_ITEM_HEIGHT
            END IF
            ci2% = ci2% + 1
        END IF
    NEXT ii2%
    ' virtY% is the virtual top of the selected item
    ' Arrow rows reserve space at top/bottom when scrolled
    DIM arrowR AS INTEGER
    arrowR% = MENU_ITEM_HEIGHT
    ' Scroll up to reveal item above top
    IF virtY% - MENU_BAR.subScroll% < arrowR% THEN
        MENU_BAR.subScroll% = virtY% - arrowR%
        IF MENU_BAR.subScroll% < 0 THEN MENU_BAR.subScroll% = 0
    END IF
    ' Scroll down to reveal item below bottom
    DIM visH   AS INTEGER
    visH% = MENU_BAR.subH% - 4
    IF visH% < MENU_ITEM_HEIGHT THEN visH% = MENU_ITEM_HEIGHT
    IF virtY% + MENU_ITEM_HEIGHT - MENU_BAR.subScroll% > visH% - arrowR% THEN
        MENU_BAR.subScroll% = virtY% + MENU_ITEM_HEIGHT + arrowR% - visH%
        IF MENU_BAR.subScroll% < 0 THEN MENU_BAR.subScroll% = 0
    END IF

    GUI_NEEDS_REDRAW% = TRUE
END SUB


''
' Check if point is within the menu bar area
' @param rawX INTEGER Raw screen X coordinate to test
' @param rawY INTEGER Raw screen Y coordinate to test
' @return INTEGER - TRUE if the point is inside the menu bar bounds
'
FUNCTION MENUBAR_in_bounds% (rawX AS INTEGER, rawY AS INTEGER)
    IF NOT MENU_BAR.visible% THEN
        MENUBAR_in_bounds% = FALSE
        EXIT FUNCTION
    END IF
    MENUBAR_in_bounds% = (rawY% >= MENU_BAR.barY% AND rawY% < MENU_BAR.barY% + MENU_BAR.barH% _
        AND rawX% >= MENU_BAR.barX% AND rawX% < MENU_BAR.barX% + MENU_BAR.barW%)
END FUNCTION


''
' Check if point is within the open submenu area
' @param rawX INTEGER Raw screen X coordinate to test
' @param rawY INTEGER Raw screen Y coordinate to test
' @return INTEGER - TRUE if the point is inside the open submenu bounds
'
FUNCTION MENUBAR_submenu_in_bounds% (rawX AS INTEGER, rawY AS INTEGER)
    IF MENU_BAR.openMenu% < 0 THEN
        MENUBAR_submenu_in_bounds% = FALSE
        EXIT FUNCTION
    END IF
    MENUBAR_submenu_in_bounds% = (rawX% >= MENU_BAR.subX% AND rawX% < MENU_BAR.subX% + MENU_BAR.subW% _
        AND rawY% >= MENU_BAR.subY% AND rawY% < MENU_BAR.subY% + MENU_BAR.subH%)
END FUNCTION


''
' Check if any menu is open
' @return INTEGER - TRUE if a menu dropdown or overflow menu is open
'
FUNCTION MENUBAR_is_open% ()
    MENUBAR_is_open% = (MENU_BAR.openMenu% >= 0) OR MENU_OVERFLOW_OPEN%
END FUNCTION


''
' Get submenu item index at a given Y coordinate
' Returns the non-divider child index, or -1 if on a divider or outside
' @param rawY INTEGER Raw screen Y coordinate to look up
' @return INTEGER - Zero-based child index of the item at rawY, or -1 if on a divider/scroll arrow/outside
'
FUNCTION MENUBAR_get_submenu_item_at% (rawY AS INTEGER)
    DIM virtY       AS INTEGER, i AS INTEGER
    DIM childIdx    AS INTEGER
    DIM screenItemY AS INTEGER, itemH AS INTEGER

    ' Account for up-scroll arrow occupying the top row
    DIM arrowOffset AS INTEGER
    arrowOffset% = 0
    IF MENU_BAR.subScroll% > 0 THEN arrowOffset% = MENU_ITEM_HEIGHT

    ' Reject clicks in the scroll arrow rows
    ' Up arrow zone
    IF MENU_BAR.subScroll% > 0 THEN
        IF rawY% >= MENU_BAR.subY% AND rawY% < MENU_BAR.subY% + MENU_ITEM_HEIGHT + 2 THEN
            MENUBAR_get_submenu_item_at% = -1
            EXIT FUNCTION
        END IF
    END IF
    ' Down arrow zone — only block it when a down arrow is actually being shown
    IF MENU_BAR.subScroll% < MENU_BAR.subScrollMax% THEN
        IF rawY% >= MENU_BAR.subY% + MENU_BAR.subH% - MENU_ITEM_HEIGHT - 2 AND rawY% < MENU_BAR.subY% + MENU_BAR.subH% THEN
            MENUBAR_get_submenu_item_at% = -1
            EXIT FUNCTION
        END IF
    END IF

    virtY%    = 2
    childIdx% = 0

    FOR i% = 0 TO MENU_ITEM_COUNT% - 1
        IF MENU_ITEMS(i%).parentIdx% <> MENU_BAR.openMenu% THEN GOTO MENUBAR_next_at

        IF MENU_ITEMS(i%).isDivider% THEN
            itemH% = MENU_DIVIDER_HEIGHT
        ELSE
            itemH% = MENU_ITEM_HEIGHT
        END IF

        screenItemY% = MENU_BAR.subY% + virtY% - MENU_BAR.subScroll% + arrowOffset%

        IF NOT MENU_ITEMS(i%).isDivider% THEN
            IF rawY% >= screenItemY% AND rawY% < screenItemY% + MENU_ITEM_HEIGHT THEN
                MENUBAR_get_submenu_item_at% = childIdx%
                EXIT FUNCTION
            END IF
        END IF

        virtY% = virtY% + itemH%
        childIdx% = childIdx% + 1

        MENUBAR_next_at:
    NEXT i%

    MENUBAR_get_submenu_item_at% = -1
END FUNCTION


''
' Render the Recent Files cascading submenu
' Positioned to the right of the main File dropdown, aligned with the RECENT item
'
SUB MENUBAR_render_recent_submenu ()
    DIM i          AS INTEGER
    DIM subBg      AS _UNSIGNED LONG, subFg AS _UNSIGNED LONG
    DIM subBorder  AS _UNSIGNED LONG, subDivider AS _UNSIGNED LONG
    DIM subSelBg   AS _UNSIGNED LONG, subSelFg AS _UNSIGNED LONG
    DIM maxW       AS INTEGER, totalH AS INTEGER
    DIM itemY      AS INTEGER, fn AS STRING
    DIM totalItems AS INTEGER
    DIM maxHotkeyW AS INTEGER
    DIM fw         AS INTEGER
    DIM rhk        AS STRING
    DIM hkX        AS INTEGER

    ' Get theme colors (same as main submenu)
    subBg~&      = THEME.MENU_SUB_bg~&
    subFg~&      = THEME.MENU_SUB_fg~&
    subBorder~&  = THEME.MENU_SUB_border~&
    subDivider~& = THEME.MENU_SUB_divider~&
    subSelBg~&   = THEME.MENU_SUB_sel_bg~&
    subSelFg~&   = THEME.MENU_SUB_sel_fg~&

    ' totalItems = recent files + divider + CLEAR
    totalItems% = RECENT_FILE_COUNT% + 2

    ' Measure max filename width and hotkey column width
    maxHotkeyW% = _PRINTWIDTH("ALT+0")                          ' All hotkeys are same visual width
    maxW%       = _PRINTWIDTH("CLEAR RECENT")                   ' Minimum label width (CLEAR has no hotkey)
    FOR i% = 1 TO RECENT_FILE_COUNT%
        fn$ = RECENT_extract_filename$(RECENT_FILES(i%))
        fw% = _PRINTWIDTH(fn$)
        IF fw% > maxW% THEN maxW% = fw%
    NEXT i%

    ' Calculate dimensions (include hotkey column alongside filename column)
    MENU_BAR.recentW% = MENU_SUB_PAD_LEFT + maxW% + MENU_SUB_HOTKEY_GAP + maxHotkeyW% + MENU_SUB_PAD_RIGHT
    IF MENU_BAR.recentW% < 120 THEN MENU_BAR.recentW% = 120

    totalH% = 4                                                 ' Top/bottom padding
    totalH% = totalH% + (RECENT_FILE_COUNT% * MENU_ITEM_HEIGHT) ' File items
    totalH% = totalH% + MENU_DIVIDER_HEIGHT                     ' Divider
    totalH% = totalH% + MENU_ITEM_HEIGHT                        ' CLEAR item
    MENU_BAR.recentH% = totalH%

    ' Position to the right of the main submenu, aligned with RECENT item Y
    MENU_BAR.recentX% = MENU_BAR.subX% + MENU_BAR.subW%
    IF MENU_BAR.recentY% = 0 THEN
        MENU_BAR.recentY% = MENU_BAR.subY% ' Fallback
    END IF

    ' Clamp right edge to screen
    IF MENU_BAR.recentX% + MENU_BAR.recentW% > SCRN.w& THEN
        ' Place to the LEFT of the main submenu instead
        MENU_BAR.recentX% = MENU_BAR.subX% - MENU_BAR.recentW%
        IF MENU_BAR.recentX% < 0 THEN MENU_BAR.recentX% = 0
    END IF

    ' Clamp bottom to screen
    IF MENU_BAR.recentY% + MENU_BAR.recentH% > SCRN.h& THEN
        MENU_BAR.recentY% = SCRN.h& - MENU_BAR.recentH%
        IF MENU_BAR.recentY% < 0 THEN MENU_BAR.recentY% = 0
    END IF

    ' Draw border
    LINE (MENU_BAR.recentX% - 1, MENU_BAR.recentY% - 1)-(MENU_BAR.recentX% + MENU_BAR.recentW%, MENU_BAR.recentY% + MENU_BAR.recentH%), subBorder~&, BF

    ' Draw background
    LINE (MENU_BAR.recentX%, MENU_BAR.recentY%)-(MENU_BAR.recentX% + MENU_BAR.recentW% - 1, MENU_BAR.recentY% + MENU_BAR.recentH% - 1), subBg~&, BF

    ' Draw recent file items
    itemY% = MENU_BAR.recentY% + 2
    FOR i% = 1 TO RECENT_FILE_COUNT%
        fn$ = RECENT_extract_filename$(RECENT_FILES(i%))

        ' Hover highlight (recentHover is 0-based: 0..count-1 = files)
        IF (i% - 1) = MENU_BAR.recentHover% THEN
            LINE (MENU_BAR.recentX% + 1, itemY%)-(MENU_BAR.recentX% + MENU_BAR.recentW% - 2, itemY% + MENU_ITEM_HEIGHT - 1), subSelBg~&, BF
            COLOR subSelFg~&, _RGBA32(0, 0, 0, 0)
        ELSE
            COLOR subFg~&, _RGBA32(0, 0, 0, 0)
        END IF

        _UPRINTSTRING (MENU_BAR.recentX% + MENU_SUB_PAD_LEFT, itemY% + 2), fn$

        ' Draw hotkey right-aligned (ALT+1..ALT+9 for slots 1-9, ALT+0 for slot 10)
        IF i% <= 9 THEN
            rhk$ = "ALT+" + LTRIM$(STR$(i%))
        ELSE
            rhk$ = "ALT+0"
        END IF
        hkX% = MENU_BAR.recentX% + MENU_BAR.recentW% - _PRINTWIDTH(rhk$) - MENU_SUB_PAD_RIGHT
        _UPRINTSTRING (hkX%, itemY% + 2), rhk$

        itemY% = itemY% + MENU_ITEM_HEIGHT
    NEXT i%

    ' Draw divider
    DIM divY AS INTEGER
    divY% = itemY% + MENU_DIVIDER_HEIGHT \ 2
    LINE (MENU_BAR.recentX% + 4, divY%)-(MENU_BAR.recentX% + MENU_BAR.recentW% - 5, divY%), subDivider~&
    itemY% = itemY% + MENU_DIVIDER_HEIGHT

    ' Draw CLEAR item (recentHover = RECENT_FILE_COUNT% means CLEAR)
    IF MENU_BAR.recentHover% = RECENT_FILE_COUNT% THEN
        LINE (MENU_BAR.recentX% + 1, itemY%)-(MENU_BAR.recentX% + MENU_BAR.recentW% - 2, itemY% + MENU_ITEM_HEIGHT - 1), subSelBg~&, BF
        COLOR subSelFg~&, _RGBA32(0, 0, 0, 0)
    ELSE
        COLOR subFg~&, _RGBA32(0, 0, 0, 0)
    END IF
    _UPRINTSTRING (MENU_BAR.recentX% + MENU_SUB_PAD_LEFT, itemY% + 2), "CLEAR RECENT"
END SUB


''
' Handle click inside the recent files submenu
' @param rawX INTEGER Raw screen X coordinate of the click
' @param rawY INTEGER Raw screen Y coordinate of the click
'
SUB MENUBAR_handle_recent_click (rawX AS INTEGER, rawY AS INTEGER)
    IF NOT MENU_BAR.recentOpen% THEN EXIT SUB
    IF RECENT_FILE_COUNT% = 0 THEN EXIT SUB
    IF NOT MENUBAR_recent_in_bounds%(rawX%, rawY%) THEN EXIT SUB

    ' Determine which item was clicked
    DIM itemY AS INTEGER, i AS INTEGER
    itemY% = MENU_BAR.recentY% + 2

    ' Check file items
    FOR i% = 1 TO RECENT_FILE_COUNT%
        IF rawY% >= itemY% AND rawY% < itemY% + MENU_ITEM_HEIGHT THEN
            ' Clicked on recent file i%
            DIM filePath AS STRING
            filePath$ = RECENT_FILES(i%)
            MENUBAR_close_all

            ' Check if file exists
            IF NOT _FILEEXISTS(filePath$) THEN
                DIM mb1 AS INTEGER
                POINTER_hide_for_dialog
                mb1% = DRAW_message_box%("File Not Found", "File not found:" + CHR$(10) + filePath$ + CHR$(10) + CHR$(10) + "Remove from recent files?", MB_BTN_YES_NO, MB_ICON_WARNING)
                POINTER_show_after_dialog
                DO WHILE _MOUSEINPUT: LOOP
                MOUSE_force_buttons_up
                IF mb1% = MB_RESULT_1 THEN
                    ' Remove this entry by shifting down
                    DIM j AS INTEGER
                    FOR j% = i% TO RECENT_FILE_COUNT% - 1
                        RECENT_FILES(j%) = RECENT_FILES(j% + 1)
                    NEXT j%
                    RECENT_FILES(RECENT_FILE_COUNT%) = ""
                    RECENT_FILE_COUNT% = RECENT_FILE_COUNT% - 1
                    CONFIG_save
                END IF
                EXIT SUB
            END IF

            ' Prompt to save if dirty
            IF CANVAS_DIRTY% THEN
                DIM mb2 AS INTEGER
                POINTER_hide_for_dialog
                mb2% = DRAW_message_box%("Unsaved Changes", "Save changes before opening?", MB_BTN_YES_NO_CANCEL, MB_ICON_WARNING)
                POINTER_show_after_dialog
                DO WHILE _MOUSEINPUT: LOOP
                MOUSE_force_buttons_up
                IF mb2% = MB_RESULT_NONE OR mb2% = MB_RESULT_3 THEN EXIT SUB ' Cancel
                IF mb2% = MB_RESULT_1 THEN          ' Yes - save first
                    IF LEN(CURRENT_DRW_FILENAME$) > 0 THEN
                        DRW_save_binary CURRENT_DRW_FILENAME$
                    ELSE
                        DRW_save_dialog
                    END IF
                END IF
                ' mb2% = 2 = No, proceed without saving
            END IF

            ' Load the file
            IF FILE_ASE_is_aseprite_file%(filePath$) THEN
                FILE_ASE_load filePath$
            ELSEIF FILE_PSD_is_psd_file%(filePath$) THEN
                FILE_PSD_load filePath$
            ELSE
                DRW_load filePath$
                CURRENT_DRW_FILENAME$ = filePath$
            END IF
            CURRENT_FILENAME$ = filePath$
            RECENT_add_file filePath$
            CFG.LAST_DIR_OPEN$ = CONFIG_extract_dir$(filePath$)
            CANVAS_DIRTY%      = FALSE
            EXIT SUB
        END IF
        itemY% = itemY% + MENU_ITEM_HEIGHT
    NEXT i%

    ' Skip divider area
    itemY% = itemY% + MENU_DIVIDER_HEIGHT

    ' Check CLEAR item
    IF rawY% >= itemY% AND rawY% < itemY% + MENU_ITEM_HEIGHT THEN
        DIM mb3 AS INTEGER
        POINTER_hide_for_dialog
        mb3% = DRAW_message_box%("Clear Recent Files", "Clear all recent files?", MB_BTN_YES_NO, MB_ICON_INFO)
        POINTER_show_after_dialog
        DO WHILE _MOUSEINPUT: LOOP
        MOUSE_force_buttons_up
        IF mb3% = MB_RESULT_1 THEN
            RECENT_clear
        END IF
        MENUBAR_close_all
        EXIT SUB
    END IF
END SUB


''
' Check if a point is within the recent files submenu bounds
' @param rawX INTEGER Raw screen X coordinate to test
' @param rawY INTEGER Raw screen Y coordinate to test
' @return INTEGER - TRUE if the point is inside the recent files submenu
'
FUNCTION MENUBAR_recent_in_bounds% (rawX AS INTEGER, rawY AS INTEGER)
    IF NOT MENU_BAR.recentOpen% OR RECENT_FILE_COUNT% = 0 THEN
        MENUBAR_recent_in_bounds% = FALSE
        EXIT FUNCTION
    END IF
    MENUBAR_recent_in_bounds% = (rawX% >= MENU_BAR.recentX% AND rawX% < MENU_BAR.recentX% + MENU_BAR.recentW% _
        AND rawY% >= MENU_BAR.recentY% AND rawY% < MENU_BAR.recentY% + MENU_BAR.recentH%)
END FUNCTION


''
' Render the overflow popup showing hidden root menu labels
'
SUB MENUBAR_render_overflow_popup ()
    IF NOT MENU_CHEVRON_ACTIVE% THEN EXIT SUB

    DIM helpIdx3  AS INTEGER
    DIM ovCount   AS INTEGER, i AS INTEGER, y AS INTEGER
    DIM ovLbl     AS STRING, ovW AS INTEGER, ovMaxW AS INTEGER
    DIM subBg     AS _UNSIGNED LONG, subFg AS _UNSIGNED LONG
    DIM subBorder AS _UNSIGNED LONG, subSelBg AS _UNSIGNED LONG
    DIM subSelFg  AS _UNSIGNED LONG

    helpIdx3% = MENU_ROOT_COUNT% - 1

    ' Count overflow items and measure widths
    ovCount% = 0
    ovMaxW%  = 0
    FOR i% = MENU_VISIBLE_COUNT% TO helpIdx3% - 1
        ovLbl$ = RTRIM$(MENU_ROOT_LABEL(i%))
        ovW%   = _PRINTWIDTH(ovLbl$)
        IF ovW% > ovMaxW% THEN ovMaxW% = ovW%
        ovCount% = ovCount% + 1
    NEXT i%
    IF ovCount% = 0 THEN EXIT SUB

    ' Theme colors
    subBg~&     = THEME.MENU_SUB_bg~&
    subFg~&     = THEME.MENU_SUB_fg~&
    subBorder~& = THEME.MENU_SUB_border~&
    subSelBg~&  = THEME.MENU_SUB_sel_bg~&
    subSelFg~&  = THEME.MENU_SUB_sel_fg~&

    ' Calculate popup dimensions
    DIM popW AS INTEGER, popH AS INTEGER
    popW% = MENU_SUB_PAD_LEFT + ovMaxW% + MENU_SUB_PAD_RIGHT
    IF popW% < 60 THEN popW% = 60
    popH% = 4 + (ovCount% * MENU_ITEM_HEIGHT) ' 2px top + 2px bottom padding

    ' Position below the chevron
    MENU_OVERFLOW_X% = MENU_CHEVRON_X%
    MENU_OVERFLOW_Y% = MENU_BAR.barY% + MENU_BAR.barH%
    MENU_OVERFLOW_W% = popW%
    MENU_OVERFLOW_H% = popH%

    ' Clamp right edge to screen
    IF MENU_OVERFLOW_X% + MENU_OVERFLOW_W% > SCRN.w& THEN
        MENU_OVERFLOW_X% = SCRN.w& - MENU_OVERFLOW_W%
        IF MENU_OVERFLOW_X% < 0 THEN MENU_OVERFLOW_X% = 0
    END IF

    ' Draw border
    LINE (MENU_OVERFLOW_X% - 1, MENU_OVERFLOW_Y% - 1)-(MENU_OVERFLOW_X% + MENU_OVERFLOW_W%, MENU_OVERFLOW_Y% + MENU_OVERFLOW_H%), subBorder~&, BF

    ' Draw background
    LINE (MENU_OVERFLOW_X%, MENU_OVERFLOW_Y%)-(MENU_OVERFLOW_X% + MENU_OVERFLOW_W% - 1, MENU_OVERFLOW_Y% + MENU_OVERFLOW_H% - 1), subBg~&, BF

    ' Draw overflow items
    y% = MENU_OVERFLOW_Y% + 2
    DIM ovIdx AS INTEGER
    ovIdx% = 0
    FOR i% = MENU_VISIBLE_COUNT% TO helpIdx3% - 1
        ovLbl$ = RTRIM$(MENU_ROOT_LABEL(i%))

        IF ovIdx% = MENU_OVERFLOW_HOVER% THEN
            LINE (MENU_OVERFLOW_X% + 1, y%)-(MENU_OVERFLOW_X% + MENU_OVERFLOW_W% - 2, y% + MENU_ITEM_HEIGHT - 1), subSelBg~&, BF
            COLOR subSelFg~&, _RGBA32(0, 0, 0, 0)
        ELSEIF NOT MENU_ROOT_ENABLED(i%) THEN
            COLOR THEME.MENU_BAR_disabled_fg~&, _RGBA32(0, 0, 0, 0)
        ELSE
            COLOR subFg~&, _RGBA32(0, 0, 0, 0)
        END IF

        _UPRINTSTRING (MENU_OVERFLOW_X% + MENU_SUB_PAD_LEFT, y% + 2), ovLbl$
        y% = y% + MENU_ITEM_HEIGHT
        ovIdx% = ovIdx% + 1
    NEXT i%
END SUB


''
' Check if a point is within the overflow popup bounds
' @param rawX INTEGER Raw screen X coordinate to test
' @param rawY INTEGER Raw screen Y coordinate to test
' @return INTEGER - TRUE if the point is inside the overflow popup
'
FUNCTION MENUBAR_overflow_in_bounds% (rawX AS INTEGER, rawY AS INTEGER)
    IF NOT MENU_OVERFLOW_OPEN% OR NOT MENU_CHEVRON_ACTIVE% THEN
        MENUBAR_overflow_in_bounds% = FALSE
        EXIT FUNCTION
    END IF
    MENUBAR_overflow_in_bounds% = (rawX% >= MENU_OVERFLOW_X% AND rawX% < MENU_OVERFLOW_X% + MENU_OVERFLOW_W% _
        AND rawY% >= MENU_OVERFLOW_Y% AND rawY% < MENU_OVERFLOW_Y% + MENU_OVERFLOW_H%)
END FUNCTION


''
' Handle click inside the overflow popup
' @param rawX INTEGER Raw screen X coordinate of the click
' @param rawY INTEGER Raw screen Y coordinate of the click
'
SUB MENUBAR_handle_overflow_click (rawX AS INTEGER, rawY AS INTEGER)
    IF NOT MENU_OVERFLOW_OPEN% OR NOT MENU_CHEVRON_ACTIVE% THEN EXIT SUB
    IF NOT MENUBAR_overflow_in_bounds%(rawX%, rawY%) THEN EXIT SUB

    ' Determine which overflow item was clicked
    DIM helpIdx4 AS INTEGER, i AS INTEGER, ovIdx AS INTEGER, itemY AS INTEGER
    helpIdx4% = MENU_ROOT_COUNT% - 1
    itemY%    = MENU_OVERFLOW_Y% + 2
    ovIdx%    = 0

    FOR i% = MENU_VISIBLE_COUNT% TO helpIdx4% - 1
        IF rawY% >= itemY% AND rawY% < itemY% + MENU_ITEM_HEIGHT THEN
            IF MENU_ROOT_ENABLED(i%) THEN
                ' Close overflow popup and open this root menu's submenu
                MENU_OVERFLOW_OPEN%  = FALSE
                MENU_OVERFLOW_HOVER% = -1
                MENU_BAR.openMenu%   = i%
                MENU_BAR.hoverRoot%  = i%
                MENU_BAR.hoverSub%   = -1
                MENU_BAR.subScroll%  = 0
                MENU_BAR.stayOpen%   = TRUE
                IF PALETTE_MENU_VISIBLE% THEN PALETTE_MENU_hide
                GUI_NEEDS_REDRAW% = TRUE
            END IF
            EXIT SUB
        END IF
        itemY% = itemY% + MENU_ITEM_HEIGHT
        ovIdx% = ovIdx% + 1
    NEXT i%
END SUB

''
' Render the Random Track cascading submenu (4 format options)
'
SUB MENUBAR_render_random_submenu ()
    DIM randBg     AS _UNSIGNED LONG
    DIM randFg     AS _UNSIGNED LONG
    DIM randBrd    AS _UNSIGNED LONG
    DIM randSBg    AS _UNSIGNED LONG
    DIM randSFg    AS _UNSIGNED LONG
    DIM randItemY  AS INTEGER
    DIM randTotalH AS INTEGER
    DIM randMaxW   AS INTEGER, randFw AS INTEGER
    DIM randI      AS INTEGER

    ' Label strings for the 6 format items (indices 0-5)
    DIM randLabels(0 TO 5) AS STRING
    randLabels(0) = ".MOD"
    randLabels(1) = ".IT"
    randLabels(2) = ".XM"
    randLabels(3) = ".RAD"
    randLabels(4) = ".MID"
    randLabels(5) = ".RMI"

    randBg~&  = THEME.MENU_SUB_bg~&
    randFg~&  = THEME.MENU_SUB_fg~&
    randBrd~& = THEME.MENU_SUB_border~&
    randSBg~& = THEME.MENU_SUB_sel_bg~&
    randSFg~& = THEME.MENU_SUB_sel_fg~&

    ' Measure width
    randMaxW% = 0
    FOR randI% = 0 TO 5
        randFw% = _PRINTWIDTH(randLabels(randI%))
        IF randFw% > randMaxW% THEN randMaxW% = randFw%
    NEXT randI%
    MENU_BAR.randomW% = MENU_SUB_PAD_LEFT + randMaxW% + MENU_SUB_PAD_RIGHT
    IF MENU_BAR.randomW% < 80 THEN MENU_BAR.randomW% = 80

    randTotalH%       = 4 + (6 * MENU_ITEM_HEIGHT)
    MENU_BAR.randomH% = randTotalH%

    ' Position to the right of the main submenu, aligned with RANDOM TRACK item Y
    MENU_BAR.randomX% = MENU_BAR.subX% + MENU_BAR.subW%
    IF MENU_BAR.randomY% = 0 THEN MENU_BAR.randomY% = MENU_BAR.subY%

    ' Clamp right edge to screen
    IF MENU_BAR.randomX% + MENU_BAR.randomW% > SCRN.w& THEN
        MENU_BAR.randomX% = MENU_BAR.subX% - MENU_BAR.randomW%
        IF MENU_BAR.randomX% < 0 THEN MENU_BAR.randomX% = 0
    END IF

    ' Clamp bottom to screen
    IF MENU_BAR.randomY% + MENU_BAR.randomH% > SCRN.h& THEN
        MENU_BAR.randomY% = SCRN.h& - MENU_BAR.randomH%
        IF MENU_BAR.randomY% < 0 THEN MENU_BAR.randomY% = 0
    END IF

    ' Draw border and background
    LINE (MENU_BAR.randomX% - 1, MENU_BAR.randomY% - 1)-(MENU_BAR.randomX% + MENU_BAR.randomW%, MENU_BAR.randomY% + MENU_BAR.randomH%), randBrd~&, BF
    LINE (MENU_BAR.randomX%, MENU_BAR.randomY%)-(MENU_BAR.randomX% + MENU_BAR.randomW% - 1, MENU_BAR.randomY% + MENU_BAR.randomH% - 1), randBg~&, BF

    ' Draw the 6 format items
    randItemY% = MENU_BAR.randomY% + 2
    FOR randI% = 0 TO 5
        IF randI% = MENU_BAR.randomHover% THEN
            LINE (MENU_BAR.randomX% + 1, randItemY%)-(MENU_BAR.randomX% + MENU_BAR.randomW% - 2, randItemY% + MENU_ITEM_HEIGHT - 1), randSBg~&, BF
            COLOR randSFg~&, _RGBA32(0, 0, 0, 0)
        ELSE
            COLOR randFg~&, _RGBA32(0, 0, 0, 0)
        END IF
        _UPRINTSTRING (MENU_BAR.randomX% + MENU_SUB_PAD_LEFT, randItemY% + 2), randLabels(randI%)
        randItemY% = randItemY% + MENU_ITEM_HEIGHT
    NEXT randI%
END SUB


''
' Handle a click inside the random track submenu
' @param rawX INTEGER Raw screen X coordinate of the click
' @param rawY INTEGER Raw screen Y coordinate of the click
'
SUB MENUBAR_handle_random_click (rawX AS INTEGER, rawY AS INTEGER)
    IF NOT MENU_BAR.randomOpen% THEN EXIT SUB
    IF NOT MENUBAR_random_in_bounds%(rawX%, rawY%) THEN EXIT SUB

    ' Determine which format item was clicked (0=MOD, 1=IT, 2=XM, 3=RAD)
    DIM rClickY AS INTEGER
    rClickY% = MENU_BAR.randomY% + 2
    DIM rIdx    AS INTEGER
    FOR rIdx% = 0 TO 5
        IF rawY% >= rClickY% AND rawY% < rClickY% + MENU_ITEM_HEIGHT THEN
            MENUBAR_close_all
            SELECT CASE rIdx%
                CASE 0 : CMD_execute_action 429 ' .MOD
                CASE 1 : CMD_execute_action 430 ' .IT
                CASE 2 : CMD_execute_action 431 ' .XM
                CASE 3 : CMD_execute_action 432 ' .RAD
                CASE 4 : CMD_execute_action 460 ' .MID
                CASE 5 : CMD_execute_action 461 ' .RMI
            END SELECT
            EXIT SUB
        END IF
        rClickY% = rClickY% + MENU_ITEM_HEIGHT
    NEXT rIdx%
END SUB


''
' Check if a point is within the random track submenu bounds
' @param rawX INTEGER Raw screen X coordinate to test
' @param rawY INTEGER Raw screen Y coordinate to test
' @return INTEGER - TRUE if the point is inside the random track submenu
'
FUNCTION MENUBAR_random_in_bounds% (rawX AS INTEGER, rawY AS INTEGER)
    IF NOT MENU_BAR.randomOpen% THEN
        MENUBAR_random_in_bounds% = FALSE
        EXIT FUNCTION
    END IF
    MENUBAR_random_in_bounds% = (rawX% >= MENU_BAR.randomX% AND rawX% < MENU_BAR.randomX% + MENU_BAR.randomW% _
        AND rawY% >= MENU_BAR.randomY% AND rawY% < MENU_BAR.randomY% + MENU_BAR.randomH%)
END FUNCTION


''
' Render the Transform cascading submenu
'
SUB MENUBAR_render_transform_submenu ()
    DIM trBg     AS _UNSIGNED LONG
    DIM trFg     AS _UNSIGNED LONG
    DIM trBrd    AS _UNSIGNED LONG
    DIM trSBg    AS _UNSIGNED LONG
    DIM trSFg    AS _UNSIGNED LONG
    DIM trItemY  AS INTEGER
    DIM trTotalH AS INTEGER
    DIM trMaxW   AS INTEGER, trFw AS INTEGER
    DIM trI      AS INTEGER

    DIM trLabels(0 TO 4) AS STRING
    trLabels(0) = "SCALE..."
    trLabels(1) = "DISTORT..."
    trLabels(2) = "PERSPECTIVE..."
    trLabels(3) = "ROTATE..."
    trLabels(4) = "SHEAR..."

    trBg~&  = THEME.MENU_SUB_bg~&
    trFg~&  = THEME.MENU_SUB_fg~&
    trBrd~& = THEME.MENU_SUB_border~&
    trSBg~& = THEME.MENU_SUB_sel_bg~&
    trSFg~& = THEME.MENU_SUB_sel_fg~&

    ' Measure width
    trMaxW% = 0
    FOR trI% = 0 TO 4
        trFw% = _PRINTWIDTH(trLabels(trI%))
        IF trFw% > trMaxW% THEN trMaxW% = trFw%
    NEXT trI%
    MENU_BAR.transformW% = MENU_SUB_PAD_LEFT + trMaxW% + MENU_SUB_PAD_RIGHT
    IF MENU_BAR.transformW% < 100 THEN MENU_BAR.transformW% = 100

    trTotalH%            = 4 + (5 * MENU_ITEM_HEIGHT)
    MENU_BAR.transformH% = trTotalH%

    ' Position to the right of the main submenu, aligned with TRANSFORM... item Y
    MENU_BAR.transformX% = MENU_BAR.subX% + MENU_BAR.subW%
    IF MENU_BAR.transformY% = 0 THEN MENU_BAR.transformY% = MENU_BAR.subY%

    ' Clamp right edge to screen
    IF MENU_BAR.transformX% + MENU_BAR.transformW% > SCRN.w& THEN
        MENU_BAR.transformX% = MENU_BAR.subX% - MENU_BAR.transformW%
        IF MENU_BAR.transformX% < 0 THEN MENU_BAR.transformX% = 0
    END IF

    ' Clamp bottom to screen
    IF MENU_BAR.transformY% + MENU_BAR.transformH% > SCRN.h& THEN
        MENU_BAR.transformY% = SCRN.h& - MENU_BAR.transformH%
        IF MENU_BAR.transformY% < 0 THEN MENU_BAR.transformY% = 0
    END IF

    ' Draw border and background
    LINE (MENU_BAR.transformX% - 1, MENU_BAR.transformY% - 1)-(MENU_BAR.transformX% + MENU_BAR.transformW%, MENU_BAR.transformY% + MENU_BAR.transformH%), trBrd~&, BF
    LINE (MENU_BAR.transformX%, MENU_BAR.transformY%)-(MENU_BAR.transformX% + MENU_BAR.transformW% - 1, MENU_BAR.transformY% + MENU_BAR.transformH% - 1), trBg~&, BF

    ' Draw the 5 transform items
    trItemY% = MENU_BAR.transformY% + 2
    FOR trI% = 0 TO 4
        IF trI% = MENU_BAR.transformHover% THEN
            LINE (MENU_BAR.transformX% + 1, trItemY%)-(MENU_BAR.transformX% + MENU_BAR.transformW% - 2, trItemY% + MENU_ITEM_HEIGHT - 1), trSBg~&, BF
            COLOR trSFg~&, _RGBA32(0, 0, 0, 0)
        ELSE
            COLOR trFg~&, _RGBA32(0, 0, 0, 0)
        END IF
        _UPRINTSTRING (MENU_BAR.transformX% + MENU_SUB_PAD_LEFT, trItemY% + 2), trLabels(trI%)
        trItemY% = trItemY% + MENU_ITEM_HEIGHT
    NEXT trI%
END SUB


''
' Handle a click inside the transform submenu
' @param rawX INTEGER Raw screen X coordinate of the click
' @param rawY INTEGER Raw screen Y coordinate of the click
'
SUB MENUBAR_handle_transform_click (rawX AS INTEGER, rawY AS INTEGER)
    IF NOT MENU_BAR.transformOpen% THEN EXIT SUB
    IF NOT MENUBAR_transform_in_bounds%(rawX%, rawY%) THEN EXIT SUB

    DIM tClickY AS INTEGER
    tClickY% = MENU_BAR.transformY% + 2
    DIM tIdx    AS INTEGER
    FOR tIdx% = 0 TO 4
        IF rawY% >= tClickY% AND rawY% < tClickY% + MENU_ITEM_HEIGHT THEN
            MENUBAR_close_all
            SELECT CASE tIdx%
                CASE 0 : CMD_execute_action TRANSFORM_ACT_SCALE
                CASE 1 : CMD_execute_action TRANSFORM_ACT_DISTORT
                CASE 2 : CMD_execute_action TRANSFORM_ACT_PERSPECTIVE
                CASE 3 : CMD_execute_action TRANSFORM_ACT_ROTATE
                CASE 4 : CMD_execute_action TRANSFORM_ACT_SHEAR
            END SELECT
            EXIT SUB
        END IF
        tClickY% = tClickY% + MENU_ITEM_HEIGHT
    NEXT tIdx%
END SUB


''
' Check if a point is within the transform submenu bounds
' @param rawX INTEGER Raw screen X coordinate to test
' @param rawY INTEGER Raw screen Y coordinate to test
' @return INTEGER - TRUE if the point is inside the transform submenu
'
FUNCTION MENUBAR_transform_in_bounds% (rawX AS INTEGER, rawY AS INTEGER)
    IF NOT MENU_BAR.transformOpen% THEN
        MENUBAR_transform_in_bounds% = FALSE
        EXIT FUNCTION
    END IF
    MENUBAR_transform_in_bounds% = (rawX% >= MENU_BAR.transformX% AND rawX% < MENU_BAR.transformX% + MENU_BAR.transformW% _
        AND rawY% >= MENU_BAR.transformY% AND rawY% < MENU_BAR.transformY% + MENU_BAR.transformH%)
END FUNCTION


''
' Render the Layout cascading submenu
'
SUB MENUBAR_render_layout_submenu ()
    DIM lyBg     AS _UNSIGNED LONG
    DIM lyFg     AS _UNSIGNED LONG
    DIM lyBrd    AS _UNSIGNED LONG
    DIM lySBg    AS _UNSIGNED LONG
    DIM lySFg    AS _UNSIGNED LONG
    DIM lyDis    AS _UNSIGNED LONG
    DIM lyItemY  AS INTEGER
    DIM lyTotalH AS INTEGER
    DIM lyMaxW   AS INTEGER, lyFw AS INTEGER
    DIM lyI      AS INTEGER

    CONST LAYOUT_ITEM_COUNT = 10

    DIM lyLabels(0 TO LAYOUT_ITEM_COUNT - 1) AS STRING
    lyLabels(0) = CHR$(251) + " TOOLBOX LEFT"
    lyLabels(1) = CHR$(251) + " TOOLBOX RIGHT"
    lyLabels(2) = CHR$(251) + " LAYER PANEL LEFT"
    lyLabels(3) = CHR$(251) + " LAYER PANEL RIGHT"
    lyLabels(4) = CHR$(251) + " EDIT BAR LEFT"
    lyLabels(5) = CHR$(251) + " EDIT BAR RIGHT"
    lyLabels(6) = CHR$(251) + " CHARACTER MAP LEFT"
    lyLabels(7) = CHR$(251) + " CHARACTER MAP RIGHT"
    lyLabels(8) = CHR$(251) + " ADVANCED BAR LEFT"
    lyLabels(9) = CHR$(251) + " ADVANCED BAR RIGHT"

    ' Determine which items are currently active (checked + grayed)
    DIM lyChecked(0 TO LAYOUT_ITEM_COUNT - 1) AS INTEGER
    lyChecked(0) = (UCASE$(_TRIM$(CFG.TOOLBOX_DOCK_EDGE)) = "LEFT")
    lyChecked(1) = (UCASE$(_TRIM$(CFG.TOOLBOX_DOCK_EDGE)) = "RIGHT")
    lyChecked(2) = (UCASE$(_TRIM$(CFG.LAYERS_PANEL_DOCK_EDGE)) = "LEFT")
    lyChecked(3) = (UCASE$(_TRIM$(CFG.LAYERS_PANEL_DOCK_EDGE)) = "RIGHT")
    lyChecked(4) = (EDIT_BAR.dockSide% = EDITBAR_DOCK_LEFT)
    lyChecked(5) = (EDIT_BAR.dockSide% = EDITBAR_DOCK_RIGHT)
    lyChecked(6) = (CHARMAP.dockSide% = CHARMAP_DOCK_LEFT)
    lyChecked(7) = (CHARMAP.dockSide% = CHARMAP_DOCK_RIGHT)
    lyChecked(8) = (ADV_BAR.dockSide% = ADVBAR_DOCK_LEFT)
    lyChecked(9) = (ADV_BAR.dockSide% = ADVBAR_DOCK_RIGHT)

    ' Update labels: show checkmark for active, space for inactive
    FOR lyI% = 0 TO LAYOUT_ITEM_COUNT - 1
        IF lyChecked(lyI%) THEN
            lyLabels(lyI%) = CHR$(251) + MID$(lyLabels(lyI%), 2)
        ELSE
            lyLabels(lyI%) = " " + MID$(lyLabels(lyI%), 2)
        END IF
    NEXT lyI%

    lyBg~&  = THEME.MENU_SUB_bg~&
    lyFg~&  = THEME.MENU_SUB_fg~&
    lyBrd~& = THEME.MENU_SUB_border~&
    lySBg~& = THEME.MENU_SUB_sel_bg~&
    lySFg~& = THEME.MENU_SUB_sel_fg~&
    ' Disabled/grayed color — midpoint between bg and fg
    lyDis~& = _RGB32((_RED32(lyFg~&) + _RED32(lyBg~&)) \ 2, (_GREEN32(lyFg~&) + _GREEN32(lyBg~&)) \ 2, (_BLUE32(lyFg~&) + _BLUE32(lyBg~&)) \ 2)

    ' Measure width — include shortcut hint text
    DIM lyHint$
    lyHint$ = "Ctrl+Shift+L-Click"
    lyMaxW% = 0
    FOR lyI% = 0 TO LAYOUT_ITEM_COUNT - 1
        lyFw% = _PRINTWIDTH(lyLabels(lyI%)) + _PRINTWIDTH("  " + lyHint$)
        IF lyFw% > lyMaxW% THEN lyMaxW% = lyFw%
    NEXT lyI%
    MENU_BAR.layoutW% = MENU_SUB_PAD_LEFT + lyMaxW% + MENU_SUB_PAD_RIGHT
    IF MENU_BAR.layoutW% < 160 THEN MENU_BAR.layoutW% = 160

    lyTotalH%         = 4 + (LAYOUT_ITEM_COUNT * MENU_ITEM_HEIGHT)
    MENU_BAR.layoutH% = lyTotalH%

    ' Position to the right of the main submenu, aligned with LAYOUT item Y
    MENU_BAR.layoutX% = MENU_BAR.subX% + MENU_BAR.subW%
    IF MENU_BAR.layoutY% = 0 THEN MENU_BAR.layoutY% = MENU_BAR.subY%

    ' Clamp right edge to screen
    IF MENU_BAR.layoutX% + MENU_BAR.layoutW% > SCRN.w& THEN
        MENU_BAR.layoutX% = MENU_BAR.subX% - MENU_BAR.layoutW%
        IF MENU_BAR.layoutX% < 0 THEN MENU_BAR.layoutX% = 0
    END IF

    ' Clamp bottom to screen
    IF MENU_BAR.layoutY% + MENU_BAR.layoutH% > SCRN.h& THEN
        MENU_BAR.layoutY% = SCRN.h& - MENU_BAR.layoutH%
        IF MENU_BAR.layoutY% < 0 THEN MENU_BAR.layoutY% = 0
    END IF

    ' Draw border and background
    LINE (MENU_BAR.layoutX% - 1, MENU_BAR.layoutY% - 1)-(MENU_BAR.layoutX% + MENU_BAR.layoutW%, MENU_BAR.layoutY% + MENU_BAR.layoutH%), lyBrd~&, BF
    LINE (MENU_BAR.layoutX%, MENU_BAR.layoutY%)-(MENU_BAR.layoutX% + MENU_BAR.layoutW% - 1, MENU_BAR.layoutY% + MENU_BAR.layoutH% - 1), lyBg~&, BF

    ' Draw the 6 layout items
    lyItemY% = MENU_BAR.layoutY% + 2
    FOR lyI% = 0 TO LAYOUT_ITEM_COUNT - 1
        DIM lyItemFg AS _UNSIGNED LONG
        IF lyChecked(lyI%) THEN
            ' Currently active — show as grayed (disabled)
            lyItemFg~& = lyDis~&
            IF lyI% = MENU_BAR.layoutHover% THEN
                LINE (MENU_BAR.layoutX% + 1, lyItemY%)-(MENU_BAR.layoutX% + MENU_BAR.layoutW% - 2, lyItemY% + MENU_ITEM_HEIGHT - 1), lySBg~&, BF
            END IF
            COLOR lyItemFg~&, _RGBA32(0, 0, 0, 0)
        ELSE
            IF lyI% = MENU_BAR.layoutHover% THEN
                LINE (MENU_BAR.layoutX% + 1, lyItemY%)-(MENU_BAR.layoutX% + MENU_BAR.layoutW% - 2, lyItemY% + MENU_ITEM_HEIGHT - 1), lySBg~&, BF
                COLOR lySFg~&, _RGBA32(0, 0, 0, 0)
            ELSE
                COLOR lyFg~&, _RGBA32(0, 0, 0, 0)
            END IF
        END IF
        _UPRINTSTRING (MENU_BAR.layoutX% + MENU_SUB_PAD_LEFT, lyItemY% + 2), lyLabels(lyI%)
        ' Draw shortcut hint right-aligned
        DIM lyHintW  AS INTEGER
        lyHintW% = _PRINTWIDTH(lyHint$)
        COLOR lyDis~&, _RGBA32(0, 0, 0, 0)
        _UPRINTSTRING (MENU_BAR.layoutX% + MENU_BAR.layoutW% - MENU_SUB_PAD_RIGHT - lyHintW%, lyItemY% + 2), lyHint$
        lyItemY% = lyItemY% + MENU_ITEM_HEIGHT
    NEXT lyI%
END SUB


''
' Handle a click inside the layout submenu
' @param rawX INTEGER Raw screen X coordinate of the click
' @param rawY INTEGER Raw screen Y coordinate of the click
'
SUB MENUBAR_handle_layout_click (rawX AS INTEGER, rawY AS INTEGER)
    IF NOT MENU_BAR.layoutOpen% THEN EXIT SUB
    IF NOT MENUBAR_layout_in_bounds%(rawX%, rawY%) THEN EXIT SUB

    DIM lClickY AS INTEGER
    lClickY% = MENU_BAR.layoutY% + 2
    DIM lIdx    AS INTEGER
    FOR lIdx% = 0 TO 9
        IF rawY% >= lClickY% AND rawY% < lClickY% + MENU_ITEM_HEIGHT THEN
            MENUBAR_close_all
            SELECT CASE lIdx%
                CASE 0 : CMD_execute_action 443
                CASE 1 : CMD_execute_action 444
                CASE 2 : CMD_execute_action 445
                CASE 3 : CMD_execute_action 446
                CASE 4 : CMD_execute_action 447
                CASE 5 : CMD_execute_action 448
                CASE 6 : CMD_execute_action 2051
                CASE 7 : CMD_execute_action 2052
                CASE 8 : CMD_execute_action 450
                CASE 9 : CMD_execute_action 451
            END SELECT
            EXIT SUB
        END IF
        lClickY% = lClickY% + MENU_ITEM_HEIGHT
    NEXT lIdx%
END SUB


''
' Check if a point is within the layout submenu bounds
' @param rawX INTEGER Raw screen X coordinate to test
' @param rawY INTEGER Raw screen Y coordinate to test
' @return INTEGER - TRUE if the point is inside the layout submenu
'
FUNCTION MENUBAR_layout_in_bounds% (rawX AS INTEGER, rawY AS INTEGER)
    IF NOT MENU_BAR.layoutOpen% THEN
        MENUBAR_layout_in_bounds% = FALSE
        EXIT FUNCTION
    END IF
    MENUBAR_layout_in_bounds% = (rawX% >= MENU_BAR.layoutX% AND rawX% < MENU_BAR.layoutX% + MENU_BAR.layoutW% _
        AND rawY% >= MENU_BAR.layoutY% AND rawY% < MENU_BAR.layoutY% + MENU_BAR.layoutH%)
END FUNCTION


''
' Check if a submenu child item (by child index) is enabled
' Used to gate hover sounds and highlight for disabled items
' @param childPosition INTEGER Zero-based child index within the currently open submenu
' @return INTEGER - TRUE if the item at childPosition is enabled
'
FUNCTION MENUBAR_is_sub_item_enabled% (childPosition AS INTEGER)
    IF childPosition% < 0 THEN MENUBAR_is_sub_item_enabled% = FALSE     : EXIT FUNCTION
    IF MENU_BAR.openMenu% < 0 THEN MENUBAR_is_sub_item_enabled% = FALSE : EXIT FUNCTION
    DIM ci AS INTEGER, mi AS INTEGER
    ci% = 0
    FOR mi% = 0 TO MENU_ITEM_COUNT% - 1
        IF MENU_ITEMS(mi%).parentIdx% = MENU_BAR.openMenu% THEN
            IF ci% = childPosition% THEN
                MENUBAR_is_sub_item_enabled% = MENU_ITEMS(mi%).enabled%
                EXIT FUNCTION
            END IF
            ci% = ci% + 1
        END IF
    NEXT mi%
    MENUBAR_is_sub_item_enabled% = FALSE
END FUNCTION


''
' Check if a submenu child item is a cascading submenu item in the CURRENTLY open menu
' Returns TRUE only when the child index matches a cascading item AND the open menu
' is the parent that owns that cascading item.
' @param childPosition INTEGER Zero-based child index within the currently open submenu
' @return INTEGER - TRUE if the item opens a cascading child submenu
'
FUNCTION MENUBAR_is_cascading_item% (childPosition AS INTEGER)
    IF childPosition% < 0 OR MENU_BAR.openMenu% < 0 THEN
        MENUBAR_is_cascading_item% = FALSE
        EXIT FUNCTION
    END IF
    ' RECENT (action 213) -> FILE (parent 0)
    IF childPosition% = MENU_BAR.recentItemIdx% AND MENU_BAR.openMenu% = 0 THEN
        MENUBAR_is_cascading_item% = TRUE
        EXIT FUNCTION
    END IF
    ' TRANSFORM... (action 331) -> EDIT (parent 1)
    IF childPosition% = MENU_BAR.transformItemIdx% AND MENU_BAR.openMenu% = 1 THEN
        MENUBAR_is_cascading_item% = TRUE
        EXIT FUNCTION
    END IF
    ' LAYOUT (action 442) -> VIEW (parent 2)
    IF childPosition% = MENU_BAR.layoutItemIdx% AND MENU_BAR.openMenu% = 2 THEN
        MENUBAR_is_cascading_item% = TRUE
        EXIT FUNCTION
    END IF
    ' PREVIEW WINDOW (action 2012) -> VIEW (parent 2)
    IF childPosition% = MENU_BAR.pvwItemIdx% AND MENU_BAR.openMenu% = 2 THEN
        MENUBAR_is_cascading_item% = TRUE
        EXIT FUNCTION
    END IF
    ' RANDOM TRACK (action 433) -> AUDIO (parent 10)
    IF childPosition% = MENU_BAR.randomItemIdx% AND MENU_BAR.openMenu% = 10 THEN
        MENUBAR_is_cascading_item% = TRUE
        EXIT FUNCTION
    END IF
    ' EXPORT AS... (action EXPORT_ACT_FLYOUT) -> FILE (parent 0)
    IF childPosition% = MENU_BAR.exportItemIdx% AND MENU_BAR.openMenu% = 0 THEN
        MENUBAR_is_cascading_item% = TRUE
        EXIT FUNCTION
    END IF
    MENUBAR_is_cascading_item% = FALSE
END FUNCTION


''
' Render the Preview Window cascading submenu
' Items: 0=Show/Hide, 1=divider, 2=Follow Mode, 3=Floating Image Mode,
'        4=divider, 5=Bin Quick Look, 6=Allow Color Picking, 7=divider,
'        8=Load Image..., 9=Recent ->
'
SUB MENUBAR_render_pvw_submenu ()
    DIM pvBg     AS _UNSIGNED LONG
    DIM pvFg     AS _UNSIGNED LONG
    DIM pvBrd    AS _UNSIGNED LONG
    DIM pvDiv    AS _UNSIGNED LONG
    DIM pvSBg    AS _UNSIGNED LONG
    DIM pvSFg    AS _UNSIGNED LONG
    DIM pvDis    AS _UNSIGNED LONG
    DIM pvItemY  AS INTEGER
    DIM pvTotalH AS INTEGER
    DIM pvMaxW   AS INTEGER, pvFw AS INTEGER
    DIM pvI      AS INTEGER

    CONST PVW_MENU_ITEMS = 10

    DIM pvLabels(0 TO PVW_MENU_ITEMS - 1) AS STRING
    IF PREVIEW.visible% AND NOT PREVIEW.autoHidden% THEN
        pvLabels(0) = " HIDE PREVIEW WINDOW      F4"
    ELSE
        pvLabels(0) = " SHOW PREVIEW WINDOW      F4"
    END IF
    pvLabels(1) = "---"
    pvLabels(2) = " FOLLOW MODE"
    pvLabels(3) = " FLOATING IMAGE MODE"
    pvLabels(4) = "---"
    pvLabels(5) = " BIN QUICK LOOK"
    pvLabels(6) = " ALLOW COLOR PICKING"
    pvLabels(7) = "---"
    pvLabels(8) = " LOAD IMAGE..."
    pvLabels(9) = " RECENT " + CHR$(16)

    ' Determine checked state
    DIM pvChecked(0 TO PVW_MENU_ITEMS - 1) AS INTEGER
    pvChecked(2) = (CFG.PREVIEW_MODE% = PREVIEW_MODE_FOLLOW)
    pvChecked(3) = (CFG.PREVIEW_MODE% = PREVIEW_MODE_FLOAT)
    pvChecked(5) = CFG.PREVIEW_BIN_QUICK_LOOK%
    pvChecked(6) = CFG.PREVIEW_COLOR_PICK%

    ' Update labels with checkmark or space
    FOR pvI% = 0 TO PVW_MENU_ITEMS - 1
        IF pvI% = 0 OR pvI% = 1 OR pvI% = 4 OR pvI% = 7 OR pvI% = 8 OR pvI% = 9 THEN GOTO pvw_render_skip_check
        IF pvChecked(pvI%) THEN
            pvLabels(pvI%) = CHR$(251) + MID$(pvLabels(pvI%), 2)
        END IF
        pvw_render_skip_check:
    NEXT pvI%

    pvBg~&  = THEME.MENU_SUB_bg~&
    pvFg~&  = THEME.MENU_SUB_fg~&
    pvBrd~& = THEME.MENU_SUB_border~&
    pvDiv~& = THEME.MENU_SUB_divider~&
    pvSBg~& = THEME.MENU_SUB_sel_bg~&
    pvSFg~& = THEME.MENU_SUB_sel_fg~&
    pvDis~& = _RGB32((_RED32(pvFg~&) + _RED32(pvBg~&)) \ 2, (_GREEN32(pvFg~&) + _GREEN32(pvBg~&)) \ 2, (_BLUE32(pvFg~&) + _BLUE32(pvBg~&)) \ 2)

    ' Measure width
    pvMaxW% = 0
    FOR pvI% = 0 TO PVW_MENU_ITEMS - 1
        IF pvI% = 1 OR pvI% = 4 OR pvI% = 7 THEN GOTO pvw_render_skip_width
        pvFw% = _PRINTWIDTH(pvLabels(pvI%))
        IF pvFw% > pvMaxW% THEN pvMaxW% = pvFw%
        pvw_render_skip_width:
    NEXT pvI%
    MENU_BAR.pvwW% = MENU_SUB_PAD_LEFT + pvMaxW% + MENU_SUB_PAD_RIGHT
    IF MENU_BAR.pvwW% < 160 THEN MENU_BAR.pvwW% = 160

    ' Calculate height: 7 regular items + 3 dividers
    pvTotalH%      = 4 + (7 * MENU_ITEM_HEIGHT) + (3 * MENU_DIVIDER_HEIGHT)
    MENU_BAR.pvwH% = pvTotalH%

    ' Position to the right of the main submenu, aligned with PREVIEW WINDOW item Y
    ' pvwY% is already set to the correct item Y by MENUBAR_render_submenu (line 928)
    MENU_BAR.pvwX% = MENU_BAR.subX% + MENU_BAR.subW%

    ' Clamp right edge to screen
    IF MENU_BAR.pvwX% + MENU_BAR.pvwW% > SCRN.w& THEN
        MENU_BAR.pvwX% = MENU_BAR.subX% - MENU_BAR.pvwW%
        IF MENU_BAR.pvwX% < 0 THEN MENU_BAR.pvwX% = 0
    END IF

    ' Clamp bottom to screen
    IF MENU_BAR.pvwY% + MENU_BAR.pvwH% > SCRN.h& THEN
        MENU_BAR.pvwY% = SCRN.h& - MENU_BAR.pvwH%
        IF MENU_BAR.pvwY% < 0 THEN MENU_BAR.pvwY% = 0
    END IF

    ' Draw border and background
    LINE (MENU_BAR.pvwX% - 1, MENU_BAR.pvwY% - 1)-(MENU_BAR.pvwX% + MENU_BAR.pvwW%, MENU_BAR.pvwY% + MENU_BAR.pvwH%), pvBrd~&, BF
    LINE (MENU_BAR.pvwX%, MENU_BAR.pvwY%)-(MENU_BAR.pvwX% + MENU_BAR.pvwW% - 1, MENU_BAR.pvwY% + MENU_BAR.pvwH% - 1), pvBg~&, BF

    ' Draw items
    pvItemY% = MENU_BAR.pvwY% + 2
    FOR pvI% = 0 TO PVW_MENU_ITEMS - 1
        ' Dividers
        IF pvI% = 1 OR pvI% = 4 OR pvI% = 7 THEN
            DIM pvDivY    AS INTEGER
            pvDivY% = pvItemY% + MENU_DIVIDER_HEIGHT \ 2
            LINE (MENU_BAR.pvwX% + 4, pvDivY%)-(MENU_BAR.pvwX% + MENU_BAR.pvwW% - 5, pvDivY%), pvDiv~&
            pvItemY% = pvItemY% + MENU_DIVIDER_HEIGHT
        ELSE
            DIM pvItemFg  AS _UNSIGNED LONG
            DIM pvEnabled AS INTEGER
            ' LOAD IMAGE is only enabled in Floating Image mode
            IF pvI% = 8 THEN
                pvEnabled% = (CFG.PREVIEW_MODE% = PREVIEW_MODE_FLOAT)
            ' RECENT is only enabled when count > 0
            ELSEIF pvI% = 9 THEN
                pvEnabled% = (RECENT_PREVIEW_COUNT% > 0)
            ELSE
                pvEnabled% = TRUE
            END IF

            IF NOT pvEnabled% THEN
                pvItemFg~& = pvDis~&
                IF pvI% = MENU_BAR.pvwHover% THEN
                    LINE (MENU_BAR.pvwX% + 1, pvItemY%)-(MENU_BAR.pvwX% + MENU_BAR.pvwW% - 2, pvItemY% + MENU_ITEM_HEIGHT - 1), pvSBg~&, BF
                END IF
                COLOR pvItemFg~&, _RGBA32(0, 0, 0, 0)
            ELSEIF pvI% = MENU_BAR.pvwHover% THEN
                LINE (MENU_BAR.pvwX% + 1, pvItemY%)-(MENU_BAR.pvwX% + MENU_BAR.pvwW% - 2, pvItemY% + MENU_ITEM_HEIGHT - 1), pvSBg~&, BF
                COLOR pvSFg~&, _RGBA32(0, 0, 0, 0)
            ELSE
                COLOR pvFg~&, _RGBA32(0, 0, 0, 0)
            END IF
            _UPRINTSTRING (MENU_BAR.pvwX% + MENU_SUB_PAD_LEFT, pvItemY% + 2), pvLabels(pvI%)

            ' Track RECENT item Y for sub-submenu positioning
            IF pvI% = 9 THEN
                MENU_BAR.pvwRecentItemIdx% = pvI%
                MENU_BAR.pvwRecentY%       = pvItemY%
            END IF

            pvItemY% = pvItemY% + MENU_ITEM_HEIGHT
        END IF
    NEXT pvI%
END SUB


''
' Handle click inside the Preview Window submenu
' @param rawX INTEGER Raw screen X coordinate of the click
' @param rawY INTEGER Raw screen Y coordinate of the click
'
SUB MENUBAR_handle_pvw_click (rawX AS INTEGER, rawY AS INTEGER)
    IF NOT MENU_BAR.pvwOpen% THEN EXIT SUB
    IF NOT MENUBAR_pvw_in_bounds%(rawX%, rawY%) THEN EXIT SUB

    DIM pvClickY AS INTEGER
    pvClickY% = MENU_BAR.pvwY% + 2
    DIM pvClickI AS INTEGER
    FOR pvClickI% = 0 TO 9
        ' Skip dividers
        IF pvClickI% = 1 OR pvClickI% = 4 OR pvClickI% = 7 THEN
            pvClickY% = pvClickY% + MENU_DIVIDER_HEIGHT
        ELSE
            IF rawY% >= pvClickY% AND rawY% < pvClickY% + MENU_ITEM_HEIGHT THEN
                ' Found the clicked item
                SELECT CASE pvClickI%
                    CASE 9
                        ' Toggle Recent sub-submenu
                        MENU_BAR.pvwRecentOpen% = NOT MENU_BAR.pvwRecentOpen%
                        IF NOT MENU_BAR.pvwRecentOpen% THEN
                            MENU_BAR.pvwRecentHover% = -1
                        END IF
                        GUI_NEEDS_REDRAW% = TRUE
                        EXIT SUB
                    CASE 8
                        ' Load Image - only if enabled (floating mode)
                        IF CFG.PREVIEW_MODE% <> PREVIEW_MODE_FLOAT THEN EXIT SUB
                        MENUBAR_close_all
                        CMD_execute_action 2017
                        EXIT SUB
                    CASE ELSE
                        MENUBAR_close_all
                        SELECT CASE pvClickI%
                            CASE 0 : CMD_execute_action 434  ' Show/Hide Preview Window
                            CASE 2 : CMD_execute_action 2013 ' Follow Mode
                            CASE 3 : CMD_execute_action 2014 ' Floating Image Mode
                            CASE 5 : CMD_execute_action 2015 ' Bin Quick Look
                            CASE 6 : CMD_execute_action 2016 ' Allow Color Picking
                        END SELECT
                        EXIT SUB
                END SELECT
            END IF
            pvClickY% = pvClickY% + MENU_ITEM_HEIGHT
        END IF
    NEXT pvClickI%
END SUB


''
' Check if a point is within the Preview Window submenu bounds
' @param rawX INTEGER Raw screen X coordinate to test
' @param rawY INTEGER Raw screen Y coordinate to test
' @return INTEGER - TRUE if the point is inside the preview window submenu
'
FUNCTION MENUBAR_pvw_in_bounds% (rawX AS INTEGER, rawY AS INTEGER)
    IF NOT MENU_BAR.pvwOpen% THEN
        MENUBAR_pvw_in_bounds% = FALSE
        EXIT FUNCTION
    END IF
    MENUBAR_pvw_in_bounds% = (rawX% >= MENU_BAR.pvwX% AND rawX% < MENU_BAR.pvwX% + MENU_BAR.pvwW% _
        AND rawY% >= MENU_BAR.pvwY% AND rawY% < MENU_BAR.pvwY% + MENU_BAR.pvwH%)
END FUNCTION


''
' Render the Preview Window > Recent cascading sub-submenu
'
SUB MENUBAR_render_pvw_recent_submenu ()
    DIM prI          AS INTEGER
    DIM prBg         AS _UNSIGNED LONG, prFg AS _UNSIGNED LONG
    DIM prBorder     AS _UNSIGNED LONG, prDivider AS _UNSIGNED LONG
    DIM prSelBg      AS _UNSIGNED LONG, prSelFg AS _UNSIGNED LONG
    DIM prMaxW       AS INTEGER, prTotalH AS INTEGER
    DIM prItemY      AS INTEGER, prFn AS STRING
    DIM prTotalItems AS INTEGER
    DIM prFw         AS INTEGER

    prBg~&      = THEME.MENU_SUB_bg~&
    prFg~&      = THEME.MENU_SUB_fg~&
    prBorder~&  = THEME.MENU_SUB_border~&
    prDivider~& = THEME.MENU_SUB_divider~&
    prSelBg~&   = THEME.MENU_SUB_sel_bg~&
    prSelFg~&   = THEME.MENU_SUB_sel_fg~&

    ' totalItems = recent files + divider + CLEAR
    prTotalItems% = RECENT_PREVIEW_COUNT% + 2

    ' Measure max filename width (no hotkeys for preview recent)
    prMaxW% = _PRINTWIDTH("CLEAR RECENT")
    FOR prI% = 1 TO RECENT_PREVIEW_COUNT%
        prFn$ = RECENT_extract_filename$(RECENT_PREVIEW_FILES(prI%))
        prFw% = _PRINTWIDTH(prFn$)
        IF prFw% > prMaxW% THEN prMaxW% = prFw%
    NEXT prI%

    MENU_BAR.pvwRecentW% = MENU_SUB_PAD_LEFT + prMaxW% + MENU_SUB_PAD_RIGHT
    IF MENU_BAR.pvwRecentW% < 120 THEN MENU_BAR.pvwRecentW% = 120

    prTotalH% = 4
    prTotalH% = prTotalH% + (RECENT_PREVIEW_COUNT% * MENU_ITEM_HEIGHT)
    prTotalH% = prTotalH% + MENU_DIVIDER_HEIGHT
    prTotalH% = prTotalH% + MENU_ITEM_HEIGHT
    MENU_BAR.pvwRecentH% = prTotalH%

    ' Position to the right of the pvw submenu, aligned with RECENT item Y
    ' pvwRecentY% is already set to the RECENT item's Y by MENUBAR_render_pvw_submenu
    MENU_BAR.pvwRecentX% = MENU_BAR.pvwX% + MENU_BAR.pvwW%

    ' Clamp right edge to screen
    IF MENU_BAR.pvwRecentX% + MENU_BAR.pvwRecentW% > SCRN.w& THEN
        MENU_BAR.pvwRecentX% = MENU_BAR.pvwX% - MENU_BAR.pvwRecentW%
        IF MENU_BAR.pvwRecentX% < 0 THEN MENU_BAR.pvwRecentX% = 0
    END IF

    ' Clamp bottom to screen
    IF MENU_BAR.pvwRecentY% + MENU_BAR.pvwRecentH% > SCRN.h& THEN
        MENU_BAR.pvwRecentY% = SCRN.h& - MENU_BAR.pvwRecentH%
        IF MENU_BAR.pvwRecentY% < 0 THEN MENU_BAR.pvwRecentY% = 0
    END IF

    ' Draw border
    LINE (MENU_BAR.pvwRecentX% - 1, MENU_BAR.pvwRecentY% - 1)-(MENU_BAR.pvwRecentX% + MENU_BAR.pvwRecentW%, MENU_BAR.pvwRecentY% + MENU_BAR.pvwRecentH%), prBorder~&, BF

    ' Draw background
    LINE (MENU_BAR.pvwRecentX%, MENU_BAR.pvwRecentY%)-(MENU_BAR.pvwRecentX% + MENU_BAR.pvwRecentW% - 1, MENU_BAR.pvwRecentY% + MENU_BAR.pvwRecentH% - 1), prBg~&, BF

    ' Draw recent preview file items
    prItemY% = MENU_BAR.pvwRecentY% + 2
    FOR prI% = 1 TO RECENT_PREVIEW_COUNT%
        prFn$ = RECENT_extract_filename$(RECENT_PREVIEW_FILES(prI%))

        IF (prI% - 1) = MENU_BAR.pvwRecentHover% THEN
            LINE (MENU_BAR.pvwRecentX% + 1, prItemY%)-(MENU_BAR.pvwRecentX% + MENU_BAR.pvwRecentW% - 2, prItemY% + MENU_ITEM_HEIGHT - 1), prSelBg~&, BF
            COLOR prSelFg~&, _RGBA32(0, 0, 0, 0)
        ELSE
            COLOR prFg~&, _RGBA32(0, 0, 0, 0)
        END IF

        _UPRINTSTRING (MENU_BAR.pvwRecentX% + MENU_SUB_PAD_LEFT, prItemY% + 2), prFn$
        prItemY% = prItemY% + MENU_ITEM_HEIGHT
    NEXT prI%

    ' Draw divider
    DIM prDivY AS INTEGER
    prDivY% = prItemY% + MENU_DIVIDER_HEIGHT \ 2
    LINE (MENU_BAR.pvwRecentX% + 4, prDivY%)-(MENU_BAR.pvwRecentX% + MENU_BAR.pvwRecentW% - 5, prDivY%), prDivider~&
    prItemY% = prItemY% + MENU_DIVIDER_HEIGHT

    ' Draw CLEAR item
    IF MENU_BAR.pvwRecentHover% = RECENT_PREVIEW_COUNT% THEN
        LINE (MENU_BAR.pvwRecentX% + 1, prItemY%)-(MENU_BAR.pvwRecentX% + MENU_BAR.pvwRecentW% - 2, prItemY% + MENU_ITEM_HEIGHT - 1), prSelBg~&, BF
        COLOR prSelFg~&, _RGBA32(0, 0, 0, 0)
    ELSE
        COLOR prFg~&, _RGBA32(0, 0, 0, 0)
    END IF
    _UPRINTSTRING (MENU_BAR.pvwRecentX% + MENU_SUB_PAD_LEFT, prItemY% + 2), "CLEAR RECENT"
END SUB


''
' Handle click inside the Preview Window Recent sub-submenu
' @param rawX INTEGER Raw screen X coordinate of the click
' @param rawY INTEGER Raw screen Y coordinate of the click
'
SUB MENUBAR_handle_pvw_recent_click (rawX AS INTEGER, rawY AS INTEGER)
    IF NOT MENU_BAR.pvwRecentOpen% THEN EXIT SUB
    IF RECENT_PREVIEW_COUNT% = 0 THEN EXIT SUB
    IF NOT MENUBAR_pvw_recent_in_bounds%(rawX%, rawY%) THEN EXIT SUB

    DIM prClickY AS INTEGER, prClickI AS INTEGER
    prClickY% = MENU_BAR.pvwRecentY% + 2

    ' Check file items
    FOR prClickI% = 1 TO RECENT_PREVIEW_COUNT%
        IF rawY% >= prClickY% AND rawY% < prClickY% + MENU_ITEM_HEIGHT THEN
            DIM prClickPath AS STRING
            prClickPath$ = RECENT_PREVIEW_FILES(prClickI%)
            MENUBAR_close_all

            IF NOT _FILEEXISTS(prClickPath$) THEN
                DIM prMb1 AS INTEGER
                POINTER_hide_for_dialog
                prMb1% = DRAW_message_box%("File Not Found", "File not found:" + CHR$(10) + prClickPath$ + CHR$(10) + CHR$(10) + "Remove from recent images?", MB_BTN_YES_NO, MB_ICON_WARNING)
                POINTER_show_after_dialog
                DO WHILE _MOUSEINPUT: LOOP
                MOUSE_force_buttons_up
                IF prMb1% = MB_RESULT_1 THEN
                    DIM prJ AS INTEGER
                    FOR prJ% = prClickI% TO RECENT_PREVIEW_COUNT% - 1
                        RECENT_PREVIEW_FILES(prJ%) = RECENT_PREVIEW_FILES(prJ% + 1)
                    NEXT prJ%
                    RECENT_PREVIEW_FILES(RECENT_PREVIEW_COUNT%) = ""
                    RECENT_PREVIEW_COUNT% = RECENT_PREVIEW_COUNT% - 1
                    CONFIG_save
                END IF
                EXIT SUB
            END IF

            ' Load this image as floating preview
            CFG.PREVIEW_MODE% = PREVIEW_MODE_FLOAT
            PREVIEW_set_floating_mode
            PREVIEW_load_floating_image prClickPath$
            EXIT SUB
        END IF
        prClickY% = prClickY% + MENU_ITEM_HEIGHT
    NEXT prClickI%

    ' Skip divider area
    prClickY% = prClickY% + MENU_DIVIDER_HEIGHT

    ' Check CLEAR item
    IF rawY% >= prClickY% AND rawY% < prClickY% + MENU_ITEM_HEIGHT THEN
        DIM prMb2 AS INTEGER
        POINTER_hide_for_dialog
        prMb2% = DRAW_message_box%("Clear Recent Images", "Clear all recent preview images?", MB_BTN_YES_NO, MB_ICON_INFO)
        POINTER_show_after_dialog
        DO WHILE _MOUSEINPUT: LOOP
        MOUSE_force_buttons_up
        IF prMb2% = MB_RESULT_1 THEN
            RECENT_PREVIEW_clear
        END IF
        MENUBAR_close_all
        EXIT SUB
    END IF
END SUB


''
' Check if a point is within the Preview Window Recent sub-submenu bounds
' @param rawX INTEGER Raw screen X coordinate to test
' @param rawY INTEGER Raw screen Y coordinate to test
' @return INTEGER - TRUE if the point is inside the preview recent sub-submenu
'
FUNCTION MENUBAR_pvw_recent_in_bounds% (rawX AS INTEGER, rawY AS INTEGER)
    IF NOT MENU_BAR.pvwRecentOpen% OR RECENT_PREVIEW_COUNT% = 0 THEN
        MENUBAR_pvw_recent_in_bounds% = FALSE
        EXIT FUNCTION
    END IF
    MENUBAR_pvw_recent_in_bounds% = (rawX% >= MENU_BAR.pvwRecentX% AND rawX% < MENU_BAR.pvwRecentX% + MENU_BAR.pvwRecentW% _
        AND rawY% >= MENU_BAR.pvwRecentY% AND rawY% < MENU_BAR.pvwRecentY% + MENU_BAR.pvwRecentH%)
END FUNCTION


''
' Render the Export As cascading submenu
' 17 format items, some disabled (not yet implemented)
'
SUB MENUBAR_render_export_submenu ()
    DIM exBg     AS _UNSIGNED LONG
    DIM exFg     AS _UNSIGNED LONG
    DIM exBrd    AS _UNSIGNED LONG
    DIM exSBg    AS _UNSIGNED LONG
    DIM exSFg    AS _UNSIGNED LONG
    DIM exItemY  AS INTEGER
    DIM exTotalH AS INTEGER
    DIM exMaxW   AS INTEGER, exFw AS INTEGER
    DIM exI      AS INTEGER

    DIM exLabels(0 TO EXPORT_FLYOUT_ITEMS - 1) AS STRING
    exLabels(0) = "PNG (DRAW NATIVE)"
    exLabels(1) = "PNG"
    exLabels(2) = "GIF"
    exLabels(3) = "JPG"
    exLabels(4) = "TGA"
    exLabels(5) = "BMP"
    exLabels(6) = "HDR"
    exLabels(7) = "ICO"
    exLabels(8) = "QOI"

    exBg~&  = THEME.MENU_SUB_bg~&
    exFg~&  = THEME.MENU_SUB_fg~&
    exBrd~& = THEME.MENU_SUB_border~&
    exSBg~& = THEME.MENU_SUB_sel_bg~&
    exSFg~& = THEME.MENU_SUB_sel_fg~&

    ' Measure width
    exMaxW% = 0
    FOR exI% = 0 TO EXPORT_FLYOUT_ITEMS - 1
        exFw% = _PRINTWIDTH(exLabels(exI%))
        IF exFw% > exMaxW% THEN exMaxW% = exFw%
    NEXT exI%
    MENU_BAR.exportW% = MENU_SUB_PAD_LEFT + exMaxW% + MENU_SUB_PAD_RIGHT
    IF MENU_BAR.exportW% < 140 THEN MENU_BAR.exportW% = 140

    exTotalH%         = 4 + (EXPORT_FLYOUT_ITEMS * MENU_ITEM_HEIGHT)
    MENU_BAR.exportH% = exTotalH%

    ' Position to the right of the main submenu, aligned with EXPORT AS... item Y
    MENU_BAR.exportX% = MENU_BAR.subX% + MENU_BAR.subW%
    IF MENU_BAR.exportY% = 0 THEN MENU_BAR.exportY% = MENU_BAR.subY%

    ' Clamp right edge to screen
    IF MENU_BAR.exportX% + MENU_BAR.exportW% > SCRN.w& THEN
        MENU_BAR.exportX% = MENU_BAR.subX% - MENU_BAR.exportW%
        IF MENU_BAR.exportX% < 0 THEN MENU_BAR.exportX% = 0
    END IF

    ' Clamp bottom to screen
    IF MENU_BAR.exportY% + MENU_BAR.exportH% > SCRN.h& THEN
        MENU_BAR.exportY% = SCRN.h& - MENU_BAR.exportH%
        IF MENU_BAR.exportY% < 0 THEN MENU_BAR.exportY% = 0
    END IF

    ' Draw border and background
    LINE (MENU_BAR.exportX% - 1, MENU_BAR.exportY% - 1)-(MENU_BAR.exportX% + MENU_BAR.exportW%, MENU_BAR.exportY% + MENU_BAR.exportH%), exBrd~&, BF
    LINE (MENU_BAR.exportX%, MENU_BAR.exportY%)-(MENU_BAR.exportX% + MENU_BAR.exportW% - 1, MENU_BAR.exportY% + MENU_BAR.exportH% - 1), exBg~&, BF

    ' Draw the export format items
    exItemY% = MENU_BAR.exportY% + 2
    FOR exI% = 0 TO EXPORT_FLYOUT_ITEMS - 1
        IF exI% = MENU_BAR.exportHover% THEN
            LINE (MENU_BAR.exportX% + 1, exItemY%)-(MENU_BAR.exportX% + MENU_BAR.exportW% - 2, exItemY% + MENU_ITEM_HEIGHT - 1), exSBg~&, BF
            COLOR exSFg~&, _RGBA32(0, 0, 0, 0)
        ELSE
            COLOR exFg~&, _RGBA32(0, 0, 0, 0)
        END IF
        _UPRINTSTRING (MENU_BAR.exportX% + MENU_SUB_PAD_LEFT, exItemY% + 2), exLabels(exI%)
        exItemY% = exItemY% + MENU_ITEM_HEIGHT
    NEXT exI%
END SUB


''
' Handle a click inside the export-as submenu
' @param rawX INTEGER Raw screen X coordinate of the click
' @param rawY INTEGER Raw screen Y coordinate of the click
'
SUB MENUBAR_handle_export_click (rawX AS INTEGER, rawY AS INTEGER)
    IF NOT MENU_BAR.exportOpen% THEN EXIT SUB
    IF NOT MENUBAR_export_in_bounds%(rawX%, rawY%) THEN EXIT SUB

    DIM exClickY AS INTEGER
    exClickY% = MENU_BAR.exportY% + 2
    DIM exIdx    AS INTEGER
    FOR exIdx% = 0 TO EXPORT_FLYOUT_ITEMS - 1
        IF rawY% >= exClickY% AND rawY% < exClickY% + MENU_ITEM_HEIGHT THEN
            MENUBAR_close_all
            SELECT CASE exIdx%
                CASE 0 : CMD_execute_action EXPORT_ACT_PNG_NATIVE
                CASE 1 : CMD_execute_action EXPORT_ACT_PNG
                CASE 2 : CMD_execute_action EXPORT_ACT_GIF
                CASE 3 : CMD_execute_action EXPORT_ACT_JPG
                CASE 4 : CMD_execute_action EXPORT_ACT_TGA
                CASE 5 : CMD_execute_action EXPORT_ACT_BMP
                CASE 6 : CMD_execute_action EXPORT_ACT_HDR
                CASE 7 : CMD_execute_action EXPORT_ACT_ICO
                CASE 8 : CMD_execute_action EXPORT_ACT_QOI
            END SELECT
            EXIT SUB
        END IF
        exClickY% = exClickY% + MENU_ITEM_HEIGHT
    NEXT exIdx%
END SUB


''
' Check if a point is within the export-as submenu bounds
' @param rawX INTEGER Raw screen X coordinate to test
' @param rawY INTEGER Raw screen Y coordinate to test
' @return INTEGER - TRUE if the point is inside the export submenu
'
FUNCTION MENUBAR_export_in_bounds% (rawX AS INTEGER, rawY AS INTEGER)
    IF NOT MENU_BAR.exportOpen% THEN
        MENUBAR_export_in_bounds% = FALSE
        EXIT FUNCTION
    END IF
    MENUBAR_export_in_bounds% = (rawX% >= MENU_BAR.exportX% AND rawX% < MENU_BAR.exportX% + MENU_BAR.exportW% _
        AND rawY% >= MENU_BAR.exportY% AND rawY% < MENU_BAR.exportY% + MENU_BAR.exportH%)
END FUNCTION
