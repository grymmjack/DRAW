''
' Update menu bar geometry based on visible panels and toolbar
'
SUB MENUBAR_update_bar_geometry ()
    DIM toolbarW AS INTEGER
    DIM scale AS INTEGER

    ' Calculate toolbar width (4 columns * scaled size + padding + border)
    scale% = CFG.TOOLBAR_SCALE%
    IF scale% < 1 THEN scale% = 1
    toolbarW% = (TB_BTN_W * scale% * TB_COLS) + (TB_BTN_PADDING * scale% * (TB_COLS - 1)) + 2

    MENU_BAR.barY% = 0
    MENU_BAR.barH% = MENU_BAR_HEIGHT

    ' Calculate X position and width based on visible panels
    IF LAYER_PANEL.visible% THEN
        MENU_BAR.barX% = CFG.LAYER_PANEL_WIDTH%
    ELSE
        MENU_BAR.barX% = 0
    END IF

    IF SCRN.showToolbar% THEN
        MENU_BAR.barW% = SCRN.w& - MENU_BAR.barX% - toolbarW%
    ELSE
        MENU_BAR.barW% = SCRN.w& - MENU_BAR.barX%
    END IF

    IF MENU_BAR.barW% < 40 THEN MENU_BAR.barW% = 40 ' Minimum width

    ' Precompute root label X positions (first pass: all items, no overflow)
    DIM oldDest AS LONG, oldFont AS LONG
    DIM x AS INTEGER, i AS INTEGER, lbl AS STRING, pw AS INTEGER

    oldDest& = _DEST
    oldFont& = _FONT
    IF MENU_BAR.fontHandle& > 0 THEN _FONT MENU_BAR.fontHandle&

    x% = MENU_BAR.barX% + MENU_PAD_LEFT

    ' Measure all non-HELP items first
    DIM helpIdx AS INTEGER
    helpIdx% = MENU_ROOT_COUNT% - 1  ' HELP is always last

    FOR i% = 0 TO helpIdx% - 1
        lbl$ = RTRIM$(MENU_ROOT_LABEL(i%))
        pw% = _PRINTWIDTH(lbl$)
        MENU_ROOT_X(i%) = x%
        MENU_ROOT_W(i%) = pw% + MENU_ROOT_GAP
        x% = x% + pw% + MENU_ROOT_GAP
    NEXT i%

    ' Measure HELP (right-justified)
    lbl$ = RTRIM$(MENU_ROOT_LABEL(helpIdx%))
    pw% = _PRINTWIDTH(lbl$)
    DIM helpW AS INTEGER
    helpW% = pw% + MENU_PAD_RIGHT
    MENU_ROOT_X(helpIdx%) = MENU_BAR.barX% + MENU_BAR.barW% - pw% - MENU_PAD_RIGHT
    MENU_ROOT_W(helpIdx%) = helpW%

    ' Check overflow: does the last non-HELP item's right edge exceed the
    ' right-justified HELP label's left edge (with a small gap)?
    DIM chevronLbl AS STRING, chevronW AS INTEGER
    DIM barRight AS INTEGER
    chevronLbl$ = ">>"
    chevronW% = _PRINTWIDTH(chevronLbl$) + MENU_ROOT_GAP + 2
    barRight% = MENU_ROOT_X(helpIdx%) - MENU_ROOT_GAP ' Space before HELP

    ' Determine how many non-HELP items fit before the chevron
    DIM lastFitIdx AS INTEGER
    lastFitIdx% = helpIdx% - 1  ' Assume all fit

    IF helpIdx% > 0 THEN
        ' Check if the rightmost non-HELP item overflows
        DIM rightEdge AS INTEGER
        rightEdge% = MENU_ROOT_X(lastFitIdx%) + MENU_ROOT_W(lastFitIdx%)
        IF rightEdge% > barRight% THEN
            ' Need overflow — find how many items fit  before chevron
            ' Reserve space for the chevron button
            DIM fitLimit AS INTEGER
            fitLimit% = barRight% - chevronW%
            lastFitIdx% = -1
            FOR i% = 0 TO helpIdx% - 1
                IF (MENU_ROOT_X(i%) + MENU_ROOT_W(i%)) <= fitLimit% THEN
                    lastFitIdx% = i%
                ELSE
                    EXIT FOR
                END IF
            NEXT i%
            IF lastFitIdx% < 0 THEN lastFitIdx% = 0 ' At least 1 item visible
        END IF
    END IF

    ' Set overflow state
    MENU_VISIBLE_COUNT% = lastFitIdx% + 1  ' Number of non-HELP items visible
    IF MENU_VISIBLE_COUNT% < helpIdx% THEN
        ' Overflow exists
        MENU_CHEVRON_ACTIVE% = TRUE
        ' Position chevron right after the last visible item
        MENU_CHEVRON_X% = MENU_ROOT_X(lastFitIdx%) + MENU_ROOT_W(lastFitIdx%) + 2
        MENU_CHEVRON_W% = chevronW%
    ELSE
        MENU_CHEVRON_ACTIVE% = FALSE
        MENU_OVERFLOW_OPEN% = FALSE
    END IF

    _FONT oldFont&
END SUB


''
' Sync checkbox states from live application state
'
SUB MENUBAR_update_checkboxes ()
    DIM i AS INTEGER

    ' Update root menu enabled states
    FOR i% = 0 TO MENU_ROOT_COUNT% - 1
        MENU_ROOT_ENABLED(i%) = TRUE ' Most roots are always enabled
    NEXT i%
    ' Brush root (index 5) always enabled so users can discover submenu
    MENU_ROOT_ENABLED(5) = TRUE

    FOR i% = 0 TO MENU_ITEM_COUNT% - 1
        ' Update checkbox states
        IF MENU_ITEMS(i%).hasCheckbox% THEN
            SELECT CASE MENU_ITEMS(i%).actionId%
                CASE 411 ' Menu Bar
                    MENU_ITEMS(i%).checked% = MENU_BAR.visible%
                CASE 404 ' Layer Panel
                    MENU_ITEMS(i%).checked% = LAYER_PANEL.visible%
                CASE 401 ' Toolbox
                    MENU_ITEMS(i%).checked% = SCRN.showToolbar%
                CASE 402 ' Color Strip/Status
                    MENU_ITEMS(i%).checked% = SCRN.showStatus%
                CASE 434 ' Preview Window
                    MENU_ITEMS(i%).checked% = PREVIEW.visible%
                CASE 901 ' Grid
                    MENU_ITEMS(i%).checked% = GRID.SHOW%
                CASE 903 ' Snap to Grid
                    MENU_ITEMS(i%).checked% = GRID.SNAP%
                CASE 906 ' Grid Tile Mode (ON = center/tiling, OFF = corner/lines)
                    MENU_ITEMS(i%).checked% = (GRID.ALIGN_MODE% = GRID_ALIGN_CENTER)
                CASE 908 ' Grid Cell Fill
                    MENU_ITEMS(i%).checked% = GRID.CELL_FILL%
                CASE 902 ' Pixel Grid
                    MENU_ITEMS(i%).checked% = PIXEL_GRID.SHOW%
                CASE 412 ' Cursors
                    MENU_ITEMS(i%).checked% = NOT POINTER.HIDDEN
                CASE 1103 ' Recolor Mode
                    MENU_ITEMS(i%).checked% = CUSTOM_BRUSH_is_active% AND CUSTOM_BRUSH.RECOLOR_MODE
                CASE 609 ' Pixel Perfect Mode
                    MENU_ITEMS(i%).checked% = BRUSH_SIZE.PIXEL_PERFECT
                CASE 1501 ' Reference Image toggle
                    MENU_ITEMS(i%).checked% = REFIMG.VISIBLE AND (REFIMG.IMAGE < -1)
                CASE 414 ' Angle Snap: Degrees
                    MENU_ITEMS(i%).checked% = NOT CFG.ANGLE_SNAP_PIXEL_ART%
                    ' Update label dynamically to show current degree value
                    MENU_ITEMS(i%).label$ = "ANGLE SNAP: " + _TRIM$(STR$(CFG.ANGLE_SNAP_DEGREES%)) + CHR$(248)
                CASE 415 ' Angle Snap: Pixel Art
                    MENU_ITEMS(i%).checked% = CFG.ANGLE_SNAP_PIXEL_ART%
                CASE 417 ' Sound FX toggle
                    MENU_ITEMS(i%).checked% = CFG.SOUNDS_ENABLED%
                CASE 420 ' Music toggle
                    MENU_ITEMS(i%).checked% = CFG.MUSIC_ENABLED%
                CASE 421 ' SFX Mute
                    MENU_ITEMS(i%).checked% = CFG.SOUNDS_MUTED%
                CASE 424 ' Music Mute
                    MENU_ITEMS(i%).checked% = CFG.MUSIC_MUTED%
                CASE 1517 ' Show Lospec palettes in picker
                    MENU_ITEMS(i%).checked% = CFG.PALETTE_SHOW_LOSPEC%
                CASE 1518 ' Show Created palettes in picker
                    MENU_ITEMS(i%).checked% = CFG.PALETTE_SHOW_CREATED%
                CASE 603 ' Drawing Mode: Color
                    MENU_ITEMS(i%).checked% = (DRAWER.mode% = DRAWER_MODE_BRUSH)
                CASE 604 ' Drawing Mode: Gradients
                    MENU_ITEMS(i%).checked% = (DRAWER.mode% = DRAWER_MODE_GRADIENT)
                CASE 605 ' Drawing Mode: Patterns
                    MENU_ITEMS(i%).checked% = (DRAWER.mode% = DRAWER_MODE_PATTERN)
            END SELECT
        END IF

        ' Update enabled states for context-sensitive items
        ' Edit operations are always enabled — they operate on the active
        ' selection if one exists, or on the entire current layer otherwise.
        SELECT CASE MENU_ITEMS(i%).actionId%
            CASE 301 ' Undo
                MENU_ITEMS(i%).enabled% = (UNDO.current% > 0) OR WORKSPACE_UNDO_can_undo%
            CASE 302 ' Redo
                MENU_ITEMS(i%).enabled% = (UNDO.current% < UNDO.count% - 1) OR WORKSPACE_UNDO_can_redo%
            CASE 305, 312 ' Paste, Paste in Place
                MENU_ITEMS(i%).enabled% = CLIPBOARD.VALID
            CASE 207 ' Revert
                MENU_ITEMS(i%).enabled% = (CURRENT_DRW_FILENAME$ <> "" OR CURRENT_FILENAME$ <> "")
            CASE 213 ' Recent
                MENU_ITEMS(i%).enabled% = (RECENT_FILE_COUNT% > 0)
            CASE 1704 ' Code (not yet implemented)
                MENU_ITEMS(i%).enabled% = FALSE
            CASE 1110 ' Export Brush
                MENU_ITEMS(i%).enabled% = CUSTOM_BRUSH_is_active%
            CASE 1102, 1103, 1104, 1105, 1106, 1107, 1108, 1109, 1111, 1112 ' Brush operations
                MENU_ITEMS(i%).enabled% = CUSTOM_BRUSH_is_active%
            CASE 408 ' Display Scale Up
                DIM maxScaleUp AS INTEGER
                maxScaleUp% = SCREEN_max_display_scale%
                MENU_ITEMS(i%).enabled% = (SCRN.displayScale% < maxScaleUp%)
                MENU_ITEMS(i%).label = "SCALE UP (" + _TRIM$(STR$(SCRN.displayScale%)) + "x -> " + _TRIM$(STR$(SCRN.displayScale% + 1)) + "x)"
                IF NOT MENU_ITEMS(i%).enabled% THEN
                    MENU_ITEMS(i%).label = "SCALE UP (MAX " + _TRIM$(STR$(maxScaleUp%)) + "x)"
                END IF
            CASE 409 ' Display Scale Down
                MENU_ITEMS(i%).enabled% = (SCRN.displayScale% > 1)
                MENU_ITEMS(i%).label = "SCALE DOWN (" + _TRIM$(STR$(SCRN.displayScale%)) + "x -> " + _TRIM$(STR$(SCRN.displayScale% - 1)) + "x)"
                IF NOT MENU_ITEMS(i%).enabled% THEN
                    MENU_ITEMS(i%).label = "SCALE DOWN (MIN 1x)"
                END IF
            CASE 416 ' Display Scale Reset
                DIM cfgScale AS INTEGER
                cfgScale% = CFG.DISPLAY_SCALE%
                IF cfgScale% < 1 THEN cfgScale% = 1
                MENU_ITEMS(i%).enabled% = (SCRN.displayScale% <> cfgScale%)
                MENU_ITEMS(i%).label = "SCALE RESET (" + _TRIM$(STR$(SCRN.displayScale%)) + "x -> " + _TRIM$(STR$(cfgScale%)) + "x)"
            CASE 418 ' SFX Vol Up
                MENU_ITEMS(i%).enabled% = CFG.SOUNDS_ENABLED% AND (NOT CFG.SOUNDS_MUTED%) AND (CFG.SOUNDS_VOLUME% < 100)
                MENU_ITEMS(i%).label$ = "SFX VOL UP (" + _TRIM$(STR$(CFG.SOUNDS_VOLUME%)) + "%)"
            CASE 419 ' SFX Vol Down
                MENU_ITEMS(i%).enabled% = CFG.SOUNDS_ENABLED% AND (NOT CFG.SOUNDS_MUTED%) AND (CFG.SOUNDS_VOLUME% > 0)
                MENU_ITEMS(i%).label$ = "SFX VOL DOWN (" + _TRIM$(STR$(CFG.SOUNDS_VOLUME%)) + "%)"
            CASE 421 ' SFX Mute
                MENU_ITEMS(i%).enabled% = CFG.SOUNDS_ENABLED%
            CASE 422 ' Music Vol Up
                MENU_ITEMS(i%).enabled% = CFG.MUSIC_ENABLED% AND (NOT CFG.MUSIC_MUTED%) AND (CFG.MUSIC_VOLUME% < 100)
                MENU_ITEMS(i%).label$ = "MUSIC VOL UP (" + _TRIM$(STR$(CFG.MUSIC_VOLUME%)) + "%)"
            CASE 423 ' Music Vol Down
                MENU_ITEMS(i%).enabled% = CFG.MUSIC_ENABLED% AND (NOT CFG.MUSIC_MUTED%) AND (CFG.MUSIC_VOLUME% > 0)
                MENU_ITEMS(i%).label$ = "MUSIC VOL DOWN (" + _TRIM$(STR$(CFG.MUSIC_VOLUME%)) + "%)"
            CASE 424 ' Music Mute
                MENU_ITEMS(i%).enabled% = CFG.MUSIC_ENABLED%
            CASE 427, 428, 433 ' Next Track, Prev Track, Random Track
                MENU_ITEMS(i%).enabled% = CFG.MUSIC_ENABLED%
            CASE 425 ' Explore Music Folder
                MENU_ITEMS(i%).enabled% = TRUE
            CASE 426 ' Now Playing display
                MENU_ITEMS(i%).enabled% = FALSE
                DIM nowPlayName AS STRING
                DIM dotPosNP AS INTEGER
                DIM npCharI AS INTEGER
                IF MUSIC_CURRENT_FILE$ <> "" THEN
                    nowPlayName$ = MUSIC_CURRENT_FILE$
                    dotPosNP% = 0
                    FOR npCharI% = LEN(nowPlayName$) TO 1 STEP -1
                        IF MID$(nowPlayName$, npCharI%, 1) = "." THEN dotPosNP% = npCharI%: EXIT FOR
                    NEXT npCharI%
                    IF dotPosNP% > 0 THEN nowPlayName$ = LEFT$(nowPlayName$, dotPosNP% - 1)
                    IF LEN(nowPlayName$) > 21 THEN nowPlayName$ = LEFT$(nowPlayName$, 20) + "~"
                    MENU_ITEMS(i%).label$ = "NOW: " + nowPlayName$
                ELSE
                    MENU_ITEMS(i%).label$ = "NOT PLAYING"
                END IF
            CASE 307 ' Select None / Deselect
                MENU_ITEMS(i%).enabled% = SELECTION_has_active%
            CASE 311 ' Invert Selection
                MENU_ITEMS(i%).enabled% = SELECTION_has_active%
            CASE 1410, 1411, 1412, 1413 ' Expand/Contract Selection
                MENU_ITEMS(i%).enabled% = SELECTION_has_active%
            CASE 324 ' Stroke Selection
                MENU_ITEMS(i%).enabled% = SELECTION_has_active%
            CASE 1907, 1908 ' Distribute layers — require 2+ selected
                MENU_ITEMS(i%).enabled% = (MULTI_SELECT_COUNT% > 1)
            CASE 711, 1414 ' Merge Selected / From Selected Layers — require 2+ selected
                MENU_ITEMS(i%).enabled% = (MULTI_SELECT_COUNT% > 1)
        END SELECT
    NEXT i%
END SUB


''
' Render the menu bar to SCRN.GUI&
'
SUB MENUBAR_render ()
    IF NOT MENU_BAR.visible% THEN EXIT SUB

    DIM oldDest AS LONG, oldFont AS LONG
    DIM i AS INTEGER, lbl AS STRING
    DIM bg AS _UNSIGNED LONG, fg AS _UNSIGNED LONG
    DIM selBg AS _UNSIGNED LONG, selFg AS _UNSIGNED LONG

    oldDest& = _DEST
    _DEST SCRN.GUI&
    oldFont& = _FONT
    IF MENU_BAR.fontHandle& > 0 THEN _FONT MENU_BAR.fontHandle&, SCRN.GUI&

    ' Recalculate positions
    MENUBAR_update_bar_geometry
    MENUBAR_update_checkboxes

    ' Get theme colors
    bg~& = THEME.MENU_BAR_bg~&
    fg~& = THEME.MENU_BAR_fg~&
    selBg~& = THEME.MENU_BAR_sel_bg~&
    selFg~& = THEME.MENU_BAR_sel_fg~&

    ' Draw menu bar background
    LINE (MENU_BAR.barX%, MENU_BAR.barY%)-(MENU_BAR.barX% + MENU_BAR.barW% - 1, MENU_BAR.barY% + MENU_BAR.barH% - 1), bg~&, BF

    ' Draw bottom border
    LINE (MENU_BAR.barX%, MENU_BAR.barY% + MENU_BAR.barH% - 1)-(MENU_BAR.barX% + MENU_BAR.barW% - 1, MENU_BAR.barY% + MENU_BAR.barH% - 1), THEME.MENU_BAR_border~&

    ' Draw root labels
    DIM helpIdx2 AS INTEGER
    helpIdx2% = MENU_ROOT_COUNT% - 1

    FOR i% = 0 TO MENU_ROOT_COUNT% - 1
        ' Skip overflow items (except HELP which is always visible)
        IF MENU_CHEVRON_ACTIVE% AND i% >= MENU_VISIBLE_COUNT% AND i% <> helpIdx2% THEN
            GOTO MENUBAR_render_skip_root
        END IF

        lbl$ = RTRIM$(MENU_ROOT_LABEL(i%))

        IF NOT MENU_ROOT_ENABLED(i%) THEN
            ' Disabled state - dimmed text
            COLOR THEME.MENU_BAR_disabled_fg~&, _RGBA32(0, 0, 0, 0)
        ELSEIF i% = MENU_BAR.openMenu% OR i% = MENU_BAR.hoverRoot% THEN
            ' Highlighted state
            LINE (MENU_ROOT_X(i%) - 2, MENU_BAR.barY%)-(MENU_ROOT_X(i%) + _PRINTWIDTH(lbl$) + 1, MENU_BAR.barY% + MENU_BAR.barH% - 2), selBg~&, BF
            COLOR selFg~&, _RGBA32(0, 0, 0, 0)
        ELSE
            ' Normal state
            COLOR fg~&, _RGBA32(0, 0, 0, 0)
        END IF

        _PRINTSTRING (MENU_ROOT_X(i%), MENU_BAR.barY% + 2), lbl$
        MENUBAR_render_skip_root:
    NEXT i%

    ' Draw overflow chevron >> if active
    IF MENU_CHEVRON_ACTIVE% THEN
        DIM chevLbl AS STRING
        chevLbl$ = ">>"
        IF MENU_OVERFLOW_OPEN% OR MENU_OVERFLOW_HOVER% >= 0 THEN
            LINE (MENU_CHEVRON_X% - 2, MENU_BAR.barY%)-(MENU_CHEVRON_X% + _PRINTWIDTH(chevLbl$) + 1, MENU_BAR.barY% + MENU_BAR.barH% - 2), selBg~&, BF
            COLOR selFg~&, _RGBA32(0, 0, 0, 0)
        ELSE
            COLOR fg~&, _RGBA32(0, 0, 0, 0)
        END IF
        _PRINTSTRING (MENU_CHEVRON_X%, MENU_BAR.barY% + 2), chevLbl$
    END IF

    ' Draw open submenu if any
    IF MENU_BAR.openMenu% >= 0 AND MENU_BAR.openMenu% < MENU_ROOT_COUNT% THEN
        MENUBAR_render_submenu MENU_BAR.openMenu%
    END IF

    ' Draw overflow popup if open
    IF MENU_OVERFLOW_OPEN% AND MENU_CHEVRON_ACTIVE% THEN
        MENUBAR_render_overflow_popup
    END IF

    _FONT oldFont&
    _DEST oldDest&
END SUB


''
' Render a dropdown submenu for a given root menu
'
SUB MENUBAR_render_submenu (rootIdx AS INTEGER)
    DIM i AS INTEGER, childCount AS INTEGER
    DIM maxLabelW AS INTEGER, maxHotkeyW AS INTEGER
    DIM lbl AS STRING, hk AS STRING
    DIM subBg AS _UNSIGNED LONG, subFg AS _UNSIGNED LONG
    DIM subBorder AS _UNSIGNED LONG, subDivider AS _UNSIGNED LONG
    DIM subSelBg AS _UNSIGNED LONG, subSelFg AS _UNSIGNED LONG
    DIM totalH AS INTEGER, itemY AS INTEGER, childIdx AS INTEGER
    DIM checkStr AS STRING

    ' Get theme colors
    subBg~& = THEME.MENU_SUB_bg~&
    subFg~& = THEME.MENU_SUB_fg~&
    subBorder~& = THEME.MENU_SUB_border~&
    subDivider~& = THEME.MENU_SUB_divider~&
    subSelBg~& = THEME.MENU_SUB_sel_bg~&
    subSelFg~& = THEME.MENU_SUB_sel_fg~&

    ' Count children and measure max widths
    childCount% = 0
    maxLabelW% = 0
    maxHotkeyW% = 0
    totalH% = 4 ' Top/bottom padding

    FOR i% = 0 TO MENU_ITEM_COUNT% - 1
        IF MENU_ITEMS(i%).parentIdx% = rootIdx% THEN
            childCount% = childCount% + 1
            IF MENU_ITEMS(i%).isDivider% THEN
                totalH% = totalH% + MENU_DIVIDER_HEIGHT
            ELSE
                totalH% = totalH% + MENU_ITEM_HEIGHT
                lbl$ = RTRIM$(MENU_ITEMS(i%).label)
                hk$ = RTRIM$(MENU_ITEMS(i%).hotkey)
                DIM lw AS INTEGER, hw AS INTEGER
                lw% = _PRINTWIDTH(lbl$)
                hw% = _PRINTWIDTH(hk$)
                IF lw% > maxLabelW% THEN maxLabelW% = lw%
                IF hw% > maxHotkeyW% THEN maxHotkeyW% = hw%
            END IF
        END IF
    NEXT i%

    MENU_BAR.subItemCount% = childCount%

    ' Calculate submenu dimensions
    DIM subW AS INTEGER
    subW% = MENU_SUB_PAD_LEFT + maxLabelW% + MENU_SUB_HOTKEY_GAP + maxHotkeyW% + MENU_SUB_PAD_RIGHT
    IF subW% < 80 THEN subW% = 80 ' Minimum width

    ' Position submenu below the root label
    MENU_BAR.subX% = MENU_ROOT_X(rootIdx%) - 2
    MENU_BAR.subY% = MENU_BAR.barY% + MENU_BAR.barH%
    MENU_BAR.subW% = subW%

    ' Clamp: left edge must not go past menu bar left edge
    IF MENU_BAR.subX% < MENU_BAR.barX% THEN
        MENU_BAR.subX% = MENU_BAR.barX%
    END IF

    ' Clamp: right edge must not go past menu bar right edge (avoid toolbar overlap)
    DIM menuBarRight AS INTEGER
    menuBarRight% = MENU_BAR.barX% + MENU_BAR.barW%
    IF MENU_BAR.subX% + MENU_BAR.subW% > menuBarRight% THEN
        MENU_BAR.subX% = menuBarRight% - MENU_BAR.subW%
    END IF
    IF MENU_BAR.subX% < MENU_BAR.barX% THEN MENU_BAR.subX% = MENU_BAR.barX%

    ' Determine scrollable region
    DIM availH AS INTEGER, maxScroll AS INTEGER
    availH% = SCRN.h& - MENU_BAR.subY%
    IF availH% < MENU_ITEM_HEIGHT * 2 THEN availH% = MENU_ITEM_HEIGHT * 2
    IF totalH% > availH% THEN
        MENU_BAR.subH% = availH%
    ELSE
        MENU_BAR.subH% = totalH%
    END IF
    maxScroll% = totalH% - MENU_BAR.subH%
    IF maxScroll% < 0 THEN maxScroll% = 0
    MENU_BAR.subScrollMax% = maxScroll%
    IF MENU_BAR.subScroll% > maxScroll% THEN MENU_BAR.subScroll% = maxScroll%
    IF MENU_BAR.subScroll% < 0 THEN MENU_BAR.subScroll% = 0

    ' Scroll arrows take 1 row of space when active
    DIM scrollArrowH AS INTEGER
    scrollArrowH% = MENU_ITEM_HEIGHT
    DIM canScrollUp AS INTEGER, canScrollDn AS INTEGER
    canScrollUp% = (MENU_BAR.subScroll% > 0)
    canScrollDn% = (MENU_BAR.subScroll% < maxScroll%)
    DIM viewportTop AS INTEGER, viewportBot AS INTEGER
    viewportTop% = MENU_BAR.subY% + 2
    viewportBot% = MENU_BAR.subY% + MENU_BAR.subH% - 2
    IF canScrollUp% THEN viewportTop% = viewportTop% + scrollArrowH%
    IF canScrollDn% THEN viewportBot% = viewportBot% - scrollArrowH%

    ' Draw submenu border
    LINE (MENU_BAR.subX% - 1, MENU_BAR.subY% - 1)-(MENU_BAR.subX% + MENU_BAR.subW%, MENU_BAR.subY% + MENU_BAR.subH%), subBorder~&, BF

    ' Draw submenu background
    LINE (MENU_BAR.subX%, MENU_BAR.subY%)-(MENU_BAR.subX% + MENU_BAR.subW% - 1, MENU_BAR.subY% + MENU_BAR.subH% - 1), subBg~&, BF

    ' Draw up scroll arrow if needed
    IF canScrollUp% THEN
        LINE (MENU_BAR.subX% + 1, MENU_BAR.subY% + 1)-(MENU_BAR.subX% + MENU_BAR.subW% - 2, MENU_BAR.subY% + scrollArrowH%), subBg~&, BF
        COLOR subFg~&, _RGBA32(0, 0, 0, 0)
        DIM arrowUpX AS INTEGER
        arrowUpX% = MENU_BAR.subX% + (MENU_BAR.subW% \ 2) - (_PRINTWIDTH(CHR$(24)) \ 2)
        _PRINTSTRING (arrowUpX%, MENU_BAR.subY% + 2), CHR$(24)
    END IF

    ' Draw menu items using virtual-Y scrolling
    DIM virtualY AS INTEGER
    virtualY% = 2  ' virtual offset from subY (content-space)
    childIdx% = 0

    FOR i% = 0 TO MENU_ITEM_COUNT% - 1
        IF MENU_ITEMS(i%).parentIdx% <> rootIdx% THEN GOTO MENUBAR_render_next_item

        DIM itemH AS INTEGER
        IF MENU_ITEMS(i%).isDivider% THEN
            itemH% = MENU_DIVIDER_HEIGHT
        ELSE
            itemH% = MENU_ITEM_HEIGHT
        END IF

        ' Compute screen Y from virtual Y and scroll offset
        itemY% = MENU_BAR.subY% + virtualY% - MENU_BAR.subScroll%

        ' Adjust for scroll arrow area at top
        IF canScrollUp% THEN itemY% = itemY% + scrollArrowH%

        ' Skip if out of visible viewport
        IF itemY% + itemH% <= viewportTop% OR itemY% >= viewportBot% THEN
            virtualY% = virtualY% + itemH%
            childIdx% = childIdx% + 1
            GOTO MENUBAR_render_next_item
        END IF

        IF MENU_ITEMS(i%).isDivider% THEN
            DIM divY AS INTEGER
            divY% = itemY% + MENU_DIVIDER_HEIGHT \ 2
            LINE (MENU_BAR.subX% + 4, divY%)-(MENU_BAR.subX% + MENU_BAR.subW% - 5, divY%), subDivider~&
            virtualY% = virtualY% + MENU_DIVIDER_HEIGHT
            childIdx% = childIdx% + 1
            GOTO MENUBAR_render_next_item
        END IF

        ' Draw highlight or normal background
        IF childIdx% = MENU_BAR.hoverSub% THEN
            LINE (MENU_BAR.subX% + 1, itemY%)-(MENU_BAR.subX% + MENU_BAR.subW% - 2, itemY% + MENU_ITEM_HEIGHT - 1), subSelBg~&, BF
            IF MENU_ITEMS(i%).enabled% THEN
                COLOR subSelFg~&, _RGBA32(0, 0, 0, 0)
            ELSE
                COLOR THEME.MENU_SUB_disabled_fg~&, _RGBA32(0, 0, 0, 0)
            END IF
        ELSE
            IF MENU_ITEMS(i%).enabled% THEN
                COLOR subFg~&, _RGBA32(0, 0, 0, 0)
            ELSE
                COLOR THEME.MENU_SUB_disabled_fg~&, _RGBA32(0, 0, 0, 0)
            END IF
        END IF

        lbl$ = RTRIM$(MENU_ITEMS(i%).label)
        hk$ = RTRIM$(MENU_ITEMS(i%).hotkey)

        IF MENU_ITEMS(i%).hasCheckbox% THEN
            IF MENU_ITEMS(i%).checked% THEN
                checkStr$ = CHR$(251)
            ELSE
                checkStr$ = " "
            END IF
            _PRINTSTRING (MENU_BAR.subX% + 4, itemY% + 2), checkStr$
        END IF

        _PRINTSTRING (MENU_BAR.subX% + MENU_SUB_PAD_LEFT, itemY% + 2), lbl$

        IF LEN(hk$) > 0 THEN
            DIM hkX AS INTEGER
            hkX% = MENU_BAR.subX% + MENU_BAR.subW% - _PRINTWIDTH(hk$) - MENU_SUB_PAD_RIGHT
            _PRINTSTRING (hkX%, itemY% + 2), hk$
        END IF

        ' Track RECENT item position for submenu
        IF MENU_ITEMS(i%).actionId% = 213 THEN
            MENU_BAR.recentItemIdx% = childIdx%
            MENU_BAR.recentY% = itemY%
            IF childIdx% = MENU_BAR.hoverSub% AND MENU_ITEMS(i%).enabled% AND NOT MENU_BAR.kbActive% THEN
                MENU_BAR.recentOpen% = TRUE
            END IF
        END IF

        ' Track RANDOM TRACK item position for submenu
        IF MENU_ITEMS(i%).actionId% = 433 THEN
            MENU_BAR.randomItemIdx% = childIdx%
            MENU_BAR.randomY% = itemY%
            IF childIdx% = MENU_BAR.hoverSub% AND MENU_ITEMS(i%).enabled% AND NOT MENU_BAR.kbActive% THEN
                MENU_BAR.randomOpen% = TRUE
            END IF
        END IF

        ' Track TRANSFORM item position for submenu
        IF MENU_ITEMS(i%).actionId% = 330 THEN
            MENU_BAR.transformItemIdx% = childIdx%
            MENU_BAR.transformY% = itemY%
            IF childIdx% = MENU_BAR.hoverSub% AND MENU_ITEMS(i%).enabled% AND NOT MENU_BAR.kbActive% THEN
                MENU_BAR.transformOpen% = TRUE
            END IF
        END IF

        virtualY% = virtualY% + MENU_ITEM_HEIGHT
        childIdx% = childIdx% + 1

        MENUBAR_render_next_item:
    NEXT i%

    ' Draw down scroll arrow if needed (on top of background, at bottom)
    IF canScrollDn% THEN
        LINE (MENU_BAR.subX% + 1, MENU_BAR.subY% + MENU_BAR.subH% - scrollArrowH%)-(MENU_BAR.subX% + MENU_BAR.subW% - 2, MENU_BAR.subY% + MENU_BAR.subH% - 1), subBg~&, BF
        COLOR subFg~&, _RGBA32(0, 0, 0, 0)
        DIM arrowDnX AS INTEGER
        arrowDnX% = MENU_BAR.subX% + (MENU_BAR.subW% \ 2) - (_PRINTWIDTH(CHR$(25)) \ 2)
        _PRINTSTRING (arrowDnX%, MENU_BAR.subY% + MENU_BAR.subH% - scrollArrowH% + 2), CHR$(25)
    END IF

    ' Render recent files submenu if open
    IF MENU_BAR.recentOpen% AND RECENT_FILE_COUNT% > 0 THEN
        MENUBAR_render_recent_submenu
    END IF

    ' Render random track submenu if open
    IF MENU_BAR.randomOpen% THEN
        MENUBAR_render_random_submenu
    END IF

    ' Render transform submenu if open
    IF MENU_BAR.transformOpen% THEN
        MENUBAR_render_transform_submenu
    END IF
END SUB


''
' Handle mouse click on menu bar or submenu
'
SUB MENUBAR_handle_click (rawX AS INTEGER, rawY AS INTEGER)
    DIM i AS INTEGER

    ' Check if click is on the overflow popup first (it renders on top)
    IF MENU_OVERFLOW_OPEN% AND MENU_CHEVRON_ACTIVE% AND MENUBAR_overflow_in_bounds%(rawX%, rawY%) THEN
        MENUBAR_handle_overflow_click rawX%, rawY%
        EXIT SUB
    END IF

    ' Check if click is on the menu bar itself
    IF rawY% >= MENU_BAR.barY% AND rawY% < MENU_BAR.barY% + MENU_BAR.barH% _
        AND rawX% >= MENU_BAR.barX% AND rawX% < MENU_BAR.barX% + MENU_BAR.barW% THEN

        ' Check for chevron >> click first
        IF MENU_CHEVRON_ACTIVE% THEN
            IF rawX% >= MENU_CHEVRON_X% - 2 AND rawX% < MENU_CHEVRON_X% + MENU_CHEVRON_W% THEN
                ' Toggle overflow popup
                IF MENU_OVERFLOW_OPEN% THEN
                    MENU_OVERFLOW_OPEN% = FALSE
                    MENU_OVERFLOW_HOVER% = -1
                ELSE
                    MENU_OVERFLOW_OPEN% = TRUE
                    MENU_OVERFLOW_HOVER% = -1
                    ' Close any open root submenu
                    MENU_BAR.openMenu% = -1
                    MENU_BAR.hoverSub% = -1
                END IF
                GUI_NEEDS_REDRAW% = TRUE
                SCENE_DIRTY% = TRUE
                EXIT SUB
            END IF
        END IF

        ' Find which root item was clicked (only check visible items + HELP)
        FOR i% = 0 TO MENU_ROOT_COUNT% - 1
            ' Skip overflow items (not HELP, not visible)
            IF MENU_CHEVRON_ACTIVE% AND i% >= MENU_VISIBLE_COUNT% AND i% <> MENU_ROOT_COUNT% - 1 THEN
                GOTO MENUBAR_click_skip_root
            END IF
            IF rawX% >= MENU_ROOT_X(i%) - 2 AND rawX% < MENU_ROOT_X(i%) + MENU_ROOT_W(i%) THEN
                IF NOT MENU_ROOT_ENABLED(i%) THEN EXIT SUB ' Disabled root
                ' Close overflow popup if open
                MENU_OVERFLOW_OPEN% = FALSE
                MENU_OVERFLOW_HOVER% = -1
                IF MENU_BAR.openMenu% = i% THEN
                    ' Clicked on same menu - close it
                    MENUBAR_close_all
                ELSE
                    ' Open this menu
                    MENU_BAR.openMenu% = i%
                    MENU_BAR.hoverRoot% = i%
                    MENU_BAR.hoverSub% = -1
                    MENU_BAR.subScroll% = 0
                    MENU_BAR.stayOpen% = TRUE
                    ' Close palette menu to avoid overlap
                    IF PALETTE_MENU_VISIBLE% THEN PALETTE_MENU_hide
                    SOUND_play SND_MENU_OPEN
                    GUI_NEEDS_REDRAW% = TRUE
                    SCENE_DIRTY% = TRUE
                END IF
                EXIT SUB
            END IF
            MENUBAR_click_skip_root:
        NEXT i%
        ' Clicked on menu bar but not on any root item - close menu if open
        IF MENU_BAR.openMenu% >= 0 THEN MENUBAR_close_all
        EXIT SUB
    END IF

    ' Check if click is on the recent files submenu
    IF MENU_BAR.recentOpen% AND MENUBAR_recent_in_bounds%(rawX%, rawY%) THEN
        MENUBAR_handle_recent_click rawX%, rawY%
        EXIT SUB
    END IF

    ' Check if click is on the random track submenu
    IF MENU_BAR.randomOpen% AND MENUBAR_random_in_bounds%(rawX%, rawY%) THEN
        MENUBAR_handle_random_click rawX%, rawY%
        EXIT SUB
    END IF

    ' Check if click is on the transform submenu
    IF MENU_BAR.transformOpen% AND MENUBAR_transform_in_bounds%(rawX%, rawY%) THEN
        MENUBAR_handle_transform_click rawX%, rawY%
        EXIT SUB
    END IF

    ' Check if click is on the open submenu
    IF MENU_BAR.openMenu% >= 0 AND MENUBAR_submenu_in_bounds%(rawX%, rawY%) THEN
        ' Handle scroll arrow clicks first
        IF MENU_BAR.subScroll% > 0 THEN
            ' Up arrow zone
            IF rawY% >= MENU_BAR.subY% AND rawY% < MENU_BAR.subY% + MENU_ITEM_HEIGHT + 2 THEN
                MENU_BAR.subScroll% = MENU_BAR.subScroll% - MENU_ITEM_HEIGHT
                IF MENU_BAR.subScroll% < 0 THEN MENU_BAR.subScroll% = 0
                GUI_NEEDS_REDRAW% = TRUE
                SCENE_DIRTY% = TRUE
                EXIT SUB
            END IF
        END IF
        IF MENU_BAR.subScroll% < MENU_BAR.subScrollMax% THEN
            ' Down arrow zone
            IF rawY% >= MENU_BAR.subY% + MENU_BAR.subH% - MENU_ITEM_HEIGHT - 2 AND rawY% < MENU_BAR.subY% + MENU_BAR.subH% THEN
                MENU_BAR.subScroll% = MENU_BAR.subScroll% + MENU_ITEM_HEIGHT
                IF MENU_BAR.subScroll% > MENU_BAR.subScrollMax% THEN MENU_BAR.subScroll% = MENU_BAR.subScrollMax%
                GUI_NEEDS_REDRAW% = TRUE
                SCENE_DIRTY% = TRUE
                EXIT SUB
            END IF
        END IF

        DIM clickedItem AS INTEGER
        clickedItem% = MENUBAR_get_submenu_item_at%(rawY%)

        IF clickedItem% >= 0 THEN
            ' Find the actual MENU_ITEMS index for this child
            DIM childIdx AS INTEGER, itemIdx AS INTEGER
            childIdx% = 0
            FOR itemIdx% = 0 TO MENU_ITEM_COUNT% - 1
                IF MENU_ITEMS(itemIdx%).parentIdx% = MENU_BAR.openMenu% THEN
                    IF MENU_ITEMS(itemIdx%).isDivider% THEN
                        childIdx% = childIdx% + 1
                        GOTO MENUBAR_click_next
                    END IF
                    IF childIdx% = clickedItem% THEN
                        ' Found the clicked item
                        IF MENU_ITEMS(itemIdx%).enabled% THEN
                            ' Intercept RECENT item: toggle submenu instead of dispatch
                            IF MENU_ITEMS(itemIdx%).actionId% = 213 THEN
                                MENU_BAR.recentOpen% = NOT MENU_BAR.recentOpen%
                                IF NOT MENU_BAR.recentOpen% THEN
                                    MENU_BAR.recentHover% = -1
                                END IF
                                GUI_NEEDS_REDRAW% = TRUE
                                EXIT SUB
                            END IF
                            IF MENU_ITEMS(itemIdx%).actionId% = 433 THEN
                                MENU_BAR.randomOpen% = NOT MENU_BAR.randomOpen%
                                IF NOT MENU_BAR.randomOpen% THEN
                                    MENU_BAR.randomHover% = -1
                                END IF
                                GUI_NEEDS_REDRAW% = TRUE
                                EXIT SUB
                            END IF
                            IF MENU_ITEMS(itemIdx%).actionId% = 330 THEN
                                MENU_BAR.transformOpen% = NOT MENU_BAR.transformOpen%
                                IF NOT MENU_BAR.transformOpen% THEN
                                    MENU_BAR.transformHover% = -1
                                END IF
                                GUI_NEEDS_REDRAW% = TRUE
                                EXIT SUB
                            END IF
                            ' Toggle checkbox if applicable
                            IF MENU_ITEMS(itemIdx%).hasCheckbox% THEN
                                MENU_ITEMS(itemIdx%).checked% = NOT MENU_ITEMS(itemIdx%).checked%
                            END IF
                            ' Execute action
                            DIM actId AS INTEGER
                            actId% = MENU_ITEMS(itemIdx%).actionId%
                            MENUBAR_close_all
                            IF actId% > 0 THEN SOUND_play SND_MENU_SELECT
                            IF actId% > 0 THEN CMD_execute_action actId%
                        END IF
                        EXIT SUB
                    END IF
                    childIdx% = childIdx% + 1
                END IF
                MENUBAR_click_next:
            NEXT itemIdx%
        END IF
        EXIT SUB
    END IF

    ' Click was outside all menu areas - close
    MENUBAR_close_all
END SUB


''
' Handle mouse movement for hover tracking
'
SUB MENUBAR_handle_mouse_move (rawX AS INTEGER, rawY AS INTEGER)
    DIM i AS INTEGER
    DIM oldHoverRoot AS INTEGER, oldHoverSub AS INTEGER

    ' If keyboard navigation is active, ignore mouse until it actually moves
    IF MENU_BAR.kbActive% THEN
        IF rawX% = MENU_BAR.lastMouseX% AND rawY% = MENU_BAR.lastMouseY% THEN
            EXIT SUB
        END IF
        ' Mouse moved — keyboard nav yields to mouse
        MENU_BAR.kbActive% = FALSE
    END IF
    MENU_BAR.lastMouseX% = rawX%
    MENU_BAR.lastMouseY% = rawY%

    oldHoverRoot% = MENU_BAR.hoverRoot%
    oldHoverSub% = MENU_BAR.hoverSub%
    DIM oldOverflowHover AS INTEGER
    oldOverflowHover% = MENU_OVERFLOW_HOVER%
    DIM oldRecentHover AS INTEGER
    oldRecentHover% = MENU_BAR.recentHover%
    DIM oldRandomHover AS INTEGER
    oldRandomHover% = MENU_BAR.randomHover%
    DIM oldTransformHover AS INTEGER
    oldTransformHover% = MENU_BAR.transformHover%

    ' Check if mouse is on the overflow popup
    IF MENU_OVERFLOW_OPEN% AND MENU_CHEVRON_ACTIVE% AND MENUBAR_overflow_in_bounds%(rawX%, rawY%) THEN
        ' Track hover within overflow popup
        DIM ovItemY AS INTEGER, ovIdx AS INTEGER, ovI AS INTEGER
        DIM ovHelpIdx AS INTEGER
        ovHelpIdx% = MENU_ROOT_COUNT% - 1
        ovItemY% = MENU_OVERFLOW_Y% + 2
        MENU_OVERFLOW_HOVER% = -1
        ovIdx% = 0
        FOR ovI% = MENU_VISIBLE_COUNT% TO ovHelpIdx% - 1
            IF rawY% >= ovItemY% AND rawY% < ovItemY% + MENU_ITEM_HEIGHT THEN
                MENU_OVERFLOW_HOVER% = ovIdx%
                EXIT FOR
            END IF
            ovItemY% = ovItemY% + MENU_ITEM_HEIGHT
            ovIdx% = ovIdx% + 1
        NEXT ovI%
        IF MENU_OVERFLOW_HOVER% <> oldOverflowHover% THEN GUI_NEEDS_REDRAW% = TRUE
        EXIT SUB

    ' Check if mouse is on the bar
    ELSEIF rawY% >= MENU_BAR.barY% AND rawY% < MENU_BAR.barY% + MENU_BAR.barH% _
        AND rawX% >= MENU_BAR.barX% AND rawX% < MENU_BAR.barX% + MENU_BAR.barW% THEN
        MENU_BAR.hoverRoot% = -1

        ' Check chevron hover
        IF MENU_CHEVRON_ACTIVE% THEN
            IF rawX% >= MENU_CHEVRON_X% - 2 AND rawX% < MENU_CHEVRON_X% + MENU_CHEVRON_W% THEN
                ' Hovering over chevron — if a menu is open, switch to showing overflow
                IF MENU_BAR.openMenu% >= 0 AND NOT MENU_OVERFLOW_OPEN% THEN
                    MENU_BAR.openMenu% = -1
                    MENU_BAR.hoverSub% = -1
                    MENU_OVERFLOW_OPEN% = TRUE
                    MENU_OVERFLOW_HOVER% = -1
                    SCENE_DIRTY% = TRUE
                END IF
                GOTO MENUBAR_hover_done
            END IF
        END IF

        FOR i% = 0 TO MENU_ROOT_COUNT% - 1
            ' Skip overflow items (not HELP)
            IF MENU_CHEVRON_ACTIVE% AND i% >= MENU_VISIBLE_COUNT% AND i% <> MENU_ROOT_COUNT% - 1 THEN
                GOTO MENUBAR_hover_skip_root
            END IF
            IF rawX% >= MENU_ROOT_X(i%) - 2 AND rawX% < MENU_ROOT_X(i%) + MENU_ROOT_W(i%) THEN
                MENU_BAR.hoverRoot% = i%
                ' If a menu is open and we hover a different root, switch to it
                IF MENU_BAR.openMenu% >= 0 AND MENU_BAR.openMenu% <> i% AND MENU_ROOT_ENABLED(i%) THEN
                    MENU_BAR.openMenu% = i%
                    MENU_BAR.hoverSub% = -1
                    MENU_BAR.subScroll% = 0
                    MENU_OVERFLOW_OPEN% = FALSE
                    MENU_OVERFLOW_HOVER% = -1
                    SCENE_DIRTY% = TRUE
                END IF
                EXIT FOR
            END IF
            MENUBAR_hover_skip_root:
        NEXT i%
        MENUBAR_hover_done:
    ELSEIF MENU_BAR.openMenu% >= 0 AND MENUBAR_random_in_bounds%(rawX%, rawY%) THEN
        ' Mouse is on the random track submenu - track hover there
        DIM randItemY AS INTEGER
        randItemY% = MENU_BAR.randomY% + 2
        MENU_BAR.randomHover% = -1
        DIM randIdx AS INTEGER
        FOR randIdx% = 0 TO 3  ' 0=MOD, 1=IT, 2=XM, 3=RAD
            IF rawY% >= randItemY% AND rawY% < randItemY% + MENU_ITEM_HEIGHT THEN
                MENU_BAR.randomHover% = randIdx%
                EXIT FOR
            END IF
            randItemY% = randItemY% + MENU_ITEM_HEIGHT
        NEXT randIdx%
        MENU_BAR.hoverSub% = MENU_BAR.randomItemIdx%
        MENU_BAR.hoverRoot% = MENU_BAR.openMenu%
        IF MENU_BAR.randomHover% <> oldRandomHover% THEN
            SOUND_play SND_MENU_HOVER
            GUI_NEEDS_REDRAW% = TRUE
        END IF
    ELSEIF MENU_BAR.openMenu% >= 0 AND MENUBAR_transform_in_bounds%(rawX%, rawY%) THEN
        ' Mouse is on the transform submenu - track hover there
        DIM trItemY AS INTEGER
        trItemY% = MENU_BAR.transformY% + 2
        MENU_BAR.transformHover% = -1
        DIM trIdx AS INTEGER
        FOR trIdx% = 0 TO TRANSFORM_FLYOUT_ITEMS - 1
            IF rawY% >= trItemY% AND rawY% < trItemY% + MENU_ITEM_HEIGHT THEN
                MENU_BAR.transformHover% = trIdx%
                EXIT FOR
            END IF
            trItemY% = trItemY% + MENU_ITEM_HEIGHT
        NEXT trIdx%
        MENU_BAR.hoverSub% = MENU_BAR.transformItemIdx%
        MENU_BAR.hoverRoot% = MENU_BAR.openMenu%
        IF MENU_BAR.transformHover% <> oldTransformHover% THEN
            SOUND_play SND_MENU_HOVER
            GUI_NEEDS_REDRAW% = TRUE
        END IF
    ELSEIF MENU_BAR.openMenu% >= 0 AND MENUBAR_recent_in_bounds%(rawX%, rawY%) THEN
        ' Mouse is on the recent files submenu - track hover there
        DIM recItemY AS INTEGER, recIdx AS INTEGER
        recItemY% = MENU_BAR.recentY% + 2
        MENU_BAR.recentHover% = -1
        ' Check file items (0-based: 0..count-1)
        FOR recIdx% = 0 TO RECENT_FILE_COUNT% - 1
            IF rawY% >= recItemY% AND rawY% < recItemY% + MENU_ITEM_HEIGHT THEN
                MENU_BAR.recentHover% = recIdx%
                EXIT FOR
            END IF
            recItemY% = recItemY% + MENU_ITEM_HEIGHT
        NEXT recIdx%
        ' Skip divider
        IF MENU_BAR.recentHover% = -1 THEN
            recItemY% = MENU_BAR.recentY% + 2 + (RECENT_FILE_COUNT% * MENU_ITEM_HEIGHT)
            recItemY% = recItemY% + MENU_DIVIDER_HEIGHT
            ' Check CLEAR item
            IF rawY% >= recItemY% AND rawY% < recItemY% + MENU_ITEM_HEIGHT THEN
                MENU_BAR.recentHover% = RECENT_FILE_COUNT% ' CLEAR index
            END IF
        END IF
        ' Keep hoverSub on the RECENT item to keep the parent highlighted
        MENU_BAR.hoverSub% = MENU_BAR.recentItemIdx%
        MENU_BAR.hoverRoot% = MENU_BAR.openMenu%
        IF MENU_BAR.recentHover% <> oldRecentHover% THEN
            SOUND_play SND_MENU_HOVER
            GUI_NEEDS_REDRAW% = TRUE
        END IF
    ELSEIF MENU_BAR.openMenu% >= 0 AND MENUBAR_submenu_in_bounds%(rawX%, rawY%) THEN
        ' Mouse is on submenu - check scroll arrow hover first
        STATIC arrowScrollTimer AS DOUBLE
        DIM inUpArrow AS INTEGER, inDnArrow AS INTEGER
        inUpArrow% = (MENU_BAR.subScroll% > 0 _
            AND rawY% >= MENU_BAR.subY% _
            AND rawY% < MENU_BAR.subY% + MENU_ITEM_HEIGHT + 2)
        inDnArrow% = (MENU_BAR.subScroll% < MENU_BAR.subScrollMax% _
            AND rawY% >= MENU_BAR.subY% + MENU_BAR.subH% - MENU_ITEM_HEIGHT - 2 _
            AND rawY% < MENU_BAR.subY% + MENU_BAR.subH%)
        IF inUpArrow% OR inDnArrow% THEN
            IF TIMER - arrowScrollTimer > 0.1 THEN
                arrowScrollTimer = TIMER
                IF inUpArrow% THEN
                    MENU_BAR.subScroll% = MENU_BAR.subScroll% - MENU_ITEM_HEIGHT
                    IF MENU_BAR.subScroll% < 0 THEN MENU_BAR.subScroll% = 0
                ELSE
                    MENU_BAR.subScroll% = MENU_BAR.subScroll% + MENU_ITEM_HEIGHT
                    IF MENU_BAR.subScroll% > MENU_BAR.subScrollMax% THEN MENU_BAR.subScroll% = MENU_BAR.subScrollMax%
                END IF
                INVALIDATE_scene
            END IF
            MENU_BAR.hoverSub% = -1
            MENU_BAR.hoverRoot% = MENU_BAR.openMenu%
        ELSE
            arrowScrollTimer = 0
            ' update submenu hover
            MENU_BAR.hoverSub% = MENUBAR_get_submenu_item_at%(rawY%)
            MENU_BAR.hoverRoot% = MENU_BAR.openMenu%
            ' Close recent submenu if hover moved away from RECENT item
            IF MENU_BAR.recentOpen% AND MENU_BAR.hoverSub% <> MENU_BAR.recentItemIdx% THEN
                MENU_BAR.recentOpen% = FALSE
                MENU_BAR.recentHover% = -1
            END IF
            ' Close random submenu if hover moved away from RANDOM TRACK item
            IF MENU_BAR.randomOpen% AND MENU_BAR.hoverSub% <> MENU_BAR.randomItemIdx% THEN
                MENU_BAR.randomOpen% = FALSE
                MENU_BAR.randomHover% = -1
            END IF
            ' Close transform submenu if hover moved away from TRANSFORM... item
            IF MENU_BAR.transformOpen% AND MENU_BAR.hoverSub% <> MENU_BAR.transformItemIdx% THEN
                MENU_BAR.transformOpen% = FALSE
                MENU_BAR.transformHover% = -1
            END IF
        END IF
    ELSE
        ' Mouse is outside all menu areas
        IF MENU_BAR.openMenu% < 0 AND NOT MENU_OVERFLOW_OPEN% THEN
            MENU_BAR.hoverRoot% = -1
            MENU_BAR.hoverSub% = -1
        END IF
        ' Close recent submenu when mouse leaves all areas
        IF MENU_BAR.recentOpen% THEN
            MENU_BAR.recentOpen% = FALSE
            MENU_BAR.recentHover% = -1
        END IF
        ' Close random submenu when mouse leaves all areas
        IF MENU_BAR.randomOpen% THEN
            MENU_BAR.randomOpen% = FALSE
            MENU_BAR.randomHover% = -1
        END IF
        ' Close transform submenu when mouse leaves all areas
        IF MENU_BAR.transformOpen% THEN
            MENU_BAR.transformOpen% = FALSE
            MENU_BAR.transformHover% = -1
        END IF
        ' Clear overflow hover when mouse leaves popup
        IF MENU_OVERFLOW_HOVER% >= 0 THEN
            MENU_OVERFLOW_HOVER% = -1
            GUI_NEEDS_REDRAW% = TRUE
        END IF
    END IF

    ' Root item hovered/switched -> MENU_OPEN; sub-item hovered -> MENU_HOVER
    ' Exception: sub-items that open a cascading menu also play MENU_OPEN
    IF MENU_BAR.hoverRoot% <> oldHoverRoot% THEN
        SOUND_play SND_MENU_OPEN
    ELSEIF MENU_BAR.hoverSub% <> oldHoverSub% OR MENU_OVERFLOW_HOVER% <> oldOverflowHover% THEN
        IF MENU_BAR.hoverSub% = MENU_BAR.recentItemIdx% OR MENU_BAR.hoverSub% = MENU_BAR.randomItemIdx% OR MENU_BAR.hoverSub% = MENU_BAR.transformItemIdx% THEN
            SOUND_play SND_MENU_OPEN
        ELSE
            SOUND_play SND_MENU_HOVER
        END IF
    END IF
    IF MENU_BAR.hoverRoot% <> oldHoverRoot% OR MENU_BAR.hoverSub% <> oldHoverSub% _
        OR MENU_OVERFLOW_HOVER% <> oldOverflowHover% THEN
        GUI_NEEDS_REDRAW% = TRUE
    END IF
END SUB


''
' Close all menus
'
SUB MENUBAR_close_all ()
    MENU_BAR.openMenu% = -1
    MENU_BAR.hoverRoot% = -1
    MENU_BAR.hoverSub% = -1
    MENU_BAR.subScroll% = 0
    MENU_BAR.stayOpen% = FALSE
    MENU_BAR.recentOpen% = FALSE
    MENU_BAR.recentHover% = -1
    MENU_BAR.randomOpen% = FALSE
    MENU_BAR.randomHover% = -1
    MENU_BAR.transformOpen% = FALSE
    MENU_BAR.transformHover% = -1
    MENU_OVERFLOW_OPEN% = FALSE
    MENU_OVERFLOW_HOVER% = -1
    GUI_NEEDS_REDRAW% = TRUE
    SCENE_DIRTY% = TRUE
END SUB


''
' Handle keyboard navigation for open menus
' Returns TRUE if key was consumed
'
FUNCTION MENUBAR_handle_key% (k AS LONG)
    MENUBAR_handle_key% = FALSE

    ' ALT tap detection: open/close menu on ALT release
    DIM altDown AS INTEGER
    $IF MAC THEN
        altDown% = MAC_ALT_HELD%
    $ELSE
        altDown% = (_KEYDOWN(KEY_LALT&) OR _KEYDOWN(KEY_RALT&))
    $END IF

    IF altDown% THEN
        IF NOT MENU_BAR.altWasDown% THEN
            MENU_BAR.altTapped% = TRUE  ' ALT just pressed, mark as potential tap
        END IF
        MENU_BAR.altWasDown% = TRUE
        ' If any other key is pressed while ALT is held, it's not a tap
        IF k& <> 0 AND k& <> -100308 AND k& <> -100307 THEN
            MENU_BAR.altTapped% = FALSE
        END IF
        ' If another modifier is held with ALT, it's not a tap (e.g. Ctrl+Alt+R)
        IF MODIFIERS.ctrl% OR MODIFIERS.shift% THEN
            MENU_BAR.altTapped% = FALSE
        END IF
        ' If a mouse button was pressed while ALT held, it's not a tap (e.g. Alt+click clone)
        IF MOUSE.B1% OR MOUSE.B2% OR MOUSE.B3% THEN
            MENU_BAR.altTapped% = FALSE
        END IF
    ELSE
        IF MENU_BAR.altWasDown% AND MENU_BAR.altTapped% THEN
            ' ALT was released without pressing another key = tap
            IF MENU_BAR.openMenu% >= 0 OR MENU_OVERFLOW_OPEN% THEN
                MENUBAR_close_all
            ELSE
                MENU_BAR.openMenu% = 0  ' Open FILE menu
                MENU_BAR.hoverRoot% = 0
                MENU_BAR.hoverSub% = -1
                GUI_NEEDS_REDRAW% = TRUE
                SCENE_DIRTY% = TRUE
            END IF
            MENU_BAR.altTapped% = FALSE
            MENU_BAR.altWasDown% = FALSE
            MENUBAR_handle_key% = TRUE
            EXIT FUNCTION
        END IF
        MENU_BAR.altWasDown% = FALSE
        MENU_BAR.altTapped% = FALSE
    END IF

    ' Only handle keys when menu or overflow is open
    IF MENU_BAR.openMenu% < 0 AND NOT MENU_OVERFLOW_OPEN% THEN EXIT FUNCTION

    ' --- Overflow popup keyboard navigation ---
    IF MENU_OVERFLOW_OPEN% AND MENU_CHEVRON_ACTIVE% THEN
        DIM ovHelpIdx2 AS INTEGER, ovCount2 AS INTEGER
        ovHelpIdx2% = MENU_ROOT_COUNT% - 1
        ovCount2% = ovHelpIdx2% - MENU_VISIBLE_COUNT%  ' Number of overflow items
        IF ovCount2% > 0 THEN
            SELECT CASE k&
                CASE 18432 ' Up arrow
                    IF MENU_OVERFLOW_HOVER% <= 0 THEN
                        MENU_OVERFLOW_HOVER% = ovCount2% - 1
                    ELSE
                        MENU_OVERFLOW_HOVER% = MENU_OVERFLOW_HOVER% - 1
                    END IF
                    MENU_BAR.kbActive% = TRUE
                    GUI_NEEDS_REDRAW% = TRUE
                    MENUBAR_handle_key% = TRUE
                    EXIT FUNCTION

                CASE 20480 ' Down arrow
                    IF MENU_OVERFLOW_HOVER% >= ovCount2% - 1 THEN
                        MENU_OVERFLOW_HOVER% = 0
                    ELSE
                        MENU_OVERFLOW_HOVER% = MENU_OVERFLOW_HOVER% + 1
                    END IF
                    MENU_BAR.kbActive% = TRUE
                    GUI_NEEDS_REDRAW% = TRUE
                    MENUBAR_handle_key% = TRUE
                    EXIT FUNCTION

                CASE 13 ' Enter — open the hovered overflow menu's submenu
                    IF MENU_OVERFLOW_HOVER% >= 0 AND MENU_OVERFLOW_HOVER% < ovCount2% THEN
                        DIM ovRootIdx AS INTEGER
                        ovRootIdx% = MENU_VISIBLE_COUNT% + MENU_OVERFLOW_HOVER%
                        IF MENU_ROOT_ENABLED(ovRootIdx%) THEN
                            MENU_OVERFLOW_OPEN% = FALSE
                            MENU_OVERFLOW_HOVER% = -1
                            MENU_BAR.openMenu% = ovRootIdx%
                            MENU_BAR.hoverRoot% = ovRootIdx%
                            MENU_BAR.hoverSub% = -1
                            MENU_BAR.subScroll% = 0
                            MENU_BAR.kbActive% = TRUE
                            GUI_NEEDS_REDRAW% = TRUE
                            SCENE_DIRTY% = TRUE
                        END IF
                    END IF
                    MENUBAR_handle_key% = TRUE
                    EXIT FUNCTION

                CASE 19200 ' Left arrow — close overflow, go to last visible root
                    MENU_OVERFLOW_OPEN% = FALSE
                    MENU_OVERFLOW_HOVER% = -1
                    DIM ovPrev AS INTEGER
                    ovPrev% = MENU_VISIBLE_COUNT% - 1
                    IF ovPrev% < 0 THEN ovPrev% = 0
                    MENU_BAR.openMenu% = ovPrev%
                    MENU_BAR.hoverRoot% = ovPrev%
                    MENU_BAR.hoverSub% = -1
                    MENU_BAR.subScroll% = 0
                    MENU_BAR.kbActive% = TRUE
                    GUI_NEEDS_REDRAW% = TRUE
                    SCENE_DIRTY% = TRUE
                    MENUBAR_handle_key% = TRUE
                    EXIT FUNCTION

                CASE 19712 ' Right arrow — close overflow, go to HELP
                    MENU_OVERFLOW_OPEN% = FALSE
                    MENU_OVERFLOW_HOVER% = -1
                    MENU_BAR.openMenu% = MENU_ROOT_COUNT% - 1
                    MENU_BAR.hoverRoot% = MENU_ROOT_COUNT% - 1
                    MENU_BAR.hoverSub% = -1
                    MENU_BAR.subScroll% = 0
                    MENU_BAR.kbActive% = TRUE
                    GUI_NEEDS_REDRAW% = TRUE
                    SCENE_DIRTY% = TRUE
                    MENUBAR_handle_key% = TRUE
                    EXIT FUNCTION

                CASE 27 ' Escape
                    MENU_OVERFLOW_OPEN% = FALSE
                    MENU_OVERFLOW_HOVER% = -1
                    GUI_NEEDS_REDRAW% = TRUE
                    MENUBAR_handle_key% = TRUE
                    EXIT FUNCTION
            END SELECT
        END IF
    END IF

    ' Only handle remaining keys when a submenu is open
    IF MENU_BAR.openMenu% < 0 THEN EXIT FUNCTION

    ' --- Recent submenu keyboard navigation ---
    IF MENU_BAR.recentOpen% AND RECENT_FILE_COUNT% > 0 THEN
        DIM recMax AS INTEGER
        recMax% = RECENT_FILE_COUNT%  ' 0..count-1 = files, count = CLEAR
        SELECT CASE k&
            CASE 18432 ' Up arrow
                IF MENU_BAR.recentHover% <= 0 THEN
                    MENU_BAR.recentHover% = recMax%  ' Wrap to CLEAR
                ELSE
                    MENU_BAR.recentHover% = MENU_BAR.recentHover% - 1
                END IF
                SOUND_play SND_MENU_HOVER
                MENU_BAR.kbActive% = TRUE
                GUI_NEEDS_REDRAW% = TRUE
                MENUBAR_handle_key% = TRUE
                EXIT FUNCTION

            CASE 20480 ' Down arrow
                IF MENU_BAR.recentHover% >= recMax% THEN
                    MENU_BAR.recentHover% = 0  ' Wrap to first file
                ELSE
                    MENU_BAR.recentHover% = MENU_BAR.recentHover% + 1
                END IF
                SOUND_play SND_MENU_HOVER
                MENU_BAR.kbActive% = TRUE
                GUI_NEEDS_REDRAW% = TRUE
                MENUBAR_handle_key% = TRUE
                EXIT FUNCTION

            CASE 13 ' Enter
                IF MENU_BAR.recentHover% >= 0 AND MENU_BAR.recentHover% < RECENT_FILE_COUNT% THEN
                    ' Load recent file
                    DIM recPath AS STRING
                    recPath$ = RECENT_FILES(MENU_BAR.recentHover% + 1)
                    MENUBAR_close_all

                    IF NOT _FILEEXISTS(recPath$) THEN
                        DIM rmb1 AS INTEGER
                        rmb1% = _MESSAGEBOX("File Not Found", "File not found:" + CHR$(10) + recPath$ + CHR$(10) + CHR$(10) + "Remove from recent files?", "yesno", "warning")
                        DO WHILE _MOUSEINPUT: LOOP
                        MOUSE_force_buttons_up
                        IF rmb1% = 1 THEN
                            DIM rj AS INTEGER
                            FOR rj% = (MENU_BAR.recentHover% + 1) TO RECENT_FILE_COUNT% - 1
                                RECENT_FILES(rj%) = RECENT_FILES(rj% + 1)
                            NEXT rj%
                            RECENT_FILES(RECENT_FILE_COUNT%) = ""
                            RECENT_FILE_COUNT% = RECENT_FILE_COUNT% - 1
                            CONFIG_save
                        END IF
                    ELSE
                        IF CANVAS_DIRTY% THEN
                            DIM rmb2 AS INTEGER
                            rmb2% = _MESSAGEBOX("Unsaved Changes", "Save changes before opening?", "yesnocancel", "warning")
                            DO WHILE _MOUSEINPUT: LOOP
                            MOUSE_force_buttons_up
                            IF rmb2% = 0 THEN
                                MENUBAR_handle_key% = TRUE
                                EXIT FUNCTION
                            END IF
                            IF rmb2% = 1 THEN
                                IF LEN(CURRENT_DRW_FILENAME$) > 0 THEN
                                    DRW_save_binary CURRENT_DRW_FILENAME$
                                ELSE
                                    DRW_save_dialog
                                END IF
                            END IF
                        END IF
                        DRW_load recPath$
                        CURRENT_DRW_FILENAME$ = recPath$
                        CURRENT_FILENAME$ = recPath$
                        RECENT_add_file recPath$
                        CFG.LAST_DIR_OPEN$ = CONFIG_extract_dir$(recPath$)
                        CANVAS_DIRTY% = FALSE
                    END IF
                ELSEIF MENU_BAR.recentHover% = RECENT_FILE_COUNT% THEN
                    ' CLEAR
                    DIM rmb3 AS INTEGER
                    rmb3% = _MESSAGEBOX("Clear Recent Files", "Clear all recent files?", "yesno", "info")
                    DO WHILE _MOUSEINPUT: LOOP
                    MOUSE_force_buttons_up
                    IF rmb3% = 1 THEN RECENT_clear
                    MENUBAR_close_all
                END IF
                MENUBAR_handle_key% = TRUE
                EXIT FUNCTION

            CASE 19200, 27 ' Left arrow or Escape - close recent submenu
                MENU_BAR.recentOpen% = FALSE
                MENU_BAR.recentHover% = -1
                MENU_BAR.kbActive% = TRUE
                GUI_NEEDS_REDRAW% = TRUE
                MENUBAR_handle_key% = TRUE
                EXIT FUNCTION
        END SELECT
    END IF

    ' --- Random Track submenu keyboard navigation ---
    IF MENU_BAR.randomOpen% THEN
        SELECT CASE k&
            CASE 18432 ' Up arrow
                IF MENU_BAR.randomHover% <= 0 THEN
                    MENU_BAR.randomHover% = 3
                ELSE
                    MENU_BAR.randomHover% = MENU_BAR.randomHover% - 1
                END IF
                SOUND_play SND_MENU_HOVER
                MENU_BAR.kbActive% = TRUE
                GUI_NEEDS_REDRAW% = TRUE
                MENUBAR_handle_key% = TRUE
                EXIT FUNCTION

            CASE 20480 ' Down arrow
                IF MENU_BAR.randomHover% >= 3 THEN
                    MENU_BAR.randomHover% = 0
                ELSE
                    MENU_BAR.randomHover% = MENU_BAR.randomHover% + 1
                END IF
                SOUND_play SND_MENU_HOVER
                MENU_BAR.kbActive% = TRUE
                GUI_NEEDS_REDRAW% = TRUE
                MENUBAR_handle_key% = TRUE
                EXIT FUNCTION

            CASE 13 ' Enter
                IF MENU_BAR.randomHover% >= 0 AND MENU_BAR.randomHover% <= 3 THEN
                    MENUBAR_close_all
                    SELECT CASE MENU_BAR.randomHover%
                        CASE 0: CMD_execute_action 429  ' .MOD
                        CASE 1: CMD_execute_action 430  ' .IT
                        CASE 2: CMD_execute_action 431  ' .XM
                        CASE 3: CMD_execute_action 432  ' .RAD
                    END SELECT
                END IF
                MENUBAR_handle_key% = TRUE
                EXIT FUNCTION

            CASE 19200, 27 ' Left arrow or Escape - close random submenu
                MENU_BAR.randomOpen% = FALSE
                MENU_BAR.randomHover% = -1
                MENU_BAR.kbActive% = TRUE
                GUI_NEEDS_REDRAW% = TRUE
                MENUBAR_handle_key% = TRUE
                EXIT FUNCTION
        END SELECT
    END IF

    ' --- Main menu keyboard navigation ---
    SELECT CASE k&
        CASE 19200 ' Left arrow
            ' Move to previous visible root menu (wrap around, skip disabled, skip overflow)
            DIM prevMenu AS INTEGER, prevLoops AS INTEGER
            prevMenu% = MENU_BAR.openMenu%
            prevLoops% = 0
            DO
                prevMenu% = prevMenu% - 1
                IF prevMenu% < 0 THEN prevMenu% = MENU_ROOT_COUNT% - 1
                ' Skip overflow items — jump from first visible to HELP
                IF MENU_CHEVRON_ACTIVE% AND prevMenu% >= MENU_VISIBLE_COUNT% AND prevMenu% <> MENU_ROOT_COUNT% - 1 THEN
                    ' If we're going left past overflow, open the overflow popup instead
                    IF MENU_BAR.openMenu% = MENU_ROOT_COUNT% - 1 THEN
                        ' Going left from HELP -> open overflow popup
                        MENU_BAR.openMenu% = -1
                        MENU_BAR.hoverSub% = -1
                        MENU_OVERFLOW_OPEN% = TRUE
                        MENU_OVERFLOW_HOVER% = (MENU_ROOT_COUNT% - 2) - MENU_VISIBLE_COUNT% ' last overflow item
                        MENU_BAR.kbActive% = TRUE
                        GUI_NEEDS_REDRAW% = TRUE
                        SCENE_DIRTY% = TRUE
                        MENUBAR_handle_key% = TRUE
                        EXIT FUNCTION
                    END IF
                    prevMenu% = MENU_VISIBLE_COUNT% - 1  ' Jump to last visible
                    IF prevMenu% < 0 THEN prevMenu% = MENU_ROOT_COUNT% - 1
                END IF
                prevLoops% = prevLoops% + 1
                IF prevLoops% > MENU_ROOT_COUNT% THEN EXIT DO ' All disabled
            LOOP UNTIL MENU_ROOT_ENABLED(prevMenu%)
            MENU_BAR.openMenu% = prevMenu%
            MENU_BAR.hoverRoot% = MENU_BAR.openMenu%
            MENU_BAR.hoverSub% = -1
            MENU_BAR.subScroll% = 0
            SOUND_play SND_MENU_OPEN
            MENU_BAR.kbActive% = TRUE
            GUI_NEEDS_REDRAW% = TRUE
            SCENE_DIRTY% = TRUE
            MENUBAR_handle_key% = TRUE

        CASE 19712 ' Right arrow
            ' Check if hovered item is RECENT - if so, open recent submenu
            IF MENU_BAR.hoverSub% = MENU_BAR.recentItemIdx% AND RECENT_FILE_COUNT% > 0 THEN
                MENU_BAR.recentOpen% = TRUE
                MENU_BAR.recentHover% = 0
                MENU_BAR.kbActive% = TRUE
                GUI_NEEDS_REDRAW% = TRUE
                MENUBAR_handle_key% = TRUE
            ELSEIF MENU_BAR.hoverSub% = MENU_BAR.randomItemIdx% THEN
                MENU_BAR.randomOpen% = TRUE
                MENU_BAR.randomHover% = 0
                MENU_BAR.kbActive% = TRUE
                GUI_NEEDS_REDRAW% = TRUE
                MENUBAR_handle_key% = TRUE
            ELSE
                ' Move to next visible root menu (wrap around, skip disabled, skip overflow)
                DIM nextMenu AS INTEGER, nextLoops AS INTEGER
                nextMenu% = MENU_BAR.openMenu%
                nextLoops% = 0
                DO
                    nextMenu% = nextMenu% + 1
                    IF nextMenu% >= MENU_ROOT_COUNT% THEN nextMenu% = 0
                    ' Skip overflow items — jump from last visible to overflow popup
                    IF MENU_CHEVRON_ACTIVE% AND nextMenu% >= MENU_VISIBLE_COUNT% AND nextMenu% <> MENU_ROOT_COUNT% - 1 THEN
                        ' Going right past last visible -> open overflow popup
                        MENU_BAR.openMenu% = -1
                        MENU_BAR.hoverSub% = -1
                        MENU_OVERFLOW_OPEN% = TRUE
                        MENU_OVERFLOW_HOVER% = 0  ' first overflow item
                        MENU_BAR.kbActive% = TRUE
                        GUI_NEEDS_REDRAW% = TRUE
                        SCENE_DIRTY% = TRUE
                        MENUBAR_handle_key% = TRUE
                        EXIT FUNCTION
                    END IF
                    nextLoops% = nextLoops% + 1
                    IF nextLoops% > MENU_ROOT_COUNT% THEN EXIT DO ' All disabled
                LOOP UNTIL MENU_ROOT_ENABLED(nextMenu%)
                MENU_BAR.openMenu% = nextMenu%
                MENU_BAR.hoverRoot% = MENU_BAR.openMenu%
                MENU_BAR.hoverSub% = -1
                MENU_BAR.subScroll% = 0
                SOUND_play SND_MENU_OPEN
                MENU_BAR.kbActive% = TRUE
                GUI_NEEDS_REDRAW% = TRUE
                SCENE_DIRTY% = TRUE
                MENUBAR_handle_key% = TRUE
            END IF

        CASE 18432 ' Up arrow
            ' Move up in submenu (skip dividers)
            MENUBAR_navigate_submenu -1
            MENUBAR_handle_key% = TRUE

        CASE 20480 ' Down arrow
            ' Move down in submenu (skip dividers)
            MENUBAR_navigate_submenu 1
            MENUBAR_handle_key% = TRUE

        CASE 13 ' Enter
            ' Execute hovered submenu item
            IF MENU_BAR.hoverSub% >= 0 THEN
                DIM childIdx2 AS INTEGER, itemIdx2 AS INTEGER
                childIdx2% = 0
                FOR itemIdx2% = 0 TO MENU_ITEM_COUNT% - 1
                    IF MENU_ITEMS(itemIdx2%).parentIdx% = MENU_BAR.openMenu% THEN
                        IF childIdx2% = MENU_BAR.hoverSub% THEN
                            IF NOT MENU_ITEMS(itemIdx2%).isDivider% AND MENU_ITEMS(itemIdx2%).enabled% THEN
                                ' Intercept RECENT item: open submenu instead
                                IF MENU_ITEMS(itemIdx2%).actionId% = 213 AND RECENT_FILE_COUNT% > 0 THEN
                                    MENU_BAR.recentOpen% = TRUE
                                    MENU_BAR.recentHover% = 0
                                    MENU_BAR.kbActive% = TRUE
                                    GUI_NEEDS_REDRAW% = TRUE
                                    MENUBAR_handle_key% = TRUE
                                    EXIT FUNCTION
                                END IF
                                IF MENU_ITEMS(itemIdx2%).hasCheckbox% THEN
                                    MENU_ITEMS(itemIdx2%).checked% = NOT MENU_ITEMS(itemIdx2%).checked%
                                END IF
                                DIM actId2 AS INTEGER
                                actId2% = MENU_ITEMS(itemIdx2%).actionId%
                                MENUBAR_close_all
                                IF actId2% > 0 THEN CMD_execute_action actId2%
                            END IF
                            MENUBAR_handle_key% = TRUE
                            EXIT FUNCTION
                        END IF
                        childIdx2% = childIdx2% + 1
                    END IF
                NEXT itemIdx2%
            END IF
            MENUBAR_handle_key% = TRUE

        CASE 27 ' Escape
            MENUBAR_close_all
            MENUBAR_handle_key% = TRUE

    END SELECT
END FUNCTION


''
' Navigate submenu up (-1) or down (+1), skipping dividers
'
SUB MENUBAR_navigate_submenu (direction AS INTEGER)
    DIM childIdx AS INTEGER
    DIM i AS INTEGER
    DIM totalChildren AS INTEGER

    ' Count ALL children (including dividers) and build a divider map
    totalChildren% = 0
    FOR i% = 0 TO MENU_ITEM_COUNT% - 1
        IF MENU_ITEMS(i%).parentIdx% = MENU_BAR.openMenu% THEN
            totalChildren% = totalChildren% + 1
        END IF
    NEXT i%

    IF totalChildren% = 0 THEN EXIT SUB

    ' Start from current position or edge
    DIM newPos AS INTEGER
    IF MENU_BAR.hoverSub% < 0 THEN
        IF direction% > 0 THEN
            newPos% = -1  ' Will be incremented to 0
        ELSE
            newPos% = totalChildren%  ' Will be decremented to last
        END IF
    ELSE
        newPos% = MENU_BAR.hoverSub%
    END IF

    ' Move in direction, skipping dividers, with wrapping
    DIM attempts AS INTEGER
    attempts% = 0
    DO
        newPos% = newPos% + direction%
        ' Wrap around
        IF newPos% < 0 THEN newPos% = totalChildren% - 1
        IF newPos% >= totalChildren% THEN newPos% = 0

        ' Check if this position is a divider
        childIdx% = 0
        DIM isDivider AS INTEGER
        isDivider% = FALSE
        FOR i% = 0 TO MENU_ITEM_COUNT% - 1
            IF MENU_ITEMS(i%).parentIdx% = MENU_BAR.openMenu% THEN
                IF childIdx% = newPos% THEN
                    isDivider% = MENU_ITEMS(i%).isDivider%
                    EXIT FOR
                END IF
                childIdx% = childIdx% + 1
            END IF
        NEXT i%

        IF NOT isDivider% THEN EXIT DO

        attempts% = attempts% + 1
        IF attempts% >= totalChildren% THEN EXIT DO  ' Safety: all dividers
    LOOP

    MENU_BAR.hoverSub% = newPos%
    IF MENU_BAR.hoverSub% = MENU_BAR.recentItemIdx% OR MENU_BAR.hoverSub% = MENU_BAR.randomItemIdx% THEN
        SOUND_play SND_MENU_OPEN
    ELSE
        SOUND_play SND_MENU_HOVER
    END IF
    MENU_BAR.kbActive% = TRUE

    ' Scroll so the newly hovered item is visible in the viewport
    ' Compute virtual Y (content-space, from top of submenu) of the selected item
    DIM virtY AS INTEGER, ci2 AS INTEGER, ii2 AS INTEGER
    virtY% = 2
    ci2% = 0
    FOR ii2% = 0 TO MENU_ITEM_COUNT% - 1
        IF MENU_ITEMS(ii2%).parentIdx% = MENU_BAR.openMenu% THEN
            IF ci2% = newPos% THEN EXIT FOR
            IF MENU_ITEMS(ii2%).isDivider% THEN
                virtY% = virtY% + MENU_DIVIDER_HEIGHT
            ELSE
                virtY% = virtY% + MENU_ITEM_HEIGHT
            END IF
            ci2% = ci2% + 1
        END IF
    NEXT ii2%
    ' virtY% is the virtual top of the selected item
    ' Arrow rows reserve space at top/bottom when scrolled
    DIM arrowR AS INTEGER
    arrowR% = MENU_ITEM_HEIGHT
    ' Scroll up to reveal item above top
    IF virtY% - MENU_BAR.subScroll% < arrowR% THEN
        MENU_BAR.subScroll% = virtY% - arrowR%
        IF MENU_BAR.subScroll% < 0 THEN MENU_BAR.subScroll% = 0
    END IF
    ' Scroll down to reveal item below bottom
    DIM visH AS INTEGER
    visH% = MENU_BAR.subH% - 4
    IF visH% < MENU_ITEM_HEIGHT THEN visH% = MENU_ITEM_HEIGHT
    IF virtY% + MENU_ITEM_HEIGHT - MENU_BAR.subScroll% > visH% - arrowR% THEN
        MENU_BAR.subScroll% = virtY% + MENU_ITEM_HEIGHT + arrowR% - visH%
        IF MENU_BAR.subScroll% < 0 THEN MENU_BAR.subScroll% = 0
    END IF

    GUI_NEEDS_REDRAW% = TRUE
END SUB


''
' Check if point is within the menu bar area
'
FUNCTION MENUBAR_in_bounds% (rawX AS INTEGER, rawY AS INTEGER)
    IF NOT MENU_BAR.visible% THEN
        MENUBAR_in_bounds% = FALSE
        EXIT FUNCTION
    END IF
    MENUBAR_in_bounds% = (rawY% >= MENU_BAR.barY% AND rawY% < MENU_BAR.barY% + MENU_BAR.barH% _
        AND rawX% >= MENU_BAR.barX% AND rawX% < MENU_BAR.barX% + MENU_BAR.barW%)
END FUNCTION


''
' Check if point is within the open submenu area
'
FUNCTION MENUBAR_submenu_in_bounds% (rawX AS INTEGER, rawY AS INTEGER)
    IF MENU_BAR.openMenu% < 0 THEN
        MENUBAR_submenu_in_bounds% = FALSE
        EXIT FUNCTION
    END IF
    MENUBAR_submenu_in_bounds% = (rawX% >= MENU_BAR.subX% AND rawX% < MENU_BAR.subX% + MENU_BAR.subW% _
        AND rawY% >= MENU_BAR.subY% AND rawY% < MENU_BAR.subY% + MENU_BAR.subH%)
END FUNCTION


''
' Check if any menu is open
'
FUNCTION MENUBAR_is_open% ()
    MENUBAR_is_open% = (MENU_BAR.openMenu% >= 0) OR MENU_OVERFLOW_OPEN%
END FUNCTION


''
' Get submenu item index at a given Y coordinate
' Returns the non-divider child index, or -1 if on a divider or outside
'
FUNCTION MENUBAR_get_submenu_item_at% (rawY AS INTEGER)
    DIM virtY AS INTEGER, i AS INTEGER
    DIM childIdx AS INTEGER
    DIM screenItemY AS INTEGER, itemH AS INTEGER

    ' Account for up-scroll arrow occupying the top row
    DIM arrowOffset AS INTEGER
    arrowOffset% = 0
    IF MENU_BAR.subScroll% > 0 THEN arrowOffset% = MENU_ITEM_HEIGHT

    ' Reject clicks in the scroll arrow rows
    ' Up arrow zone
    IF MENU_BAR.subScroll% > 0 THEN
        IF rawY% >= MENU_BAR.subY% AND rawY% < MENU_BAR.subY% + MENU_ITEM_HEIGHT + 2 THEN
            MENUBAR_get_submenu_item_at% = -1
            EXIT FUNCTION
        END IF
    END IF
    ' Down arrow zone — only block it when a down arrow is actually being shown
    IF MENU_BAR.subScroll% < MENU_BAR.subScrollMax% THEN
        IF rawY% >= MENU_BAR.subY% + MENU_BAR.subH% - MENU_ITEM_HEIGHT - 2 AND rawY% < MENU_BAR.subY% + MENU_BAR.subH% THEN
            MENUBAR_get_submenu_item_at% = -1
            EXIT FUNCTION
        END IF
    END IF

    virtY% = 2
    childIdx% = 0

    FOR i% = 0 TO MENU_ITEM_COUNT% - 1
        IF MENU_ITEMS(i%).parentIdx% <> MENU_BAR.openMenu% THEN GOTO MENUBAR_next_at

        IF MENU_ITEMS(i%).isDivider% THEN
            itemH% = MENU_DIVIDER_HEIGHT
        ELSE
            itemH% = MENU_ITEM_HEIGHT
        END IF

        screenItemY% = MENU_BAR.subY% + virtY% - MENU_BAR.subScroll% + arrowOffset%

        IF NOT MENU_ITEMS(i%).isDivider% THEN
            IF rawY% >= screenItemY% AND rawY% < screenItemY% + MENU_ITEM_HEIGHT THEN
                MENUBAR_get_submenu_item_at% = childIdx%
                EXIT FUNCTION
            END IF
        END IF

        virtY% = virtY% + itemH%
        childIdx% = childIdx% + 1

        MENUBAR_next_at:
    NEXT i%

    MENUBAR_get_submenu_item_at% = -1
END FUNCTION


''
' Render the Recent Files cascading submenu
' Positioned to the right of the main File dropdown, aligned with the RECENT item
'
SUB MENUBAR_render_recent_submenu ()
    DIM i AS INTEGER
    DIM subBg AS _UNSIGNED LONG, subFg AS _UNSIGNED LONG
    DIM subBorder AS _UNSIGNED LONG, subDivider AS _UNSIGNED LONG
    DIM subSelBg AS _UNSIGNED LONG, subSelFg AS _UNSIGNED LONG
    DIM maxW AS INTEGER, totalH AS INTEGER
    DIM itemY AS INTEGER, fn AS STRING
    DIM totalItems AS INTEGER
    DIM maxHotkeyW AS INTEGER
    DIM fw AS INTEGER
    DIM rhk AS STRING
    DIM hkX AS INTEGER

    ' Get theme colors (same as main submenu)
    subBg~& = THEME.MENU_SUB_bg~&
    subFg~& = THEME.MENU_SUB_fg~&
    subBorder~& = THEME.MENU_SUB_border~&
    subDivider~& = THEME.MENU_SUB_divider~&
    subSelBg~& = THEME.MENU_SUB_sel_bg~&
    subSelFg~& = THEME.MENU_SUB_sel_fg~&

    ' totalItems = recent files + divider + CLEAR
    totalItems% = RECENT_FILE_COUNT% + 2

    ' Measure max filename width and hotkey column width
    maxHotkeyW% = _PRINTWIDTH("ALT+0")  ' All hotkeys are same visual width
    maxW% = _PRINTWIDTH("CLEAR RECENT")  ' Minimum label width (CLEAR has no hotkey)
    FOR i% = 1 TO RECENT_FILE_COUNT%
        fn$ = RECENT_extract_filename$(RECENT_FILES(i%))
        fw% = _PRINTWIDTH(fn$)
        IF fw% > maxW% THEN maxW% = fw%
    NEXT i%

    ' Calculate dimensions (include hotkey column alongside filename column)
    MENU_BAR.recentW% = MENU_SUB_PAD_LEFT + maxW% + MENU_SUB_HOTKEY_GAP + maxHotkeyW% + MENU_SUB_PAD_RIGHT
    IF MENU_BAR.recentW% < 120 THEN MENU_BAR.recentW% = 120

    totalH% = 4 ' Top/bottom padding
    totalH% = totalH% + (RECENT_FILE_COUNT% * MENU_ITEM_HEIGHT) ' File items
    totalH% = totalH% + MENU_DIVIDER_HEIGHT                     ' Divider
    totalH% = totalH% + MENU_ITEM_HEIGHT                        ' CLEAR item
    MENU_BAR.recentH% = totalH%

    ' Position to the right of the main submenu, aligned with RECENT item Y
    MENU_BAR.recentX% = MENU_BAR.subX% + MENU_BAR.subW%
    IF MENU_BAR.recentY% = 0 THEN
        MENU_BAR.recentY% = MENU_BAR.subY%  ' Fallback
    END IF

    ' Clamp right edge to screen
    IF MENU_BAR.recentX% + MENU_BAR.recentW% > SCRN.w& THEN
        ' Place to the LEFT of the main submenu instead
        MENU_BAR.recentX% = MENU_BAR.subX% - MENU_BAR.recentW%
        IF MENU_BAR.recentX% < 0 THEN MENU_BAR.recentX% = 0
    END IF

    ' Clamp bottom to screen
    IF MENU_BAR.recentY% + MENU_BAR.recentH% > SCRN.h& THEN
        MENU_BAR.recentY% = SCRN.h& - MENU_BAR.recentH%
        IF MENU_BAR.recentY% < 0 THEN MENU_BAR.recentY% = 0
    END IF

    ' Draw border
    LINE (MENU_BAR.recentX% - 1, MENU_BAR.recentY% - 1)-(MENU_BAR.recentX% + MENU_BAR.recentW%, MENU_BAR.recentY% + MENU_BAR.recentH%), subBorder~&, BF

    ' Draw background
    LINE (MENU_BAR.recentX%, MENU_BAR.recentY%)-(MENU_BAR.recentX% + MENU_BAR.recentW% - 1, MENU_BAR.recentY% + MENU_BAR.recentH% - 1), subBg~&, BF

    ' Draw recent file items
    itemY% = MENU_BAR.recentY% + 2
    FOR i% = 1 TO RECENT_FILE_COUNT%
        fn$ = RECENT_extract_filename$(RECENT_FILES(i%))

        ' Hover highlight (recentHover is 0-based: 0..count-1 = files)
        IF (i% - 1) = MENU_BAR.recentHover% THEN
            LINE (MENU_BAR.recentX% + 1, itemY%)-(MENU_BAR.recentX% + MENU_BAR.recentW% - 2, itemY% + MENU_ITEM_HEIGHT - 1), subSelBg~&, BF
            COLOR subSelFg~&, _RGBA32(0, 0, 0, 0)
        ELSE
            COLOR subFg~&, _RGBA32(0, 0, 0, 0)
        END IF

        _PRINTSTRING (MENU_BAR.recentX% + MENU_SUB_PAD_LEFT, itemY% + 2), fn$

        ' Draw hotkey right-aligned (ALT+1..ALT+9 for slots 1-9, ALT+0 for slot 10)
        IF i% <= 9 THEN
            rhk$ = "ALT+" + LTRIM$(STR$(i%))
        ELSE
            rhk$ = "ALT+0"
        END IF
        hkX% = MENU_BAR.recentX% + MENU_BAR.recentW% - _PRINTWIDTH(rhk$) - MENU_SUB_PAD_RIGHT
        _PRINTSTRING (hkX%, itemY% + 2), rhk$

        itemY% = itemY% + MENU_ITEM_HEIGHT
    NEXT i%

    ' Draw divider
    DIM divY AS INTEGER
    divY% = itemY% + MENU_DIVIDER_HEIGHT \ 2
    LINE (MENU_BAR.recentX% + 4, divY%)-(MENU_BAR.recentX% + MENU_BAR.recentW% - 5, divY%), subDivider~&
    itemY% = itemY% + MENU_DIVIDER_HEIGHT

    ' Draw CLEAR item (recentHover = RECENT_FILE_COUNT% means CLEAR)
    IF MENU_BAR.recentHover% = RECENT_FILE_COUNT% THEN
        LINE (MENU_BAR.recentX% + 1, itemY%)-(MENU_BAR.recentX% + MENU_BAR.recentW% - 2, itemY% + MENU_ITEM_HEIGHT - 1), subSelBg~&, BF
        COLOR subSelFg~&, _RGBA32(0, 0, 0, 0)
    ELSE
        COLOR subFg~&, _RGBA32(0, 0, 0, 0)
    END IF
    _PRINTSTRING (MENU_BAR.recentX% + MENU_SUB_PAD_LEFT, itemY% + 2), "CLEAR RECENT"
END SUB


''
' Handle click inside the recent files submenu
'
SUB MENUBAR_handle_recent_click (rawX AS INTEGER, rawY AS INTEGER)
    IF NOT MENU_BAR.recentOpen% THEN EXIT SUB
    IF RECENT_FILE_COUNT% = 0 THEN EXIT SUB
    IF NOT MENUBAR_recent_in_bounds%(rawX%, rawY%) THEN EXIT SUB

    ' Determine which item was clicked
    DIM itemY AS INTEGER, i AS INTEGER
    itemY% = MENU_BAR.recentY% + 2

    ' Check file items
    FOR i% = 1 TO RECENT_FILE_COUNT%
        IF rawY% >= itemY% AND rawY% < itemY% + MENU_ITEM_HEIGHT THEN
            ' Clicked on recent file i%
            DIM filePath AS STRING
            filePath$ = RECENT_FILES(i%)
            MENUBAR_close_all

            ' Check if file exists
            IF NOT _FILEEXISTS(filePath$) THEN
                DIM mb1 AS INTEGER
                mb1% = _MESSAGEBOX("File Not Found", "File not found:" + CHR$(10) + filePath$ + CHR$(10) + CHR$(10) + "Remove from recent files?", "yesno", "warning")
                DO WHILE _MOUSEINPUT: LOOP
                MOUSE_force_buttons_up
                IF mb1% = 1 THEN
                    ' Remove this entry by shifting down
                    DIM j AS INTEGER
                    FOR j% = i% TO RECENT_FILE_COUNT% - 1
                        RECENT_FILES(j%) = RECENT_FILES(j% + 1)
                    NEXT j%
                    RECENT_FILES(RECENT_FILE_COUNT%) = ""
                    RECENT_FILE_COUNT% = RECENT_FILE_COUNT% - 1
                    CONFIG_save
                END IF
                EXIT SUB
            END IF

            ' Prompt to save if dirty
            IF CANVAS_DIRTY% THEN
                DIM mb2 AS INTEGER
                mb2% = _MESSAGEBOX("Unsaved Changes", "Save changes before opening?", "yesnocancel", "warning")
                DO WHILE _MOUSEINPUT: LOOP
                MOUSE_force_buttons_up
                IF mb2% = 0 THEN EXIT SUB ' Cancel
                IF mb2% = 1 THEN          ' Yes - save first
                    IF LEN(CURRENT_DRW_FILENAME$) > 0 THEN
                        DRW_save_binary CURRENT_DRW_FILENAME$
                    ELSE
                        DRW_save_dialog
                    END IF
                END IF
                ' mb2% = 2 = No, proceed without saving
            END IF

            ' Load the file
            DRW_load filePath$
            CURRENT_DRW_FILENAME$ = filePath$
            CURRENT_FILENAME$ = filePath$
            RECENT_add_file filePath$
            CFG.LAST_DIR_OPEN$ = CONFIG_extract_dir$(filePath$)
            CANVAS_DIRTY% = FALSE
            EXIT SUB
        END IF
        itemY% = itemY% + MENU_ITEM_HEIGHT
    NEXT i%

    ' Skip divider area
    itemY% = itemY% + MENU_DIVIDER_HEIGHT

    ' Check CLEAR item
    IF rawY% >= itemY% AND rawY% < itemY% + MENU_ITEM_HEIGHT THEN
        DIM mb3 AS INTEGER
        mb3% = _MESSAGEBOX("Clear Recent Files", "Clear all recent files?", "yesno", "info")
        DO WHILE _MOUSEINPUT: LOOP
        MOUSE_force_buttons_up
        IF mb3% = 1 THEN
            RECENT_clear
        END IF
        MENUBAR_close_all
        EXIT SUB
    END IF
END SUB


''
' Check if a point is within the recent files submenu bounds
'
FUNCTION MENUBAR_recent_in_bounds% (rawX AS INTEGER, rawY AS INTEGER)
    IF NOT MENU_BAR.recentOpen% OR RECENT_FILE_COUNT% = 0 THEN
        MENUBAR_recent_in_bounds% = FALSE
        EXIT FUNCTION
    END IF
    MENUBAR_recent_in_bounds% = (rawX% >= MENU_BAR.recentX% AND rawX% < MENU_BAR.recentX% + MENU_BAR.recentW% _
        AND rawY% >= MENU_BAR.recentY% AND rawY% < MENU_BAR.recentY% + MENU_BAR.recentH%)
END FUNCTION


''
' Render the overflow popup showing hidden root menu labels
'
SUB MENUBAR_render_overflow_popup ()
    IF NOT MENU_CHEVRON_ACTIVE% THEN EXIT SUB

    DIM helpIdx3 AS INTEGER
    DIM ovCount AS INTEGER, i AS INTEGER, y AS INTEGER
    DIM ovLbl AS STRING, ovW AS INTEGER, ovMaxW AS INTEGER
    DIM subBg AS _UNSIGNED LONG, subFg AS _UNSIGNED LONG
    DIM subBorder AS _UNSIGNED LONG, subSelBg AS _UNSIGNED LONG
    DIM subSelFg AS _UNSIGNED LONG

    helpIdx3% = MENU_ROOT_COUNT% - 1

    ' Count overflow items and measure widths
    ovCount% = 0
    ovMaxW% = 0
    FOR i% = MENU_VISIBLE_COUNT% TO helpIdx3% - 1
        ovLbl$ = RTRIM$(MENU_ROOT_LABEL(i%))
        ovW% = _PRINTWIDTH(ovLbl$)
        IF ovW% > ovMaxW% THEN ovMaxW% = ovW%
        ovCount% = ovCount% + 1
    NEXT i%
    IF ovCount% = 0 THEN EXIT SUB

    ' Theme colors
    subBg~& = THEME.MENU_SUB_bg~&
    subFg~& = THEME.MENU_SUB_fg~&
    subBorder~& = THEME.MENU_SUB_border~&
    subSelBg~& = THEME.MENU_SUB_sel_bg~&
    subSelFg~& = THEME.MENU_SUB_sel_fg~&

    ' Calculate popup dimensions
    DIM popW AS INTEGER, popH AS INTEGER
    popW% = MENU_SUB_PAD_LEFT + ovMaxW% + MENU_SUB_PAD_RIGHT
    IF popW% < 60 THEN popW% = 60
    popH% = 4 + (ovCount% * MENU_ITEM_HEIGHT) ' 2px top + 2px bottom padding

    ' Position below the chevron
    MENU_OVERFLOW_X% = MENU_CHEVRON_X%
    MENU_OVERFLOW_Y% = MENU_BAR.barY% + MENU_BAR.barH%
    MENU_OVERFLOW_W% = popW%
    MENU_OVERFLOW_H% = popH%

    ' Clamp right edge to screen
    IF MENU_OVERFLOW_X% + MENU_OVERFLOW_W% > SCRN.w& THEN
        MENU_OVERFLOW_X% = SCRN.w& - MENU_OVERFLOW_W%
        IF MENU_OVERFLOW_X% < 0 THEN MENU_OVERFLOW_X% = 0
    END IF

    ' Draw border
    LINE (MENU_OVERFLOW_X% - 1, MENU_OVERFLOW_Y% - 1)-(MENU_OVERFLOW_X% + MENU_OVERFLOW_W%, MENU_OVERFLOW_Y% + MENU_OVERFLOW_H%), subBorder~&, BF

    ' Draw background
    LINE (MENU_OVERFLOW_X%, MENU_OVERFLOW_Y%)-(MENU_OVERFLOW_X% + MENU_OVERFLOW_W% - 1, MENU_OVERFLOW_Y% + MENU_OVERFLOW_H% - 1), subBg~&, BF

    ' Draw overflow items
    y% = MENU_OVERFLOW_Y% + 2
    DIM ovIdx AS INTEGER
    ovIdx% = 0
    FOR i% = MENU_VISIBLE_COUNT% TO helpIdx3% - 1
        ovLbl$ = RTRIM$(MENU_ROOT_LABEL(i%))

        IF ovIdx% = MENU_OVERFLOW_HOVER% THEN
            LINE (MENU_OVERFLOW_X% + 1, y%)-(MENU_OVERFLOW_X% + MENU_OVERFLOW_W% - 2, y% + MENU_ITEM_HEIGHT - 1), subSelBg~&, BF
            COLOR subSelFg~&, _RGBA32(0, 0, 0, 0)
        ELSEIF NOT MENU_ROOT_ENABLED(i%) THEN
            COLOR THEME.MENU_BAR_disabled_fg~&, _RGBA32(0, 0, 0, 0)
        ELSE
            COLOR subFg~&, _RGBA32(0, 0, 0, 0)
        END IF

        _PRINTSTRING (MENU_OVERFLOW_X% + MENU_SUB_PAD_LEFT, y% + 2), ovLbl$
        y% = y% + MENU_ITEM_HEIGHT
        ovIdx% = ovIdx% + 1
    NEXT i%
END SUB


''
' Check if a point is within the overflow popup bounds
'
FUNCTION MENUBAR_overflow_in_bounds% (rawX AS INTEGER, rawY AS INTEGER)
    IF NOT MENU_OVERFLOW_OPEN% OR NOT MENU_CHEVRON_ACTIVE% THEN
        MENUBAR_overflow_in_bounds% = FALSE
        EXIT FUNCTION
    END IF
    MENUBAR_overflow_in_bounds% = (rawX% >= MENU_OVERFLOW_X% AND rawX% < MENU_OVERFLOW_X% + MENU_OVERFLOW_W% _
        AND rawY% >= MENU_OVERFLOW_Y% AND rawY% < MENU_OVERFLOW_Y% + MENU_OVERFLOW_H%)
END FUNCTION


''
' Handle click inside the overflow popup
'
SUB MENUBAR_handle_overflow_click (rawX AS INTEGER, rawY AS INTEGER)
    IF NOT MENU_OVERFLOW_OPEN% OR NOT MENU_CHEVRON_ACTIVE% THEN EXIT SUB
    IF NOT MENUBAR_overflow_in_bounds%(rawX%, rawY%) THEN EXIT SUB

    ' Determine which overflow item was clicked
    DIM helpIdx4 AS INTEGER, i AS INTEGER, ovIdx AS INTEGER, itemY AS INTEGER
    helpIdx4% = MENU_ROOT_COUNT% - 1
    itemY% = MENU_OVERFLOW_Y% + 2
    ovIdx% = 0

    FOR i% = MENU_VISIBLE_COUNT% TO helpIdx4% - 1
        IF rawY% >= itemY% AND rawY% < itemY% + MENU_ITEM_HEIGHT THEN
            IF MENU_ROOT_ENABLED(i%) THEN
                ' Close overflow popup and open this root menu's submenu
                MENU_OVERFLOW_OPEN% = FALSE
                MENU_OVERFLOW_HOVER% = -1
                MENU_BAR.openMenu% = i%
                MENU_BAR.hoverRoot% = i%
                MENU_BAR.hoverSub% = -1
                MENU_BAR.subScroll% = 0
                MENU_BAR.stayOpen% = TRUE
                IF PALETTE_MENU_VISIBLE% THEN PALETTE_MENU_hide
                GUI_NEEDS_REDRAW% = TRUE
                SCENE_DIRTY% = TRUE
            END IF
            EXIT SUB
        END IF
        itemY% = itemY% + MENU_ITEM_HEIGHT
        ovIdx% = ovIdx% + 1
    NEXT i%
END SUB

''
' Render the Random Track cascading submenu (4 format options)
'
SUB MENUBAR_render_random_submenu ()
    DIM randBg  AS _UNSIGNED LONG
    DIM randFg  AS _UNSIGNED LONG
    DIM randBrd AS _UNSIGNED LONG
    DIM randSBg AS _UNSIGNED LONG
    DIM randSFg AS _UNSIGNED LONG
    DIM randItemY AS INTEGER
    DIM randTotalH AS INTEGER
    DIM randMaxW AS INTEGER, randFw AS INTEGER
    DIM randI AS INTEGER

    ' Label strings for the 4 format items (indices 0-3)
    DIM randLabels(0 TO 3) AS STRING
    randLabels(0) = ".MOD"
    randLabels(1) = ".IT"
    randLabels(2) = ".XM"
    randLabels(3) = ".RAD"

    randBg~&  = THEME.MENU_SUB_bg~&
    randFg~&  = THEME.MENU_SUB_fg~&
    randBrd~& = THEME.MENU_SUB_border~&
    randSBg~& = THEME.MENU_SUB_sel_bg~&
    randSFg~& = THEME.MENU_SUB_sel_fg~&

    ' Measure width
    randMaxW% = 0
    FOR randI% = 0 TO 3
        randFw% = _PRINTWIDTH(randLabels(randI%))
        IF randFw% > randMaxW% THEN randMaxW% = randFw%
    NEXT randI%
    MENU_BAR.randomW% = MENU_SUB_PAD_LEFT + randMaxW% + MENU_SUB_PAD_RIGHT
    IF MENU_BAR.randomW% < 80 THEN MENU_BAR.randomW% = 80

    randTotalH% = 4 + (4 * MENU_ITEM_HEIGHT)
    MENU_BAR.randomH% = randTotalH%

    ' Position to the right of the main submenu, aligned with RANDOM TRACK item Y
    MENU_BAR.randomX% = MENU_BAR.subX% + MENU_BAR.subW%
    IF MENU_BAR.randomY% = 0 THEN MENU_BAR.randomY% = MENU_BAR.subY%

    ' Clamp right edge to screen
    IF MENU_BAR.randomX% + MENU_BAR.randomW% > SCRN.w& THEN
        MENU_BAR.randomX% = MENU_BAR.subX% - MENU_BAR.randomW%
        IF MENU_BAR.randomX% < 0 THEN MENU_BAR.randomX% = 0
    END IF

    ' Clamp bottom to screen
    IF MENU_BAR.randomY% + MENU_BAR.randomH% > SCRN.h& THEN
        MENU_BAR.randomY% = SCRN.h& - MENU_BAR.randomH%
        IF MENU_BAR.randomY% < 0 THEN MENU_BAR.randomY% = 0
    END IF

    ' Draw border and background
    LINE (MENU_BAR.randomX% - 1, MENU_BAR.randomY% - 1)-(MENU_BAR.randomX% + MENU_BAR.randomW%, MENU_BAR.randomY% + MENU_BAR.randomH%), randBrd~&, BF
    LINE (MENU_BAR.randomX%, MENU_BAR.randomY%)-(MENU_BAR.randomX% + MENU_BAR.randomW% - 1, MENU_BAR.randomY% + MENU_BAR.randomH% - 1), randBg~&, BF

    ' Draw the 4 format items
    randItemY% = MENU_BAR.randomY% + 2
    FOR randI% = 0 TO 3
        IF randI% = MENU_BAR.randomHover% THEN
            LINE (MENU_BAR.randomX% + 1, randItemY%)-(MENU_BAR.randomX% + MENU_BAR.randomW% - 2, randItemY% + MENU_ITEM_HEIGHT - 1), randSBg~&, BF
            COLOR randSFg~&, _RGBA32(0, 0, 0, 0)
        ELSE
            COLOR randFg~&, _RGBA32(0, 0, 0, 0)
        END IF
        _PRINTSTRING (MENU_BAR.randomX% + MENU_SUB_PAD_LEFT, randItemY% + 2), randLabels(randI%)
        randItemY% = randItemY% + MENU_ITEM_HEIGHT
    NEXT randI%
END SUB


''
' Handle a click inside the random track submenu
'
SUB MENUBAR_handle_random_click (rawX AS INTEGER, rawY AS INTEGER)
    IF NOT MENU_BAR.randomOpen% THEN EXIT SUB
    IF NOT MENUBAR_random_in_bounds%(rawX%, rawY%) THEN EXIT SUB

    ' Determine which format item was clicked (0=MOD, 1=IT, 2=XM, 3=RAD)
    DIM rClickY AS INTEGER
    rClickY% = MENU_BAR.randomY% + 2
    DIM rIdx AS INTEGER
    FOR rIdx% = 0 TO 3
        IF rawY% >= rClickY% AND rawY% < rClickY% + MENU_ITEM_HEIGHT THEN
            MENUBAR_close_all
            SELECT CASE rIdx%
                CASE 0: CMD_execute_action 429  ' .MOD
                CASE 1: CMD_execute_action 430  ' .IT
                CASE 2: CMD_execute_action 431  ' .XM
                CASE 3: CMD_execute_action 432  ' .RAD
            END SELECT
            EXIT SUB
        END IF
        rClickY% = rClickY% + MENU_ITEM_HEIGHT
    NEXT rIdx%
END SUB


''
' Check if a point is within the random track submenu bounds
'
FUNCTION MENUBAR_random_in_bounds% (rawX AS INTEGER, rawY AS INTEGER)
    IF NOT MENU_BAR.randomOpen% THEN
        MENUBAR_random_in_bounds% = FALSE
        EXIT FUNCTION
    END IF
    MENUBAR_random_in_bounds% = (rawX% >= MENU_BAR.randomX% AND rawX% < MENU_BAR.randomX% + MENU_BAR.randomW% _
        AND rawY% >= MENU_BAR.randomY% AND rawY% < MENU_BAR.randomY% + MENU_BAR.randomH%)
END FUNCTION


''
' Render the Transform cascading submenu
'
SUB MENUBAR_render_transform_submenu ()
    DIM trBg  AS _UNSIGNED LONG
    DIM trFg  AS _UNSIGNED LONG
    DIM trBrd AS _UNSIGNED LONG
    DIM trSBg AS _UNSIGNED LONG
    DIM trSFg AS _UNSIGNED LONG
    DIM trItemY AS INTEGER
    DIM trTotalH AS INTEGER
    DIM trMaxW AS INTEGER, trFw AS INTEGER
    DIM trI AS INTEGER

    DIM trLabels(0 TO 4) AS STRING
    trLabels(0) = "SCALE..."
    trLabels(1) = "DISTORT..."
    trLabels(2) = "PERSPECTIVE..."
    trLabels(3) = "ROTATE..."
    trLabels(4) = "SHEAR..."

    trBg~&  = THEME.MENU_SUB_bg~&
    trFg~&  = THEME.MENU_SUB_fg~&
    trBrd~& = THEME.MENU_SUB_border~&
    trSBg~& = THEME.MENU_SUB_sel_bg~&
    trSFg~& = THEME.MENU_SUB_sel_fg~&

    ' Measure width
    trMaxW% = 0
    FOR trI% = 0 TO 4
        trFw% = _PRINTWIDTH(trLabels(trI%))
        IF trFw% > trMaxW% THEN trMaxW% = trFw%
    NEXT trI%
    MENU_BAR.transformW% = MENU_SUB_PAD_LEFT + trMaxW% + MENU_SUB_PAD_RIGHT
    IF MENU_BAR.transformW% < 100 THEN MENU_BAR.transformW% = 100

    trTotalH% = 4 + (5 * MENU_ITEM_HEIGHT)
    MENU_BAR.transformH% = trTotalH%

    ' Position to the right of the main submenu, aligned with TRANSFORM... item Y
    MENU_BAR.transformX% = MENU_BAR.subX% + MENU_BAR.subW%
    IF MENU_BAR.transformY% = 0 THEN MENU_BAR.transformY% = MENU_BAR.subY%

    ' Clamp right edge to screen
    IF MENU_BAR.transformX% + MENU_BAR.transformW% > SCRN.w& THEN
        MENU_BAR.transformX% = MENU_BAR.subX% - MENU_BAR.transformW%
        IF MENU_BAR.transformX% < 0 THEN MENU_BAR.transformX% = 0
    END IF

    ' Clamp bottom to screen
    IF MENU_BAR.transformY% + MENU_BAR.transformH% > SCRN.h& THEN
        MENU_BAR.transformY% = SCRN.h& - MENU_BAR.transformH%
        IF MENU_BAR.transformY% < 0 THEN MENU_BAR.transformY% = 0
    END IF

    ' Draw border and background
    LINE (MENU_BAR.transformX% - 1, MENU_BAR.transformY% - 1)-(MENU_BAR.transformX% + MENU_BAR.transformW%, MENU_BAR.transformY% + MENU_BAR.transformH%), trBrd~&, BF
    LINE (MENU_BAR.transformX%, MENU_BAR.transformY%)-(MENU_BAR.transformX% + MENU_BAR.transformW% - 1, MENU_BAR.transformY% + MENU_BAR.transformH% - 1), trBg~&, BF

    ' Draw the 5 transform items
    trItemY% = MENU_BAR.transformY% + 2
    FOR trI% = 0 TO 4
        IF trI% = MENU_BAR.transformHover% THEN
            LINE (MENU_BAR.transformX% + 1, trItemY%)-(MENU_BAR.transformX% + MENU_BAR.transformW% - 2, trItemY% + MENU_ITEM_HEIGHT - 1), trSBg~&, BF
            COLOR trSFg~&, _RGBA32(0, 0, 0, 0)
        ELSE
            COLOR trFg~&, _RGBA32(0, 0, 0, 0)
        END IF
        _PRINTSTRING (MENU_BAR.transformX% + MENU_SUB_PAD_LEFT, trItemY% + 2), trLabels(trI%)
        trItemY% = trItemY% + MENU_ITEM_HEIGHT
    NEXT trI%
END SUB


''
' Handle a click inside the transform submenu
'
SUB MENUBAR_handle_transform_click (rawX AS INTEGER, rawY AS INTEGER)
    IF NOT MENU_BAR.transformOpen% THEN EXIT SUB
    IF NOT MENUBAR_transform_in_bounds%(rawX%, rawY%) THEN EXIT SUB

    DIM tClickY AS INTEGER
    tClickY% = MENU_BAR.transformY% + 2
    DIM tIdx AS INTEGER
    FOR tIdx% = 0 TO 4
        IF rawY% >= tClickY% AND rawY% < tClickY% + MENU_ITEM_HEIGHT THEN
            MENUBAR_close_all
            SELECT CASE tIdx%
                CASE 0: CMD_execute_action TRANSFORM_ACT_SCALE
                CASE 1: CMD_execute_action TRANSFORM_ACT_DISTORT
                CASE 2: CMD_execute_action TRANSFORM_ACT_PERSPECTIVE
                CASE 3: CMD_execute_action TRANSFORM_ACT_ROTATE
                CASE 4: CMD_execute_action TRANSFORM_ACT_SHEAR
            END SELECT
            EXIT SUB
        END IF
        tClickY% = tClickY% + MENU_ITEM_HEIGHT
    NEXT tIdx%
END SUB


''
' Check if a point is within the transform submenu bounds
'
FUNCTION MENUBAR_transform_in_bounds% (rawX AS INTEGER, rawY AS INTEGER)
    IF NOT MENU_BAR.transformOpen% THEN
        MENUBAR_transform_in_bounds% = FALSE
        EXIT FUNCTION
    END IF
    MENUBAR_transform_in_bounds% = (rawX% >= MENU_BAR.transformX% AND rawX% < MENU_BAR.transformX% + MENU_BAR.transformW% _
        AND rawY% >= MENU_BAR.transformY% AND rawY% < MENU_BAR.transformY% + MENU_BAR.transformH%)
END FUNCTION
