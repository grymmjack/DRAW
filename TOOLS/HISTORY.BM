    HISTORY_RECORDS(idx%).primaryLayerId& = layerId&
    HISTORY_RECORDS(idx%).slotIndex% = layerSlot%
    HISTORY_RECORDS(idx%).colorFG~& = drawColor~&
    HISTORY_RECORDS(idx%).flags& = flags&
    HISTORY_RECORDS(idx%).x1% = seedX%
    HISTORY_RECORDS(idx%).y1% = seedY%
    HISTORY_RECORDS(idx%).img& = beforeImg&
    HISTORY_store_after_image idx%, layerSlot%
    HISTORY_commit_record idx%
END SUB

