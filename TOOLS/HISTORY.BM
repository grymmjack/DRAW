SUB HISTORY_refresh_layer_add_snapshot (layerId AS LONG)
    DIM idx AS INTEGER
    DIM layerSlot AS INTEGER

    layerSlot% = HISTORY_find_layer_slot_by_id%(layerId&)
    IF layerSlot% = 0 THEN EXIT SUB

    FOR idx% = HISTORY.current% TO 1 STEP -1
        IF HISTORY_RECORDS(idx%).kind% = HISTORY_KIND_LAYER_ADD THEN
            IF HISTORY_RECORDS(idx%).primaryLayerId& = layerId& THEN
                HISTORY_RECORDS(idx%).slotIndex% = layerSlot%
                HISTORY_RECORDS(idx%).newZIndex% = LAYERS(layerSlot%).zIndex%
                HISTORY_capture_layer_payload idx%, layerSlot%
                EXIT SUB
            END IF
        END IF
    NEXT idx%
END SUB

SUB HISTORY_save_binary (fh AS INTEGER, canvasW AS LONG, canvasH AS LONG)
    DIM i AS INTEGER, x AS LONG, y AS LONG
    DIM hasImage AS INTEGER
    DIM c AS _UNSIGNED LONG
    DIM oldSrc AS LONG
    DIM payloadChar AS STRING * 1
    DIM payloadIndex AS LONG

    PUT #fh%, , NEXT_LAYER_HISTORY_ID&
    PUT #fh%, , HISTORY.count%
    PUT #fh%, , HISTORY.current%
    PUT #fh%, , HISTORY.nextSequence&

    FOR i% = 1 TO HISTORY.count%
        PUT #fh%, , HISTORY_RECORDS(i%).kind%
        PUT #fh%, , HISTORY_RECORDS(i%).exportKind%
        PUT #fh%, , HISTORY_RECORDS(i%).sequence&
        PUT #fh%, , HISTORY_RECORDS(i%).primaryLayerId&
        PUT #fh%, , HISTORY_RECORDS(i%).secondaryLayerId&
        PUT #fh%, , HISTORY_RECORDS(i%).slotIndex%
        PUT #fh%, , HISTORY_RECORDS(i%).oldZIndex%
        PUT #fh%, , HISTORY_RECORDS(i%).newZIndex%
        PUT #fh%, , HISTORY_RECORDS(i%).oldName$
        PUT #fh%, , HISTORY_RECORDS(i%).newName$
        PUT #fh%, , HISTORY_RECORDS(i%).oldOpacity%
        PUT #fh%, , HISTORY_RECORDS(i%).oldVisible%
        PUT #fh%, , HISTORY_RECORDS(i%).oldOpacityLock%
        PUT #fh%, , HISTORY_RECORDS(i%).oldBlendMode%
        PUT #fh%, , HISTORY_RECORDS(i%).toolId%
        PUT #fh%, , HISTORY_RECORDS(i%).flags&
        PUT #fh%, , HISTORY_RECORDS(i%).x1%
        PUT #fh%, , HISTORY_RECORDS(i%).y1%
        PUT #fh%, , HISTORY_RECORDS(i%).x2%
        PUT #fh%, , HISTORY_RECORDS(i%).y2%
        PUT #fh%, , HISTORY_RECORDS(i%).w%
        PUT #fh%, , HISTORY_RECORDS(i%).h%
        PUT #fh%, , HISTORY_RECORDS(i%).colorFG~&
        PUT #fh%, , HISTORY_RECORDS(i%).colorBG~&
        PUT #fh%, , HISTORY_RECORDS(i%).payloadOffset&
        PUT #fh%, , HISTORY_RECORDS(i%).payloadLength&
        PUT #fh%, , HISTORY_RECORDS(i%).label$

        hasImage% = (HISTORY_RECORDS(i%).img& < -1)
        PUT #fh%, , hasImage%
        IF hasImage% THEN
            oldSrc& = _SOURCE
            _SOURCE HISTORY_RECORDS(i%).img&
            FOR y& = 0 TO canvasH& - 1
                FOR x& = 0 TO canvasW& - 1
                    c~& = POINT(x&, y&)
                    PUT #fh%, , c~&
                NEXT x&
            NEXT y&
            _SOURCE oldSrc&
        END IF

        hasImage% = (HISTORY_RECORDS(i%).img2& < -1)
        PUT #fh%, , hasImage%
        IF hasImage% THEN
            oldSrc& = _SOURCE
            _SOURCE HISTORY_RECORDS(i%).img2&
            FOR y& = 0 TO canvasH& - 1
                FOR x& = 0 TO canvasW& - 1
                    c~& = POINT(x&, y&)
                    PUT #fh%, , c~&
                NEXT x&
            NEXT y&
            _SOURCE oldSrc&
        END IF

        PUT #fh%, , HISTORY_RECORDS(i%).payloadLength&
        IF HISTORY_RECORDS(i%).payloadLength& > 0 THEN
            FOR payloadIndex& = 1 TO HISTORY_RECORDS(i%).payloadLength&
                payloadChar$ = MID$(HISTORY_PAYLOADS(i%), payloadIndex&, 1)
                PUT #fh%, , payloadChar$
            NEXT payloadIndex&
        END IF
    NEXT i%
END SUB

SUB HISTORY_load_binary (fh AS INTEGER, canvasW AS LONG, canvasH AS LONG, formatVersion AS INTEGER)
    DIM i AS INTEGER, x AS LONG, y AS LONG
    DIM savedCount AS INTEGER
    DIM savedCurrent AS INTEGER
    DIM savedNextSeq AS LONG
    DIM hasImage AS INTEGER
    DIM c AS _UNSIGNED LONG
    DIM oldDest AS LONG
    DIM payloadChar AS STRING * 1
    DIM payloadIndex AS LONG

    HISTORY_clear

    GET #fh%, , NEXT_LAYER_HISTORY_ID&
    GET #fh%, , savedCount%
    GET #fh%, , savedCurrent%
    GET #fh%, , savedNextSeq&

    IF savedCount% < 0 THEN savedCount% = 0
    IF savedCount% > HISTORY_MAX_RECORDS THEN savedCount% = HISTORY_MAX_RECORDS

    FOR i% = 1 TO savedCount%
        GET #fh%, , HISTORY_RECORDS(i%).kind%
        GET #fh%, , HISTORY_RECORDS(i%).exportKind%
        GET #fh%, , HISTORY_RECORDS(i%).sequence&
        GET #fh%, , HISTORY_RECORDS(i%).primaryLayerId&
        GET #fh%, , HISTORY_RECORDS(i%).secondaryLayerId&
        GET #fh%, , HISTORY_RECORDS(i%).slotIndex%
        GET #fh%, , HISTORY_RECORDS(i%).oldZIndex%
        GET #fh%, , HISTORY_RECORDS(i%).newZIndex%
        GET #fh%, , HISTORY_RECORDS(i%).oldName$
        GET #fh%, , HISTORY_RECORDS(i%).newName$
        GET #fh%, , HISTORY_RECORDS(i%).oldOpacity%
        GET #fh%, , HISTORY_RECORDS(i%).oldVisible%
        GET #fh%, , HISTORY_RECORDS(i%).oldOpacityLock%
        GET #fh%, , HISTORY_RECORDS(i%).oldBlendMode%
        GET #fh%, , HISTORY_RECORDS(i%).toolId%
        GET #fh%, , HISTORY_RECORDS(i%).flags&
        GET #fh%, , HISTORY_RECORDS(i%).x1%
        GET #fh%, , HISTORY_RECORDS(i%).y1%
        GET #fh%, , HISTORY_RECORDS(i%).x2%
        GET #fh%, , HISTORY_RECORDS(i%).y2%
        GET #fh%, , HISTORY_RECORDS(i%).w%
        GET #fh%, , HISTORY_RECORDS(i%).h%
        GET #fh%, , HISTORY_RECORDS(i%).colorFG~&
        GET #fh%, , HISTORY_RECORDS(i%).colorBG~&
        GET #fh%, , HISTORY_RECORDS(i%).payloadOffset&
        GET #fh%, , HISTORY_RECORDS(i%).payloadLength&
        GET #fh%, , HISTORY_RECORDS(i%).label$

        GET #fh%, , hasImage%
        HISTORY_RECORDS(i%).img& = 0
        IF hasImage% THEN
            HISTORY_RECORDS(i%).img& = _NEWIMAGE(canvasW&, canvasH&, 32)
            IF HISTORY_RECORDS(i%).img& < -1 THEN
                oldDest& = _DEST
                _DEST HISTORY_RECORDS(i%).img&
                FOR y& = 0 TO canvasH& - 1
                    FOR x& = 0 TO canvasW& - 1
                        GET #fh%, , c~&
                        PSET (x&, y&), c~&
                    NEXT x&
                NEXT y&
                _DEST oldDest&
            ELSE
                HISTORY_RECORDS(i%).img& = 0
                FOR y& = 0 TO canvasH& - 1
                    FOR x& = 0 TO canvasW& - 1
                        GET #fh%, , c~&
                    NEXT x&
                NEXT y&
            END IF
        END IF

        GET #fh%, , hasImage%
        HISTORY_RECORDS(i%).img2& = 0
        IF hasImage% THEN
            HISTORY_RECORDS(i%).img2& = _NEWIMAGE(canvasW&, canvasH&, 32)
            IF HISTORY_RECORDS(i%).img2& < -1 THEN
                oldDest& = _DEST
                _DEST HISTORY_RECORDS(i%).img2&
                FOR y& = 0 TO canvasH& - 1
                    FOR x& = 0 TO canvasW& - 1
                        GET #fh%, , c~&
                        PSET (x&, y&), c~&
                    NEXT x&
                NEXT y&
                _DEST oldDest&
            ELSE
                HISTORY_RECORDS(i%).img2& = 0
                FOR y& = 0 TO canvasH& - 1
                    FOR x& = 0 TO canvasW& - 1
                        GET #fh%, , c~&
                    NEXT x&
                NEXT y&
            END IF
        END IF

        HISTORY_PAYLOADS(i%) = ""
        IF formatVersion% >= 9 THEN
            GET #fh%, , HISTORY_RECORDS(i%).payloadLength&
            IF HISTORY_RECORDS(i%).payloadLength& > 0 THEN
                HISTORY_PAYLOADS(i%) = SPACE$(HISTORY_RECORDS(i%).payloadLength&)
                FOR payloadIndex& = 1 TO HISTORY_RECORDS(i%).payloadLength&
                    GET #fh%, , payloadChar$
                    MID$(HISTORY_PAYLOADS(i%), payloadIndex&, 1) = payloadChar$
                NEXT payloadIndex&
            END IF
        ELSE
            HISTORY_RECORDS(i%).payloadLength& = 0
        END IF
    NEXT i%

    HISTORY.count% = savedCount%
    HISTORY.current% = savedCurrent%
    IF HISTORY.current% < 0 THEN HISTORY.current% = 0
    IF HISTORY.current% > HISTORY.count% THEN HISTORY.current% = HISTORY.count%
    HISTORY.maxRecords% = HISTORY_MAX_RECORDS
    HISTORY.nextSequence& = savedNextSeq&
    IF HISTORY.nextSequence& < 0 THEN HISTORY.nextSequence& = 0
    IF NEXT_LAYER_HISTORY_ID& < 1 THEN NEXT_LAYER_HISTORY_ID& = 1
    HISTORY.recording% = FALSE
    HISTORY_IN_PROGRESS% = FALSE
    FILE_BAS_wip_rebuild_from_history
END SUB

SUB HISTORY_undo ()
    DIM idx AS INTEGER
    DIM layerIndex AS INTEGER
    DIM newSlot AS INTEGER
    DIM groupSequence AS LONG

    HISTORY_sanitize_state
    IF NOT HISTORY_can_undo% THEN EXIT SUB

    idx% = HISTORY.current%
    IF idx% < 1 OR idx% > HISTORY.count% THEN EXIT SUB
    HISTORY_IN_PROGRESS% = TRUE

    groupSequence& = HISTORY_RECORDS(idx%).sequence&
    DO WHILE idx% >= 1
        IF HISTORY_RECORDS(idx%).sequence& <> groupSequence& THEN EXIT DO
        SELECT CASE HISTORY_RECORDS(idx%).kind%
            CASE HISTORY_KIND_LAYER_ADD
                layerIndex% = HISTORY_find_layer_slot_by_id%(HISTORY_RECORDS(idx%).primaryLayerId&)
                IF layerIndex% > 0 THEN HISTORY_delete_layer_by_slot layerIndex%
            CASE HISTORY_KIND_LAYER_DELETE
                newSlot% = HISTORY_create_layer_from_record%(idx%, HISTORY_RECORDS(idx%).oldZIndex%)
                IF newSlot% > 0 THEN LAYERS_select newSlot%
            CASE HISTORY_KIND_LAYER_REORDER
                HISTORY_move_layer_to_z HISTORY_RECORDS(idx%).primaryLayerId&, HISTORY_RECORDS(idx%).oldZIndex%
            CASE HISTORY_KIND_LAYER_RENAME
                layerIndex% = HISTORY_find_layer_slot_by_id%(HISTORY_RECORDS(idx%).primaryLayerId&)
                IF layerIndex% > 0 THEN LAYERS(layerIndex%).name$ = HISTORY_RECORDS(idx%).oldName$
            CASE HISTORY_KIND_LINE, HISTORY_KIND_RECT, HISTORY_KIND_ELLIPSE, HISTORY_KIND_POLYLINE, HISTORY_KIND_FILL, HISTORY_KIND_BRUSH, HISTORY_KIND_TRANSFORM
                HISTORY_apply_layer_snapshot HISTORY_RECORDS(idx%).primaryLayerId&, HISTORY_RECORDS(idx%).img&
        END SELECT
        idx% = idx% - 1
    LOOP

    HISTORY.current% = idx%
    HISTORY_IN_PROGRESS% = FALSE
    LAYER_COUNT% = LAYERS_recount%
    BLEND_invalidate_cache
    INVALIDATE_scene
    FILE_BAS_wip_rebuild_from_history
END SUB

SUB HISTORY_redo ()
    DIM idx AS INTEGER
    DIM layerIndex AS INTEGER
    DIM newSlot AS INTEGER
    DIM groupSequence AS LONG

    HISTORY_sanitize_state
    IF NOT HISTORY_can_redo% THEN EXIT SUB

    idx% = HISTORY.current% + 1
    IF idx% < 1 OR idx% > HISTORY.count% THEN EXIT SUB
    HISTORY_IN_PROGRESS% = TRUE

    groupSequence& = HISTORY_RECORDS(idx%).sequence&
    DO WHILE idx% <= HISTORY.count%
        IF HISTORY_RECORDS(idx%).sequence& <> groupSequence& THEN EXIT DO
        SELECT CASE HISTORY_RECORDS(idx%).kind%
            CASE HISTORY_KIND_LAYER_ADD
                newSlot% = HISTORY_create_layer_from_record%(idx%, HISTORY_RECORDS(idx%).newZIndex%)
                IF newSlot% > 0 THEN LAYERS_select newSlot%
            CASE HISTORY_KIND_LAYER_DELETE
                layerIndex% = HISTORY_find_layer_slot_by_id%(HISTORY_RECORDS(idx%).primaryLayerId&)
                IF layerIndex% > 0 THEN HISTORY_delete_layer_by_slot layerIndex%
            CASE HISTORY_KIND_LAYER_REORDER
                HISTORY_move_layer_to_z HISTORY_RECORDS(idx%).primaryLayerId&, HISTORY_RECORDS(idx%).newZIndex%
            CASE HISTORY_KIND_LAYER_RENAME
                layerIndex% = HISTORY_find_layer_slot_by_id%(HISTORY_RECORDS(idx%).primaryLayerId&)
                IF layerIndex% > 0 THEN LAYERS(layerIndex%).name$ = HISTORY_RECORDS(idx%).newName$
            CASE HISTORY_KIND_LINE, HISTORY_KIND_RECT, HISTORY_KIND_ELLIPSE, HISTORY_KIND_POLYLINE, HISTORY_KIND_FILL, HISTORY_KIND_BRUSH, HISTORY_KIND_TRANSFORM
                HISTORY_apply_layer_snapshot HISTORY_RECORDS(idx%).primaryLayerId&, HISTORY_RECORDS(idx%).img2&
        END SELECT
        HISTORY.current% = idx%
        idx% = idx% + 1
    LOOP

    HISTORY_IN_PROGRESS% = FALSE
    LAYER_COUNT% = LAYERS_recount%
    BLEND_invalidate_cache
    INVALIDATE_scene
    FILE_BAS_wip_rebuild_from_history
END SUB