''
' DRAW - TOOLS/MARQUEE.BM
' =============================================================================
' Marquee selection tool implementation.
'
' @author Rick Christy <grymmjack@gmail.com>
'
$INCLUDEONCE

' Unsnapped start coordinates for grid-snap cell alignment
DIM SHARED MARQUEE_UNSNAPPED_START_X AS INTEGER
DIM SHARED MARQUEE_UNSNAPPED_START_Y AS INTEGER

''
' Reset the marquee tool state
' Call this when switching away from the marquee tool
'
SUB MARQUEE_reset ()
    MARQUEE.ACTIVE% = FALSE
    MARQUEE.DRAGGING% = FALSE
    MARQUEE.RESIZING% = FALSE
    MARQUEE.MOVING% = FALSE
    MARQUEE.INITIALIZED% = FALSE
    MARQUEE.USER_CREATED = FALSE
    ' Reset magic wand state (but keep the mode)
    MAGIC_WAND_reset
    ' Reset new selection tool states
    FREEHAND_SEL_reset
    POLY_SEL_reset
    ELLIPSE_SEL_reset
END SUB


''
' Initialize the marquee tool with default configuration
' 
SUB MARQUEE_init ()
    ' Configure the bounding box for marquee selection
    MARQUEE.CFG.HandleHalfSize       = THEME.MARQUEE_HANDLE_SIZE%
    MARQUEE.CFG.HandleFullSize       = MARQUEE.CFG.HandleHalfSize * 2
    MARQUEE.CFG.EdgeHalfSize         = 1
    MARQUEE.CFG.EdgeFullSize         = MARQUEE.CFG.EdgeHalfSize * 2
    MARQUEE.CFG.HandleCornerSize     = MARQUEE.CFG.HandleFullSize
    MARQUEE.CFG.HandleEdgeSize       = MARQUEE.CFG.EdgeFullSize
    MARQUEE.CFG.DragEdgePadding      = 8
    MARQUEE.CFG.MinBoxWidth          = 1  ' 1px minimum (was 8)
    MARQUEE.CFG.MinBoxHeight         = 1  ' 1px minimum (was 8)

    ' Set colors for marquee box - use dotted/dashed appearance
    MARQUEE.CFG.colorIdle            = _RGB32(255, 255, 255)
    MARQUEE.CFG.colorHoverOnly       = _RGB32(255, 255, 0)
    MARQUEE.CFG.colorSelectedOnly    = _RGB32(255, 255, 255)
    MARQUEE.CFG.colorSelectedHover   = _RGB32(255, 255, 0)
    MARQUEE.CFG.colorDragging        = _RGB32(255, 255, 255)
    MARQUEE.CFG.colorResizing        = _RGB32(255, 255, 0)

    MARQUEE.CFG.HandleFillColor      = _RGB32(255, 0, 255)  ' Bright magenta
    MARQUEE.CFG.HandleHoverFillColor = _RGB32(0, 255, 255)  ' Bright cyan
    MARQUEE.CFG.HandleBorderColor    = _RGB32(255, 255, 255)  ' White border

    MARQUEE.CFG.KeyRepeatDelay       = 0.1
    MARQUEE.CFG.KeyRepeatRate        = 0.05

    ' Set initial position (will be set when user starts marquee)
    MARQUEE.CFG.initX = 100
    MARQUEE.CFG.initY = 100
    MARQUEE.CFG.initW = 64
    MARQUEE.CFG.initH = 64

    MARQUEE.ACTIVE% = FALSE
    MARQUEE.INITIALIZED% = FALSE
END SUB


''
' Start a new marquee selection at the given coordinates
' @param x INTEGER Starting x coordinate
' @param y INTEGER Starting y coordinate
'
SUB MARQUEE_start (x AS INTEGER, y AS INTEGER)
    ' Clear ALL existing selection state in replace mode (including wand mask)
    ' For add/subtract modes, preserve the existing selection
    IF MARQUEE.SELECTION_MODE = SEL_MODE_REPLACE THEN
        MARQUEE_clear
        MAGIC_WAND_reset
    END IF
    
    ' Store unsnapped start for grid-snap cell alignment
    MARQUEE_UNSNAPPED_START_X% = MOUSE.UNSNAPPED_X%
    MARQUEE_UNSNAPPED_START_Y% = MOUSE.UNSNAPPED_Y%

    MARQUEE.DRAG_START_X% = x
    MARQUEE.DRAG_START_Y% = y
    MARQUEE.DRAG_END_X% = x
    MARQUEE.DRAG_END_Y% = y
    MARQUEE.DRAGGING% = TRUE
    MARQUEE.INITIALIZED% = TRUE
END SUB


''
' Update the marquee tool state
' Call this from the main loop when TOOL_MARQUEE is active
' @param mouseX INTEGER Current mouse X position
' @param mouseY INTEGER Current mouse Y position
'
SUB MARQUEE_update (mouseX AS INTEGER, mouseY AS INTEGER)
    IF NOT MARQUEE.INITIALIZED% THEN MARQUEE_init
    
    IF MARQUEE.DRAGGING% THEN
        IF GRID.SNAP% AND GRID.gridWidth% > 0 THEN
            ' Grid-snapped marquee: align start/end to full cell boundaries
            DIM gw AS INTEGER, gh AS INTEGER
            gw% = GRID.gridWidth%
            gh% = GRID.gridHeight%
            IF gh% < 1 THEN gh% = gw%

            ' Compute half-grid offset for center alignment mode
            DIM halfGX AS INTEGER, halfGY AS INTEGER
            IF GRID.ALIGN_MODE% = GRID_ALIGN_CENTER THEN
                halfGX% = gw% \ 2
                halfGY% = gh% \ 2
            ELSE
                halfGX% = 0
                halfGY% = 0
            END IF

            ' Determine which cells the unsnapped start and current positions are in
            DIM startCellX AS INTEGER, startCellY AS INTEGER
            DIM endCellX AS INTEGER, endCellY AS INTEGER
            startCellX% = INT((MARQUEE_UNSNAPPED_START_X% + halfGX%) / gw%)
            startCellY% = INT((MARQUEE_UNSNAPPED_START_Y% + halfGY%) / gh%)
            endCellX% = INT((MOUSE.UNSNAPPED_X% + halfGX%) / gw%)
            endCellY% = INT((MOUSE.UNSNAPPED_Y% + halfGY%) / gh%)

            ' Compute outer edges of the cell range (exclusive end convention)
            DIM minCellX AS INTEGER, maxCellX AS INTEGER
            DIM minCellY AS INTEGER, maxCellY AS INTEGER
            IF startCellX% <= endCellX% THEN
                minCellX% = startCellX%: maxCellX% = endCellX%
            ELSE
                minCellX% = endCellX%: maxCellX% = startCellX%
            END IF
            IF startCellY% <= endCellY% THEN
                minCellY% = startCellY%: maxCellY% = endCellY%
            ELSE
                minCellY% = endCellY%: maxCellY% = startCellY%
            END IF

            ' Set DRAG_START to top-left cell edge, DRAG_END to bottom-right cell edge (exclusive)
            MARQUEE.DRAG_START_X% = minCellX% * gw% - halfGX%
            MARQUEE.DRAG_START_Y% = minCellY% * gh% - halfGY%
            MARQUEE.DRAG_END_X% = (maxCellX% + 1) * gw% - halfGX%
            MARQUEE.DRAG_END_Y% = (maxCellY% + 1) * gh% - halfGY%
        ELSE
            ' Normal (un-snapped) mode
            MARQUEE.DRAG_END_X% = mouseX
            MARQUEE.DRAG_END_Y% = mouseY
        END IF
    END IF
    ' Note: Resize is handled manually (no external BBX update needed)
END SUB


''
' Draw the marquee selection
' @param showHUD INTEGER Whether to show handles and HUD elements
'
SUB MARQUEE_draw (showHUD AS INTEGER)
    DIM tempBox AS MARQUEE_BBOX
    DIM zoomedBox AS MARQUEE_BBOX
    
    ' Calculate zoom transformation values (canvas dimensions, centered in viewport)
    DIM zw AS LONG, zh AS LONG, dx AS INTEGER, dy AS INTEGER
    zw& = SCRN.canvasW& * SCRN.zoom!
    zh& = SCRN.canvasH& * SCRN.zoom!
    dx% = (SCRN.w& - zw&) \ 2 + SCRN.offsetX% + SCRN.panelShiftX%
    dy% = (SCRN.h& - zh&) \ 2 + SCRN.offsetY%
    
    ' Explicitly set destination to canvas
    _DEST SCRN.CANVAS&
    
    IF MARQUEE.DRAGGING% THEN
        ' Draw temporary drag preview box
        IF MARQUEE.DRAG_START_X% < MARQUEE.DRAG_END_X% THEN
            tempBox.x = MARQUEE.DRAG_START_X%
        ELSE
            tempBox.x = MARQUEE.DRAG_END_X%
        END IF
        IF MARQUEE.DRAG_START_Y% < MARQUEE.DRAG_END_Y% THEN
            tempBox.y = MARQUEE.DRAG_START_Y%
        ELSE
            tempBox.y = MARQUEE.DRAG_END_Y%
        END IF
        tempBox.w = ABS(MARQUEE.DRAG_END_X% - MARQUEE.DRAG_START_X%)
        tempBox.h = ABS(MARQUEE.DRAG_END_Y% - MARQUEE.DRAG_START_Y%)
        tempBox.state = MARQUEE_STATE_IDLE
        
        ' Ensure we have at least 1 pixel width/height for visibility
        IF tempBox.w < 1 THEN tempBox.w = 1
        IF tempBox.h < 1 THEN tempBox.h = 1
        
        ' Transform to zoomed canvas coordinates
        zoomedBox.x = dx% + INT(tempBox.x * SCRN.zoom!)
        zoomedBox.y = dy% + INT(tempBox.y * SCRN.zoom!)
        zoomedBox.w = INT(tempBox.w * SCRN.zoom!)
        zoomedBox.h = INT(tempBox.h * SCRN.zoom!)
        zoomedBox.state = tempBox.state
        IF zoomedBox.w < 1 THEN zoomedBox.w = 1
        IF zoomedBox.h < 1 THEN zoomedBox.h = 1
        
        ' Draw the drag preview with dotted lines (in zoomed coordinates)
        MARQUEE_draw_dotted_box zoomedBox, FALSE
    ELSEIF MARQUEE.ACTIVE% THEN
        ' Transform to zoomed canvas coordinates
        zoomedBox.x = dx% + INT(MARQUEE.BOX.x * SCRN.zoom!)
        zoomedBox.y = dy% + INT(MARQUEE.BOX.y * SCRN.zoom!)
        zoomedBox.w = INT(MARQUEE.BOX.w * SCRN.zoom!)
        zoomedBox.h = INT(MARQUEE.BOX.h * SCRN.zoom!)
        zoomedBox.state = MARQUEE.BOX.state
        IF zoomedBox.w < 1 THEN zoomedBox.w = 1
        IF zoomedBox.h < 1 THEN zoomedBox.h = 1
        
        ' Draw the bounding box with dotted line effect (in zoomed coordinates)
        MARQUEE_draw_dotted_box zoomedBox, showHUD%
        
        ' Draw handles directly (in zoomed coordinates)
        IF showHUD% THEN
            DIM hh AS INTEGER, cx AS INTEGER, cy AS INTEGER
            DIM handleColor AS _UNSIGNED LONG
            DIM hoveredHandle AS INTEGER
            
            ' Check which handle the mouse is hovering over (if not actively resizing)
            IF NOT MARQUEE.RESIZING% THEN
                hoveredHandle% = MARQUEE_get_handle_at%(MOUSE.UNSNAPPED_X%, MOUSE.UNSNAPPED_Y%)
            ELSE
                hoveredHandle% = 0
            END IF
            
            ' Scale handle size with zoom (minimum 2px)
            ' Fixed screen-pixel handle size from theme (no zoom scaling)
            hh% = THEME.MARQUEE_HANDLE_SIZE%
            IF hh% < 2 THEN hh% = 2
            cx% = zoomedBox.x + zoomedBox.w \ 2
            cy% = zoomedBox.y + zoomedBox.h \ 2
            
            ' Draw 8 handles - filled with border, 33% opaque (alpha 85)
            ' Use cyan for active resize handle OR hovered handle, gray for others
            
            ' 1: TL corner
            IF MARQUEE.RESIZE_HANDLE% = 1 OR hoveredHandle% = 1 THEN handleColor~& = _RGBA32(0, 255, 255, 85) ELSE handleColor~& = _RGBA32(160, 160, 160, 85)
            LINE (zoomedBox.x - hh%, zoomedBox.y - hh%)-(zoomedBox.x + hh%, zoomedBox.y + hh%), handleColor~&, BF
            LINE (zoomedBox.x - hh%, zoomedBox.y - hh%)-(zoomedBox.x + hh%, zoomedBox.y + hh%), _RGBA32(255, 255, 255, 85), B
            
            ' 2: T edge
            IF MARQUEE.RESIZE_HANDLE% = 2 OR hoveredHandle% = 2 THEN handleColor~& = _RGBA32(0, 255, 255, 85) ELSE handleColor~& = _RGBA32(160, 160, 160, 85)
            LINE (cx% - hh%, zoomedBox.y - hh%)-(cx% + hh%, zoomedBox.y + hh%), handleColor~&, BF
            LINE (cx% - hh%, zoomedBox.y - hh%)-(cx% + hh%, zoomedBox.y + hh%), _RGBA32(255, 255, 255, 85), B
            
            ' 3: TR corner
            IF MARQUEE.RESIZE_HANDLE% = 3 OR hoveredHandle% = 3 THEN handleColor~& = _RGBA32(0, 255, 255, 85) ELSE handleColor~& = _RGBA32(160, 160, 160, 85)
            LINE (zoomedBox.x + zoomedBox.w - hh%, zoomedBox.y - hh%)-(zoomedBox.x + zoomedBox.w + hh%, zoomedBox.y + hh%), handleColor~&, BF
            LINE (zoomedBox.x + zoomedBox.w - hh%, zoomedBox.y - hh%)-(zoomedBox.x + zoomedBox.w + hh%, zoomedBox.y + hh%), _RGBA32(255, 255, 255, 85), B
            
            ' 4: L edge
            IF MARQUEE.RESIZE_HANDLE% = 4 OR hoveredHandle% = 4 THEN handleColor~& = _RGBA32(0, 255, 255, 85) ELSE handleColor~& = _RGBA32(160, 160, 160, 85)
            LINE (zoomedBox.x - hh%, cy% - hh%)-(zoomedBox.x + hh%, cy% + hh%), handleColor~&, BF
            LINE (zoomedBox.x - hh%, cy% - hh%)-(zoomedBox.x + hh%, cy% + hh%), _RGBA32(255, 255, 255, 85), B
            
            ' 5: R edge
            IF MARQUEE.RESIZE_HANDLE% = 5 OR hoveredHandle% = 5 THEN handleColor~& = _RGBA32(0, 255, 255, 85) ELSE handleColor~& = _RGBA32(160, 160, 160, 85)
            LINE (zoomedBox.x + zoomedBox.w - hh%, cy% - hh%)-(zoomedBox.x + zoomedBox.w + hh%, cy% + hh%), handleColor~&, BF
            LINE (zoomedBox.x + zoomedBox.w - hh%, cy% - hh%)-(zoomedBox.x + zoomedBox.w + hh%, cy% + hh%), _RGBA32(255, 255, 255, 85), B
            
            ' 6: BL corner
            IF MARQUEE.RESIZE_HANDLE% = 6 OR hoveredHandle% = 6 THEN handleColor~& = _RGBA32(0, 255, 255, 85) ELSE handleColor~& = _RGBA32(160, 160, 160, 85)
            LINE (zoomedBox.x - hh%, zoomedBox.y + zoomedBox.h - hh%)-(zoomedBox.x + hh%, zoomedBox.y + zoomedBox.h + hh%), handleColor~&, BF
            LINE (zoomedBox.x - hh%, zoomedBox.y + zoomedBox.h - hh%)-(zoomedBox.x + hh%, zoomedBox.y + zoomedBox.h + hh%), _RGBA32(255, 255, 255, 85), B
            
            ' 7: B edge
            IF MARQUEE.RESIZE_HANDLE% = 7 OR hoveredHandle% = 7 THEN handleColor~& = _RGBA32(0, 255, 255, 85) ELSE handleColor~& = _RGBA32(160, 160, 160, 85)
            LINE (cx% - hh%, zoomedBox.y + zoomedBox.h - hh%)-(cx% + hh%, zoomedBox.y + zoomedBox.h + hh%), handleColor~&, BF
            LINE (cx% - hh%, zoomedBox.y + zoomedBox.h - hh%)-(cx% + hh%, zoomedBox.y + zoomedBox.h + hh%), _RGBA32(255, 255, 255, 85), B
            
            ' 8: BR corner
            IF MARQUEE.RESIZE_HANDLE% = 8 OR hoveredHandle% = 8 THEN handleColor~& = _RGBA32(0, 255, 255, 85) ELSE handleColor~& = _RGBA32(160, 160, 160, 85)
            LINE (zoomedBox.x + zoomedBox.w - hh%, zoomedBox.y + zoomedBox.h - hh%)-(zoomedBox.x + zoomedBox.w + hh%, zoomedBox.y + zoomedBox.h + hh%), handleColor~&, BF
            LINE (zoomedBox.x + zoomedBox.w - hh%, zoomedBox.y + zoomedBox.h - hh%)-(zoomedBox.x + zoomedBox.w + hh%, zoomedBox.y + zoomedBox.h + hh%), _RGBA32(255, 255, 255, 85), B
        END IF
    END IF
END SUB


''
' Draw only the drag preview rectangle (for add/subtract mode overlay)
' This is simpler and always draws if DRAGGING is true
'
SUB MARQUEE_draw_drag_preview ()
    IF NOT MARQUEE.DRAGGING% THEN EXIT SUB
    
    DIM tempBox AS MARQUEE_BBOX
    DIM zoomedBox AS MARQUEE_BBOX
    
    ' Calculate zoom transformation values (canvas dimensions, centered in viewport)
    DIM zw AS LONG, zh AS LONG, dx AS INTEGER, dy AS INTEGER
    zw& = SCRN.canvasW& * SCRN.zoom!
    zh& = SCRN.canvasH& * SCRN.zoom!
    dx% = (SCRN.w& - zw&) \ 2 + SCRN.offsetX% + SCRN.panelShiftX%
    dy% = (SCRN.h& - zh&) \ 2 + SCRN.offsetY%
    
    ' Calculate temp box from drag coordinates
    IF MARQUEE.DRAG_START_X% < MARQUEE.DRAG_END_X% THEN
        tempBox.x = MARQUEE.DRAG_START_X%
    ELSE
        tempBox.x = MARQUEE.DRAG_END_X%
    END IF
    IF MARQUEE.DRAG_START_Y% < MARQUEE.DRAG_END_Y% THEN
        tempBox.y = MARQUEE.DRAG_START_Y%
    ELSE
        tempBox.y = MARQUEE.DRAG_END_Y%
    END IF
    tempBox.w = ABS(MARQUEE.DRAG_END_X% - MARQUEE.DRAG_START_X%)
    tempBox.h = ABS(MARQUEE.DRAG_END_Y% - MARQUEE.DRAG_START_Y%)
    
    ' Ensure minimum size for visibility
    IF tempBox.w < 1 THEN tempBox.w = 1
    IF tempBox.h < 1 THEN tempBox.h = 1
    
    ' Transform to zoomed canvas coordinates
    zoomedBox.x = dx% + INT(tempBox.x * SCRN.zoom!)
    zoomedBox.y = dy% + INT(tempBox.y * SCRN.zoom!)
    zoomedBox.w = INT(tempBox.w * SCRN.zoom!)
    zoomedBox.h = INT(tempBox.h * SCRN.zoom!)
    IF zoomedBox.w < 1 THEN zoomedBox.w = 1
    IF zoomedBox.h < 1 THEN zoomedBox.h = 1
    
    ' Draw the preview box
    _DEST SCRN.CANVAS&
    MARQUEE_draw_dotted_box zoomedBox, FALSE
END SUB


''
' Draw ONLY the existing marquee box (not the drag preview)
' Used when dragging in add/subtract mode to show both existing selection AND new drag
' @param showHUD INTEGER Whether to show handles and HUD elements
'
SUB MARQUEE_draw_existing_box (showHUD AS INTEGER)
    IF NOT MARQUEE.ACTIVE% THEN EXIT SUB
    
    DIM zoomedBox AS MARQUEE_BBOX
    
    ' Calculate zoom transformation values (canvas dimensions, centered in viewport)
    DIM zw AS LONG, zh AS LONG, dx AS INTEGER, dy AS INTEGER
    zw& = SCRN.canvasW& * SCRN.zoom!
    zh& = SCRN.canvasH& * SCRN.zoom!
    dx% = (SCRN.w& - zw&) \ 2 + SCRN.offsetX% + SCRN.panelShiftX%
    dy% = (SCRN.h& - zh&) \ 2 + SCRN.offsetY%
    
    _DEST SCRN.CANVAS&
    
    ' Transform existing box to zoomed canvas coordinates
    zoomedBox.x = dx% + INT(MARQUEE.BOX.x * SCRN.zoom!)
    zoomedBox.y = dy% + INT(MARQUEE.BOX.y * SCRN.zoom!)
    zoomedBox.w = INT(MARQUEE.BOX.w * SCRN.zoom!)
    zoomedBox.h = INT(MARQUEE.BOX.h * SCRN.zoom!)
    zoomedBox.state = MARQUEE.BOX.state
    IF zoomedBox.w < 1 THEN zoomedBox.w = 1
    IF zoomedBox.h < 1 THEN zoomedBox.h = 1
    
    ' Draw the bounding box with dotted line effect (in zoomed coordinates)
    MARQUEE_draw_dotted_box zoomedBox, showHUD%
    
    ' Draw handles if showHUD requested
    IF showHUD% THEN
        DIM hh AS INTEGER, cx AS INTEGER, cy AS INTEGER
        DIM handleColor AS _UNSIGNED LONG
        DIM hoveredHandle AS INTEGER
        
        ' Check which handle the mouse is hovering over (if not actively resizing)
        IF NOT MARQUEE.RESIZING% THEN
            hoveredHandle% = MARQUEE_get_handle_at%(MOUSE.UNSNAPPED_X%, MOUSE.UNSNAPPED_Y%)
        ELSE
            hoveredHandle% = 0
        END IF
        
        ' Fixed screen-pixel handle size from theme (no zoom scaling)
        hh% = THEME.MARQUEE_HANDLE_SIZE%
        IF hh% < 1 THEN hh% = 1
        cx% = zoomedBox.x + zoomedBox.w \ 2
        cy% = zoomedBox.y + zoomedBox.h \ 2
        
        ' Draw 8 handles - filled with border, 33% opaque (alpha 85)
        ' Use cyan for hovered handle, gray for others
        
        ' 1: TL corner
        IF hoveredHandle% = 1 THEN handleColor~& = _RGBA32(0, 255, 255, 85) ELSE handleColor~& = _RGBA32(160, 160, 160, 85)
        LINE (zoomedBox.x - hh%, zoomedBox.y - hh%)-(zoomedBox.x + hh%, zoomedBox.y + hh%), handleColor~&, BF
        LINE (zoomedBox.x - hh%, zoomedBox.y - hh%)-(zoomedBox.x + hh%, zoomedBox.y + hh%), _RGBA32(255, 255, 255, 85), B
        
        ' 2: T edge
        IF hoveredHandle% = 2 THEN handleColor~& = _RGBA32(0, 255, 255, 85) ELSE handleColor~& = _RGBA32(160, 160, 160, 85)
        LINE (cx% - hh%, zoomedBox.y - hh%)-(cx% + hh%, zoomedBox.y + hh%), handleColor~&, BF
        LINE (cx% - hh%, zoomedBox.y - hh%)-(cx% + hh%, zoomedBox.y + hh%), _RGBA32(255, 255, 255, 85), B
        
        ' 3: TR corner
        IF hoveredHandle% = 3 THEN handleColor~& = _RGBA32(0, 255, 255, 85) ELSE handleColor~& = _RGBA32(160, 160, 160, 85)
        LINE (zoomedBox.x + zoomedBox.w - hh%, zoomedBox.y - hh%)-(zoomedBox.x + zoomedBox.w + hh%, zoomedBox.y + hh%), handleColor~&, BF
        LINE (zoomedBox.x + zoomedBox.w - hh%, zoomedBox.y - hh%)-(zoomedBox.x + zoomedBox.w + hh%, zoomedBox.y + hh%), _RGBA32(255, 255, 255, 85), B
        
        ' 4: L edge
        IF hoveredHandle% = 4 THEN handleColor~& = _RGBA32(0, 255, 255, 85) ELSE handleColor~& = _RGBA32(160, 160, 160, 85)
        LINE (zoomedBox.x - hh%, cy% - hh%)-(zoomedBox.x + hh%, cy% + hh%), handleColor~&, BF
        LINE (zoomedBox.x - hh%, cy% - hh%)-(zoomedBox.x + hh%, cy% + hh%), _RGBA32(255, 255, 255, 85), B
        
        ' 5: R edge
        IF hoveredHandle% = 5 THEN handleColor~& = _RGBA32(0, 255, 255, 85) ELSE handleColor~& = _RGBA32(160, 160, 160, 85)
        LINE (zoomedBox.x + zoomedBox.w - hh%, cy% - hh%)-(zoomedBox.x + zoomedBox.w + hh%, cy% + hh%), handleColor~&, BF
        LINE (zoomedBox.x + zoomedBox.w - hh%, cy% - hh%)-(zoomedBox.x + zoomedBox.w + hh%, cy% + hh%), _RGBA32(255, 255, 255, 85), B
        
        ' 6: BL corner
        IF hoveredHandle% = 6 THEN handleColor~& = _RGBA32(0, 255, 255, 85) ELSE handleColor~& = _RGBA32(160, 160, 160, 85)
        LINE (zoomedBox.x - hh%, zoomedBox.y + zoomedBox.h - hh%)-(zoomedBox.x + hh%, zoomedBox.y + zoomedBox.h + hh%), handleColor~&, BF
        LINE (zoomedBox.x - hh%, zoomedBox.y + zoomedBox.h - hh%)-(zoomedBox.x + hh%, zoomedBox.y + zoomedBox.h + hh%), _RGBA32(255, 255, 255, 85), B
        
        ' 7: B edge
        IF hoveredHandle% = 7 THEN handleColor~& = _RGBA32(0, 255, 255, 85) ELSE handleColor~& = _RGBA32(160, 160, 160, 85)
        LINE (cx% - hh%, zoomedBox.y + zoomedBox.h - hh%)-(cx% + hh%, zoomedBox.y + zoomedBox.h + hh%), handleColor~&, BF
        LINE (cx% - hh%, zoomedBox.y + zoomedBox.h - hh%)-(cx% + hh%, zoomedBox.y + zoomedBox.h + hh%), _RGBA32(255, 255, 255, 85), B
        
        ' 8: BR corner
        IF hoveredHandle% = 8 THEN handleColor~& = _RGBA32(0, 255, 255, 85) ELSE handleColor~& = _RGBA32(160, 160, 160, 85)
        LINE (zoomedBox.x + zoomedBox.w - hh%, zoomedBox.y + zoomedBox.h - hh%)-(zoomedBox.x + zoomedBox.w + hh%, zoomedBox.y + zoomedBox.h + hh%), handleColor~&, BF
        LINE (zoomedBox.x + zoomedBox.w - hh%, zoomedBox.y + zoomedBox.h - hh%)-(zoomedBox.x + zoomedBox.w + hh%, zoomedBox.y + zoomedBox.h + hh%), _RGBA32(255, 255, 255, 85), B
    END IF
END SUB


''
' Draw a dotted/dashed box outline
' @param b MARQUEE_BBOX The bounding box to draw (already in canvas/screen coordinates)
' @param showHUD INTEGER Whether to show the HUD
'
SUB MARQUEE_draw_dotted_box (b AS MARQUEE_BBOX, showHUD AS INTEGER)
    showHUD% = showHUD% ' reserved for future HUD display logic
    DIM i AS INTEGER
    DIM dotSize AS INTEGER
    DIM gapSize AS INTEGER
    DIM x AS INTEGER, y AS INTEGER
    DIM lineColor AS _UNSIGNED LONG
    DIM prevBlend AS LONG
    
    ' Save and set blend mode
    prevBlend& = _BLEND
    _DONTBLEND
    
    ' Zoom-aware step: each canvas pixel = zoomI screen pixels
    DIM zoomI AS INTEGER
    zoomI% = INT(SCRN.zoom!)
    IF zoomI% < 1 THEN zoomI% = 1

    ' Dot/gap in canvas pixels (consistent with wand outline)
    dotSize% = 2
    gapSize% = 2
    
    ' Animate marching ants with time-based offset (in canvas-pixel units)
    DIM antOffset AS INTEGER
    antOffset% = INT(TIMER * 8) MOD (dotSize% + gapSize%)
    
    ' Use white and black for marching ants contrast
    DIM whiteColor AS _UNSIGNED LONG
    DIM blackColor AS _UNSIGNED LONG
    whiteColor~& = _RGB32(255, 255, 255)
    blackColor~& = _RGB32(0, 0, 0)
    
    ' Draw marching ants for top and bottom edges (step by zoom, fill zoomI blocks)
    DIM canvasI AS INTEGER
    DIM pattern AS INTEGER
    DIM stepPx AS INTEGER
    stepPx% = zoomI%
    IF stepPx% < 1 THEN stepPx% = 1

    FOR i% = 0 TO b.w - 1 STEP stepPx%
        x% = b.x + i%
        canvasI% = i% \ stepPx%
        pattern% = (canvasI% + antOffset%) MOD (dotSize% + gapSize%)
        
        IF pattern% < dotSize% THEN
            lineColor~& = whiteColor~&
        ELSE
            lineColor~& = blackColor~&
        END IF
        
        ' Top edge
        IF zoomI% > 1 THEN
            LINE (x%, b.y)-(x% + zoomI% - 1, b.y + zoomI% - 1), lineColor~&, BF
            ' Bottom edge
            LINE (x%, b.y + b.h - zoomI%)-(x% + zoomI% - 1, b.y + b.h - 1), lineColor~&, BF
        ELSE
            PSET (x%, b.y), lineColor~&
            PSET (x%, b.y + b.h - 1), lineColor~&
        END IF
    NEXT i%
    
    ' Draw marching ants for left and right edges (step by zoom, fill zoomI blocks)
    ' Skip corners already drawn by horizontal pass
    DIM patternV AS INTEGER
    FOR i% = stepPx% TO b.h - 1 - stepPx% STEP stepPx%
        y% = b.y + i%
        canvasI% = i% \ stepPx%
        patternV% = (canvasI% + antOffset%) MOD (dotSize% + gapSize%)
        
        IF patternV% < dotSize% THEN
            lineColor~& = whiteColor~&
        ELSE
            lineColor~& = blackColor~&
        END IF
        
        ' Left edge
        IF zoomI% > 1 THEN
            LINE (b.x, y%)-(b.x + zoomI% - 1, y% + zoomI% - 1), lineColor~&, BF
            ' Right edge
            LINE (b.x + b.w - zoomI%, y%)-(b.x + b.w - 1, y% + zoomI% - 1), lineColor~&, BF
        ELSE
            PSET (b.x, y%), lineColor~&
            PSET (b.x + b.w - 1, y%), lineColor~&
        END IF
    NEXT i%
    
    ' Restore blend mode
    IF prevBlend& THEN _BLEND
END SUB


''
' Select exactly one grid cell by generating a mask from grid cell geometry.
' This reuses GRID_fill_cell geometry so selection shape matches grid mode.
'
SUB MARQUEE_select_single_grid_cell (clickX AS INTEGER, clickY AS INTEGER, mode AS INTEGER)
    DIM cellMask AS LONG
    DIM oldDest AS LONG
    DIM maskColor AS _UNSIGNED LONG

    cellMask& = _NEWIMAGE(SCRN.canvasW&, SCRN.canvasH&, 32)
    IF cellMask& >= -1 THEN EXIT SUB

    oldDest& = _DEST
    _DEST cellMask&
    CLS , _RGBA32(0, 0, 0, 0)
    _DONTBLEND cellMask&

    maskColor~& = _RGB32(255, 255, 255)
    GRID_fill_cell_on_image cellMask&, clickX%, clickY%, maskColor~&

    _BLEND cellMask&
    _DEST oldDest&

    SELECTION_merge_mask cellMask&, mode%
END SUB


''
' Finish the drag operation and create the final BBOX
'
SUB MARQUEE_finish_drag ()
    IF NOT MARQUEE.DRAGGING% THEN EXIT SUB
    
    ' Calculate final box dimensions
    DIM finalX AS INTEGER, finalY AS INTEGER
    DIM finalW AS INTEGER, finalH AS INTEGER
    
    IF MARQUEE.DRAG_START_X% < MARQUEE.DRAG_END_X% THEN
        finalX% = MARQUEE.DRAG_START_X%
    ELSE
        finalX% = MARQUEE.DRAG_END_X%
    END IF
    IF MARQUEE.DRAG_START_Y% < MARQUEE.DRAG_END_Y% THEN
        finalY% = MARQUEE.DRAG_START_Y%
    ELSE
        finalY% = MARQUEE.DRAG_END_Y%
    END IF
    finalW% = ABS(MARQUEE.DRAG_END_X% - MARQUEE.DRAG_START_X%)
    finalH% = ABS(MARQUEE.DRAG_END_Y% - MARQUEE.DRAG_START_Y%)

    ' Check if this was just a click (no significant drag movement)
    ' In grid-snap mode, use unsnapped movement to detect clicks since
    ' cell-aligned coords may produce a full cell even for a single click
    DIM clickDeltaX AS INTEGER, clickDeltaY AS INTEGER
    IF GRID.SNAP% AND GRID.gridWidth% > 0 THEN
        clickDeltaX% = ABS(MOUSE.UNSNAPPED_X% - MARQUEE_UNSNAPPED_START_X%)
        clickDeltaY% = ABS(MOUSE.UNSNAPPED_Y% - MARQUEE_UNSNAPPED_START_Y%)
    ELSE
        clickDeltaX% = finalW%
        clickDeltaY% = finalH%
    END IF
    ' Treat only an exact no-move press/release as click-clear.
    ' This allows tiny drags (1px/2px/3px) to create real selections.
    IF clickDeltaX% = 0 AND clickDeltaY% = 0 THEN
        DIM clickOnCanvas AS INTEGER
        clickOnCanvas% = TRUE
        IF NOT SCRN.patternTileMode% THEN
            DIM clickZW AS LONG, clickZH AS LONG
            DIM clickDX AS INTEGER, clickDY AS INTEGER
            clickZW& = SCRN.canvasW& * SCRN.zoom!
            clickZH& = SCRN.canvasH& * SCRN.zoom!
            clickDX% = (SCRN.w& - clickZW&) \ 2 + SCRN.offsetX% + SCRN.panelShiftX%
            clickDY% = (SCRN.h& - clickZH&) \ 2 + SCRN.offsetY%
            clickOnCanvas% = (MOUSE.RAW_X% >= clickDX% AND MOUSE.RAW_X% < clickDX% + clickZW& AND MOUSE.RAW_Y% >= clickDY% AND MOUSE.RAW_Y% < clickDY% + clickZH&)
        END IF

        ' Workflow enhancement: with rectangular marquee + grid snap enabled,
        ' a single click should select exactly one snapped grid cell.
        ' Keep existing click-clear behavior for all other modes.
        IF NOT (GRID.SHOW% AND GRID.SNAP% AND GRID.gridWidth% > 0 AND GRID.gridHeight% > 0 AND MARQUEE.VARIANT = TOOL_SELECT_RECT AND clickOnCanvas%) THEN
            ' Just a click - clear ALL selection state in replace mode (including mask)
            IF MARQUEE.SELECTION_MODE = SEL_MODE_REPLACE THEN
                MARQUEE_clear
                MAGIC_WAND_reset
                INVALIDATE_scene
            END IF
            MARQUEE.DRAGGING% = FALSE
            EXIT SUB
        ELSE
            MARQUEE_select_single_grid_cell MARQUEE_UNSNAPPED_START_X%, MARQUEE_UNSNAPPED_START_Y%, MARQUEE.SELECTION_MODE
            MARQUEE.DRAGGING% = FALSE
            MARQUEE.SELECTION_MODE = SEL_MODE_REPLACE
            INVALIDATE_scene
            EXIT SUB
        END IF
    END IF

    ' Enforce minimum 1px selection — ABS gives 0 when endpoints match on same pixel
    IF finalW% < 1 THEN finalW% = 1
    IF finalH% < 1 THEN finalH% = 1

    ' Only create box if drag has some size
    IF finalW% >= MARQUEE.CFG.MinBoxWidth AND finalH% >= MARQUEE.CFG.MinBoxHeight THEN
        ' Handle add/subtract modes by converting to/from mask
        ' For add mode without existing selection, treat as replace (creates new selection)
        DIM useAddSubtractMode AS INTEGER
        useAddSubtractMode% = (MARQUEE.SELECTION_MODE <> SEL_MODE_REPLACE) AND (MARQUEE.ACTIVE% OR MARQUEE.WAND_HAS_SELECTION)
        
        IF useAddSubtractMode% THEN
            DIM w AS INTEGER, h AS INTEGER
            DIM px AS INTEGER, py AS INTEGER
            DIM mask_color AS _UNSIGNED LONG
            mask_color~& = _RGB32(255, 255, 255)
            w% = SCRN.canvasW&
            h% = SCRN.canvasH&
            
            ' Create mask from existing box selection if we don't have one
            IF MARQUEE.SELECTION_MASK >= -1 OR NOT MARQUEE.WAND_HAS_SELECTION THEN
                ' Convert existing box to mask
                IF MARQUEE.SELECTION_MASK < -1 THEN _FREEIMAGE MARQUEE.SELECTION_MASK
                MARQUEE.SELECTION_MASK = _NEWIMAGE(w%, h%, 32)
                IF MARQUEE.SELECTION_MASK < -1 THEN
                    _DEST MARQUEE.SELECTION_MASK
                    CLS , _RGBA32(0, 0, 0, 0)
                    _DONTBLEND MARQUEE.SELECTION_MASK
                    ' Fill existing box area
                    IF MARQUEE.ACTIVE% THEN
                        LINE (MARQUEE.BOX.x, MARQUEE.BOX.y)-(MARQUEE.BOX.x + MARQUEE.BOX.w - 1, MARQUEE.BOX.y + MARQUEE.BOX.h - 1), mask_color~&, BF
                    END IF
                    _BLEND MARQUEE.SELECTION_MASK
                END IF
            END IF
            
            ' Apply the new rectangle to the mask
            IF MARQUEE.SELECTION_MASK < -1 THEN
                _DEST MARQUEE.SELECTION_MASK
                _DONTBLEND MARQUEE.SELECTION_MASK
                IF MARQUEE.SELECTION_MODE = SEL_MODE_ADD THEN
                    ' Add: fill the new rectangle
                    LINE (finalX%, finalY%)-(finalX% + finalW% - 1, finalY% + finalH% - 1), mask_color~&, BF
                ELSEIF MARQUEE.SELECTION_MODE = SEL_MODE_SUBTRACT THEN
                    ' Subtract: clear the new rectangle (transparent)
                    LINE (finalX%, finalY%)-(finalX% + finalW% - 1, finalY% + finalH% - 1), _RGBA32(0, 0, 0, 0), BF
                END IF
                _BLEND MARQUEE.SELECTION_MASK
                
                ' Recalculate bounding box from mask
                DIM minX AS INTEGER, minY AS INTEGER, maxX AS INTEGER, maxY AS INTEGER
                minX% = w%: minY% = h%: maxX% = 0: maxY% = 0
                _SOURCE MARQUEE.SELECTION_MASK
                FOR py% = 0 TO h% - 1
                    FOR px% = 0 TO w% - 1
                        IF _ALPHA32(POINT(px%, py%)) > 0 THEN
                            IF px% < minX% THEN minX% = px%
                            IF px% > maxX% THEN maxX% = px%
                            IF py% < minY% THEN minY% = py%
                            IF py% > maxY% THEN maxY% = py%
                        END IF
                    NEXT px%
                NEXT py%
                
                ' Check if selection is empty
                IF minX% > maxX% THEN
                    ' Empty selection after subtract
                    MARQUEE_clear
                    MAGIC_WAND_reset
                ELSE
                    ' Update bounding box and wand bounds
                    MARQUEE.WAND_MIN_X = minX%
                    MARQUEE.WAND_MIN_Y = minY%
                    MARQUEE.WAND_MAX_X = maxX%
                    MARQUEE.WAND_MAX_Y = maxY%
                    MARQUEE.BOX.x = minX%
                    MARQUEE.BOX.y = minY%
                    MARQUEE.BOX.w = maxX% - minX% + 1
                    MARQUEE.BOX.h = maxY% - minY% + 1
                    MARQUEE.ACTIVE% = TRUE
                    MARQUEE.WAND_HAS_SELECTION = TRUE
                    MARQUEE.WAND_EDGE_DIRTY = TRUE
                    MARQUEE.USER_CREATED = TRUE
                END IF
            END IF
        ELSE
            ' Replace mode - simple box creation
            MARQUEE.CFG.initX = finalX%
            MARQUEE.CFG.initY = finalY%
            MARQUEE.CFG.initW = finalW%
            MARQUEE.CFG.initH = finalH%
            
            ' Initialize the bounding box with our config
            MARQUEE.BOX.x = MARQUEE.CFG.initX
            MARQUEE.BOX.y = MARQUEE.CFG.initY
            MARQUEE.BOX.w = MARQUEE.CFG.initW
            MARQUEE.BOX.h = MARQUEE.CFG.initH
            MARQUEE.BOX.state = MARQUEE_STATE_IDLE
            MARQUEE.ACTIVE% = TRUE
            MARQUEE.USER_CREATED = TRUE  ' User manually created this selection
            
            ' Clear any wand selection mask for clean replace
            IF MARQUEE.SELECTION_MASK < -1 THEN
                _FREEIMAGE MARQUEE.SELECTION_MASK
                MARQUEE.SELECTION_MASK = 0
            END IF
            MARQUEE.WAND_HAS_SELECTION = FALSE
        END IF
    END IF
    
    MARQUEE.DRAGGING% = FALSE
    MARQUEE.SELECTION_MODE = SEL_MODE_REPLACE  ' Reset mode
END SUB


''
' Check if a point is inside the active marquee box
' @param x INTEGER X coordinate to check
' @param y INTEGER Y coordinate to check
' @return INTEGER TRUE if point is inside, FALSE otherwise
'
FUNCTION MARQUEE_is_point_inside% (x AS INTEGER, y AS INTEGER)
    IF NOT MARQUEE.ACTIVE% THEN
        MARQUEE_is_point_inside% = FALSE
        EXIT FUNCTION
    END IF
    
    IF x >= MARQUEE.BOX.x AND x <= (MARQUEE.BOX.x + MARQUEE.BOX.w) THEN
        IF y >= MARQUEE.BOX.y AND y <= (MARQUEE.BOX.y + MARQUEE.BOX.h) THEN
            MARQUEE_is_point_inside% = TRUE
            EXIT FUNCTION
        END IF
    END IF
    
    MARQUEE_is_point_inside% = FALSE
END FUNCTION


''
' Clear all marquee selection state including active, dragging, resizing, and moving flags
'
SUB MARQUEE_clear ()
    MARQUEE.ACTIVE% = FALSE
    MARQUEE.DRAGGING% = FALSE
    MARQUEE.RESIZING% = FALSE
    MARQUEE.RESIZE_HANDLE% = 0
    MARQUEE.MOVING% = FALSE
    MARQUEE.USER_CREATED = FALSE
    MARQUEE.INITIALIZED% = FALSE
END SUB


''
' Get which handle (if any) is at the given coordinates
' @param x INTEGER X coordinate to check
' @param y INTEGER Y coordinate to check  
' @return INTEGER Handle number (0=none, 1=TL, 2=T, 3=TR, 4=L, 5=R, 6=BL, 7=B, 8=BR)
'
FUNCTION MARQUEE_get_handle_at% (x AS INTEGER, y AS INTEGER)
    IF NOT MARQUEE.ACTIVE% THEN
        MARQUEE_get_handle_at% = 0
        EXIT FUNCTION
    END IF
    
    DIM hh AS INTEGER, cx AS INTEGER, cy AS INTEGER
    hh% = THEME.MARQUEE_HANDLE_SIZE%
    IF hh% < 1 THEN hh% = 1
    cx% = MARQUEE.BOX.x + MARQUEE.BOX.w \ 2
    cy% = MARQUEE.BOX.y + MARQUEE.BOX.h \ 2
    
    ' Check each handle (TL, T, TR, L, R, BL, B, BR)
    ' 1: TL corner
    IF x >= MARQUEE.BOX.x - hh% AND x <= MARQUEE.BOX.x + hh% THEN
        IF y >= MARQUEE.BOX.y - hh% AND y <= MARQUEE.BOX.y + hh% THEN
            MARQUEE_get_handle_at% = 1
            EXIT FUNCTION
        END IF
    END IF
    
    ' 2: T edge
    IF x >= cx% - hh% AND x <= cx% + hh% THEN
        IF y >= MARQUEE.BOX.y - hh% AND y <= MARQUEE.BOX.y + hh% THEN
            MARQUEE_get_handle_at% = 2
            EXIT FUNCTION
        END IF
    END IF
    
    ' 3: TR corner
    IF x >= MARQUEE.BOX.x + MARQUEE.BOX.w - hh% AND x <= MARQUEE.BOX.x + MARQUEE.BOX.w + hh% THEN
        IF y >= MARQUEE.BOX.y - hh% AND y <= MARQUEE.BOX.y + hh% THEN
            MARQUEE_get_handle_at% = 3
            EXIT FUNCTION
        END IF
    END IF
    
    ' 4: L edge
    IF x >= MARQUEE.BOX.x - hh% AND x <= MARQUEE.BOX.x + hh% THEN
        IF y >= cy% - hh% AND y <= cy% + hh% THEN
            MARQUEE_get_handle_at% = 4
            EXIT FUNCTION
        END IF
    END IF
    
    ' 5: R edge
    IF x >= MARQUEE.BOX.x + MARQUEE.BOX.w - hh% AND x <= MARQUEE.BOX.x + MARQUEE.BOX.w + hh% THEN
        IF y >= cy% - hh% AND y <= cy% + hh% THEN
            MARQUEE_get_handle_at% = 5
            EXIT FUNCTION
        END IF
    END IF
    
    ' 6: BL corner
    IF x >= MARQUEE.BOX.x - hh% AND x <= MARQUEE.BOX.x + hh% THEN
        IF y >= MARQUEE.BOX.y + MARQUEE.BOX.h - hh% AND y <= MARQUEE.BOX.y + MARQUEE.BOX.h + hh% THEN
            MARQUEE_get_handle_at% = 6
            EXIT FUNCTION
        END IF
    END IF
    
    ' 7: B edge
    IF x >= cx% - hh% AND x <= cx% + hh% THEN
        IF y >= MARQUEE.BOX.y + MARQUEE.BOX.h - hh% AND y <= MARQUEE.BOX.y + MARQUEE.BOX.h + hh% THEN
            MARQUEE_get_handle_at% = 7
            EXIT FUNCTION
        END IF
    END IF
    
    ' 8: BR corner
    IF x >= MARQUEE.BOX.x + MARQUEE.BOX.w - hh% AND x <= MARQUEE.BOX.x + MARQUEE.BOX.w + hh% THEN
        IF y >= MARQUEE.BOX.y + MARQUEE.BOX.h - hh% AND y <= MARQUEE.BOX.y + MARQUEE.BOX.h + hh% THEN
            MARQUEE_get_handle_at% = 8
            EXIT FUNCTION
        END IF
    END IF
    
    MARQUEE_get_handle_at% = 0
END FUNCTION


''
' Start resizing from a handle
' @param handle INTEGER Which handle is being resized
' @param x INTEGER Starting X coordinate
' @param y INTEGER Starting Y coordinate
'
SUB MARQUEE_start_resize (handle AS INTEGER, x AS INTEGER, y AS INTEGER)
    MARQUEE.RESIZING% = TRUE
    MARQUEE.RESIZE_HANDLE% = handle
    MARQUEE.RESIZE_START_X% = x
    MARQUEE.RESIZE_START_Y% = y
    MARQUEE.RESIZE_ORIG_X% = MARQUEE.BOX.x
    MARQUEE.RESIZE_ORIG_Y% = MARQUEE.BOX.y
    MARQUEE.RESIZE_ORIG_W% = MARQUEE.BOX.w
    MARQUEE.RESIZE_ORIG_H% = MARQUEE.BOX.h
END SUB


''
' Update resize based on current mouse position
' @param x INTEGER Current X coordinate
' @param y INTEGER Current Y coordinate
'
SUB MARQUEE_update_resize (x AS INTEGER, y AS INTEGER)
    IF NOT MARQUEE.RESIZING% THEN EXIT SUB
    
    DIM dx AS INTEGER, dy AS INTEGER
    dx% = x - MARQUEE.RESIZE_START_X%
    dy% = y - MARQUEE.RESIZE_START_Y%
    
    SELECT CASE MARQUEE.RESIZE_HANDLE%
        CASE 1  ' TL corner - move top-left, adjust width/height
            MARQUEE.BOX.w = MARQUEE.RESIZE_ORIG_W% - dx%
            MARQUEE.BOX.h = MARQUEE.RESIZE_ORIG_H% - dy%
            ' Enforce minimum size
            IF MARQUEE.BOX.w < MARQUEE.CFG.MinBoxWidth THEN MARQUEE.BOX.w = MARQUEE.CFG.MinBoxWidth
            IF MARQUEE.BOX.h < MARQUEE.CFG.MinBoxHeight THEN MARQUEE.BOX.h = MARQUEE.CFG.MinBoxHeight
            ' Adjust position to keep BR corner anchored
            MARQUEE.BOX.x = MARQUEE.RESIZE_ORIG_X% + MARQUEE.RESIZE_ORIG_W% - MARQUEE.BOX.w
            MARQUEE.BOX.y = MARQUEE.RESIZE_ORIG_Y% + MARQUEE.RESIZE_ORIG_H% - MARQUEE.BOX.h
            
        CASE 2  ' T edge - move top, adjust height
            MARQUEE.BOX.h = MARQUEE.RESIZE_ORIG_H% - dy%
            ' Enforce minimum size
            IF MARQUEE.BOX.h < MARQUEE.CFG.MinBoxHeight THEN MARQUEE.BOX.h = MARQUEE.CFG.MinBoxHeight
            ' Adjust position to keep bottom edge anchored
            MARQUEE.BOX.y = MARQUEE.RESIZE_ORIG_Y% + MARQUEE.RESIZE_ORIG_H% - MARQUEE.BOX.h
            
        CASE 3  ' TR corner - adjust width, move top, adjust height
            MARQUEE.BOX.w = MARQUEE.RESIZE_ORIG_W% + dx%
            MARQUEE.BOX.h = MARQUEE.RESIZE_ORIG_H% - dy%
            ' Enforce minimum size
            IF MARQUEE.BOX.w < MARQUEE.CFG.MinBoxWidth THEN MARQUEE.BOX.w = MARQUEE.CFG.MinBoxWidth
            IF MARQUEE.BOX.h < MARQUEE.CFG.MinBoxHeight THEN MARQUEE.BOX.h = MARQUEE.CFG.MinBoxHeight
            ' Adjust Y position to keep bottom edge anchored
            MARQUEE.BOX.y = MARQUEE.RESIZE_ORIG_Y% + MARQUEE.RESIZE_ORIG_H% - MARQUEE.BOX.h
            
        CASE 4  ' L edge - move left, adjust width
            MARQUEE.BOX.w = MARQUEE.RESIZE_ORIG_W% - dx%
            ' Enforce minimum size
            IF MARQUEE.BOX.w < MARQUEE.CFG.MinBoxWidth THEN MARQUEE.BOX.w = MARQUEE.CFG.MinBoxWidth
            ' Adjust position to keep right edge anchored
            MARQUEE.BOX.x = MARQUEE.RESIZE_ORIG_X% + MARQUEE.RESIZE_ORIG_W% - MARQUEE.BOX.w
            
        CASE 5  ' R edge - adjust width only
            MARQUEE.BOX.w = MARQUEE.RESIZE_ORIG_W% + dx%
            IF MARQUEE.BOX.w < MARQUEE.CFG.MinBoxWidth THEN MARQUEE.BOX.w = MARQUEE.CFG.MinBoxWidth
            
        CASE 6  ' BL corner - move left, adjust width and height
            MARQUEE.BOX.w = MARQUEE.RESIZE_ORIG_W% - dx%
            MARQUEE.BOX.h = MARQUEE.RESIZE_ORIG_H% + dy%
            ' Enforce minimum size
            IF MARQUEE.BOX.w < MARQUEE.CFG.MinBoxWidth THEN MARQUEE.BOX.w = MARQUEE.CFG.MinBoxWidth
            IF MARQUEE.BOX.h < MARQUEE.CFG.MinBoxHeight THEN MARQUEE.BOX.h = MARQUEE.CFG.MinBoxHeight
            ' Adjust X position to keep right edge anchored
            MARQUEE.BOX.x = MARQUEE.RESIZE_ORIG_X% + MARQUEE.RESIZE_ORIG_W% - MARQUEE.BOX.w
            
        CASE 7  ' B edge - adjust height only
            MARQUEE.BOX.h = MARQUEE.RESIZE_ORIG_H% + dy%
            IF MARQUEE.BOX.h < MARQUEE.CFG.MinBoxHeight THEN MARQUEE.BOX.h = MARQUEE.CFG.MinBoxHeight
            
        CASE 8  ' BR corner - adjust width and height
            MARQUEE.BOX.w = MARQUEE.RESIZE_ORIG_W% + dx%
            MARQUEE.BOX.h = MARQUEE.RESIZE_ORIG_H% + dy%
            IF MARQUEE.BOX.w < MARQUEE.CFG.MinBoxWidth THEN MARQUEE.BOX.w = MARQUEE.CFG.MinBoxWidth
            IF MARQUEE.BOX.h < MARQUEE.CFG.MinBoxHeight THEN MARQUEE.BOX.h = MARQUEE.CFG.MinBoxHeight
    END SELECT
    
    ' Apply screen bounds (keep at least 1 pixel visible)
    IF MARQUEE.BOX.x > SCRN.w - 1 THEN MARQUEE.BOX.x = SCRN.w - 1
    IF MARQUEE.BOX.x < 1 - MARQUEE.BOX.w THEN MARQUEE.BOX.x = 1 - MARQUEE.BOX.w
    IF MARQUEE.BOX.y > SCRN.h - 1 THEN MARQUEE.BOX.y = SCRN.h - 1
    IF MARQUEE.BOX.y < 1 - MARQUEE.BOX.h THEN MARQUEE.BOX.y = 1 - MARQUEE.BOX.h
    ' Also ensure the box doesn't extend too far
    IF MARQUEE.BOX.x + MARQUEE.BOX.w > SCRN.w THEN MARQUEE.BOX.w = SCRN.w - MARQUEE.BOX.x
    IF MARQUEE.BOX.y + MARQUEE.BOX.h > SCRN.h THEN MARQUEE.BOX.h = SCRN.h - MARQUEE.BOX.y
    ' And enforce minimum again after bounds checking
    IF MARQUEE.BOX.w < 1 THEN MARQUEE.BOX.w = 1
    IF MARQUEE.BOX.h < 1 THEN MARQUEE.BOX.h = 1
END SUB


''
' Finish resizing operation
'
SUB MARQUEE_finish_resize ()
    MARQUEE.RESIZING% = FALSE
    MARQUEE.RESIZE_HANDLE% = 0
END SUB


''
' Start moving the box from inside
' @param x INTEGER Starting X coordinate
' @param y INTEGER Starting Y coordinate
'
SUB MARQUEE_start_move (x AS INTEGER, y AS INTEGER)
    MARQUEE.MOVING% = TRUE
    MARQUEE.MOVE_START_X% = x
    MARQUEE.MOVE_START_Y% = y
    MARQUEE.MOVE_ORIG_X% = MARQUEE.BOX.x
    MARQUEE.MOVE_ORIG_Y% = MARQUEE.BOX.y
END SUB


''
' Update move based on current mouse position
' @param x INTEGER Current X coordinate
' @param y INTEGER Current Y coordinate
'
SUB MARQUEE_update_move (x AS INTEGER, y AS INTEGER)
    IF NOT MARQUEE.MOVING% THEN EXIT SUB
    
    DIM dx AS INTEGER, dy AS INTEGER
    dx% = x - MARQUEE.MOVE_START_X%
    dy% = y - MARQUEE.MOVE_START_Y%
    
    MARQUEE.BOX.x = MARQUEE.MOVE_ORIG_X% + dx%
    MARQUEE.BOX.y = MARQUEE.MOVE_ORIG_Y% + dy%
    
    ' Keep box within screen bounds (at least 1 pixel visible)
    ' Left edge can go as far right as SCRN.w - 1
    IF MARQUEE.BOX.x > SCRN.w - 1 THEN MARQUEE.BOX.x = SCRN.w - 1
    ' Right edge must be at least at x=0, so x >= -(w-1) or x >= 1-w
    IF MARQUEE.BOX.x < 1 - MARQUEE.BOX.w THEN MARQUEE.BOX.x = 1 - MARQUEE.BOX.w
    ' Top edge can go as far down as SCRN.h - 1
    IF MARQUEE.BOX.y > SCRN.h - 1 THEN MARQUEE.BOX.y = SCRN.h - 1
    ' Bottom edge must be at least at y=0
    IF MARQUEE.BOX.y < 1 - MARQUEE.BOX.h THEN MARQUEE.BOX.y = 1 - MARQUEE.BOX.h
END SUB


''
' Finish moving operation
'
SUB MARQUEE_finish_move ()
    MARQUEE.MOVING% = FALSE
END SUB


' ============================================================================
' MAGIC WAND SELECTION FUNCTIONS
' ============================================================================

''
' Reset magic wand selection state (but keep mode)
'
SUB MAGIC_WAND_reset ()
    ' Free existing mask if valid
    IF MARQUEE.SELECTION_MASK < -1 THEN
        _FREEIMAGE MARQUEE.SELECTION_MASK
    END IF
    MARQUEE.SELECTION_MASK = 0
    MARQUEE.WAND_HAS_SELECTION = FALSE
    MARQUEE.WAND_MIN_X = 0
    MARQUEE.WAND_MIN_Y = 0
    MARQUEE.WAND_MAX_X = 0
    MARQUEE.WAND_MAX_Y = 0
    MARQUEE.WAND_EDGE_COUNT = 0
    MARQUEE.WAND_EDGE_DIRTY = FALSE
    REDIM WAND_EDGE_X(0) AS INTEGER
    REDIM WAND_EDGE_Y(0) AS INTEGER
END SUB


''
' Check if magic wand has an active selection
' @return INTEGER TRUE if wand has selection, FALSE otherwise
'
FUNCTION MAGIC_WAND_has_selection% ()
    MAGIC_WAND_has_selection% = MARQUEE.WAND_HAS_SELECTION
END FUNCTION


''
' Select contiguous pixels of the same color (wrapper for backward compatibility)
' @param x INTEGER X coordinate to start selection
' @param y INTEGER Y coordinate to start selection
'
SUB MAGIC_WAND_select (x AS INTEGER, y AS INTEGER)
    MAGIC_WAND_select_with_mode x%, y%, SEL_MODE_REPLACE
END SUB


''
' Select contiguous pixels of the same color using scanline flood fill algorithm
' @param x INTEGER X coordinate to start selection  
' @param y INTEGER Y coordinate to start selection
' @param mode INTEGER Selection mode: SEL_MODE_REPLACE, SEL_MODE_ADD, or SEL_MODE_SUBTRACT
'
SUB MAGIC_WAND_select_with_mode (x AS INTEGER, y AS INTEGER, mode AS INTEGER)
    DIM old_dest AS LONG
    DIM old_source AS LONG
    DIM target_color AS _UNSIGNED LONG
    DIM w AS INTEGER, h AS INTEGER
    DIM targetImg AS LONG
    DIM existing_mask AS LONG
    DIM has_existing AS INTEGER
    
    ' Get the current layer image
    targetImg& = LAYER_current_image&
    old_dest& = _DEST
    old_source& = _SOURCE
    
    _SOURCE targetImg&
    
    w% = _WIDTH(targetImg&)
    h% = _HEIGHT(targetImg&)
    
    ' Bounds check
    IF x% < 0 OR x% >= w% OR y% < 0 OR y% >= h% THEN
        _SOURCE old_source&
        EXIT SUB
    END IF
    
    ' Get target color at click position
    target_color~& = POINT(x%, y%)
    
    ' For add/subtract modes, preserve existing mask
    existing_mask& = 0
    has_existing% = FALSE
    IF mode% <> SEL_MODE_REPLACE AND MARQUEE.WAND_HAS_SELECTION AND MARQUEE.SELECTION_MASK < -1 THEN
        existing_mask& = MARQUEE.SELECTION_MASK
        has_existing% = TRUE
        MARQUEE.SELECTION_MASK = 0  ' Don't free it yet
    ELSE
        ' Reset any existing selection for replace mode
        MAGIC_WAND_reset
    END IF
    
    ' Create selection mask (white = selected, transparent = not selected)
    MARQUEE.SELECTION_MASK = _NEWIMAGE(w%, h%, 32)
    IF MARQUEE.SELECTION_MASK >= -1 THEN
        _SOURCE old_source&
        EXIT SUB ' Failed to create mask
    END IF
    
    ' Clear mask to transparent
    _DEST MARQUEE.SELECTION_MASK
    CLS , _RGBA32(0, 0, 0, 0)
    _DONTBLEND MARQUEE.SELECTION_MASK
    
    ' Initialize bounding box tracking
    MARQUEE.WAND_MIN_X = w%
    MARQUEE.WAND_MIN_Y = h%
    MARQUEE.WAND_MAX_X = 0
    MARQUEE.WAND_MAX_Y = 0
    
    ' Stack for scanline seeds - starts minimal, grows dynamically as needed
    DIM stack_capacity AS LONG
    stack_capacity& = 128
    REDIM stack_x(1 TO 128) AS INTEGER
    REDIM stack_y(1 TO 128) AS INTEGER
    DIM stack_ptr AS LONG
    
    DIM py AS INTEGER, x1 AS INTEGER, x2 AS INTEGER
    DIM sx AS INTEGER, dy AS INTEGER, ny AS INTEGER
    DIM in_span AS INTEGER
    DIM mask_color AS _UNSIGNED LONG
    
    ' Mask color is white (fully opaque) for selected pixels
    mask_color~& = _RGB32(255, 255, 255)
    
    ' Initialize with starting point
    stack_ptr& = 1
    stack_x(stack_ptr&) = x%
    stack_y(stack_ptr&) = y%
    
    WHILE stack_ptr& > 0
        ' Pop seed point from stack
        x% = stack_x(stack_ptr&)
        py% = stack_y(stack_ptr&)
        stack_ptr& = stack_ptr& - 1
        
        ' Skip if out of bounds
        IF py% < 0 OR py% >= h% OR x% < 0 OR x% >= w% THEN GOTO wand_next_seed
        
        ' Skip if already selected (check mask)
        _SOURCE MARQUEE.SELECTION_MASK
        IF POINT(x%, py%) = mask_color~& THEN GOTO wand_next_seed
        
        ' Skip if color doesn't match target
        _SOURCE targetImg&
        IF POINT(x%, py%) <> target_color~& THEN GOTO wand_next_seed
        
        ' Find left edge of scanline
        x1% = x%
        WHILE x1% > 0
            _SOURCE targetImg&
            IF POINT(x1% - 1, py%) <> target_color~& THEN EXIT WHILE
            _SOURCE MARQUEE.SELECTION_MASK
            IF POINT(x1% - 1, py%) = mask_color~& THEN EXIT WHILE
            x1% = x1% - 1
        WEND
        
        ' Find right edge of scanline
        x2% = x%
        WHILE x2% < w% - 1
            _SOURCE targetImg&
            IF POINT(x2% + 1, py%) <> target_color~& THEN EXIT WHILE
            _SOURCE MARQUEE.SELECTION_MASK
            IF POINT(x2% + 1, py%) = mask_color~& THEN EXIT WHILE
            x2% = x2% + 1
        WEND
        
        ' Mark the entire horizontal scanline as selected in mask
        _DEST MARQUEE.SELECTION_MASK
        LINE (x1%, py%)-(x2%, py%), mask_color~&
        
        ' Update bounding box
        IF x1% < MARQUEE.WAND_MIN_X THEN MARQUEE.WAND_MIN_X = x1%
        IF x2% > MARQUEE.WAND_MAX_X THEN MARQUEE.WAND_MAX_X = x2%
        IF py% < MARQUEE.WAND_MIN_Y THEN MARQUEE.WAND_MIN_Y = py%
        IF py% > MARQUEE.WAND_MAX_Y THEN MARQUEE.WAND_MAX_Y = py%
        
        ' Check scanlines above and below for new spans to fill
        FOR dy% = -1 TO 1 STEP 2
            ny% = py% + dy%
            IF ny% >= 0 AND ny% < h% THEN
                in_span% = FALSE
                ' Scan the filled span for matching pixels
                FOR sx% = x1% TO x2%
                    _SOURCE targetImg&
                    DIM pxColor AS _UNSIGNED LONG
                    pxColor~& = POINT(sx%, ny%)
                    IF pxColor~& = target_color~& THEN
                        ' Check if not already selected
                        _SOURCE MARQUEE.SELECTION_MASK
                        IF POINT(sx%, ny%) <> mask_color~& THEN
                            IF NOT in_span% THEN
                                ' Found start of new span - add seed point
                                ' Grow stack if needed
                                IF stack_ptr& >= stack_capacity& THEN
                                    stack_capacity& = stack_capacity& * 2
                                    REDIM _PRESERVE stack_x(1 TO stack_capacity&) AS INTEGER
                                    REDIM _PRESERVE stack_y(1 TO stack_capacity&) AS INTEGER
                                END IF
                                stack_ptr& = stack_ptr& + 1
                                stack_x(stack_ptr&) = sx%
                                stack_y(stack_ptr&) = ny%
                                in_span% = TRUE
                            END IF
                        ELSE
                            in_span% = FALSE
                        END IF
                    ELSE
                        ' No longer in matching span
                        in_span% = FALSE
                    END IF
                NEXT sx%
            END IF
        NEXT dy%
        
        wand_next_seed:
    WEND
    
    ' Explicitly free stack memory
    ERASE stack_x, stack_y
    
    ' Merge with existing selection if in add/subtract mode
    IF has_existing% AND existing_mask& < -1 THEN
        DIM px AS INTEGER, py2 AS INTEGER
        DIM new_pixel AS _UNSIGNED LONG, old_pixel AS _UNSIGNED LONG
        DIM final_mask AS LONG
        
        ' Create final merged mask
        final_mask& = _NEWIMAGE(w%, h%, 32)
        IF final_mask& < -1 THEN
            _DEST final_mask&
            CLS , _RGBA32(0, 0, 0, 0)
            _DONTBLEND final_mask&
            
            ' Merge based on mode
            FOR py2% = 0 TO h% - 1
                FOR px% = 0 TO w% - 1
                    _SOURCE existing_mask&
                    old_pixel~& = POINT(px%, py2%)
                    _SOURCE MARQUEE.SELECTION_MASK
                    new_pixel~& = POINT(px%, py2%)
                    
                    _DEST final_mask&
                    IF mode% = SEL_MODE_ADD THEN
                        ' Add: OR operation - selected if either mask has it
                        IF _ALPHA32(old_pixel~&) > 0 OR _ALPHA32(new_pixel~&) > 0 THEN
                            PSET (px%, py2%), mask_color~&
                            ' Update bounding box
                            IF px% < MARQUEE.WAND_MIN_X THEN MARQUEE.WAND_MIN_X = px%
                            IF px% > MARQUEE.WAND_MAX_X THEN MARQUEE.WAND_MAX_X = px%
                            IF py2% < MARQUEE.WAND_MIN_Y THEN MARQUEE.WAND_MIN_Y = py2%
                            IF py2% > MARQUEE.WAND_MAX_Y THEN MARQUEE.WAND_MAX_Y = py2%
                        END IF
                    ELSEIF mode% = SEL_MODE_SUBTRACT THEN
                        ' Subtract: AND NOT - selected if old has it but new doesn't
                        IF _ALPHA32(old_pixel~&) > 0 AND _ALPHA32(new_pixel~&) = 0 THEN
                            PSET (px%, py2%), mask_color~&
                            ' Update bounding box
                            IF px% < MARQUEE.WAND_MIN_X THEN MARQUEE.WAND_MIN_X = px%
                            IF px% > MARQUEE.WAND_MAX_X THEN MARQUEE.WAND_MAX_X = px%
                            IF py2% < MARQUEE.WAND_MIN_Y THEN MARQUEE.WAND_MIN_Y = py2%
                            IF py2% > MARQUEE.WAND_MAX_Y THEN MARQUEE.WAND_MAX_Y = py2%
                        END IF
                    END IF
                NEXT px%
            NEXT py2%
            
            _BLEND final_mask&
            
            ' Replace the new mask with merged result
            _FREEIMAGE MARQUEE.SELECTION_MASK
            MARQUEE.SELECTION_MASK = final_mask&
        END IF
        
        ' Free the old existing mask
        _FREEIMAGE existing_mask&
        
        ' Check if selection is empty after subtract
        IF mode% = SEL_MODE_SUBTRACT AND MARQUEE.WAND_MIN_X > MARQUEE.WAND_MAX_X THEN
            MAGIC_WAND_reset
            _SOURCE old_source&
            _DEST old_dest&
            EXIT SUB
        END IF
    END IF
    
    ' Mark selection as valid
    MARQUEE.WAND_HAS_SELECTION = TRUE
    MARQUEE.WAND_EDGE_DIRTY = TRUE
    
    ' Also set regular marquee box to bounding box of selection
    ' This allows resize handles to work if desired in future
    MARQUEE.BOX.x = MARQUEE.WAND_MIN_X
    MARQUEE.BOX.y = MARQUEE.WAND_MIN_Y
    MARQUEE.BOX.w = MARQUEE.WAND_MAX_X - MARQUEE.WAND_MIN_X + 1
    MARQUEE.BOX.h = MARQUEE.WAND_MAX_Y - MARQUEE.WAND_MIN_Y + 1
    MARQUEE.ACTIVE% = TRUE
    MARQUEE.INITIALIZED% = TRUE
    MARQUEE.USER_CREATED = TRUE  ' User selected with magic wand
    
    _BLEND MARQUEE.SELECTION_MASK
    _SOURCE old_source&
    _DEST old_dest&
END SUB


''
' Flood erase contiguous pixels of the same color (set to transparent)
' Used when holding E and clicking with the magic wand tool active.
' Saves undo state before modifying the current layer.
' @param x INTEGER X coordinate to start flood erase
' @param y INTEGER Y coordinate to start flood erase
'
SUB MAGIC_WAND_erase_flood (x AS INTEGER, y AS INTEGER)
    DIM old_dest AS LONG : old_dest& = _DEST
    DIM old_source AS LONG : old_source& = _SOURCE
    DIM targetImg AS LONG : targetImg& = LAYER_current_image&
    DIM history_before AS LONG
    DIM history_flags AS LONG
    DIM history_recorded AS INTEGER
    IF targetImg& >= -1 THEN EXIT SUB

    history_before& = 0
    history_flags& = 0
    history_recorded% = FALSE

    DIM w AS INTEGER : w% = _WIDTH(targetImg&)
    DIM h AS INTEGER : h% = _HEIGHT(targetImg&)
    DIM target_color AS _UNSIGNED LONG

    _SOURCE targetImg&
    IF x% < 0 OR x% >= w% OR y% < 0 OR y% >= h% THEN
        _SOURCE old_source&
        EXIT SUB
    END IF

    target_color~& = POINT(x%, y%)

    ' Nothing to erase if seed pixel is already fully transparent
    IF _ALPHA32(target_color~&) = 0 THEN
        _SOURCE old_source&
        EXIT SUB
    END IF

    IF NOT HISTORY_IN_PROGRESS% AND LAYERS(CURRENT_LAYER%).historyId& > 0 AND targetImg& < -1 THEN
        history_before& = _COPYIMAGE(targetImg&, 32)
    END IF

    DIM stack_capacity AS LONG : stack_capacity& = 128
    REDIM stack_x(1 TO 128) AS INTEGER
    REDIM stack_y(1 TO 128) AS INTEGER
    DIM stack_ptr AS LONG
    DIM py AS INTEGER, x1 AS INTEGER, x2 AS INTEGER
    DIM sx AS INTEGER, dy AS INTEGER, ny AS INTEGER
    DIM in_span AS INTEGER

    _DEST targetImg&
    _DONTBLEND targetImg&

    stack_ptr& = 1
    stack_x(1) = x%
    stack_y(1) = y%

    WHILE stack_ptr& > 0
        x% = stack_x(stack_ptr&)
        py% = stack_y(stack_ptr&)
        stack_ptr& = stack_ptr& - 1

        IF py% < 0 OR py% >= h% OR x% < 0 OR x% >= w% THEN GOTO ef_next_seed

        _SOURCE targetImg&
        IF POINT(x%, py%) <> target_color~& THEN GOTO ef_next_seed

        ' Find left and right edges of matching scanline
        x1% = x%
        WHILE x1% > 0
            _SOURCE targetImg&
            IF POINT(x1% - 1, py%) <> target_color~& THEN EXIT WHILE
            x1% = x1% - 1
        WEND

        x2% = x%
        WHILE x2% < w% - 1
            _SOURCE targetImg&
            IF POINT(x2% + 1, py%) <> target_color~& THEN EXIT WHILE
            x2% = x2% + 1
        WEND

        ' Erase matching scanline (set to fully transparent)
        _DEST targetImg&
        LINE (x1%, py%)-(x2%, py%), _RGBA32(0, 0, 0, 0)

        ' Queue seeds from adjacent rows
        FOR dy% = -1 TO 1 STEP 2
            ny% = py% + dy%
            IF ny% >= 0 AND ny% < h% THEN
                in_span% = FALSE
                FOR sx% = x1% TO x2%
                    _SOURCE targetImg&
                    IF POINT(sx%, ny%) = target_color~& THEN
                        IF NOT in_span% THEN
                            IF stack_ptr& >= stack_capacity& THEN
                                stack_capacity& = stack_capacity& * 2
                                REDIM _PRESERVE stack_x(1 TO stack_capacity&) AS INTEGER
                                REDIM _PRESERVE stack_y(1 TO stack_capacity&) AS INTEGER
                            END IF
                            stack_ptr& = stack_ptr& + 1
                            stack_x(stack_ptr&) = sx%
                            stack_y(stack_ptr&) = ny%
                            in_span% = TRUE
                        END IF
                    ELSE
                        in_span% = FALSE
                    END IF
                NEXT sx%
            END IF
        NEXT dy%

        ef_next_seed:
    WEND

    ERASE stack_x, stack_y
    _BLEND targetImg&
    IF history_before& < -1 THEN
        HISTORY_record_brush LAYERS(CURRENT_LAYER%).historyId&, CURRENT_LAYER%, _RGBA32(0, 0, 0, 0), history_flags&, history_before&, "Wand Erase"
        history_recorded% = TRUE
    END IF
    IF history_recorded% THEN HISTORY_saved_this_frame% = TRUE
    CANVAS_DIRTY% = TRUE
    SCENE_DIRTY% = TRUE
    FRAME_IDLE% = FALSE
    _SOURCE old_source&
    _DEST old_dest&
END SUB


''
' Flood fill contiguous pixels of the same color with the foreground paint color
' Used when holding F and clicking with the magic wand tool active.
' Saves undo state before modifying the current layer.
' @param x INTEGER X coordinate to start flood fill
' @param y INTEGER Y coordinate to start flood fill
'
SUB MAGIC_WAND_fill_flood (x AS INTEGER, y AS INTEGER)
    DIM old_dest AS LONG : old_dest& = _DEST
    DIM old_source AS LONG : old_source& = _SOURCE
    DIM targetImg AS LONG : targetImg& = LAYER_current_image&
    DIM history_before AS LONG
    DIM history_flags AS LONG
    DIM history_recorded AS INTEGER
    IF targetImg& >= -1 THEN EXIT SUB

    history_before& = 0
    history_flags& = 0
    history_recorded% = FALSE

    DIM w AS INTEGER : w% = _WIDTH(targetImg&)
    DIM h AS INTEGER : h% = _HEIGHT(targetImg&)
    DIM target_color AS _UNSIGNED LONG

    _SOURCE targetImg&
    IF x% < 0 OR x% >= w% OR y% < 0 OR y% >= h% THEN
        _SOURCE old_source&
        EXIT SUB
    END IF

    target_color~& = POINT(x%, y%)

    ' Nothing to do if seed already is the paint color
    IF target_color~& = PAINT_COLOR~& THEN
        _SOURCE old_source&
        EXIT SUB
    END IF

    IF NOT HISTORY_IN_PROGRESS% AND LAYERS(CURRENT_LAYER%).historyId& > 0 AND targetImg& < -1 THEN
        history_before& = _COPYIMAGE(targetImg&, 32)
    END IF

    DIM stack_capacity AS LONG : stack_capacity& = 128
    REDIM stack_x(1 TO 128) AS INTEGER
    REDIM stack_y(1 TO 128) AS INTEGER
    DIM stack_ptr AS LONG
    DIM py AS INTEGER, x1 AS INTEGER, x2 AS INTEGER
    DIM sx AS INTEGER, dy AS INTEGER, ny AS INTEGER
    DIM in_span AS INTEGER

    _DEST targetImg&
    _DONTBLEND targetImg&

    stack_ptr& = 1
    stack_x(1) = x%
    stack_y(1) = y%

    WHILE stack_ptr& > 0
        x% = stack_x(stack_ptr&)
        py% = stack_y(stack_ptr&)
        stack_ptr& = stack_ptr& - 1

        IF py% < 0 OR py% >= h% OR x% < 0 OR x% >= w% THEN GOTO ff_next_seed

        _SOURCE targetImg&
        IF POINT(x%, py%) <> target_color~& THEN GOTO ff_next_seed

        ' Find left and right edges of matching scanline
        x1% = x%
        WHILE x1% > 0
            _SOURCE targetImg&
            IF POINT(x1% - 1, py%) <> target_color~& THEN EXIT WHILE
            x1% = x1% - 1
        WEND

        x2% = x%
        WHILE x2% < w% - 1
            _SOURCE targetImg&
            IF POINT(x2% + 1, py%) <> target_color~& THEN EXIT WHILE
            x2% = x2% + 1
        WEND

        ' Paint scanline with foreground color
        _DEST targetImg&
        LINE (x1%, py%)-(x2%, py%), PAINT_COLOR~&

        ' Queue seeds from adjacent rows
        FOR dy% = -1 TO 1 STEP 2
            ny% = py% + dy%
            IF ny% >= 0 AND ny% < h% THEN
                in_span% = FALSE
                FOR sx% = x1% TO x2%
                    _SOURCE targetImg&
                    IF POINT(sx%, ny%) = target_color~& THEN
                        IF NOT in_span% THEN
                            IF stack_ptr& >= stack_capacity& THEN
                                stack_capacity& = stack_capacity& * 2
                                REDIM _PRESERVE stack_x(1 TO stack_capacity&) AS INTEGER
                                REDIM _PRESERVE stack_y(1 TO stack_capacity&) AS INTEGER
                            END IF
                            stack_ptr& = stack_ptr& + 1
                            stack_x(stack_ptr&) = sx%
                            stack_y(stack_ptr&) = ny%
                            in_span% = TRUE
                        END IF
                    ELSE
                        in_span% = FALSE
                    END IF
                NEXT sx%
            END IF
        NEXT dy%

        ff_next_seed:
    WEND

    ERASE stack_x, stack_y
    _BLEND targetImg&
    IF history_before& < -1 THEN
        HISTORY_record_fill LAYERS(CURRENT_LAYER%).historyId&, CURRENT_LAYER%, PAINT_apply_opacity~&(PAINT_COLOR~&), history_flags&, history_before&, x%, y%, "Wand Fill"
        history_recorded% = TRUE
    END IF
    IF history_recorded% THEN HISTORY_saved_this_frame% = TRUE
    CANVAS_DIRTY% = TRUE
    SCENE_DIRTY% = TRUE
    FRAME_IDLE% = FALSE
    _SOURCE old_source&
    _DEST old_dest&
END SUB


''
' Select contiguous pixels using the merged canvas (all visible layers) for color sampling
' Used when holding W and clicking with the magic wand tool active.
' All selection-mask writing is the same as MAGIC_WAND_select_with_mode; only
' the color-comparison source is changed from the current layer to a merged composite.
' @param x    INTEGER X coordinate to start selection
' @param y    INTEGER Y coordinate to start selection
' @param mode INTEGER SEL_MODE_REPLACE / SEL_MODE_ADD / SEL_MODE_SUBTRACT
'
SUB MAGIC_WAND_select_merged (x AS INTEGER, y AS INTEGER, mode AS INTEGER)
    DIM old_dest AS LONG : old_dest& = _DEST
    DIM old_source AS LONG : old_source& = _SOURCE
    DIM targetImg AS LONG : targetImg& = LAYER_current_image&
    IF targetImg& >= -1 THEN EXIT SUB

    DIM w AS INTEGER : w% = _WIDTH(targetImg&)
    DIM h AS INTEGER : h% = _HEIGHT(targetImg&)

    IF x% < 0 OR x% >= w% OR y% < 0 OR y% >= h% THEN EXIT SUB

    ' Build throwaway merged composite of all visible layers (bottom-to-top)
    DIM mergedImg AS LONG
    mergedImg& = _NEWIMAGE(w%, h%, 32)
    IF mergedImg& >= -1 THEN EXIT SUB

    _DEST mergedImg&
    CLS , _RGBA32(0, 0, 0, 0)
    _BLEND mergedImg&

    DIM zi AS INTEGER, li AS INTEGER
    DIM tmpImg AS LONG
    DIM mvMem AS _MEM
    DIM mvOff AS _OFFSET
    DIM mvPix AS _UNSIGNED LONG
    DIM mvAlpha AS _UNSIGNED _BYTE
    DIM mvNewAlpha AS INTEGER

    FOR zi% = 1 TO LAYER_COUNT%
        FOR li% = 1 TO MAX_LAYERS
            IF LAYERS(li%).imgHandle& < -1 AND LAYERS(li%).visible AND LAYERS(li%).zIndex = zi% THEN
                IF LAYERS(li%).opacity >= 255 THEN
                    _PUTIMAGE , LAYERS(li%).imgHandle&
                ELSE
                    tmpImg& = _COPYIMAGE(LAYERS(li%).imgHandle&, 32)
                    mvMem = _MEMIMAGE(tmpImg&)
                    FOR mvOff = mvMem.OFFSET TO mvMem.OFFSET + mvMem.SIZE - 4 STEP 4
                        _MEMGET mvMem, mvOff, mvPix~&
                        mvAlpha~%% = _ALPHA32(mvPix~&)
                        IF mvAlpha~%% > 0 THEN
                            mvNewAlpha% = (mvAlpha~%% * LAYERS(li%).opacity) \ 255
                            _MEMPUT mvMem, mvOff + 3, mvNewAlpha% AS _UNSIGNED _BYTE
                        END IF
                    NEXT mvOff
                    _MEMFREE mvMem
                    _PUTIMAGE , tmpImg&
                    IF tmpImg& < -1 THEN _FREEIMAGE tmpImg&
                END IF
                EXIT FOR
            END IF
        NEXT li%
    NEXT zi%

    ' Sample seed color from the merged composite
    DIM target_color AS _UNSIGNED LONG
    _SOURCE mergedImg&
    target_color~& = POINT(x%, y%)

    ' Preserve existing mask for Add/Subtract modes
    DIM existing_mask AS LONG : existing_mask& = 0
    DIM has_existing AS INTEGER : has_existing% = FALSE
    IF mode% <> SEL_MODE_REPLACE AND MARQUEE.WAND_HAS_SELECTION AND MARQUEE.SELECTION_MASK < -1 THEN
        existing_mask& = MARQUEE.SELECTION_MASK
        has_existing% = TRUE
        MARQUEE.SELECTION_MASK = 0
    ELSE
        MAGIC_WAND_reset
    END IF

    ' Create fresh selection mask
    MARQUEE.SELECTION_MASK = _NEWIMAGE(w%, h%, 32)
    IF MARQUEE.SELECTION_MASK >= -1 THEN
        _SOURCE old_source&
        _DEST old_dest&
        IF mergedImg& < -1 THEN _FREEIMAGE mergedImg&
        EXIT SUB
    END IF

    _DEST MARQUEE.SELECTION_MASK
    CLS , _RGBA32(0, 0, 0, 0)
    _DONTBLEND MARQUEE.SELECTION_MASK

    MARQUEE.WAND_MIN_X = w% : MARQUEE.WAND_MIN_Y = h%
    MARQUEE.WAND_MAX_X = 0 : MARQUEE.WAND_MAX_Y = 0

    DIM stack_capacity AS LONG : stack_capacity& = 128
    REDIM stack_x(1 TO 128) AS INTEGER
    REDIM stack_y(1 TO 128) AS INTEGER
    DIM stack_ptr AS LONG
    DIM py AS INTEGER, x1 AS INTEGER, x2 AS INTEGER
    DIM sx AS INTEGER, dy AS INTEGER, ny AS INTEGER
    DIM in_span AS INTEGER
    DIM mask_color AS _UNSIGNED LONG : mask_color~& = _RGB32(255, 255, 255)

    stack_ptr& = 1
    stack_x(1) = x%
    stack_y(1) = y%

    WHILE stack_ptr& > 0
        x% = stack_x(stack_ptr&)
        py% = stack_y(stack_ptr&)
        stack_ptr& = stack_ptr& - 1

        IF py% < 0 OR py% >= h% OR x% < 0 OR x% >= w% THEN GOTO mg_next_seed

        _SOURCE MARQUEE.SELECTION_MASK
        IF POINT(x%, py%) = mask_color~& THEN GOTO mg_next_seed

        _SOURCE mergedImg&
        IF POINT(x%, py%) <> target_color~& THEN GOTO mg_next_seed

        ' Find left and right edges
        x1% = x%
        WHILE x1% > 0
            _SOURCE mergedImg&
            IF POINT(x1% - 1, py%) <> target_color~& THEN EXIT WHILE
            _SOURCE MARQUEE.SELECTION_MASK
            IF POINT(x1% - 1, py%) = mask_color~& THEN EXIT WHILE
            x1% = x1% - 1
        WEND

        x2% = x%
        WHILE x2% < w% - 1
            _SOURCE mergedImg&
            IF POINT(x2% + 1, py%) <> target_color~& THEN EXIT WHILE
            _SOURCE MARQUEE.SELECTION_MASK
            IF POINT(x2% + 1, py%) = mask_color~& THEN EXIT WHILE
            x2% = x2% + 1
        WEND

        ' Mark scanline as selected
        _DEST MARQUEE.SELECTION_MASK
        LINE (x1%, py%)-(x2%, py%), mask_color~&

        IF x1% < MARQUEE.WAND_MIN_X THEN MARQUEE.WAND_MIN_X = x1%
        IF x2% > MARQUEE.WAND_MAX_X THEN MARQUEE.WAND_MAX_X = x2%
        IF py% < MARQUEE.WAND_MIN_Y THEN MARQUEE.WAND_MIN_Y = py%
        IF py% > MARQUEE.WAND_MAX_Y THEN MARQUEE.WAND_MAX_Y = py%

        ' Queue seeds from adjacent rows
        FOR dy% = -1 TO 1 STEP 2
            ny% = py% + dy%
            IF ny% >= 0 AND ny% < h% THEN
                in_span% = FALSE
                FOR sx% = x1% TO x2%
                    _SOURCE mergedImg&
                    DIM pxColor AS _UNSIGNED LONG
                    pxColor~& = POINT(sx%, ny%)
                    IF pxColor~& = target_color~& THEN
                        _SOURCE MARQUEE.SELECTION_MASK
                        IF POINT(sx%, ny%) <> mask_color~& THEN
                            IF NOT in_span% THEN
                                IF stack_ptr& >= stack_capacity& THEN
                                    stack_capacity& = stack_capacity& * 2
                                    REDIM _PRESERVE stack_x(1 TO stack_capacity&) AS INTEGER
                                    REDIM _PRESERVE stack_y(1 TO stack_capacity&) AS INTEGER
                                END IF
                                stack_ptr& = stack_ptr& + 1
                                stack_x(stack_ptr&) = sx%
                                stack_y(stack_ptr&) = ny%
                                in_span% = TRUE
                            END IF
                        ELSE
                            in_span% = FALSE
                        END IF
                    ELSE
                        in_span% = FALSE
                    END IF
                NEXT sx%
            END IF
        NEXT dy%

        mg_next_seed:
    WEND

    ERASE stack_x, stack_y

    ' Merge with existing selection for Add/Subtract modes
    IF has_existing% AND existing_mask& < -1 THEN
        DIM px AS INTEGER, py2 AS INTEGER
        DIM new_pixel AS _UNSIGNED LONG, old_pixel AS _UNSIGNED LONG
        DIM final_mask AS LONG

        final_mask& = _NEWIMAGE(w%, h%, 32)
        IF final_mask& < -1 THEN
            _DEST final_mask&
            CLS , _RGBA32(0, 0, 0, 0)
            _DONTBLEND final_mask&

            FOR py2% = 0 TO h% - 1
                FOR px% = 0 TO w% - 1
                    _SOURCE existing_mask&
                    old_pixel~& = POINT(px%, py2%)
                    _SOURCE MARQUEE.SELECTION_MASK
                    new_pixel~& = POINT(px%, py2%)

                    _DEST final_mask&
                    IF mode% = SEL_MODE_ADD THEN
                        IF _ALPHA32(old_pixel~&) > 0 OR _ALPHA32(new_pixel~&) > 0 THEN
                            PSET (px%, py2%), mask_color~&
                            IF px% < MARQUEE.WAND_MIN_X THEN MARQUEE.WAND_MIN_X = px%
                            IF px% > MARQUEE.WAND_MAX_X THEN MARQUEE.WAND_MAX_X = px%
                            IF py2% < MARQUEE.WAND_MIN_Y THEN MARQUEE.WAND_MIN_Y = py2%
                            IF py2% > MARQUEE.WAND_MAX_Y THEN MARQUEE.WAND_MAX_Y = py2%
                        END IF
                    ELSEIF mode% = SEL_MODE_SUBTRACT THEN
                        IF _ALPHA32(old_pixel~&) > 0 AND _ALPHA32(new_pixel~&) = 0 THEN
                            PSET (px%, py2%), mask_color~&
                            IF px% < MARQUEE.WAND_MIN_X THEN MARQUEE.WAND_MIN_X = px%
                            IF px% > MARQUEE.WAND_MAX_X THEN MARQUEE.WAND_MAX_X = px%
                            IF py2% < MARQUEE.WAND_MIN_Y THEN MARQUEE.WAND_MIN_Y = py2%
                            IF py2% > MARQUEE.WAND_MAX_Y THEN MARQUEE.WAND_MAX_Y = py2%
                        END IF
                    END IF
                NEXT px%
            NEXT py2%

            _BLEND final_mask&
            _FREEIMAGE MARQUEE.SELECTION_MASK
            MARQUEE.SELECTION_MASK = final_mask&
        END IF

        _FREEIMAGE existing_mask&

        IF mode% = SEL_MODE_SUBTRACT AND MARQUEE.WAND_MIN_X > MARQUEE.WAND_MAX_X THEN
            MAGIC_WAND_reset
            _SOURCE old_source&
            _DEST old_dest&
            IF mergedImg& < -1 THEN _FREEIMAGE mergedImg&
            EXIT SUB
        END IF
    END IF

    MARQUEE.WAND_HAS_SELECTION = TRUE
    MARQUEE.WAND_EDGE_DIRTY = TRUE
    MARQUEE.BOX.x = MARQUEE.WAND_MIN_X
    MARQUEE.BOX.y = MARQUEE.WAND_MIN_Y
    MARQUEE.BOX.w = MARQUEE.WAND_MAX_X - MARQUEE.WAND_MIN_X + 1
    MARQUEE.BOX.h = MARQUEE.WAND_MAX_Y - MARQUEE.WAND_MIN_Y + 1
    MARQUEE.ACTIVE% = TRUE
    MARQUEE.INITIALIZED% = TRUE
    MARQUEE.USER_CREATED = TRUE

    _BLEND MARQUEE.SELECTION_MASK
    IF mergedImg& < -1 THEN _FREEIMAGE mergedImg&
    _SOURCE old_source&
    _DEST old_dest&
END SUB


''
' Select ALL pixels matching the color at (x,y) across the merged composite (non-contiguous).
' Unlike MAGIC_WAND_select_merged which flood-fills contiguous regions, this selects every
' pixel in the entire image that matches the target color — useful for global color selection.
' @param x    INTEGER X coordinate to sample color from
' @param y    INTEGER Y coordinate to sample color from
' @param mode INTEGER SEL_MODE_REPLACE / SEL_MODE_ADD / SEL_MODE_SUBTRACT
'
SUB MAGIC_WAND_select_all_color_merged (x AS INTEGER, y AS INTEGER, mode AS INTEGER)
    DIM old_dest AS LONG : old_dest& = _DEST
    DIM old_source AS LONG : old_source& = _SOURCE
    DIM targetImg AS LONG : targetImg& = LAYER_current_image&
    IF targetImg& >= -1 THEN EXIT SUB

    DIM w AS INTEGER : w% = _WIDTH(targetImg&)
    DIM h AS INTEGER : h% = _HEIGHT(targetImg&)

    IF x% < 0 OR x% >= w% OR y% < 0 OR y% >= h% THEN EXIT SUB

    ' Build throwaway merged composite of all visible layers (bottom-to-top)
    DIM mergedImg AS LONG
    mergedImg& = _NEWIMAGE(w%, h%, 32)
    IF mergedImg& >= -1 THEN EXIT SUB

    _DEST mergedImg&
    CLS , _RGBA32(0, 0, 0, 0)
    _BLEND mergedImg&

    DIM zi AS INTEGER, li AS INTEGER
    DIM tmpImg AS LONG
    DIM mvMem AS _MEM
    DIM mvOff AS _OFFSET
    DIM mvPix AS _UNSIGNED LONG
    DIM mvAlpha AS _UNSIGNED _BYTE
    DIM mvNewAlpha AS INTEGER

    FOR zi% = 1 TO LAYER_COUNT%
        FOR li% = 1 TO MAX_LAYERS
            IF LAYERS(li%).imgHandle& < -1 AND LAYERS(li%).visible AND LAYERS(li%).zIndex = zi% THEN
                IF LAYERS(li%).opacity >= 255 THEN
                    _PUTIMAGE , LAYERS(li%).imgHandle&
                ELSE
                    tmpImg& = _COPYIMAGE(LAYERS(li%).imgHandle&, 32)
                    mvMem = _MEMIMAGE(tmpImg&)
                    FOR mvOff = mvMem.OFFSET TO mvMem.OFFSET + mvMem.SIZE - 4 STEP 4
                        _MEMGET mvMem, mvOff, mvPix~&
                        mvAlpha~%% = _ALPHA32(mvPix~&)
                        IF mvAlpha~%% > 0 THEN
                            mvNewAlpha% = (mvAlpha~%% * LAYERS(li%).opacity) \ 255
                            _MEMPUT mvMem, mvOff + 3, mvNewAlpha% AS _UNSIGNED _BYTE
                        END IF
                    NEXT mvOff
                    _MEMFREE mvMem
                    _PUTIMAGE , tmpImg&
                    IF tmpImg& < -1 THEN _FREEIMAGE tmpImg&
                END IF
                EXIT FOR
            END IF
        NEXT li%
    NEXT zi%

    ' Sample target color from the merged composite
    DIM target_color AS _UNSIGNED LONG
    _SOURCE mergedImg&
    target_color~& = POINT(x%, y%)

    ' Preserve existing mask for Add/Subtract modes
    DIM existing_mask AS LONG : existing_mask& = 0
    DIM has_existing AS INTEGER : has_existing% = FALSE
    IF mode% <> SEL_MODE_REPLACE AND MARQUEE.WAND_HAS_SELECTION AND MARQUEE.SELECTION_MASK < -1 THEN
        existing_mask& = MARQUEE.SELECTION_MASK
        has_existing% = TRUE
        MARQUEE.SELECTION_MASK = 0
    ELSE
        MAGIC_WAND_reset
    END IF

    ' Create fresh selection mask
    MARQUEE.SELECTION_MASK = _NEWIMAGE(w%, h%, 32)
    IF MARQUEE.SELECTION_MASK >= -1 THEN
        _SOURCE old_source&
        _DEST old_dest&
        IF mergedImg& < -1 THEN _FREEIMAGE mergedImg&
        EXIT SUB
    END IF

    _DEST MARQUEE.SELECTION_MASK
    CLS , _RGBA32(0, 0, 0, 0)
    _DONTBLEND MARQUEE.SELECTION_MASK

    MARQUEE.WAND_MIN_X = w% : MARQUEE.WAND_MIN_Y = h%
    MARQUEE.WAND_MAX_X = 0 : MARQUEE.WAND_MAX_Y = 0

    DIM mask_color AS _UNSIGNED LONG : mask_color~& = _RGB32(255, 255, 255)
    DIM px AS INTEGER, py AS INTEGER

    ' Select ALL matching pixels (non-contiguous) across the entire image
    FOR py% = 0 TO h% - 1
        FOR px% = 0 TO w% - 1
            _SOURCE mergedImg&
            IF POINT(px%, py%) = target_color~& THEN
                _DEST MARQUEE.SELECTION_MASK
                PSET (px%, py%), mask_color~&
                IF px% < MARQUEE.WAND_MIN_X THEN MARQUEE.WAND_MIN_X = px%
                IF px% > MARQUEE.WAND_MAX_X THEN MARQUEE.WAND_MAX_X = px%
                IF py% < MARQUEE.WAND_MIN_Y THEN MARQUEE.WAND_MIN_Y = py%
                IF py% > MARQUEE.WAND_MAX_Y THEN MARQUEE.WAND_MAX_Y = py%
            END IF
        NEXT px%
    NEXT py%

    ' Merge with existing selection for Add/Subtract modes
    IF has_existing% AND existing_mask& < -1 THEN
        DIM new_pixel AS _UNSIGNED LONG, old_pixel AS _UNSIGNED LONG
        DIM final_mask AS LONG

        final_mask& = _NEWIMAGE(w%, h%, 32)
        IF final_mask& < -1 THEN
            _DEST final_mask&
            CLS , _RGBA32(0, 0, 0, 0)
            _DONTBLEND final_mask&

            DIM py2 AS INTEGER
            FOR py2% = 0 TO h% - 1
                FOR px% = 0 TO w% - 1
                    _SOURCE existing_mask&
                    old_pixel~& = POINT(px%, py2%)
                    _SOURCE MARQUEE.SELECTION_MASK
                    new_pixel~& = POINT(px%, py2%)

                    _DEST final_mask&
                    IF mode% = SEL_MODE_ADD THEN
                        IF _ALPHA32(old_pixel~&) > 0 OR _ALPHA32(new_pixel~&) > 0 THEN
                            PSET (px%, py2%), mask_color~&
                            IF px% < MARQUEE.WAND_MIN_X THEN MARQUEE.WAND_MIN_X = px%
                            IF px% > MARQUEE.WAND_MAX_X THEN MARQUEE.WAND_MAX_X = px%
                            IF py2% < MARQUEE.WAND_MIN_Y THEN MARQUEE.WAND_MIN_Y = py2%
                            IF py2% > MARQUEE.WAND_MAX_Y THEN MARQUEE.WAND_MAX_Y = py2%
                        END IF
                    ELSEIF mode% = SEL_MODE_SUBTRACT THEN
                        IF _ALPHA32(old_pixel~&) > 0 AND _ALPHA32(new_pixel~&) = 0 THEN
                            PSET (px%, py2%), mask_color~&
                            IF px% < MARQUEE.WAND_MIN_X THEN MARQUEE.WAND_MIN_X = px%
                            IF px% > MARQUEE.WAND_MAX_X THEN MARQUEE.WAND_MAX_X = px%
                            IF py2% < MARQUEE.WAND_MIN_Y THEN MARQUEE.WAND_MIN_Y = py2%
                            IF py2% > MARQUEE.WAND_MAX_Y THEN MARQUEE.WAND_MAX_Y = py2%
                        END IF
                    END IF
                NEXT px%
            NEXT py2%

            _BLEND final_mask&
            _FREEIMAGE MARQUEE.SELECTION_MASK
            MARQUEE.SELECTION_MASK = final_mask&
        END IF

        _FREEIMAGE existing_mask&

        IF mode% = SEL_MODE_SUBTRACT AND MARQUEE.WAND_MIN_X > MARQUEE.WAND_MAX_X THEN
            MAGIC_WAND_reset
            _SOURCE old_source&
            _DEST old_dest&
            IF mergedImg& < -1 THEN _FREEIMAGE mergedImg&
            EXIT SUB
        END IF
    END IF

    MARQUEE.WAND_HAS_SELECTION = TRUE
    MARQUEE.WAND_EDGE_DIRTY = TRUE
    MARQUEE.BOX.x = MARQUEE.WAND_MIN_X
    MARQUEE.BOX.y = MARQUEE.WAND_MIN_Y
    MARQUEE.BOX.w = MARQUEE.WAND_MAX_X - MARQUEE.WAND_MIN_X + 1
    MARQUEE.BOX.h = MARQUEE.WAND_MAX_Y - MARQUEE.WAND_MIN_Y + 1
    MARQUEE.ACTIVE% = TRUE
    MARQUEE.INITIALIZED% = TRUE
    MARQUEE.USER_CREATED = TRUE

    _BLEND MARQUEE.SELECTION_MASK
    IF mergedImg& < -1 THEN _FREEIMAGE mergedImg&
    _SOURCE old_source&
    _DEST old_dest&
END SUB


''
' Build a cached list of edge pixel coordinates from the wand selection mask.
' Called once when the selection is created or modified — avoids scanning the
' entire bounding box with POINT() every frame during draw_outline.
'
SUB MAGIC_WAND_build_edge_cache ()
    IF NOT MARQUEE.WAND_HAS_SELECTION THEN EXIT SUB
    IF MARQUEE.SELECTION_MASK >= -1 THEN EXIT SUB

    DIM old_source AS LONG : old_source& = _SOURCE

    DIM w AS INTEGER : w% = _WIDTH(MARQUEE.SELECTION_MASK)
    DIM h AS INTEGER : h% = _HEIGHT(MARQUEE.SELECTION_MASK)
    DIM mask_mem AS _MEM : mask_mem = _MEMIMAGE(MARQUEE.SELECTION_MASK)
    DIM stride AS LONG : stride& = w% * 4  ' 32-bit = 4 bytes per pixel

    ' First pass: count edge pixels
    DIM edgeCount AS LONG : edgeCount& = 0
    DIM x AS INTEGER, y AS INTEGER
    DIM pix AS _UNSIGNED LONG
    DIM isSelected AS INTEGER, isEdge AS INTEGER

    FOR y% = MARQUEE.WAND_MIN_Y TO MARQUEE.WAND_MAX_Y
        FOR x% = MARQUEE.WAND_MIN_X TO MARQUEE.WAND_MAX_X
            _MEMGET mask_mem, mask_mem.OFFSET + (y% * stride& + x% * 4), pix~&
            isSelected% = (_ALPHA32(pix~&) > 0)
            IF isSelected% THEN
                isEdge% = FALSE
                IF x% = 0 THEN
                    isEdge% = TRUE
                ELSE
                    _MEMGET mask_mem, mask_mem.OFFSET + (y% * stride& + (x% - 1) * 4), pix~&
                    IF _ALPHA32(pix~&) = 0 THEN isEdge% = TRUE
                END IF
                IF NOT isEdge% THEN
                    IF x% = w% - 1 THEN
                        isEdge% = TRUE
                    ELSE
                        _MEMGET mask_mem, mask_mem.OFFSET + (y% * stride& + (x% + 1) * 4), pix~&
                        IF _ALPHA32(pix~&) = 0 THEN isEdge% = TRUE
                    END IF
                END IF
                IF NOT isEdge% THEN
                    IF y% = 0 THEN
                        isEdge% = TRUE
                    ELSE
                        _MEMGET mask_mem, mask_mem.OFFSET + ((y% - 1) * stride& + x% * 4), pix~&
                        IF _ALPHA32(pix~&) = 0 THEN isEdge% = TRUE
                    END IF
                END IF
                IF NOT isEdge% THEN
                    IF y% = h% - 1 THEN
                        isEdge% = TRUE
                    ELSE
                        _MEMGET mask_mem, mask_mem.OFFSET + ((y% + 1) * stride& + x% * 4), pix~&
                        IF _ALPHA32(pix~&) = 0 THEN isEdge% = TRUE
                    END IF
                END IF
                IF isEdge% THEN edgeCount& = edgeCount& + 1
            END IF
        NEXT x%
    NEXT y%

    ' Allocate edge arrays
    IF edgeCount& = 0 THEN
        MARQUEE.WAND_EDGE_COUNT = 0
        MARQUEE.WAND_EDGE_DIRTY = FALSE
        _MEMFREE mask_mem
        _SOURCE old_source&
        EXIT SUB
    END IF
    REDIM WAND_EDGE_X(1 TO edgeCount&) AS INTEGER
    REDIM WAND_EDGE_Y(1 TO edgeCount&) AS INTEGER

    ' Second pass: populate edge arrays
    DIM idx AS LONG : idx& = 0
    FOR y% = MARQUEE.WAND_MIN_Y TO MARQUEE.WAND_MAX_Y
        FOR x% = MARQUEE.WAND_MIN_X TO MARQUEE.WAND_MAX_X
            _MEMGET mask_mem, mask_mem.OFFSET + (y% * stride& + x% * 4), pix~&
            isSelected% = (_ALPHA32(pix~&) > 0)
            IF isSelected% THEN
                isEdge% = FALSE
                IF x% = 0 THEN
                    isEdge% = TRUE
                ELSE
                    _MEMGET mask_mem, mask_mem.OFFSET + (y% * stride& + (x% - 1) * 4), pix~&
                    IF _ALPHA32(pix~&) = 0 THEN isEdge% = TRUE
                END IF
                IF NOT isEdge% THEN
                    IF x% = w% - 1 THEN
                        isEdge% = TRUE
                    ELSE
                        _MEMGET mask_mem, mask_mem.OFFSET + (y% * stride& + (x% + 1) * 4), pix~&
                        IF _ALPHA32(pix~&) = 0 THEN isEdge% = TRUE
                    END IF
                END IF
                IF NOT isEdge% THEN
                    IF y% = 0 THEN
                        isEdge% = TRUE
                    ELSE
                        _MEMGET mask_mem, mask_mem.OFFSET + ((y% - 1) * stride& + x% * 4), pix~&
                        IF _ALPHA32(pix~&) = 0 THEN isEdge% = TRUE
                    END IF
                END IF
                IF NOT isEdge% THEN
                    IF y% = h% - 1 THEN
                        isEdge% = TRUE
                    ELSE
                        _MEMGET mask_mem, mask_mem.OFFSET + ((y% + 1) * stride& + x% * 4), pix~&
                        IF _ALPHA32(pix~&) = 0 THEN isEdge% = TRUE
                    END IF
                END IF
                IF isEdge% THEN
                    idx& = idx& + 1
                    WAND_EDGE_X(idx&) = x%
                    WAND_EDGE_Y(idx&) = y%
                END IF
            END IF
        NEXT x%
    NEXT y%

    MARQUEE.WAND_EDGE_COUNT = idx&
    MARQUEE.WAND_EDGE_DIRTY = FALSE
    _MEMFREE mask_mem
    _SOURCE old_source&
END SUB


''
' Draw marching ants outline around selected pixels in magic wand mask.
' Uses the pre-computed edge cache for O(edges) instead of O(bounding_box) per frame.
'
SUB MAGIC_WAND_draw_outline ()
    IF NOT MARQUEE.WAND_HAS_SELECTION THEN EXIT SUB
    IF MARQUEE.SELECTION_MASK >= -1 THEN EXIT SUB

    ' Rebuild edge cache if needed (first draw after selection creation/change)
    IF MARQUEE.WAND_EDGE_DIRTY OR MARQUEE.WAND_EDGE_COUNT = 0 THEN
        MAGIC_WAND_build_edge_cache
    END IF
    IF MARQUEE.WAND_EDGE_COUNT = 0 THEN EXIT SUB

    DIM old_dest AS LONG : old_dest& = _DEST
    _DEST SCRN.CANVAS&

    ' Calculate zoom transformation values
    DIM zw AS LONG, zh AS LONG, dx AS INTEGER, dy AS INTEGER
    zw& = SCRN.canvasW& * SCRN.zoom!
    zh& = SCRN.canvasH& * SCRN.zoom!
    dx% = (SCRN.w& - zw&) \ 2 + SCRN.offsetX% + SCRN.panelShiftX%
    dy% = (SCRN.h& - zh&) \ 2 + SCRN.offsetY%

    ' Viewport clip bounds
    DIM vx1 AS INTEGER, vy1 AS INTEGER, vx2 AS INTEGER, vy2 AS INTEGER
    vx1% = 0: vy1% = 0
    vx2% = _WIDTH(SCRN.CANVAS&) - 1
    vy2% = _HEIGHT(SCRN.CANVAS&) - 1

    ' Animate the marching ants with time-based offset
    DIM antOffset AS INTEGER
    DIM dotSize AS INTEGER, gapSize AS INTEGER
    dotSize% = 2: gapSize% = 2
    antOffset% = INT(TIMER * 8) MOD (dotSize% + gapSize%)

    DIM i AS LONG
    DIM sx AS INTEGER, sy AS INTEGER
    DIM zoomI AS INTEGER : zoomI% = INT(SCRN.zoom!)
    DIM pattern AS INTEGER

    FOR i& = 1 TO MARQUEE.WAND_EDGE_COUNT
        sx% = dx% + INT(WAND_EDGE_X(i&) * SCRN.zoom!)
        sy% = dy% + INT(WAND_EDGE_Y(i&) * SCRN.zoom!)

        ' Clip to viewport
        IF SCRN.zoom! >= 1 THEN
            IF sx% + zoomI% - 1 < vx1% OR sx% > vx2% THEN GOTO mw_next_edge
            IF sy% + zoomI% - 1 < vy1% OR sy% > vy2% THEN GOTO mw_next_edge
        ELSE
            IF sx% < vx1% OR sx% > vx2% OR sy% < vy1% OR sy% > vy2% THEN GOTO mw_next_edge
        END IF

        pattern% = ((WAND_EDGE_X(i&) + WAND_EDGE_Y(i&) + antOffset%) MOD (dotSize% + gapSize%))
        IF pattern% < dotSize% THEN
            IF zoomI% > 1 THEN
                LINE (sx%, sy%)-(sx% + zoomI% - 1, sy% + zoomI% - 1), _RGB32(255, 255, 255), BF
            ELSE
                PSET (sx%, sy%), _RGB32(255, 255, 255)
            END IF
        ELSE
            IF zoomI% > 1 THEN
                LINE (sx%, sy%)-(sx% + zoomI% - 1, sy% + zoomI% - 1), _RGB32(0, 0, 0), BF
            ELSE
                PSET (sx%, sy%), _RGB32(0, 0, 0)
            END IF
        END IF

        mw_next_edge:
    NEXT i&

    _DEST old_dest&
END SUB


''
' Clear selected pixels by making them transparent
' Used when DEL or CTRL+E is pressed with magic wand selection active
'
SUB MAGIC_WAND_clear_selected_transparent ()
    IF NOT MARQUEE.WAND_HAS_SELECTION THEN EXIT SUB
    IF MARQUEE.SELECTION_MASK >= -1 THEN EXIT SUB
    
    DIM old_dest AS LONG
    DIM old_source AS LONG
    DIM x AS INTEGER, y AS INTEGER
    DIM mask_color AS _UNSIGNED LONG
    DIM targetImg AS LONG
    DIM history_before AS LONG
    DIM history_flags AS LONG
    DIM history_recorded AS INTEGER
    
    old_dest& = _DEST
    old_source& = _SOURCE
    
    targetImg& = LAYER_current_image&
    history_before& = 0
    history_flags& = HISTORY_FLAG_CLIPPED
    history_recorded% = FALSE

    IF NOT HISTORY_IN_PROGRESS% AND LAYERS(CURRENT_LAYER%).historyId& > 0 AND targetImg& < -1 THEN
        history_before& = _COPYIMAGE(targetImg&, 32)
    END IF
    
    _SOURCE MARQUEE.SELECTION_MASK
    _DEST targetImg&
    _DONTBLEND targetImg&
    
    mask_color~& = _RGB32(255, 255, 255)
    
    ' Iterate through bounding box and clear selected pixels
    FOR y% = MARQUEE.WAND_MIN_Y TO MARQUEE.WAND_MAX_Y
        FOR x% = MARQUEE.WAND_MIN_X TO MARQUEE.WAND_MAX_X
            _SOURCE MARQUEE.SELECTION_MASK
            IF POINT(x%, y%) = mask_color~& THEN
                ' Set pixel to fully transparent
                _DEST targetImg&
                PSET (x%, y%), _RGBA32(0, 0, 0, 0)
            END IF
        NEXT x%
    NEXT y%
    
    _BLEND targetImg&
    _SOURCE old_source&
    _DEST old_dest&
    
    IF history_before& < -1 THEN
        HISTORY_record_brush LAYERS(CURRENT_LAYER%).historyId&, CURRENT_LAYER%, _RGBA32(0, 0, 0, 0), history_flags&, history_before&, "Clear Selected Transparent"
        history_recorded% = TRUE
    END IF
    IF history_recorded% THEN HISTORY_saved_this_frame% = TRUE
    
    CANVAS_DIRTY% = TRUE
END SUB

''
' Check if there's any active selection (marquee or magic wand)
' @return INTEGER TRUE if drawing should be clipped to selection, FALSE otherwise
'
FUNCTION SELECTION_has_active% ()
    ' Check for mask-based selection (magic wand or combined marquee)
    IF MARQUEE.WAND_HAS_SELECTION AND MARQUEE.SELECTION_MASK < -1 THEN
        SELECTION_has_active% = TRUE
        EXIT FUNCTION
    END IF
    
    ' Check for regular marquee selection (only if user-created)
    IF MARQUEE.ACTIVE AND MARQUEE.USER_CREATED AND MARQUEE.INITIALIZED THEN
        SELECTION_has_active% = TRUE
        EXIT FUNCTION
    END IF
    
    SELECTION_has_active% = FALSE
END FUNCTION


''
' Get the canvas-coordinate bounding box of the active selection overlay.
' Returns the rectangle that the marching ants / handles occupy on SCRN.CANVAS&.
' Used by the dirty-rect fast path in SCREEN_render to know which area needs
' restoring from the scene cache each frame.
' @param sx1 INTEGER Output left X of the bounding box in screen coordinates
' @param sy1 INTEGER Output top Y of the bounding box in screen coordinates
' @param sx2 INTEGER Output right X of the bounding box in screen coordinates
' @param sy2 INTEGER Output bottom Y of the bounding box in screen coordinates
'
SUB SELECTION_get_screen_bbox (sx1 AS INTEGER, sy1 AS INTEGER, sx2 AS INTEGER, sy2 AS INTEGER)
    DIM zw AS LONG, zh AS LONG, dx AS INTEGER, dy AS INTEGER
    zw& = SCRN.canvasW& * SCRN.zoom!
    zh& = SCRN.canvasH& * SCRN.zoom!
    dx% = (SCRN.w& - zw&) \ 2 + SCRN.offsetX% + SCRN.panelShiftX%
    dy% = (SCRN.h& - zh&) \ 2 + SCRN.offsetY%

    IF MARQUEE.WAND_HAS_SELECTION AND MARQUEE.SELECTION_MASK < -1 THEN
        ' Magic wand: use stored bounding box
        sx1% = dx% + INT(MARQUEE.WAND_MIN_X * SCRN.zoom!) - 1
        sy1% = dy% + INT(MARQUEE.WAND_MIN_Y * SCRN.zoom!) - 1
        sx2% = dx% + INT((MARQUEE.WAND_MAX_X + 1) * SCRN.zoom!)
        sy2% = dy% + INT((MARQUEE.WAND_MAX_Y + 1) * SCRN.zoom!)
    ELSEIF MARQUEE.ACTIVE% AND MARQUEE.USER_CREATED THEN
        ' Marquee box: transform box coords + handle padding
        DIM hh AS INTEGER
        hh% = INT(2 * SCRN.zoom!)
        IF hh% < 2 THEN hh% = 2
        sx1% = dx% + INT(MARQUEE.BOX.x * SCRN.zoom!) - hh% - 1
        sy1% = dy% + INT(MARQUEE.BOX.y * SCRN.zoom!) - hh% - 1
        sx2% = dx% + INT((MARQUEE.BOX.x + MARQUEE.BOX.w) * SCRN.zoom!) + hh% + 1
        sy2% = dy% + INT((MARQUEE.BOX.y + MARQUEE.BOX.h) * SCRN.zoom!) + hh% + 1
    ELSE
        ' No selection — return zero-area box
        sx1% = 0: sy1% = 0: sx2% = 0: sy2% = 0
    END IF
END SUB


''
' Check if a point is inside the active selection
' Used for clipping drawing operations to selection mask
' @param x INTEGER X coordinate to test against the active selection
' @param y INTEGER Y coordinate to test against the active selection
' @return INTEGER TRUE if point is inside selection (or no selection active), FALSE if outside
'
FUNCTION SELECTION_is_point_inside% (x AS INTEGER, y AS INTEGER)
    ' If no active selection, all points are valid
    IF NOT SELECTION_has_active% THEN
        SELECTION_is_point_inside% = TRUE
        EXIT FUNCTION
    END IF
    
    ' Check if we have a mask-based selection (magic wand OR combined marquee)
    ' A mask exists and is valid when WAND_HAS_SELECTION is true
    IF MARQUEE.WAND_HAS_SELECTION AND MARQUEE.SELECTION_MASK < -1 THEN
        ' Quick bounds check first
        IF x% < MARQUEE.WAND_MIN_X OR x% > MARQUEE.WAND_MAX_X THEN
            SELECTION_is_point_inside% = FALSE
            EXIT FUNCTION
        END IF
        IF y% < MARQUEE.WAND_MIN_Y OR y% > MARQUEE.WAND_MAX_Y THEN
            SELECTION_is_point_inside% = FALSE
            EXIT FUNCTION
        END IF
        
        ' Check the mask pixel
        DIM old_source AS LONG
        DIM mask_color AS _UNSIGNED LONG
        old_source& = _SOURCE
        _SOURCE MARQUEE.SELECTION_MASK
        mask_color~& = POINT(x%, y%)
        _SOURCE old_source&
        
        SELECTION_is_point_inside% = (mask_color~& = _RGB32(255, 255, 255))
        EXIT FUNCTION
    END IF
    
    ' Check regular marquee bounding box (simple rectangular selection)
    IF MARQUEE.ACTIVE AND MARQUEE.USER_CREATED AND MARQUEE.INITIALIZED THEN
        IF x% >= MARQUEE.BOX.x AND x% < MARQUEE.BOX.x + MARQUEE.BOX.w THEN
            IF y% >= MARQUEE.BOX.y AND y% < MARQUEE.BOX.y + MARQUEE.BOX.h THEN
                SELECTION_is_point_inside% = TRUE
                EXIT FUNCTION
            END IF
        END IF
        SELECTION_is_point_inside% = FALSE
        EXIT FUNCTION
    END IF
    
    ' No selection, allow all
    SELECTION_is_point_inside% = TRUE
END FUNCTION


''
' Select all - creates a full-canvas selection
'
SUB SELECTION_select_all ()
    DIM w AS INTEGER, h AS INTEGER
    w% = SCRN.canvasW&
    h% = SCRN.canvasH&
    
    ' Clear any existing wand selection
    IF MARQUEE.SELECTION_MASK < -1 THEN
        _FREEIMAGE MARQUEE.SELECTION_MASK
    END IF
    MARQUEE.SELECTION_MASK = 0
    MARQUEE.WAND_HAS_SELECTION = FALSE
    
    ' Set marquee box to full canvas
    MARQUEE.BOX.x = 0
    MARQUEE.BOX.y = 0
    MARQUEE.BOX.w = w%
    MARQUEE.BOX.h = h%
    MARQUEE.ACTIVE% = TRUE
    MARQUEE.INITIALIZED% = TRUE
    MARQUEE.USER_CREATED = TRUE
    
    ' Update config
    MARQUEE.CFG.initX = 0
    MARQUEE.CFG.initY = 0
    MARQUEE.CFG.initW = w%
    MARQUEE.CFG.initH = h%
    MARQUEE.BOX.x = MARQUEE.CFG.initX
    MARQUEE.BOX.y = MARQUEE.CFG.initY
    MARQUEE.BOX.w = MARQUEE.CFG.initW
    MARQUEE.BOX.h = MARQUEE.CFG.initH
    MARQUEE.BOX.state = MARQUEE_STATE_IDLE
    
    GUI_NEEDS_REDRAW% = TRUE
END SUB


''
' Invert selection - selects everything that's not currently selected
'
SUB SELECTION_invert ()
    DIM w AS INTEGER, h AS INTEGER
    DIM px AS INTEGER, py AS INTEGER
    DIM old_dest AS LONG, old_source AS LONG
    DIM mask_color AS _UNSIGNED LONG
    DIM has_selection AS INTEGER
    
    w% = SCRN.canvasW&
    h% = SCRN.canvasH&
    mask_color~& = _RGB32(255, 255, 255)
    
    has_selection% = SELECTION_has_active%
    
    ' If no selection, invert means select all (everything was "not selected")
    IF NOT has_selection% THEN
        SELECTION_select_all
        EXIT SUB
    END IF
    
    old_dest& = _DEST
    old_source& = _SOURCE
    
    ' Check if we have a mask-based selection (magic wand or combined marquee)
    IF MARQUEE.WAND_HAS_SELECTION AND MARQUEE.SELECTION_MASK < -1 THEN
        ' Invert the existing mask
        _DEST MARQUEE.SELECTION_MASK
        _DONTBLEND MARQUEE.SELECTION_MASK
        
        ' XOR-like inversion: toggle each pixel
        FOR py% = 0 TO h% - 1
            FOR px% = 0 TO w% - 1
                _SOURCE MARQUEE.SELECTION_MASK
                IF _ALPHA32(POINT(px%, py%)) > 0 THEN
                    ' Was selected, make unselected (transparent)
                    PSET (px%, py%), _RGBA32(0, 0, 0, 0)
                ELSE
                    ' Was not selected, make selected (white)
                    PSET (px%, py%), mask_color~&
                END IF
            NEXT px%
        NEXT py%
        
        _BLEND MARQUEE.SELECTION_MASK
        
        ' Recalculate bounding box
        DIM minX AS INTEGER, minY AS INTEGER, maxX AS INTEGER, maxY AS INTEGER
        minX% = w%: minY% = h%: maxX% = 0: maxY% = 0
        _SOURCE MARQUEE.SELECTION_MASK
        FOR py% = 0 TO h% - 1
            FOR px% = 0 TO w% - 1
                IF _ALPHA32(POINT(px%, py%)) > 0 THEN
                    IF px% < minX% THEN minX% = px%
                    IF px% > maxX% THEN maxX% = px%
                    IF py% < minY% THEN minY% = py%
                    IF py% > maxY% THEN maxY% = py%
                END IF
            NEXT px%
        NEXT py%
        
        IF minX% > maxX% THEN
            ' Empty selection after invert (shouldn't happen normally)
            MARQUEE_clear
            MAGIC_WAND_reset
        ELSE
            MARQUEE.WAND_MIN_X = minX%
            MARQUEE.WAND_MIN_Y = minY%
            MARQUEE.WAND_MAX_X = maxX%
            MARQUEE.WAND_MAX_Y = maxY%
            MARQUEE.BOX.x = minX%
            MARQUEE.BOX.y = minY%
            MARQUEE.BOX.w = maxX% - minX% + 1
            MARQUEE.BOX.h = maxY% - minY% + 1
        END IF
    ELSEIF MARQUEE.ACTIVE% AND MARQUEE.USER_CREATED THEN
        ' Convert rectangular marquee to mask and invert
        DIM new_mask AS LONG
        new_mask& = _NEWIMAGE(w%, h%, 32)
        IF new_mask& < -1 THEN
            _DEST new_mask&
            CLS , _RGBA32(0, 0, 0, 0)
            _DONTBLEND new_mask&
            
            ' Fill everything EXCEPT the current box
            ' Top region (above the box)
            IF MARQUEE.BOX.y > 0 THEN
                LINE (0, 0)-(w% - 1, MARQUEE.BOX.y - 1), mask_color~&, BF
            END IF
            ' Bottom region (below the box)
            IF MARQUEE.BOX.y + MARQUEE.BOX.h < h% THEN
                LINE (0, MARQUEE.BOX.y + MARQUEE.BOX.h)-(w% - 1, h% - 1), mask_color~&, BF
            END IF
            ' Left region (left of the box, between top and bottom)
            IF MARQUEE.BOX.x > 0 THEN
                LINE (0, MARQUEE.BOX.y)-(MARQUEE.BOX.x - 1, MARQUEE.BOX.y + MARQUEE.BOX.h - 1), mask_color~&, BF
            END IF
            ' Right region (right of the box, between top and bottom)
            IF MARQUEE.BOX.x + MARQUEE.BOX.w < w% THEN
                LINE (MARQUEE.BOX.x + MARQUEE.BOX.w, MARQUEE.BOX.y)-(w% - 1, MARQUEE.BOX.y + MARQUEE.BOX.h - 1), mask_color~&, BF
            END IF
            
            _BLEND new_mask&
            
            ' Replace selection with inverted mask
            IF MARQUEE.SELECTION_MASK < -1 THEN _FREEIMAGE MARQUEE.SELECTION_MASK
            MARQUEE.SELECTION_MASK = new_mask&
            MARQUEE.WAND_HAS_SELECTION = TRUE
            MARQUEE.WAND_EDGE_DIRTY = TRUE
            
            ' Update bounding box to full canvas (inverted selection spans entire canvas minus original box)
            MARQUEE.WAND_MIN_X = 0
            MARQUEE.WAND_MIN_Y = 0
            MARQUEE.WAND_MAX_X = w% - 1
            MARQUEE.WAND_MAX_Y = h% - 1
            MARQUEE.BOX.x = 0
            MARQUEE.BOX.y = 0
            MARQUEE.BOX.w = w%
            MARQUEE.BOX.h = h%
            MARQUEE.ACTIVE% = TRUE
            MARQUEE.INITIALIZED% = TRUE
            MARQUEE.USER_CREATED = TRUE
        END IF
    END IF
    
    _SOURCE old_source&
    _DEST old_dest&
    GUI_NEEDS_REDRAW% = TRUE
END SUB


' ============================================================================
' SELECTION EXPAND / CONTRACT (MORPHOLOGICAL DILATION / EROSION)
' ============================================================================

''
' Expand (dilate) the current selection by n pixels using an 8-connected kernel.
' Rect-only selections stay as rects; pixel-mask selections are dilated per-pixel.
'
' @param n INTEGER Number of pixels to expand
'
SUB SELECTION_expand (n AS INTEGER)
    DIM w AS INTEGER, h AS INTEGER
    DIM px AS INTEGER, py AS INTEGER
    DIM nx AS INTEGER, ny AS INTEGER, dx AS INTEGER, dy AS INTEGER
    DIM old_dest AS LONG, old_source AS LONG
    DIM snap AS LONG
    DIM pass AS INTEGER
    DIM any_white AS INTEGER
    DIM mask_color AS _UNSIGNED LONG

    IF n < 1 THEN EXIT SUB
    IF NOT SELECTION_has_active% THEN EXIT SUB

    w% = SCRN.canvasW&
    h% = SCRN.canvasH&
    mask_color~& = _RGB32(255, 255, 255)

    old_dest& = _DEST
    old_source& = _SOURCE

    IF MARQUEE.WAND_HAS_SELECTION AND MARQUEE.SELECTION_MASK < -1 THEN
        ' ----- Pixel-mask path: n passes of 8-connected dilation -----
        DIM minX AS INTEGER, minY AS INTEGER, maxX AS INTEGER, maxY AS INTEGER
        minX% = w%: minY% = h%: maxX% = 0: maxY% = 0

        FOR pass% = 1 TO n%
            snap& = _COPYIMAGE(MARQUEE.SELECTION_MASK, 32)
            IF snap& < -1 THEN
                _DEST MARQUEE.SELECTION_MASK
                _DONTBLEND MARQUEE.SELECTION_MASK
                FOR py% = 0 TO h% - 1
                    FOR px% = 0 TO w% - 1
                        _SOURCE snap&
                        IF _ALPHA32(POINT(px%, py%)) > 0 THEN
                            ' Already selected — leave white
                        ELSE
                            ' Check all 8 neighbours in snapshot
                            any_white% = FALSE
                            FOR dy% = -1 TO 1
                                FOR dx% = -1 TO 1
                                    IF dx% = 0 AND dy% = 0 THEN _CONTINUE
                                    nx% = px% + dx%
                                    ny% = py% + dy%
                                    IF nx% >= 0 AND nx% < w% AND ny% >= 0 AND ny% < h% THEN
                                        IF _ALPHA32(POINT(nx%, ny%)) > 0 THEN
                                            any_white% = TRUE
                                            dx% = 2  ' break inner
                                            dy% = 2  ' break outer
                                        END IF
                                    END IF
                                NEXT dx%
                            NEXT dy%
                            IF any_white% THEN
                                _DEST MARQUEE.SELECTION_MASK
                                PSET (px%, py%), mask_color~&
                            END IF
                        END IF
                    NEXT px%
                NEXT py%
                _BLEND MARQUEE.SELECTION_MASK
                _FREEIMAGE snap&
            END IF
        NEXT pass%

        ' Recalculate bounding box
        _SOURCE MARQUEE.SELECTION_MASK
        FOR py% = 0 TO h% - 1
            FOR px% = 0 TO w% - 1
                IF _ALPHA32(POINT(px%, py%)) > 0 THEN
                    IF px% < minX% THEN minX% = px%
                    IF px% > maxX% THEN maxX% = px%
                    IF py% < minY% THEN minY% = py%
                    IF py% > maxY% THEN maxY% = py%
                END IF
            NEXT px%
        NEXT py%

        MARQUEE.WAND_MIN_X = minX%
        MARQUEE.WAND_MIN_Y = minY%
        MARQUEE.WAND_MAX_X = maxX%
        MARQUEE.WAND_MAX_Y = maxY%
        MARQUEE.BOX.x = minX%
        MARQUEE.BOX.y = minY%
        MARQUEE.BOX.w = maxX% - minX% + 1
        MARQUEE.BOX.h = maxY% - minY% + 1
        MARQUEE.WAND_EDGE_DIRTY = TRUE

    ELSEIF MARQUEE.ACTIVE% AND MARQUEE.USER_CREATED THEN
        ' ----- Rect-only path: grow all four sides symmetrically -----
        MARQUEE.BOX.x = MARQUEE.BOX.x - n%
        MARQUEE.BOX.y = MARQUEE.BOX.y - n%
        MARQUEE.BOX.w = MARQUEE.BOX.w + n% * 2
        MARQUEE.BOX.h = MARQUEE.BOX.h + n% * 2
        ' Clamp to canvas
        IF MARQUEE.BOX.x < 0 THEN
            MARQUEE.BOX.w = MARQUEE.BOX.w + MARQUEE.BOX.x
            MARQUEE.BOX.x = 0
        END IF
        IF MARQUEE.BOX.y < 0 THEN
            MARQUEE.BOX.h = MARQUEE.BOX.h + MARQUEE.BOX.y
            MARQUEE.BOX.y = 0
        END IF
        IF MARQUEE.BOX.x + MARQUEE.BOX.w > w% THEN
            MARQUEE.BOX.w = w% - MARQUEE.BOX.x
        END IF
        IF MARQUEE.BOX.y + MARQUEE.BOX.h > h% THEN
            MARQUEE.BOX.h = h% - MARQUEE.BOX.y
        END IF
    END IF

    _SOURCE old_source&
    _DEST old_dest&
    GUI_NEEDS_REDRAW% = TRUE
END SUB


''
' Contract (erode) the current selection by n pixels using an 8-connected kernel.
' Rect-only selections stay as rects; pixel-mask selections are eroded per-pixel.
' If the result would be empty the selection is cleared.
'
' @param n INTEGER Number of pixels to contract
'
SUB SELECTION_contract (n AS INTEGER)
    DIM w AS INTEGER, h AS INTEGER
    DIM px AS INTEGER, py AS INTEGER
    DIM nx AS INTEGER, ny AS INTEGER, dx AS INTEGER, dy AS INTEGER
    DIM old_dest AS LONG, old_source AS LONG
    DIM snap AS LONG
    DIM pass AS INTEGER
    DIM any_empty AS INTEGER
    DIM minX AS INTEGER, minY AS INTEGER, maxX AS INTEGER, maxY AS INTEGER

    IF n < 1 THEN EXIT SUB
    IF NOT SELECTION_has_active% THEN EXIT SUB

    w% = SCRN.canvasW&
    h% = SCRN.canvasH&

    old_dest& = _DEST
    old_source& = _SOURCE

    IF MARQUEE.WAND_HAS_SELECTION AND MARQUEE.SELECTION_MASK < -1 THEN
        ' ----- Pixel-mask path: n passes of 8-connected erosion -----
        FOR pass% = 1 TO n%
            snap& = _COPYIMAGE(MARQUEE.SELECTION_MASK, 32)
            IF snap& < -1 THEN
                _DEST MARQUEE.SELECTION_MASK
                _DONTBLEND MARQUEE.SELECTION_MASK
                FOR py% = 0 TO h% - 1
                    FOR px% = 0 TO w% - 1
                        _SOURCE snap&
                        IF _ALPHA32(POINT(px%, py%)) > 0 THEN
                            ' Currently selected — remove if any neighbour is empty
                            any_empty% = FALSE
                            FOR dy% = -1 TO 1
                                FOR dx% = -1 TO 1
                                    IF dx% = 0 AND dy% = 0 THEN _CONTINUE
                                    nx% = px% + dx%
                                    ny% = py% + dy%
                                    IF nx% < 0 OR nx% >= w% OR ny% < 0 OR ny% >= h% THEN
                                        ' Edge of canvas counts as empty
                                        any_empty% = TRUE
                                        dx% = 2
                                        dy% = 2
                                    ELSEIF _ALPHA32(POINT(nx%, ny%)) = 0 THEN
                                        any_empty% = TRUE
                                        dx% = 2
                                        dy% = 2
                                    END IF
                                NEXT dx%
                            NEXT dy%
                            IF any_empty% THEN
                                _DEST MARQUEE.SELECTION_MASK
                                PSET (px%, py%), _RGBA32(0, 0, 0, 0)
                            END IF
                        END IF
                    NEXT px%
                NEXT py%
                _BLEND MARQUEE.SELECTION_MASK
                _FREEIMAGE snap&
            END IF
        NEXT pass%

        ' Recalculate bounding box — check for empty mask
        minX% = w%: minY% = h%: maxX% = -1: maxY% = -1
        _SOURCE MARQUEE.SELECTION_MASK
        FOR py% = 0 TO h% - 1
            FOR px% = 0 TO w% - 1
                IF _ALPHA32(POINT(px%, py%)) > 0 THEN
                    IF px% < minX% THEN minX% = px%
                    IF px% > maxX% THEN maxX% = px%
                    IF py% < minY% THEN minY% = py%
                    IF py% > maxY% THEN maxY% = py%
                END IF
            NEXT px%
        NEXT py%

        IF maxX% < 0 THEN
            ' Mask is fully eroded — clear selection
            _SOURCE old_source&
            _DEST old_dest&
            MARQUEE_clear
            MAGIC_WAND_reset
            GUI_NEEDS_REDRAW% = TRUE
            EXIT SUB
        ELSE
            MARQUEE.WAND_MIN_X = minX%
            MARQUEE.WAND_MIN_Y = minY%
            MARQUEE.WAND_MAX_X = maxX%
            MARQUEE.WAND_MAX_Y = maxY%
            MARQUEE.BOX.x = minX%
            MARQUEE.BOX.y = minY%
            MARQUEE.BOX.w = maxX% - minX% + 1
            MARQUEE.BOX.h = maxY% - minY% + 1
            MARQUEE.WAND_EDGE_DIRTY = TRUE
        END IF

    ELSEIF MARQUEE.ACTIVE% AND MARQUEE.USER_CREATED THEN
        ' ----- Rect-only path: shrink all four sides symmetrically -----
        MARQUEE.BOX.x = MARQUEE.BOX.x + n%
        MARQUEE.BOX.y = MARQUEE.BOX.y + n%
        MARQUEE.BOX.w = MARQUEE.BOX.w - n% * 2
        MARQUEE.BOX.h = MARQUEE.BOX.h - n% * 2
        ' If rect collapsed to nothing, clear selection
        IF MARQUEE.BOX.w <= 0 OR MARQUEE.BOX.h <= 0 THEN
            _SOURCE old_source&
            _DEST old_dest&
            MARQUEE_clear
            MAGIC_WAND_reset
            GUI_NEEDS_REDRAW% = TRUE
            EXIT SUB
        END IF
    END IF

    _SOURCE old_source&
    _DEST old_dest&
    GUI_NEEDS_REDRAW% = TRUE
END SUB


' ============================================================================
' SELECTION MASK MERGE HELPER
' ============================================================================

''
' Merge a newly-generated selection mask with the existing MARQUEE.SELECTION_MASK.
' For SEL_MODE_ADD, pixels selected in either mask are selected in result.
' For SEL_MODE_SUBTRACT, pixels in old mask but NOT in new mask are selected.
' For SEL_MODE_REPLACE, new_mask replaces existing mask entirely.
' After merge, updates bounding box and sets WAND_HAS_SELECTION.
' The new_mask image is consumed (freed) by this function.
'
' @param new_mask LONG The newly-generated mask image handle
' @param mode INTEGER Selection mode (SEL_MODE_REPLACE/ADD/SUBTRACT)
'
SUB SELECTION_merge_mask (new_mask AS LONG, mode AS INTEGER)
    DIM w AS INTEGER, h AS INTEGER
    DIM px AS INTEGER, py AS INTEGER
    DIM old_pixel AS _UNSIGNED LONG, new_pixel AS _UNSIGNED LONG
    DIM mask_color AS _UNSIGNED LONG
    DIM old_dest AS LONG, old_source AS LONG
    DIM final_mask AS LONG
    DIM minX AS INTEGER, minY AS INTEGER, maxX AS INTEGER, maxY AS INTEGER

    IF new_mask >= -1 THEN EXIT SUB

    old_dest& = _DEST
    old_source& = _SOURCE
    mask_color~& = _RGB32(255, 255, 255)
    w% = _WIDTH(new_mask&)
    h% = _HEIGHT(new_mask&)

    IF mode% = SEL_MODE_REPLACE THEN
        ' Simple replace: free old mask, use new one directly
        IF MARQUEE.SELECTION_MASK < -1 THEN _FREEIMAGE MARQUEE.SELECTION_MASK
        MARQUEE.SELECTION_MASK = new_mask&
    ELSEIF (MARQUEE.SELECTION_MASK < -1 AND MARQUEE.WAND_HAS_SELECTION) _
        OR (MARQUEE.ACTIVE% AND NOT MARQUEE.WAND_HAS_SELECTION) THEN
        ' Merge with existing selection (mask-based OR box-based)
        ' If we have a box selection without a mask, convert it to a mask first
        IF (MARQUEE.SELECTION_MASK >= -1 OR NOT MARQUEE.WAND_HAS_SELECTION) AND MARQUEE.ACTIVE% THEN
            DIM box_mask AS LONG
            box_mask& = _NEWIMAGE(w%, h%, 32)
            IF box_mask& < -1 THEN
                _DEST box_mask&
                CLS , _RGBA32(0, 0, 0, 0)
                _DONTBLEND box_mask&
                LINE (MARQUEE.BOX.x, MARQUEE.BOX.y)-(MARQUEE.BOX.x + MARQUEE.BOX.w - 1, MARQUEE.BOX.y + MARQUEE.BOX.h - 1), mask_color~&, BF
                _BLEND box_mask&
                IF MARQUEE.SELECTION_MASK < -1 THEN _FREEIMAGE MARQUEE.SELECTION_MASK
                MARQUEE.SELECTION_MASK = box_mask&
                MARQUEE.WAND_HAS_SELECTION = TRUE
                MARQUEE.WAND_EDGE_DIRTY = TRUE
            END IF
        END IF
        ' Now merge with existing mask
        final_mask& = _NEWIMAGE(w%, h%, 32)
        IF final_mask& < -1 THEN
            _DEST final_mask&
            CLS , _RGBA32(0, 0, 0, 0)
            _DONTBLEND final_mask&

            FOR py% = 0 TO h% - 1
                FOR px% = 0 TO w% - 1
                    _SOURCE MARQUEE.SELECTION_MASK
                    old_pixel~& = POINT(px%, py%)
                    _SOURCE new_mask&
                    new_pixel~& = POINT(px%, py%)

                    _DEST final_mask&
                    IF mode% = SEL_MODE_ADD THEN
                        IF _ALPHA32(old_pixel~&) > 0 OR _ALPHA32(new_pixel~&) > 0 THEN
                            PSET (px%, py%), mask_color~&
                        END IF
                    ELSEIF mode% = SEL_MODE_SUBTRACT THEN
                        IF _ALPHA32(old_pixel~&) > 0 AND _ALPHA32(new_pixel~&) = 0 THEN
                            PSET (px%, py%), mask_color~&
                        END IF
                    END IF
                NEXT px%
            NEXT py%

            _BLEND final_mask&
            _FREEIMAGE MARQUEE.SELECTION_MASK
            _FREEIMAGE new_mask&
            MARQUEE.SELECTION_MASK = final_mask&
        ELSE
            ' Failed to create final mask, keep new one
            _FREEIMAGE MARQUEE.SELECTION_MASK
            MARQUEE.SELECTION_MASK = new_mask&
        END IF
    ELSE
        ' No existing selection at all — for add, just use new_mask directly
        ' For subtract with no existing selection, nothing to subtract from
        IF mode% = SEL_MODE_SUBTRACT THEN
            _FREEIMAGE new_mask&
            _SOURCE old_source&
            _DEST old_dest&
            EXIT SUB
        END IF
        IF MARQUEE.SELECTION_MASK < -1 THEN _FREEIMAGE MARQUEE.SELECTION_MASK
        MARQUEE.SELECTION_MASK = new_mask&
    END IF

    ' Recalculate bounding box from mask
    minX% = w%: minY% = h%: maxX% = 0: maxY% = 0
    IF MARQUEE.SELECTION_MASK < -1 THEN
        _SOURCE MARQUEE.SELECTION_MASK
        FOR py% = 0 TO h% - 1
            FOR px% = 0 TO w% - 1
                IF _ALPHA32(POINT(px%, py%)) > 0 THEN
                    IF px% < minX% THEN minX% = px%
                    IF px% > maxX% THEN maxX% = px%
                    IF py% < minY% THEN minY% = py%
                    IF py% > maxY% THEN maxY% = py%
                END IF
            NEXT px%
        NEXT py%
    END IF

    IF minX% > maxX% THEN
        ' Empty selection after merge
        MARQUEE_clear
        MAGIC_WAND_reset
    ELSE
        MARQUEE.WAND_MIN_X = minX%
        MARQUEE.WAND_MIN_Y = minY%
        MARQUEE.WAND_MAX_X = maxX%
        MARQUEE.WAND_MAX_Y = maxY%
        MARQUEE.BOX.x = minX%
        MARQUEE.BOX.y = minY%
        MARQUEE.BOX.w = maxX% - minX% + 1
        MARQUEE.BOX.h = maxY% - minY% + 1
        MARQUEE.ACTIVE% = TRUE
        MARQUEE.INITIALIZED% = TRUE
        MARQUEE.USER_CREATED = TRUE
        MARQUEE.WAND_HAS_SELECTION = TRUE
        MARQUEE.WAND_EDGE_DIRTY = TRUE
    END IF

    _SOURCE old_source&
    _DEST old_dest&
END SUB


' ============================================================================
' FREEHAND SELECTION FUNCTIONS
' ============================================================================

''
' Reset freehand selection state
'
SUB FREEHAND_SEL_reset ()
    MARQUEE.FREE_DRAWING = FALSE
    MARQUEE.FREE_POINT_COUNT = 0
END SUB


''
' Start a freehand selection path at the given position
' @param x INTEGER Starting X coordinate (canvas space)
' @param y INTEGER Starting Y coordinate (canvas space)
'
SUB FREEHAND_SEL_start (x AS INTEGER, y AS INTEGER)
    MARQUEE.FREE_DRAWING = TRUE
    MARQUEE.FREE_POINT_COUNT = 1
    SEL_POINTS_X(0) = x%
    SEL_POINTS_Y(0) = y%
END SUB


''
' Append a point to the freehand path (skips duplicates)
' @param x INTEGER Current X coordinate (canvas space)
' @param y INTEGER Current Y coordinate (canvas space)
'
SUB FREEHAND_SEL_update (x AS INTEGER, y AS INTEGER)
    IF NOT MARQUEE.FREE_DRAWING THEN EXIT SUB
    IF MARQUEE.FREE_POINT_COUNT >= SEL_MAX_POINTS THEN EXIT SUB

    ' Skip duplicate points
    DIM lastIdx AS INTEGER
    lastIdx% = MARQUEE.FREE_POINT_COUNT - 1
    IF lastIdx% >= 0 THEN
        IF SEL_POINTS_X(lastIdx%) = x% AND SEL_POINTS_Y(lastIdx%) = y% THEN EXIT SUB
    END IF

    SEL_POINTS_X(MARQUEE.FREE_POINT_COUNT) = x%
    SEL_POINTS_Y(MARQUEE.FREE_POINT_COUNT) = y%
    MARQUEE.FREE_POINT_COUNT = MARQUEE.FREE_POINT_COUNT + 1
END SUB


''
' Finish the freehand selection path and generate a selection mask.
' The path is auto-closed (last point connects back to first point).
' @param mode INTEGER Selection mode (SEL_MODE_REPLACE/ADD/SUBTRACT)
'
SUB FREEHAND_SEL_finish (mode AS INTEGER)
    DIM w AS INTEGER, h AS INTEGER
    DIM new_mask AS LONG
    DIM old_dest AS LONG
    DIM mask_color AS _UNSIGNED LONG

    IF NOT MARQUEE.FREE_DRAWING THEN EXIT SUB

    ' Need at least 3 points to form a closed shape
    IF MARQUEE.FREE_POINT_COUNT < 3 THEN
        FREEHAND_SEL_reset
        EXIT SUB
    END IF

    w% = SCRN.canvasW&
    h% = SCRN.canvasH&
    mask_color~& = _RGB32(255, 255, 255)

    ' Create new mask image
    new_mask& = _NEWIMAGE(w%, h%, 32)
    IF new_mask& >= -1 THEN
        FREEHAND_SEL_reset
        EXIT SUB
    END IF

    old_dest& = _DEST
    _DEST new_mask&
    CLS , _RGBA32(0, 0, 0, 0)
    _DONTBLEND new_mask&

    ' Temporarily disable selection so POLY_FILL_scanline doesn't clip to existing selection
    DIM saved_active AS INTEGER, saved_wand AS INTEGER
    saved_active% = MARQUEE.ACTIVE%
    saved_wand% = MARQUEE.WAND_HAS_SELECTION
    MARQUEE.ACTIVE% = FALSE
    MARQUEE.WAND_HAS_SELECTION = FALSE

    POLY_FILL_scanline SEL_POINTS_X(), SEL_POINTS_Y(), MARQUEE.FREE_POINT_COUNT, mask_color~&, new_mask&

    ' Restore selection state before merge
    MARQUEE.ACTIVE% = saved_active%
    MARQUEE.WAND_HAS_SELECTION = saved_wand%

    _BLEND new_mask&
    _DEST old_dest&

    ' Merge with existing selection
    SELECTION_merge_mask new_mask&, mode%

    FREEHAND_SEL_reset
    GUI_NEEDS_REDRAW% = TRUE
END SUB


''
' Draw the freehand path preview while the user is drawing.
' Renders connected lines on SCRN.CANVAS& in zoomed screen coordinates.
'
SUB FREEHAND_SEL_draw_preview ()
    IF NOT MARQUEE.FREE_DRAWING THEN EXIT SUB
    IF MARQUEE.FREE_POINT_COUNT < 1 THEN EXIT SUB

    DIM old_dest AS LONG
    DIM i AS INTEGER
    DIM sx1 AS INTEGER, sy1 AS INTEGER, sx2 AS INTEGER, sy2 AS INTEGER
    DIM zw AS LONG, zh AS LONG, dx AS INTEGER, dy AS INTEGER
    DIM antOffset AS INTEGER
    DIM dotSize AS INTEGER, gapSize AS INTEGER

    old_dest& = _DEST
    _DEST SCRN.CANVAS&

    ' Calculate zoom transformation
    zw& = SCRN.canvasW& * SCRN.zoom!
    zh& = SCRN.canvasH& * SCRN.zoom!
    dx% = (SCRN.w& - zw&) \ 2 + SCRN.offsetX% + SCRN.panelShiftX%
    dy% = (SCRN.h& - zh&) \ 2 + SCRN.offsetY%

    ' Animate marching ants
    dotSize% = 2: gapSize% = 2
    antOffset% = INT(TIMER * 8) MOD (dotSize% + gapSize%)

    ' Draw the path segments
    FOR i% = 0 TO MARQUEE.FREE_POINT_COUNT - 2
        sx1% = dx% + INT(SEL_POINTS_X(i%) * SCRN.zoom!)
        sy1% = dy% + INT(SEL_POINTS_Y(i%) * SCRN.zoom!)
        sx2% = dx% + INT(SEL_POINTS_X(i% + 1) * SCRN.zoom!)
        sy2% = dy% + INT(SEL_POINTS_Y(i% + 1) * SCRN.zoom!)
        LINE (sx1%, sy1%)-(sx2%, sy2%), _RGB32(255, 255, 255)
    NEXT i%

    ' Draw closing line from last point back to first (dashed)
    IF MARQUEE.FREE_POINT_COUNT >= 2 THEN
        sx1% = dx% + INT(SEL_POINTS_X(MARQUEE.FREE_POINT_COUNT - 1) * SCRN.zoom!)
        sy1% = dy% + INT(SEL_POINTS_Y(MARQUEE.FREE_POINT_COUNT - 1) * SCRN.zoom!)
        sx2% = dx% + INT(SEL_POINTS_X(0) * SCRN.zoom!)
        sy2% = dy% + INT(SEL_POINTS_Y(0) * SCRN.zoom!)
        LINE (sx1%, sy1%)-(sx2%, sy2%), _RGBA32(255, 255, 255, 128)
    END IF

    ' Draw line from last point to current mouse position
    sx1% = dx% + INT(SEL_POINTS_X(MARQUEE.FREE_POINT_COUNT - 1) * SCRN.zoom!)
    sy1% = dy% + INT(SEL_POINTS_Y(MARQUEE.FREE_POINT_COUNT - 1) * SCRN.zoom!)
    sx2% = dx% + INT(MOUSE.UNSNAPPED_X% * SCRN.zoom!)
    sy2% = dy% + INT(MOUSE.UNSNAPPED_Y% * SCRN.zoom!)
    LINE (sx1%, sy1%)-(sx2%, sy2%), _RGBA32(255, 255, 0, 200)

    _DEST old_dest&
END SUB


' ============================================================================
' POLYGON SELECTION FUNCTIONS
' ============================================================================

''
' Reset polygon selection state
'
SUB POLY_SEL_reset ()
    MARQUEE.POLY_DRAWING = FALSE
    MARQUEE.POLY_POINT_COUNT = 0
    MARQUEE.POLY_CLOSED = FALSE
END SUB


''
' Add a vertex to the polygon selection.
' On first click, starts a new polygon. On subsequent clicks, appends vertices.
' @param x INTEGER Vertex X coordinate (canvas space)
' @param y INTEGER Vertex Y coordinate (canvas space)
'
SUB POLY_SEL_add_point (x AS INTEGER, y AS INTEGER)
    ' If polygon hasn't started yet, start it
    IF NOT MARQUEE.POLY_DRAWING THEN
        MARQUEE.POLY_DRAWING = TRUE
        MARQUEE.POLY_POINT_COUNT = 1
        MARQUEE.POLY_CLOSED = FALSE
        SEL_POINTS_X(0) = x%
        SEL_POINTS_Y(0) = y%
        EXIT SUB
    END IF

    IF MARQUEE.POLY_POINT_COUNT >= SEL_MAX_POINTS THEN EXIT SUB

    ' Check for proximity to first point (auto-close if within 3 pixels)
    IF MARQUEE.POLY_POINT_COUNT >= 3 THEN
        DIM distX AS INTEGER, distY AS INTEGER
        distX% = ABS(x% - SEL_POINTS_X(0))
        distY% = ABS(y% - SEL_POINTS_Y(0))
        IF distX% <= 3 AND distY% <= 3 THEN
            ' Close the polygon (don't add the final point, it auto-closes)
            POLY_SEL_close MARQUEE.SELECTION_MODE
            EXIT SUB
        END IF
    END IF

    ' Add the new vertex
    SEL_POINTS_X(MARQUEE.POLY_POINT_COUNT) = x%
    SEL_POINTS_Y(MARQUEE.POLY_POINT_COUNT) = y%
    MARQUEE.POLY_POINT_COUNT = MARQUEE.POLY_POINT_COUNT + 1
END SUB


''
' Close the polygon and generate a selection mask.
' Requires at least 3 vertices to form a valid polygon.
' @param mode INTEGER Selection mode (SEL_MODE_REPLACE/ADD/SUBTRACT)
'
SUB POLY_SEL_close (mode AS INTEGER)
    DIM w AS INTEGER, h AS INTEGER
    DIM new_mask AS LONG
    DIM old_dest AS LONG
    DIM mask_color AS _UNSIGNED LONG

    IF NOT MARQUEE.POLY_DRAWING THEN EXIT SUB

    ' Need at least 3 vertices for a polygon
    IF MARQUEE.POLY_POINT_COUNT < 3 THEN
        POLY_SEL_reset
        EXIT SUB
    END IF

    w% = SCRN.canvasW&
    h% = SCRN.canvasH&
    mask_color~& = _RGB32(255, 255, 255)

    ' Create new mask image
    new_mask& = _NEWIMAGE(w%, h%, 32)
    IF new_mask& >= -1 THEN
        POLY_SEL_reset
        EXIT SUB
    END IF

    old_dest& = _DEST
    _DEST new_mask&
    CLS , _RGBA32(0, 0, 0, 0)
    _DONTBLEND new_mask&

    ' Temporarily disable selection so POLY_FILL_scanline doesn't clip to existing selection
    DIM saved_active2 AS INTEGER, saved_wand2 AS INTEGER
    saved_active2% = MARQUEE.ACTIVE%
    saved_wand2% = MARQUEE.WAND_HAS_SELECTION
    MARQUEE.ACTIVE% = FALSE
    MARQUEE.WAND_HAS_SELECTION = FALSE

    POLY_FILL_scanline SEL_POINTS_X(), SEL_POINTS_Y(), MARQUEE.POLY_POINT_COUNT, mask_color~&, new_mask&

    ' Restore selection state before merge
    MARQUEE.ACTIVE% = saved_active2%
    MARQUEE.WAND_HAS_SELECTION = saved_wand2%

    _BLEND new_mask&
    _DEST old_dest&

    ' Merge with existing selection
    SELECTION_merge_mask new_mask&, mode%

    POLY_SEL_reset
    GUI_NEEDS_REDRAW% = TRUE
END SUB


''
' Draw the polygon selection preview while user is placing vertices.
' Shows placed vertices, connecting lines, rubber band line to mouse,
' and a dim closing line from mouse back to first vertex.
'
SUB POLY_SEL_draw_preview ()
    IF NOT MARQUEE.POLY_DRAWING THEN EXIT SUB
    IF MARQUEE.POLY_POINT_COUNT < 1 THEN EXIT SUB

    DIM old_dest AS LONG
    DIM i AS INTEGER
    DIM sx1 AS INTEGER, sy1 AS INTEGER, sx2 AS INTEGER, sy2 AS INTEGER
    DIM zw AS LONG, zh AS LONG, dx AS INTEGER, dy AS INTEGER

    old_dest& = _DEST
    _DEST SCRN.CANVAS&

    ' Calculate zoom transformation
    zw& = SCRN.canvasW& * SCRN.zoom!
    zh& = SCRN.canvasH& * SCRN.zoom!
    dx% = (SCRN.w& - zw&) \ 2 + SCRN.offsetX% + SCRN.panelShiftX%
    dy% = (SCRN.h& - zh&) \ 2 + SCRN.offsetY%

    ' Determine current mouse position (with grid snap and optional angle snap)
    DIM polyPrvX AS INTEGER, polyPrvY AS INTEGER
    IF MODIFIERS.ctrlShift% THEN
        ' Ctrl+Shift: use unsnapped coords with angle snap
        polyPrvX% = MOUSE.UNSNAPPED_X%
        polyPrvY% = MOUSE.UNSNAPPED_Y%
        IF MARQUEE.POLY_POINT_COUNT >= 1 THEN
            SNAP_to_angle SEL_POINTS_X(MARQUEE.POLY_POINT_COUNT - 1), SEL_POINTS_Y(MARQUEE.POLY_POINT_COUNT - 1), polyPrvX%, polyPrvY%, CFG.ANGLE_SNAP_DEGREES%
        END IF
    ELSE
        ' Normal: use grid-snapped coords
        polyPrvX% = MOUSE.X%
        polyPrvY% = MOUSE.Y%
    END IF

    ' Draw path segments between placed vertices (white solid)
    FOR i% = 0 TO MARQUEE.POLY_POINT_COUNT - 2
        sx1% = dx% + INT(SEL_POINTS_X(i%) * SCRN.zoom!)
        sy1% = dy% + INT(SEL_POINTS_Y(i%) * SCRN.zoom!)
        sx2% = dx% + INT(SEL_POINTS_X(i% + 1) * SCRN.zoom!)
        sy2% = dy% + INT(SEL_POINTS_Y(i% + 1) * SCRN.zoom!)
        LINE (sx1%, sy1%)-(sx2%, sy2%), _RGB32(255, 255, 255)
    NEXT i%

    ' Draw rubber band line from last vertex to mouse position (yellow)
    sx1% = dx% + INT(SEL_POINTS_X(MARQUEE.POLY_POINT_COUNT - 1) * SCRN.zoom!)
    sy1% = dy% + INT(SEL_POINTS_Y(MARQUEE.POLY_POINT_COUNT - 1) * SCRN.zoom!)
    sx2% = dx% + INT(polyPrvX% * SCRN.zoom!)
    sy2% = dy% + INT(polyPrvY% * SCRN.zoom!)
    LINE (sx1%, sy1%)-(sx2%, sy2%), _RGBA32(255, 255, 0, 200)

    ' Draw closing line from mouse to first vertex (dim white)
    IF MARQUEE.POLY_POINT_COUNT >= 2 THEN
        sx1% = dx% + INT(polyPrvX% * SCRN.zoom!)
        sy1% = dy% + INT(polyPrvY% * SCRN.zoom!)
        sx2% = dx% + INT(SEL_POINTS_X(0) * SCRN.zoom!)
        sy2% = dy% + INT(SEL_POINTS_Y(0) * SCRN.zoom!)
        LINE (sx1%, sy1%)-(sx2%, sy2%), _RGBA32(255, 255, 255, 80)
    END IF

    ' Draw vertex dots
    DIM vx AS INTEGER, vy AS INTEGER
    DIM dotR AS INTEGER
    dotR% = INT(SCRN.zoom!)
    IF dotR% < 1 THEN dotR% = 1
    FOR i% = 0 TO MARQUEE.POLY_POINT_COUNT - 1
        vx% = dx% + INT(SEL_POINTS_X(i%) * SCRN.zoom!)
        vy% = dy% + INT(SEL_POINTS_Y(i%) * SCRN.zoom!)
        LINE (vx% - dotR%, vy% - dotR%)-(vx% + dotR%, vy% + dotR%), _RGB32(255, 255, 255), BF
        LINE (vx% - dotR%, vy% - dotR%)-(vx% + dotR%, vy% + dotR%), _RGB32(0, 0, 0), B
    NEXT i%

    ' Highlight first vertex if close enough to close
    IF MARQUEE.POLY_POINT_COUNT >= 3 THEN
        DIM closeDistX AS INTEGER, closeDistY AS INTEGER
        closeDistX% = ABS(polyPrvX% - SEL_POINTS_X(0))
        closeDistY% = ABS(polyPrvY% - SEL_POINTS_Y(0))
        IF closeDistX% <= 3 AND closeDistY% <= 3 THEN
            vx% = dx% + INT(SEL_POINTS_X(0) * SCRN.zoom!)
            vy% = dy% + INT(SEL_POINTS_Y(0) * SCRN.zoom!)
            DIM hlR AS INTEGER
            hlR% = dotR% + 1
            LINE (vx% - hlR%, vy% - hlR%)-(vx% + hlR%, vy% + hlR%), _RGB32(0, 255, 255), B
        END IF
    END IF

    _DEST old_dest&
END SUB


' ============================================================================
' ELLIPSE SELECTION FUNCTIONS
' ============================================================================

''
' Reset ellipse selection state
'
SUB ELLIPSE_SEL_reset ()
    MARQUEE.ELLIP_DRAGGING = FALSE
    MARQUEE.ELLIP_START_X = 0
    MARQUEE.ELLIP_START_Y = 0
    MARQUEE.ELLIP_END_X = 0
    MARQUEE.ELLIP_END_Y = 0
END SUB


''
' Start an ellipse selection drag
' @param x INTEGER Starting X coordinate (canvas space)
' @param y INTEGER Starting Y coordinate (canvas space)
'
SUB ELLIPSE_SEL_start (x AS INTEGER, y AS INTEGER)
    MARQUEE.ELLIP_DRAGGING = TRUE
    MARQUEE.ELLIP_START_X = x%
    MARQUEE.ELLIP_START_Y = y%
    MARQUEE.ELLIP_END_X = x%
    MARQUEE.ELLIP_END_Y = y%
END SUB


''
' Update the ellipse selection drag end point
' @param x INTEGER Current X coordinate (canvas space)
' @param y INTEGER Current Y coordinate (canvas space)
'
SUB ELLIPSE_SEL_update (x AS INTEGER, y AS INTEGER)
    IF NOT MARQUEE.ELLIP_DRAGGING THEN EXIT SUB
    MARQUEE.ELLIP_END_X = x%
    MARQUEE.ELLIP_END_Y = y%
END SUB


''
' Finish the ellipse selection drag and generate a selection mask.
' The ellipse is inscribed in the drag rectangle (same as rect marquee bounds).
' @param mode INTEGER Selection mode (SEL_MODE_REPLACE/ADD/SUBTRACT)
'
SUB ELLIPSE_SEL_finish (mode AS INTEGER)
    DIM w AS INTEGER, h AS INTEGER
    DIM new_mask AS LONG
    DIM old_dest AS LONG
    DIM mask_color AS _UNSIGNED LONG
    DIM bx AS INTEGER, by AS INTEGER, bw AS INTEGER, bh AS INTEGER
    DIM cx AS SINGLE, cy AS SINGLE, rx AS SINGLE, ry AS SINGLE
    DIM py AS INTEGER, dx2 AS SINGLE, dy2 AS SINGLE
    DIM x_left AS INTEGER, x_right AS INTEGER

    IF NOT MARQUEE.ELLIP_DRAGGING THEN EXIT SUB

    ' Calculate bounding box from drag
    IF MARQUEE.ELLIP_START_X < MARQUEE.ELLIP_END_X THEN
        bx% = MARQUEE.ELLIP_START_X
    ELSE
        bx% = MARQUEE.ELLIP_END_X
    END IF
    IF MARQUEE.ELLIP_START_Y < MARQUEE.ELLIP_END_Y THEN
        by% = MARQUEE.ELLIP_START_Y
    ELSE
        by% = MARQUEE.ELLIP_END_Y
    END IF
    bw% = ABS(MARQUEE.ELLIP_END_X - MARQUEE.ELLIP_START_X)
    bh% = ABS(MARQUEE.ELLIP_END_Y - MARQUEE.ELLIP_START_Y)

    ' Need minimum size
    IF bw% < 2 OR bh% < 2 THEN
        ELLIPSE_SEL_reset
        EXIT SUB
    END IF

    w% = SCRN.canvasW&
    h% = SCRN.canvasH&
    mask_color~& = _RGB32(255, 255, 255)

    ' Create new mask image
    new_mask& = _NEWIMAGE(w%, h%, 32)
    IF new_mask& >= -1 THEN
        ELLIPSE_SEL_reset
        EXIT SUB
    END IF

    old_dest& = _DEST
    _DEST new_mask&
    CLS , _RGBA32(0, 0, 0, 0)
    _DONTBLEND new_mask&

    ' Calculate ellipse center and radii from bounding box
    cx! = bx% + bw% / 2.0
    cy! = by% + bh% / 2.0
    rx! = bw% / 2.0
    ry! = bh% / 2.0

    ' Fill ellipse using scanline algorithm: (x-cx)^2/rx^2 + (y-cy)^2/ry^2 <= 1
    DIM y_start AS INTEGER, y_end AS INTEGER
    y_start% = by%
    y_end% = by% + bh% - 1

    FOR py% = y_start% TO y_end%
        dy2! = (py% - cy!) / ry!
        IF ABS(dy2!) <= 1.0001 THEN
            dx2! = rx! * SQR(1 - dy2! * dy2!)
            x_left% = INT(cx! - dx2! + 0.5)
            x_right% = INT(cx! + dx2! + 0.5)
            IF x_left% < 0 THEN x_left% = 0
            IF x_right% >= w% THEN x_right% = w% - 1
            IF x_left% <= x_right% THEN
                LINE (x_left%, py%)-(x_right%, py%), mask_color~&
            END IF
        END IF
    NEXT py%

    _BLEND new_mask&
    _DEST old_dest&

    ' Merge with existing selection
    SELECTION_merge_mask new_mask&, mode%

    ELLIPSE_SEL_reset
    GUI_NEEDS_REDRAW% = TRUE
END SUB


''
' Draw the ellipse selection preview while the user is dragging.
' Renders an ellipse outline on SCRN.CANVAS& in zoomed screen coordinates.
'
SUB ELLIPSE_SEL_draw_preview ()
    IF NOT MARQUEE.ELLIP_DRAGGING THEN EXIT SUB

    DIM old_dest AS LONG
    DIM zw AS LONG, zh AS LONG, dx AS INTEGER, dy AS INTEGER
    DIM bx AS INTEGER, by AS INTEGER, bw AS INTEGER, bh AS INTEGER
    DIM cx AS SINGLE, cy AS SINGLE, rx AS SINGLE, ry AS SINGLE
    DIM angle AS SINGLE
    DIM prevX AS INTEGER, prevY AS INTEGER, curX AS INTEGER, curY AS INTEGER
    DIM antOffset AS INTEGER
    DIM dotSize AS INTEGER, gapSize AS INTEGER

    old_dest& = _DEST
    _DEST SCRN.CANVAS&

    ' Calculate zoom transformation
    zw& = SCRN.canvasW& * SCRN.zoom!
    zh& = SCRN.canvasH& * SCRN.zoom!
    dx% = (SCRN.w& - zw&) \ 2 + SCRN.offsetX% + SCRN.panelShiftX%
    dy% = (SCRN.h& - zh&) \ 2 + SCRN.offsetY%

    ' Calculate bounding box from drag
    IF MARQUEE.ELLIP_START_X < MARQUEE.ELLIP_END_X THEN
        bx% = MARQUEE.ELLIP_START_X
    ELSE
        bx% = MARQUEE.ELLIP_END_X
    END IF
    IF MARQUEE.ELLIP_START_Y < MARQUEE.ELLIP_END_Y THEN
        by% = MARQUEE.ELLIP_START_Y
    ELSE
        by% = MARQUEE.ELLIP_END_Y
    END IF
    bw% = ABS(MARQUEE.ELLIP_END_X - MARQUEE.ELLIP_START_X)
    bh% = ABS(MARQUEE.ELLIP_END_Y - MARQUEE.ELLIP_START_Y)

    IF bw% < 1 OR bh% < 1 THEN
        _DEST old_dest&
        EXIT SUB
    END IF

    ' Calculate ellipse center and radii in screen coordinates
    cx! = dx% + (bx% + bw% / 2.0) * SCRN.zoom!
    cy! = dy% + (by% + bh% / 2.0) * SCRN.zoom!
    rx! = (bw% / 2.0) * SCRN.zoom!
    ry! = (bh% / 2.0) * SCRN.zoom!

    ' Animate marching ants
    dotSize% = 2: gapSize% = 2
    antOffset% = INT(TIMER * 8) MOD (dotSize% + gapSize%)

    ' Draw ellipse outline using parametric equation
    DIM numSegments AS INTEGER
    numSegments% = INT(2 * 3.14159 * ((rx! + ry!) / 2)) + 16
    IF numSegments% < 32 THEN numSegments% = 32
    IF numSegments% > 360 THEN numSegments% = 360

    DIM step_angle AS SINGLE
    step_angle! = 6.28318 / numSegments%

    prevX% = INT(cx! + rx!)
    prevY% = INT(cy!)

    DIM segIdx AS INTEGER
    FOR segIdx% = 1 TO numSegments%
        angle! = segIdx% * step_angle!
        curX% = INT(cx! + rx! * COS(angle!))
        curY% = INT(cy! + ry! * SIN(angle!))

        ' Alternate white/black for marching ants effect
        DIM pattern2 AS INTEGER
        pattern2% = ((segIdx% + antOffset%) MOD (dotSize% + gapSize%))
        IF pattern2% < dotSize% THEN
            LINE (prevX%, prevY%)-(curX%, curY%), _RGB32(255, 255, 255)
        ELSE
            LINE (prevX%, prevY%)-(curX%, curY%), _RGB32(0, 0, 0)
        END IF

        prevX% = curX%
        prevY% = curY%
    NEXT segIdx%

    _DEST old_dest&
END SUB