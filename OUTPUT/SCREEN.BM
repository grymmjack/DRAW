''
' DRAW - OUTPUT/SCREEN.BM
' =============================================================================
' Screen output files subs and functions.
'
' @todo
' @depends ./SCREEN.BI
' @author Rick Christy <grymmjack@gmail.com>
'
$INCLUDEONCE

''
' Mark GUI as needing redraw
' Call this when: tool switches, palette changes, window resizes, toolbar/status toggles
'
SUB GUI_mark_dirty ()
    GUI_NEEDS_REDRAW% = TRUE
END SUB


''
' Returns TRUE when the canvas is small enough for Pattern Tile Mode (<=512 in both dims).
' @return INTEGER - TRUE if canvas width and height are both <= 512
'
FUNCTION SCREEN_pattern_tile_allowed% ()
    SCREEN_pattern_tile_allowed% = (SCRN.canvasW& <= 512 AND SCRN.canvasH& <= 512)
END FUNCTION


''
' Force Pattern Tile Mode OFF if the canvas exceeds 512 in either dimension.
' Call after any resize, load, or new-document operation.
'
SUB SCREEN_pattern_tile_force_off ()
    IF SCRN.patternTileMode% AND NOT SCREEN_pattern_tile_allowed% THEN
        SCRN.patternTileMode% = FALSE
        INVALIDATE_scene
    END IF
END SUB


''
' Get effective maximum viewport width, accounting for desktop and display scale.
' When WIN_MAX_WIDTH is 0 (unlimited), derives max from desktop / displayScale.
' @return LONG - Maximum viewport width in pixels
'
FUNCTION SCREEN_effective_max_w& ()
    DIM effMax AS LONG
    IF CFG.WIN_MAX_WIDTH% > 0 THEN
        effMax& = CFG.WIN_MAX_WIDTH%
    ELSE
        ' Auto-derive from desktop: viewport * displayScale must fit on screen
        ' Leave 100px margin for taskbar/dock
        IF SCRN.displayScale% > 0 THEN
            effMax& = (_DESKTOPWIDTH - 100) \ SCRN.displayScale%
        ELSE
            effMax& = _DESKTOPWIDTH - 100
        END IF
    END IF
    SCREEN_effective_max_w& = effMax&
END FUNCTION


''
' Get effective maximum viewport height, accounting for desktop and display scale.
' When WIN_MAX_HEIGHT is 0 (unlimited), derives max from desktop / displayScale.
' @return LONG - Maximum viewport height in pixels
'
FUNCTION SCREEN_effective_max_h& ()
    DIM effMax AS LONG
    IF CFG.WIN_MAX_HEIGHT% > 0 THEN
        effMax& = CFG.WIN_MAX_HEIGHT%
    ELSE
        ' Auto-derive from desktop: viewport * displayScale must fit on screen
        ' Leave 100px margin for taskbar/dock
        IF SCRN.displayScale% > 0 THEN
            effMax& = (_DESKTOPHEIGHT - 100) \ SCRN.displayScale%
        ELSE
            effMax& = _DESKTOPHEIGHT - 100
        END IF
    END IF
    SCREEN_effective_max_h& = effMax&
END FUNCTION

''
' Detects the resolution of the desktop and sets the width and height to It
' 
SUB SCREEN_detect_desktop_resolution()
    ' Query desktop resolution without forcing SCREEN 0 creation.
    ' _DESKTOPWIDTH/_DESKTOPHEIGHT query the OS display directly.
    ' Retry briefly if SDL2 hasn't initialized the display subsystem yet.
    DIM ddr_retries AS INTEGER
    ddr_retries% = 0
    DO
        SCRN.w& = _DESKTOPWIDTH
        SCRN.h& = _DESKTOPHEIGHT
        IF SCRN.w& > 0 AND SCRN.h& > 0 THEN EXIT DO
        _DELAY 0.01
        ddr_retries% = ddr_retries% + 1
    LOOP UNTIL ddr_retries% >= 100 ' Max 1 second
    ' Fallback if detection failed
    IF SCRN.w& <= 0 THEN SCRN.w& = 640
    IF SCRN.h& <= 0 THEN SCRN.h& = 400
END SUB


''
' Returns recommended DISPLAY_SCALE and TOOLBAR_SCALE for known desktop
' resolutions.  outScale% = 0 means "no preset, use algorithm".
' Tolerances: width ±10px, height ±10px.
' @param desktopW LONG Desktop width in pixels
' @param desktopH LONG Desktop height in pixels
' @param outScale INTEGER Output: recommended display scale (0 = no preset match)
' @param outTB INTEGER Output: recommended toolbar scale (0 = no preset match)
'
SUB SCREEN_get_resolution_preset (desktopW AS LONG, desktopH AS LONG, outScale AS INTEGER, outTB AS INTEGER)
    outScale% = 0
    outTB%    = 0
    SELECT CASE desktopW&
        CASE 3830 TO 3850 ' 3840x2160 (4K)
            IF desktopH& >= 2150 AND desktopH& <= 2170 THEN outScale% = 4: outTB% = 2
        CASE 2550 TO 2570 ' 2560x1440 (QHD)
            IF desktopH& >= 1430 AND desktopH& <= 1450 THEN outScale% = 4: outTB% = 2
        CASE 1910 TO 1930 ' 1920x1080 (FHD)
            IF desktopH& >= 1070 AND desktopH& <= 1090 THEN outScale% = 3: outTB% = 2
        CASE 1590 TO 1610 ' 1600x900
            IF desktopH& >= 890  AND desktopH& <= 910  THEN outScale% = 3: outTB% = 1
        CASE 1526 TO 1546 ' 1536x864
            IF desktopH& >= 854  AND desktopH& <= 874  THEN outScale% = 2: outTB% = 2
        CASE 1430 TO 1450 ' 1440x900
            IF desktopH& >= 890  AND desktopH& <= 910  THEN outScale% = 2: outTB% = 2
        CASE 1356 TO 1376 ' 1366x768 and 1360x768
            IF desktopH& >= 758  AND desktopH& <= 778  THEN outScale% = 2: outTB% = 2
        CASE 1270 TO 1290 ' 1280x720 (HD)
            IF desktopH& >= 710  AND desktopH& <= 730  THEN outScale% = 2: outTB% = 2
        CASE 1014 TO 1034 ' 1024x768
            IF desktopH& >= 758  AND desktopH& <= 778  THEN outScale% = 2: outTB% = 1
    END SELECT
END SUB


''
' Estimates the highest TOOLBAR_SCALE that fits in the given viewport,
' using PROPORTIONAL thresholds relative to the unscaled 12px menu bar.
'
' The menu bar is always 12px (8px font + 4px padding).
' TB=2 (22px buttons) gives a 1.8:1 ratio vs menu — good.
' TB=3 (33px) gives 2.75:1 — only acceptable with very large viewports
'   where the menu text looks tiny and bigger buttons help.
' TB=4 (44px) gives 3.67:1 — only for huge viewports (scale=1 or 2 on 4K).
'
' These thresholds are intentionally high: TB=2 is the typical auto-detect
' result. TB=3/4 require viewports so large that the 12px menu bar itself
' appears proportionally small.
' @param vpW LONG Viewport width in pixels
' @param vpH LONG Viewport height in pixels
' @return INTEGER - Recommended toolbar scale (1-4)
'
FUNCTION SCREEN_estimate_toolbar_scale% (vpW AS LONG, vpH AS LONG)
    ' TB=4 only when viewport is enormous (e.g., 4K at 1x or 2x scale)
    IF vpW& >= 1200 AND vpH& >= 900 THEN
        SCREEN_estimate_toolbar_scale% = 4
    ' TB=3 for large viewports (e.g., 1440p+ at 2x)
    ELSEIF vpW& >= 900 AND vpH& >= 700 THEN
        SCREEN_estimate_toolbar_scale% = 3
    ' TB=2 is the standard for most auto-detect scenarios
    ELSEIF vpW& >= 440 AND vpH& >= 300 THEN
        SCREEN_estimate_toolbar_scale% = 2
    ELSE
        SCREEN_estimate_toolbar_scale% = 1
    END IF
END FUNCTION


''
' Calculates the minimum viewport width for a given toolbar scale.
' Chrome accounted for:
'   Toolbar:      4×(11×TB) + 3×(1×TB) + 2   (TB_COLS=4, TB_BTN_W=11, TB_BTN_PADDING=1)
'   Layers panel: 100 px   (default CFG.LAYER_PANEL_WIDTH)
'   Edit bar:      20 px   (18 base + 1+1 borders)
'   Min canvas:   320 px   (minimum usable canvas + menu bar width)
' @param tbScale INTEGER Toolbar scale factor (1-4)
' @return LONG - Minimum viewport width in pixels
'
FUNCTION SCREEN_chrome_min_w& (tbScale AS INTEGER)
    DIM toolboxW AS LONG
    toolboxW&            = 4 * (11 * tbScale%) + 3 * (1 * tbScale%) + 2
    SCREEN_chrome_min_w& = toolboxW& + 100 + 20 + 320
END FUNCTION


''
' Calculates the minimum viewport height for a given toolbar scale.
' Returns the binding constraint: MAX of toolbar-column needs vs canvas-column needs.
'
' Toolbar column (all scaled by tbScale):
'   Toolbar buttons:  7 rows x 11px + 6 gaps x 1px = 83
'   Organizer:        3 rows x 10px + 2 gaps x 1px = 32
'   Drawer bins:     10 rows x  7px + 9 gaps x 1px = 79
'   Drawer padding:   2 x 1px                       =  2
'   Subtotal scaled: (83 + 32 + 79 + 2) = 196 x tbScale
' Non-scaled chrome:
'   Org-to-drawer gap: 1px
'   Status bar:       11px
'   Palette strip:    12px
'   Subtotal fixed:   24px
'
' Canvas column:  12 (menu) + 200 (canvas) + 11 (status) + 12 (palette) = 235
' @param tbScale INTEGER Toolbar scale factor (1-4)
' @return LONG - Minimum viewport height in pixels
'
FUNCTION SCREEN_chrome_min_h& (tbScale AS INTEGER)
    DIM tbColH AS LONG, canvasColH AS LONG
    tbColH&     = (196 * tbScale%) + 24 ' toolbar+org+drawer (scaled) + bottom chrome (fixed)
    canvasColH& = 235                   ' menu + min canvas + bottom chrome
    IF tbColH& > canvasColH& THEN
        SCREEN_chrome_min_h& = tbColH&
    ELSE
        SCREEN_chrome_min_h& = canvasColH&
    END IF
END FUNCTION


''
' Detects optimal display scale based on desktop resolution.
' Chrome-aware: accounts for toolbar, organizer, drawer, layers panel,
' edit bar, menu bar, status bar, and palette strip when choosing scale.
' Checks resolution presets first, then falls back to algorithm.
' Auto-detect caps at 4x; users can set higher manually via DISPLAY_SCALE.
' Also sets SCREEN_preset_toolbar_scale% when a preset matches.
' @return INTEGER - Recommended display scale (1-4)
'
FUNCTION SCREEN_detect_display_scale% ()
    DIM desktopW AS LONG, desktopH AS LONG
    DIM targetW  AS LONG, targetH AS LONG
    DIM scale    AS INTEGER
    DIM vpW      AS LONG, vpH AS LONG
    
    ' Reset preset hint
    SCREEN_preset_toolbar_scale% = 0
    
    ' Query desktop resolution
    DIM dds_retries AS INTEGER
    dds_retries% = 0
    DO
        desktopW& = _DESKTOPWIDTH
        desktopH& = _DESKTOPHEIGHT
        IF desktopW& > 0 AND desktopH& > 0 THEN EXIT DO
        _DELAY 0.01
        dds_retries% = dds_retries% + 1
    LOOP UNTIL dds_retries% >= 100 ' Max 1 second
    IF desktopW& <= 0 THEN desktopW& = 1280
    IF desktopH& <= 0 THEN desktopH& = 720
    
    ' --- Check resolution presets first ---
    DIM presetScale AS INTEGER, presetTB AS INTEGER
    SCREEN_get_resolution_preset desktopW&, desktopH&, presetScale%, presetTB%
    IF presetScale% > 0 THEN
        ' Clamp to configured max
        IF presetScale% > CFG.DISPLAY_SCALE_MAX% THEN presetScale% = CFG.DISPLAY_SCALE_MAX%
        SCREEN_preset_toolbar_scale% = presetTB%
        _LOGINFO "SCREEN_detect: preset match for " + _TRIM$(STR$(desktopW&)) + "x" + _TRIM$(STR$(desktopH&)) + " -> scale=" + _TRIM$(STR$(presetScale%)) + "x TB=" + _TRIM$(STR$(presetTB%))
        SCREEN_detect_display_scale% = presetScale%
        EXIT FUNCTION
    END IF
    
    ' --- Chrome-aware algorithm for unlisted resolutions ---
    ' Target window size = 90% of desktop
    targetW& = (desktopW& * 9) \ 10
    targetH& = (desktopH& * 9) \ 10
    
    ' Auto-detect caps at 4x (manual override can go to DISPLAY_SCALE_MAX 8)
    DIM autoMax AS INTEGER
    autoMax% = 4
    IF CFG.DISPLAY_SCALE_MAX% < autoMax% THEN autoMax% = CFG.DISPLAY_SCALE_MAX%
    
    ' Find highest scale where ALL chrome + min canvas fits in viewport
    DIM estTB AS INTEGER
    DIM minW  AS LONG, minH AS LONG
    scale% = autoMax%
    DO WHILE scale% > 1
        vpW& = targetW& \ scale%
        vpH& = targetH& \ scale%
        
        ' Estimate toolbar scale for this viewport
        estTB% = SCREEN_estimate_toolbar_scale%(vpW&, vpH&)
        
        ' Calculate chrome-aware minimums
        minW& = SCREEN_chrome_min_w&(estTB%)
        minH& = SCREEN_chrome_min_h&(estTB%)
        
        IF vpW& >= minW& AND vpH& >= minH& THEN
            _LOGINFO "SCREEN_detect: algorithm picked " + _TRIM$(STR$(scale%)) + "x for " + _TRIM$(STR$(desktopW&)) + "x" + _TRIM$(STR$(desktopH&)) + " (vp=" + _TRIM$(STR$(vpW&)) + "x" + _TRIM$(STR$(vpH&)) + " estTB=" + _TRIM$(STR$(estTB%)) + " minW=" + _TRIM$(STR$(minW&)) + " minH=" + _TRIM$(STR$(minH&)) + ")"
            SCREEN_detect_display_scale% = scale%
            EXIT FUNCTION
        END IF
        _LOGINFO "SCREEN_detect: rejecting " + _TRIM$(STR$(scale%)) + "x (vp=" + _TRIM$(STR$(vpW&)) + "x" + _TRIM$(STR$(vpH&)) + " < min " + _TRIM$(STR$(minW&)) + "x" + _TRIM$(STR$(minH&)) + ")"
        scale% = scale% - 1
    LOOP
    
    ' Minimum scale is 1
    IF scale% < 1 THEN scale% = 1
    _LOGINFO "SCREEN_detect: fallback to " + _TRIM$(STR$(scale%)) + "x for " + _TRIM$(STR$(desktopW&)) + "x" + _TRIM$(STR$(desktopH&))
    
    SCREEN_detect_display_scale% = scale%
END FUNCTION


''
' Returns the maximum display scale that fits on the current desktop.
' Used by menu system to disable Scale Up when already at max.
' @return INTEGER - Maximum display scale that fits on the desktop
'
FUNCTION SCREEN_max_display_scale% ()
    DIM maxW AS INTEGER, maxH AS INTEGER, maxS AS INTEGER
    IF SCRN.w& <= 0 OR SCRN.h& <= 0 THEN
        SCREEN_max_display_scale% = 1
        EXIT FUNCTION
    END IF
    maxW% = _DESKTOPWIDTH \ SCRN.w&
    maxH% = _DESKTOPHEIGHT \ SCRN.h&
    maxS% = maxW%
    IF maxH% < maxS% THEN maxS% = maxH%
    IF maxS% > CFG.DISPLAY_SCALE_MAX% THEN maxS% = CFG.DISPLAY_SCALE_MAX%
    IF maxS% < 1 THEN maxS% = 1
    SCREEN_max_display_scale% = maxS%
END FUNCTION


''
' Set display scale at runtime (for hotkey scaling).
' Clamps to valid range, resizes the OS window, and saves config.
' @param newScale INTEGER Desired display scale (will be clamped to 1..max)
'
SUB SCREEN_set_display_scale (newScale AS INTEGER)
    DIM winW         AS LONG, winH AS LONG
    DIM maxFitW      AS INTEGER, maxFitH AS INTEGER
    DIM clampedScale AS INTEGER
    DIM maxScale     AS INTEGER
    
    ' Don't allow scale changes in fullscreen mode
    IF CFG.FULLSCREEN% THEN EXIT SUB
    
    clampedScale% = newScale%
    
    ' Clamp to minimum of 1
    IF clampedScale% < 1 THEN clampedScale% = 1
    
    ' Clamp to configured maximum
    IF clampedScale% > CFG.DISPLAY_SCALE_MAX% THEN
        clampedScale% = CFG.DISPLAY_SCALE_MAX%
    END IF
    
    ' Clamp to fit on desktop (use full desktop — user explicitly requested scale change)
    maxFitW%  = _DESKTOPWIDTH \ SCRN.w&
    maxFitH%  = _DESKTOPHEIGHT \ SCRN.h&
    maxScale% = maxFitW%
    IF maxFitH% < maxScale% THEN maxScale% = maxFitH%
    IF maxScale% > CFG.DISPLAY_SCALE_MAX% THEN maxScale% = CFG.DISPLAY_SCALE_MAX%
    IF clampedScale% > maxScale% THEN clampedScale% = maxScale%
    
    _LOGINFO "SCREEN_set_display_scale: requested=" + _TRIM$(STR$(newScale%)) + " clamped=" + _TRIM$(STR$(clampedScale%)) + " current=" + _TRIM$(STR$(SCRN.displayScale%)) + " maxFit=" + _TRIM$(STR$(maxScale%)) + " desktop=" + _TRIM$(STR$(_DESKTOPWIDTH)) + "x" + _TRIM$(STR$(_DESKTOPHEIGHT)) + " viewport=" + _TRIM$(STR$(SCRN.w&)) + "x" + _TRIM$(STR$(SCRN.h&))
    
    ' No change needed (already at requested scale or at limit)
    IF clampedScale% = SCRN.displayScale% THEN
        IF newScale% > SCRN.displayScale% THEN
            _LOGWARN "SCREEN_set_display_scale: cannot scale up, " + _TRIM$(STR$(SCRN.displayScale%)) + "x is max for " + _TRIM$(STR$(SCRN.w&)) + "x" + _TRIM$(STR$(SCRN.h&)) + " on " + _TRIM$(STR$(_DESKTOPWIDTH)) + "x" + _TRIM$(STR$(_DESKTOPHEIGHT)) + " desktop"
        ELSEIF newScale% < SCRN.displayScale% THEN
            _LOGWARN "SCREEN_set_display_scale: cannot scale down, already at minimum (1x)"
        END IF
        EXIT SUB
    END IF
    
    ' Update display scale
    SCRN.displayScale% = clampedScale%
    
    ' Recreate window-sized screen surface at new scale; no glutReshapeWindow needed.
    winW& = SCRN.w& * SCRN.displayScale%
    winH& = SCRN.h& * SCRN.displayScale%
    _LOGINFO "SCREEN_set_display_scale: resizing window to " + _TRIM$(STR$(winW&)) + "x" + _TRIM$(STR$(winH&)) + " (scale " + _TRIM$(STR$(SCRN.displayScale%)) + "x)"
    SCREEN_DEFERRED_RESIZE% = SCREEN_DEFERRED_RESIZE% + 1
    SCREEN _NEWIMAGE(winW&, winH&, 32)
    _DEST SCRN.CANVAS&
    _SCREENMOVE _MIDDLE
    
    ' Reset input state after window resize
    MOUSE_cleanup_after_dialog FALSE ' Clear buffers but don't move mouse (no dialog, but same cleanup needed)
    _MOUSEHIDE                       ' Ensure system cursor stays hidden
    
    ' Mark GUI as needing redraw
    GUI_NEEDS_REDRAW% = TRUE
    
    ' Recalculate toolbar scale if it was auto-detected
    IF SCREEN_toolbar_scale_is_auto% THEN
        DIM setNewTB AS INTEGER
        setNewTB% = SCREEN_estimate_toolbar_scale%(SCRN.w&, SCRN.h&)
        IF setNewTB% <> CFG.TOOLBAR_SCALE% THEN
            _LOGINFO "SCREEN_set_display_scale: toolbar scale " + _TRIM$(STR$(CFG.TOOLBAR_SCALE%)) + " -> " + _TRIM$(STR$(setNewTB%)) + " for viewport " + _TRIM$(STR$(SCRN.w&)) + "x" + _TRIM$(STR$(SCRN.h&))
            CFG.TOOLBAR_SCALE% = setNewTB%
            SCREEN_compute_layout
        END IF
    END IF
    
    ' Mark config as changed
    CFG.DISPLAY_SCALE_CHANGED% = TRUE
END SUB


''
' Called when the OS resizes the window (maximize, drag, etc.).
' Keeps the display scale fixed and changes the viewport size to match the
' new window dimensions.  Recreates viewport-sized image buffers so the UI
' gains or loses canvas area.  SCENE_CACHE auto-recreates via size check.
' @param newW LONG New OS window width in pixels
' @param newH LONG New OS window height in pixels
'
SUB SCREEN_snap_window_to_scale (newW AS LONG, newH AS LONG)
    DIM newVpW    AS LONG, newVpH AS LONG
    DIM oldCanvas AS LONG, oldGUI AS LONG
    DIM winW      AS LONG, winH AS LONG

    IF SCRN.displayScale% < 1 THEN SCRN.displayScale% = 1

    ' Derive new viewport from window size / display scale
    newVpW& = newW& \ SCRN.displayScale%
    newVpH& = newH& \ SCRN.displayScale%

    ' Round down to even for clean GPU scaling
    newVpW& = (newVpW& \ 2) * 2
    newVpH& = (newVpH& \ 2) * 2

    ' Enforce absolute minimums
    IF newVpW& < 320 THEN newVpW& = 320
    IF newVpH& < 200 THEN newVpH& = 200

    ' Enforce WIN_MIN/MAX from config
    IF CFG.WIN_MIN_WIDTH% > 0 AND newVpW& < CFG.WIN_MIN_WIDTH% THEN newVpW& = CFG.WIN_MIN_WIDTH%
    IF CFG.WIN_MIN_HEIGHT% > 0 AND newVpH& < CFG.WIN_MIN_HEIGHT% THEN newVpH& = CFG.WIN_MIN_HEIGHT%
    IF CFG.WIN_MAX_WIDTH% > 0 AND newVpW& > CFG.WIN_MAX_WIDTH% THEN newVpW& = CFG.WIN_MAX_WIDTH%
    IF CFG.WIN_MAX_HEIGHT% > 0 AND newVpH& > CFG.WIN_MAX_HEIGHT% THEN newVpH& = CFG.WIN_MAX_HEIGHT%

    ' No change — skip to prevent resonance with our own SCREEN _NEWIMAGE events
    IF newVpW& = SCRN.w& AND newVpH& = SCRN.h& THEN EXIT SUB

    _LOGINFO "SCREEN_snap: viewport " + _TRIM$(STR$(SCRN.w&)) + "x" + _TRIM$(STR$(SCRN.h&)) + " -> " + _TRIM$(STR$(newVpW&)) + "x" + _TRIM$(STR$(newVpH&)) + " (window " + _TRIM$(STR$(newW&)) + "x" + _TRIM$(STR$(newH&)) + " at " + _TRIM$(STR$(SCRN.displayScale%)) + "x)"

    ' Save old handles for cleanup
    oldCanvas& = SCRN.CANVAS&
    oldGUI&    = SCRN.GUI&

    ' Update viewport dimensions
    SCRN.w& = newVpW&
    SCRN.h& = newVpH&

    ' Recreate viewport-sized image buffers
    SCRN.CANVAS& = _NEWIMAGE(SCRN.w&, SCRN.h&, 32)
    SCRN.GUI&    = _NEWIMAGE(SCRN.w&, SCRN.h&, 32)

    ' Free old buffers (after creating new ones so _DEST never points to freed handle)
    IF oldCanvas& < -1 THEN _FREEIMAGE oldCanvas&
    IF oldGUI& < -1 THEN _FREEIMAGE oldGUI&

    ' Recreate OS window at correctly scaled size (snap to integer multiple)
    winW& = SCRN.w& * SCRN.displayScale%
    winH& = SCRN.h& * SCRN.displayScale%
    SCREEN_DEFERRED_RESIZE% = SCREEN_DEFERRED_RESIZE% + 1
    SCREEN _NEWIMAGE(winW&, winH&, 32)
    _DEST SCRN.CANVAS&

    ' Full scene + GUI invalidation (SCENE_CACHE auto-resizes via size check)
    INVALIDATE_scene
END SUB


''
' Initialize the screen and various images we will use
' 
SUB SCREEN_init ()
    DIM winW AS LONG, winH AS LONG
    
    ' Load configuration from disk
    CONFIG_load

    ' Load runtime theme overrides from THEME.CFG (after CONFIG_load so CFG.THEME$ is known)
    THEME_load
    
    SCRN.w&   = 0
    SCRN.h&   = 0
    SCRN.bpp% = 0
    
    ' Determine display scale FIRST (needed for auto-detect viewport sizing)
    IF CFG.DISPLAY_SCALE% > 0 THEN
        ' Use explicit scale from config
        SCRN.displayScale% = CFG.DISPLAY_SCALE%
        ' Clamp to max
        IF SCRN.displayScale% > CFG.DISPLAY_SCALE_MAX% THEN
            SCRN.displayScale% = CFG.DISPLAY_SCALE_MAX%
        END IF
    ELSE
        ' Auto-detect optimal scale
        SCRN.displayScale% = SCREEN_detect_display_scale%
    END IF
    
    ' Ensure minimum scale of 1
    IF SCRN.displayScale% < 1 THEN SCRN.displayScale% = 1
    
    ' Get screen dimensions from config or auto-detect
    IF CFG.SCREEN_WIDTH% > 0 AND CFG.SCREEN_HEIGHT% > 0 THEN
        ' Use configured dimensions (these are viewport/internal pixels)
        SCRN.w& = CFG.SCREEN_WIDTH%
        SCRN.h& = CFG.SCREEN_HEIGHT%
    ELSE
        ' Auto-detect viewport: derive from desktop / displayScale.
        ' When scale is explicit (CFG.DISPLAY_SCALE>0), fill the desktop exactly:
        '   viewport = desktop / scale  (window = desktop, perfect fill, any aspect ratio)
        ' When scale is also auto, stay at 90% so the window has a centering margin.
        SCREEN_detect_desktop_resolution
        DIM targetW AS LONG, targetH AS LONG
        IF CFG.DISPLAY_SCALE% > 0 THEN
            ' Explicit scale: viewport fills the monitor exactly regardless of ratio
            targetW& = SCRN.w&
            targetH& = SCRN.h&
        ELSE
            ' Auto scale: leave ~10% margin around the window
            targetW& = (SCRN.w& * 9) \ 10
            targetH& = (SCRN.h& * 9) \ 10
        END IF
        SCRN.w& = targetW& \ SCRN.displayScale%
        SCRN.h& = targetH& \ SCRN.displayScale%
        ' Round down to nearest even number for clean GPU scaling
        SCRN.w& = (SCRN.w& \ 2) * 2
        SCRN.h& = (SCRN.h& \ 2) * 2
    END IF
    
    ' Enforce WIN_MIN/MAX on initial viewport
    IF CFG.WIN_MIN_WIDTH% > 0 AND SCRN.w& < CFG.WIN_MIN_WIDTH% THEN
        SCRN.w& = CFG.WIN_MIN_WIDTH%
    END IF
    IF CFG.WIN_MIN_HEIGHT% > 0 AND SCRN.h& < CFG.WIN_MIN_HEIGHT% THEN
        SCRN.h& = CFG.WIN_MIN_HEIGHT%
    END IF
    IF CFG.WIN_MAX_WIDTH% > 0 AND SCRN.w& > CFG.WIN_MAX_WIDTH% THEN
        SCRN.w& = CFG.WIN_MAX_WIDTH%
    END IF
    IF CFG.WIN_MAX_HEIGHT% > 0 AND SCRN.h& > CFG.WIN_MAX_HEIGHT% THEN
        SCRN.h& = CFG.WIN_MAX_HEIGHT%
    END IF
    
    ' Ensure window (viewport * scale) fits on desktop.
    ' DISPLAY_SCALE controls how large the content appears — it takes priority.
    ' If the viewport is too large for the requested scale, SHRINK THE VIEWPORT
    ' (not the scale). This way DISPLAY_SCALE=3 always means 3x magnification.
    ' SCREEN_WIDTH/HEIGHT become a "desired maximum" viewport, reduced as needed.
    DIM initMaxW     AS LONG, initMaxH AS LONG
    DIM initDesktopW AS LONG, initDesktopH AS LONG
    initDesktopW& = _DESKTOPWIDTH
    initDesktopH& = _DESKTOPHEIGHT
    IF CFG.DISPLAY_SCALE% > 0 THEN
        ' User explicitly set scale — use full desktop as window limit
        initMaxW& = initDesktopW&
        initMaxH& = initDesktopH&
    ELSE
        ' Auto-detect — 90% margin for comfortable centering
        initMaxW& = (initDesktopW& * 9) \ 10
        initMaxH& = (initDesktopH& * 9) \ 10
    END IF
    IF initMaxW& < 320 THEN initMaxW& = 320
    IF initMaxH& < 200 THEN initMaxH& = 200
    
    ' If window (viewport * scale) exceeds desktop, shrink viewport to fit
    ' at the requested scale, rather than reducing the scale.
    DIM maxVpW   AS LONG, maxVpH AS LONG
    maxVpW& = initMaxW& \ SCRN.displayScale%
    maxVpH& = initMaxH& \ SCRN.displayScale%
    ' Round down to even for clean GPU scaling
    maxVpW& = (maxVpW& \ 2) * 2
    maxVpH& = (maxVpH& \ 2) * 2
    DIM vpShrunk AS INTEGER
    vpShrunk% = FALSE
    IF SCRN.w& > maxVpW& THEN
        _LOGINFO "SCREEN_init: shrinking viewport width from " + _TRIM$(STR$(SCRN.w&)) + " to " + _TRIM$(STR$(maxVpW&)) + " to fit " + _TRIM$(STR$(SCRN.displayScale%)) + "x scale on " + _TRIM$(STR$(initDesktopW&)) + " wide desktop"
        SCRN.w&   = maxVpW&
        vpShrunk% = TRUE
    END IF
    IF SCRN.h& > maxVpH& THEN
        _LOGINFO "SCREEN_init: shrinking viewport height from " + _TRIM$(STR$(SCRN.h&)) + " to " + _TRIM$(STR$(maxVpH&)) + " to fit " + _TRIM$(STR$(SCRN.displayScale%)) + "x scale on " + _TRIM$(STR$(initDesktopH&)) + " tall desktop"
        SCRN.h&   = maxVpH&
        vpShrunk% = TRUE
    END IF
    
    ' Safety: if viewport went below chrome-aware minimum, reduce scale as last resort
    DIM minW     AS LONG, minH AS LONG
    DIM safetyTB AS INTEGER
    safetyTB% = SCREEN_estimate_toolbar_scale%(SCRN.w&, SCRN.h&)
    minW&     = SCREEN_chrome_min_w&(safetyTB%)
    minH&     = SCREEN_chrome_min_h&(safetyTB%)
    IF CFG.WIN_MIN_WIDTH% > 0 AND CFG.WIN_MIN_WIDTH% > minW& THEN minW& = CFG.WIN_MIN_WIDTH%
    IF CFG.WIN_MIN_HEIGHT% > 0 AND CFG.WIN_MIN_HEIGHT% > minH& THEN minH& = CFG.WIN_MIN_HEIGHT%
    DO WHILE (SCRN.w& < minW& OR SCRN.h& < minH&) AND SCRN.displayScale% > 1
        SCRN.displayScale% = SCRN.displayScale% - 1
        maxVpW& = initMaxW& \ SCRN.displayScale%
        maxVpH& = initMaxH& \ SCRN.displayScale%
        maxVpW& = (maxVpW& \ 2) * 2
        maxVpH& = (maxVpH& \ 2) * 2
        IF CFG.SCREEN_WIDTH% > 0 THEN
            SCRN.w& = CFG.SCREEN_WIDTH%
            IF SCRN.w& > maxVpW& THEN SCRN.w& = maxVpW&
        ELSE
            SCRN.w& = maxVpW&
        END IF
        IF CFG.SCREEN_HEIGHT% > 0 THEN
            SCRN.h& = CFG.SCREEN_HEIGHT%
            IF SCRN.h& > maxVpH& THEN SCRN.h& = maxVpH&
        ELSE
            SCRN.h& = maxVpH&
        END IF
        ' Recompute chrome-aware minimums for the new viewport
        safetyTB% = SCREEN_estimate_toolbar_scale%(SCRN.w&, SCRN.h&)
        minW&     = SCREEN_chrome_min_w&(safetyTB%)
        minH&     = SCREEN_chrome_min_h&(safetyTB%)
        IF CFG.WIN_MIN_WIDTH% > 0 AND CFG.WIN_MIN_WIDTH% > minW& THEN minW& = CFG.WIN_MIN_WIDTH%
        IF CFG.WIN_MIN_HEIGHT% > 0 AND CFG.WIN_MIN_HEIGHT% > minH& THEN minH& = CFG.WIN_MIN_HEIGHT%
        _LOGWARN "SCREEN_init: viewport too small at " + _TRIM$(STR$(SCRN.displayScale% + 1)) + "x, reducing scale to " + _TRIM$(STR$(SCRN.displayScale%)) + "x (viewport now " + _TRIM$(STR$(SCRN.w&)) + "x" + _TRIM$(STR$(SCRN.h&)) + ")"
    LOOP
    
    ' Re-enforce WIN_MIN after any shrinking (in case viewport was reduced)
    IF CFG.WIN_MIN_WIDTH% > 0 AND SCRN.w& < CFG.WIN_MIN_WIDTH% THEN
        SCRN.w& = CFG.WIN_MIN_WIDTH%
    END IF
    IF CFG.WIN_MIN_HEIGHT% > 0 AND SCRN.h& < CFG.WIN_MIN_HEIGHT% THEN
        SCRN.h& = CFG.WIN_MIN_HEIGHT%
    END IF
    
    ' Log diagnostics
    _LOGINFO "SCREEN_init: desktop=" + _TRIM$(STR$(initDesktopW&)) + "x" + _TRIM$(STR$(initDesktopH&)) + " viewport=" + _TRIM$(STR$(SCRN.w&)) + "x" + _TRIM$(STR$(SCRN.h&)) + " scale=" + _TRIM$(STR$(SCRN.displayScale%)) + "x window=" + _TRIM$(STR$(SCRN.w& * SCRN.displayScale%)) + "x" + _TRIM$(STR$(SCRN.h& * SCRN.displayScale%))
    IF vpShrunk% THEN
        _LOGINFO "SCREEN_init: viewport was reduced from configured " + _TRIM$(STR$(CFG.SCREEN_WIDTH%)) + "x" + _TRIM$(STR$(CFG.SCREEN_HEIGHT%)) + " to " + _TRIM$(STR$(SCRN.w&)) + "x" + _TRIM$(STR$(SCRN.h&)) + " to honor " + _TRIM$(STR$(SCRN.displayScale%)) + "x display scale"
    END IF
    
    ' Auto-detect toolbar scale from viewport size if not explicitly set
    IF CFG.TOOLBAR_SCALE% = 0 THEN
        SCREEN_toolbar_scale_is_auto% = TRUE
        ' If a resolution preset provided a recommended TB scale, use it
        IF SCREEN_preset_toolbar_scale% > 0 THEN
            CFG.TOOLBAR_SCALE% = SCREEN_preset_toolbar_scale%
            _LOGINFO "SCREEN_init: using preset toolbar scale=" + _TRIM$(STR$(CFG.TOOLBAR_SCALE%))
        ELSE
            ' Calculate highest TB scale that fits the viewport proportionally
            CFG.TOOLBAR_SCALE% = SCREEN_estimate_toolbar_scale%(SCRN.w&, SCRN.h&)
            _LOGINFO "SCREEN_init: auto-detected toolbar scale=" + _TRIM$(STR$(CFG.TOOLBAR_SCALE%)) + " for viewport " + _TRIM$(STR$(SCRN.w&)) + "x" + _TRIM$(STR$(SCRN.h&))
        END IF
    ELSE
        SCREEN_toolbar_scale_is_auto% = FALSE
    END IF

    ' Canvas dimensions: use command-line override, config default, or viewport
    IF CMDLINE_CANVAS_W% > 0 AND CMDLINE_CANVAS_H% > 0 THEN
        ' Command-line --canvas-size takes highest priority
        SCRN.canvasW& = CMDLINE_CANVAS_W%
        SCRN.canvasH& = CMDLINE_CANVAS_H%
    ELSEIF CFG.DEFAULT_CANVAS_SIZE_W% > 0 AND CFG.DEFAULT_CANVAS_SIZE_H% > 0 THEN
        ' Config default canvas size
        SCRN.canvasW& = CFG.DEFAULT_CANVAS_SIZE_W%
        SCRN.canvasH& = CFG.DEFAULT_CANVAS_SIZE_H%
    ELSE
        ' 0 = fill viewport (legacy behavior)
        SCRN.canvasW& = SCRN.w&
        SCRN.canvasH& = SCRN.h&
    END IF
    _LOGINFO "SCREEN_init: canvas=" + _TRIM$(STR$(SCRN.canvasW&)) + "x" + _TRIM$(STR$(SCRN.canvasH&)) + " viewport=" + _TRIM$(STR$(SCRN.w&)) + "x" + _TRIM$(STR$(SCRN.h&))
    
    SCRN.zoom!                          = 1.0  ' Start at 1x zoom
    SCRN.zoomMin!                       = 0.25 ' 25% minimum zoom
    SCRN.zoomMax!                       = 32.0 '32x maximum zoom
    SCRN.offsetX%                       = 0
    SCRN.offsetY%                       = 0
    SCRN.panning%                       = FALSE
    SCRN.panStartX%                     = 0
    SCRN.panStartY%                     = 0
    SCRN.panOrigOffsetX%                = 0
    SCRN.panOrigOffsetY%                = 0
    SCRN.showToolbar%                   = TRUE
    SCRN.showStatus%                    = TRUE
    SCRN.toolbarManuallyHidden%         = FALSE
    SCRN.statusManuallyHidden%          = FALSE
    SCRN.menubarManuallyHidden%         = FALSE
    SCRN.layerPanelManuallyHidden%      = FALSE
    SCRN.previewManuallyHidden%         = FALSE
    SCRN.showEditBar%                   = FALSE
    SCRN.editBarManuallyHidden%         = FALSE
    SCRN.editBarHiddenByToggleAll%      = FALSE
    SCRN.uiLeftEdge%                    = 0
    SCRN.uiRightEdge%                   = SCRN.w& - 1
    SCRN.layerPanelX%                   = 0
    SCRN.toolboxX%                      = 0
    SCRN.toolbarHiddenByToggleRight%    = FALSE
    SCRN.editBarHiddenByToggleRight%    = FALSE
    SCRN.editBarHiddenByToggleLeft%     = FALSE
    SCRN.layerPanelHiddenByToggleLeft%  = FALSE
    SCRN.layerPanelHiddenByToggleRight% = FALSE
    SCRN.menubarHiddenByToggleTop%      = FALSE
    SCRN.statusHiddenByToggleBottom%    = FALSE
    SCRN.showCanvasBorder%              = TRUE
    SCRN.canvasBorderOpacity%           = 100

    ' Create image buffers (canvas at viewport size, painting at canvas size)
    SCRN.CANVAS&   = _NEWIMAGE(SCRN.w&, SCRN.h&, 32)
    SCRN.PAINTING& = _NEWIMAGE(SCRN.canvasW&, SCRN.canvasH&, 32)
    SCRN.GUI&      = _NEWIMAGE(SCRN.w&, SCRN.h&, 32)
    ' SCRN.CURSOR& removed — cursors now draw directly onto SCRN.CANVAS&
    
    _DEST SCRN.PAINTING&
    CLS , _RGBA32(0, 0, 0, 0)
    _DEST SCRN.GUI&
    
    ' Open the OS window at the correct scaled size immediately.
    ' SCRN.CANVAS& stays as an offscreen render target (all rendering uses
    ' _DEST SCRN.CANVAS& explicitly). SCREEN_render scales it to screen 0
    ' with _PUTIMAGE before each _DISPLAY call. No glutReshapeWindow needed.
    winW& = SCRN.w& * SCRN.displayScale%
    winH& = SCRN.h& * SCRN.displayScale%
    _LOGINFO "SCREEN_init: window target=" + _TRIM$(STR$(winW&)) + "x" + _TRIM$(STR$(winH&)) + " (" + _TRIM$(STR$(SCRN.displayScale%)) + "x scale)"
    SCREEN _NEWIMAGE(winW&, winH&, 32)
    _DEST SCRN.CANVAS&
    _SCREENMOVE _MIDDLE
    
    ' Set window icon (cross-platform via SDL2)
    DIM iconHandle AS LONG
    iconHandle& = _LOADIMAGE("./ASSETS/ICONS/icon.png", 32)
    IF iconHandle& < -1 THEN
        _ICON iconHandle&
        _FREEIMAGE iconHandle&
    END IF
    
    IF CFG.FULLSCREEN% THEN _FULLSCREEN _SQUAREPIXELS
    SCRN.bpp% = _PIXELSIZE
    ' Initialize tools
    LAYERS_init                                ' Initialize layers system (must be after CONFIG_load)
    MOVE_init
    TEXT_init
    GRID_init
    PIXEL_GRID_init
    SMART_GUIDES_init
    SYMMETRY_init
    STATUS_init
    PALETTE_LOADER_init
    PALETTE_STRIP_init
    CMD_init                                   ' Initialize command palette
    MENUBAR_init                               ' Initialize menu bar (must be after CONFIG_load for theme)
    SCRN.showMenubar% = TRUE
    PREVIEW_init                               ' Initialize preview window (must be after CONFIG_load and SCREEN dimensions set)
    EDITBAR_init                               ' Initialize edit bar (must be after CONFIG_load and THEME_load)
    ADVBAR_init                                ' Initialize advanced bar (must be after CONFIG_load and THEME_load)
    CHARMAP_init                               ' Initialize character map panel (must be after CONFIG_load)
    TEXT_BAR_init                              ' Initialize text formatting bar

    ' Save config if this was a first-run (file didn't exist)
    ' Now SCRN.w/h and displayScale are resolved, so saved values will be correct
    IF CONFIG_NEEDS_INITIAL_SAVE% THEN
        CONFIG_NEEDS_INITIAL_SAVE% = FALSE
        CONFIG_save
    END IF

    ' Run deferred config upgrade (must be here — DRAW_alert needs valid screen)
    IF CMDLINE_CONFIG_UPGRADE% THEN
        CONFIG_upgrade
    END IF
END SUB


''
' Render all visible layers with zoom, compositing bottom-to-top.
' Handles blend modes, opacity caching, partial composite cache, and move preview.
'
' @param dx INTEGER X offset for zoomed canvas placement
' @param dy INTEGER Y offset for zoomed canvas placement
' @param zw LONG Zoomed canvas width
' @param zh LONG Zoomed canvas height
'
SUB RENDER_layers (dx AS INTEGER, dy AS INTEGER, zw AS LONG, zh AS LONG)
    _DEST SCRN.CANVAS&
    _BLEND SCRN.CANVAS&

    IF LAYER_COUNT% > 0 THEN
        ' Composite layers by zIndex (bottom to top)
        DIM layerI       AS INTEGER
        DIM layerFound   AS INTEGER
        DIM useComposite AS INTEGER
        DIM compositeImg AS LONG

        ' Check if we need per-pixel blending (any non-Normal blend mode)
        ' Also force composite when preview window is visible (needs native-res buffer)
        useComposite% = BLEND_needs_composite% OR PREVIEW.visible%

        ' Rebuild render order lookup table if dirty
        IF RENDER_ORDER_DIRTY% THEN RENDER_ORDER_rebuild

        ' Start index for layer loop (1 = full composite, >1 = partial cache hit)
        DIM compositeStartIdx AS INTEGER
        DIM savePartialCache  AS INTEGER
        compositeStartIdx% = 1
        savePartialCache%  = FALSE

        ' Region-based compositing: when we have a valid dirty rect and a cached
        ' composite result, restore from cache and only update the dirty region.
        DIM useRegionComposite AS INTEGER
        DIM rcX1               AS INTEGER, rcY1 AS INTEGER, rcX2 AS INTEGER, rcY2 AS INTEGER
        useRegionComposite% = FALSE

        IF useComposite% THEN
            ' Reuse persistent composite buffer (avoid _NEWIMAGE/_FREEIMAGE every frame)
            IF COMPOSITE_BUFFER& = 0 OR _
               COMPOSITE_BUFFER_W& <> SCRN.canvasW& OR _
               COMPOSITE_BUFFER_H& <> SCRN.canvasH& THEN
                IF COMPOSITE_BUFFER& < -1 THEN _FREEIMAGE COMPOSITE_BUFFER&
                COMPOSITE_BUFFER&       = _NEWIMAGE(SCRN.canvasW&, SCRN.canvasH&, 32)
                COMPOSITE_BUFFER_W&     = SCRN.canvasW&
                COMPOSITE_BUFFER_H&     = SCRN.canvasH&
                COMPOSITE_RESULT_VALID% = FALSE
            END IF
            compositeImg& = COMPOSITE_BUFFER&

            ' --- Region composite fast path ---
            ' When we have a cached composite result and a small dirty rect,
            ' restore from cache and only recomposite the dirty region.
            ' This avoids full-canvas per-pixel blend loops (the #1 CPU cost).
            IF COMP_DIRTY_VALID% AND COMPOSITE_RESULT_VALID% AND _
               NOT BLEND_HAS_ISOLATED_GROUPS% AND _
               COMPOSITE_RESULT_CACHE& <> 0 AND _
               _WIDTH(COMPOSITE_RESULT_CACHE&)  = SCRN.canvasW& AND _
               _HEIGHT(COMPOSITE_RESULT_CACHE&) = SCRN.canvasH& THEN
                ' Clamp dirty rect to canvas bounds
                rcX1% = COMP_DIRTY_X1% : rcY1% = COMP_DIRTY_Y1%
                rcX2% = COMP_DIRTY_X2% : rcY2% = COMP_DIRTY_Y2%
                IF rcX1% < 0 THEN rcX1% = 0
                IF rcY1% < 0 THEN rcY1% = 0
                IF rcX2% >= SCRN.canvasW& THEN rcX2% = SCRN.canvasW& - 1
                IF rcY2% >= SCRN.canvasH& THEN rcY2% = SCRN.canvasH& - 1
                ' Only use region path when dirty rect is < 25% of canvas (otherwise full is faster)
                DIM rcArea AS LONG, rcCanvasArea AS LONG
                rcArea&       = CLNG(rcX2% - rcX1% + 1) * CLNG(rcY2% - rcY1% + 1)
                rcCanvasArea& = CLNG(SCRN.canvasW&) * CLNG(SCRN.canvasH&)
                IF rcX2% >= rcX1% AND rcY2% >= rcY1% AND rcArea& < (rcCanvasArea& \ 4) THEN
                    useRegionComposite% = TRUE
                    ' Restore full composite from previous frame
                    DIM rcOldDest AS LONG
                    rcOldDest& = _DEST
                    _DEST compositeImg&
                    _DONTBLEND compositeImg&
                    _PUTIMAGE , COMPOSITE_RESULT_CACHE&, compositeImg&
                    ' Clear only the dirty region so we can re-composite it
                    LINE (rcX1%, rcY1%)-(rcX2%, rcY2%), _RGBA32(0, 0, 0, 0), BF
                    _BLEND compositeImg&
                    _DEST rcOldDest&
                    compositeStartIdx% = 1 ' Must process all layers for the region
                END IF
            END IF

            IF NOT useRegionComposite% THEN
                ' --- Standard composite path ---
                ' Partial composite cache: skip layers below current when only current changes
                DIM currentRenderIdx AS INTEGER
                DIM cri              AS INTEGER
                currentRenderIdx% = 0
                FOR cri% = 1 TO RENDER_ORDER_COUNT%
                    IF RENDER_ORDER%(cri%) = CURRENT_LAYER% THEN
                        currentRenderIdx% = cri%
                        EXIT FOR
                    END IF
                NEXT cri%

                DIM compOldDest AS LONG
                compOldDest& = _DEST

                IF currentRenderIdx% > 1 AND COMPOSITE_BELOW_VALID% AND _
                   NOT BLEND_HAS_ISOLATED_GROUPS% AND _
                   COMPOSITE_BELOW_LAYER% = CURRENT_LAYER% AND _
                   COMPOSITE_BELOW_CACHE& <> 0 THEN
                    ' Partial cache hit — restore composite of layers below current
                    _DEST compositeImg&
                    _DONTBLEND compositeImg&
                    _PUTIMAGE , COMPOSITE_BELOW_CACHE&, compositeImg&
                    _BLEND compositeImg&
                    _DEST compOldDest&
                    compositeStartIdx% = currentRenderIdx%
                ELSE
                    ' Full composite — clear buffer
                    _DEST compositeImg&
                    _DONTBLEND compositeImg&
                    CLS , _RGBA32(0, 0, 0, 0)
                    _BLEND compositeImg&
                    _DEST compOldDest&
                    ' Schedule partial cache save if current layer isn't the bottommost
                    IF currentRenderIdx% > 1 THEN savePartialCache% = TRUE
                END IF
            END IF
        END IF

        ' === Group compositing state — stack for nested isolated groups ===
        DIM compositeTarget AS LONG
        compositeTarget&      = compositeImg&
        GROUP_COMP_STACK_TOP% = 0

        ' Allocate/resize group composite stack buffers if isolated groups exist
        IF BLEND_HAS_ISOLATED_GROUPS% AND useComposite% THEN
            IF GROUP_COMP_STACK_W& <> SCRN.canvasW& OR _
               GROUP_COMP_STACK_H& <> SCRN.canvasH& THEN
                DIM gcAllocI AS INTEGER
                FOR gcAllocI% = 1 TO MAX_GROUP_NESTING
                    IF GROUP_COMP_STACK(gcAllocI%) < -1 THEN _FREEIMAGE GROUP_COMP_STACK(gcAllocI%)
                    GROUP_COMP_STACK(gcAllocI%) = _NEWIMAGE(SCRN.canvasW&, SCRN.canvasH&, 32)
                NEXT gcAllocI%
                GROUP_COMP_STACK_W& = SCRN.canvasW&
                GROUP_COMP_STACK_H& = SCRN.canvasH&
            END IF
        END IF

        FOR layerI% = compositeStartIdx% TO RENDER_ORDER_COUNT%
            layerFound% = RENDER_ORDER%(layerI%)

            IF layerFound% > 0 THEN
                ' === Group header layer: flush this group's buffer & skip ===
                IF LAYERS(layerFound%).layerType% = LAYER_TYPE_GROUP THEN
                    ' Check if this group header is the top of the isolation stack
                    IF GROUP_COMP_STACK_TOP% > 0 AND useComposite% THEN
                        IF GROUP_COMP_STACK_IDX(GROUP_COMP_STACK_TOP%) = layerFound% THEN
                            ' Flush this group's buffer onto the target below it
                            DIM grpFlushBuf    AS LONG
                            DIM grpFlushTarget AS LONG
                            DIM grpOpacity     AS INTEGER
                            DIM grpBlend       AS INTEGER
                            grpFlushBuf& = GROUP_COMP_STACK(GROUP_COMP_STACK_TOP%)
                            grpOpacity%  = LAYERS(layerFound%).opacity%
                            grpBlend%    = LAYERS(layerFound%).blendMode%

                            ' Determine target: parent stack level, or compositeImg if at bottom
                            IF GROUP_COMP_STACK_TOP% > 1 THEN
                                grpFlushTarget& = GROUP_COMP_STACK(GROUP_COMP_STACK_TOP% - 1)
                            ELSE
                                grpFlushTarget& = compositeImg&
                            END IF

                            IF grpBlend% = BLEND_NORMAL AND grpOpacity% = 255 THEN
                                DIM gfOD    AS LONG: gfOD& = _DEST
                                _DEST grpFlushTarget&
                                _PUTIMAGE , grpFlushBuf&, grpFlushTarget&
                                _DEST gfOD&
                            ELSEIF grpBlend% = BLEND_NORMAL THEN
                                DIM gcMem   AS _MEM
                                DIM gcOff   AS _OFFSET
                                DIM gcPix   AS _UNSIGNED LONG
                                DIM gcAlpha AS _UNSIGNED _BYTE
                                DIM gcNewA  AS INTEGER
                                gcMem = _MEMIMAGE(grpFlushBuf&)
                                FOR gcOff = gcMem.OFFSET TO gcMem.OFFSET + gcMem.SIZE - 4 STEP 4
                                    _MEMGET gcMem, gcOff, gcPix~&
                                    gcAlpha~%% = _ALPHA32(gcPix~&)
                                    IF gcAlpha~%% > 0 THEN
                                        gcNewA% = (gcAlpha~%% * grpOpacity%) \ 255
                                        _MEMPUT gcMem, gcOff + 3, gcNewA% AS _UNSIGNED _BYTE
                                    END IF
                                NEXT gcOff
                                _MEMFREE gcMem
                                gfOD& = _DEST
                                _DEST grpFlushTarget&
                                _PUTIMAGE , grpFlushBuf&, grpFlushTarget&
                                _DEST gfOD&
                            ELSE
                                LAYER_blend_composite grpFlushTarget&, grpFlushBuf&, grpBlend%, grpOpacity%
                            END IF

                            ' Pop stack
                            GROUP_COMP_STACK_IDX(GROUP_COMP_STACK_TOP%) = 0
                            GROUP_COMP_STACK_TOP% = GROUP_COMP_STACK_TOP% - 1

                            ' Update composite target
                            IF GROUP_COMP_STACK_TOP% > 0 THEN
                                compositeTarget& = GROUP_COMP_STACK(GROUP_COMP_STACK_TOP%)
                            ELSE
                                compositeTarget& = compositeImg&
                            END IF
                        END IF
                    END IF
                    ' Skip rendering the 1x1 sentinel image
                    _CONTINUE
                END IF

                ' === Group child detection: push isolated group onto stack ===
                IF useComposite% AND BLEND_HAS_ISOLATED_GROUPS% THEN
                    DIM parentGrp            AS INTEGER
                    parentGrp% = LAYERS(layerFound%).parentGroupIdx%
                    DIM isIsolatedGroupChild AS INTEGER
                    isIsolatedGroupChild% = FALSE
                    IF parentGrp% > 0 THEN
                        IF parentGrp% <= MAX_LAYERS THEN
                            IF LAYERS(parentGrp%).imgHandle& <> 0 THEN
                                IF LAYERS(parentGrp%).layerType% = LAYER_TYPE_GROUP THEN
                                    IF NOT LAYERS(parentGrp%).passThrough% THEN
                                        IF LAYERS(parentGrp%).visible% THEN
                                            isIsolatedGroupChild% = TRUE
                                        END IF
                                    END IF
                                END IF
                            END IF
                        END IF
                    END IF
                    IF isIsolatedGroupChild% THEN
                        ' Push new group onto stack if not already the active one
                        DIM needPush AS INTEGER
                        needPush% = TRUE
                        IF GROUP_COMP_STACK_TOP% > 0 THEN
                            IF GROUP_COMP_STACK_IDX(GROUP_COMP_STACK_TOP%) = parentGrp% THEN
                                needPush% = FALSE ' Already compositing into this group
                            END IF
                        END IF
                        IF needPush% AND GROUP_COMP_STACK_TOP% < MAX_GROUP_NESTING THEN
                            GROUP_COMP_STACK_TOP% = GROUP_COMP_STACK_TOP% + 1
                            GROUP_COMP_STACK_IDX(GROUP_COMP_STACK_TOP%) = parentGrp%
                            ' Clear buffer
                            DIM gcInitOD     AS LONG: gcInitOD& = _DEST
                            _DEST GROUP_COMP_STACK(GROUP_COMP_STACK_TOP%)
                            _DONTBLEND GROUP_COMP_STACK(GROUP_COMP_STACK_TOP%)
                            CLS , _RGBA32(0, 0, 0, 0)
                            _BLEND GROUP_COMP_STACK(GROUP_COMP_STACK_TOP%)
                            _DEST gcInitOD&
                        END IF
                        IF GROUP_COMP_STACK_TOP% > 0 THEN
                            compositeTarget& = GROUP_COMP_STACK(GROUP_COMP_STACK_TOP%)
                        END IF
                    ELSE
                        ' Not in an isolated group — use parent stack level or compositeImg
                        IF GROUP_COMP_STACK_TOP% > 0 THEN
                            ' Check if our parent is one of the stacked groups
                            DIM foundInStack AS INTEGER
                            DIM stackScan    AS INTEGER
                            foundInStack% = FALSE
                            FOR stackScan% = GROUP_COMP_STACK_TOP% TO 1 STEP -1
                                IF GROUP_COMP_STACK_IDX(stackScan%) = parentGrp% THEN
                                    compositeTarget& = GROUP_COMP_STACK(stackScan%)
                                    foundInStack%    = TRUE
                                    EXIT FOR
                                END IF
                            NEXT stackScan%
                            IF NOT foundInStack% THEN compositeTarget& = compositeImg&
                        ELSE
                            compositeTarget& = compositeImg&
                        END IF
                    END IF
                ELSE
                    compositeTarget& = compositeImg&
                END IF

                ' Skip children of invisible groups (Photoshop-like: walk up parent chain)
                DIM skipParGrp AS INTEGER
                DIM skipLayer  AS INTEGER
                skipLayer%  = FALSE
                skipParGrp% = LAYERS(layerFound%).parentGroupIdx%
                DO WHILE skipParGrp% > 0
                    IF skipParGrp% <= MAX_LAYERS THEN
                        IF LAYERS(skipParGrp%).imgHandle& <> 0 THEN
                            IF NOT LAYERS(skipParGrp%).visible% THEN
                                skipLayer% = TRUE
                                EXIT DO
                            END IF
                        END IF
                        skipParGrp% = LAYERS(skipParGrp%).parentGroupIdx%
                    ELSE
                        EXIT DO
                    END IF
                LOOP
                IF skipLayer% THEN _CONTINUE

                IF LAYERS(layerFound%).visible% THEN
                ' Render dirty text layers into their imgHandle before compositing
                IF LAYERS(layerFound%).layerType% = LAYER_TYPE_TEXT THEN
                    DIM tlDIdx AS INTEGER
                    tlDIdx% = LAYERS(layerFound%).textDataIdx%
                    IF tlDIdx% >= 1 AND TEXT_LAYER_DATA(tlDIdx%).dirty THEN
                        TEXT_LAYER_render tlDIdx%, LAYERS(layerFound%).imgHandle&
                        ' Only clear dirty if NOT the actively-editing text layer
                        ' TEXT_render_preview also needs the dirty flag to refresh its preview cache
                        IF NOT (TEXT.ACTIVE AND TEXT.editingTextLayer% = layerFound%) THEN
                            TEXT_LAYER_DATA(tlDIdx%).dirty = FALSE
                        END IF
                    END IF
                END IF
                ' Determine which image to render for this layer
                ' If MOVE tool is active on this layer, use the preview buffer instead
                DIM layerRenderSource AS LONG
                DIM useMoveBuf        AS INTEGER
                useMoveBuf% = FALSE
                DIM moveTargetLayer   AS INTEGER
                moveTargetLayer% = MOVE.CAPTURED_LAYER
                IF moveTargetLayer% < 1 THEN moveTargetLayer% = CURRENT_LAYER%
                IF CURRENT_TOOL% = TOOL_MOVE AND MOVE.ACTIVE AND layerFound% = moveTargetLayer% THEN
                    layerRenderSource& = MOVE_get_preview_buffer&
                    IF layerRenderSource& = 0 THEN
                        layerRenderSource& = LAYERS(layerFound%).imgHandle&
                    ELSE
                        useMoveBuf% = TRUE
                    END IF
                ELSEIF CURRENT_TOOL% = TOOL_MOVE AND MOVE.ACTIVE THEN
                    ' Check if this layer is one of the multi-selected layers being dragged
                    DIM mlPreview AS LONG
                    mlPreview& = MOVE_get_multi_layer_preview&(layerFound%)
                    IF mlPreview& <> 0 THEN
                        layerRenderSource& = mlPreview&
                        useMoveBuf%        = TRUE
                    ELSE
                        layerRenderSource& = LAYERS(layerFound%).imgHandle&
                    END IF
                ELSE
                    layerRenderSource& = LAYERS(layerFound%).imgHandle&
                END IF

                ' Get opacity-adjusted image (cached when possible)
                DIM opacityImg    AS LONG
                DIM layerOpacityI AS INTEGER
                layerOpacityI% = LAYERS(layerFound%).opacity%
                IF layerOpacityI% < 255 AND NOT useMoveBuf% THEN
                    ' Check if opacity cache is valid
                    IF LAYERS(layerFound%).opacityCacheImg& <> 0 AND _
                       LAYERS(layerFound%).opacityCacheVal% = layerOpacityI% AND _
                       NOT LAYERS(layerFound%).contentDirty% THEN
                        ' Cache hit — use cached opacity image
                        opacityImg& = LAYERS(layerFound%).opacityCacheImg&
                    ELSE
                        ' Cache miss — rebuild opacity image
                        IF LAYERS(layerFound%).opacityCacheImg& = 0 THEN
                            LAYERS(layerFound%).opacityCacheImg& = _NEWIMAGE(SCRN.canvasW&, SCRN.canvasH&, 32)
                        END IF
                        ' Copy source to cache and apply opacity
                        _DEST LAYERS(layerFound%).opacityCacheImg&
                        _DONTBLEND LAYERS(layerFound%).opacityCacheImg&
                        _PUTIMAGE , layerRenderSource&, LAYERS(layerFound%).opacityCacheImg&
                        _BLEND LAYERS(layerFound%).opacityCacheImg&
                        DIM layerMem  AS _MEM
                        layerMem = _MEMIMAGE(LAYERS(layerFound%).opacityCacheImg&)
                        DIM pixOffset AS _OFFSET
                        DIM pixVal    AS _UNSIGNED LONG
                        DIM pixAlpha  AS _UNSIGNED _BYTE
                        DIM newAlpha  AS INTEGER
                        FOR pixOffset = layerMem.OFFSET TO layerMem.OFFSET + layerMem.SIZE - 4 STEP 4
                            _MEMGET layerMem, pixOffset, pixVal~&
                            pixAlpha~%% = _ALPHA32(pixVal~&)
                            IF pixAlpha~%% > 0 THEN
                                newAlpha% = (pixAlpha~%% * layerOpacityI%) \ 255
                                _MEMPUT layerMem, pixOffset + 3, newAlpha% AS _UNSIGNED _BYTE
                            END IF
                        NEXT pixOffset
                        _MEMFREE layerMem
                        _DEST SCRN.CANVAS&
                        LAYERS(layerFound%).opacityCacheVal% = layerOpacityI%
                        LAYERS(layerFound%).contentDirty%    = FALSE
                        opacityImg&                          = LAYERS(layerFound%).opacityCacheImg&
                    END IF
                ELSEIF layerOpacityI% < 255 AND useMoveBuf% THEN
                    ' Move preview — can't cache, build temp copy
                    opacityImg& = _COPYIMAGE(layerRenderSource&, 32)
                    layerMem    = _MEMIMAGE(opacityImg&)
                    FOR pixOffset = layerMem.OFFSET TO layerMem.OFFSET + layerMem.SIZE - 4 STEP 4
                        _MEMGET layerMem, pixOffset, pixVal~&
                        pixAlpha~%% = _ALPHA32(pixVal~&)
                        IF pixAlpha~%% > 0 THEN
                            newAlpha% = (pixAlpha~%% * layerOpacityI%) \ 255
                            _MEMPUT layerMem, pixOffset + 3, newAlpha% AS _UNSIGNED _BYTE
                        END IF
                    NEXT pixOffset
                    _MEMFREE layerMem
                ELSE
                    opacityImg& = 0 ' No opacity adjustment needed
                END IF

                ' Render the layer (using opacityImg if available, else layerRenderSource)
                DIM renderImg AS LONG
                IF opacityImg& <> 0 THEN
                    renderImg& = opacityImg&
                ELSE
                    renderImg& = layerRenderSource&
                END IF

                IF useComposite% THEN
                    IF useRegionComposite% AND compositeTarget& = compositeImg& THEN
                        ' --- Region composite path: only update dirty rect ---
                        ' (Region path only applies to main composite, not group buffers)
                        IF LAYERS(layerFound%).blendMode% = BLEND_NORMAL THEN
                            ' Blit only the dirty region from this layer
                            _DEST compositeTarget&
                            _PUTIMAGE (rcX1%, rcY1%)-(rcX2%, rcY2%), renderImg&, compositeTarget&, (rcX1%, rcY1%)-(rcX2%, rcY2%)
                            _DEST SCRN.CANVAS&
                        ELSE
                            ' Region-based blend: only process dirty rect pixels
                            LAYER_blend_composite_region compositeTarget&, layerRenderSource&, LAYERS(layerFound%).blendMode%, LAYERS(layerFound%).opacity%, rcX1%, rcY1%, rcX2%, rcY2%
                        END IF
                    ELSE
                        ' --- Full composite buffer path (blend modes) ---
                        IF LAYERS(layerFound%).blendMode% = BLEND_NORMAL THEN
                            _DEST compositeTarget&
                            _PUTIMAGE , renderImg&
                            _DEST SCRN.CANVAS&
                        ELSE
                            ' Non-Normal blend: pass ORIGINAL image — blend function handles opacity
                            LAYER_blend_composite compositeTarget&, layerRenderSource&, LAYERS(layerFound%).blendMode%, LAYERS(layerFound%).opacity%
                        END IF
                    END IF
                ELSE
                    ' --- Fast path (all Normal blend) ---
                    _PUTIMAGE (dx%, dy%)-(dx% + zw& - 1, dy% + zh& - 1), renderImg&
                END IF

                ' Free temp image if we made one for move preview
                IF useMoveBuf% AND opacityImg& <> 0 THEN
                    IF opacityImg& < -1 THEN _FREEIMAGE opacityImg&
                END IF
                END IF ' visible%
            END IF ' layerFound% > 0

            ' Save partial composite cache at boundary just below current layer
            ' Skip when isolated groups are active (cache doesn't account for group buffer)
            IF NOT useRegionComposite% AND NOT BLEND_HAS_ISOLATED_GROUPS% _
               AND savePartialCache% AND layerI% = currentRenderIdx% - 1 THEN
                IF COMPOSITE_BELOW_CACHE& = 0 OR _
                   _WIDTH(COMPOSITE_BELOW_CACHE&) <> SCRN.canvasW& OR _
                   _HEIGHT(COMPOSITE_BELOW_CACHE&) <> SCRN.canvasH& THEN
                    IF COMPOSITE_BELOW_CACHE& < -1 THEN _FREEIMAGE COMPOSITE_BELOW_CACHE&
                    COMPOSITE_BELOW_CACHE& = _NEWIMAGE(SCRN.canvasW&, SCRN.canvasH&, 32)
                END IF
                DIM pcOldDest AS LONG
                pcOldDest& = _DEST
                _DEST COMPOSITE_BELOW_CACHE&
                _DONTBLEND COMPOSITE_BELOW_CACHE&
                _PUTIMAGE , compositeImg&, COMPOSITE_BELOW_CACHE&
                _BLEND COMPOSITE_BELOW_CACHE&
                _DEST pcOldDest&
                COMPOSITE_BELOW_LAYER% = CURRENT_LAYER%
                COMPOSITE_BELOW_VALID% = TRUE
                savePartialCache%      = FALSE
            END IF
        NEXT layerI%

        ' If using composite, render the final composite to canvas with zoom
        IF useComposite% THEN
            _PUTIMAGE (dx%, dy%)-(dx% + zw& - 1, dy% + zh& - 1), compositeImg&, SCRN.CANVAS&
            ' compositeImg& is persistent (COMPOSITE_BUFFER&), do NOT free it

            ' Save completed composite for next frame's region-based path
            IF COMPOSITE_RESULT_CACHE& = 0 OR _
               _WIDTH(COMPOSITE_RESULT_CACHE&) <> SCRN.canvasW& OR _
               _HEIGHT(COMPOSITE_RESULT_CACHE&) <> SCRN.canvasH& THEN
                IF COMPOSITE_RESULT_CACHE& < -1 THEN _FREEIMAGE COMPOSITE_RESULT_CACHE&
                COMPOSITE_RESULT_CACHE& = _NEWIMAGE(SCRN.canvasW&, SCRN.canvasH&, 32)
            END IF
            DIM crOldDest AS LONG
            crOldDest& = _DEST
            _DEST COMPOSITE_RESULT_CACHE&
            _DONTBLEND COMPOSITE_RESULT_CACHE&
            _PUTIMAGE , compositeImg&, COMPOSITE_RESULT_CACHE&
            _BLEND COMPOSITE_RESULT_CACHE&
            _DEST crOldDest&
            COMPOSITE_RESULT_VALID% = TRUE
        END IF
    ELSE
        ' Fallback: Use SCRN.PAINTING if no layers exist yet (legacy support)
        DIM paint_source AS LONG
        paint_source& = MOVE_get_preview_buffer&
        IF paint_source& <> 0 THEN
            _SOURCE paint_source&
            _PUTIMAGE (dx%, dy%)-(dx% + zw& - 1, dy% + zh& - 1), paint_source&
        ELSE
            _SOURCE SCRN.PAINTING&
            _PUTIMAGE (dx%, dy%)-(dx% + zw& - 1, dy% + zh& - 1), SCRN.PAINTING&
        END IF
    END IF
END SUB


''
' Render grid overlays (regular grid + pixel grid cache).
' Called after layer compositing, before border/GUI.
'
' @param dx INTEGER X offset for zoomed canvas placement
' @param dy INTEGER Y offset for zoomed canvas placement
' @param zw LONG Zoomed canvas width
' @param zh LONG Zoomed canvas height
'
SUB RENDER_grids (dx AS INTEGER, dy AS INTEGER, zw AS LONG, zh AS LONG)
    IF GRID.SHOW% AND SCRN.zoom! >= 0.25 THEN
        _DEST SCRN.CANVAS&
        _BLEND SCRN.CANVAS&
        ' Standard axis-aligned grid at zoom < 100%: the cached canvas-resolution image
        ' has 1-pixel lines that disappear or shift with nearest-neighbour downscaling.
        ' Draw directly in screen space instead — each line is exactly 1 screen pixel.
        DIM ssGridAngle AS SINGLE
        IF CFG.GRID_ANGLE! <> 0 THEN
            ssGridAngle! = CFG.GRID_ANGLE!
        ELSE
            ssGridAngle! = THEME.GRID_angle!
        END IF

        IF GRID.GRID_MODE% = GRID_MODE_SQUARE AND ssGridAngle! = 0! AND SCRN.zoom! < 1.0! THEN
            DIM ssStepX AS SINGLE : ssStepX! = GRID.gridWidth%  * SCRN.zoom!
            DIM ssStepY AS SINGLE : ssStepY! = GRID.gridHeight% * SCRN.zoom!
            IF ssStepX! >= 2! AND ssStepY! >= 2! THEN
                ' Resolve colour + opacity (mirrors GRID_draw resolution logic)
                DIM ssColor   AS _UNSIGNED LONG
                DIM ssOpacity AS INTEGER
                IF CFG.GRID_COLOR_FG~& <> 0 THEN
                    ssColor~& = CFG.GRID_COLOR_FG~&
                ELSE
                    ssColor~& = GRID.fgColor~&
                END IF
                IF CFG.GRID_OPACITY% > 0 THEN
                    ssOpacity% = CFG.GRID_OPACITY%
                ELSE
                    ssOpacity% = THEME.GRID_opacity%
                END IF
                ssColor~& = _RGBA32(_RED32(ssColor~&), _GREEN32(ssColor~&), _BLUE32(ssColor~&), ssOpacity%)
                ' Vertical lines
                DIM ssx       AS SINGLE : ssx! = dx% + GRID.xPos% * SCRN.zoom!
                DO WHILE INT(ssx!) <= dx% + zw& - 1
                    IF INT(ssx!) >= dx% THEN
                        LINE (INT(ssx!), dy%)-(INT(ssx!), dy% + zh& - 1), ssColor~&
                    END IF
                    ssx! = ssx! + ssStepX!
                LOOP
                ' Horizontal lines
                DIM ssy       AS SINGLE : ssy! = dy% + GRID.yPos% * SCRN.zoom!
                DO WHILE INT(ssy!) <= dy% + zh& - 1
                    IF INT(ssy!) >= dy% THEN
                        LINE (dx%, INT(ssy!))-(dx% + zw& - 1, INT(ssy!)), ssColor~&
                    END IF
                    ssy! = ssy! + ssStepY!
                LOOP
            END IF
        ELSE
            ' Non-square / rotated grids, or zoom >= 100%: use cached image
            _PUTIMAGE (dx%, dy%)-(dx% + zw& - 1, dy% + zh& - 1), GRID.imgHandle&, SCRN.CANVAS&
        END IF
    END IF
    ' Character grid overlay (on top of regular grid)
    ' Show char grid whenever cells are at least 2 screen-pixels wide/tall (visible at any zoom)
    DIM cgMinVis AS INTEGER
    cgMinVis% = (CHARMAP.charGridW% > 0 AND CHARMAP.charGridH% > 0 AND _
                 SCRN.zoom! * CHARMAP.charGridW% >= 2 AND SCRN.zoom! * CHARMAP.charGridH% >= 2)
    IF CHARMAP.charGridShow% AND cgMinVis% THEN
        IF CHARMAP.charGridImg& < -1 THEN
            _DEST SCRN.CANVAS&
            _BLEND SCRN.CANVAS&
            _PUTIMAGE (dx%, dy%)-(dx% + zw& - 1, dy% + zh& - 1), CHARMAP.charGridImg&, SCRN.CANVAS&
        END IF
    END IF
    ' Pixel grid shows at 400%+ zoom if enabled (on top of regular grid)
    IF PIXEL_GRID.SHOW% AND SCRN.zoom! >= 4.0 THEN
        DIM pgx       AS INTEGER, pgy AS INTEGER
        DIM pzoom     AS INTEGER
        DIM pgColor   AS _UNSIGNED LONG
        DIM pgOpacity AS INTEGER
        pzoom% = INT(SCRN.zoom!)
        ' Resolve pixel grid color: config overrides theme (CFG 0 = use theme)
        IF CFG.PIXELGRID_COLOR_FG~& <> 0 THEN
            pgColor~& = CFG.PIXELGRID_COLOR_FG~&
        ELSE
            pgColor~& = _RGB32(_RED32(THEME.PIXEL_GRID_color_fg~&), _GREEN32(THEME.PIXEL_GRID_color_fg~&), _BLUE32(THEME.PIXEL_GRID_color_fg~&))
        END IF
        ' Resolve pixel grid opacity: config overrides theme (CFG 0 = use theme)
        IF CFG.PIXELGRID_OPACITY% > 0 THEN
            pgOpacity% = CFG.PIXELGRID_OPACITY%
        ELSE
            pgOpacity% = THEME.PIXEL_GRID_opacity%
        END IF

        ' Reuse cached pixel grid image if zoom/size/color/opacity unchanged
        IF PG_CACHE_IMG& = 0 OR _
           PG_CACHE_ZW& <> zw& OR _
           PG_CACHE_ZH& <> zh& OR _
           PG_CACHE_ZOOM% <> pzoom% OR _
           PG_CACHE_COLOR~& <> pgColor~& OR _
           PG_CACHE_OPACITY% <> pgOpacity% THEN
            ' Cache miss — rebuild pixel grid image
            IF PG_CACHE_IMG& < -1 THEN _FREEIMAGE PG_CACHE_IMG&
            PG_CACHE_IMG&     = _NEWIMAGE(zw& + 1, zh& + 1, 32)
            PG_CACHE_ZW&      = zw&
            PG_CACHE_ZH&      = zh&
            PG_CACHE_ZOOM%    = pzoom%
            PG_CACHE_COLOR~&  = pgColor~&
            PG_CACHE_OPACITY% = pgOpacity%
            _DEST PG_CACHE_IMG&
            CLS , _RGBA32(0, 0, 0, 0)
            ' Draw vertical lines between each pixel column
            FOR pgx% = 0 TO SCRN.canvasW&
                LINE (pgx% * pzoom%, 0)-(pgx% * pzoom%, zh&), pgColor~&
            NEXT pgx%
            ' Draw horizontal lines between each pixel row
            FOR pgy% = 0 TO SCRN.canvasH&
                LINE (0, pgy% * pzoom%)-(zw&, pgy% * pzoom%), pgColor~&
            NEXT pgy%
            ' Apply resolved opacity globally to all drawn pixels
            _SETALPHA pgOpacity%, pgColor~& TO pgColor~&, PG_CACHE_IMG&
        END IF
        ' Composite cached pixel grid onto canvas
        _DEST SCRN.CANVAS&
        _BLEND SCRN.CANVAS&
        _PUTIMAGE (dx%, dy%), PG_CACHE_IMG&
    END IF
END SUB


''
' Render tool previews (line, rect, ellipse, polygon, marquee drag, move, text, zoom).
' Drawn on canvas after grids/symmetry/border/import, before GUI layer.
'
' @param dx INTEGER X offset for zoomed canvas placement
' @param dy INTEGER Y offset for zoomed canvas placement
' @param zw LONG Zoomed canvas width
' @param zh LONG Zoomed canvas height
'
SUB RENDER_tool_previews (dx AS INTEGER, dy AS INTEGER, zw AS LONG, zh AS LONG)
    ' NOTE: Selection marching ants rendering moved AFTER scene cache save
    ' (SkipToPointer section) so animated ants don't force full scene re-render.
    ' Draw MARQUEE dragging preview (only when using marquee tool)
    IF CURRENT_TOOL% = TOOL_MARQUEE AND MARQUEE.DRAGGING% THEN
        MARQUEE_draw_drag_preview
    END IF
    ' Draw freehand selection preview (while dragging lasso path)
    IF CURRENT_TOOL% = TOOL_MARQUEE AND MARQUEE.VARIANT = TOOL_SELECT_FREE AND MARQUEE.FREE_DRAWING THEN
        FREEHAND_SEL_draw_preview
    END IF
    ' Draw polygon selection preview (while placing vertices)
    IF CURRENT_TOOL% = TOOL_MARQUEE AND MARQUEE.VARIANT = TOOL_SELECT_POLY AND MARQUEE.POLY_DRAWING THEN
        POLY_SEL_draw_preview
    END IF
    ' Draw ellipse selection preview (while drag-defining bounding box)
    IF CURRENT_TOOL% = TOOL_MARQUEE AND MARQUEE.VARIANT = TOOL_SELECT_ELLIPSE AND MARQUEE.ELLIP_DRAGGING THEN
        ELLIPSE_SEL_draw_preview
    END IF
    ' Draw MOVE transform preview if active
    IF CURRENT_TOOL% = TOOL_MOVE AND MOVE.ACTIVE THEN
        _DEST SCRN.CANVAS&
        MOVE_render_preview SCRN.CANVAS&
        IF MARQUEE.USER_CREATED THEN
            MARQUEE_draw TRUE
        END IF
    END IF
    ' Draw TEXT preview if editing
    IF CURRENT_TOOL% = TOOL_TEXT AND TEXT.ACTIVE THEN
        _DEST SCRN.CANVAS&
        TEXT_render_preview SCRN.CANVAS&, dx%, dy%, SCRN.zoom!
    END IF
    ' Draw ZOOM drag-to-region preview rectangle
    IF CURRENT_TOOL% = TOOL_ZOOM AND ZOOM.DRAGGING THEN
        DIM zx1       AS INTEGER, zy1 AS INTEGER, zx2 AS INTEGER, zy2 AS INTEGER
        zx1% = ZOOM.START_X : zy1% = ZOOM.START_Y
        zx2% = ZOOM.END_X   : zy2% = ZOOM.END_Y
        DIM zDragDist AS INTEGER
        zDragDist% = ABS(zx2% - zx1%) + ABS(zy2% - zy1%)
        IF zDragDist% >= 8 THEN
            _DEST SCRN.CANVAS&
            LINE (zx1%, zy1%)-(zx2%, zy2%), THEME.ZOOM_BOX_fill~&, BF
            LINE (zx1%, zy1%)-(zx2%, zy2%), THEME.ZOOM_BOX_border~&, B
            LINE (zx1% - 1, zy1% - 1)-(zx2% + 1, zy2% + 1), THEME.ZOOM_BOX_outer_border~&, B
        END IF
    END IF
    ' Determine preview color - use white with black outline effect for transparent
    ' Use DRAW_COLOR~& so right-click previews background color
    DIM preview_color AS _UNSIGNED LONG
    IF _ALPHA32(DRAW_COLOR~&) = 0 THEN
        preview_color~& = THEME.TOOL_PREVIEW_transparent_fg~&
    ELSE
        preview_color~& = DRAW_COLOR~&
    END IF

    ' Shape tool previews: draw at canvas resolution, then _PUTIMAGE scale to
    ' screen so line/shape thickness scales proportionally with zoom level.
    DIM need_shape_preview AS INTEGER
    need_shape_preview% = FALSE
    IF NOT SCRN.panning% THEN
        IF CURRENT_TOOL% = TOOL_LINE AND LINE_TOOL.DRAGGING THEN need_shape_preview% = TRUE
        IF (CURRENT_TOOL% = TOOL_POLYGON OR CURRENT_TOOL% = TOOL_POLYGON_FILLED) AND POLY_LINE.HAS_LAST THEN need_shape_preview% = TRUE
        IF (CURRENT_TOOL% = TOOL_RECT OR CURRENT_TOOL% = TOOL_RECT_FILLED) AND RECT_TOOL.DRAGGING THEN need_shape_preview% = TRUE
        IF (CURRENT_TOOL% = TOOL_ELLIPSE OR CURRENT_TOOL% = TOOL_ELLIPSE_FILLED) AND ELLIPSE_TOOL.DRAGGING THEN need_shape_preview% = TRUE
    END IF

    IF need_shape_preview% THEN
        ' Create canvas-resolution overlay for shape previews
        DIM shpImg AS LONG
        shpImg& = _NEWIMAGE(SCRN.canvasW&, SCRN.canvasH&, 32)
        IF shpImg& < -1 THEN
            _DEST shpImg&
            _DONTBLEND shpImg&
            CLS , _RGBA32(0, 0, 0, 0)

            ' --- LINE preview at canvas resolution ---
            IF CURRENT_TOOL% = TOOL_LINE AND LINE_TOOL.DRAGGING THEN
                GRAD_CTX_set LINE_TOOL.START_X, LINE_TOOL.START_Y, LINE_TOOL.END_X, LINE_TOOL.END_Y
                DIM lnBrSz AS INTEGER
                lnBrSz% = BRUSH_SIZE_pixels%
                IF lnBrSz% > 1 AND NOT CUSTOM_BRUSH_is_active% THEN
                    ' Thick brush preview
                    IF _ALPHA32(PAINT_COLOR~&) = 0 THEN
                        PREVIEW_draw_brushed_line LINE_TOOL.START_X - 1, LINE_TOOL.START_Y, LINE_TOOL.END_X - 1, LINE_TOOL.END_Y, THEME.TOOL_PREVIEW_transparent_outline~&
                        PREVIEW_draw_brushed_line LINE_TOOL.START_X + 1, LINE_TOOL.START_Y, LINE_TOOL.END_X + 1, LINE_TOOL.END_Y, THEME.TOOL_PREVIEW_transparent_outline~&
                    END IF
                    PREVIEW_draw_brushed_line LINE_TOOL.START_X, LINE_TOOL.START_Y, LINE_TOOL.END_X, LINE_TOOL.END_Y, preview_color~&
                ELSE
                    ' 1px thin preview (brush size 1 or custom brush)
                    IF _ALPHA32(PAINT_COLOR~&) = 0 THEN
                        LINE (LINE_TOOL.START_X - 1, LINE_TOOL.START_Y)-(LINE_TOOL.END_X - 1, LINE_TOOL.END_Y), THEME.TOOL_PREVIEW_transparent_outline~&
                        LINE (LINE_TOOL.START_X + 1, LINE_TOOL.START_Y)-(LINE_TOOL.END_X + 1, LINE_TOOL.END_Y), THEME.TOOL_PREVIEW_transparent_outline~&
                        LINE (LINE_TOOL.START_X, LINE_TOOL.START_Y - 1)-(LINE_TOOL.END_X, LINE_TOOL.END_Y - 1), THEME.TOOL_PREVIEW_transparent_outline~&
                        LINE (LINE_TOOL.START_X, LINE_TOOL.START_Y + 1)-(LINE_TOOL.END_X, LINE_TOOL.END_Y + 1), THEME.TOOL_PREVIEW_transparent_outline~&
                    END IF
                    IF DRAWER_has_paint_mode% THEN
                        LINE_draw_resolved LINE_TOOL.START_X, LINE_TOOL.START_Y, LINE_TOOL.END_X, LINE_TOOL.END_Y, PAINT_COLOR~&
                    ELSE
                        LINE (LINE_TOOL.START_X, LINE_TOOL.START_Y)-(LINE_TOOL.END_X, LINE_TOOL.END_Y), preview_color~&
                    END IF
                END IF
            END IF
            ' Line spokes preview
            IF CURRENT_TOOL% = TOOL_LINE AND LINE_TOOL.DRAGGING AND LINE_TOOL.SPOKES > 0 THEN
                LINE_draw_spokes LINE_TOOL.START_X, LINE_TOOL.START_Y, LINE_TOOL.END_X, LINE_TOOL.END_Y, preview_color~&, LINE_TOOL.SPOKES
            END IF
            ' Line end-cap preview
            IF CURRENT_TOOL% = TOOL_LINE AND LINE_TOOL.DRAGGING THEN
                IF LINE_TOOL.START_CAP <> LINE_CAP_NONE OR LINE_TOOL.END_CAP <> LINE_CAP_NONE THEN
                    DIM lcapHw AS INTEGER
                    lcapHw% = BRUSH_SIZE_pixels%
                    IF lcapHw% < 3 THEN lcapHw% = 3
                    IF LINE_TOOL.START_CAP <> LINE_CAP_NONE THEN
                        LINE_draw_cap shpImg&, LINE_TOOL.START_CAP, LINE_TOOL.START_X, LINE_TOOL.START_Y, LINE_TOOL.END_X, LINE_TOOL.END_Y, lcapHw%, preview_color~&
                    END IF
                    IF LINE_TOOL.END_CAP <> LINE_CAP_NONE THEN
                        LINE_draw_cap shpImg&, LINE_TOOL.END_CAP, LINE_TOOL.END_X, LINE_TOOL.END_Y, LINE_TOOL.START_X, LINE_TOOL.START_Y, lcapHw%, preview_color~&
                    END IF
                END IF
            END IF

            GRAD_CTX_clear

            ' --- POLY_LINE (polygon) preview at canvas resolution ---
            IF (CURRENT_TOOL% = TOOL_POLYGON OR CURRENT_TOOL% = TOOL_POLYGON_FILLED) AND POLY_LINE.HAS_LAST THEN
                ' Compute preview endpoint with optional angle snap
                DIM polyPrevX AS INTEGER, polyPrevY AS INTEGER
                polyPrevX% = MOUSE.X%
                polyPrevY% = MOUSE.Y%
                ' Tile mode: unwrap preview endpoint relative to last polygon point
                IF SCRN.patternTileMode% THEN
                    DIM plDiffX AS INTEGER : plDiffX% = polyPrevX% - POLY_LINE.LAST_X
                    IF plDiffX% > SCRN.canvasW& \ 2 THEN polyPrevX% = polyPrevX% - SCRN.canvasW&
                    IF plDiffX% < -(SCRN.canvasW& \ 2) THEN polyPrevX% = polyPrevX% + SCRN.canvasW&
                    DIM plDiffY AS INTEGER : plDiffY% = polyPrevY% - POLY_LINE.LAST_Y
                    IF plDiffY% > SCRN.canvasH& \ 2 THEN polyPrevY% = polyPrevY% - SCRN.canvasH&
                    IF plDiffY% < -(SCRN.canvasH& \ 2) THEN polyPrevY% = polyPrevY% + SCRN.canvasH&
                END IF
                IF MODIFIERS.ctrlShift% THEN
                    polyPrevX% = MOUSE.UNSNAPPED_X%
                    polyPrevY% = MOUSE.UNSNAPPED_Y%
                    SNAP_to_angle POLY_LINE.LAST_X, POLY_LINE.LAST_Y, polyPrevX%, polyPrevY%, CFG.ANGLE_SNAP_DEGREES%
                END IF
                GRAD_CTX_set POLY_LINE.LAST_X, POLY_LINE.LAST_Y, polyPrevX%, polyPrevY%
                DIM plBrSz AS INTEGER
                plBrSz% = BRUSH_SIZE_pixels%
                IF plBrSz% > 1 AND NOT CUSTOM_BRUSH_is_active% AND NOT POLY_LINE.FILLED THEN
                    ' Thick brush preview
                    IF _ALPHA32(PAINT_COLOR~&) = 0 THEN
                        PREVIEW_draw_brushed_line POLY_LINE.LAST_X - 1, POLY_LINE.LAST_Y, polyPrevX% - 1, polyPrevY%, THEME.TOOL_PREVIEW_transparent_outline~&
                        PREVIEW_draw_brushed_line POLY_LINE.LAST_X + 1, POLY_LINE.LAST_Y, polyPrevX% + 1, polyPrevY%, THEME.TOOL_PREVIEW_transparent_outline~&
                    END IF
                    PREVIEW_draw_brushed_line POLY_LINE.LAST_X, POLY_LINE.LAST_Y, polyPrevX%, polyPrevY%, preview_color~&
                ELSE
                    ' 1px thin preview
                    IF _ALPHA32(PAINT_COLOR~&) = 0 THEN
                        LINE (POLY_LINE.LAST_X - 1, POLY_LINE.LAST_Y)-(polyPrevX% - 1, polyPrevY%), THEME.TOOL_PREVIEW_transparent_outline~&
                        LINE (POLY_LINE.LAST_X + 1, POLY_LINE.LAST_Y)-(polyPrevX% + 1, polyPrevY%), THEME.TOOL_PREVIEW_transparent_outline~&
                        LINE (POLY_LINE.LAST_X, POLY_LINE.LAST_Y - 1)-(polyPrevX%, polyPrevY% - 1), THEME.TOOL_PREVIEW_transparent_outline~&
                        LINE (POLY_LINE.LAST_X, POLY_LINE.LAST_Y + 1)-(polyPrevX%, polyPrevY% + 1), THEME.TOOL_PREVIEW_transparent_outline~&
                    END IF
                    IF DRAWER_has_paint_mode% THEN
                        LINE_draw_resolved POLY_LINE.LAST_X, POLY_LINE.LAST_Y, polyPrevX%, polyPrevY%, PAINT_COLOR~&
                    ELSE
                        LINE (POLY_LINE.LAST_X, POLY_LINE.LAST_Y)-(polyPrevX%, polyPrevY%), preview_color~&
                    END IF
                END IF
            END IF

            GRAD_CTX_clear

            ' --- RECT preview at canvas resolution ---
            IF (CURRENT_TOOL% = TOOL_RECT OR CURRENT_TOOL% = TOOL_RECT_FILLED) AND RECT_TOOL.DRAGGING THEN
                GRAD_CTX_set RECT_TOOL.START_X, RECT_TOOL.START_Y, RECT_TOOL.END_X, RECT_TOOL.END_Y
                DIM rtBrSz AS INTEGER
                rtBrSz% = BRUSH_SIZE_pixels%
                IF rtBrSz% > 1 AND NOT RECT_TOOL.FILLED AND NOT CUSTOM_BRUSH_is_active% THEN
                    ' Thick brush outline rect preview (4 brushed lines)
                    DIM rsx AS INTEGER, rsy AS INTEGER, rex AS INTEGER, rey AS INTEGER
                    rsx% = RECT_TOOL.START_X : rsy% = RECT_TOOL.START_Y
                    rex% = RECT_TOOL.END_X   : rey% = RECT_TOOL.END_Y
                    PREVIEW_draw_brushed_line rsx%, rsy%, rex%, rsy%, preview_color~&
                    PREVIEW_draw_brushed_line rex%, rsy%, rex%, rey%, preview_color~&
                    PREVIEW_draw_brushed_line rex%, rey%, rsx%, rey%, preview_color~&
                    PREVIEW_draw_brushed_line rsx%, rey%, rsx%, rsy%, preview_color~&
                    ' Symmetry
                    IF SYMMETRY.MODE > 0 THEN
                        DIM rect_sx(0 TO 7) AS INTEGER, rect_sy(0 TO 7) AS INTEGER
                        DIM rect_ex(0 TO 7) AS INTEGER, rect_ey(0 TO 7) AS INTEGER
                        DIM rect_count AS INTEGER, rect_i AS INTEGER
                        SYMMETRY_get_mirrored_points rsx%, rsy%, rect_sx%(), rect_sy%(), rect_count%
                        SYMMETRY_get_mirrored_points rex%, rey%, rect_ex%(), rect_ey%(), rect_count%
                        FOR rect_i% = 0 TO rect_count% - 1
                            PREVIEW_draw_brushed_line rect_sx%(rect_i%), rect_sy%(rect_i%), rect_ex%(rect_i%), rect_sy%(rect_i%), preview_color~&
                            PREVIEW_draw_brushed_line rect_ex%(rect_i%), rect_sy%(rect_i%), rect_ex%(rect_i%), rect_ey%(rect_i%), preview_color~&
                            PREVIEW_draw_brushed_line rect_ex%(rect_i%), rect_ey%(rect_i%), rect_sx%(rect_i%), rect_ey%(rect_i%), preview_color~&
                            PREVIEW_draw_brushed_line rect_sx%(rect_i%), rect_ey%(rect_i%), rect_sx%(rect_i%), rect_sy%(rect_i%), preview_color~&
                        NEXT rect_i%
                    END IF
                ELSE
                    ' 1px rect preview (or filled rect)
                    IF _ALPHA32(PAINT_COLOR~&) = 0 THEN
                        IF RECT_TOOL.FILLED THEN
                            LINE (RECT_TOOL.START_X - 1, RECT_TOOL.START_Y - 1)-(RECT_TOOL.END_X + 1, RECT_TOOL.END_Y + 1), THEME.TOOL_PREVIEW_transparent_outline~&, B
                        ELSE
                            LINE (RECT_TOOL.START_X - 1, RECT_TOOL.START_Y - 1)-(RECT_TOOL.END_X + 1, RECT_TOOL.END_Y + 1), THEME.TOOL_PREVIEW_transparent_outline~&, B
                            LINE (RECT_TOOL.START_X + 1, RECT_TOOL.START_Y + 1)-(RECT_TOOL.END_X - 1, RECT_TOOL.END_Y - 1), THEME.TOOL_PREVIEW_transparent_outline~&, B
                        END IF
                    END IF
                    IF RECT_TOOL.FILLED THEN
                        IF DRAWER_has_paint_mode% THEN
                            DIM rect_preview_min_x AS INTEGER, rect_preview_min_y AS INTEGER
                            DIM rect_preview_max_x AS INTEGER, rect_preview_max_y AS INTEGER
                            DIM rect_preview_x     AS INTEGER, rect_preview_y AS INTEGER
                            rect_preview_min_x% = RECT_TOOL.START_X : rect_preview_max_x% = RECT_TOOL.END_X
                            rect_preview_min_y% = RECT_TOOL.START_Y : rect_preview_max_y% = RECT_TOOL.END_Y
                            IF rect_preview_min_x% > rect_preview_max_x% THEN SWAP rect_preview_min_x%, rect_preview_max_x%
                            IF rect_preview_min_y% > rect_preview_max_y% THEN SWAP rect_preview_min_y%, rect_preview_max_y%
                            FOR rect_preview_y% = rect_preview_min_y% TO rect_preview_max_y%
                                FOR rect_preview_x% = rect_preview_min_x% TO rect_preview_max_x%
                                    PSET (rect_preview_x%, rect_preview_y%), DRAWER_resolve_paint_color~&(rect_preview_x%, rect_preview_y%, DRAW_COLOR~&)
                                NEXT rect_preview_x%
                            NEXT rect_preview_y%
                        ELSE
                            LINE (RECT_TOOL.START_X, RECT_TOOL.START_Y)-(RECT_TOOL.END_X, RECT_TOOL.END_Y), preview_color~&, BF
                        END IF
                    ELSE
                        LINE (RECT_TOOL.START_X, RECT_TOOL.START_Y)-(RECT_TOOL.END_X, RECT_TOOL.END_Y), preview_color~&, B
                    END IF
                    ' Draw symmetry rectangles at canvas resolution
                    IF SYMMETRY.MODE > 0 THEN
                        DIM rect_sx2(0 TO 7) AS INTEGER, rect_sy2(0 TO 7) AS INTEGER
                        DIM rect_ex2(0 TO 7) AS INTEGER, rect_ey2(0 TO 7) AS INTEGER
                        DIM rect_count2 AS INTEGER, rect_i2 AS INTEGER
                        SYMMETRY_get_mirrored_points RECT_TOOL.START_X, RECT_TOOL.START_Y, rect_sx2%(), rect_sy2%(), rect_count2%
                        SYMMETRY_get_mirrored_points RECT_TOOL.END_X, RECT_TOOL.END_Y, rect_ex2%(), rect_ey2%(), rect_count2%
                        FOR rect_i2% = 0 TO rect_count2% - 1
                            IF RECT_TOOL.FILLED THEN
                                IF DRAWER_has_paint_mode% THEN
                                    rect_preview_min_x% = rect_sx2%(rect_i2%) : rect_preview_max_x% = rect_ex2%(rect_i2%)
                                    rect_preview_min_y% = rect_sy2%(rect_i2%) : rect_preview_max_y% = rect_ey2%(rect_i2%)
                                    IF rect_preview_min_x% > rect_preview_max_x% THEN SWAP rect_preview_min_x%, rect_preview_max_x%
                                    IF rect_preview_min_y% > rect_preview_max_y% THEN SWAP rect_preview_min_y%, rect_preview_max_y%
                                    FOR rect_preview_y% = rect_preview_min_y% TO rect_preview_max_y%
                                        FOR rect_preview_x% = rect_preview_min_x% TO rect_preview_max_x%
                                            PSET (rect_preview_x%, rect_preview_y%), DRAWER_resolve_paint_color~&(rect_preview_x%, rect_preview_y%, DRAW_COLOR~&)
                                        NEXT rect_preview_x%
                                    NEXT rect_preview_y%
                                ELSE
                                    LINE (rect_sx2%(rect_i2%), rect_sy2%(rect_i2%))-(rect_ex2%(rect_i2%), rect_ey2%(rect_i2%)), preview_color~&, BF
                                END IF
                            ELSE
                                LINE (rect_sx2%(rect_i2%), rect_sy2%(rect_i2%))-(rect_ex2%(rect_i2%), rect_ey2%(rect_i2%)), preview_color~&, B
                            END IF
                        NEXT rect_i2%
                    END IF
                END IF
            END IF
            ' Rect division lines preview (drawn after the rect outline/fill)
            IF (CURRENT_TOOL% = TOOL_RECT OR CURRENT_TOOL% = TOOL_RECT_FILLED) AND RECT_TOOL.DRAGGING THEN
                IF RECT_TOOL.H_DIVISIONS > 0 OR RECT_TOOL.V_DIVISIONS > 0 THEN
                    RECT_draw_divisions RECT_TOOL.START_X, RECT_TOOL.START_Y, RECT_TOOL.END_X, RECT_TOOL.END_Y, preview_color~&, RECT_TOOL.H_DIVISIONS, RECT_TOOL.V_DIVISIONS
                END IF
            END IF

            GRAD_CTX_clear

            ' --- ELLIPSE preview at canvas resolution ---
            IF (CURRENT_TOOL% = TOOL_ELLIPSE OR CURRENT_TOOL% = TOOL_ELLIPSE_FILLED) AND ELLIPSE_TOOL.DRAGGING THEN
                GRAD_CTX_set ELLIPSE_TOOL.START_X, ELLIPSE_TOOL.START_Y, ELLIPSE_TOOL.END_X, ELLIPSE_TOOL.END_Y
                DIM pcx AS INTEGER, pcy AS INTEGER, prx AS SINGLE, pry AS SINGLE, pasp AS SINGLE
                pcx% = (ELLIPSE_TOOL.START_X + ELLIPSE_TOOL.END_X) \ 2
                pcy% = (ELLIPSE_TOOL.START_Y + ELLIPSE_TOOL.END_Y) \ 2
                prx! = ABS(ELLIPSE_TOOL.END_X - ELLIPSE_TOOL.START_X) / 2
                pry! = ABS(ELLIPSE_TOOL.END_Y - ELLIPSE_TOOL.START_Y) / 2
                IF prx! > 0 THEN pasp! = pry! / prx! ELSE pasp! = 1

                IF prx! > 0 THEN
                    DIM elBrSz AS INTEGER
                    elBrSz% = BRUSH_SIZE_pixels%
                    IF elBrSz% > 1 AND NOT ELLIPSE_TOOL.FILLED AND NOT CUSTOM_BRUSH_is_active% THEN
                        ' Thick brush ellipse outline preview
                        PREVIEW_draw_brushed_ellipse pcx%, pcy%, prx!, pry!, preview_color~&
                        ' Symmetry
                        IF SYMMETRY.MODE > 0 THEN
                            DIM ell_csx(0 TO 7) AS INTEGER, ell_csy(0 TO 7) AS INTEGER
                            DIM ell_count AS INTEGER, ell_i AS INTEGER
                            SYMMETRY_get_mirrored_points pcx%, pcy%, ell_csx%(), ell_csy%(), ell_count%
                            FOR ell_i% = 0 TO ell_count% - 1
                                PREVIEW_draw_brushed_ellipse ell_csx%(ell_i%), ell_csy%(ell_i%), prx!, pry!, preview_color~&
                            NEXT ell_i%
                        END IF
                    ELSE
                        ' 1px (or filled) ellipse preview
                        IF _ALPHA32(PAINT_COLOR~&) = 0 THEN
                            CIRCLE (pcx%, pcy%), prx! + 1, THEME.TOOL_PREVIEW_transparent_outline~&, , , pasp!
                        END IF
                        IF ELLIPSE_TOOL.FILLED THEN
                            IF DRAWER_has_paint_mode% THEN
                                DIM preview_scan_y  AS INTEGER, preview_scan_x AS INTEGER
                                DIM preview_x_left  AS INTEGER, preview_x_right AS INTEGER
                                DIM preview_y_start AS INTEGER, preview_y_end AS INTEGER
                                DIM preview_dy      AS SINGLE, preview_dx AS SINGLE
                                preview_y_start% = pcy% - INT(pry! + 0.5)
                                preview_y_end%   = pcy% + INT(pry! + 0.5)
                                FOR preview_scan_y% = preview_y_start% TO preview_y_end%
                                    preview_dy! = (preview_scan_y% - pcy%) / pry!
                                    IF ABS(preview_dy!) <= 1.0001 THEN
                                        preview_dx!      = prx! * SQR(1 - preview_dy! * preview_dy!)
                                        preview_x_left%  = pcx% - INT(preview_dx! + 0.5)
                                        preview_x_right% = pcx% + INT(preview_dx! + 0.5)
                                        FOR preview_scan_x% = preview_x_left% TO preview_x_right%
                                            PSET (preview_scan_x%, preview_scan_y%), DRAWER_resolve_paint_color~&(preview_scan_x%, preview_scan_y%, DRAW_COLOR~&)
                                        NEXT preview_scan_x%
                                    END IF
                                NEXT preview_scan_y%
                            ELSE
                                DIM preview_temp    AS LONG
                                DIM preview_w       AS INTEGER, preview_h AS INTEGER
                                DIM temp_cx         AS INTEGER, temp_cy AS INTEGER
                                preview_w%    = INT(prx! * 2 + 4)
                                preview_h%    = INT(pry! * 2 + 4)
                                preview_temp& = _NEWIMAGE(preview_w%, preview_h%, 32)
                                _DEST preview_temp&
                                CLS , _RGBA32(0, 0, 0, 0)
                                _CLEARCOLOR _RGBA32(0, 0, 0, 0), preview_temp&
                                temp_cx% = preview_w% \ 2
                                temp_cy% = preview_h% \ 2
                                CIRCLE (temp_cx%, temp_cy%), prx!, preview_color~&, , , pasp!
                                PAINT (temp_cx%, temp_cy%), preview_color~&, preview_color~&
                                _DEST shpImg&
                                _PUTIMAGE (pcx% - temp_cx%, pcy% - temp_cy%), preview_temp&, shpImg&
                                IF preview_temp& < -1 THEN _FREEIMAGE preview_temp&
                            END IF
                        ELSE
                            CIRCLE (pcx%, pcy%), prx!, preview_color~&, , , pasp!
                        END IF
                        ' Symmetry for 1px / filled path
                        IF SYMMETRY.MODE > 0 THEN
                            DIM ell_csx2(0 TO 7) AS INTEGER, ell_csy2(0 TO 7) AS INTEGER
                            DIM ell_count2 AS INTEGER, ell_i2 AS INTEGER
                            SYMMETRY_get_mirrored_points pcx%, pcy%, ell_csx2%(), ell_csy2%(), ell_count2%
                            FOR ell_i2% = 0 TO ell_count2% - 1
                                IF ELLIPSE_TOOL.FILLED THEN
                                    IF DRAWER_has_paint_mode% THEN
                                        preview_y_start% = ell_csy2%(ell_i2%) - INT(pry! + 0.5)
                                        preview_y_end%   = ell_csy2%(ell_i2%) + INT(pry! + 0.5)
                                        FOR preview_scan_y% = preview_y_start% TO preview_y_end%
                                            preview_dy! = (preview_scan_y% - ell_csy2%(ell_i2%)) / pry!
                                            IF ABS(preview_dy!) <= 1.0001 THEN
                                                preview_dx!      = prx! * SQR(1 - preview_dy! * preview_dy!)
                                                preview_x_left%  = ell_csx2%(ell_i2%) - INT(preview_dx! + 0.5)
                                                preview_x_right% = ell_csx2%(ell_i2%) + INT(preview_dx! + 0.5)
                                                FOR preview_scan_x% = preview_x_left% TO preview_x_right%
                                                    PSET (preview_scan_x%, preview_scan_y%), DRAWER_resolve_paint_color~&(preview_scan_x%, preview_scan_y%, DRAW_COLOR~&)
                                                NEXT preview_scan_x%
                                            END IF
                                        NEXT preview_scan_y%
                                    ELSE
                                        preview_temp& = _NEWIMAGE(preview_w%, preview_h%, 32)
                                        _DEST preview_temp&
                                        CLS , _RGBA32(0, 0, 0, 0)
                                        _CLEARCOLOR _RGBA32(0, 0, 0, 0), preview_temp&
                                        CIRCLE (temp_cx%, temp_cy%), prx!, preview_color~&, , , pasp!
                                        PAINT (temp_cx%, temp_cy%), preview_color~&, preview_color~&
                                        _DEST shpImg&
                                        _PUTIMAGE (ell_csx2%(ell_i2%) - temp_cx%, ell_csy2%(ell_i2%) - temp_cy%), preview_temp&, shpImg&
                                        IF preview_temp& < -1 THEN _FREEIMAGE preview_temp&
                                    END IF
                                ELSE
                                    CIRCLE (ell_csx2%(ell_i2%), ell_csy2%(ell_i2%)), prx!, preview_color~&, , , pasp!
                                END IF
                            NEXT ell_i2%
                        END IF
                    END IF
                END IF
            END IF
            ' Ellipse modifier preview (spokes and rings, drawn after ellipse outline/fill)
            IF (CURRENT_TOOL% = TOOL_ELLIPSE OR CURRENT_TOOL% = TOOL_ELLIPSE_FILLED) AND ELLIPSE_TOOL.DRAGGING THEN
                IF ELLIPSE_TOOL.SLICES > 0 OR ELLIPSE_TOOL.RINGS > 0 THEN
                    DIM emod_cx AS INTEGER, emod_cy AS INTEGER, emod_rx AS SINGLE, emod_ry AS SINGLE
                    emod_cx% = (ELLIPSE_TOOL.START_X + ELLIPSE_TOOL.END_X) \ 2
                    emod_cy% = (ELLIPSE_TOOL.START_Y + ELLIPSE_TOOL.END_Y) \ 2
                    emod_rx! = ABS(ELLIPSE_TOOL.END_X - ELLIPSE_TOOL.START_X) / 2
                    emod_ry! = ABS(ELLIPSE_TOOL.END_Y - ELLIPSE_TOOL.START_Y) / 2
                    ELLIPSE_draw_modifiers emod_cx%, emod_cy%, emod_rx!, emod_ry!, preview_color~&, ELLIPSE_TOOL.SLICES, ELLIPSE_TOOL.RINGS
                END IF
            END IF

            GRAD_CTX_clear

            ' Scale canvas-resolution overlay to screen with zoom
            DIM prev_blend AS LONG
            prev_blend& = _BLEND(SCRN.CANVAS&)
            _DEST SCRN.CANVAS&
            _BLEND SCRN.CANVAS&
            _BLEND shpImg& ' Re-enable alpha blending for compositing (was _DONTBLEND for drawing)
            IF SCRN.patternTileMode% THEN
                ' Self-tile the overlay so shapes wrapping past canvas edges appear correctly
                DIM tmpShp AS LONG
                tmpShp& = _COPYIMAGE(shpImg&, 32)
                DIM stRow  AS INTEGER, stCol AS INTEGER
                FOR stRow% = -1 TO 1
                    FOR stCol% = -1 TO 1
                        IF stRow% <> 0 OR stCol% <> 0 THEN
                            _PUTIMAGE (stCol% * SCRN.canvasW&, stRow% * SCRN.canvasH&), tmpShp&, shpImg&
                        END IF
                    NEXT stCol%
                NEXT stRow%
                IF tmpShp& < -1 THEN _FREEIMAGE tmpShp&
                ' Blit to all 9 tile positions
                DIM spRow  AS INTEGER, spCol AS INTEGER
                DIM spdx   AS INTEGER, spdy AS INTEGER
                FOR spRow% = -1 TO 1
                    FOR spCol% = -1 TO 1
                        spdx% = dx% + spCol% * zw&
                        spdy% = dy% + spRow% * zh&
                        _PUTIMAGE (spdx%, spdy%)-(spdx% + zw& - 1, spdy% + zh& - 1), shpImg&, SCRN.CANVAS&
                    NEXT spCol%
                NEXT spRow%
            ELSE
                _PUTIMAGE (dx%, dy%)-(dx% + zw& - 1, dy% + zh& - 1), shpImg&, SCRN.CANVAS&
            END IF
            IF prev_blend& = 0 THEN _DONTBLEND SCRN.CANVAS&
            _FREEIMAGE shpImg&
        END IF
    END IF
END SUB


''
' Render selection overlay (marching ants) after scene cache save.
' Drawn every active frame regardless of SCENE_DIRTY since ants animate.
'
SUB RENDER_selection_overlay ()
    IF SELECTION_has_active% THEN
        IF MARQUEE.WAND_HAS_SELECTION AND MARQUEE.SELECTION_MASK < -1 THEN
            _DEST SCRN.CANVAS&
            MAGIC_WAND_draw_outline
        ELSEIF MARQUEE.ACTIVE% AND MARQUEE.USER_CREATED THEN
            IF MARQUEE.DRAGGING% AND MARQUEE.SELECTION_MODE <> SEL_MODE_REPLACE THEN
                _DEST SCRN.CANVAS&
                MARQUEE_draw_existing_box TRUE
            ELSE
                _DEST SCRN.CANVAS&
                MARQUEE_draw TRUE
            END IF
        END IF
    END IF
END SUB


''
''
' Returns TRUE if raw screen coordinates are within the canvas work area
' (the apron + canvas region, bounded by all side panels and top/bottom chrome).
' Use this to gate assistants (crosshair, loupe) that must not render over UI.
'
FUNCTION SCREEN_mouse_over_work_area% (rawX AS INTEGER, rawY AS INTEGER)
    ' Horizontal: must be inside the work area left/right edges
    IF rawX% < SCRN.uiLeftEdge% OR rawX% > SCRN.uiRightEdge% THEN
        SCREEN_mouse_over_work_area% = FALSE
        EXIT FUNCTION
    END IF

    ' Vertical top: past menu bar if shown, plus text bar if shown
    DIM topY AS INTEGER
    topY% = 0
    IF SCRN.showMenubar% AND MENU_BAR.visible% THEN topY% = MENU_BAR_HEIGHT
    IF TEXT_BAR.visible% THEN topY% = TEXT_BAR.barY% + TEXT_BAR.barH%
    IF rawY% < topY% THEN
        SCREEN_mouse_over_work_area% = FALSE
        EXIT FUNCTION
    END IF

    ' Vertical bottom: before status bar and palette strip if shown
    DIM botY AS INTEGER
    botY% = SCRN.h& - 1
    IF SCRN.showStatus% THEN
        botY% = SCRN.h& - 1 - THEME.STATUS_height% - PALETTE_STRIP_get_height%
    END IF
    IF rawY% > botY% THEN
        SCREEN_mouse_over_work_area% = FALSE
        EXIT FUNCTION
    END IF

    SCREEN_mouse_over_work_area% = TRUE
END FUNCTION


' Render crosshair overlay and command palette.
' Crosshair shown when SHIFT held (without CTRL), not over UI, not in text mode.
'
SUB RENDER_crosshair_and_command_palette ()
    DIM shiftHeld AS INTEGER, ctrlHeld AS INTEGER, altHeld AS INTEGER
    shiftHeld% = MODIFIERS.shift%
    ctrlHeld%  = MODIFIERS.ctrl%
    altHeld%   = MODIFIERS.alt%

    DIM cmx AS INTEGER, cmy AS INTEGER
    cmx% = MOUSE.RAW_X%
    cmy% = MOUSE.RAW_Y%

    ' Positive work-area test: suppress assistants whenever mouse is outside the
    ' canvas+apron zone (over toolbar, layer panel, editbar, advbar, charmap, etc.)
    DIM overUI AS INTEGER
    overUI% = NOT SCREEN_mouse_over_work_area%(cmx%, cmy%)

    ' Also suppress over floating overlays that can appear within the work area
    IF NOT overUI% AND PALETTE_MENU_VISIBLE% THEN overUI% = TRUE
    IF NOT overUI% AND MENUBAR_is_open% THEN overUI% = TRUE
    IF NOT overUI% AND PREVIEW.visible% AND NOT PREVIEW.autoHidden% THEN
        IF PREVIEW_hit_window%(cmx%, cmy%) THEN overUI% = TRUE
    END IF

    IF shiftHeld% AND NOT ctrlHeld% AND CURRENT_TOOL% <> TOOL_TEXT AND NOT overUI% THEN
        CROSSHAIR_render
    END IF

    ' Command palette is rendered AFTER the selection overlay (SkipToPointer section)
    ' so it always appears in front of marching ants. Do NOT render it here.
END SUB


''
' Compute panel layout geometry from config and current visibility.
' Sets SCRN.layerPanelX%, SCRN.toolboxX%, SCRN.uiLeftEdge%, SCRN.uiRightEdge%.
' Must be called once per render pass before any panel renders.
'
SUB SCREEN_compute_layout ()
    DIM scale           AS INTEGER
    DIM toolboxW        AS INTEGER
    DIM editBarW        AS INTEGER
    DIM leftX           AS INTEGER
    DIM rightX          AS INTEGER
    DIM textBarWillShow AS INTEGER
    DIM charMapTopY     AS INTEGER

    scale% = CFG.TOOLBAR_SCALE%
    IF scale% < 1 THEN scale% = 1
    IF scale% > 4 THEN scale% = 4
    toolboxW% = TB_COLS * (TB_BTN_W * scale%) + (TB_COLS - 1) * (TB_BTN_PADDING * scale%) + 2
    editBarW% = THEME.EDIT_BAR_WIDTH% + THEME.EDIT_BAR_LEFT_BORDER_WIDTH% + THEME.EDIT_BAR_RIGHT_BORDER_WIDTH%
    DIM advBarW AS INTEGER
    advBarW% = THEME.EDIT_BAR_WIDTH% + THEME.EDIT_BAR_LEFT_BORDER_WIDTH% + THEME.EDIT_BAR_RIGHT_BORDER_WIDTH%

    leftX%  = 0
    rightX% = SCRN.w& - 1

    ' Predict text bar visibility for top chrome geometry.
    IF SCRN.textBarHiddenByToggleAll% THEN
        textBarWillShow% = FALSE
    ELSE
        textBarWillShow% = (CURRENT_TOOL% = TOOL_TEXT) OR (TEXT_BAR.editingLayerIdx% > 0)
    END IF
    charMapTopY% = 0
    IF SCRN.showMenubar% THEN charMapTopY% = charMapTopY% + MENU_BAR_HEIGHT
    ' Note: charmap column is carved from rightX independently of the text bar,
    ' so the charmap panel top does NOT need to include the text bar height.

    ' ---------- LEFT side: layers (outermost) > toolbox > editbar (innermost) ----------
    IF UCASE$(_TRIM$(CFG.LAYERS_PANEL_DOCK_EDGE)) = "LEFT" AND LAYER_PANEL.visible% THEN
        SCRN.layerPanelX% = leftX%
        leftX% = leftX% + LAYER_PANEL.width%
    END IF
    IF UCASE$(_TRIM$(CFG.TOOLBOX_DOCK_EDGE)) = "LEFT" AND SCRN.showToolbar% THEN
        SCRN.toolboxX% = leftX%
        leftX% = leftX% + toolboxW%
    END IF

    ' ---------- RIGHT side: layers (outermost) > toolbox > editbar (innermost) ----------
    IF UCASE$(_TRIM$(CFG.LAYERS_PANEL_DOCK_EDGE)) = "RIGHT" AND LAYER_PANEL.visible% THEN
        rightX% = rightX% - LAYER_PANEL.width%
        SCRN.layerPanelX% = rightX% + 1
    END IF
    IF UCASE$(_TRIM$(CFG.TOOLBOX_DOCK_EDGE)) = "RIGHT" AND SCRN.showToolbar% THEN
        rightX% = rightX% - toolboxW%
        SCRN.toolboxX% = rightX% + 1
    END IF

    ' Menubar spans over bar columns, so save edges before both bars
    SCRN.menuBarLeftEdge%  = leftX%
    SCRN.menuBarRightEdge% = rightX%

    ' Advanced Bar (outermost of the two bars — further from canvas)
    IF ADV_BAR.dockSide% = ADVBAR_DOCK_LEFT AND SCRN.showAdvBar% THEN
        SCRN.advBarX% = leftX%
        leftX% = leftX% + advBarW%
    END IF
    IF ADV_BAR.dockSide% = ADVBAR_DOCK_RIGHT AND SCRN.showAdvBar% THEN
        rightX% = rightX% - advBarW%
        SCRN.advBarX% = rightX% + 1
    END IF

    ' Edit Bar (innermost of the two bars — closer to canvas)
    IF EDIT_BAR.dockSide% = EDITBAR_DOCK_LEFT AND SCRN.showEditBar% THEN
        SCRN.editBarX% = leftX%
        leftX% = leftX% + editBarW%
    END IF
    IF EDIT_BAR.dockSide% = EDITBAR_DOCK_RIGHT AND SCRN.showEditBar% THEN
        rightX% = rightX% - editBarW%
        SCRN.editBarX% = rightX% + 1
    END IF

    ' Character Map panel docking (inside editbar)
    IF SCRN.showCharMap% THEN
        DIM charMapW          AS INTEGER
        DIM charMapBottomBars AS INTEGER

        ' Ensure cache/cell metrics are current before computing panel width,
        ' so first-frame layout is correct even when auto cell sizing is active.
        IF NOT CHARMAP.cacheValid% OR _
           CHARMAP.cacheFontIdx% <> TEXT_BAR.selectedFontIdx% OR _
              CHARMAP.cacheFontSize% <> CHARMAP_effective_font_size% OR _
           CHARMAP.cacheMono% <> TEXT_BAR.monoActive% THEN
            CHARMAP_rebuild_cache
        END IF

        charMapW% = CHARMAP_panel_width%
        IF CHARMAP.dockSide% = CHARMAP_DOCK_LEFT THEN
            SCRN.charMapX% = leftX%
            leftX% = leftX% + charMapW%
        ELSE
            rightX% = rightX% - charMapW%
            SCRN.charMapX% = rightX% + 1
        END IF
        ' Update panel geometry for hit testing / rendering
        CHARMAP.panelX1%   = SCRN.charMapX%
        CHARMAP.panelX2%   = SCRN.charMapX% + charMapW% - 1
        CHARMAP.panelY1%   = charMapTopY%
        charMapBottomBars% = 0
        IF SCRN.showStatus% THEN
            charMapBottomBars% = THEME.STATUS_height% + PALETTE_STRIP_get_height%
        END IF
        CHARMAP.panelY2% = SCRN.h& - charMapBottomBars% - 1
        IF CHARMAP.panelY2% < CHARMAP.panelY1% THEN CHARMAP.panelY2% = CHARMAP.panelY1%
        CHARMAP.panelW% = charMapW%
        CHARMAP.gridX%  = CHARMAP.panelX1% + 2
        CHARMAP.gridY%  = CHARMAP.panelY1% + 2
    END IF

    SCRN.uiLeftEdge%  = leftX%
    SCRN.uiRightEdge% = rightX%

    ' Compute horizontal panel shift for centering canvas between side panels.
    ' All canvas dx calculations use: (SCRN.w& - zw&) \ 2 + SCRN.offsetX% + SCRN.panelShiftX%
    DIM availW AS INTEGER
    availW%           = rightX% - leftX% + 1
    SCRN.panelShiftX% = leftX% + (availW% - SCRN.w&) \ 2

    ' Text formatting bar — sits below menu bar when text tool active or editing text layer
    ' Respect toggle-all (F11) — suppress visibility while hidden by toggle-all
    IF SCRN.textBarHiddenByToggleAll% THEN
        TEXT_BAR.visible% = FALSE
    ELSE
        TEXT_BAR.visible% = (CURRENT_TOOL% = TOOL_TEXT) OR (TEXT_BAR.editingLayerIdx% > 0)
    END IF
    IF TEXT_BAR.visible% AND SCRN.showMenubar% THEN
        TEXT_BAR.barX% = SCRN.uiLeftEdge%
        TEXT_BAR.barY% = MENU_BAR_HEIGHT
        TEXT_BAR.barW% = SCRN.uiRightEdge% - SCRN.uiLeftEdge% + 1
        TEXT_BAR.barH% = THEME.TEXT_BAR_ROW_HEIGHT% * 2
    ELSEIF TEXT_BAR.visible% THEN
        TEXT_BAR.barX% = SCRN.uiLeftEdge%
        TEXT_BAR.barY% = 0
        TEXT_BAR.barW% = SCRN.uiRightEdge% - SCRN.uiLeftEdge% + 1
        TEXT_BAR.barH% = THEME.TEXT_BAR_ROW_HEIGHT% * 2
    END IF
END SUB


''
' Render GUI elements (toolbar, status bar, palette strip, layer panel, menu bar).
' Only redraws when GUI_NEEDS_REDRAW% is TRUE.
'
SUB RENDER_gui_elements ()
    SCREEN_compute_layout
    IF GUI_NEEDS_REDRAW% THEN
        _DEST SCRN.GUI&
        CLS , _RGBA32(0, 0, 0, 0)

        IF SCRN.showToolbar% THEN
            TOOLBAR_render 0, 0, TB_TOTAL - 1
            ' Organizer sits directly beneath toolbar
            DIM org_scale AS INTEGER
            DIM org_tb_y2 AS INTEGER
            org_scale% = CFG.TOOLBAR_SCALE%
            IF org_scale% < 1 THEN org_scale% = 1
            IF org_scale% > 4 THEN org_scale% = 4
            org_tb_y2% = TB_TOP + (TB_ROWS * TB_BTN_H * org_scale%) + ((TB_ROWS - 1) * TB_BTN_PADDING * org_scale%)
            ORGANIZER_render org_tb_y2%
            DRAWER_render
        END IF
        IF SCRN.showEditBar% THEN
            EDITBAR_render
        END IF
        IF SCRN.showAdvBar% THEN
            ADVBAR_render
        END IF

        IF SCRN.showCharMap% THEN
            CHARMAP_render
        END IF

        IF SCRN.showStatus% THEN
            PALETTE_STRIP_render
            STATUS_render
        END IF

        IF LAYER_PANEL.visible% THEN
            LAYER_PANEL_render SCRN.h&
        END IF

        ' Text formatting bar below menu bar
        IF TEXT_BAR.visible% THEN
            TEXT_BAR.needsRedraw% = TRUE ' GUI buffer cleared — always redraw
            TEXT_BAR_render
            TEXT_BAR_sync_paint_color
        END IF

        ' Menu bar renders LAST so submenus overlay other widgets
        IF SCRN.showMenubar% AND MENU_BAR.visible% THEN
            MENUBAR_render
        END IF

        ' Palette menu renders AFTER menubar so it overlays the bar
        IF PALETTE_MENU_VISIBLE% THEN PALETTE_MENU_render
    END IF

    _DEST SCRN.CANVAS&
END SUB


''
' Draws screen
' 
SUB SCREEN_render ()
    PERF_start PERF_RENDER_TOTAL
    DIM so_used_fallback AS INTEGER ' TRUE when STATUS-ONLY fallback routes to SkipToPointer
    ' ========================================================================
    ' GUI-ONLY REFRESH: When only GUI elements changed (e.g. brush size in
    ' status bar) but the scene (layers, grid) hasn't, re-composite just the
    ' GUI overlay onto the cached scene. Avoids expensive layer compositing,
    ' grid rendering, and transparency checkerboard.
    ' ========================================================================
    IF NOT SCENE_DIRTY% AND GUI_NEEDS_REDRAW% AND SCENE_CACHE& <> 0 THEN
        PERF_start PERF_GUI_ONLY_PATH
        SCREEN_compute_layout
        ' Re-render GUI elements with updated content
        _DEST SCRN.GUI&
        CLS , _RGBA32(0, 0, 0, 0)
        IF SCRN.showToolbar% THEN
            TOOLBAR_render 0, 0, TB_TOTAL - 1
            ' Organizer sits directly beneath toolbar
            DIM org_s2  AS INTEGER
            DIM org_ty2 AS INTEGER
            org_s2% = CFG.TOOLBAR_SCALE%
            IF org_s2% < 1 THEN org_s2% = 1
            IF org_s2% > 4 THEN org_s2% = 4
            org_ty2% = TB_TOP + (TB_ROWS * TB_BTN_H * org_s2%) + ((TB_ROWS - 1) * TB_BTN_PADDING * org_s2%)
            ORGANIZER_render org_ty2%
            DRAWER_render
        END IF
        IF SCRN.showEditBar% THEN
            EDITBAR_render
        END IF
        IF SCRN.showAdvBar% THEN
            ADVBAR_render
        END IF

        IF SCRN.showCharMap% THEN
            CHARMAP_render
        END IF

        IF SCRN.showStatus% THEN
            PALETTE_STRIP_render
            STATUS_render
        END IF

        IF LAYER_PANEL.visible% THEN
            LAYER_PANEL_render SCRN.h&
        END IF

        ' Text formatting bar below menu bar
        IF TEXT_BAR.visible% THEN
            TEXT_BAR.needsRedraw% = TRUE ' GUI buffer cleared — always redraw
            TEXT_BAR_render
            TEXT_BAR_sync_paint_color
        END IF

        ' Menu bar renders LAST so submenus overlay other widgets
        IF SCRN.showMenubar% AND MENU_BAR.visible% THEN
            MENUBAR_render
        END IF

        ' Palette menu renders AFTER menubar so it overlays the bar
        IF PALETTE_MENU_VISIBLE% THEN PALETTE_MENU_render

        ' Restore cached scene, overlay updated GUI, update cache
        _DEST SCRN.CANVAS&
        _DONTBLEND SCRN.CANVAS&
        _PUTIMAGE , SCENE_CACHE&, SCRN.CANVAS&
        _BLEND SCRN.CANVAS&
        _PUTIMAGE , SCRN.GUI&, SCRN.CANVAS&

        ' Scrollbar overlay (on top of GUI)
        SCROLLBAR_update
        SCROLLBAR_render

        ' NOTE: Do NOT save SCRN.CANVAS& back to SCENE_CACHE& here.
        ' The scene cache must contain only the scene (layers+grid), not GUI
        ' overlays. Baking GUI into the cache causes stacking artifacts when
        ' popups move (e.g. font subfolder menus) because the old popup
        ' position gets baked into the cache and composited under the new GUI.

        ' Jump to pointer+selection+upscale — must NOT fall through to
        ' dirty-rect, which only upscales the pointer region and would
        ' leave the updated GUI invisible in the window image.
        STATUS_NEEDS_REDRAW% = FALSE
        PERF_stop PERF_GUI_ONLY_PATH
        GOTO SkipToPointer
    END IF

    ' ========================================================================
    ' STATUS-ONLY REFRESH: Mouse moved over canvas — only cursor coordinates
    ' in the status bar changed.  Fully self-contained: partial blits for
    ' pointer dirty-rect + status strip only, partial window present, EXIT SUB.
    ' Never touches the palette strip swatch loop or does any full-frame copy.
    ' Falls back to SkipToPointer only when partial present is unsafe.
    ' ========================================================================
    IF NOT SCENE_DIRTY% AND NOT GUI_NEEDS_REDRAW% AND STATUS_NEEDS_REDRAW% AND SCENE_CACHE& <> 0 THEN
        PERF_start PERF_GUI_ONLY_PATH
        ' SCREEN_compute_layout is intentionally skipped here.
        ' STATUS-ONLY fires only when NOT GUI_NEEDS_REDRAW%, meaning the GUI
        ' (and therefore layout) is unchanged from the last full or GUI-only
        ' render — the values computed then are still valid.

        ' Same partial-present safety gates as the dirty-rect path.
        ' PREVIEW.visible% is no longer a gate here: we call PREVIEW_render inline
        ' and present the preview window rect as a separate partial present, so the
        ' expensive full-frame window scale is never needed just for canvas hover.
        DIM so_can_partial AS INTEGER
        so_can_partial% = NOT SCRN.patternTileMode%
        IF IMG_IMPORT.STATE > IMPORT_STATE_IDLE THEN so_can_partial% = FALSE
        IF REFIMG.REPOSITION THEN so_can_partial% = FALSE
        IF CURRENT_TOOL% = TOOL_MOVE AND MOVE.ACTIVE THEN so_can_partial% = FALSE
        IF CURRENT_TOOL% = TOOL_PICKER AND PICKER.ACTIVE% THEN so_can_partial% = FALSE
        IF LAYER_PANEL.blendPopupOpen% OR DRAWER.contextMenuOpen% OR CMD_PALETTE.visible THEN so_can_partial% = FALSE
        IF TOOLTIP.ACTIVE% THEN so_can_partial% = FALSE  ' Tooltip needs full SkipToPointer path
        IF MENUBAR_is_open% THEN so_can_partial% = FALSE             ' Menu dropdowns need full GUI composite over preview
        IF PREVIEW.floatTooltipActive% THEN so_can_partial% = FALSE   ' Float tooltip extends beyond preview bounds
        IF CURRENT_TOOL% = TOOL_TEXT AND NOT TEXT.ACTIVE THEN so_can_partial% = FALSE  ' Text hover outline needs SkipToPointer path

        ' Update only the pure status bar row in SCRN.GUI& (NOT palette strip).
        DIM so_statusTop AS INTEGER
        so_statusTop% = SCRN.h& - THEME.STATUS_height%
        IF so_statusTop% < 0 THEN so_statusTop% = 0
        IF SCRN.showStatus% THEN
            _DEST SCRN.GUI&
            LINE (0, so_statusTop%)-(SCRN.w& - 1, SCRN.h& - 1), _RGBA32(0, 0, 0, 0), BF
            STATUS_render
            _DEST SCRN.CANVAS&
        END IF

        IF so_can_partial% THEN
            ' Build union dirty rect: old pointer position + new pointer position.
            DIM so_pad AS INTEGER
            so_pad% = POINTER_get_dirty_pad%
            DIM so_nx  AS INTEGER, so_ny AS INTEGER
            so_nx% = MOUSE.RAW_X%
            so_ny% = MOUSE.RAW_Y%
            DIM so_px1 AS INTEGER, so_py1 AS INTEGER, so_px2 AS INTEGER, so_py2 AS INTEGER
            so_px1% = so_nx% - so_pad%
            so_py1% = so_ny% - so_pad%
            so_px2% = so_nx% + so_pad%
            so_py2% = so_ny% + so_pad%
            IF POINTER.PREV_DRAW_X% > -9999 THEN
                DIM so_opx AS INTEGER, so_opy AS INTEGER
                so_opx% = POINTER.PREV_DRAW_X%
                so_opy% = POINTER.PREV_DRAW_Y%
                IF so_opx% - so_pad% < so_px1% THEN so_px1% = so_opx% - so_pad%
                IF so_opy% - so_pad% < so_py1% THEN so_py1% = so_opy% - so_pad%
                IF so_opx% + so_pad% > so_px2% THEN so_px2% = so_opx% + so_pad%
                IF so_opy% + so_pad% > so_py2% THEN so_py2% = so_opy% + so_pad%
            END IF
            IF so_px1% < 0 THEN so_px1% = 0
            IF so_py1% < 0 THEN so_py1% = 0
            IF so_px2% >= SCRN.w& THEN so_px2% = SCRN.w& - 1
            IF so_py2% >= SCRN.h& THEN so_py2% = SCRN.h& - 1

            ' Restore pointer area from scene cache (erase old ghost).
            _DEST SCRN.CANVAS&
            _DONTBLEND SCRN.CANVAS&
            _PUTIMAGE (so_px1%, so_py1%)-(so_px2%, so_py2%), SCENE_CACHE&, SCRN.CANVAS&, (so_px1%, so_py1%)-(so_px2%, so_py2%)
            _BLEND SCRN.CANVAS&

            ' Selection overlay (marching ants animate every frame).
            IF SELECTION_has_active% THEN
                IF MARQUEE.WAND_HAS_SELECTION AND MARQUEE.SELECTION_MASK < -1 THEN
                    _DEST SCRN.CANVAS&
                    MAGIC_WAND_draw_outline
                ELSEIF MARQUEE.ACTIVE% AND MARQUEE.USER_CREATED THEN
                    IF MARQUEE.DRAGGING% AND MARQUEE.SELECTION_MODE <> SEL_MODE_REPLACE THEN
                        _DEST SCRN.CANVAS&
                        MARQUEE_draw_existing_box TRUE
                    ELSE
                        _DEST SCRN.CANVAS&
                        MARQUEE_draw TRUE
                    END IF
                END IF
            END IF

            ' Draw pointer at new position.
            POINTER_update
            POINTER_render

            ' Preview window: only re-render when content has actually changed.
            ' In follow-pointer mode the viewport pans with the cursor — must re-render every frame.
            ' Otherwise content is static unless the pointer dirty-rect overlaps the preview window,
            ' which would expose a SCENE_CACHE hole that needs repairing.
            ' Skipping saves an expensive _PUTIMAGE of COMPOSITE_BUFFER& per frame.
            IF PREVIEW.visible% AND NOT PREVIEW.autoHidden% THEN
                DIM so_pv_need_render AS INTEGER
                so_pv_need_render% = PREVIEW.followPointer%
                IF NOT so_pv_need_render% THEN
                    ' Check if pointer dirty-rect overlaps preview bounds
                    IF so_px2% >= PREVIEW.x% AND so_px1% <= PREVIEW.x% + PREVIEW.w% - 1 AND _
                       so_py2% >= PREVIEW.y% AND so_py1% <= PREVIEW.y% + PREVIEW.h% - 1 THEN
                        so_pv_need_render% = TRUE
                    END IF
                END IF
                IF so_pv_need_render% THEN
                    PREVIEW_render SCRN.CANVAS&
                END IF
            END IF

            _DEST SCRN.CANVAS&
            _PUTIMAGE (so_px1%, so_py1%)-(so_px2%, so_py2%), SCRN.GUI&, SCRN.CANVAS&, (so_px1%, so_py1%)-(so_px2%, so_py2%)

            ' Status strip: restore from SCENE_CACHE, overlay updated GUI,
            ' write back to SCENE_CACHE so next dirty-rect frame has correct cache.
            IF SCRN.showStatus% THEN
                _DEST SCRN.CANVAS&
                _DONTBLEND SCRN.CANVAS&
                _PUTIMAGE (0, so_statusTop%)-(SCRN.w& - 1, SCRN.h& - 1), SCENE_CACHE&, SCRN.CANVAS&, (0, so_statusTop%)-(SCRN.w& - 1, SCRN.h& - 1)
                _BLEND SCRN.CANVAS&
                _PUTIMAGE (0, so_statusTop%)-(SCRN.w& - 1, SCRN.h& - 1), SCRN.GUI&, SCRN.CANVAS&, (0, so_statusTop%)-(SCRN.w& - 1, SCRN.h& - 1)
                _DEST SCENE_CACHE&
                _DONTBLEND SCENE_CACHE&
                _PUTIMAGE (0, so_statusTop%)-(SCRN.w& - 1, SCRN.h& - 1), SCRN.CANVAS&, SCENE_CACHE&, (0, so_statusTop%)-(SCRN.w& - 1, SCRN.h& - 1)
                _BLEND SCENE_CACHE&
                _DEST SCRN.CANVAS&
            END IF

            SCROLLBAR_render
            RENDER_crosshair_and_command_palette
            POINTER_render_cursor_overlay
            PREVIEW_render_tooltip SCRN.CANVAS&
            TOOLTIP_render SCRN.CANVAS&

            POINTER.PREV_DRAW_X% = so_nx%
            POINTER.PREV_DRAW_Y% = so_ny%

            ' Partial window presents: pointer area + status strip + preview window.
            ' Avoids the expensive full-frame _PUTIMAGE scale to window.
            DIM so_sc     AS INTEGER
            DIM so_winW   AS LONG, so_winH AS LONG
            DIM so_exactW AS LONG, so_exactH AS LONG
            so_sc% = SCRN.displayScale%
            IF so_sc% < 1 THEN so_sc% = 1
            so_winW&   = _WIDTH(0)
            so_winH&   = _HEIGHT(0)
            so_exactW& = CLNG(SCRN.w&) * so_sc%
            so_exactH& = CLNG(SCRN.h&) * so_sc%
            IF so_winW& <> so_exactW& OR so_winH& <> so_exactH& THEN
                _DEST 0
                _DONTBLEND 0
                LINE (0, 0)-(so_winW& - 1, so_winH& - 1), CFG.CANVAS_APRON_COLOR~&, BF
                _BLEND 0
            END IF
            _PUTIMAGE (CLNG(so_px1%) * so_sc%, CLNG(so_py1%) * so_sc%)-(CLNG(so_px2% + 1) * so_sc% - 1, CLNG(so_py2% + 1) * so_sc% - 1), SCRN.CANVAS&, 0, (so_px1%, so_py1%)-(so_px2%, so_py2%)
            IF SCRN.showStatus% THEN
                _PUTIMAGE (0, CLNG(so_statusTop%) * so_sc%)-(_WIDTH(0) - 1, _HEIGHT(0) - 1), SCRN.CANVAS&, 0, (0, so_statusTop%)-(SCRN.w& - 1, SCRN.h& - 1)
            END IF
            ' Preview window partial present: present the preview widget area directly
            ' instead of doing a full-frame upscale just because preview is visible.
            IF PREVIEW.visible% AND NOT PREVIEW.autoHidden% THEN
                DIM so_pv_x1 AS INTEGER, so_pv_y1 AS INTEGER
                DIM so_pv_x2 AS INTEGER, so_pv_y2 AS INTEGER
                so_pv_x1% = PREVIEW.x%
                so_pv_y1% = PREVIEW.y%
                so_pv_x2% = PREVIEW.x% + PREVIEW.w% - 1
                IF PREVIEW.minimized% THEN
                    so_pv_y2% = PREVIEW.y% + THEME.PREVIEW_title_height% + THEME.PREVIEW_border_width% * 2 - 1
                ELSE
                    so_pv_y2% = PREVIEW.y% + PREVIEW.h% - 1
                END IF
                IF so_pv_x1% < 0 THEN so_pv_x1% = 0
                IF so_pv_y1% < 0 THEN so_pv_y1% = 0
                IF so_pv_x2% >= SCRN.w& THEN so_pv_x2% = SCRN.w& - 1
                IF so_pv_y2% >= SCRN.h& THEN so_pv_y2% = SCRN.h& - 1
                _PUTIMAGE (CLNG(so_pv_x1%) * so_sc%, CLNG(so_pv_y1%) * so_sc%)-(CLNG(so_pv_x2% + 1) * so_sc% - 1, CLNG(so_pv_y2% + 1) * so_sc% - 1), SCRN.CANVAS&, 0, (so_pv_x1%, so_pv_y1%)-(so_pv_x2%, so_pv_y2%)
            END IF

            ' ==== COLOR MIXER (after partial blit, draws directly to screen 0) ====
            COLORMIXER_render
            BROWSER_render
            TOOLTIP_reblit_to_screen0

            _DISPLAY
            STATUS_NEEDS_REDRAW% = FALSE
            GUI_NEEDS_REDRAW%    = FALSE
            PERF_stop PERF_GUI_ONLY_PATH
            PERF_stop PERF_RENDER_TOTAL
            EXIT SUB
        END IF

        ' Fallback when partial present is unsafe (preview visible, popup open, etc.).
        ' Still skips PALETTE_STRIP_render. Restore scene from cache and jump to
        ' SkipToPointer. SCRN.GUI& was updated with STATUS_render above, so
        ' SkipToPointer's GUI composite will reflect the new status.
        ' so_used_fallback% signals SkipToPointer to use a partial GUI composite
        ' (pointer dirty-rect + status strip only) instead of the expensive
        ' full-frame alpha-blend — the biggest per-frame cost on canvas hover.
        _DEST SCRN.CANVAS&
        _DONTBLEND SCRN.CANVAS&
        _PUTIMAGE , SCENE_CACHE&, SCRN.CANVAS&
        _BLEND SCRN.CANVAS&
        _DEST SCRN.CANVAS&
        ' When text tool hover forced us into this fallback (so_can_partial% was FALSE),
        ' use full GUI composite at SkipToPointer so the hover outline area is properly handled.
        IF CURRENT_TOOL% = TOOL_TEXT AND NOT TEXT.ACTIVE THEN
            so_used_fallback% = FALSE
        ELSE
            so_used_fallback% = TRUE
        END IF
        STATUS_NEEDS_REDRAW% = FALSE
        PERF_stop PERF_GUI_ONLY_PATH
        GOTO SkipToPointer
    END IF

    ' ========================================================================
    ' DIRTY-RECT FAST PATH: When the scene hasn't changed, restore+redraw
    ' only the regions that need updating (pointer area + selection overlay)
    ' instead of copying and scaling the full canvas every frame.
    ' ========================================================================
    IF NOT SCENE_DIRTY% AND SCENE_CACHE& <> 0 AND NOT SCRN.patternTileMode% THEN
        ' Skip dirty-rect optimization when popup overlays are open — they need
        ' full-frame consistency to avoid flicker and z-order artifacts with scrollbars.
        IF LAYER_PANEL.blendPopupOpen% OR DRAWER.contextMenuOpen% OR CMD_PALETTE.visible THEN
            _DEST SCRN.CANVAS&
            _DONTBLEND SCRN.CANVAS&
            _PUTIMAGE , SCENE_CACHE&, SCRN.CANVAS&
            _BLEND SCRN.CANVAS&
            GOTO SkipToPointer
        END IF

        PERF_start PERF_DIRTY_RECT_PATH
        DIM new_mx AS INTEGER, new_my AS INTEGER
        new_mx% = MOUSE.RAW_X%
        new_my% = MOUSE.RAW_Y%

        ' Dynamic padding: covers cursor PNG + brush preview + overlays
        DIM ptr_pad AS INTEGER
        ptr_pad% = POINTER_get_dirty_pad%

        ' Build union bounding box of old + new pointer areas (canvas coords)
        DIM dr_x1 AS INTEGER, dr_y1 AS INTEGER
        DIM dr_x2 AS INTEGER, dr_y2 AS INTEGER

        IF POINTER.PREV_DRAW_X% <= -9999 THEN
            ' First frame after full render — use new position only
            dr_x1% = new_mx% - ptr_pad%
            dr_y1% = new_my% - ptr_pad%
            dr_x2% = new_mx% + ptr_pad%
            dr_y2% = new_my% + ptr_pad%
        ELSE
            ' Union of old rect + new rect
            DIM ox1 AS INTEGER, oy1 AS INTEGER, ox2 AS INTEGER, oy2 AS INTEGER
            ox1% = POINTER.PREV_DRAW_X% - ptr_pad%
            oy1% = POINTER.PREV_DRAW_Y% - ptr_pad%
            ox2% = POINTER.PREV_DRAW_X% + ptr_pad%
            oy2% = POINTER.PREV_DRAW_Y% + ptr_pad%

            dr_x1% = new_mx% - ptr_pad%
            dr_y1% = new_my% - ptr_pad%
            dr_x2% = new_mx% + ptr_pad%
            dr_y2% = new_my% + ptr_pad%

            IF ox1% < dr_x1% THEN dr_x1% = ox1%
            IF oy1% < dr_y1% THEN dr_y1% = oy1%
            IF ox2% > dr_x2% THEN dr_x2% = ox2%
            IF oy2% > dr_y2% THEN dr_y2% = oy2%
        END IF

        ' Expand dirty rect to include selection overlay (marching ants + handles)
        DIM has_sel AS INTEGER
        has_sel% = SELECTION_has_active%
        IF has_sel% THEN
            DIM sel_x1 AS INTEGER, sel_y1 AS INTEGER
            DIM sel_x2 AS INTEGER, sel_y2 AS INTEGER
            SELECTION_get_screen_bbox sel_x1%, sel_y1%, sel_x2%, sel_y2%
            IF sel_x1% < dr_x1% THEN dr_x1% = sel_x1%
            IF sel_y1% < dr_y1% THEN dr_y1% = sel_y1%
            IF sel_x2% > dr_x2% THEN dr_x2% = sel_x2%
            IF sel_y2% > dr_y2% THEN dr_y2% = sel_y2%
        END IF

        ' Clamp to canvas bounds
        IF dr_x1% < 0 THEN dr_x1% = 0
        IF dr_y1% < 0 THEN dr_y1% = 0
        IF dr_x2% >= SCRN.w& THEN dr_x2% = SCRN.w& - 1
        IF dr_y2% >= SCRN.h& THEN dr_y2% = SCRN.h& - 1

        ' Dirty-rect path only pays off when overlays stay local to the pointer area.
        ' Wider overlays are handled by the full cached-scene path below.
        ' PREVIEW.visible% is no longer a gate: preview is handled inline the same way
        ' as the STATUS-ONLY path (conditional render + separate partial window present).
        DIM can_partial_present AS INTEGER
        can_partial_present% = TRUE
        IF IMG_IMPORT.STATE > IMPORT_STATE_IDLE THEN can_partial_present% = FALSE
        IF REFIMG.REPOSITION THEN can_partial_present% = FALSE
        IF CURRENT_TOOL% = TOOL_MOVE AND MOVE.ACTIVE THEN can_partial_present% = FALSE
        IF CURRENT_TOOL% = TOOL_PICKER AND PICKER.ACTIVE% THEN can_partial_present% = FALSE
        IF TOOLTIP.ACTIVE% THEN can_partial_present% = FALSE  ' Tooltip needs full SkipToPointer path
        IF MENUBAR_is_open% THEN can_partial_present% = FALSE             ' Menu dropdowns need full GUI composite over preview
        IF PREVIEW.floatTooltipActive% THEN can_partial_present% = FALSE   ' Float tooltip extends beyond preview bounds
        IF CURRENT_TOOL% = TOOL_TEXT AND NOT TEXT.ACTIVE THEN can_partial_present% = FALSE  ' Text hover outline needs SkipToPointer path

        ' Area check: if dirty rect > half the canvas, or overlays are broader than the
        ' pointer region, fall back to full copy
        DIM dr_area AS LONG, canvas_area AS LONG
        dr_area&     = CLNG(dr_x2% - dr_x1% + 1) * CLNG(dr_y2% - dr_y1% + 1)
        canvas_area& = SCRN.w& * SCRN.h&

        IF can_partial_present% AND dr_area& < (canvas_area& \ 2) AND dr_x2% > dr_x1% AND dr_y2% > dr_y1% THEN
            ' --- Partial restore from scene cache (erase old pointer + ants) ---
            _DEST SCRN.CANVAS&
            _DONTBLEND SCRN.CANVAS&
            _PUTIMAGE (dr_x1%, dr_y1%)-(dr_x2%, dr_y2%), SCENE_CACHE&, SCRN.CANVAS&, (dr_x1%, dr_y1%)-(dr_x2%, dr_y2%)
            _BLEND SCRN.CANVAS&

            ' --- Redraw selection overlay (marching ants animate each frame) ---
            IF has_sel% THEN
                IF MARQUEE.WAND_HAS_SELECTION AND MARQUEE.SELECTION_MASK < -1 THEN
                    _DEST SCRN.CANVAS&
                    MAGIC_WAND_draw_outline
                ELSEIF MARQUEE.ACTIVE% AND MARQUEE.USER_CREATED THEN
                    IF MARQUEE.DRAGGING% AND MARQUEE.SELECTION_MODE <> SEL_MODE_REPLACE THEN
                        _DEST SCRN.CANVAS&
                        MARQUEE_draw_existing_box TRUE
                    ELSE
                        _DEST SCRN.CANVAS&
                        MARQUEE_draw TRUE
                    END IF
                END IF
            END IF

            ' --- Draw pointer at new position ---
            POINTER_update
            POINTER_render

            ' --- Clip pointer and selection overlays back behind fixed UI elements ---
            _DEST SCRN.CANVAS&
            _PUTIMAGE (dr_x1%, dr_y1%)-(dr_x2%, dr_y2%), SCRN.GUI&, SCRN.CANVAS&, (dr_x1%, dr_y1%)-(dr_x2%, dr_y2%)

            ' --- Preview window (inline, same logic as STATUS-ONLY path) ---
            ' Re-render only when follow-pointer mode is active (viewport pans with cursor)
            ' or when the pointer dirty-rect overlaps the preview window bounds
            ' (which would expose a SCENE_CACHE hole that needs repairing).
            IF PREVIEW.visible% AND NOT PREVIEW.autoHidden% THEN
                DIM dr_pv_need_render AS INTEGER
                dr_pv_need_render% = PREVIEW.followPointer%
                IF NOT dr_pv_need_render% THEN
                    IF dr_x2% >= PREVIEW.x% AND dr_x1% <= PREVIEW.x% + PREVIEW.w% - 1 AND _
                       dr_y2% >= PREVIEW.y% AND dr_y1% <= PREVIEW.y% + PREVIEW.h% - 1 THEN
                        dr_pv_need_render% = TRUE
                    END IF
                END IF
                IF dr_pv_need_render% THEN
                    PREVIEW_render SCRN.CANVAS&
                END IF
            END IF

            ' --- Crosshair assistant overlay ---
            RENDER_crosshair_and_command_palette
            
            ' --- Scrollbar overlay on top of GUI ---
            SCROLLBAR_render

            ' --- Contextual status bars ---
            IF IMG_IMPORT.STATE > IMPORT_STATE_IDLE THEN
                _DEST SCRN.CANVAS&
                IMAGE_IMPORT_draw_status SCRN.CANVAS&
            ELSEIF REFIMG.REPOSITION THEN
                _DEST SCRN.CANVAS&
                REFIMG_render_status SCRN.CANVAS&
            ELSEIF CURRENT_TOOL% = TOOL_MOVE AND MOVE.ACTIVE THEN
                _DEST SCRN.CANVAS&
                MOVE_render_status SCRN.CANVAS&
            END IF

            IF CURRENT_TOOL% = TOOL_PICKER AND PICKER.ACTIVE% AND _
               SCREEN_mouse_over_work_area%(MOUSE.RAW_X%, MOUSE.RAW_Y%) THEN
                PICKER_LOUPE_render SCRN.CANVAS&
                PREVIEW_render_loupe SCRN.CANVAS&
            END IF

            ' --- Final overlay popups (must stay above GUI, scrollbars, and status overlays) ---
            IF LAYER_PANEL.blendPopupOpen% THEN
                LAYER_PANEL_blend_popup_render
            END IF
            IF LAYER_PANEL.ctxMenuOpen% THEN
                LAYER_PANEL_ctx_menu_render
            END IF
            IF DRAWER.contextMenuOpen% THEN
                DRAWER_context_menu_render
            END IF
            IF CMD_PALETTE.visible THEN
                CMD_render SCRN.CANVAS&
            END IF
            
            ' --- Redraw cursor on top of GUI ---
            POINTER_render_cursor_overlay
            PREVIEW_render_tooltip SCRN.CANVAS&
            TOOLTIP_render SCRN.CANVAS&

            ' --- Save pointer position for next frame ---
            POINTER.PREV_DRAW_X% = new_mx%
            POINTER.PREV_DRAW_Y% = new_my%

            ' Present only the scaled dirty rectangle to the window.
            DIM dr_scale  AS INTEGER
            DIM dr_winW   AS LONG, dr_winH AS LONG
            DIM dr_exactW AS LONG, dr_exactH AS LONG
            DIM win_x1    AS LONG, win_y1 AS LONG, win_x2 AS LONG, win_y2 AS LONG
            dr_scale% = SCRN.displayScale%
            IF dr_scale% < 1 THEN dr_scale% = 1
            dr_winW&   = _WIDTH(0)
            dr_winH&   = _HEIGHT(0)
            dr_exactW& = CLNG(SCRN.w&) * dr_scale%
            dr_exactH& = CLNG(SCRN.h&) * dr_scale%
            IF dr_winW& <> dr_exactW& OR dr_winH& <> dr_exactH& THEN
                _DEST 0
                _DONTBLEND 0
                LINE (0, 0)-(dr_winW& - 1, dr_winH& - 1), CFG.CANVAS_APRON_COLOR~&, BF
                _BLEND 0
            END IF
            win_x1& = CLNG(dr_x1%) * dr_scale%
            win_y1& = CLNG(dr_y1%) * dr_scale%
            win_x2& = CLNG(dr_x2% + 1) * dr_scale% - 1
            win_y2& = CLNG(dr_y2% + 1) * dr_scale% - 1
            _PUTIMAGE (win_x1&, win_y1&)-(win_x2&, win_y2&), SCRN.CANVAS&, 0, (dr_x1%, dr_y1%)-(dr_x2%, dr_y2%)

            ' Preview window partial present (avoids full-frame upscale just for preview)
            IF PREVIEW.visible% AND NOT PREVIEW.autoHidden% THEN
                DIM dr_pv_x1 AS INTEGER, dr_pv_y1 AS INTEGER
                DIM dr_pv_x2 AS INTEGER, dr_pv_y2 AS INTEGER
                dr_pv_x1% = PREVIEW.x%
                dr_pv_y1% = PREVIEW.y%
                dr_pv_x2% = PREVIEW.x% + PREVIEW.w% - 1
                IF PREVIEW.minimized% THEN
                    dr_pv_y2% = PREVIEW.y% + THEME.PREVIEW_title_height% + THEME.PREVIEW_border_width% * 2 - 1
                ELSE
                    dr_pv_y2% = PREVIEW.y% + PREVIEW.h% - 1
                END IF
                IF dr_pv_x1% < 0 THEN dr_pv_x1% = 0
                IF dr_pv_y1% < 0 THEN dr_pv_y1% = 0
                IF dr_pv_x2% >= SCRN.w& THEN dr_pv_x2% = SCRN.w& - 1
                IF dr_pv_y2% >= SCRN.h& THEN dr_pv_y2% = SCRN.h& - 1
                _PUTIMAGE (CLNG(dr_pv_x1%) * dr_scale%, CLNG(dr_pv_y1%) * dr_scale%)-(CLNG(dr_pv_x2% + 1) * dr_scale% - 1, CLNG(dr_pv_y2% + 1) * dr_scale% - 1), SCRN.CANVAS&, 0, (dr_pv_x1%, dr_pv_y1%)-(dr_pv_x2%, dr_pv_y2%)
            END IF

            ' ==== FLOATING PANELS (after partial blit, draw directly to screen 0) ====
            COLORMIXER_render
            BROWSER_render
            TOOLTIP_reblit_to_screen0

            PERF_stop PERF_DIRTY_RECT_PATH
            PERF_start PERF_DISPLAY_CALL
            _DISPLAY
            PERF_stop PERF_DISPLAY_CALL
            STATUS_NEEDS_REDRAW% = FALSE
            GUI_NEEDS_REDRAW%    = FALSE
            PERF_stop PERF_RENDER_TOTAL
            EXIT SUB
        END IF
        ' --- Dirty rect too large: fall through to full-copy fast path ---

        ' Full-copy fast path (selection covers too much area)
        PERF_stop PERF_DIRTY_RECT_PATH
        _DEST SCRN.CANVAS&
        _DONTBLEND SCRN.CANVAS&
        _PUTIMAGE , SCENE_CACHE&, SCRN.CANVAS&
        _BLEND SCRN.CANVAS&
        GOTO SkipToPointer
    END IF

    ' todo get status to hide when painting 
    PERF_start PERF_FULL_CLS_GUI
    _DEST SCRN.CANVAS&
    _DONTBLEND SCRN.CANVAS&
    CLS , CFG.CANVAS_APRON_COLOR~&
    _BLEND SCRN.CANVAS&
    
    ' Clear GUI layer and render toolbar/status conditionally
    ' Only redraw GUI elements when GUI_NEEDS_REDRAW is TRUE (optimization)
    RENDER_gui_elements
    PERF_stop PERF_FULL_CLS_GUI
    
    ' Calculate zoomed dimensions and position (using canvas dimensions, centered in viewport)
    DIM zw AS LONG, zh AS LONG, dx AS INTEGER, dy AS INTEGER
    IF SCRN.patternTileMode% THEN
        ' In tile mode, compute viewport for the full 3x3 area
        DIM totalZW AS LONG, totalZH AS LONG
        totalZW& = SCRN.canvasW& * 3 * SCRN.zoom!
        totalZH& = SCRN.canvasH& * 3 * SCRN.zoom!
        DIM baseDX  AS INTEGER, baseDY AS INTEGER
        baseDX% = (SCRN.w& - totalZW&) \ 2 + SCRN.offsetX% + SCRN.panelShiftX%
        baseDY% = (SCRN.h& - totalZH&) \ 2 + SCRN.offsetY%
        ' Single-tile zoomed size
        zw& = SCRN.canvasW& * SCRN.zoom!
        zh& = SCRN.canvasH& * SCRN.zoom!
        ' Center tile origin (the source tile)
        dx% = baseDX% + zw&
        dy% = baseDY% + zh&
    ELSE
        zw& = SCRN.canvasW& * SCRN.zoom!
        zh& = SCRN.canvasH& * SCRN.zoom!
        dx% = (SCRN.w& - zw&) \ 2 + SCRN.offsetX% + SCRN.panelShiftX%
        dy% = (SCRN.h& - zh&) \ 2 + SCRN.offsetY%
    END IF

    IF SCRN.patternTileMode% THEN
        ' ====== PATTERN TILE MODE: Render 3x3 grid of tiles ======
        DIM tRow AS INTEGER, tCol AS INTEGER
        DIM tdx  AS INTEGER, tdy AS INTEGER

        ' Render checkerboard, layers, ref image, and grids for each tile
        PERF_start PERF_FULL_CHECKERBOARD
        FOR tRow% = -1 TO 1
            FOR tCol% = -1 TO 1
                tdx% = dx% + tCol% * zw&
                tdy% = dy% + tRow% * zh&
                TRANSPARENCY_render SCRN.CANVAS&, tdx%, tdy%, zw&, zh&
            NEXT tCol%
        NEXT tRow%
        PERF_stop PERF_FULL_CHECKERBOARD

        ' Grid behind art (when GRID_ON_TOP is off)
        IF NOT CFG.GRID_ON_TOP% THEN
            PERF_start PERF_FULL_GRIDS
            FOR tRow% = -1 TO 1
                FOR tCol% = -1 TO 1
                    tdx% = dx% + tCol% * zw&
                    tdy% = dy% + tRow% * zh&
                    RENDER_grids tdx%, tdy%, zw&, zh&
                NEXT tCol%
            NEXT tRow%
            PERF_stop PERF_FULL_GRIDS
        END IF

        PERF_start PERF_FULL_LAYERS
        FOR tRow% = -1 TO 1
            FOR tCol% = -1 TO 1
                tdx% = dx% + tCol% * zw&
                tdy% = dy% + tRow% * zh&
                RENDER_layers tdx%, tdy%, zw&, zh&
            NEXT tCol%
        NEXT tRow%
        PERF_stop PERF_FULL_LAYERS

        ' Reference image — render on center tile only
        IF REFIMG.IMAGE < -1 AND REFIMG.VISIBLE THEN
            REFIMG_render SCRN.CANVAS&, dx%, dy%, zw&, zh&
        END IF

        ' Grid on top of art (when GRID_ON_TOP is on)
        IF CFG.GRID_ON_TOP% THEN
            PERF_start PERF_FULL_GRIDS
            FOR tRow% = -1 TO 1
                FOR tCol% = -1 TO 1
                    tdx% = dx% + tCol% * zw&
                    tdy% = dy% + tRow% * zh&
                    RENDER_grids tdx%, tdy%, zw&, zh&
                NEXT tCol%
            NEXT tRow%
            PERF_stop PERF_FULL_GRIDS
        END IF

        ' Symmetry guides — center tile only
        PERF_start PERF_FULL_SYMMETRY
        IF SYMMETRY.MODE > 0 THEN
            IF SYMMETRY.imgHandle& = 0 OR _WIDTH(SYMMETRY.imgHandle&) <> zw& OR _HEIGHT(SYMMETRY.imgHandle&) <> zh& THEN
                IF SYMMETRY.imgHandle& < -1 THEN _FREEIMAGE SYMMETRY.imgHandle&
                SYMMETRY.imgHandle& = _NEWIMAGE(zw&, zh&, 32)
                SYMMETRY.DIRTY%     = TRUE
            END IF
            SYMMETRY_render_guides zw&, zh&, SCRN.zoom!
            _DEST SCRN.CANVAS&
            _BLEND SCRN.CANVAS&
            _PUTIMAGE (dx%, dy%), SYMMETRY.imgHandle&, SCRN.CANVAS&
        END IF
        PERF_stop PERF_FULL_SYMMETRY

        ' Draw tile boundaries and center border (controlled by # toggle)
        IF SCRN.showCanvasBorder% THEN
            _DEST SCRN.CANVAS&
            DIM tileBorderColor   AS _UNSIGNED LONG
            DIM tileBorderAlpha   AS INTEGER
            tileBorderAlpha% = INT(SCRN.canvasBorderOpacity% * 0.8 * 2.55)
            IF tileBorderAlpha% > 255 THEN tileBorderAlpha% = 255
            IF tileBorderAlpha% < 1 THEN tileBorderAlpha% = 1
            tileBorderColor~& = _RGBA32(128, 128, 128, tileBorderAlpha%)
            FOR tRow% = -1 TO 1
                FOR tCol% = -1 TO 1
                    tdx% = dx% + tCol% * zw&
                    tdy% = dy% + tRow% * zh&
                    LINE (tdx% - 1, tdy% - 1)-(tdx% + zw&, tdy% + zh&), tileBorderColor~&, B
                NEXT tCol%
            NEXT tRow%
            ' Center tile border (brighter to indicate source)
            DIM centerAlpha       AS INTEGER
            centerAlpha% = INT(SCRN.canvasBorderOpacity% * 2.55)
            IF centerAlpha% > 255 THEN centerAlpha% = 255
            IF centerAlpha% < 1 THEN centerAlpha% = 1
            DIM centerBorderColor AS _UNSIGNED LONG
            centerBorderColor~& = _RGBA32(_RED32(THEME.CANVAS_border~&), _GREEN32(THEME.CANVAS_border~&), _BLUE32(THEME.CANVAS_border~&), centerAlpha%)
            LINE (dx% - 1, dy% - 1)-(dx% + zw&, dy% + zh&), centerBorderColor~&, B
        END IF
    ELSE
        ' ====== NORMAL MODE: Single canvas render ======
        PERF_start PERF_FULL_CHECKERBOARD
        TRANSPARENCY_render SCRN.CANVAS&, dx%, dy%, zw&, zh&
        PERF_stop PERF_FULL_CHECKERBOARD

        ' Grid behind art (when GRID_ON_TOP is off)
        IF NOT CFG.GRID_ON_TOP% THEN
            PERF_start PERF_FULL_GRIDS
            RENDER_grids dx%, dy%, zw&, zh&
            PERF_stop PERF_FULL_GRIDS
        END IF

        PERF_start PERF_FULL_LAYERS
        RENDER_layers dx%, dy%, zw&, zh&
        PERF_stop PERF_FULL_LAYERS

        ' ==== REFERENCE IMAGE (above layers, behind grid) ====
        IF REFIMG.IMAGE < -1 AND REFIMG.VISIBLE THEN
            REFIMG_render SCRN.CANVAS&, dx%, dy%, zw&, zh&
        END IF
        ' ==== END REFERENCE IMAGE ====

        ' Grid on top of art (when GRID_ON_TOP is on)
        IF CFG.GRID_ON_TOP% THEN
            PERF_start PERF_FULL_GRIDS
            RENDER_grids dx%, dy%, zw&, zh&
            PERF_stop PERF_FULL_GRIDS
        END IF

        ' Draw symmetry guide overlay (after grids, before border/GUI)
        PERF_start PERF_FULL_SYMMETRY
        IF SYMMETRY.MODE > 0 THEN
            ' Recreate guide image if size changed
            IF SYMMETRY.imgHandle& = 0 OR _WIDTH(SYMMETRY.imgHandle&) <> zw& OR _HEIGHT(SYMMETRY.imgHandle&) <> zh& THEN
                IF SYMMETRY.imgHandle& < -1 THEN _FREEIMAGE SYMMETRY.imgHandle&
                SYMMETRY.imgHandle& = _NEWIMAGE(zw&, zh&, 32)
                SYMMETRY.DIRTY%     = TRUE
            END IF

            ' (Logging removed from render path for performance)
            SYMMETRY_render_guides zw&, zh&, SCRN.zoom!
            _DEST SCRN.CANVAS&
            _BLEND SCRN.CANVAS&          ' Use alpha blending for transparency
            _PUTIMAGE (dx%, dy%), SYMMETRY.imgHandle&, SCRN.CANVAS&
        END IF
        PERF_stop PERF_FULL_SYMMETRY

        ' Draw border around canvas (after painting layer)
        ' Hide border when all UI panels are hidden (F11 full canvas mode)
        IF SCRN.showCanvasBorder% AND (SCRN.showToolbar% OR SCRN.showStatus% OR LAYER_PANEL.visible% OR MENU_BAR.visible%) THEN
            DIM normBorderAlpha AS INTEGER
            normBorderAlpha% = INT(SCRN.canvasBorderOpacity% * 2.55)
            IF normBorderAlpha% > 255 THEN normBorderAlpha% = 255
            IF normBorderAlpha% < 1 THEN normBorderAlpha% = 1
            DIM normBorderColor AS _UNSIGNED LONG
            normBorderColor~& = _RGBA32(_RED32(THEME.CANVAS_border~&), _GREEN32(THEME.CANVAS_border~&), _BLUE32(THEME.CANVAS_border~&), normBorderAlpha%)
            LINE (dx% - 1, dy% - 1)-(dx% + zw&, dy% + zh&), normBorderColor~&, B
        END IF
    END IF
    
    ' ==== IMAGE IMPORT PREVIEW ====
    ' Draw import preview if in import mode (on top of painting, below GUI)
    IF IMG_IMPORT.STATE > IMPORT_STATE_IDLE THEN
        _DEST SCRN.CANVAS&
        IMAGE_IMPORT_draw SCRN.CANVAS&
    END IF
    ' ==== END IMAGE IMPORT PREVIEW ====

    ' ==== CROP OVERLAY ====
    IF CROP.STATE = CROP_STATE_ACTIVE THEN
        _DEST SCRN.CANVAS&
        CROP_render SCRN.CANVAS&
        ' Re-render grid on top of the crop overlay so it stays visible
        ' when the grid was showing before entering crop mode.
        RENDER_grids dx%, dy%, zw&, zh&
    END IF
    ' ==== END CROP OVERLAY ====

    ' ==== TRANSFORM OVERLAY (same position as IMPORT/CROP: above layers, below GUI) ====
    IF TRANSFORM.ACTIVE THEN
        _DEST SCRN.CANVAS&
        _BLEND SCRN.CANVAS&
        TRANSFORM_render_overlay
    END IF
    ' ==== END TRANSFORM OVERLAY ====

    ' ==== FILL ADJ OVERLAY ====
    IF FILL_ADJ.ACTIVE% THEN
        _DEST SCRN.CANVAS&
        _BLEND SCRN.CANVAS&
        FILL_ADJ_render_overlay
    END IF
    ' ==== END FILL ADJ OVERLAY ====

    ' ==== TOOL PREVIEWS (BEFORE GUI LAYER) ====
    PERF_start PERF_FULL_TOOL_PREVIEW
    RENDER_tool_previews dx%, dy%, zw&, zh&
    PERF_stop PERF_FULL_TOOL_PREVIEW
    
    ' ==== GUI LAYER (AFTER TOOL PREVIEWS) ====
    PERF_start PERF_FULL_GUI_OVERLAY
    _DEST SCRN.CANVAS& : _SOURCE SCRN.GUI& : _PUTIMAGE
    PERF_stop PERF_FULL_GUI_OVERLAY
    
    ' Render crosshair AFTER GUI layer so it's visible (using SHIFT key alone)
    ' Skip when Text tool is active (SHIFT is used for uppercase letters)
    ' Skip when CTRL or ALT are also held (those are modifier combos for other functions)
    PERF_start PERF_FULL_CROSSHAIR_CMD
    RENDER_crosshair_and_command_palette
    PERF_stop PERF_FULL_CROSSHAIR_CMD
    
    ' Render scrollbars on top of GUI (overlay when canvas > viewport)
    SCROLLBAR_update
    SCROLLBAR_render
    
    ' Save scene to cache (everything rendered, before cursor)
    PERF_start PERF_SCENE_CACHE_SAVE
    IF SCENE_CACHE& = 0 OR _WIDTH(SCENE_CACHE&) <> SCRN.w& OR _HEIGHT(SCENE_CACHE&) <> SCRN.h& THEN
        IF SCENE_CACHE& < -1 THEN _FREEIMAGE SCENE_CACHE&
        SCENE_CACHE& = _NEWIMAGE(SCRN.w&, SCRN.h&, 32)
    END IF
    _DEST SCENE_CACHE&
    _DONTBLEND SCENE_CACHE&
    _PUTIMAGE , SCRN.CANVAS&, SCENE_CACHE&
    _BLEND SCENE_CACHE&
    _DEST SCRN.CANVAS&
    SCENE_DIRTY% = FALSE
    PERF_stop PERF_SCENE_CACHE_SAVE

    SkipToPointer:
    ' ==== SELECTION OVERLAY (after scene cache, animates without full re-render) ====
    PERF_start PERF_SELECTION_OVERLAY
    RENDER_selection_overlay
    PERF_stop PERF_SELECTION_OVERLAY

    ' ==== SMART GUIDES (show alignment lines when moving layers) ====
    IF SMART_GUIDES.ENABLED% AND MOVE.TRANSFORMING AND (SMART_GUIDES.hCount% > 0 OR SMART_GUIDES.vCount% > 0) THEN
        DIM sgZW AS LONG, sgZH AS LONG
        DIM sgDX AS INTEGER, sgDY AS INTEGER
        sgZW& = SCRN.canvasW& * SCRN.zoom!
        sgZH& = SCRN.canvasH& * SCRN.zoom!
        IF SCRN.patternTileMode% THEN
            sgDX% = (SCRN.w& - sgZW& * 3) \ 2 + SCRN.offsetX% + sgZW&
            sgDY% = (SCRN.h& - sgZH& * 3) \ 2 + SCRN.offsetY% + sgZH&
        ELSE
            sgDX% = (SCRN.w& - sgZW&) \ 2 + SCRN.offsetX% + SCRN.panelShiftX%
            sgDY% = (SCRN.h& - sgZH&) \ 2 + SCRN.offsetY%
        END IF
        SMART_GUIDES_render SCRN.CANVAS&, sgDX%, sgDY%, SCRN.zoom!
    END IF

    ' ==== TEXT LAYER HOVER OUTLINE (after scene cache, moves with mouse) ====
    IF CURRENT_TOOL% = TOOL_TEXT AND NOT TEXT.ACTIVE THEN
        ' Compute canvas-to-screen offset locally (dx%/dy% from the main
        ' render path are not set when we arrive via GOTO SkipToPointer).
        DIM hovZW AS LONG, hovZH AS LONG
        DIM hovDX AS INTEGER, hovDY AS INTEGER
        hovZW& = SCRN.canvasW& * SCRN.zoom!
        hovZH& = SCRN.canvasH& * SCRN.zoom!
        IF SCRN.patternTileMode% THEN
            hovDX% = (SCRN.w& - hovZW& * 3) \ 2 + SCRN.offsetX% + hovZW&
            hovDY% = (SCRN.h& - hovZH& * 3) \ 2 + SCRN.offsetY% + hovZH&
        ELSE
            hovDX% = (SCRN.w& - hovZW&) \ 2 + SCRN.offsetX% + SCRN.panelShiftX%
            hovDY% = (SCRN.h& - hovZH&) \ 2 + SCRN.offsetY%
        END IF
        DIM hovLi AS INTEGER
        FOR hovLi% = MAX_LAYERS TO 1 STEP -1
            IF LAYERS(hovLi%).imgHandle& < -1 AND LAYERS(hovLi%).layerType% = LAYER_TYPE_TEXT THEN
                IF LAYERS(hovLi%).visible% THEN
                    DIM hovTd AS INTEGER
                    hovTd% = LAYERS(hovLi%).textDataIdx%
                    IF hovTd% >= 1 AND TEXT_LAYER_DATA(hovTd%).used THEN
                        IF TEXT_LAYER_DATA(hovTd%).charCount > 0 THEN
                            DIM hovCX AS INTEGER, hovCY AS INTEGER
                            hovCX% = TEXT_LAYER_DATA(hovTd%).startX
                            hovCY% = TEXT_LAYER_DATA(hovTd%).startY
                            DIM hovW  AS INTEGER, hovH AS INTEGER
                            TEXT_LAYER_get_bounds hovTd%, hovW%, hovH%
                            ' Hit-test mouse in canvas coords (use unsnapped to avoid grid-snap shimmer)
                            IF MOUSE.UNSNAPPED_X% >= hovCX% AND MOUSE.UNSNAPPED_X% < hovCX% + hovW% AND MOUSE.UNSNAPPED_Y% >= hovCY% AND MOUSE.UNSNAPPED_Y% < hovCY% + hovH% THEN
                                ' Convert canvas coords to screen coords
                                DIM hovSX1    AS INTEGER, hovSY1 AS INTEGER
                                DIM hovSX2    AS INTEGER, hovSY2 AS INTEGER
                                hovSX1% = INT(hovCX% * SCRN.zoom!) + hovDX% - 1
                                hovSY1% = INT(hovCY% * SCRN.zoom!) + hovDY% - 1
                                hovSX2% = INT((hovCX% + hovW%) * SCRN.zoom!) + hovDX%
                                hovSY2% = INT((hovCY% + hovH%) * SCRN.zoom!) + hovDY%
                                _DEST SCRN.CANVAS&
                                DIM hovStroke AS INTEGER, hovS AS INTEGER
                                hovStroke% = THEME.TEXT_LAYER_HOVER_OUTLINE_WIDTH%
                                IF hovStroke% < 1 THEN hovStroke% = 1
                                FOR hovS% = 0 TO hovStroke% - 1
                                    LINE (hovSX1% - hovS%, hovSY1% - hovS%)-(hovSX2% + hovS%, hovSY2% + hovS%), THEME.TEXT_LAYER_HOVER_OUTLINE~&, B
                                NEXT hovS%
                                EXIT FOR
                            END IF
                        END IF
                    END IF
                END IF
            END IF
        NEXT hovLi%
    END IF

    PERF_start PERF_POINTER_RENDER
    POINTER_update
    POINTER_render
    PERF_stop PERF_POINTER_RENDER

    ' ==== PREVIEW WINDOW (before GUI re-composite so menus, pickers, etc. render on top) ====
    PREVIEW_render SCRN.CANVAS&

    ' Re-composite GUI so brush previews and marching ants don't show over UI elements.
    ' This must happen AFTER POINTER_render since brush previews are drawn there.
    ' STATUS-ONLY fallback: partial composite to skip the expensive full-frame alpha-blend.
    _DEST SCRN.CANVAS&
    IF so_used_fallback% AND NOT MENUBAR_is_open% THEN
        ' Partial: only clip pointer dirty-rect + status strip (nothing else changed).
        DIM so_fb_pad AS INTEGER
        so_fb_pad% = POINTER_get_dirty_pad%
        DIM so_fb_px1 AS INTEGER, so_fb_py1 AS INTEGER, so_fb_px2 AS INTEGER, so_fb_py2 AS INTEGER
        so_fb_px1% = MOUSE.RAW_X% - so_fb_pad%
        so_fb_py1% = MOUSE.RAW_Y% - so_fb_pad%
        so_fb_px2% = MOUSE.RAW_X% + so_fb_pad%
        so_fb_py2% = MOUSE.RAW_Y% + so_fb_pad%
        IF POINTER.PREV_DRAW_X% > -9999 THEN
            IF POINTER.PREV_DRAW_X% - so_fb_pad% < so_fb_px1% THEN so_fb_px1% = POINTER.PREV_DRAW_X% - so_fb_pad%
            IF POINTER.PREV_DRAW_Y% - so_fb_pad% < so_fb_py1% THEN so_fb_py1% = POINTER.PREV_DRAW_Y% - so_fb_pad%
            IF POINTER.PREV_DRAW_X% + so_fb_pad% > so_fb_px2% THEN so_fb_px2% = POINTER.PREV_DRAW_X% + so_fb_pad%
            IF POINTER.PREV_DRAW_Y% + so_fb_pad% > so_fb_py2% THEN so_fb_py2% = POINTER.PREV_DRAW_Y% + so_fb_pad%
        END IF
        IF so_fb_px1% < 0 THEN so_fb_px1% = 0
        IF so_fb_py1% < 0 THEN so_fb_py1% = 0
        IF so_fb_px2% >= SCRN.w& THEN so_fb_px2% = SCRN.w& - 1
        IF so_fb_py2% >= SCRN.h& THEN so_fb_py2% = SCRN.h& - 1
        _PUTIMAGE (so_fb_px1%, so_fb_py1%)-(so_fb_px2%, so_fb_py2%), SCRN.GUI&, SCRN.CANVAS&, (so_fb_px1%, so_fb_py1%)-(so_fb_px2%, so_fb_py2%)
        IF SCRN.showStatus% THEN
            DIM so_fb_statusTop AS INTEGER
            so_fb_statusTop% = SCRN.h& - THEME.STATUS_height%
            IF so_fb_statusTop% < 0 THEN so_fb_statusTop% = 0
            _PUTIMAGE (0, so_fb_statusTop%)-(SCRN.w& - 1, SCRN.h& - 1), SCRN.GUI&, SCRN.CANVAS&, (0, so_fb_statusTop%)-(SCRN.w& - 1, SCRN.h& - 1)
        END IF
    ELSE
        _SOURCE SCRN.GUI& : _PUTIMAGE
    END IF
    
    ' Re-render scrollbars after GUI re-composite (they must stay on top)
    SCROLLBAR_render

    ' ==== CONTEXTUAL STATUS BARS (after second GUI composite so they're visible) ====
    ' These hint bars replace the regular status bar area with contextual keyboard hints
    IF IMG_IMPORT.STATE > IMPORT_STATE_IDLE THEN
        _DEST SCRN.CANVAS&
        IMAGE_IMPORT_draw_status SCRN.CANVAS&
    ELSEIF REFIMG.REPOSITION THEN
        _DEST SCRN.CANVAS&
        REFIMG_render_status SCRN.CANVAS&
    ELSEIF CURRENT_TOOL% = TOOL_MOVE AND MOVE.ACTIVE THEN
        _DEST SCRN.CANVAS&
        MOVE_render_status SCRN.CANVAS&
    END IF
    ' ==== END CONTEXTUAL STATUS BARS ====

    IF CURRENT_TOOL% = TOOL_PICKER AND PICKER.ACTIVE% AND _
       SCREEN_mouse_over_work_area%(MOUSE.RAW_X%, MOUSE.RAW_Y%) THEN
        PICKER_LOUPE_render SCRN.CANVAS&
        PREVIEW_render_loupe SCRN.CANVAS&
    END IF

    ' ==== FINAL OVERLAY POPUPS (must stay above GUI, scrollbars, and status overlays) ====
    IF LAYER_PANEL.blendPopupOpen% THEN
        LAYER_PANEL_blend_popup_render
    END IF
    IF LAYER_PANEL.ctxMenuOpen% THEN
        LAYER_PANEL_ctx_menu_render
    END IF
    IF DRAWER.contextMenuOpen% THEN
        DRAWER_context_menu_render
    END IF
    IF CMD_PALETTE.visible THEN
        CMD_render SCRN.CANVAS&
    END IF
    
    ' Redraw cursor on top of GUI (cursor must be visible above all UI elements)
    POINTER_render_cursor_overlay

    ' ==== TOOLTIP (on top of everything, including cursor and UI chrome) ====
    PREVIEW_render_tooltip SCRN.CANVAS&
    DRAWER_wheel_tooltip_render SCRN.CANVAS&
    TOOLTIP_render SCRN.CANVAS&

    ' Save pointer position for next frame's dirty-rect optimization
    POINTER.PREV_DRAW_X% = MOUSE.RAW_X%
    POINTER.PREV_DRAW_Y% = MOUSE.RAW_Y%
    
    ' Present canvas to window.
    PERF_start PERF_FINAL_SCALE
    ' ==== GRAYSCALE PREVIEW PASS (canvas work area only — leaves chrome untouched) ====
    IF GRAYSCALE_PREVIEW_ACTIVE% THEN
        ' Compute canvas work-area rect (matches PREVIEW_clamp_to_work_area).
        DIM grsX1 AS INTEGER, grsY1 AS INTEGER, grsX2 AS INTEGER, grsY2 AS INTEGER
        grsX1% = SCRN.uiLeftEdge%
        grsX2% = SCRN.uiRightEdge% - 1
        IF SCRN.showMenubar% AND MENU_BAR.visible% THEN
            grsY1% = MENU_BAR_HEIGHT
        ELSE
            grsY1% = 0
        END IF
        IF TEXT_BAR.visible% THEN
            DIM grsTbB   AS INTEGER : grsTbB% = TEXT_BAR.barY% + TEXT_BAR.barH%
            IF grsTbB% > grsY1% THEN grsY1% = grsTbB%
        END IF
        IF SCRN.showStatus% THEN
            grsY2% = SCRN.h& - THEME.STATUS_height% - PALETTE_STRIP_get_height% - 1
        ELSE
            grsY2% = SCRN.h& - 1
        END IF
        IF grsX1% < 0 THEN grsX1% = 0
        IF grsY1% < 0 THEN grsY1% = 0
        IF grsX2% > SCRN.w& - 1 THEN grsX2% = SCRN.w& - 1
        IF grsY2% > SCRN.h& - 1 THEN grsY2% = SCRN.h& - 1
        IF grsX2% >= grsX1% AND grsY2% >= grsY1% THEN
            DIM grsFrame AS _MEM : grsFrame = _MEMIMAGE(SCRN.CANVAS&)
            DIM grsW     AS LONG : grsW& = SCRN.w&
            DIM grsRow   AS INTEGER, grsCol AS INTEGER
            DIM grsOff   AS _OFFSET, grsPx AS _UNSIGNED LONG
            DIM grsR     AS INTEGER, grsG AS INTEGER, grsB AS INTEGER, grsA AS INTEGER, grsV AS INTEGER
            FOR grsRow% = grsY1% TO grsY2%
                grsOff = grsFrame.OFFSET + (CLNG(grsRow%) * grsW& + grsX1%) * 4
                FOR grsCol% = grsX1% TO grsX2%
                    _MEMGET grsFrame, grsOff, grsPx
                    grsA% = _ALPHA32(grsPx)
                    IF grsA% <> 0 THEN
                        grsR% = _RED32(grsPx): grsG% = _GREEN32(grsPx): grsB% = _BLUE32(grsPx)
                        grsV% = INT(0.299! * CSNG(grsR%) + 0.587! * CSNG(grsG%) + 0.114! * CSNG(grsB%))
                        IF grsV% > 255 THEN grsV% = 255
                        grsPx = _RGBA32(grsV%, grsV%, grsV%, grsA%)
                        _MEMPUT grsFrame, grsOff, grsPx
                    END IF
                    grsOff = grsOff + 4
                NEXT grsCol%
            NEXT grsRow%
            _MEMFREE grsFrame
        END IF
    END IF
    _PUTIMAGE (0, 0)-(_WIDTH(0) - 1, _HEIGHT(0) - 1), SCRN.CANVAS&, 0
    PERF_stop PERF_FINAL_SCALE

    ' ==== FLOATING PANELS (after canvas upscale, draw directly to screen 0) ====
    COLORMIXER_render
    BROWSER_render
    TOOLTIP_reblit_to_screen0

    PERF_start PERF_DISPLAY_CALL
    _DISPLAY
    PERF_stop PERF_DISPLAY_CALL
    
    ' Reset dirty flags at end of render
    STATUS_NEEDS_REDRAW% = FALSE
    GUI_NEEDS_REDRAW%    = FALSE
    PERF_stop PERF_RENDER_TOTAL
END SUB
