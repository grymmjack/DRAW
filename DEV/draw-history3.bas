END SUB

SUB DrawFilledEllipse (x1 AS INTEGER, y1 AS INTEGER, x2 AS INTEGER, y2 AS INTEGER, drawCol AS _UNSIGNED LONG, layerId AS LONG)
    DIM cx AS INTEGER, cy AS INTEGER
    DIM rx AS SINGLE, ry AS SINGLE
