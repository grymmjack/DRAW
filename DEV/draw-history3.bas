    layerVisible(layerId) = isVisible
    layerZ(layerId) = zPos
    layerOpacity(layerId) = opacityVal
    layerName(layerId) = layerLabel
END SUB

SUB DeleteLayer (layerId AS LONG)
    IF layerId < 1 OR layerId > MAX_LAYER_ID THEN EXIT SUB
    IF layerImg(layerId) < -1 THEN _FREEIMAGE layerImg(layerId): layerImg(layerId) = 0
    layerActive(layerId) = 0
    layerVisible(layerId) = 0
    layerZ(layerId) = 0
    layerOpacity(layerId) = 0
    layerName(layerId) = ""
END SUB

SUB MoveLayerToZ (layerId AS LONG, targetZ AS INTEGER)
