SUB CreateLayer (layerId AS LONG, zPos AS INTEGER, isVisible AS INTEGER, opacityVal AS INTEGER, layerLabel AS STRING)
    IF layerId < 1 OR layerId > MAX_LAYER_ID THEN EXIT SUB
    IF layerImg(layerId) < -1 THEN _FREEIMAGE layerImg(layerId)
    layerImg(layerId) = _NEWIMAGE(CANVAS_W, CANVAS_H, 32)
    IF layerImg(layerId) >= -1 THEN EXIT SUB
    _DEST layerImg(layerId)
    CLS , _RGBA32(0, 0, 0, 0)
    _DEST 0
