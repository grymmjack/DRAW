''
' Handles changing colors with keyboard
' @param keypress STRING The keyboard key character pressed
' @todo
' 
SUB KEYBOARD_colors (keypress AS STRING)
    SELECT CASE keypress$
        CASE "1": PAINT_OPACITY% = 10: GUI_NEEDS_REDRAW% = TRUE: SCENE_DIRTY% = TRUE
        CASE "2": PAINT_OPACITY% = 20: GUI_NEEDS_REDRAW% = TRUE: SCENE_DIRTY% = TRUE
        CASE "3": PAINT_OPACITY% = 30: GUI_NEEDS_REDRAW% = TRUE: SCENE_DIRTY% = TRUE
        CASE "4": PAINT_OPACITY% = 40: GUI_NEEDS_REDRAW% = TRUE: SCENE_DIRTY% = TRUE
        CASE "5": PAINT_OPACITY% = 50: GUI_NEEDS_REDRAW% = TRUE: SCENE_DIRTY% = TRUE
        CASE "6": PAINT_OPACITY% = 60: GUI_NEEDS_REDRAW% = TRUE: SCENE_DIRTY% = TRUE
        CASE "7": PAINT_OPACITY% = 70: GUI_NEEDS_REDRAW% = TRUE: SCENE_DIRTY% = TRUE
        CASE "8": PAINT_OPACITY% = 80: GUI_NEEDS_REDRAW% = TRUE: SCENE_DIRTY% = TRUE
        CASE "9": PAINT_OPACITY% = 90: GUI_NEEDS_REDRAW% = TRUE: SCENE_DIRTY% = TRUE
        CASE "0": PAINT_OPACITY% = 100: GUI_NEEDS_REDRAW% = TRUE: SCENE_DIRTY% = TRUE
        CASE "*"  ' Random Track — play a random music track
            IF CFG.MUSIC_ENABLED% THEN
                CMD_execute_action 433
                FRAME_IDLE% = FALSE
            END IF
        CASE "#"  ' Toggle canvas border visibility
            CMD_execute_action 441
            FRAME_IDLE% = FALSE
        CASE "x", "X"  ' Swap foreground and background colors
            DIM temp_color AS _UNSIGNED LONG
            DIM temp_idx AS INTEGER
            DIM temp_trans AS INTEGER
            temp_color~& = PAINT_COLOR~&
            temp_idx% = PAL_FG_IDX%
            temp_trans% = PAL_FG_IS_TRANSPARENT%
            PAINT_COLOR~& = PAINT_BG_COLOR~&
            PAL_FG_IDX% = PAL_BG_IDX%
            PAL_FG_IS_TRANSPARENT% = PAL_BG_IS_TRANSPARENT%
            PAINT_BG_COLOR~& = temp_color~&
            PAL_BG_IDX% = temp_idx%
            PAL_BG_IS_TRANSPARENT% = temp_trans%
            GUI_NEEDS_REDRAW% = TRUE
        EVERYCASE:
            KEY_COLOR%   = TRUE 
            WHEEL_COLOR% = FALSE
    END SELECT
END SUB


''
' Handles tool selection with keyboard
' @param keypress STRING The keyboard key character pressed
'
SUB KEYBOARD_tools (keypress AS STRING)
    ' H = Flip Horizontal (works with any tool — no tool conflict)
    IF keypress$ = "h" OR keypress$ = "H" THEN
        CMD_execute_action 315
        EXIT SUB
    END IF
    ' V = Flip Vertical only when move tool has floating selection
    ' (V is also the Move tool shortcut, so it can't be universal)
    IF CURRENT_TOOL% = TOOL_MOVE AND MOVE.ACTIVE THEN
        IF keypress$ = "v" OR keypress$ = "V" THEN
            CMD_execute_action 316
            EXIT SUB
        END IF
    END IF

    DIM prevTool AS INTEGER
    prevTool% = CURRENT_TOOL%

    SELECT CASE keypress$
        CASE "b", "B"
            PREVIOUS_TOOL% = CURRENT_TOOL%
            CURRENT_TOOL% = TOOL_BRUSH
            TOOLS_reset_all FALSE  ' Reset all tools, preserve marquee selection
        CASE "f", "F"
            ' When magic wand is active, hold-F at click time triggers flood fill —
            ' suppress tool switch so the key is available for that modifier behavior
            IF CURRENT_TOOL% = TOOL_MARQUEE AND MARQUEE.MAGIC_WAND_MODE THEN EXIT SUB
            PREVIOUS_TOOL% = CURRENT_TOOL%
            CURRENT_TOOL% = TOOL_FILL
            TOOLS_reset_all FALSE  ' Reset all tools, preserve marquee selection
            FILL_activate              ' Re-activate fill after reset
        CASE "d", "D"
            PREVIOUS_TOOL% = CURRENT_TOOL%
            CURRENT_TOOL% = TOOL_DOT
            TOOLS_reset_all FALSE  ' Reset all tools, preserve marquee selection
        CASE "l", "L"
            PREVIOUS_TOOL% = CURRENT_TOOL%
            CURRENT_TOOL% = TOOL_LINE
            TOOLS_reset_all FALSE  ' Reset all tools, preserve marquee selection
        CASE "p", "P"
            PREVIOUS_TOOL% = CURRENT_TOOL%
            ' SHIFT+P = filled polygon, P = outline polygon
            IF _KEYDOWN(KEY_LSHIFT&) OR _KEYDOWN(KEY_RSHIFT&) THEN
                CURRENT_TOOL% = TOOL_POLYGON_FILLED
            ELSE
                CURRENT_TOOL% = TOOL_POLYGON
            END IF
            TOOLS_reset_all FALSE  ' Reset all tools, preserve marquee selection
            ' Set filled flag for polygon
            POLY_LINE.FILLED = (CURRENT_TOOL% = TOOL_POLYGON_FILLED)
        CASE "r", "R"
            PREVIOUS_TOOL% = CURRENT_TOOL%
            ' SHIFT+R = filled rectangle, R = outline rectangle
            IF _KEYDOWN(KEY_LSHIFT&) OR _KEYDOWN(KEY_RSHIFT&) THEN
                CURRENT_TOOL% = TOOL_RECT_FILLED
            ELSE
                CURRENT_TOOL% = TOOL_RECT
            END IF
            TOOLS_reset_all FALSE  ' Reset all tools, preserve marquee selection
        CASE "c", "C"
            PREVIOUS_TOOL% = CURRENT_TOOL%
            ' SHIFT+C = filled ellipse, C = outline ellipse
            IF _KEYDOWN(KEY_LSHIFT&) OR _KEYDOWN(KEY_RSHIFT&) THEN
                CURRENT_TOOL% = TOOL_ELLIPSE_FILLED
            ELSE
                CURRENT_TOOL% = TOOL_ELLIPSE
            END IF
            TOOLS_reset_all FALSE  ' Reset all tools, preserve marquee selection
        CASE "m", "M"
            ' Already in rect-marquee mode — suppress key-repeat sound/reset
            IF CURRENT_TOOL% = TOOL_MARQUEE AND NOT MARQUEE.MAGIC_WAND_MODE AND MARQUEE.VARIANT = TOOL_SELECT_RECT THEN EXIT SUB
            PREVIOUS_TOOL% = CURRENT_TOOL%
            CURRENT_TOOL% = TOOL_MARQUEE
            TOOLS_reset_all FALSE  ' Reset all tools, preserve marquee selection
            ' Clear auto-created marquee from MOVE tool (preserve user-created ones)
            IF MARQUEE.ACTIVE% AND NOT MARQUEE.USER_CREATED THEN
                MARQUEE_reset
            END IF
            MARQUEE.MAGIC_WAND_MODE = FALSE  ' Regular marquee mode
            MARQUEE.VARIANT = TOOL_SELECT_RECT
            SOUND_play SND_SELECTION
        CASE "w", "W"
            ' Already in wand mode — suppress key-repeat sound/reset
            IF CURRENT_TOOL% = TOOL_MARQUEE AND MARQUEE.MAGIC_WAND_MODE THEN EXIT SUB
            PREVIOUS_TOOL% = CURRENT_TOOL%
            CURRENT_TOOL% = TOOL_MARQUEE
            TOOLS_reset_all FALSE  ' Reset all tools, preserve marquee selection
            ' Enable magic wand mode (same as right-click on marquee tool)
            MARQUEE.MAGIC_WAND_MODE = TRUE
            MARQUEE.VARIANT = TOOL_SELECT_WAND
            MAGIC_WAND_reset
            MARQUEE.ACTIVE% = FALSE
            MARQUEE.INITIALIZED% = FALSE
            SOUND_play SND_SELECTION
        CASE "v", "V"
            PREVIOUS_TOOL% = CURRENT_TOOL%
            CURRENT_TOOL% = TOOL_MOVE
            TOOLS_reset_all FALSE  ' Reset all tools, preserve marquee selection
            ' Always capture selection - handles both marquee and full-layer cases
            MOVE_capture_selection
        CASE "i", "I"
            PREVIOUS_TOOL% = CURRENT_TOOL%
            CURRENT_TOOL% = TOOL_PICKER
            TOOLS_reset_all FALSE  ' Reset all tools, preserve marquee selection
            PICKER_activate            ' Re-activate picker after reset
        CASE "k", "K"
            PREVIOUS_TOOL% = CURRENT_TOOL%
            CURRENT_TOOL% = TOOL_SPRAY
            TOOLS_reset_all FALSE  ' Reset all tools, preserve marquee selection
        CASE "z", "Z"
            PREVIOUS_TOOL% = CURRENT_TOOL%
            CURRENT_TOOL% = TOOL_ZOOM
            TOOLS_reset_all FALSE  ' Reset all tools, preserve marquee selection
        CASE "t", "T"
            PREVIOUS_TOOL% = CURRENT_TOOL%
            CURRENT_TOOL% = TOOL_TEXT
            TOOLS_reset_all FALSE  ' Reset all tools, preserve marquee selection
            ' SHIFT+T = Tiny5 font, T = VGA default font (CTRL+T handled separately)
            IF _KEYDOWN(KEY_LSHIFT&) OR _KEYDOWN(KEY_RSHIFT&) THEN
                TEXT.USE_CUSTOM = FALSE
                TEXT.USE_TINY5 = TRUE
                TEXT.CHAR_WIDTH = 5
                TEXT.LINE_HEIGHT = 6  ' 5px font + 1px gap
            ELSE
                TEXT.USE_CUSTOM = FALSE
                TEXT.USE_TINY5 = FALSE
                TEXT.CHAR_WIDTH = 8
                TEXT.LINE_HEIGHT = 13  ' 8px font + larger gap for readability
            END IF
            TEXT_reset       ' Reset text tool when switching to it
            GUI_NEEDS_REDRAW% = TRUE
        CASE CHR$(27)  ' ESC key - reset poly line tool, cancel move, cancel layer drag, apply text, or clear selection
            ' First check if layer drag is in progress
            IF LAYER_PANEL_is_dragging% THEN
                LAYER_PANEL_drag_cancel
            ELSEIF FILL_ADJ_is_active% THEN
                FILL_ADJ_cancel
                GUI_NEEDS_REDRAW% = TRUE
            ELSEIF TRANSFORM.ACTIVE THEN
                TRANSFORM_cancel
                GUI_NEEDS_REDRAW% = TRUE
            ELSEIF CURRENT_TOOL% = TOOL_MOVE AND MOVE.ACTIVE THEN
                ' Cancel the move: restore pixels to original position, discard undo states
                ' Set frame flag BEFORE reset so MOVE_apply_transform skips its undo save
                ' (the apply just restores original pixels — saving would create a phantom state
                ' identical to the pre-capture state, wasting a CTRL+Z press)
                HISTORY_saved_this_frame% = TRUE
                MOVE_cancel_transform
                MOVE_reset
                ' Clear auto-created marquee but keep TOOL_MOVE selected
                IF MARQUEE.ACTIVE% AND NOT MARQUEE.USER_CREATED THEN
                    MARQUEE_reset
                END IF
                GUI_NEEDS_REDRAW% = TRUE
            ELSEIF CURRENT_TOOL% = TOOL_TEXT AND TEXT.ACTIVE THEN
                TEXT_apply
            ELSEIF CURRENT_TOOL% = TOOL_POLYGON OR CURRENT_TOOL% = TOOL_POLYGON_FILLED THEN
                POLY_LINE_cancel_restore
            ELSEIF MARQUEE.MAGIC_WAND_MODE AND MARQUEE.WAND_HAS_SELECTION THEN
                ' Clear magic wand selection from any tool
                MAGIC_WAND_reset
                MARQUEE.ACTIVE% = FALSE
                GUI_NEEDS_REDRAW% = TRUE
            ELSEIF MARQUEE.ACTIVE% THEN
                ' Clear regular marquee selection from any tool
                MARQUEE_clear
                GUI_NEEDS_REDRAW% = TRUE
            END IF
        CASE CHR$(13)  ' ENTER key - finish poly line (keeps tool active), apply move transform, or newline in text
            IF CURRENT_TOOL% = TOOL_TEXT AND TEXT.ACTIVE THEN
                TEXT_newline
            ELSEIF FILL_ADJ_is_active% THEN
                FILL_ADJ_commit
                GUI_NEEDS_REDRAW% = TRUE
            ELSEIF TRANSFORM.ACTIVE THEN
                TRANSFORM_commit
                GUI_NEEDS_REDRAW% = TRUE
            ELSEIF CURRENT_TOOL% = TOOL_POLYGON OR CURRENT_TOOL% = TOOL_POLYGON_FILLED THEN
                POLY_LINE_reset
                ' Keep tool selected so user can draw more polygons
                GUI_NEEDS_REDRAW% = TRUE
            ELSEIF CURRENT_TOOL% = TOOL_MOVE AND MOVE.ACTIVE THEN
                MOVE_apply_transform
                ' After applying, clear move state and return to marquee tool
                MOVE_reset
                CURRENT_TOOL% = TOOL_MARQUEE
                ' Clear marquee selection
                MARQUEE.ACTIVE = FALSE
                MARQUEE.INITIALIZED = FALSE
                GUI_NEEDS_REDRAW% = TRUE
            END IF
        CASE CHR$(26), CHR$(90), CHR$(122) ' Ctrl+Z - handled in loop handler with single-press
            ' Do nothing here - handled in KEYBOARD_input_handler_loop
        CASE CHR$(25), CHR$(89), CHR$(121) ' Ctrl+Y - handled in loop handler with single-press
            ' Do nothing here - handled in KEYBOARD_input_handler_loop
    END SELECT

    ' If tool changed, force a full scene rebuild immediately.
    ' GUI_NEEDS_REDRAW% alone is not enough: the GUI-only render path restores
    ' SCENE_CACHE& (which has the old TEXT BAR baked in) and then composites a
    ' transparent SCRN.GUI& on top — leaving the stale bar visible.
    ' SCENE_DIRTY% = TRUE forces the full render path which rebuilds SCENE_CACHE&
    ' from scratch, so the TEXT BAR (and any other chrome tied to CURRENT_TOOL%)
    ' disappears in the same frame as the tool switch.
    IF CURRENT_TOOL% <> prevTool% THEN
        GUI_NEEDS_REDRAW% = TRUE
        SCENE_DIRTY% = TRUE
        FRAME_IDLE% = FALSE
    END IF
END SUB


''
' Handles brush size changes with keyboard
' @param keypress STRING The keyboard key character pressed
'
SUB KEYBOARD_brush_size (keypress AS STRING)
    SELECT CASE keypress$
        CASE "["
            BRUSH_SIZE_decrease
        CASE "]"
            BRUSH_SIZE_increase
    END SELECT
END SUB


''
' Handles assistant toggles with keyboard
' @param keypress STRING The keyboard key character pressed
'
SUB KEYBOARD_assistants (keypress AS STRING)
    ' Don't trigger assistants when in text edit mode
    IF CURRENT_TOOL% = TOOL_TEXT AND TEXT.ACTIVE THEN EXIT SUB
    
    SELECT CASE keypress$
        CASE "~", "`"
            BRUSH_SIZE_toggle_preview
            GUI_NEEDS_REDRAW% = TRUE
            FRAME_IDLE% = FALSE
        CASE "|", "\"
            BRUSH_SIZE_toggle_shape
            GUI_NEEDS_REDRAW% = TRUE
            FRAME_IDLE% = FALSE
    END SELECT
END SUB


''
' Handle function keys F1-F8 using _KEYDOWN() — runs unconditionally every frame.
' F1-F3: Color/Gradient/Pattern modes, F4: Preview Window toggle, F6: Pixel perfect, F7: Symmetry cycle, F8: Fill Adjust toggle.
' Uses _KEYDOWN() instead of INKEY$ so they work regardless of buffer state.
'
SUB KEYBOARD_handle_function_keys ()
    ' Don't trigger when text tool is active (matches KEYBOARD_assistants behavior)
    IF CURRENT_TOOL% = TOOL_TEXT AND TEXT.ACTIVE THEN EXIT SUB

    STATIC f1Pressed AS INTEGER, f2Pressed AS INTEGER
    STATIC f3Pressed AS INTEGER, f4Pressed AS INTEGER
    STATIC f6Pressed AS INTEGER, f7Pressed AS INTEGER, f8Pressed AS INTEGER

    ' F1-F3: paint mode shortcuts
    IF _KEYDOWN(15104) THEN ' F1
        IF NOT f1Pressed% THEN
            DRAWER_set_mode DRAWER_MODE_BRUSH
            GUI_NEEDS_REDRAW% = TRUE
            FRAME_IDLE% = FALSE
            f1Pressed% = TRUE
        END IF
    ELSE
        f1Pressed% = FALSE
    END IF

    IF _KEYDOWN(15360) THEN ' F2
        IF NOT f2Pressed% THEN
            DRAWER_set_mode DRAWER_MODE_GRADIENT
            GUI_NEEDS_REDRAW% = TRUE
            FRAME_IDLE% = FALSE
            f2Pressed% = TRUE
        END IF
    ELSE
        f2Pressed% = FALSE
    END IF

    IF _KEYDOWN(15616) THEN ' F3
        IF NOT f3Pressed% THEN
            DRAWER_set_mode DRAWER_MODE_PATTERN
            GUI_NEEDS_REDRAW% = TRUE
            FRAME_IDLE% = FALSE
            f3Pressed% = TRUE
        END IF
    ELSE
        f3Pressed% = FALSE
    END IF

    ' F4: Toggle Preview Window
    IF _KEYDOWN(15872) THEN ' F4
        IF NOT f4Pressed% THEN
            CMD_execute_action 434
            f4Pressed% = TRUE
        END IF
    ELSE
        f4Pressed% = FALSE
    END IF

    ' F5: Toggle Edit Bar
    STATIC f5Pressed AS INTEGER
    IF _KEYDOWN(16128) THEN ' F5
        IF NOT f5Pressed% THEN
            CMD_execute_action 435
            f5Pressed% = TRUE
        END IF
    ELSE
        f5Pressed% = FALSE
    END IF

    ' F6: Pixel perfect toggle
    IF _KEYDOWN(16384) THEN ' F6
        IF NOT f6Pressed% THEN
            BRUSH_SIZE_toggle_pixel_perfect
            GUI_NEEDS_REDRAW% = TRUE
            FRAME_IDLE% = FALSE
            f6Pressed% = TRUE
        END IF
    ELSE
        f6Pressed% = FALSE
    END IF

    ' F7: Symmetry cycle
    IF _KEYDOWN(16640) THEN ' F7
        IF NOT f7Pressed% THEN
            SYMMETRY_cycle_mode
            GUI_NEEDS_REDRAW% = TRUE
            FRAME_IDLE% = FALSE
            f7Pressed% = TRUE
        END IF
    ELSE
        f7Pressed% = FALSE
    END IF

    ' F8: Interactive Fill Adjust toggle (custom brush or paint mode)
    IF _KEYDOWN(16896) THEN ' F8
        IF NOT f8Pressed% THEN
            IF CUSTOM_BRUSH_is_active% OR DRAWER_has_paint_mode% THEN
                FILL_ADJ_toggle_enabled
            END IF
            GUI_NEEDS_REDRAW% = TRUE
            FRAME_IDLE% = FALSE
            f8Pressed% = TRUE
        END IF
    ELSE
        f8Pressed% = FALSE
    END IF
END SUB


''
' Handle command palette keyboard input with arrow key repeat.
' Returns TRUE if command palette consumed the input (caller should EXIT SUB).
' @return INTEGER - TRUE if the command palette consumed the key event
'
FUNCTION KEYBOARD_handle_command_palette% ()
    IF NOT CMD_PALETTE.visible THEN
        KEYBOARD_handle_command_palette% = FALSE
        EXIT FUNCTION
    END IF

    DIM cmd_keypress AS STRING
    cmd_keypress$ = INKEY$
    ' Fallback: if INKEY$ was empty, try _KEYHIT-derived character
    IF cmd_keypress$ = "" AND KEYHIT_CHAR$ <> "" THEN
        cmd_keypress$ = KEYHIT_CHAR$
    END IF
    IF cmd_keypress$ <> "" THEN
        CMD_handle_key cmd_keypress$
    END IF
    
    ' Handle arrow key and page navigation for command palette with key repeat
    STATIC cmdArrowUp AS INTEGER, cmdArrowDown AS INTEGER
    STATIC cmdPageUp AS INTEGER, cmdPageDown AS INTEGER
    STATIC cmdRepeatTimer AS DOUBLE
    STATIC cmdRepeatDelay AS DOUBLE
    DIM cmdArrowUpNow AS INTEGER, cmdArrowDownNow AS INTEGER
    DIM cmdPageUpNow AS INTEGER, cmdPageDownNow AS INTEGER
    DIM cmdCurrentTime AS DOUBLE
    
    ' Key repeat settings (in seconds)
    CONST CMD_REPEAT_INITIAL = 0.3   ' Initial delay before repeat starts
    CONST CMD_REPEAT_RATE = 0.08     ' Delay between repeats (~12 per second)
    
    cmdArrowUpNow% = _KEYDOWN(18432)    ' Up arrow
    cmdArrowDownNow% = _KEYDOWN(20480)  ' Down arrow
    cmdPageUpNow% = _KEYDOWN(18688)     ' Page Up
    cmdPageDownNow% = _KEYDOWN(20736)   ' Page Down
    cmdCurrentTime# = TIMER(.001)
    
    ' Arrow Up with repeat
    IF cmdArrowUpNow% THEN
        IF NOT cmdArrowUp% THEN
            CMD_navigate_up
            cmdRepeatTimer# = cmdCurrentTime#
            cmdRepeatDelay# = CMD_REPEAT_INITIAL
        ELSEIF cmdCurrentTime# - cmdRepeatTimer# >= cmdRepeatDelay# THEN
            CMD_navigate_up
            cmdRepeatTimer# = cmdCurrentTime#
            cmdRepeatDelay# = CMD_REPEAT_RATE
        END IF
    END IF
    
    ' Arrow Down with repeat
    IF cmdArrowDownNow% THEN
        IF NOT cmdArrowDown% THEN
            CMD_navigate_down
            cmdRepeatTimer# = cmdCurrentTime#
            cmdRepeatDelay# = CMD_REPEAT_INITIAL
        ELSEIF cmdCurrentTime# - cmdRepeatTimer# >= cmdRepeatDelay# THEN
            CMD_navigate_down
            cmdRepeatTimer# = cmdCurrentTime#
            cmdRepeatDelay# = CMD_REPEAT_RATE
        END IF
    END IF
    
    ' Page Up with repeat
    IF cmdPageUpNow% THEN
        IF NOT cmdPageUp% THEN
            CMD_navigate_page_up
            cmdRepeatTimer# = cmdCurrentTime#
            cmdRepeatDelay# = CMD_REPEAT_INITIAL
        ELSEIF cmdCurrentTime# - cmdRepeatTimer# >= cmdRepeatDelay# THEN
            CMD_navigate_page_up
            cmdRepeatTimer# = cmdCurrentTime#
            cmdRepeatDelay# = CMD_REPEAT_RATE
        END IF
    END IF
    
    ' Page Down with repeat
    IF cmdPageDownNow% THEN
        IF NOT cmdPageDown% THEN
            CMD_navigate_page_down
            cmdRepeatTimer# = cmdCurrentTime#
            cmdRepeatDelay# = CMD_REPEAT_INITIAL
        ELSEIF cmdCurrentTime# - cmdRepeatTimer# >= cmdRepeatDelay# THEN
            CMD_navigate_page_down
            cmdRepeatTimer# = cmdCurrentTime#
            cmdRepeatDelay# = CMD_REPEAT_RATE
        END IF
    END IF
    
    cmdArrowUp% = cmdArrowUpNow%
    cmdArrowDown% = cmdArrowDownNow%
    cmdPageUp% = cmdPageUpNow%
    cmdPageDown% = cmdPageDownNow%
    
    KEYBOARD_handle_command_palette% = TRUE  ' Consumed
END FUNCTION


''
' Handle image import mode keyboard input (Enter, ESC, arrow keys).
' Returns TRUE if import mode consumed the input (caller should EXIT SUB).
' @return INTEGER - TRUE if image import mode consumed the key event
'
FUNCTION KEYBOARD_handle_image_import% ()
    IF IMG_IMPORT.STATE <= IMPORT_STATE_IDLE THEN
        KEYBOARD_handle_image_import% = FALSE
        EXIT FUNCTION
    END IF

    DIM keypress AS STRING
    keypress$ = INKEY$
    IF keypress$ <> "" THEN
        DIM import_key_code AS INTEGER
        import_key_code% = ASC(keypress$)
        
        SELECT CASE import_key_code%
            CASE 27  ' ESC - cancel import
                IMAGE_IMPORT_cancel
            CASE 13  ' ENTER - apply import
                IF IMG_IMPORT.STATE = IMPORT_STATE_LOADED THEN
                    ' Use dimensions already set during loading
                    ' (centered at original size for small images, fitted for large)
                    IMAGE_IMPORT_update_crop_from_zoom
                    IMG_IMPORT.STATE = IMPORT_STATE_PLACING
                END IF
                IMAGE_IMPORT_apply
                SCENE_DIRTY% = TRUE
                FRAME_IDLE% = FALSE
        END SELECT
    END IF
    
    ' Arrow key handling for import mode (works in LOADED or PLACING state)
    IF IMG_IMPORT.STATE >= IMPORT_STATE_LOADED THEN
        DIM impIsCtrl AS INTEGER, impIsShift AS INTEGER, impIsAlt AS INTEGER
        DIM impMoveStep AS INTEGER
        
        impIsCtrl% = MODIFIERS.ctrl%
        impIsShift% = MODIFIERS.shift%
        impIsAlt% = MODIFIERS.alt%
        impMoveStep% = 1
        IF impIsShift% THEN impMoveStep% = CFG.NUDGE_N%
        
        ' Single-press detection for arrow keys
        STATIC impKeyUpLast AS INTEGER, impKeyDownLast AS INTEGER
        STATIC impKeyLeftLast AS INTEGER, impKeyRightLast AS INTEGER
        DIM impKeyUpNow AS INTEGER, impKeyDownNow AS INTEGER
        DIM impKeyLeftNow AS INTEGER, impKeyRightNow AS INTEGER
        
        impKeyUpNow% = _KEYDOWN(18432)    ' Up arrow
        impKeyDownNow% = _KEYDOWN(20480)  ' Down arrow
        impKeyLeftNow% = _KEYDOWN(19200)  ' Left arrow
        impKeyRightNow% = _KEYDOWN(19712) ' Right arrow
        
        ' Arrow keys: Ctrl=resize, Alt=pan within image, plain=move box
        IF impKeyUpNow% AND NOT impKeyUpLast% THEN
            IF impIsCtrl% THEN
                IMAGE_IMPORT_resize_by 0, -impMoveStep%
            ELSEIF impIsAlt% THEN
                IMAGE_IMPORT_pan_by 0, -impMoveStep%
            ELSE
                IMAGE_IMPORT_nudge 0, -impMoveStep%
            END IF
        END IF
        IF impKeyDownNow% AND NOT impKeyDownLast% THEN
            IF impIsCtrl% THEN
                IMAGE_IMPORT_resize_by 0, impMoveStep%
            ELSEIF impIsAlt% THEN
                IMAGE_IMPORT_pan_by 0, impMoveStep%
            ELSE
                IMAGE_IMPORT_nudge 0, impMoveStep%
            END IF
        END IF
        IF impKeyLeftNow% AND NOT impKeyLeftLast% THEN
            IF impIsCtrl% THEN
                IMAGE_IMPORT_resize_by -impMoveStep%, 0
            ELSEIF impIsAlt% THEN
                IMAGE_IMPORT_pan_by -impMoveStep%, 0
            ELSE
                IMAGE_IMPORT_nudge -impMoveStep%, 0
            END IF
        END IF
        IF impKeyRightNow% AND NOT impKeyRightLast% THEN
            IF impIsCtrl% THEN
                IMAGE_IMPORT_resize_by impMoveStep%, 0
            ELSEIF impIsAlt% THEN
                IMAGE_IMPORT_pan_by impMoveStep%, 0
            ELSE
                IMAGE_IMPORT_nudge impMoveStep%, 0
            END IF
        END IF
        
        ' Update last key states
        impKeyUpLast% = impKeyUpNow%
        impKeyDownLast% = impKeyDownNow%
        impKeyLeftLast% = impKeyLeftNow%
        impKeyRightLast% = impKeyRightNow%
        
        ' > key (Shift+.) = Rotate CW 90, < key (Shift+,) = Rotate CCW 90
        STATIC impRotateCWLast AS INTEGER, impRotateCCWLast AS INTEGER
        DIM impRotateCWNow AS INTEGER, impRotateCCWNow AS INTEGER
        impRotateCWNow% = _KEYDOWN(62)   ' ASCII 62 = >
        impRotateCCWNow% = _KEYDOWN(60)  ' ASCII 60 = <
        IF impRotateCWNow% AND NOT impRotateCWLast% THEN
            IMG_IMPORT.ROTATION = (IMG_IMPORT.ROTATION + 90) MOD 360   ' CW
            IMAGE_IMPORT_rebuild_preview
            _LOGINFO "IMAGE_IMPORT: Rotation = " + STR$(IMG_IMPORT.ROTATION) + " degrees (CW)"
        END IF
        impRotateCWLast% = impRotateCWNow%
        IF impRotateCCWNow% AND NOT impRotateCCWLast% THEN
            IMG_IMPORT.ROTATION = (IMG_IMPORT.ROTATION + 270) MOD 360  ' CCW
            IMAGE_IMPORT_rebuild_preview
            _LOGINFO "IMAGE_IMPORT: Rotation = " + STR$(IMG_IMPORT.ROTATION) + " degrees (CCW)"
        END IF
        impRotateCCWLast% = impRotateCCWNow%
        
        ' Home = Flip Horizontal, End = Flip Vertical
        STATIC impFlipHLast AS INTEGER
        DIM impFlipHNow AS INTEGER
        impFlipHNow% = _KEYDOWN(18176)  ' Home key
        IF impFlipHNow% AND NOT impFlipHLast% THEN
            IMG_IMPORT.FLIP_H = NOT IMG_IMPORT.FLIP_H
            IMAGE_IMPORT_rebuild_preview
            _LOGINFO "IMAGE_IMPORT: Flip H = " + STR$(IMG_IMPORT.FLIP_H)
        END IF
        impFlipHLast% = impFlipHNow%
        
        STATIC impFlipVLast AS INTEGER
        DIM impFlipVNow AS INTEGER
        impFlipVNow% = _KEYDOWN(20224)  ' End key
        IF impFlipVNow% AND NOT impFlipVLast% THEN
            IMG_IMPORT.FLIP_V = NOT IMG_IMPORT.FLIP_V
            IMAGE_IMPORT_rebuild_preview
            _LOGINFO "IMAGE_IMPORT: Flip V = " + STR$(IMG_IMPORT.FLIP_V)
        END IF
        impFlipVLast% = impFlipVNow%
        
        ' Page Up = Scale up 50% from original, Page Down = Scale down 50% from original
        STATIC impScaleUpLast AS INTEGER, impScaleDnLast AS INTEGER
        DIM impScaleUpNow AS INTEGER, impScaleDnNow AS INTEGER
        impScaleUpNow% = _KEYDOWN(18688)  ' Page Up
        impScaleDnNow% = _KEYDOWN(20736)  ' Page Down
        IF impScaleUpNow% AND NOT impScaleUpLast% THEN
            IMG_IMPORT.SCALE_FACTOR = IMG_IMPORT.SCALE_FACTOR * 1.5
            ' Recalculate dest dimensions from original * scale factor
            DIM impSuW AS INTEGER, impSuH AS INTEGER
            impSuW% = INT(IMG_IMPORT.IMAGE_W * IMG_IMPORT.SCALE_FACTOR)
            impSuH% = INT(IMG_IMPORT.IMAGE_H * IMG_IMPORT.SCALE_FACTOR)
            IF impSuW% < 1 THEN impSuW% = 1
            IF impSuH% < 1 THEN impSuH% = 1
            ' Center adjustment
            DIM impSuOldCX AS INTEGER, impSuOldCY AS INTEGER
            impSuOldCX% = IMG_IMPORT.DEST_X + IMG_IMPORT.DEST_W \ 2
            impSuOldCY% = IMG_IMPORT.DEST_Y + IMG_IMPORT.DEST_H \ 2
            IMG_IMPORT.DEST_W = impSuW%
            IMG_IMPORT.DEST_H = impSuH%
            IMG_IMPORT.DEST_X = impSuOldCX% - impSuW% \ 2
            IMG_IMPORT.DEST_Y = impSuOldCY% - impSuH% \ 2
            IMAGE_IMPORT_update_crop_from_zoom
            SCENE_DIRTY% = TRUE
            FRAME_IDLE% = FALSE
            _LOGINFO "IMAGE_IMPORT: Scale factor = " + STR$(IMG_IMPORT.SCALE_FACTOR)
        END IF
        impScaleUpLast% = impScaleUpNow%
        IF impScaleDnNow% AND NOT impScaleDnLast% THEN
            IMG_IMPORT.SCALE_FACTOR = IMG_IMPORT.SCALE_FACTOR * 0.5
            IF IMG_IMPORT.SCALE_FACTOR < 0.01 THEN IMG_IMPORT.SCALE_FACTOR = 0.01
            ' Recalculate dest dimensions from original * scale factor
            DIM impSdW AS INTEGER, impSdH AS INTEGER
            impSdW% = INT(IMG_IMPORT.IMAGE_W * IMG_IMPORT.SCALE_FACTOR)
            impSdH% = INT(IMG_IMPORT.IMAGE_H * IMG_IMPORT.SCALE_FACTOR)
            IF impSdW% < 1 THEN impSdW% = 1
            IF impSdH% < 1 THEN impSdH% = 1
            ' Center adjustment
            DIM impSdOldCX AS INTEGER, impSdOldCY AS INTEGER
            impSdOldCX% = IMG_IMPORT.DEST_X + IMG_IMPORT.DEST_W \ 2
            impSdOldCY% = IMG_IMPORT.DEST_Y + IMG_IMPORT.DEST_H \ 2
            IMG_IMPORT.DEST_W = impSdW%
            IMG_IMPORT.DEST_H = impSdH%
            IMG_IMPORT.DEST_X = impSdOldCX% - impSdW% \ 2
            IMG_IMPORT.DEST_Y = impSdOldCY% - impSdH% \ 2
            IMAGE_IMPORT_update_crop_from_zoom
            SCENE_DIRTY% = TRUE
            FRAME_IDLE% = FALSE
            _LOGINFO "IMAGE_IMPORT: Scale factor = " + STR$(IMG_IMPORT.SCALE_FACTOR)
        END IF
        impScaleDnLast% = impScaleDnNow%
    END IF
    
    KEYBOARD_handle_image_import% = TRUE  ' Consumed
END FUNCTION


''
' Handle crop tool keyboard input (Enter, ESC, arrow keys).
' Returns TRUE if crop mode consumed the input (caller should EXIT SUB).
' @return INTEGER - TRUE if the crop tool consumed the key event
'
FUNCTION KEYBOARD_handle_crop_tool% ()
    IF CROP.STATE <> CROP_STATE_ACTIVE THEN
        KEYBOARD_handle_crop_tool% = FALSE
        EXIT FUNCTION
    END IF

    DIM cropKey AS STRING
    cropKey$ = INKEY$
    IF cropKey$ <> "" THEN
        DIM cropKeyCode AS INTEGER
        cropKeyCode% = ASC(cropKey$)

        SELECT CASE cropKeyCode%
            CASE 27  ' ESC - cancel crop
                CROP_cancel
                KEYBOARD_handle_crop_tool% = TRUE
                EXIT FUNCTION
            CASE 13  ' ENTER - apply crop
                CROP_apply
                KEYBOARD_handle_crop_tool% = TRUE
                EXIT FUNCTION
        END SELECT
    END IF

    ' Arrow keys and other input fall through to normal marquee handling
    KEYBOARD_handle_crop_tool% = FALSE
END FUNCTION


''
' Handle menu bar keyboard navigation (ALT tap, arrow keys, Enter, Escape).
' Returns TRUE if menu consumed the input (caller should EXIT SUB).
' @return INTEGER - TRUE if the menu bar consumed the key event
'
FUNCTION KEYBOARD_handle_menubar% ()
    IF NOT (SCRN.showMenubar% AND MENU_BAR.visible%) THEN
        KEYBOARD_handle_menubar% = FALSE
        EXIT FUNCTION
    END IF

    DIM menuKey AS LONG
    menuKey& = 0
    ' When a menu or overflow popup is open, read INKEY$ and convert to key codes
    IF MENU_BAR.openMenu% >= 0 OR MENU_OVERFLOW_OPEN% THEN
        DIM menuKeyPress AS STRING
        menuKeyPress$ = INKEY$
        IF LEN(menuKeyPress$) = 1 THEN
            menuKey& = ASC(menuKeyPress$)
        ELSEIF LEN(menuKeyPress$) = 2 THEN
            SELECT CASE ASC(menuKeyPress$, 2)
                CASE 75: menuKey& = 19200   ' Left arrow
                CASE 77: menuKey& = 19712   ' Right arrow
                CASE 72: menuKey& = 18432   ' Up arrow
                CASE 80: menuKey& = 20480   ' Down arrow
            END SELECT
        END IF
    END IF
    IF MENUBAR_handle_key%(menuKey&) THEN
        ' Menu consumed the key event — drain any remaining INKEY$ and skip
        DIM drain$ : drain$ = INKEY$
        KEYBOARD_handle_menubar% = TRUE
        EXIT FUNCTION
    END IF
    ' When a menu dropdown or overflow popup is open, block ALL other keyboard processing
    ' (arrow keys via _KEYDOWN would otherwise leak to marquee/move nudge)
    IF MENU_BAR.openMenu% >= 0 OR MENU_OVERFLOW_OPEN% THEN
        KEYBOARD_handle_menubar% = TRUE
    ELSE
        KEYBOARD_handle_menubar% = FALSE
    END IF
END FUNCTION


''
' Handle palette menu keyboard input (ESC, arrows, Enter, a-z navigation).
' Returns TRUE if palette menu consumed the input (caller should EXIT SUB).
' @return INTEGER - TRUE if the palette menu consumed the key event
'
FUNCTION KEYBOARD_handle_palette_menu% ()
    IF NOT PALETTE_MENU_VISIBLE% THEN
        KEYBOARD_handle_palette_menu% = FALSE
        EXIT FUNCTION
    END IF

    IF _KEYDOWN(27) THEN  ' ESC key
        PALETTE_MENU_hide
        KEYBOARD_handle_palette_menu% = TRUE
        EXIT FUNCTION
    END IF
    
    ' Handle arrow key navigation
    STATIC menuArrowUp AS INTEGER, menuArrowDown AS INTEGER
    DIM menuArrowUpNow AS INTEGER, menuArrowDownNow AS INTEGER
    menuArrowUpNow% = _KEYDOWN(18432)  ' Up arrow
    menuArrowDownNow% = _KEYDOWN(20480)  ' Down arrow
    
    IF menuArrowUpNow% AND NOT menuArrowUp% THEN
        PALETTE_MENU_navigate_up
    END IF
    IF menuArrowDownNow% AND NOT menuArrowDown% THEN
        PALETTE_MENU_navigate_down
    END IF
    menuArrowUp% = menuArrowUpNow%
    menuArrowDown% = menuArrowDownNow%
    
    ' Handle Enter to select current hover
    STATIC menuEnterPressed AS INTEGER
    DIM menuEnterNow AS INTEGER
    menuEnterNow% = _KEYDOWN(13)
    IF menuEnterNow% AND NOT menuEnterPressed% THEN
        IF PALETTE_MENU_HOVER% >= 0 AND PALETTE_MENU_HOVER% < PALETTE_LOADER_COUNT% THEN
            DIM dummy AS INTEGER
            dummy% = PALETTE_LOADER_load_by_index%(PALETTE_MENU_HOVER%)
            PAL_set_defaults_by_size
            PALETTE_STRIP_SCROLL_OFFSET% = 0
            PALETTE_MENU_hide
            menuEnterPressed% = menuEnterNow%
            KEYBOARD_handle_palette_menu% = TRUE
            EXIT FUNCTION
        END IF
    END IF
    menuEnterPressed% = menuEnterNow%
    
    ' Handle alphabetical navigation (a-z)
    DIM menu_key AS STRING
    menu_key$ = INKEY$
    IF LEN(menu_key$) = 1 THEN
        DIM menu_key_code AS INTEGER
        menu_key_code% = ASC(menu_key$)
        ' Check if it's a letter (a-z or A-Z)
        IF (menu_key_code% >= 65 AND menu_key_code% <= 90) OR (menu_key_code% >= 97 AND menu_key_code% <= 122) THEN
            PALETTE_MENU_jump_to_char menu_key$
        END IF
    END IF
    
    KEYBOARD_handle_palette_menu% = TRUE  ' Consumed
END FUNCTION


''
' Handle text tool keyboard input when text editing is active.
' Returns TRUE if text tool consumed the input (caller should EXIT SUB).
' @param keypress STRING The keyboard key character pressed
' @return INTEGER - TRUE if the text tool consumed the key event
'
FUNCTION KEYBOARD_handle_text_tool% (keypress AS STRING)
    IF NOT (CURRENT_TOOL% = TOOL_TEXT AND TEXT.ACTIVE) THEN
        KEYBOARD_handle_text_tool% = FALSE
        EXIT FUNCTION
    END IF

    ' --- Typography hotkeys (Ctrl/Alt combos via _KEYDOWN with STATIC guards) ---
    STATIC ctrlBold AS INTEGER, ctrlItalic AS INTEGER
    STATIC ctrlUnder AS INTEGER, ctrlStrike AS INTEGER
    STATIC ctrlSizUp AS INTEGER, ctrlSizDn AS INTEGER
    STATIC ctrlKernUp AS INTEGER, ctrlKernDn AS INTEGER
    STATIC ctrlBaseUp AS INTEGER, ctrlBaseDn AS INTEGER

    ' Ctrl+B = Toggle Bold
    IF MODIFIERS.ctrl% AND (_KEYDOWN(98) OR _KEYDOWN(66)) THEN
        IF NOT ctrlBold% THEN
            TEXT_BAR.boldActive% = NOT TEXT_BAR.boldActive%
            IF TEXT_has_selection% THEN TEXT_BAR_apply_style_to_selection "bold"
            FRAME_IDLE% = FALSE: GUI_NEEDS_REDRAW% = TRUE
            ctrlBold% = TRUE
        END IF
        KEYBOARD_handle_text_tool% = TRUE: EXIT FUNCTION
    ELSE: ctrlBold% = FALSE
    END IF

    ' Ctrl+I = Toggle Italic
    IF MODIFIERS.ctrl% AND (_KEYDOWN(105) OR _KEYDOWN(73)) THEN
        IF NOT ctrlItalic% THEN
            TEXT_BAR.italicActive% = NOT TEXT_BAR.italicActive%
            IF TEXT_has_selection% THEN TEXT_BAR_apply_style_to_selection "italic"
            FRAME_IDLE% = FALSE: GUI_NEEDS_REDRAW% = TRUE
            ctrlItalic% = TRUE
        END IF
        KEYBOARD_handle_text_tool% = TRUE: EXIT FUNCTION
    ELSE: ctrlItalic% = FALSE
    END IF

    ' Ctrl+U = Toggle Underline
    IF MODIFIERS.ctrl% AND (_KEYDOWN(117) OR _KEYDOWN(85)) THEN
        IF NOT ctrlUnder% THEN
            TEXT_BAR.underlineActive% = NOT TEXT_BAR.underlineActive%
            IF TEXT_has_selection% THEN TEXT_BAR_apply_style_to_selection "underline"
            FRAME_IDLE% = FALSE: GUI_NEEDS_REDRAW% = TRUE
            ctrlUnder% = TRUE
        END IF
        KEYBOARD_handle_text_tool% = TRUE: EXIT FUNCTION
    ELSE: ctrlUnder% = FALSE
    END IF

    ' Ctrl+Shift+X = Toggle Strikethrough
    IF MODIFIERS.ctrl% AND MODIFIERS.shift% AND (_KEYDOWN(120) OR _KEYDOWN(88)) THEN
        IF NOT ctrlStrike% THEN
            TEXT_BAR.strikeActive% = NOT TEXT_BAR.strikeActive%
            IF TEXT_has_selection% THEN TEXT_BAR_apply_style_to_selection "strike"
            FRAME_IDLE% = FALSE: GUI_NEEDS_REDRAW% = TRUE
            ctrlStrike% = TRUE
        END IF
        KEYBOARD_handle_text_tool% = TRUE: EXIT FUNCTION
    ELSE: ctrlStrike% = FALSE
    END IF

    ' Ctrl+Shift+. = Increase font size
    ' Check both unshifted (46=.) and shifted (62=>) codes for Linux/SDL2 compatibility
    IF MODIFIERS.ctrl% AND MODIFIERS.shift% AND (_KEYDOWN(46) OR _KEYDOWN(62)) THEN
        IF NOT ctrlSizUp% THEN
            ' Sync bar size from selection/cursor so we step from the actual text size
            TEXT_sync_bar_to_cursor
            DIM sizeIdx AS INTEGER
            FOR sizeIdx% = 0 TO TEXT_BAR_SIZE_COUNT - 1
                IF TEXT_BAR_SIZES(sizeIdx%) > TEXT_BAR.selectedSize% THEN
                    TEXT_BAR.selectedSize% = TEXT_BAR_SIZES(sizeIdx%)
                    EXIT FOR
                END IF
            NEXT sizeIdx%
            IF TEXT_has_selection% AND TEXT.editingTextLayer% >= 1 THEN
                DIM suTd AS INTEGER
                suTd% = LAYERS(TEXT.editingTextLayer%).textDataIdx%
                IF suTd% >= 1 THEN
                    DIM suMin AS INTEGER, suMax AS INTEGER
                    suMin% = TEXT.selStart%: suMax% = TEXT.selEnd%
                    IF suMin% > suMax% THEN SWAP suMin%, suMax%
                    TEXT_LAYER_set_selection_attr suTd%, suMin%, suMax% - 1, "FONT_SIZE", TEXT_BAR.selectedSize%
                    TEXT_LAYER_DATA(suTd%).dirty = TRUE
                    TEXT.CURSOR_X = TEXT_LAYER_get_char_x%(suTd%, TEXT_LAYER_DATA(suTd%).cursorPos)
                    SCENE_DIRTY% = TRUE
                END IF
            END IF
            FRAME_IDLE% = FALSE: GUI_NEEDS_REDRAW% = TRUE
            ctrlSizUp% = TRUE
        END IF
        KEYBOARD_handle_text_tool% = TRUE: EXIT FUNCTION
    ELSE: ctrlSizUp% = FALSE
    END IF

    ' Ctrl+Shift+, = Decrease font size
    ' Check both unshifted (44=,) and shifted (60=<) codes for Linux/SDL2 compatibility
    IF MODIFIERS.ctrl% AND MODIFIERS.shift% AND (_KEYDOWN(44) OR _KEYDOWN(60)) THEN
        IF NOT ctrlSizDn% THEN
            ' Sync bar size from selection/cursor so we step from the actual text size
            TEXT_sync_bar_to_cursor
            DIM sizeIdx2 AS INTEGER
            FOR sizeIdx2% = TEXT_BAR_SIZE_COUNT - 1 TO 0 STEP -1
                IF TEXT_BAR_SIZES(sizeIdx2%) < TEXT_BAR.selectedSize% THEN
                    TEXT_BAR.selectedSize% = TEXT_BAR_SIZES(sizeIdx2%)
                    EXIT FOR
                END IF
            NEXT sizeIdx2%
            IF TEXT_has_selection% AND TEXT.editingTextLayer% >= 1 THEN
                DIM sdTd AS INTEGER
                sdTd% = LAYERS(TEXT.editingTextLayer%).textDataIdx%
                IF sdTd% >= 1 THEN
                    DIM sdMin AS INTEGER, sdMax AS INTEGER
                    sdMin% = TEXT.selStart%: sdMax% = TEXT.selEnd%
                    IF sdMin% > sdMax% THEN SWAP sdMin%, sdMax%
                    TEXT_LAYER_set_selection_attr sdTd%, sdMin%, sdMax% - 1, "FONT_SIZE", TEXT_BAR.selectedSize%
                    TEXT_LAYER_DATA(sdTd%).dirty = TRUE
                    TEXT.CURSOR_X = TEXT_LAYER_get_char_x%(sdTd%, TEXT_LAYER_DATA(sdTd%).cursorPos)
                    SCENE_DIRTY% = TRUE
                END IF
            END IF
            FRAME_IDLE% = FALSE: GUI_NEEDS_REDRAW% = TRUE
            ctrlSizDn% = TRUE
        END IF
        KEYBOARD_handle_text_tool% = TRUE: EXIT FUNCTION
    ELSE: ctrlSizDn% = FALSE
    END IF

    ' Ctrl+Alt+. / Ctrl+Alt+> = Increase kerning at cursor or selection
    IF MODIFIERS.ctrl% AND MODIFIERS.alt% AND (_KEYDOWN(46) OR _KEYDOWN(62)) THEN
        IF NOT ctrlKernUp% THEN
            IF TEXT.editingTextLayer% >= 1 THEN
                DIM kuTd AS INTEGER
                kuTd% = LAYERS(TEXT.editingTextLayer%).textDataIdx%
                IF kuTd% >= 1 THEN
                    IF TEXT_has_selection% THEN
                        DIM kuMin AS INTEGER, kuMax AS INTEGER
                        kuMin% = TEXT.selStart%: kuMax% = TEXT.selEnd%
                        IF kuMin% > kuMax% THEN SWAP kuMin%, kuMax%
                        DIM kuC AS INTEGER
                        FOR kuC% = kuMin% TO kuMax% - 1
                            TL_KERN(kuTd%, kuC%) = TL_KERN(kuTd%, kuC%) + 1
                        NEXT kuC%
                    ELSEIF TEXT_LAYER_DATA(kuTd%).cursorPos < TEXT_LAYER_DATA(kuTd%).charCount THEN
                        TL_KERN(kuTd%, TEXT_LAYER_DATA(kuTd%).cursorPos) = TL_KERN(kuTd%, TEXT_LAYER_DATA(kuTd%).cursorPos) + 1
                    END IF
                    TEXT_LAYER_DATA(kuTd%).dirty = TRUE
                    TEXT.CURSOR_X = TEXT_LAYER_get_char_x%(kuTd%, TEXT_LAYER_DATA(kuTd%).cursorPos)
                    SCENE_DIRTY% = TRUE
                END IF
            END IF
            FRAME_IDLE% = FALSE: GUI_NEEDS_REDRAW% = TRUE
            ctrlKernUp% = TRUE
        END IF
        KEYBOARD_handle_text_tool% = TRUE: EXIT FUNCTION
    ELSE: ctrlKernUp% = FALSE
    END IF

    ' Ctrl+Alt+, / Ctrl+Alt+< = Decrease kerning at cursor or selection
    IF MODIFIERS.ctrl% AND MODIFIERS.alt% AND (_KEYDOWN(44) OR _KEYDOWN(60)) THEN
        IF NOT ctrlKernDn% THEN
            IF TEXT.editingTextLayer% >= 1 THEN
                DIM kdTd AS INTEGER
                kdTd% = LAYERS(TEXT.editingTextLayer%).textDataIdx%
                IF kdTd% >= 1 THEN
                    IF TEXT_has_selection% THEN
                        DIM kdMin AS INTEGER, kdMax AS INTEGER
                        kdMin% = TEXT.selStart%: kdMax% = TEXT.selEnd%
                        IF kdMin% > kdMax% THEN SWAP kdMin%, kdMax%
                        DIM kdC AS INTEGER
                        FOR kdC% = kdMin% TO kdMax% - 1
                            TL_KERN(kdTd%, kdC%) = TL_KERN(kdTd%, kdC%) - 1
                        NEXT kdC%
                    ELSEIF TEXT_LAYER_DATA(kdTd%).cursorPos < TEXT_LAYER_DATA(kdTd%).charCount THEN
                        TL_KERN(kdTd%, TEXT_LAYER_DATA(kdTd%).cursorPos) = TL_KERN(kdTd%, TEXT_LAYER_DATA(kdTd%).cursorPos) - 1
                    END IF
                    TEXT_LAYER_DATA(kdTd%).dirty = TRUE
                    TEXT.CURSOR_X = TEXT_LAYER_get_char_x%(kdTd%, TEXT_LAYER_DATA(kdTd%).cursorPos)
                    SCENE_DIRTY% = TRUE
                END IF
            END IF
            FRAME_IDLE% = FALSE: GUI_NEEDS_REDRAW% = TRUE
            ctrlKernDn% = TRUE
        END IF
        KEYBOARD_handle_text_tool% = TRUE: EXIT FUNCTION
    ELSE: ctrlKernDn% = FALSE
    END IF

    ' Ctrl+Alt+Up = Raise baseline at cursor or selection
    IF MODIFIERS.ctrl% AND MODIFIERS.alt% AND _KEYDOWN(18432) THEN
        IF NOT ctrlBaseUp% THEN
            IF TEXT.editingTextLayer% >= 1 THEN
                DIM buTd AS INTEGER
                buTd% = LAYERS(TEXT.editingTextLayer%).textDataIdx%
                IF buTd% >= 1 THEN
                    IF TEXT_has_selection% THEN
                        DIM buMin AS INTEGER, buMax AS INTEGER
                        buMin% = TEXT.selStart%: buMax% = TEXT.selEnd%
                        IF buMin% > buMax% THEN SWAP buMin%, buMax%
                        DIM buC AS INTEGER
                        FOR buC% = buMin% TO buMax% - 1
                            TL_BASELINE(buTd%, buC%) = TL_BASELINE(buTd%, buC%) + 1
                        NEXT buC%
                    ELSEIF TEXT_LAYER_DATA(buTd%).cursorPos < TEXT_LAYER_DATA(buTd%).charCount THEN
                        TL_BASELINE(buTd%, TEXT_LAYER_DATA(buTd%).cursorPos) = TL_BASELINE(buTd%, TEXT_LAYER_DATA(buTd%).cursorPos) + 1
                    END IF
                    TEXT_LAYER_DATA(buTd%).dirty = TRUE
                    SCENE_DIRTY% = TRUE
                END IF
            END IF
            FRAME_IDLE% = FALSE: GUI_NEEDS_REDRAW% = TRUE
            ctrlBaseUp% = TRUE
        END IF
        KEYBOARD_handle_text_tool% = TRUE: EXIT FUNCTION
    ELSE: ctrlBaseUp% = FALSE
    END IF

    ' Ctrl+Alt+Down = Lower baseline at cursor or selection
    IF MODIFIERS.ctrl% AND MODIFIERS.alt% AND _KEYDOWN(20480) THEN
        IF NOT ctrlBaseDn% THEN
            IF TEXT.editingTextLayer% >= 1 THEN
                DIM bdTd AS INTEGER
                bdTd% = LAYERS(TEXT.editingTextLayer%).textDataIdx%
                IF bdTd% >= 1 THEN
                    IF TEXT_has_selection% THEN
                        DIM bdMin AS INTEGER, bdMax AS INTEGER
                        bdMin% = TEXT.selStart%: bdMax% = TEXT.selEnd%
                        IF bdMin% > bdMax% THEN SWAP bdMin%, bdMax%
                        DIM bdC AS INTEGER
                        FOR bdC% = bdMin% TO bdMax% - 1
                            TL_BASELINE(bdTd%, bdC%) = TL_BASELINE(bdTd%, bdC%) - 1
                        NEXT bdC%
                    ELSEIF TEXT_LAYER_DATA(bdTd%).cursorPos < TEXT_LAYER_DATA(bdTd%).charCount THEN
                        TL_BASELINE(bdTd%, TEXT_LAYER_DATA(bdTd%).cursorPos) = TL_BASELINE(bdTd%, TEXT_LAYER_DATA(bdTd%).cursorPos) - 1
                    END IF
                    TEXT_LAYER_DATA(bdTd%).dirty = TRUE
                    SCENE_DIRTY% = TRUE
                END IF
            END IF
            FRAME_IDLE% = FALSE: GUI_NEEDS_REDRAW% = TRUE
            ctrlBaseDn% = TRUE
        END IF
        KEYBOARD_handle_text_tool% = TRUE: EXIT FUNCTION
    ELSE: ctrlBaseDn% = FALSE
    END IF

    ' --- Text clipboard operations ---
    STATIC ctrlCopy AS INTEGER, ctrlPaste AS INTEGER
    STATIC ctrlCut AS INTEGER, ctrlSelAll AS INTEGER

    ' Ctrl+C = Copy selected text to OS clipboard (with rich formatting)
    IF MODIFIERS.ctrl% AND NOT MODIFIERS.shift% AND (_KEYDOWN(99) OR _KEYDOWN(67)) THEN
        IF NOT ctrlCopy% THEN
            IF TEXT_has_selection% AND TEXT.editingTextLayer% >= 1 THEN
                DIM cpTd AS INTEGER
                cpTd% = LAYERS(TEXT.editingTextLayer%).textDataIdx%
                IF cpTd% >= 1 THEN
                    DIM cpStart AS INTEGER, cpEnd AS INTEGER
                    cpStart% = TEXT.selStart%: cpEnd% = TEXT.selEnd%
                    IF cpStart% > cpEnd% THEN SWAP cpStart%, cpEnd%
                    DIM cpText AS STRING
                    cpText$ = ""
                    TEXT_CLIP_COUNT% = 0
                    DIM cpI AS INTEGER
                    FOR cpI% = cpStart% TO cpEnd% - 1
                        DIM cpIdx AS INTEGER
                        cpIdx% = cpI% - cpStart%
                        cpText$ = cpText$ + TL_CHAR(cpTd%, cpI%)
                        TEXT_CLIP_CHAR(cpIdx%) = TL_CHAR(cpTd%, cpI%)
                        TEXT_CLIP_FG(cpIdx%) = TL_FG(cpTd%, cpI%)
                        TEXT_CLIP_BG(cpIdx%) = TL_BG(cpTd%, cpI%)
                        TEXT_CLIP_FONT_IDX(cpIdx%) = TL_FONT_IDX(cpTd%, cpI%)
                        TEXT_CLIP_FONT_SIZE(cpIdx%) = TL_FONT_SIZE(cpTd%, cpI%)
                        TEXT_CLIP_BOLD(cpIdx%) = TL_BOLD(cpTd%, cpI%)
                        TEXT_CLIP_ITALIC(cpIdx%) = TL_ITALIC(cpTd%, cpI%)
                        TEXT_CLIP_UNDERLINE(cpIdx%) = TL_UNDERLINE(cpTd%, cpI%)
                        TEXT_CLIP_STRIKE(cpIdx%) = TL_STRIKE(cpTd%, cpI%)
                        TEXT_CLIP_KERN(cpIdx%) = TL_KERN(cpTd%, cpI%)
                        TEXT_CLIP_BASELINE(cpIdx%) = TL_BASELINE(cpTd%, cpI%)
                        TEXT_CLIP_COUNT% = TEXT_CLIP_COUNT% + 1
                    NEXT cpI%
                    TEXT_CLIP_PLAIN$ = cpText$
                    _CLIPBOARD$ = cpText$
                END IF
            END IF
            ctrlCopy% = TRUE
        END IF
        KEYBOARD_handle_text_tool% = TRUE: EXIT FUNCTION
    ELSE: ctrlCopy% = FALSE
    END IF

    ' Ctrl+X = Cut selected text to OS clipboard (with rich formatting)
    IF MODIFIERS.ctrl% AND NOT MODIFIERS.shift% AND (_KEYDOWN(120) OR _KEYDOWN(88)) THEN
        IF NOT ctrlCut% THEN
            IF TEXT_has_selection% AND TEXT.editingTextLayer% >= 1 THEN
                DIM cxTd AS INTEGER
                cxTd% = LAYERS(TEXT.editingTextLayer%).textDataIdx%
                IF cxTd% >= 1 THEN
                    DIM cxStart AS INTEGER, cxEnd AS INTEGER
                    cxStart% = TEXT.selStart%: cxEnd% = TEXT.selEnd%
                    IF cxStart% > cxEnd% THEN SWAP cxStart%, cxEnd%
                    DIM cxText AS STRING
                    cxText$ = ""
                    TEXT_CLIP_COUNT% = 0
                    DIM cxI AS INTEGER
                    FOR cxI% = cxStart% TO cxEnd% - 1
                        DIM cxIdx AS INTEGER
                        cxIdx% = cxI% - cxStart%
                        cxText$ = cxText$ + TL_CHAR(cxTd%, cxI%)
                        TEXT_CLIP_CHAR(cxIdx%) = TL_CHAR(cxTd%, cxI%)
                        TEXT_CLIP_FG(cxIdx%) = TL_FG(cxTd%, cxI%)
                        TEXT_CLIP_BG(cxIdx%) = TL_BG(cxTd%, cxI%)
                        TEXT_CLIP_FONT_IDX(cxIdx%) = TL_FONT_IDX(cxTd%, cxI%)
                        TEXT_CLIP_FONT_SIZE(cxIdx%) = TL_FONT_SIZE(cxTd%, cxI%)
                        TEXT_CLIP_BOLD(cxIdx%) = TL_BOLD(cxTd%, cxI%)
                        TEXT_CLIP_ITALIC(cxIdx%) = TL_ITALIC(cxTd%, cxI%)
                        TEXT_CLIP_UNDERLINE(cxIdx%) = TL_UNDERLINE(cxTd%, cxI%)
                        TEXT_CLIP_STRIKE(cxIdx%) = TL_STRIKE(cxTd%, cxI%)
                        TEXT_CLIP_KERN(cxIdx%) = TL_KERN(cxTd%, cxI%)
                        TEXT_CLIP_BASELINE(cxIdx%) = TL_BASELINE(cxTd%, cxI%)
                        TEXT_CLIP_COUNT% = TEXT_CLIP_COUNT% + 1
                    NEXT cxI%
                    TEXT_CLIP_PLAIN$ = cxText$
                    _CLIPBOARD$ = cxText$
                    ' Delete the selected characters (back to front)
                    DIM cxD AS INTEGER
                    FOR cxD% = cxEnd% - 1 TO cxStart% STEP -1
                        TEXT_LAYER_DATA(cxTd%).cursorPos = cxD% + 1
                        TEXT_LAYER_delete_char cxTd%
                    NEXT cxD%
                    TEXT_clear_selection
                    TEXT_LAYER_DATA(cxTd%).dirty = TRUE
                    ' Update cursor position after cut
                    TEXT.CURSOR_X = TEXT_LAYER_get_char_x%(cxTd%, TEXT_LAYER_DATA(cxTd%).cursorPos)
                    TEXT.CURSOR_Y = TEXT_LAYER_get_line_y%(cxTd%, TEXT_LAYER_get_line_for_char%(cxTd%, TEXT_LAYER_DATA(cxTd%).cursorPos))
                    FRAME_IDLE% = FALSE: SCENE_DIRTY% = TRUE
                END IF
            END IF
            ctrlCut% = TRUE
        END IF
        KEYBOARD_handle_text_tool% = TRUE: EXIT FUNCTION
    ELSE: ctrlCut% = FALSE
    END IF

    ' Ctrl+V = Paste text from OS clipboard (with rich formatting if available)
    IF MODIFIERS.ctrl% AND NOT MODIFIERS.shift% AND (_KEYDOWN(118) OR _KEYDOWN(86)) THEN
        IF NOT ctrlPaste% THEN
            DIM pastedText AS STRING
            pastedText$ = _CLIPBOARD$
            IF LEN(pastedText$) > 0 THEN
                ' Check if we have a matching rich clipboard (internal copy/cut)
                DIM useRichClip AS INTEGER
                useRichClip% = FALSE
                IF TEXT_CLIP_COUNT% > 0 AND pastedText$ = TEXT_CLIP_PLAIN$ THEN
                    useRichClip% = TRUE
                END IF
                DIM pvTd AS INTEGER
                IF TEXT.editingTextLayer% >= 1 THEN
                    pvTd% = LAYERS(TEXT.editingTextLayer%).textDataIdx%
                ELSE
                    pvTd% = 0
                END IF
                DIM pvRichIdx AS INTEGER
                pvRichIdx% = 0
                DIM pvI AS INTEGER
                FOR pvI% = 1 TO LEN(pastedText$)
                    DIM pvCh AS STRING
                    pvCh$ = MID$(pastedText$, pvI%, 1)
                    DIM pvCode AS INTEGER
                    pvCode% = ASC(pvCh$)
                    IF pvCode% = 13 OR pvCode% = 10 THEN
                        ' Skip LF after CR in CRLF pairs
                        IF pvCode% = 13 AND pvI% < LEN(pastedText$) THEN
                            IF ASC(MID$(pastedText$, pvI% + 1, 1)) = 10 THEN pvI% = pvI% + 1
                        END IF
                        TEXT_newline
                        pvRichIdx% = pvRichIdx% + 1
                    ELSEIF pvCode% >= 32 AND pvCode% <= 126 THEN
                        TEXT_add_char pvCh$
                        ' Override with rich clipboard attributes if available
                        IF useRichClip% AND pvRichIdx% < TEXT_CLIP_COUNT% AND pvTd% >= 1 THEN
                            DIM pvCharIdx AS INTEGER
                            pvCharIdx% = TEXT_LAYER_DATA(pvTd%).cursorPos - 1
                            IF pvCharIdx% >= 0 AND pvCharIdx% < TEXT_LAYER_MAX_CHARS THEN
                                TL_FG(pvTd%, pvCharIdx%) = TEXT_CLIP_FG(pvRichIdx%)
                                TL_BG(pvTd%, pvCharIdx%) = TEXT_CLIP_BG(pvRichIdx%)
                                TL_FONT_IDX(pvTd%, pvCharIdx%) = TEXT_CLIP_FONT_IDX(pvRichIdx%)
                                TL_FONT_SIZE(pvTd%, pvCharIdx%) = TEXT_CLIP_FONT_SIZE(pvRichIdx%)
                                TL_BOLD(pvTd%, pvCharIdx%) = TEXT_CLIP_BOLD(pvRichIdx%)
                                TL_ITALIC(pvTd%, pvCharIdx%) = TEXT_CLIP_ITALIC(pvRichIdx%)
                                TL_UNDERLINE(pvTd%, pvCharIdx%) = TEXT_CLIP_UNDERLINE(pvRichIdx%)
                                TL_STRIKE(pvTd%, pvCharIdx%) = TEXT_CLIP_STRIKE(pvRichIdx%)
                                TL_KERN(pvTd%, pvCharIdx%) = TEXT_CLIP_KERN(pvRichIdx%)
                                TL_BASELINE(pvTd%, pvCharIdx%) = TEXT_CLIP_BASELINE(pvRichIdx%)
                            END IF
                        END IF
                        pvRichIdx% = pvRichIdx% + 1
                    END IF
                NEXT pvI%
                FRAME_IDLE% = FALSE: SCENE_DIRTY% = TRUE
            END IF
            ctrlPaste% = TRUE
        END IF
        KEYBOARD_handle_text_tool% = TRUE: EXIT FUNCTION
    ELSE: ctrlPaste% = FALSE
    END IF

    ' Ctrl+A = Select all text in current text layer
    IF MODIFIERS.ctrl% AND NOT MODIFIERS.shift% AND (_KEYDOWN(97) OR _KEYDOWN(65)) THEN
        IF NOT ctrlSelAll% THEN
            IF TEXT.editingTextLayer% >= 1 THEN
                DIM saTd AS INTEGER
                saTd% = LAYERS(TEXT.editingTextLayer%).textDataIdx%
                IF saTd% >= 1 AND TEXT_LAYER_DATA(saTd%).charCount > 0 THEN
                    TEXT.selStart% = 0
                    TEXT.selEnd% = TEXT_LAYER_DATA(saTd%).charCount
                    TEXT.selActive% = TRUE
                    FRAME_IDLE% = FALSE: GUI_NEEDS_REDRAW% = TRUE
                END IF
            END IF
            ctrlSelAll% = TRUE
        END IF
        KEYBOARD_handle_text_tool% = TRUE: EXIT FUNCTION
    ELSE: ctrlSelAll% = FALSE
    END IF

    ' --- Arrow key / cursor navigation (via _KEYDOWN for repeat support) ---
    IF TEXT.editingTextLayer% >= 1 THEN
        DIM akTd AS INTEGER
        akTd% = LAYERS(TEXT.editingTextLayer%).textDataIdx%
        IF akTd% >= 1 THEN
            DIM akPos AS INTEGER
            akPos% = TEXT_LAYER_DATA(akTd%).cursorPos

            ' --- Ctrl+Left = jump to previous word boundary ---
            STATIC ctrlLeftWas AS INTEGER
            IF MODIFIERS.ctrl% AND NOT MODIFIERS.shift% AND _KEYDOWN(19200) THEN
                IF NOT ctrlLeftWas% THEN
                    IF TEXT.selActive% THEN TEXT_clear_selection
                    DIM wlPos AS INTEGER
                    wlPos% = TEXT_LAYER_prev_word_pos%(akTd%, akPos%)
                    TEXT_LAYER_DATA(akTd%).cursorPos = wlPos%
                    TEXT.CURSOR_X = TEXT_LAYER_get_char_x%(akTd%, wlPos%)
                    TEXT.CURSOR_Y = TEXT_LAYER_get_line_y%(akTd%, TEXT_LAYER_get_line_for_char%(akTd%, wlPos%))
                    TEXT.CURSOR_BLINK = 1: TEXT.BLINK_TIMER = TIMER
                    FRAME_IDLE% = FALSE: SCENE_DIRTY% = TRUE
                    ctrlLeftWas% = TRUE
                END IF
                KEYBOARD_handle_text_tool% = TRUE: EXIT FUNCTION
            ELSE: ctrlLeftWas% = FALSE
            END IF

            ' --- Ctrl+Right = jump to next word boundary ---
            STATIC ctrlRightWas AS INTEGER
            IF MODIFIERS.ctrl% AND NOT MODIFIERS.shift% AND _KEYDOWN(19712) THEN
                IF NOT ctrlRightWas% THEN
                    IF TEXT.selActive% THEN TEXT_clear_selection
                    DIM wrPos AS INTEGER
                    wrPos% = TEXT_LAYER_next_word_pos%(akTd%, akPos%)
                    TEXT_LAYER_DATA(akTd%).cursorPos = wrPos%
                    TEXT.CURSOR_X = TEXT_LAYER_get_char_x%(akTd%, wrPos%)
                    TEXT.CURSOR_Y = TEXT_LAYER_get_line_y%(akTd%, TEXT_LAYER_get_line_for_char%(akTd%, wrPos%))
                    TEXT.CURSOR_BLINK = 1: TEXT.BLINK_TIMER = TIMER
                    FRAME_IDLE% = FALSE: SCENE_DIRTY% = TRUE
                    ctrlRightWas% = TRUE
                END IF
                KEYBOARD_handle_text_tool% = TRUE: EXIT FUNCTION
            ELSE: ctrlRightWas% = FALSE
            END IF

            ' --- Ctrl+Shift+Left = select to previous word boundary ---
            STATIC ctrlShiftLeftWas AS INTEGER
            IF MODIFIERS.ctrl% AND MODIFIERS.shift% AND _KEYDOWN(19200) THEN
                IF NOT ctrlShiftLeftWas% THEN
                    DIM cslPos AS INTEGER
                    cslPos% = TEXT_LAYER_prev_word_pos%(akTd%, akPos%)
                    IF TEXT.selStart% < 0 THEN TEXT.selStart% = akPos%
                    TEXT_LAYER_DATA(akTd%).cursorPos = cslPos%
                    TEXT.selEnd% = cslPos%
                    IF TEXT.selStart% <> TEXT.selEnd% THEN
                        TEXT.selActive% = TRUE
                    ELSE
                        TEXT.selActive% = FALSE
                    END IF
                    TEXT.CURSOR_X = TEXT_LAYER_get_char_x%(akTd%, cslPos%)
                    TEXT.CURSOR_Y = TEXT_LAYER_get_line_y%(akTd%, TEXT_LAYER_get_line_for_char%(akTd%, cslPos%))
                    TEXT.CURSOR_BLINK = 1: TEXT.BLINK_TIMER = TIMER
                    FRAME_IDLE% = FALSE: SCENE_DIRTY% = TRUE
                    ctrlShiftLeftWas% = TRUE
                END IF
                KEYBOARD_handle_text_tool% = TRUE: EXIT FUNCTION
            ELSE: ctrlShiftLeftWas% = FALSE
            END IF

            ' --- Ctrl+Shift+Right = select to next word boundary ---
            STATIC ctrlShiftRightWas AS INTEGER
            IF MODIFIERS.ctrl% AND MODIFIERS.shift% AND _KEYDOWN(19712) THEN
                IF NOT ctrlShiftRightWas% THEN
                    DIM csrPos AS INTEGER
                    csrPos% = TEXT_LAYER_next_word_pos%(akTd%, akPos%)
                    IF TEXT.selStart% < 0 THEN TEXT.selStart% = akPos%
                    TEXT_LAYER_DATA(akTd%).cursorPos = csrPos%
                    TEXT.selEnd% = csrPos%
                    IF TEXT.selStart% <> TEXT.selEnd% THEN
                        TEXT.selActive% = TRUE
                    ELSE
                        TEXT.selActive% = FALSE
                    END IF
                    TEXT.CURSOR_X = TEXT_LAYER_get_char_x%(akTd%, csrPos%)
                    TEXT.CURSOR_Y = TEXT_LAYER_get_line_y%(akTd%, TEXT_LAYER_get_line_for_char%(akTd%, csrPos%))
                    TEXT.CURSOR_BLINK = 1: TEXT.BLINK_TIMER = TIMER
                    FRAME_IDLE% = FALSE: SCENE_DIRTY% = TRUE
                    ctrlShiftRightWas% = TRUE
                END IF
                KEYBOARD_handle_text_tool% = TRUE: EXIT FUNCTION
            ELSE: ctrlShiftRightWas% = FALSE
            END IF

            ' --- Up arrow (18432) = move cursor up one line ---
            STATIC arrowUpWas AS INTEGER
            STATIC arrowUpTimer AS DOUBLE
            STATIC arrowUpDelay AS DOUBLE
            IF _KEYDOWN(18432) AND NOT MODIFIERS.ctrl% THEN
                DIM arrowUpNow AS DOUBLE
                arrowUpNow# = TIMER(.001)
                DIM doUpMove AS INTEGER
                doUpMove% = FALSE
                IF NOT arrowUpWas% THEN
                    doUpMove% = TRUE
                    arrowUpTimer# = arrowUpNow#
                    arrowUpDelay# = 0.3
                ELSEIF arrowUpNow# - arrowUpTimer# >= arrowUpDelay# THEN
                    doUpMove% = TRUE
                    arrowUpTimer# = arrowUpNow#
                    arrowUpDelay# = 0.08
                END IF
                IF doUpMove% THEN
                    akPos% = TEXT_LAYER_DATA(akTd%).cursorPos
                    DIM upLine AS INTEGER
                    upLine% = TEXT_LAYER_get_line_for_char%(akTd%, akPos%)
                    IF upLine% > 0 THEN
                        ' Get current X position and target the line above
                        DIM upCurX AS INTEGER
                        upCurX% = TEXT_LAYER_get_char_x%(akTd%, akPos%)
                        DIM upTargetY AS INTEGER
                        upTargetY% = TEXT_LAYER_get_line_y%(akTd%, upLine% - 1)
                        DIM upNewPos AS INTEGER
                        upNewPos% = TEXT_LAYER_get_cursor_at_pos%(akTd%, upCurX%, upTargetY% + 1)
                        IF upNewPos% < 0 THEN upNewPos% = TL_LINE_BREAK(akTd%, upLine% - 1)
                        IF MODIFIERS.shift% THEN
                            IF TEXT.selStart% < 0 THEN TEXT.selStart% = akPos%
                            TEXT.selEnd% = upNewPos%
                            IF TEXT.selStart% <> TEXT.selEnd% THEN
                                TEXT.selActive% = TRUE
                            ELSE
                                TEXT.selActive% = FALSE
                            END IF
                        ELSEIF TEXT.selActive% THEN
                            TEXT_clear_selection
                        END IF
                        TEXT_LAYER_DATA(akTd%).cursorPos = upNewPos%
                        TEXT.CURSOR_X = TEXT_LAYER_get_char_x%(akTd%, upNewPos%)
                        TEXT.CURSOR_Y = TEXT_LAYER_get_line_y%(akTd%, upLine% - 1)
                    ELSE
                        ' Already on first line — move to start
                        IF MODIFIERS.shift% THEN
                            IF TEXT.selStart% < 0 THEN TEXT.selStart% = akPos%
                            TEXT.selEnd% = 0
                            IF TEXT.selStart% <> TEXT.selEnd% THEN
                                TEXT.selActive% = TRUE
                            ELSE
                                TEXT.selActive% = FALSE
                            END IF
                        ELSEIF TEXT.selActive% THEN
                            TEXT_clear_selection
                        END IF
                        TEXT_LAYER_DATA(akTd%).cursorPos = 0
                        TEXT.CURSOR_X = TEXT_LAYER_get_char_x%(akTd%, 0)
                        TEXT.CURSOR_Y = TEXT_LAYER_get_line_y%(akTd%, 0)
                    END IF
                    TEXT.CURSOR_BLINK = 1: TEXT.BLINK_TIMER = TIMER
                    FRAME_IDLE% = FALSE: SCENE_DIRTY% = TRUE
                END IF
                arrowUpWas% = TRUE
                KEYBOARD_handle_text_tool% = TRUE: EXIT FUNCTION
            ELSE: arrowUpWas% = FALSE
            END IF

            ' --- Down arrow (20480) = move cursor down one line ---
            STATIC arrowDownWas AS INTEGER
            STATIC arrowDownTimer AS DOUBLE
            STATIC arrowDownDelay AS DOUBLE
            IF _KEYDOWN(20480) AND NOT MODIFIERS.ctrl% THEN
                DIM arrowDownNow AS DOUBLE
                arrowDownNow# = TIMER(.001)
                DIM doDownMove AS INTEGER
                doDownMove% = FALSE
                IF NOT arrowDownWas% THEN
                    doDownMove% = TRUE
                    arrowDownTimer# = arrowDownNow#
                    arrowDownDelay# = 0.3
                ELSEIF arrowDownNow# - arrowDownTimer# >= arrowDownDelay# THEN
                    doDownMove% = TRUE
                    arrowDownTimer# = arrowDownNow#
                    arrowDownDelay# = 0.08
                END IF
                IF doDownMove% THEN
                    akPos% = TEXT_LAYER_DATA(akTd%).cursorPos
                    DIM dnLine AS INTEGER
                    dnLine% = TEXT_LAYER_get_line_for_char%(akTd%, akPos%)
                    IF dnLine% < TEXT_LAYER_DATA(akTd%).lineCount - 1 THEN
                        ' Get current X position and target the line below
                        DIM dnCurX AS INTEGER
                        dnCurX% = TEXT_LAYER_get_char_x%(akTd%, akPos%)
                        DIM dnTargetY AS INTEGER
                        dnTargetY% = TEXT_LAYER_get_line_y%(akTd%, dnLine% + 1)
                        DIM dnNewPos AS INTEGER
                        dnNewPos% = TEXT_LAYER_get_cursor_at_pos%(akTd%, dnCurX%, dnTargetY% + 1)
                        IF dnNewPos% < 0 THEN dnNewPos% = TL_LINE_BREAK(akTd%, dnLine% + 1)
                        IF MODIFIERS.shift% THEN
                            IF TEXT.selStart% < 0 THEN TEXT.selStart% = akPos%
                            TEXT.selEnd% = dnNewPos%
                            IF TEXT.selStart% <> TEXT.selEnd% THEN
                                TEXT.selActive% = TRUE
                            ELSE
                                TEXT.selActive% = FALSE
                            END IF
                        ELSEIF TEXT.selActive% THEN
                            TEXT_clear_selection
                        END IF
                        TEXT_LAYER_DATA(akTd%).cursorPos = dnNewPos%
                        TEXT.CURSOR_X = TEXT_LAYER_get_char_x%(akTd%, dnNewPos%)
                        TEXT.CURSOR_Y = TEXT_LAYER_get_line_y%(akTd%, dnLine% + 1)
                    ELSE
                        ' Already on last line — move to end
                        DIM dnEndPos AS INTEGER
                        dnEndPos% = TEXT_LAYER_DATA(akTd%).charCount
                        IF MODIFIERS.shift% THEN
                            IF TEXT.selStart% < 0 THEN TEXT.selStart% = akPos%
                            TEXT.selEnd% = dnEndPos%
                            IF TEXT.selStart% <> TEXT.selEnd% THEN
                                TEXT.selActive% = TRUE
                            ELSE
                                TEXT.selActive% = FALSE
                            END IF
                        ELSEIF TEXT.selActive% THEN
                            TEXT_clear_selection
                        END IF
                        TEXT_LAYER_DATA(akTd%).cursorPos = dnEndPos%
                        TEXT.CURSOR_X = TEXT_LAYER_get_char_x%(akTd%, dnEndPos%)
                        TEXT.CURSOR_Y = TEXT_LAYER_get_line_y%(akTd%, dnLine%)
                    END IF
                    TEXT.CURSOR_BLINK = 1: TEXT.BLINK_TIMER = TIMER
                    FRAME_IDLE% = FALSE: SCENE_DIRTY% = TRUE
                END IF
                arrowDownWas% = TRUE
                KEYBOARD_handle_text_tool% = TRUE: EXIT FUNCTION
            ELSE: arrowDownWas% = FALSE
            END IF

            ' Left arrow (19200)
            STATIC arrowLeftWas AS INTEGER
            STATIC arrowLeftTimer AS DOUBLE
            STATIC arrowLeftDelay AS DOUBLE
            IF _KEYDOWN(19200) THEN
                DIM arrowLeftNow AS DOUBLE
                arrowLeftNow# = TIMER(.001)
                DIM doLeftMove AS INTEGER
                doLeftMove% = FALSE
                IF NOT arrowLeftWas% THEN
                    doLeftMove% = TRUE
                    arrowLeftTimer# = arrowLeftNow#
                    arrowLeftDelay# = 0.3
                ELSEIF arrowLeftNow# - arrowLeftTimer# >= arrowLeftDelay# THEN
                    doLeftMove% = TRUE
                    arrowLeftTimer# = arrowLeftNow#
                    arrowLeftDelay# = 0.08
                END IF
                IF doLeftMove% THEN
                    akPos% = TEXT_LAYER_DATA(akTd%).cursorPos
                    IF MODIFIERS.shift% THEN
                        ' Shift+Left: extend selection leftward
                        IF akPos% > 0 THEN
                            IF TEXT.selStart% < 0 THEN TEXT.selStart% = akPos%
                            TEXT_LAYER_DATA(akTd%).cursorPos = akPos% - 1
                            TEXT.selEnd% = akPos% - 1
                            IF TEXT.selStart% <> TEXT.selEnd% THEN
                                TEXT.selActive% = TRUE
                            ELSE
                                TEXT.selActive% = FALSE
                            END IF
                        END IF
                    ELSEIF TEXT.selActive% THEN
                        ' Collapse selection to left edge
                        DIM clpL AS INTEGER
                        clpL% = TEXT.selStart%
                        IF TEXT.selEnd% < clpL% THEN clpL% = TEXT.selEnd%
                        TEXT_LAYER_DATA(akTd%).cursorPos = clpL%
                        TEXT_clear_selection
                    ELSE
                        ' Clear any stale selection anchor
                        TEXT.selStart% = -1: TEXT.selEnd% = -1
                        IF akPos% > 0 THEN
                            TEXT_LAYER_DATA(akTd%).cursorPos = akPos% - 1
                        END IF
                    END IF
                    TEXT.CURSOR_X = TEXT_LAYER_get_char_x%(akTd%, TEXT_LAYER_DATA(akTd%).cursorPos)
                    TEXT.CURSOR_Y = TEXT_LAYER_get_line_y%(akTd%, TEXT_LAYER_get_line_for_char%(akTd%, TEXT_LAYER_DATA(akTd%).cursorPos))
                    TEXT.CURSOR_BLINK = 1: TEXT.BLINK_TIMER = TIMER
                    FRAME_IDLE% = FALSE: SCENE_DIRTY% = TRUE
                END IF
                arrowLeftWas% = TRUE
                KEYBOARD_handle_text_tool% = TRUE: EXIT FUNCTION
            ELSE: arrowLeftWas% = FALSE
            END IF

            ' Right arrow (19712)
            STATIC arrowRightWas AS INTEGER
            STATIC arrowRightTimer AS DOUBLE
            STATIC arrowRightDelay AS DOUBLE
            IF _KEYDOWN(19712) THEN
                DIM arrowRightNow AS DOUBLE
                arrowRightNow# = TIMER(.001)
                DIM doRightMove AS INTEGER
                doRightMove% = FALSE
                IF NOT arrowRightWas% THEN
                    doRightMove% = TRUE
                    arrowRightTimer# = arrowRightNow#
                    arrowRightDelay# = 0.3
                ELSEIF arrowRightNow# - arrowRightTimer# >= arrowRightDelay# THEN
                    doRightMove% = TRUE
                    arrowRightTimer# = arrowRightNow#
                    arrowRightDelay# = 0.08
                END IF
                IF doRightMove% THEN
                    akPos% = TEXT_LAYER_DATA(akTd%).cursorPos
                    IF MODIFIERS.shift% THEN
                        ' Shift+Right: extend selection rightward
                        IF akPos% < TEXT_LAYER_DATA(akTd%).charCount THEN
                            IF TEXT.selStart% < 0 THEN TEXT.selStart% = akPos%
                            TEXT_LAYER_DATA(akTd%).cursorPos = akPos% + 1
                            TEXT.selEnd% = akPos% + 1
                            IF TEXT.selStart% <> TEXT.selEnd% THEN
                                TEXT.selActive% = TRUE
                            ELSE
                                TEXT.selActive% = FALSE
                            END IF
                        END IF
                    ELSEIF TEXT.selActive% THEN
                        ' Collapse selection to right edge
                        DIM clpR AS INTEGER
                        clpR% = TEXT.selStart%
                        IF TEXT.selEnd% > clpR% THEN clpR% = TEXT.selEnd%
                        TEXT_LAYER_DATA(akTd%).cursorPos = clpR%
                        TEXT_clear_selection
                    ELSE
                        ' Clear any stale selection anchor
                        TEXT.selStart% = -1: TEXT.selEnd% = -1
                        IF akPos% < TEXT_LAYER_DATA(akTd%).charCount THEN
                            TEXT_LAYER_DATA(akTd%).cursorPos = akPos% + 1
                        END IF
                    END IF
                    TEXT.CURSOR_X = TEXT_LAYER_get_char_x%(akTd%, TEXT_LAYER_DATA(akTd%).cursorPos)
                    TEXT.CURSOR_Y = TEXT_LAYER_get_line_y%(akTd%, TEXT_LAYER_get_line_for_char%(akTd%, TEXT_LAYER_DATA(akTd%).cursorPos))
                    TEXT.CURSOR_BLINK = 1: TEXT.BLINK_TIMER = TIMER
                    FRAME_IDLE% = FALSE: SCENE_DIRTY% = TRUE
                END IF
                arrowRightWas% = TRUE
                KEYBOARD_handle_text_tool% = TRUE: EXIT FUNCTION
            ELSE: arrowRightWas% = FALSE
            END IF

            ' Home key (18176) — move to start of current line
            IF _KEYDOWN(18176) THEN
                DIM akLine AS INTEGER
                akLine% = TEXT_LAYER_get_line_for_char%(akTd%, akPos%)
                DIM akLineStart AS INTEGER
                akLineStart% = TL_LINE_BREAK(akTd%, akLine%)
                IF MODIFIERS.shift% THEN
                    IF TEXT.selStart% < 0 THEN TEXT.selStart% = akPos%
                    TEXT.selEnd% = akLineStart%
                    IF TEXT.selStart% <> TEXT.selEnd% THEN
                        TEXT.selActive% = TRUE
                    ELSE
                        TEXT.selActive% = FALSE
                    END IF
                ELSEIF TEXT.selActive% THEN
                    TEXT_clear_selection
                END IF
                TEXT_LAYER_DATA(akTd%).cursorPos = akLineStart%
                TEXT.CURSOR_X = TEXT_LAYER_get_char_x%(akTd%, akLineStart%)
                TEXT.CURSOR_Y = TEXT_LAYER_get_line_y%(akTd%, akLine%)
                TEXT.CURSOR_BLINK = 1: TEXT.BLINK_TIMER = TIMER
                FRAME_IDLE% = FALSE: SCENE_DIRTY% = TRUE
                KEYBOARD_handle_text_tool% = TRUE: EXIT FUNCTION
            END IF

            ' End key (20224) — move to end of current line
            IF _KEYDOWN(20224) THEN
                DIM akLine2 AS INTEGER
                akLine2% = TEXT_LAYER_get_line_for_char%(akTd%, akPos%)
                DIM akLineEnd AS INTEGER
                IF akLine2% < TEXT_LAYER_DATA(akTd%).lineCount - 1 THEN
                    akLineEnd% = TL_LINE_BREAK(akTd%, akLine2% + 1) - 1
                ELSE
                    akLineEnd% = TEXT_LAYER_DATA(akTd%).charCount
                END IF
                IF MODIFIERS.shift% THEN
                    IF TEXT.selStart% < 0 THEN TEXT.selStart% = akPos%
                    TEXT.selEnd% = akLineEnd%
                    IF TEXT.selStart% <> TEXT.selEnd% THEN
                        TEXT.selActive% = TRUE
                    ELSE
                        TEXT.selActive% = FALSE
                    END IF
                ELSEIF TEXT.selActive% THEN
                    TEXT_clear_selection
                END IF
                TEXT_LAYER_DATA(akTd%).cursorPos = akLineEnd%
                TEXT.CURSOR_X = TEXT_LAYER_get_char_x%(akTd%, akLineEnd%)
                TEXT.CURSOR_Y = TEXT_LAYER_get_line_y%(akTd%, akLine2%)
                TEXT.CURSOR_BLINK = 1: TEXT.BLINK_TIMER = TIMER
                FRAME_IDLE% = FALSE: SCENE_DIRTY% = TRUE
                KEYBOARD_handle_text_tool% = TRUE: EXIT FUNCTION
            END IF

            ' Delete key (21248) — delete character after cursor (or selection)
            STATIC delKeyWas AS INTEGER
            STATIC delKeyTimer AS DOUBLE
            STATIC delKeyDelay AS DOUBLE
            IF _KEYDOWN(21248) THEN
                DIM delKeyNow AS DOUBLE
                delKeyNow# = TIMER(.001)
                IF NOT delKeyWas% THEN
                    IF TEXT_has_selection% THEN
                        TEXT_delete_selection
                        TEXT_LAYER_DATA(akTd%).dirty = TRUE
                    ELSEIF akPos% < TEXT_LAYER_DATA(akTd%).charCount THEN
                        TEXT_LAYER_DATA(akTd%).cursorPos = akPos% + 1
                        TEXT_LAYER_delete_char akTd%
                        TEXT_LAYER_DATA(akTd%).dirty = TRUE
                    END IF
                    TEXT.CURSOR_X = TEXT_LAYER_get_char_x%(akTd%, TEXT_LAYER_DATA(akTd%).cursorPos)
                    TEXT.CURSOR_Y = TEXT_LAYER_get_line_y%(akTd%, TEXT_LAYER_get_line_for_char%(akTd%, TEXT_LAYER_DATA(akTd%).cursorPos))
                    TEXT.CURSOR_BLINK = 1: TEXT.BLINK_TIMER = TIMER
                    FRAME_IDLE% = FALSE: SCENE_DIRTY% = TRUE
                    delKeyTimer# = delKeyNow#
                    delKeyDelay# = 0.3
                ELSEIF delKeyNow# - delKeyTimer# >= delKeyDelay# THEN
                    akPos% = TEXT_LAYER_DATA(akTd%).cursorPos
                    IF TEXT_has_selection% THEN
                        TEXT_delete_selection
                        TEXT_LAYER_DATA(akTd%).dirty = TRUE
                    ELSEIF akPos% < TEXT_LAYER_DATA(akTd%).charCount THEN
                        TEXT_LAYER_DATA(akTd%).cursorPos = akPos% + 1
                        TEXT_LAYER_delete_char akTd%
                        TEXT_LAYER_DATA(akTd%).dirty = TRUE
                    END IF
                    TEXT.CURSOR_X = TEXT_LAYER_get_char_x%(akTd%, TEXT_LAYER_DATA(akTd%).cursorPos)
                    TEXT.CURSOR_Y = TEXT_LAYER_get_line_y%(akTd%, TEXT_LAYER_get_line_for_char%(akTd%, TEXT_LAYER_DATA(akTd%).cursorPos))
                    TEXT.CURSOR_BLINK = 1: TEXT.BLINK_TIMER = TIMER
                    FRAME_IDLE% = FALSE: SCENE_DIRTY% = TRUE
                    delKeyTimer# = delKeyNow#
                    delKeyDelay# = 0.08
                END IF
                delKeyWas% = TRUE
                KEYBOARD_handle_text_tool% = TRUE: EXIT FUNCTION
            ELSE: delKeyWas% = FALSE
            END IF
        END IF
    END IF

    ' --- Standard character input ---
    IF keypress$ <> "" THEN
        DIM char_code AS INTEGER
        char_code = ASC(keypress$)
        
        SELECT CASE char_code
            CASE 27  ' ESC - close dropdowns first, or cancel text entry
                IF TEXT_BAR.fontDropdownOpen% OR TEXT_BAR.sizeDropdownOpen% THEN
                    TEXT_BAR_close_dropdowns
                    FRAME_IDLE% = FALSE: SCENE_DIRTY% = TRUE: GUI_NEEDS_REDRAW% = TRUE
                ELSE
                    TEXT_cancel
                END IF
            CASE 13  ' ENTER - newline
                SOUND_play SND_TEXT_ENTER
                TEXT_newline
            CASE 9   ' TAB - insert 4 spaces
                SOUND_play SND_TEXT_CHAR
                DIM tabI AS INTEGER
                FOR tabI% = 1 TO 4
                    TEXT_add_char " "
                NEXT tabI%
            CASE 8   ' BACKSPACE
                SOUND_play SND_MENU_SELECT
                TEXT_backspace
            CASE 32 TO 126  ' Printable ASCII characters
                SOUND_play SND_TEXT_CHAR
                TEXT_add_char keypress$
            ' Ignore other special keys while text editing
        END SELECT
    END IF
    KEYBOARD_handle_text_tool% = TRUE  ' Consumed - don't process other keyboard handlers
END FUNCTION


''
' Handle custom brush controls (Ctrl+B to capture, HOME/END/PgUp/PgDn/etc for transformations).
'
SUB KEYBOARD_handle_custom_brush ()
    ' Ctrl+B to capture/clear custom brush
    STATIC ctrlBPressed AS INTEGER
    IF MODIFIERS.ctrl% AND _KEYDOWN(98) THEN ' Ctrl+B (98 = 'b' key)
        IF NOT ctrlBPressed% THEN
            IF CUSTOM_BRUSH_is_active% THEN
                CUSTOM_BRUSH_reset
                CUSTOM_BRUSH_clear_stash
                GUI_NEEDS_REDRAW% = TRUE
            ELSEIF MARQUEE.ACTIVE% THEN
                CUSTOM_BRUSH_capture_from_marquee
                SOUND_play SND_CLIPBOARD
                ' Immediately switch to Brush tool so the new brush is ready to use
                CMD_execute_action 101
                GUI_NEEDS_REDRAW% = TRUE
            END IF
            ctrlBPressed% = TRUE
        END IF
    ELSE
        ctrlBPressed% = FALSE
    END IF
    
    ' Skip transform keys when text tool is actively editing — these keys are handled
    ' by KEYBOARD_handle_text_tool% for cursor navigation instead
    IF TEXT.ACTIVE THEN GOTO SkipTransformKeys

    ' HOME key for horizontal flip
    STATIC homePressed AS INTEGER
    IF _KEYDOWN(18176) AND NOT MODIFIERS.ctrl% THEN
        IF NOT homePressed% THEN
            IF CUSTOM_BRUSH_is_active% THEN
                CUSTOM_BRUSH_toggle_flip_h
            ELSE
                CMD_execute_action 315 ' Flip Horizontal (layer/selection)
            END IF
            homePressed% = TRUE
        END IF
    ELSE
        homePressed% = FALSE
    END IF
    
    ' END key for vertical flip
    STATIC endPressed AS INTEGER
    IF _KEYDOWN(20224) AND NOT MODIFIERS.ctrl% THEN
        IF NOT endPressed% THEN
            IF CUSTOM_BRUSH_is_active% THEN
                CUSTOM_BRUSH_toggle_flip_v
            ELSE
                CMD_execute_action 316 ' Flip Vertical (layer/selection)
            END IF
            endPressed% = TRUE
        END IF
    ELSE
        endPressed% = FALSE
    END IF
    
    ' Page Up for scaling brush up / Scale +50%
    STATIC pgUpPressed AS INTEGER
    IF _KEYDOWN(18688) AND NOT MODIFIERS.ctrl% THEN
        IF NOT pgUpPressed% THEN
            IF CUSTOM_BRUSH_is_active% THEN
                CUSTOM_BRUSH_scale_up
            ELSE
                CMD_execute_action 318 ' Scale +50% (layer/selection)
            END IF
            pgUpPressed% = TRUE
        END IF
    ELSE
        pgUpPressed% = FALSE
    END IF
    
    ' Page Down for scaling brush down / Scale -50%
    STATIC pgDnPressed AS INTEGER
    IF _KEYDOWN(20736) AND NOT MODIFIERS.ctrl% THEN
        IF NOT pgDnPressed% THEN
            IF CUSTOM_BRUSH_is_active% THEN
                CUSTOM_BRUSH_scale_down
            ELSE
                CMD_execute_action 317 ' Scale -50% (layer/selection)
            END IF
            pgDnPressed% = TRUE
        END IF
    ELSE
        pgDnPressed% = FALSE
    END IF

    SkipTransformKeys:
    
    ' / key for resetting brush scale
    STATIC slashPressed AS INTEGER
    IF CUSTOM_BRUSH_is_active% AND _KEYDOWN(47) THEN
        IF NOT slashPressed% THEN
            CUSTOM_BRUSH_scale_reset
            slashPressed% = TRUE
        END IF
    ELSE
        slashPressed% = FALSE
    END IF
    
    ' > key (Shift+.) for rotating 90 CW (universal, only outside image import)
    STATIC rotateCWPressed AS INTEGER
    IF _KEYDOWN(62) AND NOT TEXT.ACTIVE THEN  ' ASCII 62 = >
        IF NOT rotateCWPressed% THEN
            IF IMG_IMPORT.STATE = IMPORT_STATE_IDLE THEN
                IF TRANSFORM.ACTIVE THEN
                    TRANSFORM_rotate_step 90.0!
                ELSE
                    CMD_execute_action 319
                END IF
            END IF
            rotateCWPressed% = TRUE
        END IF
    ELSE
        rotateCWPressed% = FALSE
    END IF
    
    ' < key (Shift+,) for rotating 90 CCW (universal, only outside image import)
    STATIC rotateCCWPressed AS INTEGER
    IF _KEYDOWN(60) AND NOT TEXT.ACTIVE THEN  ' ASCII 60 = <
        IF NOT rotateCCWPressed% THEN
            IF IMG_IMPORT.STATE = IMPORT_STATE_IDLE THEN
                IF TRANSFORM.ACTIVE THEN
                    TRANSFORM_rotate_step -90.0!
                ELSE
                    CMD_execute_action 320
                END IF
            END IF
            rotateCCWPressed% = TRUE
        END IF
    ELSE
        rotateCCWPressed% = FALSE
    END IF
    
    ' F9 for toggling recolor mode
    STATIC f9Pressed AS INTEGER
    IF _KEYDOWN(17152) THEN ' F9
        IF NOT f9Pressed% THEN
            _LOGINFO "F9 pressed - CUSTOM_BRUSH_is_active% = " + STR$(CUSTOM_BRUSH_is_active%)
            IF CUSTOM_BRUSH_is_active% THEN
                CUSTOM_BRUSH_toggle_recolor
            ELSE
                _LOGINFO "F9 ignored - custom brush not active"
            END IF
            f9Pressed% = TRUE
        END IF
    ELSE
        f9Pressed% = FALSE
    END IF
    
    ' ` (backtick) for toggling outline visibility
    STATIC backtickPressed AS INTEGER
    IF CUSTOM_BRUSH_is_active% AND _KEYDOWN(96) THEN
        IF NOT backtickPressed% THEN
            CUSTOM_BRUSH_toggle_outline
            backtickPressed% = TRUE
        END IF
    ELSE
        backtickPressed% = FALSE
    END IF
    
    ' Shift+O for applying outline with BG color
    STATIC shiftOPressed AS INTEGER
    IF CUSTOM_BRUSH_is_active% AND MODIFIERS.shift% AND (_KEYDOWN(79) OR _KEYDOWN(111)) THEN
        IF NOT shiftOPressed% THEN
            CUSTOM_BRUSH_apply_outline
            shiftOPressed% = TRUE
        END IF
    ELSE
        shiftOPressed% = FALSE
    END IF
    
    ' F12 for exporting custom brush
    STATIC f12Pressed AS INTEGER
    IF _KEYDOWN(34304) THEN ' F12
        IF NOT f12Pressed% THEN
            _LOGINFO "F12 key detected"
            IF CUSTOM_BRUSH_is_active% THEN
                _LOGINFO "Custom brush is active, proceeding with export"
                DIM export_filename AS STRING
                export_filename$ = "brush_" + _TRIM$(STR$(TIMER)) + ".png"
                CUSTOM_BRUSH_export_png export_filename$
            ELSE
                _LOGERROR "F12 pressed but custom brush is not active (create brush with Ctrl+B first)"
            END IF
            f12Pressed% = TRUE
        END IF
    ELSE
        f12Pressed% = FALSE
    END IF
END SUB


''
' Handle UI toggle keys (TAB, F10, F11, Ctrl+F11).
'
SUB KEYBOARD_handle_ui_toggles ()
    ' Static variables to prevent key repeat
    STATIC tabPressed AS INTEGER, f10Pressed AS INTEGER, f11Pressed AS INTEGER
    
    ' Handle TAB for toolbar toggle (but not when CTRL or SHIFT is held, or text editing)
    IF _KEYDOWN(9) AND NOT MODIFIERS.ctrl% AND NOT MODIFIERS.shift% AND NOT (CURRENT_TOOL% = TOOL_TEXT AND TEXT.ACTIVE) THEN
        IF NOT tabPressed% THEN
            SCRN.showToolbar% = NOT SCRN.showToolbar%
            SCRN.toolbarManuallyHidden% = NOT SCRN.showToolbar%
            INVALIDATE_scene
            tabPressed% = TRUE
        END IF
    ELSE
        tabPressed% = FALSE
    END IF
    
    ' Handle F10 for status bar toggle
    IF _KEYDOWN(17408) THEN ' F10
        IF NOT f10Pressed% THEN
            SCRN.showStatus% = NOT SCRN.showStatus%
            SCRN.statusManuallyHidden% = NOT SCRN.showStatus%
            INVALIDATE_scene
            f10Pressed% = TRUE
        END IF
    ELSE
        f10Pressed% = FALSE
    END IF
    
    ' Handle F11 for toggle all UI panels (delegates to CMD action 403)
    IF _KEYDOWN(34048) AND NOT MODIFIERS.ctrl% THEN ' F11 (not Ctrl+F11)
        IF NOT f11Pressed% THEN
            CMD_execute_action 403
            FRAME_IDLE% = FALSE
            f11Pressed% = TRUE
        END IF
    ELSEIF NOT _KEYDOWN(34048) THEN
        f11Pressed% = FALSE
    END IF
    
    ' Handle Ctrl+F11 for menu bar toggle only
    STATIC ctrlF11Pressed AS INTEGER
    IF _KEYDOWN(34048) AND MODIFIERS.ctrl% THEN ' Ctrl+F11
        IF NOT ctrlF11Pressed% THEN
            MENU_BAR.visible% = NOT MENU_BAR.visible%
            SCRN.showMenubar% = MENU_BAR.visible%
            SCRN.menubarManuallyHidden% = NOT MENU_BAR.visible%
            IF NOT MENU_BAR.visible% THEN MENUBAR_close_all
            INVALIDATE_scene
            ctrlF11Pressed% = TRUE
        END IF
    ELSE
        ctrlF11Pressed% = FALSE
    END IF
    
    ' Handle Ctrl+R for reference image toggle.
    ' Undo/redo combos must take precedence in this frame; on Linux/SDL2 the
    ' letter-key state can occasionally jitter during Ctrl combos and we must
    ' never let Ctrl+Z/Y open reference-image flows.
    ' Guard checks both ASCII codes (122/90 for z/Z, 121/89 for y/Y) AND
    ' control character codes (26 for Ctrl+Z, 25 for Ctrl+Y) because _KEYDOWN
    ' may report the control code instead of the letter when Ctrl is held.
    ' Also poison the guard when R is held with Shift (tool shortcuts like
    ' Shift+R for filled rect) so a fast Shift+R → Ctrl+Z doesn't race.
    STATIC ctrlRPressed AS INTEGER
    IF NOT MODIFIERS.ctrl% AND MODIFIERS.shift% AND (_KEYDOWN(114) OR _KEYDOWN(82)) THEN
        ctrlRPressed% = TRUE
    END IF
    IF MODIFIERS.ctrl% AND NOT MODIFIERS.shift% AND NOT MODIFIERS.alt% AND (_KEYDOWN(114) OR _KEYDOWN(82)) AND NOT (_KEYDOWN(122) OR _KEYDOWN(90) OR _KEYDOWN(26) OR _KEYDOWN(121) OR _KEYDOWN(89) OR _KEYDOWN(25)) THEN
        IF NOT ctrlRPressed% THEN
            REFIMG_toggle
            FRAME_IDLE% = FALSE
            ctrlRPressed% = TRUE
        END IF
    ELSEIF NOT _KEYDOWN(114) AND NOT _KEYDOWN(82) THEN
        ctrlRPressed% = FALSE
    END IF
    
    ' Handle Ctrl+Alt+R for random palette.
    ' As above, keep this from competing with undo/redo key combos.
    STATIC ctrlAltRPressed AS INTEGER
    IF MODIFIERS.ctrl% AND MODIFIERS.alt% AND NOT MODIFIERS.shift% AND (_KEYDOWN(114) OR _KEYDOWN(82)) AND NOT (_KEYDOWN(122) OR _KEYDOWN(90) OR _KEYDOWN(26) OR _KEYDOWN(121) OR _KEYDOWN(89) OR _KEYDOWN(25)) THEN
        IF NOT ctrlAltRPressed% THEN
            CMD_execute_action 1512
            FRAME_IDLE% = FALSE
            ctrlAltRPressed% = TRUE
        END IF
    ELSEIF NOT _KEYDOWN(114) AND NOT _KEYDOWN(82) THEN
        ctrlAltRPressed% = FALSE
    END IF

    ' Handle Ctrl+PgUp  = display scale up
    ' Handle Ctrl+PgDn  = display scale down
    ' Handle Ctrl+Alt+PgDn = display scale reset
    IF NOT CFG.FULLSCREEN% THEN
        STATIC scaleUpPressed AS INTEGER
        IF MODIFIERS.ctrl% AND NOT MODIFIERS.alt% AND _KEYDOWN(KEY_PGUP&) THEN
            IF NOT scaleUpPressed% THEN
                CMD_execute_action 408
                FRAME_IDLE% = FALSE
                scaleUpPressed% = TRUE
            END IF
        ELSEIF NOT _KEYDOWN(KEY_PGUP&) THEN
            scaleUpPressed% = FALSE
        END IF

        STATIC scaleDownPressed AS INTEGER
        IF MODIFIERS.ctrl% AND NOT MODIFIERS.alt% AND _KEYDOWN(KEY_PGDN&) THEN
            IF NOT scaleDownPressed% THEN
                CMD_execute_action 409
                FRAME_IDLE% = FALSE
                scaleDownPressed% = TRUE
            END IF
        ELSEIF NOT _KEYDOWN(KEY_PGDN&) THEN
            scaleDownPressed% = FALSE
        END IF

        STATIC scaleResetPressed AS INTEGER
        IF MODIFIERS.ctrlAlt% AND _KEYDOWN(KEY_PGDN&) THEN
            IF NOT scaleResetPressed% THEN
                CMD_execute_action 416
                FRAME_IDLE% = FALSE
                scaleResetPressed% = TRUE
            END IF
        ELSEIF NOT _KEYDOWN(KEY_PGDN&) THEN
            scaleResetPressed% = FALSE
        END IF
    END IF

    ' Ctrl+Shift+Left  = Hide/Show Left Side UI (action 436)
    ' Ctrl+Shift+Right = Hide/Show Right Side UI (action 437)
    ' Ctrl+Shift+Up    = Hide/Show Menu Bar (action 438)
    ' Ctrl+Shift+Down  = Hide/Show Status/Colors (action 439)
    ' Uses _KEYDOWN + STATIC pressed guards (Linux/SDL2 safe pattern)
    ' Note: Ctrl+Shift accepted (Alt optional) for Linux/SDL2 reliability.
    STATIC sideLeftPressed AS INTEGER
    IF MODIFIERS.ctrl% AND MODIFIERS.shift% AND _KEYDOWN(19200) THEN
        IF NOT sideLeftPressed% THEN
            CMD_execute_action 436
            FRAME_IDLE% = FALSE
            sideLeftPressed% = TRUE
        END IF
    ELSEIF NOT _KEYDOWN(19200) THEN
        sideLeftPressed% = FALSE
    END IF

    STATIC sideRightPressed AS INTEGER
    IF MODIFIERS.ctrl% AND MODIFIERS.shift% AND _KEYDOWN(19712) THEN
        IF NOT sideRightPressed% THEN
            CMD_execute_action 437
            FRAME_IDLE% = FALSE
            sideRightPressed% = TRUE
        END IF
    ELSEIF NOT _KEYDOWN(19712) THEN
        sideRightPressed% = FALSE
    END IF

    STATIC sideUpPressed AS INTEGER
    IF MODIFIERS.ctrl% AND MODIFIERS.shift% AND _KEYDOWN(18432) THEN
        IF NOT sideUpPressed% THEN
            CMD_execute_action 438
            FRAME_IDLE% = FALSE
            sideUpPressed% = TRUE
        END IF
    ELSEIF NOT _KEYDOWN(18432) THEN
        sideUpPressed% = FALSE
    END IF

    STATIC sideDownPressed AS INTEGER
    IF MODIFIERS.ctrl% AND MODIFIERS.shift% AND _KEYDOWN(20480) THEN
        IF NOT sideDownPressed% THEN
            CMD_execute_action 439
            FRAME_IDLE% = FALSE
            sideDownPressed% = TRUE
        END IF
    ELSEIF NOT _KEYDOWN(20480) THEN
        sideDownPressed% = FALSE
    END IF

    ' Handle Shift+Tab for Pattern Tile Mode toggle (skip during text editing)
    STATIC shiftTabPressed AS INTEGER
    IF MODIFIERS.shift% AND NOT MODIFIERS.ctrl% AND NOT MODIFIERS.alt% AND _KEYDOWN(9) AND NOT (CURRENT_TOOL% = TOOL_TEXT AND TEXT.ACTIVE) THEN
        IF NOT shiftTabPressed% THEN
            CMD_execute_action 440
            FRAME_IDLE% = FALSE
            shiftTabPressed% = TRUE
        END IF
    ELSEIF NOT _KEYDOWN(9) THEN
        shiftTabPressed% = FALSE
    END IF
END SUB


''
' Handle DELETE and BACKSPACE keys.
' DEL       = Edit > Clear (clears selection, or whole layer if no selection)
' Backspace = Fill with FG color
' Shift+Backspace = Fill with BG color
'
SUB KEYBOARD_handle_delete_backspace ()
    ' DELETE = Edit > Clear (same as Edit menu > Clear)
    STATIC deletePressed AS INTEGER
    IF _KEYDOWN(KEY_DELETE&) AND NOT MODIFIERS.ctrl% AND NOT MODIFIERS.shift% THEN
        IF NOT deletePressed% THEN
            IF NOT (CURRENT_TOOL% = TOOL_TEXT AND TEXT.ACTIVE) THEN
                CMD_execute_action 306
            END IF
            deletePressed% = TRUE
        END IF
    ELSEIF NOT _KEYDOWN(KEY_DELETE&) THEN
        deletePressed% = FALSE
    END IF

    ' BACKSPACE = Fill with FG, SHIFT+BACKSPACE = Fill with BG
    STATIC backspacePressed AS INTEGER
    IF _KEYDOWN(KEY_BACKSPACE&) THEN
        IF NOT backspacePressed% THEN
            IF NOT (CURRENT_TOOL% = TOOL_TEXT AND TEXT.ACTIVE) THEN
                IF MODIFIERS.shift% THEN
                    CMD_execute_action 314  ' Fill with BG
                ELSE
                    CMD_execute_action 313  ' Fill with FG
                END IF
            END IF
            backspacePressed% = TRUE
        END IF
    ELSE
        backspacePressed% = FALSE
    END IF
END SUB


''
' Handle grid control keys (apostrophe, semicolon, period, comma).
'
SUB KEYBOARD_handle_grid_controls ()
    ' Apostrophe (') for grid toggle, SHIFT+' (double quote) for pixel grid toggle
    STATIC gridTogglePressed AS INTEGER
    STATIC pixelGridTogglePressed AS INTEGER
    
    ' CTRL+' to cycle grid mode (square -> diagonal -> isometric -> hex)
    STATIC gridModeCyclePressed AS INTEGER
    IF _KEYDOWN(39) AND MODIFIERS.ctrl% THEN
        IF NOT gridModeCyclePressed% THEN
            GRID.GRID_MODE% = (GRID.GRID_MODE% + 1) MOD GRID_MODE_COUNT
            GRID_draw
            INVALIDATE_scene
            gridModeCyclePressed% = TRUE
        END IF
    ELSE
        gridModeCyclePressed% = FALSE
    END IF

    ' Check for double quote (SHIFT+apostrophe = key code 34)
    IF _KEYDOWN(34) THEN ' double quote (SHIFT+')
        IF NOT pixelGridTogglePressed% THEN
            PIXEL_GRID.SHOW% = NOT PIXEL_GRID.SHOW%
            INVALIDATE_scene
            pixelGridTogglePressed% = TRUE
        END IF
    ELSEIF _KEYDOWN(39) AND NOT MODIFIERS.ctrl% THEN ' apostrophe (no shift, no ctrl)
        IF NOT gridTogglePressed% THEN
            GRID.SHOW% = NOT GRID.SHOW%
            INVALIDATE_scene
            gridTogglePressed% = TRUE
        END IF
    ELSE
        gridTogglePressed% = FALSE
        pixelGridTogglePressed% = FALSE
    END IF
    
    ' Semicolon (;) for snap-to-grid toggle
    STATIC snapTogglePressed AS INTEGER
    IF _KEYDOWN(59) THEN
        IF NOT snapTogglePressed% THEN
            GRID.SNAP% = NOT GRID.SNAP%
            GUI_NEEDS_REDRAW% = TRUE
            FRAME_IDLE% = FALSE
            snapTogglePressed% = TRUE
        END IF
    ELSE
        snapTogglePressed% = FALSE
    END IF
    
    ' Period (.) to increase grid size
    STATIC periodPressed AS INTEGER
    IF _KEYDOWN(46) THEN
        IF NOT periodPressed% THEN
            IF GRID.gridWidth% < 50 THEN
                GRID.gridWidth% = GRID.gridWidth% + 1
                GRID.gridHeight% = GRID.gridHeight% + 1
                GRID_draw
                INVALIDATE_scene
            END IF
            periodPressed% = TRUE
        END IF
    ELSE
        periodPressed% = FALSE
    END IF
    
    ' Comma (,) to decrease grid size
    STATIC commaPressed AS INTEGER
    IF _KEYDOWN(44) THEN
        IF NOT commaPressed% THEN
            IF GRID.gridWidth% > 2 THEN
                GRID.gridWidth% = GRID.gridWidth% - 1
                GRID.gridHeight% = GRID.gridHeight% - 1
                GRID_draw
                INVALIDATE_scene
            END IF
            commaPressed% = TRUE
        END IF
    ELSE
        commaPressed% = FALSE
    END IF
    
    ' CTRL+SHIFT+/ to set grid size from brush size
    ' Note: SHIFT+/ produces ? (key code 63), not / (key code 47)
    STATIC ctrlShiftSlashPressed AS INTEGER
    IF _KEYDOWN(63) AND MODIFIERS.ctrl% AND MODIFIERS.shift% THEN
        IF NOT ctrlShiftSlashPressed% THEN
            ' Set grid to brush size and enable tile mode (center alignment)
            IF CUSTOM_BRUSH_is_active% THEN
                ' Use custom brush dimensions
                GRID.gridWidth% = CUSTOM_BRUSH.WIDTH%
                GRID.gridHeight% = CUSTOM_BRUSH.HEIGHT%
            ELSE
                ' Use regular brush size
                GRID.gridWidth% = BRUSH_PIXEL_SIZES(BRUSH_SIZE.CURRENT)
                GRID.gridHeight% = BRUSH_PIXEL_SIZES(BRUSH_SIZE.CURRENT)
            END IF
            GRID.ALIGN_MODE% = GRID_ALIGN_CENTER  ' Center/tile mode for filling gaps
            GRID.SNAP% = TRUE  ' Enable snap to grid
            GRID_draw
            INVALIDATE_scene
            ctrlShiftSlashPressed% = TRUE
        END IF
    ELSE
        ctrlShiftSlashPressed% = FALSE
    END IF
    
    ' Slash (/) to toggle grid alignment mode (corner vs center) - only if no modifiers
    STATIC slashPressed AS INTEGER
    IF _KEYDOWN(47) AND NOT MODIFIERS.ctrl% AND NOT MODIFIERS.shift% AND NOT MODIFIERS.alt% THEN
        IF NOT slashPressed% THEN
            ' Toggle between corner and center alignment
            IF GRID.ALIGN_MODE% = GRID_ALIGN_CORNER THEN
                GRID.ALIGN_MODE% = GRID_ALIGN_CENTER
            ELSE
                GRID.ALIGN_MODE% = GRID_ALIGN_CORNER
            END IF
            GUI_NEEDS_REDRAW% = TRUE
            FRAME_IDLE% = FALSE
            slashPressed% = TRUE
        END IF
    ELSE
        slashPressed% = FALSE
    END IF
END SUB


''
' Handle marquee tool arrow key controls (move/resize with single-press detection).
'
SUB KEYBOARD_handle_marquee_keys ()
    IF NOT (CURRENT_TOOL% = TOOL_MARQUEE AND MARQUEE.ACTIVE%) THEN EXIT SUB
    ' Skip when Ctrl+Shift are held (side toggle combo uses those + arrows)
    IF MODIFIERS.ctrl% AND MODIFIERS.shift% THEN EXIT SUB
    
    DIM moveStep AS INTEGER
    DIM marqKeyUpNow AS INTEGER, marqKeyDownNow AS INTEGER
    DIM marqKeyLeftNow AS INTEGER, marqKeyRightNow AS INTEGER
    
    moveStep% = 1
    IF MODIFIERS.shift% THEN moveStep% = 10
    
    marqKeyUpNow% = _KEYDOWN(18432)
    marqKeyDownNow% = _KEYDOWN(20480)
    marqKeyLeftNow% = _KEYDOWN(19200)
    marqKeyRightNow% = _KEYDOWN(19712)

    IF marqKeyUpNow% AND NOT MARQUEE.KEY_UP_LAST THEN
        IF MODIFIERS.ctrl% THEN
            MARQUEE.BOX.h = MARQUEE.BOX.h - moveStep%
            IF MARQUEE.BOX.h < 8 THEN MARQUEE.BOX.h = 8
        ELSE
            MARQUEE.BOX.y = MARQUEE.BOX.y - moveStep%
        END IF
    END IF
    IF marqKeyDownNow% AND NOT MARQUEE.KEY_DOWN_LAST THEN
        IF MODIFIERS.ctrl% THEN
            MARQUEE.BOX.h = MARQUEE.BOX.h + moveStep%
        ELSE
            MARQUEE.BOX.y = MARQUEE.BOX.y + moveStep%
        END IF
    END IF
    IF marqKeyLeftNow% AND NOT MARQUEE.KEY_LEFT_LAST THEN
        IF MODIFIERS.ctrl% THEN
            MARQUEE.BOX.w = MARQUEE.BOX.w - moveStep%
            IF MARQUEE.BOX.w < 8 THEN MARQUEE.BOX.w = 8
        ELSE
            MARQUEE.BOX.x = MARQUEE.BOX.x - moveStep%
        END IF
    END IF
    IF marqKeyRightNow% AND NOT MARQUEE.KEY_RIGHT_LAST THEN
        IF MODIFIERS.ctrl% THEN
            MARQUEE.BOX.w = MARQUEE.BOX.w + moveStep%
        ELSE
            MARQUEE.BOX.x = MARQUEE.BOX.x + moveStep%
        END IF
    END IF
    
    MARQUEE.KEY_UP_LAST = marqKeyUpNow%
    MARQUEE.KEY_DOWN_LAST = marqKeyDownNow%
    MARQUEE.KEY_LEFT_LAST = marqKeyLeftNow%
    MARQUEE.KEY_RIGHT_LAST = marqKeyRightNow%
END SUB


''
''
' Handle M+= / M+- / M+Shift+= / M+Shift+- chords for expand/contract selection.
' Only fires when a selection is active. M held via _KEYDOWN (held), not _KEYHIT (tap),
' so it does not conflict with the marquee tool-activation tap on M.
' No Ctrl/Alt guard to avoid collision with any Ctrl+M or Alt+M future bindings.
'
SUB KEYBOARD_handle_marquee_expand_contract ()
    IF NOT SELECTION_has_active% THEN EXIT SUB
    ' Require M held, no Ctrl, no Alt
    IF NOT (_KEYDOWN(77) OR _KEYDOWN(109)) THEN EXIT SUB
    IF MODIFIERS.ctrl% OR MODIFIERS.alt% THEN EXIT SUB

    STATIC expand1Pressed AS INTEGER
    STATIC contract1Pressed AS INTEGER
    STATIC expandNPressed AS INTEGER
    STATIC contractNPressed AS INTEGER

    ' = key (61) without Shift → Expand 1px
    IF NOT MODIFIERS.shift% AND _KEYDOWN(61) THEN
        IF NOT expand1Pressed% THEN
            CMD_execute_action 1410
            FRAME_IDLE% = FALSE
            expand1Pressed% = TRUE
        END IF
    ELSE
        IF NOT _KEYDOWN(61) THEN expand1Pressed% = FALSE
    END IF

    ' - key (45) without Shift → Contract 1px
    IF NOT MODIFIERS.shift% AND _KEYDOWN(45) THEN
        IF NOT contract1Pressed% THEN
            CMD_execute_action 1411
            FRAME_IDLE% = FALSE
            contract1Pressed% = TRUE
        END IF
    ELSE
        IF NOT _KEYDOWN(45) THEN contract1Pressed% = FALSE
    END IF

    ' = key (61) with Shift (i.e. + on US keyboard) → Expand NUDGE_N px
    IF MODIFIERS.shift% AND _KEYDOWN(61) THEN
        IF NOT expandNPressed% THEN
            CMD_execute_action 1412
            FRAME_IDLE% = FALSE
            expandNPressed% = TRUE
        END IF
    ELSE
        IF NOT _KEYDOWN(61) THEN expandNPressed% = FALSE
    END IF

    ' - key (45) with Shift (i.e. _ on US keyboard) → Contract NUDGE_N px
    IF MODIFIERS.shift% AND _KEYDOWN(45) THEN
        IF NOT contractNPressed% THEN
            CMD_execute_action 1413
            FRAME_IDLE% = FALSE
            contractNPressed% = TRUE
        END IF
    ELSE
        IF NOT _KEYDOWN(45) THEN contractNPressed% = FALSE
    END IF
END SUB


''
' Handle MOVE tool arrow key controls.
' CTRL+Arrows: nudge selection/layer by 1px (auto-captures if not active).
' CTRL+SHIFT+Arrows: nudge by CFG.NUDGE_N% px.
' When move IS active: bare Arrows also nudge 1px, SHIFT+Arrows nudge CFG.NUDGE_N% px.
'
SUB KEYBOARD_handle_move_keys ()
    DIM moveMoveStep AS INTEGER
    DIM keyUpNow AS INTEGER, keyDownNow AS INTEGER, keyLeftNow AS INTEGER, keyRightNow AS INTEGER

    keyUpNow% = _KEYDOWN(18432)
    keyDownNow% = _KEYDOWN(20480)
    keyLeftNow% = _KEYDOWN(19200)
    keyRightNow% = _KEYDOWN(19712)

    DIM anyArrow AS INTEGER
    anyArrow% = keyUpNow% OR keyDownNow% OR keyLeftNow% OR keyRightNow%

    ' --- CTRL+Arrow (no Shift, no Alt): auto-activate move tool and nudge ---
    ' Alt+Arrow is reserved for side-toggle combos; skip move when Alt is held.
    ' Shift is also excluded so that Ctrl+Shift+Arrow (en route to
    ' Ctrl+Alt+Shift+Arrow where Alt arrives a frame later) doesn't
    ' accidentally auto-switch to the move tool.
    ' When already in move mode, Ctrl+Shift+Arrow nudge-by-N still works
    ' via the bare-arrow section below.
    IF MODIFIERS.ctrl% AND NOT MODIFIERS.alt% AND NOT MODIFIERS.shift% AND anyArrow% THEN
        ' If not currently in move tool, switch to it
        IF CURRENT_TOOL% <> TOOL_MOVE THEN
            PREVIOUS_TOOL% = CURRENT_TOOL%
            CURRENT_TOOL% = TOOL_MOVE
            TOOLS_reset_all FALSE
            GUI_NEEDS_REDRAW% = TRUE
        END IF
        ' If move not active, capture the selection/layer
        IF NOT MOVE.ACTIVE THEN
            MOVE_capture_selection
        END IF

        moveMoveStep% = 1
        IF MODIFIERS.shift% THEN moveMoveStep% = CFG.NUDGE_N%

        IF keyUpNow% AND NOT MOVE_KEY_UP_LAST% THEN
            MOVE_nudge 0, -moveMoveStep%
        END IF
        IF keyDownNow% AND NOT MOVE_KEY_DOWN_LAST% THEN
            MOVE_nudge 0, moveMoveStep%
        END IF
        IF keyLeftNow% AND NOT MOVE_KEY_LEFT_LAST% THEN
            MOVE_nudge -moveMoveStep%, 0
        END IF
        IF keyRightNow% AND NOT MOVE_KEY_RIGHT_LAST% THEN
            MOVE_nudge moveMoveStep%, 0
        END IF

        MOVE_KEY_UP_LAST% = keyUpNow%
        MOVE_KEY_DOWN_LAST% = keyDownNow%
        MOVE_KEY_LEFT_LAST% = keyLeftNow%
        MOVE_KEY_RIGHT_LAST% = keyRightNow%

        ' Update clone mode based on ALT key
        MOVE.CLONING = MODIFIERS.alt%
        MOVE_update_preview_buffer
        EXIT SUB
    END IF

    ' --- Move tool active: bare arrows nudge, SHIFT = large step ---
    ' Skip bare-arrow nudge when Ctrl+Shift are held (side toggle combo)
    IF MODIFIERS.ctrl% AND MODIFIERS.shift% THEN
        MOVE_KEY_UP_LAST% = keyUpNow%
        MOVE_KEY_DOWN_LAST% = keyDownNow%
        MOVE_KEY_LEFT_LAST% = keyLeftNow%
        MOVE_KEY_RIGHT_LAST% = keyRightNow%
        EXIT SUB
    END IF
    IF NOT (CURRENT_TOOL% = TOOL_MOVE AND MOVE.ACTIVE) THEN
        ' Not in active move mode and no CTRL held — clear key state and exit
        MOVE_KEY_UP_LAST% = keyUpNow%
        MOVE_KEY_DOWN_LAST% = keyDownNow%
        MOVE_KEY_LEFT_LAST% = keyLeftNow%
        MOVE_KEY_RIGHT_LAST% = keyRightNow%
        EXIT SUB
    END IF

    moveMoveStep% = 1
    IF MODIFIERS.shift% THEN moveMoveStep% = CFG.NUDGE_N%

    IF keyUpNow% AND NOT MOVE_KEY_UP_LAST% THEN
        MOVE_nudge 0, -moveMoveStep%
    END IF
    IF keyDownNow% AND NOT MOVE_KEY_DOWN_LAST% THEN
        MOVE_nudge 0, moveMoveStep%
    END IF
    IF keyLeftNow% AND NOT MOVE_KEY_LEFT_LAST% THEN
        MOVE_nudge -moveMoveStep%, 0
    END IF
    IF keyRightNow% AND NOT MOVE_KEY_RIGHT_LAST% THEN
        MOVE_nudge moveMoveStep%, 0
    END IF

    MOVE_KEY_UP_LAST% = keyUpNow%
    MOVE_KEY_DOWN_LAST% = keyDownNow%
    MOVE_KEY_LEFT_LAST% = keyLeftNow%
    MOVE_KEY_RIGHT_LAST% = keyRightNow%

    ' Update clone mode based on ALT key
    MOVE.CLONING = MODIFIERS.alt%
    MOVE_update_preview_buffer
END SUB


''
' Handle clipboard, selection, and undo operations (Ctrl+C/X/V/E/T/D/A/I/Z/Y).
'
SUB KEYBOARD_handle_clipboard_operations ()
    ' Static variables for single-press detection
    STATIC CLIPBOARD_KEY_D_LAST AS INTEGER
    STATIC CLIPBOARD_KEY_A_LAST AS INTEGER
    STATIC CLIPBOARD_KEY_I_LAST AS INTEGER
    
    DIM keyDNow AS INTEGER, keyANow AS INTEGER, keyINow AS INTEGER
    IF NOT MODIFIERS.ctrl% THEN EXIT SUB
    
    DIM selIsShift AS INTEGER
    selIsShift% = MODIFIERS.shift%
    
    ' Ctrl+D: Deselect
    keyDNow% = _KEYDOWN(100)
    IF keyDNow% AND NOT CLIPBOARD_KEY_D_LAST% THEN
        IF MARQUEE.WAND_HAS_SELECTION AND MARQUEE.SELECTION_MASK < -1 THEN
            MAGIC_WAND_reset
            MARQUEE.ACTIVE% = FALSE
            GUI_NEEDS_REDRAW% = TRUE
            FRAME_IDLE% = FALSE
        ELSEIF MARQUEE.ACTIVE% THEN
            MARQUEE_clear
            GUI_NEEDS_REDRAW% = TRUE
            FRAME_IDLE% = FALSE
        END IF
    END IF
    CLIPBOARD_KEY_D_LAST% = keyDNow%
    
    ' Ctrl+A: Select All
    keyANow% = _KEYDOWN(97)
    IF keyANow% AND NOT CLIPBOARD_KEY_A_LAST% AND NOT selIsShift% THEN
        SELECTION_select_all
    END IF
    CLIPBOARD_KEY_A_LAST% = keyANow%
    
    ' Ctrl+Shift+I: Invert Selection
    keyINow% = _KEYDOWN(105) OR _KEYDOWN(73)
    IF keyINow% AND NOT CLIPBOARD_KEY_I_LAST% AND selIsShift% THEN
        SELECTION_invert
    END IF
    CLIPBOARD_KEY_I_LAST% = keyINow%
    
    ' Clipboard operations
    DIM clipIsShift AS INTEGER, clipIsAlt AS INTEGER
    DIM keyCNow AS INTEGER, keyXNow AS INTEGER, keyVNow AS INTEGER, keyENow AS INTEGER
    
    clipIsShift% = selIsShift%
    clipIsAlt% = MODIFIERS.alt%
    
    keyCNow% = _KEYDOWN(99) OR _KEYDOWN(67)
    keyXNow% = _KEYDOWN(120) OR _KEYDOWN(88)
    keyVNow% = _KEYDOWN(118) OR _KEYDOWN(86)
    keyENow% = _KEYDOWN(101) OR _KEYDOWN(69)
    
    ' Ctrl+C: Copy
    IF keyCNow% AND NOT CLIPBOARD_KEY_C_LAST% AND NOT clipIsShift% AND NOT clipIsAlt% THEN
        CLIPBOARD_copy
    END IF
    
    ' Ctrl+Shift+C: Copy merged
    IF keyCNow% AND NOT CLIPBOARD_KEY_C_LAST% AND clipIsShift% AND NOT clipIsAlt% THEN
        CLIPBOARD_copy_merged
    END IF
    
    ' Ctrl+X: Cut
    IF keyXNow% AND NOT CLIPBOARD_KEY_X_LAST% AND NOT clipIsShift% AND NOT clipIsAlt% THEN
        CLIPBOARD_cut
    END IF

    ' Ctrl+Alt+C: Copy to New Layer
    IF keyCNow% AND NOT CLIPBOARD_KEY_C_LAST% AND clipIsAlt% AND NOT clipIsShift% THEN
        CMD_execute_action 321
    END IF

    ' Ctrl+Alt+X: Cut to New Layer
    IF keyXNow% AND NOT CLIPBOARD_KEY_X_LAST% AND clipIsAlt% AND NOT clipIsShift% THEN
        CMD_execute_action 323
    END IF
    
    ' Ctrl+V: Paste
    IF keyVNow% AND NOT CLIPBOARD_KEY_V_LAST% AND NOT clipIsShift% AND NOT clipIsAlt% THEN
        CLIPBOARD_paste MOUSE.X%, MOUSE.Y%
    END IF

    ' Ctrl+Shift+V: Paste from OS Clipboard
    IF keyVNow% AND NOT CLIPBOARD_KEY_V_LAST% AND clipIsShift% AND NOT clipIsAlt% THEN
        CMD_execute_action 330
    END IF
    
    ' Ctrl+E: Clear selection
    IF keyENow% AND NOT CLIPBOARD_KEY_E_LAST% AND NOT clipIsShift% AND NOT clipIsAlt% THEN
        IF CURRENT_TOOL% = TOOL_MARQUEE AND MARQUEE.MAGIC_WAND_MODE AND MARQUEE.WAND_HAS_SELECTION THEN
            MAGIC_WAND_clear_selected_transparent
            MAGIC_WAND_reset
            GUI_NEEDS_REDRAW% = TRUE
        ELSE
            CLIPBOARD_clear_selection
        END IF
    END IF
    
    ' Ctrl+T: Activate text tool with custom font
    DIM keyTNow AS INTEGER
    keyTNow% = _KEYDOWN(116)
    IF keyTNow% AND NOT CLIPBOARD_KEY_T_LAST% AND NOT clipIsShift% AND NOT clipIsAlt% THEN
        _LOGINFO "CTRL-T pressed!"
        _LOGINFO "Custom font handle: " + STR$(TEXT.CUSTOM_FONT_HANDLE)
        PREVIOUS_TOOL% = CURRENT_TOOL%
        CURRENT_TOOL% = TOOL_TEXT
        TOOLS_reset_all FALSE  ' Reset all tools, preserve marquee selection
        
        IF TEXT.CUSTOM_FONT_HANDLE > 0 THEN
            _LOGINFO "Using custom font!"
            TEXT.USE_CUSTOM = TRUE
            TEXT.USE_TINY5 = FALSE
            DIM old_font_ctrl AS LONG
            old_font_ctrl& = _FONT
            _FONT TEXT.CUSTOM_FONT_HANDLE
            TEXT.CHAR_WIDTH = _PRINTWIDTH("A")
            TEXT.LINE_HEIGHT = _FONTHEIGHT + 2
            _FONT old_font_ctrl&
            _LOGINFO "Custom font activated - width: " + STR$(TEXT.CHAR_WIDTH) + " height: " + STR$(TEXT.LINE_HEIGHT)
        ELSE
            _LOGINFO "No custom font loaded - using VGA"
            TEXT.USE_CUSTOM = FALSE
            TEXT.USE_TINY5 = FALSE
            TEXT.CHAR_WIDTH = 8
            TEXT.LINE_HEIGHT = 13
        END IF
        TEXT_reset
    END IF
    
    ' Update key states
    CLIPBOARD_KEY_C_LAST% = keyCNow%
    CLIPBOARD_KEY_X_LAST% = keyXNow%
    CLIPBOARD_KEY_V_LAST% = keyVNow%
    CLIPBOARD_KEY_E_LAST% = keyENow%
    CLIPBOARD_KEY_T_LAST% = keyTNow%
    
    ' Undo/Redo operations
    DIM keyZNow AS INTEGER, keyYNow AS INTEGER
    
    keyZNow% = _KEYDOWN(122) OR _KEYDOWN(90)
    keyYNow% = _KEYDOWN(121) OR _KEYDOWN(89)
    
    ' Ctrl+Z: Intelligent Undo (or abort active Move)
    IF keyZNow% AND NOT UNDO_KEY_Z_LAST% AND NOT clipIsShift% AND NOT clipIsAlt% THEN
        IF CURRENT_TOOL% = TOOL_MOVE AND MOVE.ACTIVE THEN
            ' Abort the active move instead of undoing — same as ESC
            ' Suppress undo save so MOVE_apply_transform (called by MOVE_reset)
            ' doesn't create a phantom state identical to pre-capture
            HISTORY_saved_this_frame% = TRUE
            MOVE_cancel_transform
            MOVE_reset
            ' Clear auto-created marquee but keep TOOL_MOVE selected
            IF MARQUEE.ACTIVE% AND NOT MARQUEE.USER_CREATED THEN
                MARQUEE_reset
            END IF
            GUI_NEEDS_REDRAW% = TRUE
            FRAME_IDLE% = FALSE
        ELSEIF (CURRENT_TOOL% = TOOL_POLYGON OR CURRENT_TOOL% = TOOL_POLYGON_FILLED) AND POLY_LINE.HAS_LAST AND POLY_LINE.HISTORY_BEFORE_IMG < -1 THEN
            POLY_LINE_cancel_restore
            GUI_NEEDS_REDRAW% = TRUE
            FRAME_IDLE% = FALSE
        ELSE
            IF HISTORY_can_undo% THEN
                _LOGINFO "CTRL-Z: History undo"
                HISTORY_undo
            END IF
            GUI_NEEDS_REDRAW% = TRUE
            FRAME_IDLE% = FALSE
            SCREEN_render
        END IF
    END IF
    UNDO_KEY_Z_LAST% = keyZNow%
    
    ' Ctrl+Y OR Ctrl+Shift+Z: Intelligent Redo
    IF (keyYNow% AND NOT UNDO_KEY_Y_LAST%) OR (keyZNow% AND NOT UNDO_KEY_Z_LAST% AND clipIsShift%) THEN
        IF HISTORY_can_redo% THEN
            _LOGINFO "CTRL-Y: History redo"
            HISTORY_redo
        END IF
        GUI_NEEDS_REDRAW% = TRUE
        FRAME_IDLE% = FALSE
        SCREEN_render
    END IF
    UNDO_KEY_Y_LAST% = keyYNow%
END SUB


''
' Handle file operations (Ctrl+O/S/Shift+S/Alt+S).
'
SUB KEYBOARD_handle_file_operations ()
    IF NOT MODIFIERS.ctrl% THEN EXIT SUB
    
    DIM fileIsShift AS INTEGER, fileIsAlt AS INTEGER
    DIM keyONow AS INTEGER, keySNow AS INTEGER, keyNNow AS INTEGER
    
    fileIsShift% = MODIFIERS.shift%
    fileIsAlt% = MODIFIERS.alt%
    
    keyONow% = _KEYDOWN(111) OR _KEYDOWN(79)
    keySNow% = _KEYDOWN(115) OR _KEYDOWN(83)
    keyNNow% = _KEYDOWN(110) OR _KEYDOWN(78)
    
    ' Ctrl+N: New canvas (only if SHIFT not pressed - CTRL+SHIFT+N is new layer)
    IF keyNNow% AND NOT fileIsShift% AND NOT FILE_KEY_N_LAST% THEN
        DRW_new_canvas
    END IF
    
    ' Ctrl+O: Open file
    IF keyONow% AND NOT FILE_KEY_O_LAST% THEN
        LOAD_image
    END IF
    
    ' Ctrl+S variants: Save operations
    IF keySNow% AND NOT FILE_KEY_S_LAST% THEN
        IF fileIsShift% AND fileIsAlt% THEN
            ' Ctrl+Alt+Shift+S: Export Selection
            CMD_execute_action 205
        ELSEIF fileIsShift% AND NOT fileIsAlt% THEN
            SAVE_as
        ELSEIF NOT fileIsShift% AND NOT fileIsAlt% THEN
            SAVE_image
        END IF
    END IF
    
    FILE_KEY_N_LAST% = keyNNow%
    FILE_KEY_O_LAST% = keyONow%
    FILE_KEY_S_LAST% = keySNow%
END SUB


''
' Handle zoom shortcuts (Ctrl+0/+/-).
'
SUB KEYBOARD_handle_zoom_shortcuts ()
    IF NOT MODIFIERS.ctrl% THEN EXIT SUB
    
    DIM zoomIsShift AS INTEGER, zoomIsAlt AS INTEGER
    zoomIsShift% = MODIFIERS.shift%
    zoomIsAlt% = MODIFIERS.alt%
    
    ' Skip if using display scale combo (Ctrl+Alt+Shift)
    IF zoomIsShift% AND zoomIsAlt% THEN EXIT SUB
    
    STATIC zoom0Pressed AS INTEGER, zoomPlusPressed AS INTEGER, zoomMinusPressed AS INTEGER
    
    ' Ctrl+0: Reset zoom to 100% and center
    IF _KEYDOWN(48) THEN
        IF NOT zoom0Pressed% THEN
            SCRN.zoom! = 1.0
            SCRN.offsetX% = 0
            SCRN.offsetY% = 0
            GUI_NEEDS_REDRAW% = TRUE
            zoom0Pressed% = TRUE
        END IF
    ELSE
        zoom0Pressed% = FALSE
    END IF
    
    ' Ctrl+=: Zoom in
    IF _KEYDOWN(61) THEN
        IF NOT zoomPlusPressed% THEN
            IF SCRN.zoom! < 0.5 THEN
                SCRN.zoom! = 0.5
            ELSEIF SCRN.zoom! < 1.0 THEN
                SCRN.zoom! = 1.0
            ELSE
                SCRN.zoom! = INT(SCRN.zoom!) + 1.0
                IF SCRN.zoom! > SCRN.zoomMax! THEN SCRN.zoom! = SCRN.zoomMax!
            END IF
            GUI_NEEDS_REDRAW% = TRUE
            zoomPlusPressed% = TRUE
        END IF
    ELSE
        zoomPlusPressed% = FALSE
    END IF
    
    ' Ctrl+-: Zoom out
    IF _KEYDOWN(45) THEN
        IF NOT zoomMinusPressed% THEN
            IF SCRN.zoom! > 1.0 THEN
                SCRN.zoom! = INT(SCRN.zoom!) - 1.0
                IF SCRN.zoom! < 1.0 THEN SCRN.zoom! = 1.0
            ELSEIF SCRN.zoom! > 0.5 THEN
                SCRN.zoom! = 0.5
            ELSE
                SCRN.zoom! = 0.25
            END IF
            GUI_NEEDS_REDRAW% = TRUE
            zoomMinusPressed% = TRUE
        END IF
    ELSE
        zoomMinusPressed% = FALSE
    END IF
END SUB


''
' Handle layer navigation shortcuts (Shift+[/]).
' NOTE: Ctrl+Alt+E and Ctrl+Alt+Shift+E were moved to KEYBOARD_layers because
' KEYBOARD_handle_layer_shortcuts can be skipped by EXIT SUB when Alt is held
' (menubar steals focus). KEYBOARD_layers always runs unconditionally.
'
SUB KEYBOARD_handle_layer_shortcuts ()
    DIM isCtrl AS INTEGER, isShift AS INTEGER, isAlt AS INTEGER
    isCtrl% = MODIFIERS.ctrl%
    isShift% = MODIFIERS.shift%
    isAlt% = MODIFIERS.alt%
    
    STATIC layerShiftBracketLPressed AS INTEGER, layerShiftBracketRPressed AS INTEGER
    layerShiftBracketLPressed% = FALSE  ' Cleared; { } repurposed for music track next/prev
    layerShiftBracketRPressed% = FALSE
    
    ' (Ctrl+Alt+E and Ctrl+Alt+Shift+E handled in KEYBOARD_layers — see note above)
END SUB


''
' Handle keyboard input
' 
SUB KEYBOARD_input_handler ()
    DIM keypress AS STRING
    DIM drainKey AS LONG
    
    ' Layer keyboard handling - MUST run first before any EXIT SUB statements
    ' Uses _KEYDOWN() so runs every frame regardless of INKEY$ state
    ' Skip when text tool is actively editing — all global hotkeys are gated
    IF NOT (CURRENT_TOOL% = TOOL_TEXT AND TEXT.ACTIVE) THEN KEYBOARD_layers

    ' Eraser hold/tap handling - MUST run before EXIT SUBs
    ' Uses _KEYDOWN() so runs every frame regardless of INKEY$ state
    IF NOT (CURRENT_TOOL% = TOOL_TEXT AND TEXT.ACTIVE) THEN KEYBOARD_handle_eraser_hold

    ' Ctrl+Shift+Arrow = side toggles — handle at top, EXIT SUB.
    ' On Linux/SDL2, Alt frequently fails to register when Ctrl+Shift are held.
    ' We accept Ctrl+Shift (with or without Alt) to ensure reliability.
    ' The move auto-activation already requires NOT shift%, so no conflict.
    ' Skip when text tool is editing — Ctrl+Shift+Arrow is word select there.
    IF MODIFIERS.ctrl% AND MODIFIERS.shift% AND NOT (CURRENT_TOOL% = TOOL_TEXT AND TEXT.ACTIVE) THEN
        IF _KEYDOWN(19200) OR _KEYDOWN(19712) OR _KEYDOWN(18432) OR _KEYDOWN(20480) THEN
            KEYBOARD_handle_ui_toggles
            ' Keep move/marquee key tracking in sync to prevent false transitions
            MOVE_KEY_UP_LAST% = _KEYDOWN(18432)
            MOVE_KEY_DOWN_LAST% = _KEYDOWN(20480)
            MOVE_KEY_LEFT_LAST% = _KEYDOWN(19200)
            MOVE_KEY_RIGHT_LAST% = _KEYDOWN(19712)
            EXIT SUB
        END IF
    END IF

    IF DRAWER.contextMenuOpen% AND _KEYDOWN(27) THEN
        DRAWER_context_menu_close
        EXIT SUB
    END IF

    ' Close blend mode popup on Escape before other handlers
    IF LAYER_PANEL.blendPopupOpen% AND _KEYDOWN(27) THEN
        LAYER_PANEL_blend_popup_close
        EXIT SUB
    END IF

    ' Handle menu bar keyboard navigation (ALT tap, arrow keys, Enter, Escape)
    IF KEYBOARD_handle_menubar% THEN EXIT SUB
    
    ' Handle IMAGE IMPORT mode - intercept Enter/Escape and arrow keys
    IF KEYBOARD_handle_image_import% THEN EXIT SUB

    ' Handle CROP mode - intercept Enter/Escape and arrow keys
    IF KEYBOARD_handle_crop_tool% THEN EXIT SUB
    
    ' Handle REFERENCE IMAGE reposition mode - intercept Enter/Escape
    IF KEYBOARD_handle_refimg_reposition% THEN EXIT SUB
    
    ' Handle command palette if visible
    IF KEYBOARD_handle_command_palette% THEN EXIT SUB
    
    ' Handle palette menu if visible
    IF KEYBOARD_handle_palette_menu% THEN EXIT SUB
    
    ' NOTE: Display scale hotkeys (CTRL+ALT+SHIFT+=/-) are handled in DRAW.BAS main loop
    ' using _KEYHIT which is more reliable on Linux for complex modifier combinations

    ' On Linux/SDL2, Ctrl/Alt combinations can leak ASCII control characters into
    ' INKEY$ even though the real shortcut handling below uses _KEYDOWN(). Drain the
    ' keyboard buffer before any INKEY$-driven tool/color handlers so modifier presses
    ' cannot masquerade as ESC/Z/Y/etc. when the user is only holding modifiers.
    IF MODIFIERS.ctrl% OR MODIFIERS.alt% THEN
        drainKey& = _KEYHIT
        DO WHILE drainKey& <> 0
            drainKey& = _KEYHIT
        LOOP
        keypress$ = ""
        KEYHIT_CHAR$ = ""  ' Also clear the _KEYHIT fallback from DRAW.BAS main loop
    END IF
    
    ' Handle custom brush controls (Ctrl+B to capture, HOME/END/PgUp/PgDn for transformations)
    IF NOT (CURRENT_TOOL% = TOOL_TEXT AND TEXT.ACTIVE) THEN KEYBOARD_handle_custom_brush

    ' Shift+Delete = Set BG transparent (leave FG as-is)
    STATIC shiftDelBgPressed AS INTEGER
    IF NOT (CURRENT_TOOL% = TOOL_TEXT AND TEXT.ACTIVE) AND MODIFIERS.shift% AND NOT MODIFIERS.ctrl% AND NOT MODIFIERS.alt% AND _KEYDOWN(KEY_DELETE&) THEN
        IF NOT shiftDelBgPressed% THEN
            PAL_BG_IS_TRANSPARENT% = TRUE
            PAINT_BG_COLOR~& = _RGBA32(0, 0, 0, 0)
            GUI_NEEDS_REDRAW% = TRUE
            FRAME_IDLE% = FALSE
            shiftDelBgPressed% = TRUE
        END IF
    ELSEIF NOT _KEYDOWN(KEY_DELETE&) THEN
        shiftDelBgPressed% = FALSE
    END IF

    ' Ctrl+D = Reset FG to white, BG to black
    STATIC ctrlDPressed AS INTEGER
    IF NOT (CURRENT_TOOL% = TOOL_TEXT AND TEXT.ACTIVE) AND MODIFIERS.ctrl% AND NOT MODIFIERS.shift% AND NOT MODIFIERS.alt% AND _KEYDOWN(100) THEN
        IF NOT ctrlDPressed% THEN
            PAL_FG_IS_TRANSPARENT% = FALSE
            PAINT_COLOR~& = _RGB32(255, 255, 255)
            PAL_FG_IDX% = PAL_find_index%(_RGB32(255, 255, 255))
            IF PAL_FG_IDX% < 0 THEN PAL_FG_IDX% = 0
            PAL_BG_IS_TRANSPARENT% = FALSE
            PAINT_BG_COLOR~& = _RGB32(0, 0, 0)
            PAL_BG_IDX% = PAL_find_index%(_RGB32(0, 0, 0))
            IF PAL_BG_IDX% < 0 THEN PAL_BG_IDX% = 0
            GUI_NEEDS_REDRAW% = TRUE
            FRAME_IDLE% = FALSE
            ctrlDPressed% = TRUE
        END IF
    ELSEIF NOT _KEYDOWN(100) THEN
        ctrlDPressed% = FALSE
    END IF

    ' If text tool is active and editing, block ALL other keyboard processing except text input
    IF keypress$ = "" THEN keypress$ = INKEY$
    ' Fallback: if INKEY$ was empty, try _KEYHIT-derived character
    IF keypress$ = "" AND KEYHIT_CHAR$ <> "" THEN keypress$ = KEYHIT_CHAR$
    IF KEYBOARD_handle_text_tool%(keypress$) THEN EXIT SUB
    IF keypress$ <> "" THEN
        ' Handle ? for command palette with search (before other processing)
        IF keypress$ = "?" THEN
            CMD_show_palette
        ELSE
            KEYBOARD_colors keypress$
            KEYBOARD_tools keypress$
            KEYBOARD_brush_size keypress$
            KEYBOARD_assistants keypress$
            ' Music track controls ( { = Prev Track, } = Next Track )
            IF CFG.MUSIC_ENABLED% THEN
                SELECT CASE keypress$
                    CASE "{"
                        CMD_execute_action 428
                        FRAME_IDLE% = FALSE
                    CASE "}"
                        CMD_execute_action 427
                        FRAME_IDLE% = FALSE
                END SELECT
            END IF
        END IF
    END IF
    
    ' Note: KEYBOARD_layers is called at the TOP of this sub before any EXIT SUB statements
    
    ' Handle function keys F1-F8 (uses _KEYDOWN, must run unconditionally)
    KEYBOARD_handle_function_keys
    
    ' Handle UI toggle keys (extracted for clarity)
    KEYBOARD_handle_ui_toggles
    
    ' Handle DELETE and BACKSPACE keys (extracted for clarity)
    KEYBOARD_handle_delete_backspace
    
    ' Handle grid control keys (extracted for clarity)
    KEYBOARD_handle_grid_controls
    
    ' Handle marquee tool arrow keys (extracted for clarity)
    KEYBOARD_handle_marquee_keys

    ' Handle marquee expand/contract chords: M+= / M+- / M+Shift+= / M+Shift+-
    KEYBOARD_handle_marquee_expand_contract

    ' Handle MOVE tool arrow keys (extracted for clarity)
    KEYBOARD_handle_move_keys
    
    ' Handle clipboard, selection, and undo operations (extracted for clarity)
    KEYBOARD_handle_clipboard_operations
    
    ' Handle file operations (extracted for clarity)
    KEYBOARD_handle_file_operations

    ' Handle ALT+1-0 recent file shortcuts
    KEYBOARD_handle_recent_files

    ' Handle zoom shortcuts (extracted for clarity)
    KEYBOARD_handle_zoom_shortcuts
    
    ' Handle layer navigation and merge shortcuts (extracted for clarity)
    KEYBOARD_handle_layer_shortcuts
END SUB


''
' Handle ALT+1-0 shortcuts to open recent files (1=slot 1, 0=slot 10)
'
SUB KEYBOARD_handle_recent_files ()
    IF NOT MODIFIERS.alt% THEN EXIT SUB
    IF MODIFIERS.ctrl% THEN EXIT SUB
    IF MODIFIERS.shift% THEN EXIT SUB

    STATIC rfLast(0 TO 9) AS INTEGER
    DIM rfIdx AS INTEGER
    DIM rfNow AS INTEGER
    DIM rfSlot AS INTEGER
    DIM rfPath AS STRING
    DIM rfMsg AS INTEGER
    DIM rfKey AS INTEGER
    DIM rfKeyCodes(0 TO 9) AS INTEGER
    rfKeyCodes%(0) = 49  ' '1'
    rfKeyCodes%(1) = 50  ' '2'
    rfKeyCodes%(2) = 51  ' '3'
    rfKeyCodes%(3) = 52  ' '4'
    rfKeyCodes%(4) = 53  ' '5'
    rfKeyCodes%(5) = 54  ' '6'
    rfKeyCodes%(6) = 55  ' '7'
    rfKeyCodes%(7) = 56  ' '8'
    rfKeyCodes%(8) = 57  ' '9'
    rfKeyCodes%(9) = 48  ' '0' = slot 10

    FOR rfIdx% = 0 TO 9
        rfKey% = rfKeyCodes%(rfIdx%)
        rfNow% = _KEYDOWN(rfKey%)
        IF rfNow% AND NOT rfLast%(rfIdx%) THEN
            rfSlot% = rfIdx% + 1
            IF rfKey% = 48 THEN rfSlot% = 10
            IF rfSlot% <= RECENT_FILE_COUNT% THEN
                rfPath$ = RECENT_FILES(rfSlot%)
                IF rfPath$ <> "" THEN
                    IF NOT _FILEEXISTS(rfPath$) THEN
                        rfMsg% = _MESSAGEBOX("File Not Found", "File not found:" + CHR$(10) + rfPath$ + CHR$(10) + CHR$(10) + "Remove from recent files?", "yesno", "warning", 0)
                        DO WHILE _MOUSEINPUT: LOOP
                        MOUSE_force_buttons_up
                        IF rfMsg% = 1 THEN
                            DIM rfi AS INTEGER
                            FOR rfi% = rfSlot% TO RECENT_FILE_COUNT% - 1
                                RECENT_FILES(rfi%) = RECENT_FILES(rfi% + 1)
                            NEXT rfi%
                            RECENT_FILES(RECENT_FILE_COUNT%) = ""
                            RECENT_FILE_COUNT% = RECENT_FILE_COUNT% - 1
                            CONFIG_save
                        END IF
                    ELSE
                        IF CANVAS_DIRTY% THEN
                            rfMsg% = _MESSAGEBOX("Unsaved Changes", "Save changes before opening?", "yesnocancel", "warning", 0)
                            DO WHILE _MOUSEINPUT: LOOP
                            MOUSE_force_buttons_up
                            IF rfMsg% = 0 THEN
                                rfLast%(rfIdx%) = rfNow%
                                MENU_BAR.altTapped% = FALSE
                                MENU_BAR.altWasDown% = FALSE
                                EXIT SUB
                            END IF
                            IF rfMsg% = 1 THEN
                                IF LEN(CURRENT_DRW_FILENAME$) > 0 THEN
                                    DRW_save_binary CURRENT_DRW_FILENAME$
                                ELSE
                                    DRW_save_dialog
                                END IF
                            END IF
                        END IF
                        DRW_load rfPath$
                        CURRENT_DRW_FILENAME$ = rfPath$
                        CURRENT_FILENAME$ = rfPath$
                        RECENT_add_file rfPath$
                        CFG.LAST_DIR_OPEN$ = CONFIG_extract_dir$(rfPath$)
                        CANVAS_DIRTY% = FALSE
                    END IF
                    MENU_BAR.altTapped% = FALSE
                    MENU_BAR.altWasDown% = FALSE
                END IF
            END IF
        END IF
        rfLast%(rfIdx%) = rfNow%
    NEXT rfIdx%
END SUB


''
' Post-render keyboard input processing loop
'
SUB KEYBOARD_input_handler_loop ()
    DIM k AS LONG
    k& = _KEYHIT
    DO WHILE k& <> 0
        k& = _KEYHIT
    LOOP
    
    ' === ALT+O / ALT+X: Open .DRAW project file / Exit (ALT-only, no CTRL) ===
    STATIC DRW_KEY_O_LAST AS INTEGER
    DIM drwIsAlt AS INTEGER, drwIsCtrl AS INTEGER
    DIM drwKeyONow AS INTEGER
    
    drwIsAlt% = MODIFIERS.alt%
    drwIsCtrl% = MODIFIERS.ctrl%
    drwKeyONow% = _KEYDOWN(111)
    
    ' ALT+O (no CTRL): Open .draw project
    IF drwIsAlt% AND NOT drwIsCtrl% AND drwKeyONow% AND NOT DRW_KEY_O_LAST% THEN
        DRW_open_dialog
        ' Reset ALT tap state so menu bar doesn't open after dialog returns
        MENU_BAR.altTapped% = FALSE
        MENU_BAR.altWasDown% = FALSE
    END IF
    
    ' ALT+X (no CTRL): Exit application
    STATIC DRW_KEY_X_LAST AS INTEGER
    DIM drwKeyXNow AS INTEGER
    drwKeyXNow% = _KEYDOWN(120) OR _KEYDOWN(88)  ' lowercase x or uppercase X
    IF drwIsAlt% AND NOT drwIsCtrl% AND drwKeyXNow% AND NOT DRW_KEY_X_LAST% THEN
        CMD_execute_action 212
        MENU_BAR.altTapped% = FALSE
        MENU_BAR.altWasDown% = FALSE
    END IF
    DRW_KEY_X_LAST% = drwKeyXNow%
    
    DRW_KEY_O_LAST% = drwKeyONow%
END SUB


''
' Handle layer-related keyboard shortcuts
' 
SUB KEYBOARD_layers ()
    DIM isCtrl AS INTEGER, isShift AS INTEGER, isAlt AS INTEGER
    STATIC layerCtrlTabPressed AS INTEGER
    STATIC layerCtrlShiftNPressed AS INTEGER
    STATIC layerCtrlDPressed AS INTEGER
    STATIC layerCtrlShiftRPressed AS INTEGER
    STATIC layerCtrlBracketLPressed AS INTEGER
    STATIC layerCtrlBracketRPressed AS INTEGER
    STATIC layerCtrlShiftBracketLPressed AS INTEGER
    STATIC layerCtrlShiftBracketRPressed AS INTEGER
    STATIC layerCtrlShiftDelPressed AS INTEGER
    
    isCtrl% = MODIFIERS.ctrl%
    isShift% = MODIFIERS.shift%
    isAlt% = MODIFIERS.alt%
    
    ' CTRL+L: Toggle layer panel visibility
    IF isCtrl% AND (_KEYDOWN(ASC("l")) OR _KEYDOWN(ASC("L"))) AND NOT isShift% AND NOT isAlt% THEN
        IF NOT layerCtrlTabPressed% THEN
            LAYER_PANEL.visible% = NOT LAYER_PANEL.visible%
            SCRN.layerPanelManuallyHidden% = NOT LAYER_PANEL.visible%
            INVALIDATE_scene
            layerCtrlTabPressed% = TRUE
        END IF
    ELSEIF NOT _KEYDOWN(ASC("l")) AND NOT _KEYDOWN(ASC("L")) THEN
        layerCtrlTabPressed% = FALSE
    END IF
    
    ' CTRL+SHIFT+N: New layer
    IF isCtrl% AND isShift% AND (_KEYDOWN(110) OR _KEYDOWN(78)) THEN
        IF NOT layerCtrlShiftNPressed% THEN
            DIM newLayerIdx AS INTEGER
            newLayerIdx% = LAYERS_new%
            layerCtrlShiftNPressed% = TRUE
        END IF
    ELSEIF NOT _KEYDOWN(110) AND NOT _KEYDOWN(78) THEN
        layerCtrlShiftNPressed% = FALSE
    END IF
    
    ' CTRL+SHIFT+Delete: Delete current layer
    IF isCtrl% AND isShift% AND _KEYDOWN(21248) THEN
        IF NOT layerCtrlShiftDelPressed% THEN
            LAYERS_delete CURRENT_LAYER%
            layerCtrlShiftDelPressed% = TRUE
        END IF
    ELSEIF NOT _KEYDOWN(21248) THEN
        layerCtrlShiftDelPressed% = FALSE
    END IF
    
    ' CTRL+SHIFT+D: Duplicate layer
    IF isCtrl% AND isShift% AND (_KEYDOWN(100) OR _KEYDOWN(68)) THEN
        IF NOT layerCtrlDPressed% THEN
            LAYERS_duplicate CURRENT_LAYER%
            layerCtrlDPressed% = TRUE
        END IF
    ELSEIF NOT _KEYDOWN(100) AND NOT _KEYDOWN(68) THEN
        layerCtrlDPressed% = FALSE
    END IF
    
    ' CTRL+SHIFT+R: Rename layer
    IF isCtrl% AND isShift% AND (_KEYDOWN(114) OR _KEYDOWN(82)) THEN
        IF NOT layerCtrlShiftRPressed% THEN
            LAYERS_rename CURRENT_LAYER%
            layerCtrlShiftRPressed% = TRUE
        END IF
    ELSEIF NOT _KEYDOWN(114) AND NOT _KEYDOWN(82) THEN
        layerCtrlShiftRPressed% = FALSE
    END IF
    
    ' CTRL+PgUp: Move layer up in stack
    IF isCtrl% AND NOT isShift% AND _KEYDOWN(18688) THEN
        IF NOT layerCtrlBracketLPressed% THEN
            LAYERS_move_up CURRENT_LAYER%
            layerCtrlBracketLPressed% = TRUE
        END IF
    ELSEIF NOT _KEYDOWN(18688) THEN
        layerCtrlBracketLPressed% = FALSE
    END IF
    
    ' CTRL+PgDn: Move layer down in stack
    IF isCtrl% AND NOT isShift% AND _KEYDOWN(20736) THEN
        IF NOT layerCtrlBracketRPressed% THEN
            LAYERS_move_down CURRENT_LAYER%
            layerCtrlBracketRPressed% = TRUE
        END IF
    ELSEIF NOT _KEYDOWN(20736) THEN
        layerCtrlBracketRPressed% = FALSE
    END IF
    
    ' CTRL+SHIFT+[: Move layer to bottom
    IF isCtrl% AND isShift% AND _KEYDOWN(123) THEN
        IF NOT layerCtrlShiftBracketLPressed% THEN
            LAYERS_to_bottom CURRENT_LAYER%
            layerCtrlShiftBracketLPressed% = TRUE
        END IF
    ELSE
        layerCtrlShiftBracketLPressed% = FALSE
    END IF
    
    ' CTRL+SHIFT+]: Move layer to top
    IF isCtrl% AND isShift% AND _KEYDOWN(125) THEN
        IF NOT layerCtrlShiftBracketRPressed% THEN
            LAYERS_to_top CURRENT_LAYER%
            layerCtrlShiftBracketRPressed% = TRUE
        END IF
    ELSE
        layerCtrlShiftBracketRPressed% = FALSE
    END IF
    
    ' CTRL+Home: Arrange layer to top
    STATIC layerCtrlHomePressed AS INTEGER
    IF isCtrl% AND NOT isShift% AND _KEYDOWN(18176) THEN
        IF NOT layerCtrlHomePressed% THEN
            LAYERS_to_top CURRENT_LAYER%
            layerCtrlHomePressed% = TRUE
        END IF
    ELSEIF NOT _KEYDOWN(18176) THEN
        layerCtrlHomePressed% = FALSE
    END IF
    
    ' CTRL+End: Arrange layer to bottom
    STATIC layerCtrlEndPressed AS INTEGER
    IF isCtrl% AND NOT isShift% AND _KEYDOWN(20224) THEN
        IF NOT layerCtrlEndPressed% THEN
            LAYERS_to_bottom CURRENT_LAYER%
            layerCtrlEndPressed% = TRUE
        END IF
    ELSEIF NOT _KEYDOWN(20224) THEN
        layerCtrlEndPressed% = FALSE
    END IF

    ' Ctrl+Alt+E: Merge layer down
    ' MUST be here (not in KEYBOARD_handle_layer_shortcuts) so Alt does not
    ' trigger the menubar and block the hotkey via EXIT SUB.
    STATIC layerCtrlAltEPressed AS INTEGER
    IF isCtrl% AND isAlt% AND NOT isShift% AND _KEYDOWN(101) THEN
        IF NOT layerCtrlAltEPressed% THEN
            LAYERS_merge_down CURRENT_LAYER%
            layerCtrlAltEPressed% = TRUE
        END IF
    ELSEIF NOT _KEYDOWN(101) THEN
        layerCtrlAltEPressed% = FALSE
    END IF

    ' Ctrl+Alt+Shift+E: Merge all visible layers
    ' MUST be here (not in KEYBOARD_handle_layer_shortcuts) so Alt does not
    ' trigger the menubar and block the hotkey via EXIT SUB.
    STATIC layerCtrlAltShiftEPressed AS INTEGER
    IF isCtrl% AND isShift% AND isAlt% AND (_KEYDOWN(69) OR _KEYDOWN(101)) THEN
        IF NOT layerCtrlAltShiftEPressed% THEN
            _LOGINFO "MERGE_VISIBLE: triggered (ctrl=" + STR$(isCtrl%) + " shift=" + STR$(isShift%) + " alt=" + STR$(isAlt%) + " kd69=" + STR$(_KEYDOWN(69)) + " kd101=" + STR$(_KEYDOWN(101)) + ")"
            LAYERS_merge_visible
            layerCtrlAltShiftEPressed% = TRUE
        END IF
    ELSEIF NOT (_KEYDOWN(69) OR _KEYDOWN(101)) THEN
        layerCtrlAltShiftEPressed% = FALSE
    END IF
END SUB


''
' Handle keyboard input during reference image reposition mode.
' Returns TRUE if input was consumed (caller should EXIT SUB).
' @return INTEGER - TRUE if reposition mode consumed the key event
'
FUNCTION KEYBOARD_handle_refimg_reposition% ()
    IF NOT REFIMG.REPOSITION THEN
        KEYBOARD_handle_refimg_reposition% = FALSE
        EXIT FUNCTION
    END IF

    DIM keypress AS STRING
    keypress$ = INKEY$
    IF keypress$ <> "" THEN
        DIM kc AS INTEGER
        kc% = ASC(keypress$)
        
        SELECT CASE kc%
            CASE 27  ' ESC - cancel reposition (restore original position? no — just exit mode)
                REFIMG_reposition_finish
            CASE 13  ' ENTER - confirm reposition
                REFIMG_reposition_finish
        END SELECT
    END IF
    
    ' Arrow keys for fine positioning
    STATIC refKeyUpLast AS INTEGER, refKeyDownLast AS INTEGER
    STATIC refKeyLeftLast AS INTEGER, refKeyRightLast AS INTEGER
    DIM refStep AS INTEGER
    refStep% = 1
    IF MODIFIERS.shift% THEN refStep% = 10
    
    DIM refKeyUp AS INTEGER, refKeyDown AS INTEGER
    DIM refKeyLeft AS INTEGER, refKeyRight AS INTEGER
    refKeyUp% = _KEYDOWN(18432)
    refKeyDown% = _KEYDOWN(20480)
    refKeyLeft% = _KEYDOWN(19200)
    refKeyRight% = _KEYDOWN(19712)
    
    IF refKeyUp% AND NOT refKeyUpLast% THEN
        REFIMG.POS_Y = REFIMG.POS_Y - refStep%
        SCENE_DIRTY% = TRUE
    END IF
    IF refKeyDown% AND NOT refKeyDownLast% THEN
        REFIMG.POS_Y = REFIMG.POS_Y + refStep%
        SCENE_DIRTY% = TRUE
    END IF
    IF refKeyLeft% AND NOT refKeyLeftLast% THEN
        REFIMG.POS_X = REFIMG.POS_X - refStep%
        SCENE_DIRTY% = TRUE
    END IF
    IF refKeyRight% AND NOT refKeyRightLast% THEN
        REFIMG.POS_X = REFIMG.POS_X + refStep%
        SCENE_DIRTY% = TRUE
    END IF
    
    refKeyUpLast% = refKeyUp%
    refKeyDownLast% = refKeyDown%
    refKeyLeftLast% = refKeyLeft%
    refKeyRightLast% = refKeyRight%
    
    KEYBOARD_handle_refimg_reposition% = TRUE  ' Consumed
END FUNCTION


''
' Hold E = temporary eraser (restores previous tool on release)
' Tap E  = permanently switch to eraser tool
'
' Uses _KEYDOWN for physical key state tracking. Must be called every frame
' before any EXIT SUB statements in KEYBOARD_input_handler.
'
SUB KEYBOARD_handle_eraser_hold ()
    CONST E_KEY_CODE = 101           ' physical 'e' keycode for _KEYDOWN
    CONST E_HOLD_THRESHOLD = 0.18    ' seconds to distinguish hold vs tap

    STATIC eHeld        AS INTEGER   ' E key is currently down
    STATIC eTempMode    AS INTEGER   ' currently in temporary eraser mode
    STATIC ePressTime   AS DOUBLE    ' TIMER value when E was first pressed
    STATIC ePreTool     AS INTEGER   ' tool to restore when temp mode ends

    ' Skip when modifiers are held (CTRL+E = clear selection, etc.)
    ' or when text tool is active (E should type text)
    ' or when command palette is open (E should search)
    IF MODIFIERS.ctrl% OR MODIFIERS.alt% THEN EXIT SUB
    IF CURRENT_TOOL% = TOOL_TEXT THEN EXIT SUB
    IF CMD_PALETTE.visible THEN EXIT SUB
    ' When magic wand is active, hold-E at click time triggers flood erase —
    ' suppress eraser-hold logic so the key stays available for that modifier behavior
    IF CURRENT_TOOL% = TOOL_MARQUEE AND MARQUEE.MAGIC_WAND_MODE THEN EXIT SUB

    DIM eIsDown AS INTEGER
    eIsDown% = _KEYDOWN(E_KEY_CODE)

    IF eIsDown% THEN
        IF NOT eHeld% THEN
            ' --- Key just went down ---
            eHeld% = TRUE
            eTempMode% = FALSE
            ePressTime# = TIMER
            ' Save current tool so we can restore it on release
            IF CURRENT_TOOL% <> TOOL_ERASER THEN
                ePreTool% = CURRENT_TOOL%
            ELSE
                ePreTool% = PREVIOUS_TOOL%
            END IF
        ELSEIF NOT eTempMode% THEN
            ' --- Key still held, check threshold ---
            DIM elapsed AS DOUBLE
            elapsed# = TIMER - ePressTime#
            IF elapsed# < 0 THEN elapsed# = elapsed# + 86400  ' midnight wrap
            IF elapsed# >= E_HOLD_THRESHOLD THEN
                ' Hold detected: engage temporary eraser
                eTempMode% = TRUE
                PREVIOUS_TOOL% = ePreTool%
                CURRENT_TOOL% = TOOL_ERASER
                TOOLS_reset_all FALSE
                ERASER_activate
                INVALIDATE_scene
            END IF
        END IF
    ELSE
        IF eHeld% THEN
            ' --- Key just released ---
            IF eTempMode% THEN
                ' Was in temporary mode: restore previous tool
                ERASER_deactivate
                IF ePreTool% <> TOOL_NULL AND ePreTool% <> TOOL_ERASER THEN
                    CURRENT_TOOL% = ePreTool%
                ELSE
                    CURRENT_TOOL% = TOOL_BRUSH
                END IF
                PREVIOUS_TOOL% = TOOL_ERASER
                TOOLS_reset_all FALSE
                eTempMode% = FALSE
            ELSE
                ' Was a quick tap: permanently switch to eraser
                IF CURRENT_TOOL% <> TOOL_ERASER THEN
                    PREVIOUS_TOOL% = ePreTool%
                END IF
                CMD_execute_action 118
            END IF
            eHeld% = FALSE
            INVALIDATE_scene
        END IF
    END IF
END SUB